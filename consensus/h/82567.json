{"members":[{"header_text":" مُحَمَّدُ بْنُ مَسْعُودٍ اَلْعَيَّاشِيُّ فِي  تَفْسِيرِهِ عَنْ  أَيُّوبَ بْنِ نُوحِ بْنِ دَرَّاجٍ قَالَ:","body_text":"سَاَلْتُ اَبَا الْحَسَنِ الثَّالِثَ عَلَيْهِ السَّلاَمُ عَنِ الْجَامُوسِ وَ اَعْلَمْتُهُ اَنَّ اَهْلَ الْعِرَاقِ يَقُولُونَ اِنَّهُ مَسْخٌ فَقَالَ اَ وَ مَا سَمِعْتَ قَوْلَ اللَّهِ <quranic_text>«وَ مِنَ الْاِبِلِ اِثْنَيْنِ وَ مِنَ الْبَقَرِ اِثْنَيْنِ»</quranic_text> <footnote>[الانعام۱۴۴]</footnote> .","translation":"","aligned_body":"سَاَلْتُ اَبَا الْحَسَنِ الثَّالِثَ عَلَيْهِ السَّلاَمُ عَنِ الْجَامُوسِ وَ اَعْلَمْتُهُ اَنَّ اَهْلَ الْعِرَاقِ يَقُولُونَ اِنَّهُ مَسْخٌ فَقَالَ اَ وَ مَا سَمِعْتَ قَوْلَ اللَّهِ TAG_OPEN:quranic_text وَ مِنَ الْاِبِلِ اِثْنَيْنِ وَ مِنَ الْبَقَرِ اِثْنَيْنِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۱۴۴ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"الثالث","display":"الثَّالِثَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الجاموس","display":"الْجَامُوسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعلمته","display":"اَعْلَمْتُهُ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"العراق","display":"الْعِرَاقِ"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"مسخ","display":"مَسْخٌ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"سمعت","display":"سَمِعْتَ"},{"kind":"word","token":"قول","display":"قَوْلَ"},{"kind":"word","token":"الله","displa