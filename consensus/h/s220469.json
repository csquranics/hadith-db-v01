{"members":[{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> أَنَّهُ قَالَ:","body_text":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«فَمَنْ عُفِيَ لَهُ مِنْ اَخِيهِ شَيْءٌ»</quranic_text> <footnote>[البقرة۱۷۸]</footnote> الْايَةَ قَالَ هُوَ الرَّجُلُ يَقْبَلُ الدِّيَةَ فَاَمَرَ اللَّهُ عَزَّ وَ جَلَّ الَّذِي لَهُ الْحَقُّ اَنْ يَتَّبِعَهُ بِمَعْرُوفٍ وَ لاَ يُعْسِرَهُ وَ اَمَرَ الَّذِي عَلَيْهِ الْحَقُّ اَنْ لاَ يَظْلِمَهُ [وَ اَنْ] يُؤَدِّيَ اِلَيْهِ بِاِحْسَانٍ.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text فَمَنْ عُفِيَ لَهُ مِنْ اَخِيهِ شَيْءٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۷۸ TAG_CLOSE:footnote الْايَةَ قَالَ هُوَ الرَّجُلُ يَقْبَلُ الدِّيَةَ فَاَمَرَ اللَّهُ عَزَّ وَ جَلَّ الَّذِي لَهُ الْحَقُّ اَنْ يَتَّبِعَهُ بِمَعْرُوفٍ وَ لاَ يُعْسِرَهُ وَ اَمَرَ الَّذِي عَلَيْهِ الْحَقُّ اَنْ لاَ يَظْلِمَهُ وَ اَنْ يُؤَدِّيَ اِلَيْهِ بِاِحْسَانٍ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"عفي","display":"عُفِيَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اخيه","display":"اَخِيهِ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۷۸","display":"۱۷۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ