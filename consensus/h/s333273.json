{"members":[{"header_text":" وَ أَسْنَدَ  اِبْنُ جَبْرٍ فِي  نُخَبِهِ إِلَى <teller> اَلْبَاقِرِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"قَوْلَ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لِعَلِيٍّ <quranic_text>«اِنَّ الَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ اُولٰئِكَ هُمْ خَيْرُ الْبَرِيَّةِ»</quranic_text> <footnote>[البينة۷]</footnote> اَنْتَ وَ شِيعَتُكَ شِبَاعاً مَرْوِيِّينَ وَ مِيعَادِي وَ مِيعَادُكُمْ الْحَوْضُ وَ اِذَا حُشِرَ النَّاسُ جِئْتَ اَنْتَ وَ شِيعَتُكَ شِبَاعاً مَرْوِيِّينَ غُرّاً مُحَجَّلِينَ.","translation":"","aligned_body":"قَوْلَ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لِعَلِيٍّ TAG_OPEN:quranic_text اِنَّ الَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ اُولٰئِكَ هُمْ خَيْرُ الْبَرِيَّةِ TAG_CLOSE:quranic_text TAG_OPEN:footnote البينة ۷ TAG_CLOSE:footnote اَنْتَ وَ شِيعَتُكَ شِبَاعاً مَرْوِيِّينَ وَ مِيعَادِي وَ مِيعَادُكُمْ الْحَوْضُ وَ اِذَا حُشِرَ النَّاسُ جِئْتَ اَنْتَ وَ شِيعَتُكَ شِبَاعاً مَرْوِيِّينَ غُرّاً مُحَجَّلِينَ"}],"body_consensus_columns":[{"kind":"word","token":"قول","display":"قَوْلَ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"لعلي","display":"لِعَلِيٍّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عملوا","display":"عَمِلُوا"},{"kind":"word","token":"الصالحات","display":"الصّٰالِحٰاتِ"},{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"خير","display":"خَيْرُ"},{"kind":"word","token":"البريه","display":"الْبَرِيَّةِ"},{"kind":"tag_close","tag_name":"qur