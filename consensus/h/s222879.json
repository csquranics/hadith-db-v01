{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«كُلُّ مَنْ عَلَيْهٰا فٰانٍ وَ يَبْقيٰ وَجْهُ رَبِّكَ»</quranic_text> <footnote>[الرحمن۲۶]</footnote> قَالَ دِينُ رَبِّكَ وَ قَالَ عَلِيُّ بْنُ الْحُسَيْنِ عَلَيْهِ السَّلاَمُ نَحْنُ الْوَجْهُ الَّذِي يُؤْتَي اللَّهُ مِنْهُ.","translation":"","aligned_body":"TAG_OPEN:quranic_text كُلُّ مَنْ عَلَيْهٰا فٰانٍ وَ يَبْقيٰ وَجْهُ رَبِّكَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرحمن ۲۶ TAG_CLOSE:footnote قَالَ دِينُ رَبِّكَ وَ قَالَ عَلِيُّ بْنُ الْحُسَيْنِ عَلَيْهِ السَّلاَمُ نَحْنُ الْوَجْهُ الَّذِي يُؤْتَي اللَّهُ مِنْهُ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عليها","display":"عَلَيْهٰا"},{"kind":"word","token":"فان","display":"فٰانٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يبقي","display":"يَبْقيٰ"},{"kind":"word","token":"وجه","display":"وَجْهُ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرحمن","display":"الرحمن"},{"kind":"word","token":"۲۶","display":"۲۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"دين","display":"دِينُ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"الوجه","display":"الْوَجْهُ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يؤتي","display":"يُؤْتَي"