{"members":[{"header_text":" عَنْهُ عَنْ  يَعْقُوبَ بْنِ يَزِيدَ عَنْ  رَجُلٍ عَنِ  اَلْحَكَمِ بْنِ مِسْكِينٍ عَنْ  أَيُّوبَ بْنِ اَلْحُرِّ بَيَّاعِ اَلْهَرَوِيِّ قَالَ:","body_text":"قَالَ لِي اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ يَا اَيُّوبُ مَا مِنْ اَحَدٍ اِلاَّ وَ قَدْ بَرَزَ عَلَيْهِ الْحَقُّ حَتَّي يَصْدَعَ قَبِلَهُ اَمْ تَرَكَهُ وَ ذَلِكَ اَنَّ اللَّهَ يَقُولُ فِي كِتَابِهِ - <quranic_text>«بَلْ نَقْذِفُ بِالْحَقِّ عَلَي الْبٰاطِلِ فَيَدْمَغُهُ فَاِذٰا هُوَ زٰاهِقٌ وَ لَكُمُ الْوَيْلُ مِمّٰا تَصِفُونَ»</quranic_text> <footnote>[الانبياء۱۸]</footnote> .","translation":"","aligned_body":"قَالَ لِي اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ يَا اَيُّوبُ مَا مِنْ اَحَدٍ اِلاَّ وَ قَدْ بَرَزَ عَلَيْهِ الْحَقُّ حَتَّي يَصْدَعَ قَبِلَهُ اَمْ تَرَكَهُ وَ ذَلِكَ اَنَّ اللَّهَ يَقُولُ فِي كِتَابِهِ - TAG_OPEN:quranic_text بَلْ نَقْذِفُ بِالْحَقِّ عَلَي الْبٰاطِلِ فَيَدْمَغُهُ فَاِذٰا هُوَ زٰاهِقٌ وَ لَكُمُ الْوَيْلُ مِمّٰا تَصِفُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانبياء ۱۸ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ايوب","display":"اَيُّوبُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"احد","display":"اَحَدٍ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"برز","display":"بَرَزَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"الحق","display":"الْحَقُّ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"يص