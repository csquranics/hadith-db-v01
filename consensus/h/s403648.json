{"members":[{"header_text":" عَنْهُ: بِإِسْنَادِهِ عَنْ أَبِي عَبْدِ اَللَّهِ (عَلَيْهِ اَلسَّلاَمُ):","body_text":"فِي قَوْلِهِ عَزَّ وَ جَلَّ: <quranic_text>«وَ مَنْ دَخَلَهُ كٰانَ امِناً»</quranic_text> <footnote>[العمران۹۷]</footnote> . قَالَ: «فِي قَائِمِنَا اَهْلَ الْبَيْتِ، فَمَنْ بَايَعَهُ، وَ دَخَلَ مَعَهُ، وَ مَسَحَ عَلَي يَدِهِ، وَ دَخَلَ فِي عَقْدِ اَصْحَابِهِ، كَانَ امِناً».","translation":"","aligned_body":"فِي قَوْلِهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ مَنْ دَخَلَهُ كٰانَ امِناً TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۹۷ TAG_CLOSE:footnote قَالَ فِي قَائِمِنَا اَهْلَ الْبَيْتِ فَمَنْ بَايَعَهُ وَ دَخَلَ مَعَهُ وَ مَسَحَ عَلَي يَدِهِ وَ دَخَلَ فِي عَقْدِ اَصْحَابِهِ كَانَ امِناً"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"دخله","display":"دَخَلَهُ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"امنا","display":"امِناً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۹۷","display":"۹۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قائمنا","display":"قَائِمِنَا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"بايعه","display":"بَايَعَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"معه","display":"مَعَهُ"},{"kind":"