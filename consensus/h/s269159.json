{"members":[{"header_text":" وَ قَالَ عَلَيْهِ السَّلاَمُ:","body_text":"اَلزُّهْدُ كُلُّهُ فِي كَلِمَتَيْنِ مِنَ الْقُرْانِ قَالَ اللَّهُ تَعَالَي: <quranic_text>«لِكَيْلاٰ تَاْسَوْا عَليٰ مٰا فٰاتَكُمْ وَ لاٰ تَفْرَحُوا بِمٰا اتٰاكُمْ»</quranic_text> <footnote>[الحديد۲۳]</footnote> فَمَنْ لَمْ يَاْسَ عَلَي الْمَاضِي وَ لَمْ يَفْرَحْ بِالْاتِي فَهُوَ الزَّاهِدُ.","translation":"","aligned_body":"اَلزُّهْدُ كُلُّهُ فِي كَلِمَتَيْنِ مِنَ الْقُرْانِ قَالَ اللَّهُ تَعَالَي TAG_OPEN:quranic_text لِكَيْلاٰ تَاْسَوْا عَليٰ مٰا فٰاتَكُمْ وَ لاٰ تَفْرَحُوا بِمٰا اتٰاكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحديد ۲۳ TAG_CLOSE:footnote فَمَنْ لَمْ يَاْسَ عَلَي الْمَاضِي وَ لَمْ يَفْرَحْ بِالْاتِي فَهُوَ الزَّاهِدُ"}],"body_consensus_columns":[{"kind":"word","token":"الزهد","display":"اَلزُّهْدُ"},{"kind":"word","token":"كله","display":"كُلُّهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كلمتين","display":"كَلِمَتَيْنِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لكيلا","display":"لِكَيْلاٰ"},{"kind":"word","token":"تاسوا","display":"تَاْسَوْا"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"فاتكم","display":"فٰاتَكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تفرحوا","display":"تَفْرَحُوا"},{"kind":"word","token":"بما","display":"بِمٰا"},{"kind":"word","token":"اتاكم","display":"اتٰاكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحديد","display":"الحديد"},{"kind":"word","token":"۲۳","display":"۲۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word",