{"members":[{"header_text":" اَلْفَضْلُ بْنُ اَلْحَسَنِ اَلطَّبْرِسِيُّ فِي  مَجْمَعِ اَلْبَيَانِ : ","body_text":"فِي قَوْلِهِ تَعَالَي <quranic_text>«وَ مَتِّعُوهُنَّ عَلَي الْمُوسِعِ قَدَرُهُ وَ عَلَي الْمُقْتِرِ قَدَرُهُ»</quranic_text> <footnote>[البقرة۲۳۶]</footnote> قَالَ اِنَّمَا تَجِبُ الْمُتْعَةُ لِلَّتِي لَمْ يُسَمَّ لَهَا صَدَاقٌ خَاصَّةً وَ هُوَ الْمَرْوِيُّ عَنِ الْبَاقِرِ وَ الصَّادِقِ عَلَيْهِمَا السَّلاَمُ .","translation":"","aligned_body":"فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text وَ مَتِّعُوهُنَّ عَلَي الْمُوسِعِ قَدَرُهُ وَ عَلَي الْمُقْتِرِ قَدَرُهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۳۶ TAG_CLOSE:footnote قَالَ اِنَّمَا تَجِبُ الْمُتْعَةُ لِلَّتِي لَمْ يُسَمَّ لَهَا صَدَاقٌ خَاصَّةً وَ هُوَ الْمَرْوِيُّ عَنِ الْبَاقِرِ وَ الصَّادِقِ عَلَيْهِمَا السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"متعوهن","display":"مَتِّعُوهُنَّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الموسع","display":"الْمُوسِعِ"},{"kind":"word","token":"قدره","display":"قَدَرُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المقتر","display":"الْمُقْتِرِ"},{"kind":"word","token":"قدره","display":"قَدَرُهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۳۶","display":"۲۳۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"تجب","display":"تَجِبُ"},{"kind":"word","token":"المتعه","display":"الْمُتْعَةُ"},{"kind":"word","token":"للتي","display":"لِلَّتِي"},{"kind":"word","token":"ل