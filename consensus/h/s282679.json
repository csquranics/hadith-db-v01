{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«يَسْئَلُونَكَ عَنِ الْاَنْفٰالِ»</quranic_text> <footnote>[الانفال۱]</footnote> قَالَ نَزَلَتْ يَسْئَلُونَكَ الْاَنْفَالَ <quranic_text>«قُلِ الْاَنْفٰالُ لِلّٰهِ وَ الرَّسُولِ فَاتَّقُوا اللّٰهَ وَ اَصْلِحُوا ذٰاتَ بَيْنِكُمْ وَ اَطِيعُوا اللّٰهَ وَ رَسُولَهُ اِنْ كُنْتُمْ مُؤْمِنِينَ»</quranic_text> <footnote>[الانفال۱]</footnote> .","translation":"","aligned_body":"TAG_OPEN:quranic_text يَسْئَلُونَكَ عَنِ الْاَنْفٰالِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانفال ۱ TAG_CLOSE:footnote قَالَ نَزَلَتْ يَسْئَلُونَكَ الْاَنْفَالَ TAG_OPEN:quranic_text قُلِ الْاَنْفٰالُ لِلّٰهِ وَ الرَّسُولِ فَاتَّقُوا اللّٰهَ وَ اَصْلِحُوا ذٰاتَ بَيْنِكُمْ وَ اَطِيعُوا اللّٰهَ وَ رَسُولَهُ اِنْ كُنْتُمْ مُؤْمِنِينَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانفال ۱ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يسئلونك","display":"يَسْئَلُونَكَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الانفال","display":"الْاَنْفٰالِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"يسئلونك","display":"يَسْئَلُونَكَ"},{"kind":"word","token":"الانفال","display":"الْاَنْفَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلِ"},{"kind":"word","token":"الانفال","display":"الْاَنْفٰالُ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرسول","display":"الرَّسُولِ"},{"kind":"word","token":"فاتقوا","display":"فَاتَّقُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"و","display":"وَ"},{