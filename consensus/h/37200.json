{"members":[{"header_text":" مُحَمَّدُ بْنُ يَعْقُوبَ: عَنْ عَلِيِّ بْنِ إِبْرَاهِيمَ، عَنْ مُحَمَّدِ بْنِ عِيسَى، عَنْ يُونُسَ؛ وَ عَلِيُّ بْنُ مُحَمَّدٍ، عَنْ سَهْلِ بْنِ زِيَادٍ أَبِي سَعِيدٍ، عَنْ مُحَمَّدِ بْنِ عِيسَى، عَنْ يُونُسَ، عَنِ اِبْنِ مُسْكَانَ، عَنْ أَبِي بَصِيرٍ، عَنْ أَبِي عَبْدِ اَللَّهِ (عَلَيْهِ اَلسَّلاَمُ)، قَالَ:","body_text":"«اَلرِّجْسُ هُوَ الشَّكُّ، وَ اللَّهِ لاَ نَشُكُّ فِي رَبِّنَا اَبَداً». وَ عَنْهُ: عَنْ مُحَمَّدِ بْنِ يَحْيَي، عَنْ اَحْمَدَ بْنِ مُحَمَّدِ بْنِ عِيسَي، عَنْ مُحَمَّدِ بْنِ خَالِدٍ وَ الْحُسَيْنِ بْنِ سَعِيدٍ، عَنِ النَّضْرِ بْنِ سُوَيْدٍ، عَنْ يَحْيَي بْنِ عِمْرَانَ الْحَلَبِيِّ، عَنْ اَيُّوبَ بْنِ الْحُرِّ وَ عِمْرَانَ بْنِ عَلِيٍّ الْحَلَبِيِّ، عَنْ اَبِي بَصِيرٍ، عَنْ اَبِي عَبْدِ اللَّهِ (عَلَيْهِ السَّلاَمُ) مِثْلَ ذَلِكَ.","translation":"","aligned_body":"- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - اَلرِّجْسُ هُوَ الشَّكُّ وَ اللَّهِ لاَ نَشُكُّ فِي رَبِّنَا اَبَداً وَ عَنْهُ عَنْ مُحَمَّدِ بْنِ يَحْيَي عَنْ اَحْمَدَ بْنِ مُحَمَّدِ بْنِ عِيسَي عَنْ مُحَمَّدِ بْنِ خَالِدٍ وَ الْحُسَيْنِ بْنِ سَعِيدٍ عَنِ النَّضْرِ بْنِ سُوَيْدٍ عَنْ يَحْيَي بْنِ عِمْرَانَ الْحَلَبِيِّ عَنْ اَيُّوبَ بْنِ الْحُرِّ وَ عِمْرَانَ بْنِ عَلِيٍّ الْحَلَبِيِّ عَنْ اَبِي بَصِيرٍ عَنْ اَبِي عَبْدِ اللَّهِ - عَلَيْهِ السَّلاَمُ - مِثْلَ ذَلِكَ"},{"header_text":" عليّ بن إبراهيم، عن محمّد بن عيسى ، عن يونس و عليّ بن محمّد، عن سهل بن زياد. و أبي سعيد، عن محمّد بن عيسى[، عن يونس،] عن ابن مسكان، عن أبي بصير، عن أبي عبد اللّٰه - عليه السّلام - و ذكر حديثا طويلا. يقول فيه - عليه السّلام - حاكيا عن رسول اللّٰه - صلّى اللّٰه عليه و آله و سلم - و قال - عليه السّلام-:","body_text":"اوصيكم بكتاب اللّٰه و اهل بيتي، فانّي سالت اللّٰه - عزّ و جلّ - ان لا يفرّق بينهما حتّي يوردهما عليّ الخوض، فاعطاني ذلك. و قال: لا تعلّموهم، فانّهم اعلم منكم. و قال: انّهم لن يخرجوكم من باب هدي، و لن يدخلوكم في باب ضلالة. فلو سكت رسول اللّٰه - صلّي اللّٰه عليه و اله و سلم - و لم يبيّن من اهل بيته، لادّعاها ال فلان و ال فلان. و لكنّ اللّٰه - عزّ و جلّ - انزله في كتابه لنبيّه - صلّي اللّٰه عليه و اله و سلم- <quranic_text>«اِنَّمٰا يُرِيدُ اللّٰهُ لِيُذْهِبَ عَنْكُمُ الرِّجْسَ اَهْلَ الْبَيْتِ وَ يُطَهِّرَكُمْ تَطْهِيراً»</quranic_text> <footnote>[الاحزاب۳۳]</footnote> . و كان عليّ و الحسن و الحسين و فاطمة - عليهم السّلام - فادخلهم رسول اللّٰه - صلّي اللّٰه عليه و اله و سلم - تحت الكساء في بيت امّ سلمة، ثمّ قال: اللّهمّ انّ لكلّ نبيّ اهلا و ثقلا و هؤلاء اهل بيتي و ثقلي. فقالت امّ سلمة: ا لست من اهلك؟ فقال: انّك الي خير، و لكن هؤلاء اهلي و ثقلي. و في اخر الحديث و قال: «الرّجس» هو الشّكّ. و اللّٰه لا نشكّ في ربّنا ابدا. محمّد بن يحيي، عن احمد بن محمّد بن عيسي، عن محمّد بن خالد و الحسين بن سعيد، عن النّضر بن سويد، عن يحيي بن عمران الحلبيّ[، عن ايّوب بن الحرّ و عمران بن علّي الحلبّي،] عن ابي بصير، عن ابي عبد اللّٰه - عليه السّلام - مثل ذلك.","translation":"","aligned_body":"اوصيكم بكتاب اللّٰه و اهل بيتي فانّي سالت اللّٰه - عزّ و جلّ - ان لا يفرّق بينهما حتّي يوردهما عليّ الخوض فاعطاني ذلك و قال لا تعلّموهم فانّهم اعلم منكم و قال انّهم لن يخرجوكم من باب هدي و لن يدخلوكم في باب ضلالة فلو سكت رسول اللّٰه - صلّي اللّٰه عليه و اله و سلم - و لم يبيّن من اهل بيته لادّعاها ال فلان و ال فلان و لكنّ اللّٰه - عزّ و جلّ - انزله في كتابه لنبيّه - صلّي اللّٰه عليه و اله و سلم- TAG_OPEN:quranic_text اِنَّمٰا يُرِيدُ اللّٰهُ لِيُذْهِبَ عَنْكُمُ الرِّجْسَ اَهْلَ الْبَيْتِ وَ يُطَهِّرَكُمْ تَطْهِيراً TAG_CLOSE:quranic_text TAG_OPEN:footnote الاحزاب ۳۳ TAG_CLOSE:footnote و كان عليّ و الحسن و الحسين و فاطمة - عليهم السّلام - فادخلهم رسول اللّٰه - صلّي اللّٰه عليه و اله و سلم - تحت الكساء في بيت امّ سلمة ثمّ قال اللّهمّ انّ لكلّ نبيّ اهلا و ثقلا و هؤلاء اهل بيتي و ثقلي فقالت امّ سلمة ا لست من اهلك فقال انّك الي خير و لكن هؤلاء اهلي و ثقلي و في اخر الحديث و قال الرّجس هو الشّكّ و اللّٰه لا نشكّ في ربّنا ابدا - - - محمّد بن يحيي عن احمد بن محمّد بن عيسي عن محمّد بن خالد و الحسين بن سعيد عن النّضر بن سويد عن يحيي بن عمران الحلبيّ عن ايّوب بن الحرّ و عمران بن علّي الحلبّي عن ابي بصير عن ابي عبد اللّٰه - عليه السّلام - مثل ذلك"}],"body_consensus_columns":[{"kind":"word","token":"اوصيكم","display":"اوصيكم"},{"kind":"word","token":"بكتاب","display":"بكتاب"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اهل","display":"اهل"},{"kind":"word","token":"بيتي","display":"بيتي"},{"kind":"word","token":"فاني","display":"فانّي"},{"kind":"word","token":"سالت","display":"سالت"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عزّ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"جل","display":"جلّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"لا","display":"لا"},{"kind":"word","token":"يفرق","display":"يفرّق"},{"kind":"word","token":"بينهما","display":"بينهما"},{"kind":"word","token":"حتي","display":"حتّي"},{"kind":"word","token":"يوردهما","display":"يوردهما"},{"kind":"word","token":"علي","display":"عليّ"},{"kind":"word","token":"الخوض","display":"الخوض"},{"kind":"word","token":"فاعطاني","display":"فاعطاني"},{"kind":"word","token":"ذلك","display":"ذلك"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"لا","display":"لا"},{"kind":"word","token":"تعلموهم","display":"تعلّموهم"},{"kind":"word","token":"فانهم","display":"فانّهم"},{"kind":"word","token":"اعلم","display":"اعلم"},{"kind":"word","token":"منكم","display":"منكم"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"انهم","display":"انّهم"},{"kind":"word","token":"لن","display":"لن"},{"kind":"word","token":"يخرجوكم","display":"يخرج