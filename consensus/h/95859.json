{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«فَاِذٰا اُوذِيَ فِي اللّٰهِ»</quranic_text> <footnote>[العنكبوت۱۰]</footnote> اَيْ اِذَا اذَاهُ اِنْسَانٌ اَوْ اَصَابَهُ ضُرٌّ اَوْ فَاقَةٌ اَوْ خَوْفٌ مِنَ الظَّالِمِينَ دَخَلَ مَعَهُمْ فِي دِينِهِمْ فَرَاَي اَنَّ مَا يَفْعَلُونَهُ هُوَ مِثْلُ عَذَابِ اللَّهِ الَّذِي لاَ يَنْقَطِعُ.","translation":"","aligned_body":"TAG_OPEN:quranic_text فَاِذٰا اُوذِيَ فِي اللّٰهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote العنكبوت ۱۰ TAG_CLOSE:footnote اَيْ اِذَا اذَاهُ اِنْسَانٌ اَوْ اَصَابَهُ ضُرٌّ اَوْ فَاقَةٌ اَوْ خَوْفٌ مِنَ الظَّالِمِينَ دَخَلَ مَعَهُمْ فِي دِينِهِمْ فَرَاَي اَنَّ مَا يَفْعَلُونَهُ هُوَ مِثْلُ عَذَابِ اللَّهِ الَّذِي لاَ يَنْقَطِعُ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاذا","display":"فَاِذٰا"},{"kind":"word","token":"اوذي","display":"اُوذِيَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العنكبوت","display":"العنكبوت"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اذاه","display":"اذَاهُ"},{"kind":"word","token":"انسان","display":"اِنْسَانٌ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"اصابه","display":"اَصَابَهُ"},{"kind":"word","token":"ضر","display":"ضُرٌّ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"فاقه","display":"فَاقَةٌ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"خوف","display":"خَوْفٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الظالمين","display":"الظَّالِمِينَ"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"معهم","display":"مَعَهُمْ"},{"kind":"word","toke