{"members":[{"header_text":" وَ قَدْ رَوَى  نُوحُ بْنُ دَرَّاجٍ عَنْ  مُحَمَّدِ بْنِ مُسْلِمٍ عَنْ  حَبَّةَ اَلْعُرَنِيِّ قَالَ:","body_text":"سَمِعْتُ عَلِيّاً عَلَيْهِ السَّلاَمُ حِينَ بَرَزَ اَهْلُ الْجَمَلِ وَ هُوَ يَقُولُ وَ اللَّهِ لَقَدْ عَلِمَتْ صَاحِبَةُ الْهَوْدَجِ اَنَّ اَهْلَ الْجَمَلِ مَلْعُونُونَ عَلَي لِسَانِ النَّبِيِّ الْاُمِّيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ <quranic_text>«وَ قَدْ خٰابَ مَنِ اِفْتَريٰ»</quranic_text> <footnote>[طه۶۱]</footnote> .","translation":"","aligned_body":"سَمِعْتُ عَلِيّاً عَلَيْهِ السَّلاَمُ حِينَ بَرَزَ اَهْلُ الْجَمَلِ وَ هُوَ يَقُولُ وَ اللَّهِ لَقَدْ عَلِمَتْ صَاحِبَةُ الْهَوْدَجِ اَنَّ اَهْلَ الْجَمَلِ مَلْعُونُونَ عَلَي لِسَانِ النَّبِيِّ الْاُمِّيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ TAG_OPEN:quranic_text وَ قَدْ خٰابَ مَنِ اِفْتَريٰ TAG_CLOSE:quranic_text TAG_OPEN:footnote طه ۶۱ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"سمعت","display":"سَمِعْتُ"},{"kind":"word","token":"عليا","display":"عَلِيّاً"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"برز","display":"بَرَزَ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"الجمل","display":"الْجَمَلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"علمت","display":"عَلِمَتْ"},{"kind":"word","token":"صاحبه","display":"صَاحِبَةُ"},{"kind":"word","token":"الهودج","display":"الْهَوْدَجِ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"الجمل","display":"الْجَمَلِ"},{"kind":"word","token":"ملعونون","display":"مَلْعُونُونَ"},{"kind":"word","token":"علي","display":"عَ