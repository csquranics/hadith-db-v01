{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«هُوَ الَّذِي يُرِيكُمُ الْبَرْقَ خَوْفاً وَ طَمَعاً»</quranic_text> <footnote>[الرعد۱۲]</footnote> يَعْنِي يَخَافُهُ قَوْمٌ وَ يَطْمَعُ فِيهِ قَوْمٌ اَنْ يُمْطَرُوا <quranic_text>«وَ يُنْشِئُ السَّحٰابَ الثِّقٰالَ»</quranic_text> <footnote>[الرعد۱۲]</footnote> يَعْنِي يَرْفَعُهَا مِنَ الْاَرْضِ <quranic_text>«وَ يُسَبِّحُ الرَّعْدُ»</quranic_text> <footnote>[الرعد۱۳]</footnote> اَيِ الْمَلَكُ الَّذِي يَسُوقُ السَّحَابَ <quranic_text>«وَ هُوَ شَدِيدُ الْمِحٰالِ»</quranic_text> <footnote>[الرعد۱۳]</footnote> اَيْ شَدِيدُ الْغَضَبِ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text هُوَ الَّذِي يُرِيكُمُ الْبَرْقَ خَوْفاً وَ طَمَعاً TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۱۲ TAG_CLOSE:footnote يَعْنِي يَخَافُهُ قَوْمٌ وَ يَطْمَعُ فِيهِ قَوْمٌ اَنْ يُمْطَرُوا TAG_OPEN:quranic_text وَ يُنْشِئُ السَّحٰابَ الثِّقٰالَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۱۲ TAG_CLOSE:footnote يَعْنِي يَرْفَعُهَا مِنَ الْاَرْضِ TAG_OPEN:quranic_text وَ يُسَبِّحُ الرَّعْدُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۱۳ TAG_CLOSE:footnote اَيِ الْمَلَكُ الَّذِي يَسُوقُ السَّحَابَ TAG_OPEN:quranic_text وَ هُوَ شَدِيدُ الْمِحٰالِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۱۳ TAG_CLOSE:footnote اَيْ شَدِيدُ الْغَضَبِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يريكم","display":"يُرِيكُمُ"},{"kind":"word","token":"البرق","display":"الْبَرْقَ"},{"kind":"word","token":"خوفا","display":"خَوْفاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طمعا","display":"طَمَعاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۱۲","display":"۱۲"},{"k