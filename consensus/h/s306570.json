{"members":[{"header_text":" عَنْ  زُرَارَةَ عَنْ <teller> أَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ</teller> قَالَ: سَمِعْتُهُ يَقُولُ: ","body_text":" <quranic_text>«فَلَمّٰا اتٰاهُمٰا صٰالِحاً جَعَلاٰ لَهُ شُرَكٰاءَ فِيمٰا اتٰاهُمٰا»</quranic_text> <footnote>[الاعراف۱۹۰]</footnote> قَالَ: هُوَ ادَمُ وَ حَوَّاءُ اِنَّمَا كَانَ شِرْكُهُمَا شِرْكَ طَاعَةٍ وَ لَيْسَ شِرْكَ عِبَادَةٍ، وَ فِي رِوَايَةٍ اُخْرَي وَ لَمْ يَكُنْ شِرْكَ عِبَادَةٍ.","translation":"","aligned_body":"TAG_OPEN:quranic_text فَلَمّٰا اتٰاهُمٰا صٰالِحاً جَعَلاٰ لَهُ شُرَكٰاءَ فِيمٰا اتٰاهُمٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الاعراف ۱۹۰ TAG_CLOSE:footnote قَالَ هُوَ ادَمُ وَ حَوَّاءُ اِنَّمَا كَانَ شِرْكُهُمَا شِرْكَ طَاعَةٍ وَ لَيْسَ شِرْكَ عِبَادَةٍ وَ فِي رِوَايَةٍ اُخْرَي وَ لَمْ يَكُنْ شِرْكَ عِبَادَةٍ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلما","display":"فَلَمّٰا"},{"kind":"word","token":"اتاهما","display":"اتٰاهُمٰا"},{"kind":"word","token":"صالحا","display":"صٰالِحاً"},{"kind":"word","token":"جعلا","display":"جَعَلاٰ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"شركاء","display":"شُرَكٰاءَ"},{"kind":"word","token":"فيما","display":"فِيمٰا"},{"kind":"word","token":"اتاهما","display":"اتٰاهُمٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۹۰","display":"۱۹۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ادم","display":"ادَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حواء","display":"حَوَّاءُ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"شركهما","display":"شِرْكُهُمَا"},{"kind":"word","token":"شرك","display":"شِرْكَ"},{"kind":"word","token":"طاعه","display":"طَاعَ