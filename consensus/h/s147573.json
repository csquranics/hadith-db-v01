{"members":[{"header_text":" مُحَمَّدُ بْنُ يَعْقُوبَ عَنْ  عَلِيِّ بْنِ إِبْرَاهِيمَ عَنْ  أَبِيهِ عَنْ  حَمَّادٍ عَنْ  حَرِيزٍ عَنْ  مُحَمَّدِ بْنِ مُسْلِمٍ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«وَ اُذْكُرُوا اللّٰهَ فِي اَيّٰامٍ مَعْدُودٰاتٍ»</quranic_text> <footnote>[البقرة۲۰۳]</footnote> فَقَالَ التَّكْبِيرُ فِي اَيَّامِ التَّشْرِيقِ مِنْ صَلاَةِ الظُّهْرِ وَ مَنْ اَقَامَ بِمِنًي فَصَلَّي بِهَا الظُّهْرَ وَ الْعَصْرَ فَلْيُكَبِّرْ.","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ اُذْكُرُوا اللّٰهَ فِي اَيّٰامٍ مَعْدُودٰاتٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۰۳ TAG_CLOSE:footnote فَقَالَ التَّكْبِيرُ فِي اَيَّامِ التَّشْرِيقِ مِنْ صَلاَةِ الظُّهْرِ وَ مَنْ اَقَامَ بِمِنًي فَصَلَّي بِهَا الظُّهْرَ وَ الْعَصْرَ فَلْيُكَبِّرْ"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذكروا","display":"اُذْكُرُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ايام","display":"اَيّٰامٍ"},{"kind":"word","token":"معدودات","display":"مَعْدُودٰاتٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"