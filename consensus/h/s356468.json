{"members":[{"header_text":" عَنْ  أَنَسٍ قَالَ:","body_text":"قَوْلُهُ تَعَالَي مَرَجَ الْبَحْرَيْنِ يَلْتَقِيٰانِ عَلِيٌّ وَ فَاطِمَةُ <quranic_text>«يَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَ الْمَرْجٰانُ ۱-۵ ۲۲:۵۵»</quranic_text> <footnote>[الرحمن۲۲]</footnote> قَالَ الْحَسَنُ وَ الْحُسَيْنُ وَ عَنِ اِبْنِ عَبَّاسٍ قَالَ: عَلِيٌّ وَ فَاطِمَةُ <quranic_text>«بَيْنَهُمٰا بَرْزَخٌ ۱-۲ ۲۰:۵۵»</quranic_text> <footnote>[الفرقان۵۳]</footnote> النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ <quranic_text>«يَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَ الْمَرْجٰانُ ۱-۵ ۲۲:۵۵»</quranic_text> <footnote>[الرحمن۲۲]</footnote> الْحَسَنُ وَ الْحُسَيْنُ صَلَوَاتُ اللَّهِ عَلَيْهِمَا [].","translation":"","aligned_body":"قَوْلُهُ تَعَالَي مَرَجَ الْبَحْرَيْنِ يَلْتَقِيٰانِ عَلِيٌّ وَ فَاطِمَةُ TAG_OPEN:quranic_text يَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَ الْمَرْجٰانُ ۱- ۵ ۲۲ ۵۵ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرحمن ۲۲ TAG_CLOSE:footnote قَالَ الْحَسَنُ وَ الْحُسَيْنُ وَ عَنِ اِبْنِ عَبَّاسٍ قَالَ عَلِيٌّ وَ فَاطِمَةُ TAG_OPEN:quranic_text بَيْنَهُمٰا بَرْزَخٌ ۱- ۲ ۲۰ ۵۵ TAG_CLOSE:quranic_text TAG_OPEN:footnote الفرقان ۵۳ TAG_CLOSE:footnote النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ TAG_OPEN:quranic_text يَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَ الْمَرْجٰانُ ۱- ۵ ۲۲ ۵۵ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرحمن ۲۲ TAG_CLOSE:footnote الْحَسَنُ وَ الْحُسَيْنُ صَلَوَاتُ اللَّهِ عَلَيْهِمَا"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"مرج","display":"مَرَجَ"},{"kind":"word","token":"البحرين","display":"الْبَحْرَيْنِ"},{"kind":"word","token":"يلتقيان","display":"يَلْتَقِيٰانِ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يخرج","display":"يَخْرُجُ"},{"kind":"word","token":"منهما","display":"مِنْهُمَا"},{"kind":"word","token":"ال