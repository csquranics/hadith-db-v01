{"members":[{"header_text":" سن،  [المحاسن] ،  أَبِي  عَمَّنْ حَدَّثَهُ رَفَعَهُ إِلَى <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> قَالَ:","body_text":"اِنَّهُ لاَ يَسَعُكُمْ فِيمَا يَنْزِلُ بِكُمْ مِمَّا لاَ تَعْلَمُونَ اِلاَّ الْكَفُّ عَنْهُ وَ التَّثَبُّتُ فِيهِ وَ الرَّدُّ اِلَي اَئِمَّةِ الْمُسْلِمِينَ حَتَّي يُعَرِّفُوكُمْ فِيهِ الْحَقَّ وَ يَحْمِلُوكُمْ فِيهِ عَلَي الْقَصْدِ قَالَ اللَّهُ عَزَّ وَ جَلَّ: <quranic_text>«فَسْئَلُوا اَهْلَ الذِّكْرِ اِنْ كُنْتُمْ لاٰ تَعْلَمُونَ»</quranic_text> <footnote>[النحل۴۳]</footnote> .","translation":"","aligned_body":"اِنَّهُ لاَ يَسَعُكُمْ فِيمَا يَنْزِلُ بِكُمْ مِمَّا لاَ تَعْلَمُونَ اِلاَّ الْكَفُّ عَنْهُ وَ التَّثَبُّتُ فِيهِ وَ الرَّدُّ اِلَي اَئِمَّةِ الْمُسْلِمِينَ حَتَّي يُعَرِّفُوكُمْ فِيهِ الْحَقَّ وَ يَحْمِلُوكُمْ فِيهِ عَلَي الْقَصْدِ قَالَ اللَّهُ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text فَسْئَلُوا اَهْلَ الذِّكْرِ اِنْ كُنْتُمْ لاٰ تَعْلَمُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote النحل ۴۳ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يسعكم","display":"يَسَعُكُمْ"},{"kind":"word","token":"فيما","display":"فِيمَا"},{"kind":"word","token":"ينزل","display":"يَنْزِلُ"},{"kind":"word","token":"بكم","display":"بِكُمْ"},{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تعلمون","display":"تَعْلَمُونَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"الكف","display":"الْكَفُّ"},{"kind":"word","token":"عنه","display":"عَنْهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"التثبت","display":"التَّثَبُّتُ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرد","display":"الرَّدُّ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ائمه","display":"اَئِمَّةِ"},{"kind":"word","token":"ال