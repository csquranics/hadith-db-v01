{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«وَ قٰالُوا اِنْ نَتَّبِعِ الْهُديٰ مَعَكَ»</quranic_text> <footnote>[القصص۵۷]</footnote> قَالَ نَزَلَتْ فِي قُرَيْشٍ حِينَ دَعَاهُمْ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اِلَي الْاِسْلاَمِ وَ الْهِجْرَةِ قَالُوا <quranic_text>«اِنْ نَتَّبِعِ الْهُديٰ مَعَكَ نُتَخَطَّفْ مِنْ اَرْضِنٰا»</quranic_text> <footnote>[القصص۵۷]</footnote> .","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text وَ قٰالُوا اِنْ نَتَّبِعِ الْهُديٰ مَعَكَ TAG_CLOSE:quranic_text TAG_OPEN:footnote القصص ۵۷ TAG_CLOSE:footnote قَالَ نَزَلَتْ فِي قُرَيْشٍ حِينَ دَعَاهُمْ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اِلَي الْاِسْلاَمِ وَ الْهِجْرَةِ قَالُوا TAG_OPEN:quranic_text اِنْ نَتَّبِعِ الْهُديٰ مَعَكَ نُتَخَطَّفْ مِنْ اَرْضِنٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote القصص ۵۷ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"نتبع","display":"نَتَّبِعِ"},{"kind":"word","token":"الهدي","display":"الْهُديٰ"},{"kind":"word","token":"معك","display":"مَعَكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۵۷","display":"۵۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قريش","display":"قُرَيْشٍ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"دعاهم","display":"دَعَاهُمْ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"k