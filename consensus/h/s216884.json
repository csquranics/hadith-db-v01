{"members":[{"header_text":" فِقْهُ <teller> اَلرِّضَا، عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"وَ اِذَا اَرَدْتَ اَنْ تُرْسِلَ الْكَلْبَ اِلَي الصَّيْدِ فَسَمِّ اللَّهَ عَلَيْهِ فَاِنْ اَدْرَكْتَهُ حَيّاً فَاذْبَحْهُ وَ اِنْ اَدْرَكْتَهُ وَ قَدْ قَتَلَهُ كَلْبُكَ فَكُلْ مِنْهُ وَ اِنْ اَكَلَ بَعْضَهُ لِقَوْلِهِ <quranic_text>«فَكُلُوا مِمّٰا اَمْسَكْنَ عَلَيْكُمْ»</quranic_text> <footnote>[المائدة۴]</footnote> .","translation":"","aligned_body":"وَ اِذَا اَرَدْتَ اَنْ تُرْسِلَ الْكَلْبَ اِلَي الصَّيْدِ فَسَمِّ اللَّهَ عَلَيْهِ فَاِنْ اَدْرَكْتَهُ حَيّاً فَاذْبَحْهُ وَ اِنْ اَدْرَكْتَهُ وَ قَدْ قَتَلَهُ كَلْبُكَ فَكُلْ مِنْهُ وَ اِنْ اَكَلَ بَعْضَهُ لِقَوْلِهِ TAG_OPEN:quranic_text فَكُلُوا مِمّٰا اَمْسَكْنَ عَلَيْكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۴ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اردت","display":"اَرَدْتَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ترسل","display":"تُرْسِلَ"},{"kind":"word","token":"الكلب","display":"الْكَلْبَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الصيد","display":"الصَّيْدِ"},{"kind":"word","token":"فسم","display":"فَسَمِّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"ادركته","display":"اَدْرَكْتَهُ"},{"kind":"word","token":"حيا","display":"حَيّاً"},{"kind":"word","token":"فاذبحه","display":"فَاذْبَحْهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"ادركته","display":"اَدْرَكْتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"قتله","display":"قَتَلَهُ"},{"kind":"word","token":"كلبك","display":"كَلْبُكَ"},{"kind":"word","token":"فكل","display":"فَكُلْ"},{"kind":"word"