{"members":[{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، عَنْ <teller> أَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ</teller> أَنَّهُ قَالَ:","body_text":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«وَ مَنْ عٰادَ فَيَنْتَقِمُ اللّٰهُ مِنْهُ»</quranic_text> <footnote>[المائدة۹۵]</footnote> قَالَ مَنْ قَتَلَ صَيْداً وَ هُوَ مُحْرِمٌ حُكِمَ عَلَيْهِ اَنْ يَجْزِيَ بِمِثْلِهِ فَاِنْ عَادَ فَقَتَلَ اخَرَ لَمْ يُحْكَمْ عَلَيْهِ وَ يَنْتَقِمُ اللَّهُ مِنْهُ.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ مَنْ عٰادَ فَيَنْتَقِمُ اللّٰهُ مِنْهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۹۵ TAG_CLOSE:footnote قَالَ مَنْ قَتَلَ صَيْداً وَ هُوَ مُحْرِمٌ حُكِمَ عَلَيْهِ اَنْ يَجْزِيَ بِمِثْلِهِ فَاِنْ عَادَ فَقَتَلَ اخَرَ لَمْ يُحْكَمْ عَلَيْهِ وَ يَنْتَقِمُ اللَّهُ مِنْهُ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عاد","display":"عٰادَ"},{"kind":"word","token":"فينتقم","display":"فَيَنْتَقِمُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۹۵","display":"۹۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قتل","display":"قَتَلَ"},{"kind":"word","token":"صيدا","display":"صَيْداً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token