{"members":[{"header_text":" يف،  [الطرائف] ،  اَلثَّعْلَبِيُّ رَفَعَهُ إِلَى  اِبْنِ عَبَّاسٍ : ","body_text":"فِي قَوْلِهِ تَعَالَي: <quranic_text>«طُوبيٰ لَهُمْ وَ حُسْنُ مَابٍ»</quranic_text> <footnote>[الرعد۲۹]</footnote> قَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ طُوبَي شَجَرَةٌ اَصْلُهَا فِي دَارِ عَلِيٍّ وَ فِي دَارِ كُلِّ مُؤْمِنٍ مِنْهَا غُصْنٌ فَقَالَ: <quranic_text>«طُوبيٰ لَهُمْ وَ حُسْنُ مَابٍ»</quranic_text> <footnote>[الرعد۲۹]</footnote> يَعْنِي حُسْنَ مَرْجِعٍ.","translation":"","aligned_body":"فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text طُوبيٰ لَهُمْ وَ حُسْنُ مَابٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۲۹ TAG_CLOSE:footnote قَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ طُوبَي شَجَرَةٌ اَصْلُهَا فِي دَارِ عَلِيٍّ وَ فِي دَارِ كُلِّ مُؤْمِنٍ مِنْهَا غُصْنٌ فَقَالَ TAG_OPEN:quranic_text طُوبيٰ لَهُمْ وَ حُسْنُ مَابٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۲۹ TAG_CLOSE:footnote يَعْنِي حُسْنَ مَرْجِعٍ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"طوبي","display":"طُوبيٰ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حسن","display":"حُسْنُ"},{"kind":"word","token":"ماب","display":"مَابٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","di