{"members":[{"header_text":" اَلْعَيَّاشِيُّ : عَنْ  زُرَارَةَ ، عَنْ <teller> أَبِي عَبْدِ اَللَّهِ (عَلَيْهِ اَلسَّلاَمُ)</teller> :","body_text":"فِي قَوْلِ اللَّهِ: <quranic_text>«وَ تِلْكَ الْاَيّٰامُ نُدٰاوِلُهٰا بَيْنَ النّٰاسِ»</quranic_text> <footnote>[العمران۱۴۰]</footnote> . قَالَ: «مَا زَالَ مُنْذُ خَلَقَ اللَّهُ تَعَالَي ادَمَ دَوْلَةٌ لِلَّهِ وَ دَوْلَةٌ لِاِبْلِيسَ، فَاَيْنَ دَوْلَةُ اللَّهِ تَعَالَي، اَ مَا هُوَ اِلاَّ قَائِمٌ وَاحِدٌ؟».","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ TAG_OPEN:quranic_text وَ تِلْكَ الْاَيّٰامُ نُدٰاوِلُهٰا بَيْنَ النّٰاسِ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۱۴۰ TAG_CLOSE:footnote قَالَ مَا زَالَ مُنْذُ خَلَقَ اللَّهُ تَعَالَي ادَمَ دَوْلَةٌ لِلَّهِ وَ دَوْلَةٌ لِاِبْلِيسَ فَاَيْنَ دَوْلَةُ اللَّهِ تَعَالَي اَ مَا هُوَ اِلاَّ قَائِمٌ وَاحِدٌ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تلك","display":"تِلْكَ"},{"kind":"word","token":"الايام","display":"الْاَيّٰامُ"},{"kind":"word","token":"نداولها","display":"نُدٰاوِلُهٰا"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۴۰","display":"۱۴۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"زال","display":"زَالَ"},{"kind":"word","token":"منذ","display":"مُنْذُ"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"ادم","display":"ادَمَ"},{"kind":"word","token":"دول