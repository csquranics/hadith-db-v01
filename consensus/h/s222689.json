{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ لاٰ تَذَرُنَّ وَدًّا وَ لاٰ سُوٰاعاً وَ لاٰ يَغُوثَ وَ يَعُوقَ وَ نَسْراً»</quranic_text> <footnote>[نوح۲۳]</footnote> قَالَ كَانَتْ وَدٌّ صَنَماً لِكَلْبٍ وَ كَانَتْ سُوَاعٌ لِهُذَيْلٍ وَ يَغُوثُ لِمُرَادٍ وَ كَانَتْ يَعُوقُ لِهَمْدَانَ وَ كَانَتْ نَسْرٌ لِحُصَيْنٍ.","translation":"","aligned_body":"TAG_OPEN:quranic_text وَ لاٰ تَذَرُنَّ وَدًّا وَ لاٰ سُوٰاعاً وَ لاٰ يَغُوثَ وَ يَعُوقَ وَ نَسْراً TAG_CLOSE:quranic_text TAG_OPEN:footnote نوح ۲۳ TAG_CLOSE:footnote قَالَ كَانَتْ وَدٌّ صَنَماً لِكَلْبٍ وَ كَانَتْ سُوَاعٌ لِهُذَيْلٍ وَ يَغُوثُ لِمُرَادٍ وَ كَانَتْ يَعُوقُ لِهَمْدَانَ وَ كَانَتْ نَسْرٌ لِحُصَيْنٍ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تذرن","display":"تَذَرُنَّ"},{"kind":"word","token":"ودا","display":"وَدًّا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"سواعا","display":"سُوٰاعاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يغوث","display":"يَغُوثَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يعوق","display":"يَعُوقَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نسرا","display":"نَسْراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"نوح","display":"نوح"},{"kind":"word","token":"۲۳","display":"۲۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"ود","display":"وَدٌّ"},{"kind":"word","token":"صنما","display":"صَنَماً"},{"kind":"word","token":"لكلب","display":"لِكَلْبٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},