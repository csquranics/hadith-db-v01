{"members":[{"header_text":" مُحَمَّدُ بْنُ مَسْعُودٍ اَلْعَيَّاشِيُّ فِي  تَفْسِيرِهِ ، عَنْ  عَبْدِ اَلْأَعْلَى قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ <quranic_text>«رَبَّنٰا اتِنٰا فِي الدُّنْيٰا حَسَنَةً وَ فِي الْاخِرَةِ حَسَنَةً وَ قِنٰا عَذٰابَ النّٰارِ»</quranic_text> <footnote>[البقرة۲۰۱]</footnote> قَالَ رِضْوَانُ اللَّهِ وَ الْجَنَّةُ وَ السَّعَةُ فِي الْمَعِيشَةِ وَ حُسْنُ الْخُلُقِ فِي الدُّنْيَا.","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ TAG_OPEN:quranic_text رَبَّنٰا اتِنٰا فِي الدُّنْيٰا حَسَنَةً وَ فِي الْاخِرَةِ حَسَنَةً وَ قِنٰا عَذٰابَ النّٰارِ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۰۱ TAG_CLOSE:footnote قَالَ رِضْوَانُ اللَّهِ وَ الْجَنَّةُ وَ السَّعَةُ فِي الْمَعِيشَةِ وَ حُسْنُ الْخُلُقِ فِي الدُّنْيَا"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ربنا","display":"رَبَّنٰا"},{"kind":"word","token":"اتنا","display":"اتِنٰا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الدنيا","display":"الدُّنْيٰا"},{"kind":"word","token":"حسنه","display":"حَسَنَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الاخره","display":"الْاخِرَةِ"},{"kind":"word","token":"حسنه","display":"حَسَنَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قنا","display":"قِنٰا"},{"kind":"word","token":"عذاب","display":"عَذٰابَ"},{"kind":"word","tok