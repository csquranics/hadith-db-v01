{"members":[{"header_text":" عَنِ اَلْحُسَيْنِ بْنِ سَعِيدٍ اَلْمَكْفُوفِ:","body_text":"كَتَبَ اِلَيْهِ فِي كِتَابٍ لَهُ: جُعِلْتُ فِدَاكَ يَا سَيِّدِي عَلِّمْ مَوْلاَكَ مَا مَعْنَي <quranic_text>«اِنَّ اللّٰهَ لاٰ يُغَيِّرُ مٰا بِقَوْمٍ حَتّٰي يُغَيِّرُوا مٰا بِاَنْفُسِهِمْ»</quranic_text> <footnote>[الرعد۱۱]</footnote> فَكَتَبَ صَلَوَاتُ اللّه عليه: اما التغيير فانه ليس اليهم حتّي يتولوا ذلك بانفسهم بخطاياهم و ارتكابهم ما نهي عنه","translation":"","aligned_body":"كَتَبَ اِلَيْهِ فِي كِتَابٍ لَهُ جُعِلْتُ فِدَاكَ يَا سَيِّدِي عَلِّمْ مَوْلاَكَ مَا مَعْنَي TAG_OPEN:quranic_text اِنَّ اللّٰهَ لاٰ يُغَيِّرُ مٰا بِقَوْمٍ حَتّٰي يُغَيِّرُوا مٰا بِاَنْفُسِهِمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۱۱ TAG_CLOSE:footnote فَكَتَبَ صَلَوَاتُ اللّه عليه اما التغيير فانه ليس اليهم حتّي يتولوا ذلك بانفسهم بخطاياهم و ارتكابهم ما نهي عنه"}],"body_consensus_columns":[{"kind":"word","token":"كتب","display":"كَتَبَ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتاب","display":"كِتَابٍ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"جعلت","display":"جُعِلْتُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"سيدي","display":"سَيِّدِي"},{"kind":"word","token":"علم","display":"عَلِّمْ"},{"kind":"word","token":"مولاك","display":"مَوْلاَكَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"معني","display":"مَعْنَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يغير","display":"يُغَيِّرُ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"بقوم","display":"بِقَوْمٍ"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"يغيروا","display":"يُغَيِّرُوا"},{"kind":"word","token":"ما","display"