{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"قَوْلُهُ: <quranic_text>«الْيَوْمَ يَئِسَ الَّذِينَ كَفَرُوا مِنْ دِينِكُمْ»</quranic_text> <footnote>[المائدة۳]</footnote> قَالَ: ذَلِكَ لَمَّا نَزَلَتْ وَلاَيَةُ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text الْيَوْمَ يَئِسَ الَّذِينَ كَفَرُوا مِنْ دِينِكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۳ TAG_CLOSE:footnote قَالَ ذَلِكَ لَمَّا نَزَلَتْ وَلاَيَةُ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اليوم","display":"الْيَوْمَ"},{"kind":"word","token":"يئس","display":"يَئِسَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"كفروا","display":"كَفَرُوا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"دينكم","display":"دِينِكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"ولايه","display":"وَلاَيَةُ"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}