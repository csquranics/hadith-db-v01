{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«وَيْلٌ لِكُلِّ اَفّٰاكٍ»</quranic_text> <footnote>[الجاثية۷]</footnote> اَيْ كَذَّابٍ قَوْلُهُ: <quranic_text>«وَ اِذٰا عَلِمَ مِنْ ايٰاتِنٰا شَيْئاً»</quranic_text> <footnote>[الجاثية۹]</footnote> يَعْنِي اِذَا رَاَي فَوَضَعَ الْعِلْمَ مَكَانَ الرُّؤْيَةِ قَوْلُهُ: <quranic_text>«عَذٰابٌ مِنْ رِجْزٍ اَلِيمٌ»</quranic_text> <footnote>[الجاثية۱۱]</footnote> قَالَ الشِّدَّةُ وَ السُّوءُ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text وَيْلٌ لِكُلِّ اَفّٰاكٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الجاثية ۷ TAG_CLOSE:footnote اَيْ كَذَّابٍ قَوْلُهُ TAG_OPEN:quranic_text وَ اِذٰا عَلِمَ مِنْ ايٰاتِنٰا شَيْئاً TAG_CLOSE:quranic_text TAG_OPEN:footnote الجاثية ۹ TAG_CLOSE:footnote يَعْنِي اِذَا رَاَي فَوَضَعَ الْعِلْمَ مَكَانَ الرُّؤْيَةِ قَوْلُهُ TAG_OPEN:quranic_text عَذٰابٌ مِنْ رِجْزٍ اَلِيمٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote الجاثية ۱۱ TAG_CLOSE:footnote قَالَ الشِّدَّةُ وَ السُّوءُ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ويل","display":"وَيْلٌ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"افاك","display":"اَفّٰاكٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الجاثيه","display":"الجاثية"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"كذاب","display":"كَذَّابٍ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"علم","display":"عَلِمَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اياتنا","display":"ايٰاتِنٰا"},{"kind":"word","token":"شيئا","display":"شَيْ