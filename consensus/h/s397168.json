{"members":[{"header_text":" فِي مَجْمَعِ اَلْبَيَانِ:","body_text":" <quranic_text>«اِنَّ قٰارُونَ كٰانَ مِنْ قَوْمِ مُوسيٰ»</quranic_text> <footnote>[القصص۷۶]</footnote> اَيْ كَانَ مِنْ بَنِي اِسْرَائِيلَ ثُمَّ مَنْ سِبْطِ مُوسَي وَ هُوَ اِبْنُ خَالَتِهِ عَنْ عَطَاءٍ عَنِ اِبْنِ عَبَّاسٍ وَ رُوِيَ ذَلِكَ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ.","translation":"","aligned_body":"TAG_OPEN:quranic_text اِنَّ قٰارُونَ كٰانَ مِنْ قَوْمِ مُوسيٰ TAG_CLOSE:quranic_text TAG_OPEN:footnote القصص ۷۶ TAG_CLOSE:footnote اَيْ كَانَ مِنْ بَنِي اِسْرَائِيلَ ثُمَّ مَنْ سِبْطِ مُوسَي وَ هُوَ اِبْنُ خَالَتِهِ عَنْ عَطَاءٍ عَنِ اِبْنِ عَبَّاسٍ وَ رُوِيَ ذَلِكَ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"قارون","display":"قٰارُونَ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قوم","display":"قَوْمِ"},{"kind":"word","token":"موسي","display":"مُوسيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۷۶","display":"۷۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرَائِيلَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"سبط","display":"سِبْطِ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"خالته","display":"خَالَتِهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"عطا