{"members":[{"header_text":" م،  [تفسير <teller> الإمام عليه السلام</teller> ] : ","body_text":"قَوْلُهُ عَزَّ وَ جَلَّ: <quranic_text>«اَقِيمُوا الصَّلاٰةَ وَ اتُوا الزَّكٰاةَ»</quranic_text> <footnote>[البقرة۴۳]</footnote> قَالَ الْاِمَامُ عَلَيْهِ السَّلاَمُ اتُوا الزَّكَاةَ مُسْتَحِقَّهَا لاَ تُؤْتُوهَا كَافِراً وَ لاَ مُنَافِقاً قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ الْمُتَصَدِّقُ عَلَي اَعْدَائِنَا كَالسَّارِقِ فِي حَرَمِ اللَّهِ.","translation":"","aligned_body":"قَوْلُهُ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text اَقِيمُوا الصَّلاٰةَ وَ اتُوا الزَّكٰاةَ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۴۳ TAG_CLOSE:footnote قَالَ الْاِمَامُ عَلَيْهِ السَّلاَمُ اتُوا الزَّكَاةَ مُسْتَحِقَّهَا لاَ تُؤْتُوهَا كَافِراً وَ لاَ مُنَافِقاً قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ الْمُتَصَدِّقُ عَلَي اَعْدَائِنَا كَالسَّارِقِ فِي حَرَمِ اللَّهِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اقيموا","display":"اَقِيمُوا"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتوا","display":"اتُوا"},{"kind":"word","token":"الزكاه","display":"الزَّكٰاةَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الامام","display":"الْاِمَامُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اتوا","display":"اتُوا"},{"kind":"word","token":"الزكاه","display":"الزَّكَاةَ"},{"kind":"word","token":"مستحقها","display":"مُسْتَح