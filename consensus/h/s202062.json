{"members":[{"header_text":" وَ عَنِ  اَلْحُسَيْنِ بْنِ مُسْلِمٍ عَنْ <teller> أَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ</teller> أَنَّهُ قَالَ فِي حَدِيثٍ:","body_text":"اَلْاَرْزَاقُ مَوْظُوفَةٌ مَقْسُومَةٌ وَ لِلَّهِ فَضْلٌ يَقْسِمُهُ مِنْ طُلُوعِ الْفَجْرِ اِلَي طُلُوعِ الشَّمْسِ وَ ذَلِكَ قَوْلُهُ تَعَالَي <quranic_text>«وَ سْئَلُوا اللّٰهَ مِنْ فَضْلِهِ»</quranic_text> <footnote>[النساء۳۲]</footnote> ثُمَّ قَالَ وَ لَذِكْرُ اللَّهِ بَعْدَ طُلُوعِ الْفَجْرِ اَبْلَغُ فِي طَلَبِ الرِّزْقِ مِنَ الضَّارِبِ فِي الْاَرْضِ.","translation":"","aligned_body":"اَلْاَرْزَاقُ مَوْظُوفَةٌ مَقْسُومَةٌ وَ لِلَّهِ فَضْلٌ يَقْسِمُهُ مِنْ طُلُوعِ الْفَجْرِ اِلَي طُلُوعِ الشَّمْسِ وَ ذَلِكَ قَوْلُهُ تَعَالَي TAG_OPEN:quranic_text وَ سْئَلُوا اللّٰهَ مِنْ فَضْلِهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۳۲ TAG_CLOSE:footnote ثُمَّ قَالَ وَ لَذِكْرُ اللَّهِ بَعْدَ طُلُوعِ الْفَجْرِ اَبْلَغُ فِي طَلَبِ الرِّزْقِ مِنَ الضَّارِبِ فِي الْاَرْضِ"}],"body_consensus_columns":[{"kind":"word","token":"الارزاق","display":"اَلْاَرْزَاقُ"},{"kind":"word","token":"موظوفه","display":"مَوْظُوفَةٌ"},{"kind":"word","token":"مقسومه","display":"مَقْسُومَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"فضل","display":"فَضْلٌ"},{"kind":"word","token":"يقسمه","display":"يَقْسِمُهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"طلوع","display":"طُلُوعِ"},{"kind":"word","token":"الفجر","display":"الْفَجْرِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"طلوع","display":"طُلُوعِ"},{"kind":"word","token":"الشمس","display":"الشَّمْسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئلوا","display":"سْئَلُوا"},{"kind":"word","t