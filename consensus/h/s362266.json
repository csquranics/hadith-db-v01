{"members":[{"header_text":" \" شَهْرُ بْنُ حَوْشَبٍ عَنْ  عَبْدِ اَلرَّحْمَنِ بْنِ غُنَيْمٍ قَالَ:","body_text":"كُنْتُ عِنْدَ اَبِي الدَّرْدَاءِ اِذْ دَخَلَ عَلَيْهِ رَجُلٌ مِنَ الْمَدِينَةِ فَسَاَلَهُ فَقَالَ اَيْنَ تَرَكْتَ اَبَا ذَرٍّ فَقَالَ بِالرَّبَذَةِ فَقَالَ اَبُو الدَّرْدَاءِ <quranic_text>«اِنّٰا لِلّٰهِ وَ اِنّٰا اِلَيْهِ رٰاجِعُونَ»</quranic_text> <footnote>[البقرة۱۵۶]</footnote> لَوْ اَنَّ اَبَا ذَرٍّ قَطَعَ مِنِّي عُضْواً مَا هِجْتُهُ لِمَا سَمِعْتُ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ يَقُولُ فِيهِ.","translation":"","aligned_body":"كُنْتُ عِنْدَ اَبِي الدَّرْدَاءِ اِذْ دَخَلَ عَلَيْهِ رَجُلٌ مِنَ الْمَدِينَةِ فَسَاَلَهُ فَقَالَ اَيْنَ تَرَكْتَ اَبَا ذَرٍّ فَقَالَ بِالرَّبَذَةِ فَقَالَ اَبُو الدَّرْدَاءِ TAG_OPEN:quranic_text اِنّٰا لِلّٰهِ وَ اِنّٰا اِلَيْهِ رٰاجِعُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۵۶ TAG_CLOSE:footnote لَوْ اَنَّ اَبَا ذَرٍّ قَطَعَ مِنِّي عُضْواً مَا هِجْتُهُ لِمَا سَمِعْتُ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ يَقُولُ فِيهِ"}],"body_consensus_columns":[{"kind":"word","token":"كنت","display":"كُنْتُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"الدرداء","display":"الدَّرْدَاءِ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المدينه","display":"الْمَدِينَةِ"},{"kind":"word","token":"فساله","display":"فَسَاَلَهُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"اين","display":"اَيْنَ"},{"kind":"word","token":"تركت","display":"تَرَكْتَ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"ذر","display":"ذَرٍّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"بالربذه","display":"بِالرَّبَذَةِ"},{"kind":"word","token":"فقال","dis