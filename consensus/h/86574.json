{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ لاٰ تَحَاضُّونَ عَليٰ طَعٰامِ الْمِسْكِينِ»</quranic_text> <footnote>[الفجر۱۸]</footnote> اَيْ لاَ تَرْعَوْنَ وَ هُمُ الَّذِينَ غَصَبُوا الَ مُحَمَّدٍ حَقَّهُمْ وَ اَكَلُوا اَمْوَالَ اَيْتَامِهِمْ وَ فُقَرَائِهِمْ وَ اَبْنَاءِ سَبِيلِهِمْ.","translation":"","aligned_body":"TAG_OPEN:quranic_text وَ لاٰ تَحَاضُّونَ عَليٰ طَعٰامِ الْمِسْكِينِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الفجر ۱۸ TAG_CLOSE:footnote اَيْ لاَ تَرْعَوْنَ وَ هُمُ الَّذِينَ غَصَبُوا الَ مُحَمَّدٍ حَقَّهُمْ وَ اَكَلُوا اَمْوَالَ اَيْتَامِهِمْ وَ فُقَرَائِهِمْ وَ اَبْنَاءِ سَبِيلِهِمْ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تحاضون","display":"تَحَاضُّونَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"طعام","display":"طَعٰامِ"},{"kind":"word","token":"المسكين","display":"الْمِسْكِينِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفجر","display":"الفجر"},{"kind":"word","token":"۱۸","display":"۱۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ترعون","display":"تَرْعَوْنَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"غصبوا","display":"غَصَبُوا"},{"kind":"word","token":"ال","display":"الَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"حقهم","display":"حَقَّهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اكلوا","display":"اَكَلُوا"},{"kind":"word","token":"اموال","display":"اَمْوَالَ"},{"kind":"word","token":"ايتامهم","display":"اَيْتَامِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"ki