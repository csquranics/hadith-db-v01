{"members":[{"header_text":" كِتَابُ  دُرُسْتَ بْنِ أَبِي مَنْصُورٍ ، عَنْ  جَمِيلِ بْنِ دَرَّاجٍ قَالَ:","body_text":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اَصْلَحَكَ اللَّهُ <quranic_text>«وَ لاٰ يَرْضيٰ لِعِبٰادِهِ الْكُفْرَ»</quranic_text> <footnote>[الزمر۷]</footnote> قَالَ فَقَالَ النَّاسُ جَمِيعاً لَمْ يَرْضَ لَهُمُ الْكُفْرَ قَالَ قُلْتُ جُعِلْتُ فِدَاكَ <quranic_text>«وَ مٰا خَلَقْتُ الْجِنَّ وَ الْاِنْسَ اِلاّٰ لِيَعْبُدُونِ»</quranic_text> <footnote>[الذاريات۵۶]</footnote> قَالَ فَقَالَ خَلَقَهُمْ لِلْعِبَادَةِ.","translation":"","aligned_body":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اَصْلَحَكَ اللَّهُ TAG_OPEN:quranic_text وَ لاٰ يَرْضيٰ لِعِبٰادِهِ الْكُفْرَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الزمر ۷ TAG_CLOSE:footnote قَالَ فَقَالَ النَّاسُ جَمِيعاً لَمْ يَرْضَ لَهُمُ الْكُفْرَ قَالَ قُلْتُ جُعِلْتُ فِدَاكَ TAG_OPEN:quranic_text وَ مٰا خَلَقْتُ الْجِنَّ وَ الْاِنْسَ اِلاّٰ لِيَعْبُدُونِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الذاريات ۵۶ TAG_CLOSE:footnote قَالَ فَقَالَ خَلَقَهُمْ لِلْعِبَادَةِ"}],"body_consensus_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اصلحك","display":"اَصْلَحَكَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يرضي","display":"يَرْضيٰ"},{"kind":"word","token":"لعباده","display":"لِعِبٰادِهِ"},{"kind":"word","token":"الكفر","display":"الْكُفْرَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزمر","display":"الزمر"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_n