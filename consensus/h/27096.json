{"members":[{"header_text":"","body_text":"تِلْكُمْ قُرَيْشٌ تَمَنَّانِي لِتَقْتُلَنِيفَلاَ وَ رَبِّكَ مَا بَزُّوا وَ لاَ ظَفِرُوا فَاِنْ بَقِيتُ فَرَهْنٌ ذِمَّتِي لَكُمُبِذَاتِ وَدْقَيْنِ لاَ يَعْفُو لَهَا اَثَرٌ وَ اِنْ هَلَكْتُ فَاِنِّي سَوْفَ اُورِثُهُمْذُلَّ الْحَيَاةِ فَقَدْ خَانُوا وَ قَدْ غَدَرُوا اِمَّا بَقِيتُ فَاِنِّي لَسْتُ مُتَّخِذاًاَهْلاً وَ لاَ شِيعَةً فِي الدِّينِ اِذْ فَجَرُوا قَدْ بَايَعُونِي وَ لَمْ يُوفُوا بِبَيْعَتِهِمْوَ مَاكَرُونِي فِي الْاَعْدَاءِ اِذْ مَكَرُوا","translation":"","aligned_body":"تِلْكُمْ قُرَيْشٌ تَمَنَّانِي لِتَقْتُلَنِيفَلاَ - - - - - - - - - - - - - - - وَ رَبِّكَ مَا بَزُّوا وَ - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - لاَ ظَفِرُوا فَاِنْ بَقِيتُ فَرَهْنٌ ذِمَّتِي لَكُمُبِذَاتِ وَدْقَيْنِ لاَ يَعْفُو لَهَا - - - اَثَرٌ وَ اِنْ هَلَكْتُ فَاِنِّي سَوْفَ اُورِثُهُمْذُلَّ الْحَيَاةِ فَقَدْ خَانُوا وَ قَدْ غَدَرُوا اِمَّا بَقِيتُ فَاِنِّي لَسْتُ مُتَّخِذاًاَهْلاً وَ لاَ شِيعَةً فِي الدِّينِ اِذْ فَجَرُوا قَدْ بَايَعُونِي وَ لَمْ يُوفُوا بِبَيْعَتِهِمْوَ مَاكَرُونِي فِي - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - الْاَعْدَاءِ اِذْ - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - مَكَرُوا - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"},{"header_text":" وَ مِنْهُ فِي اَلشِّكَايَةِ مِمَّنْ خَانَهُ وَ خَالَفَهُ مِنْ  قُرَيْشٍ وَ غَيْرِهِمْ:","body_text":"تِلْكُمْ قُرَيْشٌ تَمَنَّانِي لِتَقْتُلَنِيفَلاَ وَ رَبِّكَ مَا بَزُّوا وَ لاَ ظَفِرُوا فَاِنْ بَقِيتُ فَرَهْنٌ ذِمَّتِي لَهُمْبِذَاتِ وَدْقَيْنِ لاَ يَعْفُو لَهَا اَثَرٌ وَ اِنْ هَلَكْتُ فَاِنِّي سَوْفَ اُوَرِّثُهُمْذُلَّ الْحَيَاةِ فَقَدْ خَانُوا وَ قَدْ غَدَرُوا اِمَّا بَقِيتُ فَاِنِّي لَسْتُ مُتَّخِذاًاَهْلاً وَ لاَ شِيعَةً فِي الدِّينِ اِذْ فَجَرُوا قَدْ بَايَعُونِي وَ لَمْ يُوفُوا بِبَيْعَتِهِمْوَ مَاكَرُونِي فِي الْاَعْدَاءِ اِذْ مَكَرُوا وَ نَاصَبُونِي فِي حَرْبٍ مُضَرَّمَةٍمَا لَمْ يُلاَقِ اَبُو بَكْرٍ وَ لاَ عُمَرُ","translation":"","aligned_body":"تِلْكُمْ قُرَيْشٌ تَمَنَّانِي لِتَقْتُلَنِيفَلاَ - - - - - - - - - - - - - - - وَ رَبِّكَ مَا بَزُّوا وَ - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - لاَ ظَفِرُوا فَاِنْ بَقِيتُ فَرَهْنٌ ذِمَّتِي لَهُمْبِذَاتِ وَدْقَيْنِ لاَ يَعْفُو لَهَا اَثَرٌ - - - وَ اِنْ هَلَكْتُ فَاِنِّي سَوْفَ اُوَرِّثُهُمْذُلَّ الْحَيَاةِ فَقَدْ خَانُوا وَ قَدْ غَدَرُوا اِمَّا بَقِيتُ فَاِنِّي لَسْتُ مُتَّخِذاًاَهْلاً وَ لاَ شِيعَةً فِي الدِّينِ اِذْ فَجَرُوا قَدْ بَايَعُونِي وَ لَمْ يُوفُوا بِبَيْعَتِهِمْوَ مَاكَرُونِي فِي - - الْاَعْدَاءِ اِذْ مَكَرُوا وَ - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - نَاصَبُونِي فِي حَرْبٍ مُضَرَّمَةٍمَا لَمْ - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - يُلاَقِ اَبُو بَكْرٍ وَ لاَ - - - - - - - - - - - - - - - - - - - - - - - - - - - - عُمَرُ"},{"header_text":" قَالَ: حَدَّثَنَا حَمَّادُ بْنُ عِيسَى اَلْجُهَنِيُّ قَالَ: حَدَّثَنِي مِسْمَعُ بْنُ سَتَّارٍ عَنْ <innocent> جَعْفَرِ بْنِ مُحَمَّدٍ</innocent> عَنْ<teller> أَبِيهِ</teller> قَالَ:","body_text":"عَنْ اَبِيهِ قَالَ: بَلَغَ مُعَاوِيَةَ اَنَّ عَلِيّاً عَلَيْهِ السَّلاَمُ يَسْتَنْفِرُ النَّاسَ بِالْكُوفَةِ لِلْمَسِيرِ اِلَيْهِ اِلَي الشَّامِ وَ ذَلِكَ بَعْدَ الْمُوَادَعَةِ وَ الْحُكُومَةِ فَبَلَغَ ذَلِكَ مِنْ مُعَاوِيَةَ الْمُبَالِغُ وَ جَعَلَ يَدُسُّ الرِّجَالَ اِلَي عَلِيٍّ عَلَيْهِ السَّلاَمُ لِلْقَتْلِ وَ يَعْمَلُ الْحِيلَةَ فِي ذَلِكَ اِلَي اَنْ كَاتَبَ عَمْرَو بْنَ حُرَيْثٍ الْمَخْزُومِيَّ اِلَي الْكُوفَةِ فَقَدِمَ الرَّجُلُ اِلَي عَمْرِو بْنِ حُرَيْثٍ فَاَنْزَلَهُ فِي مَكَانٍ يَقْرُبُ مِنْهُ وَ كَانَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ لاَ يَرَي الْمَسْحَ عَلَي الْخُفَّيْنِ وَ كَانَ يَجْلِسُ فِي مَسْجِدِ الْكُوفَةِ الْاَعْظَمِ يُفْتِي النَّاسَ وَ يَقْضِي بَيْنَهُمْ حَتَّي تَجِبَ الصَّلاَةُ فَيَخْلَعُ الْخُفَّيْنِ وَ يُطَهِّرُ الرِّجْلَيْنِ وَ يُصَلِّي بِالنَّاسِ فَاِذَا اَرَادَ اَنْ يَنْصَرِفَ اِلَي اَهْلِهِ لَبِسَ خُفَّهُ وَ اِنْصَرَفَ فَاَجْمَعَ الرَّجُلُ اَنْ يُرْصِدَ عَلِيّاً عَلَيْهِ السَّلاَمُ فَاِذَا خَلَعَ خُفَّيْهِ جَعَلَ فِي اَحَدِهِمَا اَفْعًي اَوْ قَالَ ثُعْبَانٌ مِمَّا كَانَ مَعَهُ فَفَعَلَ ذَلِكَ وَ جَعَلَ الْاَفْعَي اَوْ قَالَ الثُّعْبَانُ فِي اَحَدِ الْخُفَّيْنِ فَلَمَّا اَرَادَ اَمِيرُ الْمُؤْمِنِينَ اَنْ يَلْبَسَ خُفَّهُ اِنْقَضَّ عُقَابٌ فَاخْتَطَفَ الْخُفَّ وَ طَارَ بِهِ فِي الْجَوِّ ثُمَّ طَرَحَهُ فَخَرَجَ الْاَفْعَي فَقُتِلَ قَالَ فَقَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ لِلنَّاسِ خُذُوا اَبْوَابَ الْمَسْجِدِ فَاُخِذَتِ الْاَبْوَابُ وَ نَظَرُوا فَاِذَا رَجُلٌ غَرِيبٌ وَ هُوَ الرَّجُلُ الَّذِي اَرْصَدَ عَلِيّاً بِمَا صَنَعَ فَاعْتَرَفَ اَنَّ مُعَاوِيَةَ بَعَثَهُ لِذَلِكَ اِلَي عَمْرِو بْنِ حُرَيْثٍ قَالَ فَقَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ جِيئُوا بِعَمْرِو بْنِ حُرَيْثٍ وَ لاَ تَنَالُوهُ بِسُوءٍ فَانْطَلَقُوا فَجَاءُوا بِهِ تَرْتَعِدُ فَرَائِصُهُ فَاَرَادُوا قَتْلَهُ فَقَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ دَعُوهُ فَلَيْسَ هُوَ وَ لاَ مُعَاوِيَةُ بِقَاتِلِي وَ لاَ يَقْدِرَانِ عَلَي ذَلِكَ اِنَّ قَاتِلِي رَجُلٌ مِنْ مُرَادٍ ضَرْبٌ مِنَ الرِّجَالِ اَعْسَرُ اَيْسَرُ اُصَيْفِرُ يَنْظُرُ بِعَيْنَيْ شَيْطَانٍ وَ جَعَلَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ يَصِفُهُ قَالَ يَقْتُلُنِي فِي الشَّهْرِ الْحَرَامِ لاَ بَلْ فِي شَهْرِ الصِّيَامِ عَهْدٌ مِنَ النَّبِيِّ الْاُمِّيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اِلَيَّ بِذَلِكَ <quranic_text>«وَ قَدْ خٰابَ مَنِ اِفْتَريٰ»</quranic_text> <footnote>[طه۶۱]</footnote> ثُمَّ اَطْلَقَ عَنْ عَمْرٍو وَ اَنْشَاَ يَقُولُ تِلْكُمْ قُرَيْشٌ تَمَنَّانِي لِتَقْتُلَنِيفَلاَ وَ رَبِّكَ مَا تَرْوَي وَ لاَ ظَفِرُوا اِمَّا بَقِيتُ فَاِنِّي لَسْتُ مُتَّخِذاًاَهْلاً وَ لاَ شِيعَةً فِي الدِّينِ اِذْ غَدَرُوا قَدْ بَايَعُونِي فَمَا اَوْفَوْا بِبَيْعَتِهِمْيَوْماً وَ مَالُوا بِاَهْلِ الْكُفْرِ اِذْ كَفَرُوا وَ قَلَصُوا لِي عَنْ حَرْبٍ مُشَمَّرَةٍمَا لَمْ يُلاَقِ اَبُو بَكْرٍ وَ لاَ عُمَرُ فَاِنْ هَلَكْتُ فَرَهْنٌ ذِمَّتِي لَكُمْبِذَاتِ وَدْقَيْنِ لاَ يَعْفُو لَهَا بَشَرٌ عَامَ الثَّلاَثِينَ خَيْلٌ غَيْرُ مُخَلَّقَةٍاِذَا الْمُحَرَّمُ عَنْهَا مَرَّ اَوْ صَفَرٌ وَ سَوْفَ يَاْتِيكَ عَنْ اَنْبَاءِ مَلْحَمَةٍيَبِيضُ مِنْ ذِكْرِهِمْ اَنْبَاءَهَا الشَّعْرُ اِذَا اِلْتَقَي مَرَّةً بِالْمَرَجِ جَمْعُهُمْتَعْلُو قُضَاعَةُ اَوْ يَشْقَي بِهَا مُضَرُ فَسَوْفَ يُبْعَثُ مَهْدِيٌّ لِسُنَّتِهِفَيَنْشُرُ الْوَحْيَ وَ الدِّينَ الَّذِي طَهَّرُوا.","translation":"","aligned_body":"- - - عَنْ اَبِيهِ قَالَ بَلَغَ مُعَاوِيَةَ اَنَّ عَلِيّاً عَلَيْهِ السَّلاَمُ يَسْتَنْفِرُ النَّاسَ بِالْكُوفَةِ لِلْمَسِيرِ اِلَيْهِ اِلَي الشَّامِ وَ ذَلِكَ بَعْدَ الْمُوَادَعَةِ وَ الْحُكُومَةِ فَبَلَغَ ذَلِكَ مِنْ مُعَاوِيَةَ الْمُبَالِغُ وَ جَعَلَ يَدُسُّ الرِّجَالَ اِلَي عَلِيٍّ عَلَيْهِ السَّلاَمُ لِلْقَتْلِ وَ يَعْمَلُ الْحِيلَةَ فِي ذَلِكَ اِلَي اَنْ كَاتَبَ عَمْرَو بْنَ حُرَيْثٍ الْمَخْزُومِيَّ اِلَي الْكُوفَةِ فَقَدِمَ الرَّجُلُ اِلَي عَمْرِو بْنِ حُرَيْثٍ فَاَنْزَلَهُ فِي مَكَانٍ يَقْرُبُ مِنْهُ وَ كَانَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ لاَ - - - - - - - - - - يَرَي الْمَسْحَ عَلَي الْخُفَّيْنِ وَ كَانَ يَجْلِسُ - - - - - - - - - - - - - - - - - - - - - - - - - - - - فِي مَسْجِدِ الْكُوفَةِ الْاَعْظَمِ يُفْتِي النَّاسَ وَ يَقْضِي بَيْنَهُمْ حَتَّي تَجِبَ الصَّلاَةُ فَيَخْلَعُ الْخُفَّيْنِ وَ يُطَهِّرُ الرِّجْلَيْنِ وَ يُصَلِّي بِالنَّاسِ فَاِذَا اَرَادَ اَنْ يَنْصَرِفَ اِلَي اَهْلِهِ لَبِسَ خُفَّهُ وَ اِنْصَرَفَ فَاَجْمَعَ الرَّجُلُ اَنْ يُرْصِدَ عَلِيّاً عَلَيْهِ السَّلاَمُ فَاِذَا خَلَعَ خُفَّيْهِ جَعَلَ فِي اَحَدِهِمَا اَفْعًي اَوْ قَالَ ثُعْبَانٌ مِمَّا كَانَ مَعَهُ فَفَعَلَ ذَلِكَ وَ جَعَلَ الْاَفْعَي اَوْ قَالَ الثُّعْبَانُ فِي اَحَدِ الْخُفَّيْنِ فَلَمَّا اَرَادَ اَمِيرُ الْمُؤْمِنِينَ اَنْ يَلْبَسَ خُفَّهُ اِنْقَضَّ عُقَابٌ فَاخْتَطَفَ الْخُفَّ وَ طَارَ بِهِ فِي الْجَوِّ ثُمَّ طَرَحَهُ فَخَرَجَ الْاَفْعَي فَقُتِلَ قَالَ فَقَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ لِلنَّاسِ خُذُوا اَبْوَابَ الْمَسْجِدِ فَاُخِذَتِ الْاَبْوَابُ وَ نَظَرُوا فَاِذَا رَجُلٌ غَرِيبٌ وَ هُوَ الرَّجُلُ الَّذِي اَرْصَدَ عَلِيّاً بِمَا صَنَعَ فَاعْتَرَفَ اَنَّ مُعَاوِيَةَ بَعَثَهُ لِذَلِكَ اِلَي عَمْرِو بْنِ حُرَيْثٍ قَالَ فَقَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ جِيئُوا بِعَمْرِو بْنِ حُرَيْثٍ وَ لاَ تَنَالُوهُ بِسُوءٍ فَانْطَلَقُوا فَجَاءُوا بِهِ تَرْتَعِدُ فَرَائِصُهُ فَاَرَادُوا قَتْلَهُ فَقَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ دَعُوهُ فَلَيْسَ هُوَ وَ لاَ مُعَاوِيَةُ بِقَاتِلِي وَ لاَ يَقْدِرَانِ عَلَي ذَلِكَ اِنَّ قَاتِلِي رَجُلٌ مِنْ مُرَادٍ ضَرْبٌ مِنَ الرِّجَالِ اَعْسَرُ اَيْسَرُ اُصَيْفِرُ يَنْظُرُ بِعَيْنَيْ شَيْطَانٍ وَ - - - - - جَعَلَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ يَصِفُهُ"},{"header_text":" وَ رَوَى  أَبُو عُثْمَانَ اَلْمَازِنِيُّ أَنَّهُ قَالَ عَلَيْهِ السَّلاَمُ:","body_text":"تِلْكُمْ قُرَيْشٌ تَمَنَّانِي لِتَقْتُلَنِيفَلاَ وَ رَبِّكَ مَا فَازُوا وَ مَا ظَفِرُوا فَاِنْ بَقِيتُ فَرَهْنٌ ذِمَّتِي لَهُمْبِذَاتِ وَدْقَيْنِ لاَ يَعْفُو لَهَا اَثَرٌ وَ اِنْ هَلَكْتُ فَاِنِّي سَوْفَ اُوتِرُهُمْذُلَّ الْمَمَاتِ فَقَدْ خَانُوا وَ قَدْ غَدَرُوا وَ اَمَرَ الْحَسَنَ عَلَيْهِ السَّلاَمُ اَنْ يُصَلِّيَ الْغَدَاةَ بِالنَّاسِ وَ رُوِيَ اَنَّهُ دَفَعَ فِي ظُهْرِهِ جَعْدَةَ فَصَلَّي بِالنَّاسِ الْغَدَاةَ.","translation":"","aligned_body":"تِلْكُمْ قُرَيْشٌ تَمَنَّانِي لِتَقْتُلَنِيفَلاَ - - - - - - - - - - - - - - - وَ رَبِّكَ مَا فَازُوا وَ - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - مَا ظَفِرُوا فَاِنْ بَقِيتُ فَرَهْنٌ ذِمَّتِي لَهُمْبِذَاتِ وَدْقَيْنِ لاَ يَعْفُو لَهَا - - - اَثَرٌ وَ اِنْ هَلَكْتُ فَاِنِّي سَوْفَ اُوتِرُهُمْذُلَّ الْمَمَاتِ فَقَدْ خَانُوا وَ قَدْ غَدَرُوا - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - وَ اَمَرَ الْحَسَنَ - - - - - - - - - - - - - - - عَلَيْهِ السَّلاَمُ - - - - - - - - - - - - - - - - - - - - - - - - - - - - اَنْ - - - - - - - - - - - - - - - - - - - - يُصَلِّيَ الْغَدَاةَ بِالنَّاسِ - - - - - - - - - - - - - - - - - - - - - - - - - 