{"members":[{"header_text":" فس، ،  [تفسير القمي] : ","body_text":" <quranic_text>«ثُمَّ لَتُسْئَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ»</quranic_text> <footnote>[التكاثر۸]</footnote> اَيْ عَنِ الْوَلاَيَةِ وَ الدَّلِيلُ عَلَي ذَلِكَ قَوْلُهُ: <quranic_text>«وَ قِفُوهُمْ اِنَّهُمْ مَسْؤُلُونَ»</quranic_text> <footnote>[الصافات۲۴]</footnote> قَالَ عَنِ الْوَلاَيَةِ.","translation":"","aligned_body":"ثُمَّ لَتُسْئَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ التكاثر۸ اَيْ عَنِ الْوَلاَيَةِ وَ الدَّلِيلُ عَلَي ذَلِكَ قَوْلُهُ وَ قِفُوهُمْ اِنَّهُمْ مَسْؤُلُونَ الصافات۲۴ قَالَ عَنِ الْوَلاَيَةِ"}],"body_consensus_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"لتسئلن","display":"لَتُسْئَلُنَّ"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"النعيم","display":"النَّعِيمِ"},{"kind":"word","token":"التكاثر۸","display":"التكاثر۸"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الولايه","display":"الْوَلاَيَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الدليل","display":"الدَّلِيلُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قفوهم","display":"قِفُوهُمْ"},{"kind":"word","token":"انهم","display":"اِنَّهُمْ"},{"kind":"word","token":"مسؤلون","display":"مَسْؤُلُونَ"},{"kind":"word","token":"الصافات۲۴","display":"الصافات۲۴"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الولايه","display":"الْوَلاَيَةِ"}]}