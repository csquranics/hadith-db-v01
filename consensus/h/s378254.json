{"members":[{"header_text":" اَلْكَلْبِيُّ وَ  أَبُو صَالِحٍ عَنِ  اِبْنِ عَبَّاسٍ : ","body_text":" <quranic_text>«يٰا اَيُّهَا الَّذِينَ امَنُوا اِتَّقُوا اللّٰهَ وَ كُونُوا مَعَ الصّٰادِقِينَ»</quranic_text> <footnote>[التوبة۱۱۹]</footnote> اَيْ كُونُوا مَعَ عَلِيِّ بْنِ اَبِي طَالِبٍ ذَكَرَهُ الثَّعْلَبِيُّ فِي تَفْسِيرِهِ عَنْ جَابِرٍ عَنْ اَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ وَ عَنِ الْكَلْبِيِّ عَنْ اَبِي صَالِحٍ عَنِ اِبْنِ عَبَّاسٍ وَ ذَكَرَهُ اِبْرَاهِيمُ الثَّقَفِيُّ عَنِ اِبْنِ عَبَّاسٍ وَ السُّدِّيِّ وَ جَعْفَرِ بْنِ مُحَمَّدٍ عَنْ اَبِيهِ عَلَيْهِ السَّلاَمُ :.","translation":"","aligned_body":"TAG_OPEN:quranic_text يٰا اَيُّهَا الَّذِينَ امَنُوا اِتَّقُوا اللّٰهَ وَ كُونُوا مَعَ الصّٰادِقِينَ TAG_CLOSE:quranic_text TAG_OPEN:footnote التوبة ۱۱۹ TAG_CLOSE:footnote اَيْ كُونُوا مَعَ عَلِيِّ بْنِ اَبِي طَالِبٍ ذَكَرَهُ الثَّعْلَبِيُّ فِي تَفْسِيرِهِ عَنْ جَابِرٍ عَنْ اَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ وَ عَنِ الْكَلْبِيِّ عَنْ اَبِي صَالِحٍ عَنِ اِبْنِ عَبَّاسٍ وَ ذَكَرَهُ اِبْرَاهِيمُ الثَّقَفِيُّ عَنِ اِبْنِ عَبَّاسٍ وَ السُّدِّيِّ وَ جَعْفَرِ بْنِ مُحَمَّدٍ عَنْ اَبِيهِ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كونوا","display":"كُونُوا"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"الصادقين","display":"الصّٰادِقِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۱۱۹","display":"۱۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","toke