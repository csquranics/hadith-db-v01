{"members":[{"header_text":" 115 - وَ عَنِ اِبْنِ أَسْبَاطٍ عَنْ أَبِي اَلْحَسَنِ اَلرِّضَا عَلَيْهِ اَلسَّلاَمُ قَالَ:","body_text":"كَانَ فِي الْكَنْزِ الَّذِي قَالَ اللَّهُ <quranic_text>«وَ كٰانَ تَحْتَهُ كَنْزٌ لَهُمٰا»</quranic_text> <footnote>[الكهف۸۲]</footnote> لَوْحٌ مِنْ ذَهَبٍ فِيهِ: بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ لاَ اِلَهَ اِلاَّ اللَّهُ مُحَمَّدٌ رَسُولُ اللَّهِ، عَجِبْتُ لِمَنْ اَيْقَنَ بِالْمَوْتِ كَيْفَ يَفْرَحُ؟ (الحديث).","translation":"","aligned_body":"كَانَ فِي الْكَنْزِ الَّذِي قَالَ اللَّهُ TAG_OPEN:quranic_text وَ كٰانَ تَحْتَهُ كَنْزٌ لَهُمٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الكهف ۸۲ TAG_CLOSE:footnote لَوْحٌ مِنْ ذَهَبٍ فِيهِ بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ لاَ اِلَهَ اِلاَّ اللَّهُ مُحَمَّدٌ رَسُولُ اللَّهِ عَجِبْتُ لِمَنْ اَيْقَنَ بِالْمَوْتِ كَيْفَ يَفْرَحُ الحديث"}],"body_consensus_columns":[{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الكنز","display":"الْكَنْزِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"تحته","display":"تَحْتَهُ"},{"kind":"word","token":"كنز","display":"كَنْزٌ"},{"kind":"word","token":"لهما","display":"لَهُمٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","token":"۸۲","display":"۸۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"لوح","display":"لَوْحٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ذهب","display":"ذَهَبٍ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"الرحمن","display