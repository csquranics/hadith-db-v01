{"members":[{"header_text":" وَ بِإِسْنَادِهِ عَنْ  جَعْفَرِ بْنِ بَشِيرٍ عَنْ  مُعَلًّى أَبِي عُثْمَانَ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ</teller> : ","body_text":"سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«فَمَنْ تَصَدَّقَ بِهِ فَهُوَ كَفّٰارَةٌ لَهُ»</quranic_text> <footnote>[المائدة۴۵]</footnote> قَالَ يُكَفَّرُ عَنْهُ مِنْ ذُنُوبِهِ عَلَي قَدْرِ مَا عَفَا عَنِ الْعَمْدِ وَ فِي الْعَمْدِ يُقْتَلُ الرَّجُلُ بِالرَّجُلِ اِلاَّ اَنْ يَعْفُوَ اَوْ يَقْبَلَ الدِّيَةَ وَ لَهُ مَا تَرَاضَوْا عَلَيْهِ الْحَدِيثَ.","translation":"","aligned_body":"سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text فَمَنْ تَصَدَّقَ بِهِ فَهُوَ كَفّٰارَةٌ لَهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۴۵ TAG_CLOSE:footnote قَالَ يُكَفَّرُ عَنْهُ مِنْ ذُنُوبِهِ عَلَي قَدْرِ مَا عَفَا عَنِ الْعَمْدِ وَ فِي الْعَمْدِ يُقْتَلُ الرَّجُلُ بِالرَّجُلِ اِلاَّ اَنْ يَعْفُوَ اَوْ يَقْبَلَ الدِّيَةَ وَ لَهُ مَا تَرَاضَوْا عَلَيْهِ الْحَدِيثَ"}],"body_consensus_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"تصدق","display":"تَصَدَّقَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"كفاره","display":"كَفّٰارَةٌ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۴۵","display":"۴۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ي