{"members":[{"header_text":" عَنْ  حَنَانِ بْنِ سَدِيرٍ عَنْ  أَبِيهِ عَنْ<teller> أَبِي جَعْفَرٍ عَلَيْهِ اَلسَّلاَمُ</teller> قَالَ: سَمِعْتُهُ يَقُولُ","body_text":"فِي قَوْلِ اللَّهِ تَبَارَكَ وَ تَعَالَي: <quranic_text>«اِنَّمٰا اَنْتَ مُنْذِرٌ وَ لِكُلِّ قَوْمٍ هٰادٍ»</quranic_text> <footnote>[الرعد۷]</footnote> فَقَالَ: رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ الْمُنْذِرُ وَ عَلِيٌّ الْهَادِي، وَ كُلُّ اِمَامٍ هَادٍ لِلْقَرْنِ الَّذِي هُوَ فِيهِ.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ تَبَارَكَ وَ تَعَالَي TAG_OPEN:quranic_text اِنَّمٰا اَنْتَ مُنْذِرٌ وَ لِكُلِّ قَوْمٍ هٰادٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۷ TAG_CLOSE:footnote فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ الْمُنْذِرُ وَ عَلِيٌّ الْهَادِي وَ كُلُّ اِمَامٍ هَادٍ لِلْقَرْنِ الَّذِي هُوَ فِيهِ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"منذر","display":"مُنْذِرٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"قوم","display":"قَوْمٍ"},{"kind":"word","token":"هاد","display":"هٰادٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display