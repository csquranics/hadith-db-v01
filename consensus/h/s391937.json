{"members":[{"header_text":" فِي  تَفْسِيرِ  عَلِيِّ بْنِ إِبْرَاهِيمَ :","body_text":"قَوْلُهُ، <quranic_text>«يَوْمَ يَجْمَعُ اللّٰهُ الرُّسُلَ فَيَقُولُ مٰا ذٰا اُجِبْتُمْ»</quranic_text> <footnote>[المائدة۱۰۹]</footnote> فَاِنَّهُ حَدَّثَنِي اَبِي عَنِ الْحَسَنِ بْنِ مَحْبُوبٍ عَنِ الْعَلاَ عَنْ مُحَمَّدٍ عَنْ اَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ قَالَ: مَا ذَا اُجِبْتُمْ فِي اَوْصِيَائِكُمْ فَيَقُولُونَ لاَ عِلْمَ لَنَا بِمَا فَعَلُوا بَعْدَنَا بِهِمْ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text يَوْمَ يَجْمَعُ اللّٰهُ الرُّسُلَ فَيَقُولُ مٰا ذٰا اُجِبْتُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۱۰۹ TAG_CLOSE:footnote فَاِنَّهُ حَدَّثَنِي اَبِي عَنِ الْحَسَنِ بْنِ مَحْبُوبٍ عَنِ الْعَلاَ عَنْ مُحَمَّدٍ عَنْ اَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ قَالَ مَا ذَا اُجِبْتُمْ فِي اَوْصِيَائِكُمْ فَيَقُولُونَ لاَ عِلْمَ لَنَا بِمَا فَعَلُوا بَعْدَنَا بِهِمْ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"يجمع","display":"يَجْمَعُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"الرسل","display":"الرُّسُلَ"},{"kind":"word","token":"فيقول","display":"فَيَقُولُ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ذا","display":"ذٰا"},{"kind":"word","token":"اجبتم","display":"اُجِبْتُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۱۰۹","display":"۱۰۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"حدثني","display":"حَدَّثَنِي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"محبوب","display":