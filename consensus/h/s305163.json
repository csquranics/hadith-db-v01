{"members":[{"header_text":" عَنْ  عَمَّارِ بْنِ مَرْوَانَ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> قَالَ:","body_text":"سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ <quranic_text>«اِنْ تَرَكَ خَيْراً الْوَصِيَّةُ»</quranic_text> <footnote>[البقرة۱۸۰]</footnote> قَالَ: حَقٌّ جَعَلَهُ اللَّهُ فِي اَمْوَالِ النَّاسِ لِصَاحِبِ هَذَا الْاَمْرِ، قَالَ: قُلْتُ: لِذَلِكَ حَدٌّ مَحْدُودٌ قَالَ: نَعَمْ قَالَ قُلْتُ: كَمْ قَالَ: اَدْنَاهُ السُّدُسُ وَ اَكْثَرُهُ الثُّلُثُ.","translation":"","aligned_body":"سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ TAG_OPEN:quranic_text اِنْ تَرَكَ خَيْراً الْوَصِيَّةُ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۸۰ TAG_CLOSE:footnote قَالَ حَقٌّ جَعَلَهُ اللَّهُ فِي اَمْوَالِ النَّاسِ لِصَاحِبِ هَذَا الْاَمْرِ قَالَ قُلْتُ لِذَلِكَ حَدٌّ مَحْدُودٌ قَالَ نَعَمْ قَالَ قُلْتُ كَمْ قَالَ اَدْنَاهُ السُّدُسُ وَ اَكْثَرُهُ الثُّلُثُ"}],"body_consensus_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"ترك","display":"تَرَكَ"},{"kind":"word","token":"خيرا","display":"خَيْراً"},{"kind":"word","token":"الوصيه","display":"الْوَصِيَّةُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۸۰","display":"۱۸۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"حق","display":"حَقٌّ"},{"kind":"word","token":"جعله","display":"جَعَلَهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اموال","display":"اَمْوَالِ"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"word","token":"لصاحب","display":"لِصَاحِبِ"},{"kind":"word","toke