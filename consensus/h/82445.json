{"members":[{"header_text":" فِقْهُ <teller> اَلرِّضَا، عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"اِنْ خَطَبَ اِلَيْكَ رَجُلٌ رَضِيتَ دِينَهُ وَ خُلُقَهُ فَزَوِّجْهُ وَ لاَ يَمْنَعْكَ فَقْرُهُ وَ فَاقَتُهُ قَالَ اللَّهُ تَعَالَي <quranic_text>«وَ اِنْ يَتَفَرَّقٰا يُغْنِ اللّٰهُ كُلاًّ مِنْ سَعَتِهِ»</quranic_text> <footnote>[النساء۱۳۰]</footnote> وَ قَالَ <quranic_text>«اِنْ يَكُونُوا فُقَرٰاءَ يُغْنِهِمُ اللّٰهُ مِنْ فَضْلِهِ وَ اللّٰهُ وٰاسِعٌ عَلِيمٌ»</quranic_text> <footnote>[النور۳۲]</footnote> .","translation":"","aligned_body":"اِنْ خَطَبَ اِلَيْكَ رَجُلٌ رَضِيتَ دِينَهُ وَ خُلُقَهُ فَزَوِّجْهُ وَ لاَ يَمْنَعْكَ فَقْرُهُ وَ فَاقَتُهُ قَالَ اللَّهُ تَعَالَي TAG_OPEN:quranic_text وَ اِنْ يَتَفَرَّقٰا يُغْنِ اللّٰهُ كُلاًّ مِنْ سَعَتِهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۳۰ TAG_CLOSE:footnote وَ قَالَ TAG_OPEN:quranic_text اِنْ يَكُونُوا فُقَرٰاءَ يُغْنِهِمُ اللّٰهُ مِنْ فَضْلِهِ وَ اللّٰهُ وٰاسِعٌ عَلِيمٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote النور ۳۲ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"خطب","display":"خَطَبَ"},{"kind":"word","token":"اليك","display":"اِلَيْكَ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"رضيت","display":"رَضِيتَ"},{"kind":"word","token":"دينه","display":"دِينَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"خلقه","display":"خُلُقَهُ"},{"kind":"word","token":"فزوجه","display":"فَزَوِّجْهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يمنعك","display":"يَمْنَعْكَ"},{"kind":"word","token":"فقره","display":"فَقْرُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فاقته","display":"فَاقَتُهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","toke