{"members":[{"header_text":" عَنْهُ عَنْ  أَبِيهِ  عَمَّنْ ذَكَرَهُ عَنْ  حَنَانِ بْنِ أَبِي عَلِيٍّ عَنْ  ضُرَيْسٍ اَلْكُنَاسِيِّ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ <quranic_text>«وَ هُدُوا اِلَي الطَّيِّبِ مِنَ الْقَوْلِ وَ هُدُوا اِليٰ صِرٰاطِ الْحَمِيدِ»</quranic_text> <footnote>[الحج۲۴]</footnote> فَقَالَ هُوَ وَ اللَّهِ هَذَا الْاَمْرُ الَّذِي اَنْتُمْ عَلَيْهِ.","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ TAG_OPEN:quranic_text وَ هُدُوا اِلَي الطَّيِّبِ مِنَ الْقَوْلِ وَ هُدُوا اِليٰ صِرٰاطِ الْحَمِيدِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحج ۲۴ TAG_CLOSE:footnote فَقَالَ هُوَ وَ اللَّهِ هَذَا الْاَمْرُ الَّذِي اَنْتُمْ عَلَيْهِ"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هدوا","display":"هُدُوا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الطيب","display":"الطَّيِّبِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"القول","display":"الْقَوْلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هدوا","display":"هُدُوا"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"صراط","display":"صِرٰاطِ"},{"kind":"word","token":"الحميد","display":"الْحَمِيدِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۲۴