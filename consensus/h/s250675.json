{"members":[{"header_text":" فس،  [تفسير  القمي ] ، : ","body_text":" <quranic_text>«وَ مَنْ عٰاقَبَ»</quranic_text> <footnote>[الحج۶۰]</footnote> يَعْنِي رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ <quranic_text>«بِمِثْلِ مٰا عُوقِبَ بِهِ»</quranic_text> <footnote>[الحج۶۰]</footnote> يَعْنِي حِينَ اَرَادُوا اَنْ يَقْتُلُوهُ <quranic_text>«ثُمَّ بُغِيَ عَلَيْهِ لَيَنْصُرَنَّهُ اللّٰهُ»</quranic_text> <footnote>[الحج۶۰]</footnote> بِالْقَائِمِ مِنْ وُلْدِهِ عَلَيْهِ السَّلاَمُ.","translation":"","aligned_body":"TAG_OPEN:quranic_text وَ مَنْ عٰاقَبَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحج ۶۰ TAG_CLOSE:footnote يَعْنِي رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ TAG_OPEN:quranic_text بِمِثْلِ مٰا عُوقِبَ بِهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحج ۶۰ TAG_CLOSE:footnote يَعْنِي حِينَ اَرَادُوا اَنْ يَقْتُلُوهُ TAG_OPEN:quranic_text ثُمَّ بُغِيَ عَلَيْهِ لَيَنْصُرَنَّهُ اللّٰهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحج ۶۰ TAG_CLOSE:footnote بِالْقَائِمِ مِنْ وُلْدِهِ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عاقب","display":"عٰاقَبَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۶۰","display":"۶۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بمثل","display":"بِمِثْلِ"},{"kind":"word","token":"ما","display":"مٰا"