{"members":[{"header_text":" وَ عَنْ  يَعْقُوبَ بْنِ يَزِيدَ عَنِ  اِبْنِ أَبِي عُمَيْرٍ عَنْ  هِشَامِ بْنِ سَالِمٍ عَنْ  زُرَارَةَ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ تَعَالَي <quranic_text>«فَسْئَلُوا»</quranic_text> <footnote>[النحل۴۳]</footnote> الْايَةَ مَنْ هُمْ قَالَ نَحْنُ هُمْ قَالَ قُلْتُ عَلَيْنَا اَنْ نَسْاَلَكُمْ قَالَ نَعَمْ قُلْتُ فَعَلَيْكُمْ اَنْ تُجِيبُونَا قَالَ ذَاكَ اِلَيْنَا.","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ تَعَالَي TAG_OPEN:quranic_text فَسْئَلُوا TAG_CLOSE:quranic_text TAG_OPEN:footnote النحل ۴۳ TAG_CLOSE:footnote الْايَةَ مَنْ هُمْ قَالَ نَحْنُ هُمْ قَالَ قُلْتُ عَلَيْنَا اَنْ نَسْاَلَكُمْ قَالَ نَعَمْ قُلْتُ فَعَلَيْكُمْ اَنْ تُجِيبُونَا قَالَ ذَاكَ اِلَيْنَا"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فسئلوا","display":"فَسْئَلُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النحل","display":"النحل"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"قال