{"members":[{"header_text":" وَ عَنْ<teller> عَلِيٍّ صَلَوَاتُ اللَّهِ عَلَيْهِ</teller> أَنَّهُ قَالَ :","body_text":"فِي قَوْلِ اللَّهِ تَعَالَي <quranic_text>«ثُمَّ لْيَقْضُوا تَفَثَهُمْ وَ لْيُوفُوا نُذُورَهُمْ وَ لْيَطَّوَّفُوا بِالْبَيْتِ الْعَتِيقِ»</quranic_text> <footnote>[الحج۲۹]</footnote> قَالَ التَّفَثُ الرَّمْيُ وَ الْحَلْقُ وَ النُّذُورُ مَنْ نَذَرَ اَنْ يَمْشِيَ وَ الطَّوَافُ هُوَ طَوَافُ الزِّيَارَةِ بَعْدَ الذَّبْحِ وَ الْحَلْقِ يَوْمَ النَّحْرِ وَ هَذَا الطَّوَافُ هُوَ طَوَافٌ وَاجِبٌ.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ تَعَالَي TAG_OPEN:quranic_text ثُمَّ لْيَقْضُوا تَفَثَهُمْ وَ لْيُوفُوا نُذُورَهُمْ وَ لْيَطَّوَّفُوا بِالْبَيْتِ الْعَتِيقِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحج ۲۹ TAG_CLOSE:footnote قَالَ التَّفَثُ الرَّمْيُ وَ الْحَلْقُ وَ النُّذُورُ مَنْ نَذَرَ اَنْ يَمْشِيَ وَ الطَّوَافُ هُوَ طَوَافُ الزِّيَارَةِ بَعْدَ الذَّبْحِ وَ الْحَلْقِ يَوْمَ النَّحْرِ وَ هَذَا الطَّوَافُ هُوَ طَوَافٌ وَاجِبٌ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"ليقضوا","display":"لْيَقْضُوا"},{"kind":"word","token":"تفثهم","display":"تَفَثَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ليوفوا","display":"لْيُوفُوا"},{"kind":"word","token":"نذورهم","display":"نُذُورَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ليطوفوا","display":"لْيَطَّوَّفُوا"},{"kind":"word","token":"بالبيت","display":"بِالْبَيْتِ"},{"kind":"word","token":"العتيق","display":"الْعَتِيقِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"w