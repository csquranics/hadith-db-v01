{"members":[{"header_text":"<teller> اَلْإِمَامُ أَبُو مُحَمَّدٍ اَلْعَسْكَرِيُّ عَلَيْهِ السَّلاَمُ</teller> فِي  تَفْسِيرِهِ : ","body_text":"اِعْلَمُوا اَنَّ غَيْبَتَكُمْ لِاَخِيكُمُ الْمُؤْمِنِ مِنْ شِيعَةِ الِ مُحَمَّدٍ عَلَيْهِمُ السَّلاَمُ اَعْظَمُ فِي التَّحْرِيمِ مِنَ الْمَيْتَةِ قَالَ اللَّهُ عَزَّ وَ جَلَّ <quranic_text>«وَ لاٰ يَغْتَبْ بَعْضُكُمْ بَعْضاً اَ يُحِبُّ اَحَدُكُمْ اَنْ يَاْكُلَ لَحْمَ اَخِيهِ مَيْتاً فَكَرِهْتُمُوهُ»</quranic_text> <footnote>[الحجرات۱۲]</footnote> .","translation":"","aligned_body":"اِعْلَمُوا اَنَّ غَيْبَتَكُمْ لِاَخِيكُمُ الْمُؤْمِنِ مِنْ شِيعَةِ الِ مُحَمَّدٍ عَلَيْهِمُ السَّلاَمُ اَعْظَمُ فِي التَّحْرِيمِ مِنَ الْمَيْتَةِ قَالَ اللَّهُ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ لاٰ يَغْتَبْ بَعْضُكُمْ بَعْضاً اَ يُحِبُّ اَحَدُكُمْ اَنْ يَاْكُلَ لَحْمَ اَخِيهِ مَيْتاً فَكَرِهْتُمُوهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحجرات ۱۲ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"اعلموا","display":"اِعْلَمُوا"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"غيبتكم","display":"غَيْبَتَكُمْ"},{"kind":"word","token":"لاخيكم","display":"لِاَخِيكُمُ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شيعه","display":"شِيعَةِ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اعظم","display":"اَعْظَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"التحريم","display":"التَّحْرِيمِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الميته","display":"الْمَيْتَةِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","displa