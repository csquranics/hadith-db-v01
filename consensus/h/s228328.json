{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«بُهْتٰاناً عَظِيماً»</quranic_text> <footnote>[النساء۱۵۶]</footnote> اَيْ قَوْلُهُمْ اِنَّهَا فَجَرَتْ قَوْلُهُ: <quranic_text>«وَ قَوْلِهِمْ اِنّٰا قَتَلْنَا الْمَسِيحَ »</quranic_text> <footnote>[النساء۱۵۷]</footnote> لَمَّا رَفَعَهُ اللَّهُ اِلَيْهِ <quranic_text>«وَ مٰا قَتَلُوهُ وَ مٰا صَلَبُوهُ وَ لٰكِنْ شُبِّهَ لَهُمْ»</quranic_text> <footnote>[النساء۱۵۷]</footnote> .","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text بُهْتٰاناً عَظِيماً TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۵۶ TAG_CLOSE:footnote اَيْ قَوْلُهُمْ اِنَّهَا فَجَرَتْ قَوْلُهُ TAG_OPEN:quranic_text وَ قَوْلِهِمْ اِنّٰا قَتَلْنَا الْمَسِيحَ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۵۷ TAG_CLOSE:footnote لَمَّا رَفَعَهُ اللَّهُ اِلَيْهِ TAG_OPEN:quranic_text وَ مٰا قَتَلُوهُ وَ مٰا صَلَبُوهُ وَ لٰكِنْ شُبِّهَ لَهُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۵۷ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بهتانا","display":"بُهْتٰاناً"},{"kind":"word","token":"عظيما","display":"عَظِيماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۵۶","display":"۱۵۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"قولهم","display":"قَوْلُهُمْ"},{"kind":"word","token":"انها","display":"اِنَّهَا"},{"kind":"word","token":"فجرت","display":"فَجَرَتْ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قولهم","display":"قَوْلِهِمْ"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"قتلنا","display":"قَتَلْنَا"},{"kind":"word","token":"المسيح","display"