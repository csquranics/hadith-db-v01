{"members":[{"header_text":" عَنْ  مُحَمَّدٍ عَنْ <teller> أَحَدِهِمَا</teller> : ","body_text":"اَنَّهُ سُئِلَ عَنْ قَوْلِهِ <quranic_text>«يَوْمَ نَدْعُوا كُلَّ اُنٰاسٍ بِاِمٰامِهِمْ»</quranic_text> <footnote>[الاسراء۷۱]</footnote> فَقَالَ: مَا كَانُوا يَاْتَمُّونَ بِهِ فِي الدُّنْيَا، وَ يُؤْتَي بِالشَّمْسِ وَ الْقَمَرِ فَتُقْذَفَانِ فِي جَهَنَّمَ وَ مَنْ كَانَ يَعْبُدُهُمَا.","translation":"","aligned_body":"اَنَّهُ سُئِلَ عَنْ قَوْلِهِ TAG_OPEN:quranic_text يَوْمَ نَدْعُوا كُلَّ اُنٰاسٍ بِاِمٰامِهِمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الاسراء ۷۱ TAG_CLOSE:footnote فَقَالَ مَا كَانُوا يَاْتَمُّونَ بِهِ فِي الدُّنْيَا وَ يُؤْتَي بِالشَّمْسِ وَ الْقَمَرِ فَتُقْذَفَانِ فِي جَهَنَّمَ وَ مَنْ كَانَ يَعْبُدُهُمَا"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"ندعوا","display":"نَدْعُوا"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"اناس","display":"اُنٰاسٍ"},{"kind":"word","token":"بامامهم","display":"بِاِمٰامِهِمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۷۱","display":"۷۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"ياتمون","display":"يَاْتَمُّونَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الدنيا","display":"الدُّنْيَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يؤتي","display":"يُؤْتَي"},{"kind":"word","token":"بالشمس","display":"بِالشَّمْسِ"},{"kind"