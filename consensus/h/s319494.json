{"members":[{"header_text":" وَ عَنْ<teller> جَعْفَرِ بْنِ مُحَمَّدٍ صَلَوَاتُ اللَّهِ عَلَيْهِ</teller> أَنَّهُ قَالَ :","body_text":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«اِنْ تُبْدُوا الصَّدَقٰاتِ فَنِعِمّٰا هِيَ وَ اِنْ تُخْفُوهٰا وَ تُؤْتُوهَا الْفُقَرٰاءَ فَهُوَ خَيْرٌ لَكُمْ»</quranic_text> <footnote>[البقرة۲۷۱]</footnote> الْايَةَ قَالَ لَيْسَ ذَلِكَ بِالزَّكَاةِ وَ لَكِنَّهُ الرَّجُلُ يَتَصَدَّقُ لِنَفْسِهِ وَ اِنَّمَا كَانَتِ الزَّكَاةُ عَلاَنِيَةً لَيْسَتْ بِسِرٍّ.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text اِنْ تُبْدُوا الصَّدَقٰاتِ فَنِعِمّٰا هِيَ وَ اِنْ تُخْفُوهٰا وَ تُؤْتُوهَا الْفُقَرٰاءَ فَهُوَ خَيْرٌ لَكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۷۱ TAG_CLOSE:footnote الْايَةَ قَالَ لَيْسَ ذَلِكَ بِالزَّكَاةِ وَ لَكِنَّهُ الرَّجُلُ يَتَصَدَّقُ لِنَفْسِهِ وَ اِنَّمَا كَانَتِ الزَّكَاةُ عَلاَنِيَةً لَيْسَتْ بِسِرٍّ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"تبدوا","display":"تُبْدُوا"},{"kind":"word","token":"الصدقات","display":"الصَّدَقٰاتِ"},{"kind":"word","token":"فنعما","display":"فَنِعِمّٰا"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"تخفوها","display":"تُخْفُوهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تؤتوها","display":"تُؤْتُوهَا"},{"kind":"word","token":"الفقراء","display":"الْفُقَرٰاءَ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"خير","display":"خَيْرٌ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"tag_close","ta