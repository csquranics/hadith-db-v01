{"members":[{"header_text":" قَالَ<teller> أَمِيرُ اَلْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ</teller> :","body_text":" <quranic_text>«شَهِيدَيْنِ مِنْ رِجٰالِكُمْ»</quranic_text> <footnote>[البقرة۲۸۲]</footnote> قَالَ: مِنْ اَحْرَارِكُمْ مِنَ الْمُسْلِمِينَ [اَلْعُدُولِ]. قَالَ عَلَيْهِ السَّلاَمُ: اِسْتَشْهِدُوهُمْ لِتَحُوطُوا بِهِمْ اَدْيَانَكُمْ وَ اَمْوَالَكُمْ وَ لِتَسْتَعْمِلُوا اَدَبَ اللَّهِ وَ وَصِيَّتَهُ، فَاِنَّ فِيهِمَا النَّفْعَ وَ الْبَرَكَةَ، وَ لاَ تُخَالِفُوهُمَا فَيَلْحَقَكُمُ النَّدَمُ، حَيْثُ لاَ يَنْفَعُكُمُ النَّدَمُ.","translation":"","aligned_body":"TAG_OPEN:quranic_text شَهِيدَيْنِ مِنْ رِجٰالِكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۸۲ TAG_CLOSE:footnote قَالَ مِنْ اَحْرَارِكُمْ مِنَ الْمُسْلِمِينَ اَلْعُدُولِ قَالَ عَلَيْهِ السَّلاَمُ اِسْتَشْهِدُوهُمْ لِتَحُوطُوا بِهِمْ اَدْيَانَكُمْ وَ اَمْوَالَكُمْ وَ لِتَسْتَعْمِلُوا اَدَبَ اللَّهِ وَ وَصِيَّتَهُ فَاِنَّ فِيهِمَا النَّفْعَ وَ الْبَرَكَةَ وَ لاَ تُخَالِفُوهُمَا فَيَلْحَقَكُمُ النَّدَمُ حَيْثُ لاَ يَنْفَعُكُمُ النَّدَمُ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"شهيدين","display":"شَهِيدَيْنِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"رجالكم","display":"رِجٰالِكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۸۲","display":"۲۸۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"احراركم","display":"اَحْرَارِكُمْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المسلمين","display":"الْمُسْلِمِينَ"},{"kind":"word","token":"العدول","display":"اَلْعُدُولِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"استشهدوهم","dis