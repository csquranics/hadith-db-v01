{"members":[{"header_text":"","body_text":"وَ اَمَّا قَوْلُهُ <quranic_text>«اَ تَاْمُرُونَ النّٰاسَ بِالْبِرِّ وَ تَنْسَوْنَ اَنْفُسَكُمْ»</quranic_text> <footnote>[البقرة۴۴]</footnote> قَالَ نَزَلَتْ فِي الْقُصَّاصِ وَ الْخُطَّابِ وَ هُوَ قَوْلُ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ وَ عَلَي كُلِّ مِنْبَرٍ مِنْهُمْ خَطِيبٌ مِصْقَعٌ، يَكْذِبُ عَلَي اللَّهِ وَ عَلَي رَسُولِهِ وَ عَلَي كِتَابِهِ.","translation":"","aligned_body":"وَ اَمَّا قَوْلُهُ TAG_OPEN:quranic_text اَ تَاْمُرُونَ النّٰاسَ بِالْبِرِّ وَ تَنْسَوْنَ اَنْفُسَكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۴۴ TAG_CLOSE:footnote قَالَ نَزَلَتْ فِي الْقُصَّاصِ وَ الْخُطَّابِ وَ هُوَ قَوْلُ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ وَ عَلَي كُلِّ مِنْبَرٍ مِنْهُمْ خَطِيبٌ مِصْقَعٌ يَكْذِبُ عَلَي اللَّهِ وَ عَلَي رَسُولِهِ وَ عَلَي كِتَابِهِ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"تامرون","display":"تَاْمُرُونَ"},{"kind":"word","token":"الناس","display":"النّٰاسَ"},{"kind":"word","token":"بالبر","display":"بِالْبِرِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تنسون","display":"تَنْسَوْنَ"},{"kind":"word","token":"انفسكم","display":"اَنْفُسَكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۴۴","display":"۴۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القصاص","display":"الْقُصَّاصِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الخطاب","display":"الْخُطَّابِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","to