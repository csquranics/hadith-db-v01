{"members":[{"header_text":"<teller> اَلْبَاقِرُ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"اَلْحَسَنَةُ وَلاَيَةُ عَلِيٍّ عَلَيْهِ السَّلاَمُ وَ حُبُّهُ وَ السَّيِّئَةُ عَدَاوَتُهُ وَ بُغْضُهُ وَ لاَ يُرْفَعُ مَعَهَا عَمَلٌ وَ قَالَ عَلَيْهِ السَّلاَمُ <quranic_text>«وَ مَنْ يَقْتَرِفْ حَسَنَةً نَزِدْ لَهُ فِيهٰا حُسْناً»</quranic_text> <footnote>[الشوري۲۳]</footnote> قَالَ الْمَوَدَّةُ لِعَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ .","translation":"","aligned_body":"اَلْحَسَنَةُ وَلاَيَةُ عَلِيٍّ عَلَيْهِ السَّلاَمُ وَ حُبُّهُ وَ السَّيِّئَةُ عَدَاوَتُهُ وَ بُغْضُهُ وَ لاَ يُرْفَعُ مَعَهَا عَمَلٌ وَ قَالَ عَلَيْهِ السَّلاَمُ TAG_OPEN:quranic_text وَ مَنْ يَقْتَرِفْ حَسَنَةً نَزِدْ لَهُ فِيهٰا حُسْناً TAG_CLOSE:quranic_text TAG_OPEN:footnote الشوري ۲۳ TAG_CLOSE:footnote قَالَ الْمَوَدَّةُ لِعَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"الحسنه","display":"اَلْحَسَنَةُ"},{"kind":"word","token":"ولايه","display":"وَلاَيَةُ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حبه","display":"حُبُّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السيئه","display":"السَّيِّئَةُ"},{"kind":"word","token":"عداوته","display":"عَدَاوَتُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بغضه","display":"بُغْضُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يرفع","display":"يُرْفَعُ"},{"kind":"word","token":"معها","display":"مَعَهَا"},{"kind":"word","token":"عمل","display":"عَمَلٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word"