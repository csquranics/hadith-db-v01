{"members":[{"header_text":" اَلْمَكَارِمُ : ","body_text":"وَ اِذَا اَرَدْتَ النُّهُوضَ مِنَ التَّعْقِيبِ فَقُلْ <quranic_text>«سُبْحٰانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمّٰا يَصِفُونَ وَ سَلاٰمٌ عَلَي الْمُرْسَلِينَ وَ الْحَمْدُ لِلّٰهِ رَبِّ الْعٰالَمِينَ»</quranic_text> <footnote>[الصافات۱۸۰]</footnote> فَقَدْ رُوِيَ عَنْ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ اَنَّهُ قَالَ مَنْ اَرَادَ اَنْ يَكْتَالَ بِالْمِكْيَالِ الْاَوْفَي فَلْيَكُنْ هَذَا اخِرَ قَوْلِهِ فَاِنَّ لَهُ مِنْ كُلِّ مُسْلِمٍ حَسَنَةً.","translation":"","aligned_body":"وَ اِذَا اَرَدْتَ النُّهُوضَ مِنَ التَّعْقِيبِ فَقُلْ TAG_OPEN:quranic_text سُبْحٰانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمّٰا يَصِفُونَ وَ سَلاٰمٌ عَلَي الْمُرْسَلِينَ وَ الْحَمْدُ لِلّٰهِ رَبِّ الْعٰالَمِينَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الصافات ۱۸۰ TAG_CLOSE:footnote فَقَدْ رُوِيَ عَنْ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ اَنَّهُ قَالَ مَنْ اَرَادَ اَنْ يَكْتَالَ بِالْمِكْيَالِ الْاَوْفَي فَلْيَكُنْ هَذَا اخِرَ قَوْلِهِ فَاِنَّ لَهُ مِنْ كُلِّ مُسْلِمٍ حَسَنَةً"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اردت","display":"اَرَدْتَ"},{"kind":"word","token":"النهوض","display":"النُّهُوضَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"التعقيب","display":"التَّعْقِيبِ"},{"kind":"word","token":"فقل","display":"فَقُلْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سبحان","display":"سُبْحٰانَ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"رب","display":"رَبِّ"},{"kind":"word","token":"العزه","display":"الْعِزَّةِ"},{"kind":"word","token":"عما","display":"عَمّٰا"},{"kind":"word","token":"يصفون","display":"يَصِفُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلام","display":"سَلاٰمٌ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المرسلين","display":"الْمُرْسَلِينَ"},{"kind":"word","token":"و","display":"و