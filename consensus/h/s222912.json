{"members":[{"header_text":" ج،  [الإحتجاج] ، عَنِ  اَلْعَبَّاسِ بْنِ هِلاَلٍ قَالَ:","body_text":"سَاَلْتُ اَبَا الْحَسَنِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«اللّٰهُ نُورُ السَّمٰاوٰاتِ وَ الْاَرْضِ»</quranic_text> <footnote>[النور۳۵]</footnote> فَقَالَ عَلَيْهِ السَّلاَمُ هَادِي مَنْ فِي السَّمَاوَاتِ وَ هَادِي مَنْ فِي الْاَرْضِ.","translation":"","aligned_body":"سَاَلْتُ اَبَا الْحَسَنِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text اللّٰهُ نُورُ السَّمٰاوٰاتِ وَ الْاَرْضِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النور ۳۵ TAG_CLOSE:footnote فَقَالَ عَلَيْهِ السَّلاَمُ هَادِي مَنْ فِي السَّمَاوَاتِ وَ هَادِي مَنْ فِي الْاَرْضِ"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"نور","display":"نُورُ"},{"kind":"word","token":"السماوات","display":"السَّمٰاوٰاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۳۵","display":"۳۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"هادي","disp