{"members":[{"header_text":" وَ  اَلْعَيَّاشِيُّ <teller> عَنْهُ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"اَنَّهُ سُئِلَ عَنْهَا فَقَالَ مَنْسُوخَةٌ قِيلَ وَ مَا نَسَخَهَا قَالَ قَوْلُ اللَّهِ: <quranic_text>«فَاتَّقُوا اللّٰهَ مَا اِسْتَطَعْتُمْ»</quranic_text> <footnote>[التغابن۱۶]</footnote> .","translation":"","aligned_body":"اَنَّهُ سُئِلَ عَنْهَا فَقَالَ مَنْسُوخَةٌ قِيلَ وَ مَا نَسَخَهَا قَالَ قَوْلُ اللَّهِ TAG_OPEN:quranic_text فَاتَّقُوا اللّٰهَ مَا اِسْتَطَعْتُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote التغابن ۱۶ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عنها","display":"عَنْهَا"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"منسوخه","display":"مَنْسُوخَةٌ"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"نسخها","display":"نَسَخَهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاتقوا","display":"فَاتَّقُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"استطعتم","display":"اِسْتَطَعْتُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التغابن","display":"التغابن"},{"kind":"word","token":"۱۶","display":"۱۶"},{"kind":"tag_close","tag_name":"footnote"}]}