{"members":[{"header_text":" وَ عَنْ  صَفْوَانَ عَنْ  عَلاَءٍ عَنْ  مُحَمَّدِ بْنِ مُسْلِمٍ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ جَلَّ وَ عَزَّ <quranic_text>«وَ لَقَدْ اتَيْنٰاكَ سَبْعاً مِنَ الْمَثٰانِي وَ الْقُرْانَ الْعَظِيمَ»</quranic_text> <footnote>[الحجر۸۷]</footnote> قَالَ فَاتِحَةُ الْكِتَابِ مِنْ كُنُوزِ الْجَنَّةِ وَ فِيهَا <quranic_text>«بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ»</quranic_text> <footnote>[الفاتحة۱]</footnote> الْخَبَرَ.","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ جَلَّ وَ عَزَّ TAG_OPEN:quranic_text وَ لَقَدْ اتَيْنٰاكَ سَبْعاً مِنَ الْمَثٰانِي وَ الْقُرْانَ الْعَظِيمَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحجر ۸۷ TAG_CLOSE:footnote قَالَ فَاتِحَةُ الْكِتَابِ مِنْ كُنُوزِ الْجَنَّةِ وَ فِيهَا TAG_OPEN:quranic_text بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الفاتحة ۱ TAG_CLOSE:footnote الْخَبَرَ"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"اتيناك","display":"اتَيْنٰاكَ"},{"kind":"word","token":"سبعا","display":"سَبْعاً"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المثاني","display":"الْمَثٰانِي"},{"kind":"word","token":"و","display":"وَ"},{"