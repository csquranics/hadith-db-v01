{"members":[{"header_text":" وَ عَنْ  عَبْدِ اَللَّهِ بْنِ عَبَّاسٍ عَنْ <teller> رَسُولِ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ وَ آلِهِ</teller> أَنَّهُ قَالَ:","body_text":"مَا مِنْ مُؤْمِنٍ ذَكَرٍ اَوْ اُنْثَي حُرٍّ اَوْ مَمْلُوكٍ اِلاَّ وَ لِلَّهِ عَلَيْهِ حَقٌّ وَاجِبٌ اَنْ يَتَعَلَّمَ مِنَ الْقُرْانِ وَ يَتَفَقَّهَ فِيهِ ثُمَّ قَرَاَ هَذِهِ الْايَةَ <quranic_text>«وَ لٰكِنْ كُونُوا رَبّٰانِيِّينَ بِمٰا كُنْتُمْ تُعَلِّمُونَ الْكِتٰابَ»</quranic_text> <footnote>[العمران۷۹]</footnote> الْايَةَ.","translation":"","aligned_body":"مَا مِنْ مُؤْمِنٍ ذَكَرٍ اَوْ اُنْثَي حُرٍّ اَوْ مَمْلُوكٍ اِلاَّ وَ لِلَّهِ عَلَيْهِ حَقٌّ وَاجِبٌ اَنْ يَتَعَلَّمَ مِنَ الْقُرْانِ وَ يَتَفَقَّهَ فِيهِ ثُمَّ قَرَاَ هَذِهِ الْايَةَ TAG_OPEN:quranic_text وَ لٰكِنْ كُونُوا رَبّٰانِيِّينَ بِمٰا كُنْتُمْ تُعَلِّمُونَ الْكِتٰابَ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۷۹ TAG_CLOSE:footnote الْايَةَ"}],"body_consensus_columns":[{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٍ"},{"kind":"word","token":"ذكر","display":"ذَكَرٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"انثي","display":"اُنْثَي"},{"kind":"word","token":"حر","display":"حُرٍّ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"مملوك","display":"مَمْلُوكٍ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"حق","display":"حَقٌّ"},{"kind":"word","token":"واجب","display":"وَاجِبٌ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتعلم","display":"يَتَعَلَّمَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يتفقه","display":"يَتَفَقَّهَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{