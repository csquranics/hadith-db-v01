{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"ثُمَّ قَالَ لِنَبِيِّهِ (صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ): قُلْ لَهُمْ <quranic_text>«تَعٰالَوْا اَتْلُ مٰا حَرَّمَ رَبُّكُمْ عَلَيْكُمْ اَلاّٰ تُشْرِكُوا بِهِ شَيْئاً وَ بِالْوٰالِدَيْنِ اِحْسٰاناً»</quranic_text> <footnote>[الانعام۱۵۱]</footnote> قَالَ: الْوَالِدَيْنِ رَسُولُ اللَّهِ وَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِمَا السَّلاَمُ.","translation":"","aligned_body":"ثُمَّ قَالَ لِنَبِيِّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ قُلْ لَهُمْ TAG_OPEN:quranic_text تَعٰالَوْا اَتْلُ مٰا حَرَّمَ رَبُّكُمْ عَلَيْكُمْ اَلاّٰ تُشْرِكُوا بِهِ شَيْئاً وَ بِالْوٰالِدَيْنِ اِحْسٰاناً TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۱۵۱ TAG_CLOSE:footnote قَالَ الْوَالِدَيْنِ رَسُولُ اللَّهِ وَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِمَا السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لنبيه","display":"لِنَبِيِّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"تعالوا","display":"تَعٰالَوْا"},{"kind":"word","token":"اتل","display":"اَتْلُ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"حرم","display":"حَرَّمَ"},{"kind":"word","token":"ربكم","display":"رَبُّكُمْ"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"الا","display":"اَلاّٰ"},{"kind":"word","token":"تشركوا","display":"تُشْرِكُوا"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بالوالدين","display":"بِالْوٰالِدَيْنِ"},