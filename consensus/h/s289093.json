{"members":[{"header_text":" عُدَّةُ اَلدَّاعِي ، عَنِ  اَلْفَضْلِ بْنِ أَبِي قُرَّةَ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"مِثْلَهُ ثُمَّ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِيرَاثُ اللَّهِ عَزَّ وَ جَلَّ مِنْ عَبْدِهِ الْمُؤْمِنِ وَلَدٌ يَعْبُدُهُ مِنْ بَعْدِهِ ثُمَّ تَلاَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ ايَةَ زَكَرِيَّا - <quranic_text>«فَهَبْ لِي مِنْ لَدُنْكَ وَلِيًّا يَرِثُنِي وَ يَرِثُ مِنْ الِ يَعْقُوبَ وَ اِجْعَلْهُ رَبِّ رَضِيًّا»</quranic_text> <footnote>[مريم۵]</footnote> .","translation":"","aligned_body":"مِثْلَهُ ثُمَّ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِيرَاثُ اللَّهِ عَزَّ وَ جَلَّ مِنْ عَبْدِهِ الْمُؤْمِنِ وَلَدٌ يَعْبُدُهُ مِنْ بَعْدِهِ ثُمَّ تَلاَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ ايَةَ زَكَرِيَّا - TAG_OPEN:quranic_text فَهَبْ لِي مِنْ لَدُنْكَ وَلِيًّا يَرِثُنِي وَ يَرِثُ مِنْ الِ يَعْقُوبَ وَ اِجْعَلْهُ رَبِّ رَضِيًّا TAG_CLOSE:quranic_text TAG_OPEN:footnote مريم ۵ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"مثله","display":"مِثْلَهُ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"ميراث","display":"مِيرَاثُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عبده","display":"عَبْدِهِ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنِ"},{"kind":"word","token":"ولد","display":"وَلَدٌ"},{"kind":"word