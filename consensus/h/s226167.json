{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ اِذْ اَخَذَ اللّٰهُ»</quranic_text> <footnote>[العمران۸۱]</footnote> الْايَةَ فَاِنَّ اللَّهَ اَخَذَ مِيثَاقَ نَبِيِّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عَلَي الْاَنْبِيَاءِ اَنْ يُؤْمِنُوا بِهِ وَ يَنْصُرُوهُ وَ يُخْبِرُوا اُمَمَهُمْ بِخَبَرِهِ.","translation":"","aligned_body":"TAG_OPEN:quranic_text وَ اِذْ اَخَذَ اللّٰهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۸۱ TAG_CLOSE:footnote الْايَةَ فَاِنَّ اللَّهَ اَخَذَ مِيثَاقَ نَبِيِّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عَلَي الْاَنْبِيَاءِ اَنْ يُؤْمِنُوا بِهِ وَ يَنْصُرُوهُ وَ يُخْبِرُوا اُمَمَهُمْ بِخَبَرِهِ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۸۱","display":"۸۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"ميثاق","display":"مِيثَاقَ"},{"kind":"word","token":"نبيه","display":"نَبِيِّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الانبياء","display":"الْاَنْبِيَاءِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يؤمنوا","display":"يُؤْمِنُوا"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display"