{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ رَتِّلِ الْقُرْانَ تَرْتِيلاً»</quranic_text> <footnote>[المزمل۴]</footnote> قَالَ بَيِّنْهُ تِبْيَاناً وَ لاَ تَنْثُرْهُ نَثْرَ الرَّمْلِ وَ لاَ تَهُذَّهُ هَذَّ الشِّعْرِ وَ لَكِنْ اَقْرِعْ بِهِ الْقُلُوبَ الْقَاسِيَةَ.","translation":"","aligned_body":"وَ رَتِّلِ الْقُرْانَ تَرْتِيلاً المزمل۴ قَالَ بَيِّنْهُ تِبْيَاناً وَ لاَ تَنْثُرْهُ نَثْرَ الرَّمْلِ وَ لاَ تَهُذَّهُ هَذَّ الشِّعْرِ وَ لَكِنْ اَقْرِعْ بِهِ الْقُلُوبَ الْقَاسِيَةَ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رتل","display":"رَتِّلِ"},{"kind":"word","token":"القران","display":"الْقُرْانَ"},{"kind":"word","token":"ترتيلا","display":"تَرْتِيلاً"},{"kind":"word","token":"المزمل۴","display":"المزمل۴"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"بينه","display":"بَيِّنْهُ"},{"kind":"word","token":"تبيانا","display":"تِبْيَاناً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تنثره","display":"تَنْثُرْهُ"},{"kind":"word","token":"نثر","display":"نَثْرَ"},{"kind":"word","token":"الرمل","display":"الرَّمْلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تهذه","display":"تَهُذَّهُ"},{"kind":"word","token":"هذ","display":"هَذَّ"},{"kind":"word","token":"الشعر","display":"الشِّعْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لَكِنْ"},{"kind":"word","token":"اقرع","display":"اَقْرِعْ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"القلوب","display":"الْقُلُوبَ"},{"kind":"word","token":"القاسيه","display":"الْقَاسِيَةَ"}]}