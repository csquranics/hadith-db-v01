{"members":[{"header_text":" ير،  [بصائر الدرجات] ،  أَحْمَدُ عَنِ  اَلْحُسَيْنِ عَنْ  بَعْضِ أَصْحَابِنَا عَنِ  اِبْنِ عَمِيرَةَ عَنِ  اِبْنِ اَلْمُغِيرَةِ قَالَ:","body_text":"كُنَّا عِنْدَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ فَسَاَلَهُ رَجُلٌ عَنْ قَوْلِ اللَّهِ: <quranic_text>«كُلُّ شَيْءٍ هٰالِكٌ اِلاّٰ وَجْهَهُ»</quranic_text> <footnote>[القصص۸۸]</footnote> قَالَ مَا يَقُولُونَ فِيهِ قُلْتُ يَقُولُونَ يَهْلِكُ كُلُّ شَيْءٍ اِلاَّ وَجْهَهُ فَقَالَ يَهْلِكُ كُلُّ شَيْءٍ اِلاَّ وَجْهَهُ الَّذِي يُؤْتَي مِنْهُ وَ نَحْنُ وَجْهُ اللَّهِ الَّذِي يُؤْتَي مِنْهُ.","translation":"","aligned_body":"كُنَّا عِنْدَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ فَسَاَلَهُ رَجُلٌ عَنْ قَوْلِ اللَّهِ TAG_OPEN:quranic_text كُلُّ شَيْءٍ هٰالِكٌ اِلاّٰ وَجْهَهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote القصص ۸۸ TAG_CLOSE:footnote قَالَ مَا يَقُولُونَ فِيهِ قُلْتُ يَقُولُونَ يَهْلِكُ كُلُّ شَيْءٍ اِلاَّ وَجْهَهُ فَقَالَ يَهْلِكُ كُلُّ شَيْءٍ اِلاَّ وَجْهَهُ الَّذِي يُؤْتَي مِنْهُ وَ نَحْنُ وَجْهُ اللَّهِ الَّذِي يُؤْتَي مِنْهُ"}],"body_consensus_columns":[{"kind":"word","token":"كنا","display":"كُنَّا"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فساله","display":"فَسَاَلَهُ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"هالك","display":"هٰالِكٌ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"وجهه","display":"وَجْهَهُ"},{"kind":"tag_close","tag_name":"quranic_text"}