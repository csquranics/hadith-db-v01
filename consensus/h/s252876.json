{"members":[{"header_text":" وَ عَنِ  اِبْنِ عَبَّاسٍ : ","body_text":" <quranic_text>«رَبُّ الْمَشْرِقَيْنِ وَ رَبُّ الْمَغْرِبَيْنِ»</quranic_text> <footnote>[الرحمن۱۷]</footnote> قَالَ لِلشَّمْسِ مَطْلِعٌ فِي الشِّتَاءِ وَ مَغْرِبٌ فِي الشِّتَاءِ وَ مَطْلِعٌ فِي الصَّيْفِ وَ مَغْرِبٌ فِي الصَّيْفِ غَيْرُ مَطْلِعِهَا فِي الشِّتَاءِ وَ غَيْرُ مَغْرِبِهَا فِي الشِّتَاءِ.","translation":"","aligned_body":"TAG_OPEN:quranic_text رَبُّ الْمَشْرِقَيْنِ وَ رَبُّ الْمَغْرِبَيْنِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرحمن ۱۷ TAG_CLOSE:footnote قَالَ لِلشَّمْسِ مَطْلِعٌ فِي الشِّتَاءِ وَ مَغْرِبٌ فِي الشِّتَاءِ وَ مَطْلِعٌ فِي الصَّيْفِ وَ مَغْرِبٌ فِي الصَّيْفِ غَيْرُ مَطْلِعِهَا فِي الشِّتَاءِ وَ غَيْرُ مَغْرِبِهَا فِي الشِّتَاءِ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"رب","display":"رَبُّ"},{"kind":"word","token":"المشرقين","display":"الْمَشْرِقَيْنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رب","display":"رَبُّ"},{"kind":"word","token":"المغربين","display":"الْمَغْرِبَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرحمن","display":"الرحمن"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"للشمس","display":"لِلشَّمْسِ"},{"kind":"word","token":"مطلع","display":"مَطْلِعٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الشتاء","display":"الشِّتَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مغرب","display":"مَغْرِبٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الشتاء","display":"الشِّتَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مطلع","display":"مَطْلِعٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الصيف","display":"الصَّيْفِ"},{"kind":"word","token":"و","display":"وَ"},{"kind"