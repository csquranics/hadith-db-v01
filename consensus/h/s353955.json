{"members":[{"header_text":"","body_text":"قَوْلُهُ تَعَالَي: <quranic_text>«وَ قِفُوهُمْ اِنَّهُمْ مَسْؤُلُونَ»</quranic_text> <footnote>[الصافات۲۴]</footnote> قَالَ اَبُو سَعِيدٍ الْخُدْرِيُّ صَاحِبُ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مَسْئُولُونَ عَنْ وَلاَيَةِ عَلِيِّ بْنِ اَبِي طَالِبٍ .","translation":"","aligned_body":"قَوْلُهُ تَعَالَي TAG_OPEN:quranic_text وَ قِفُوهُمْ اِنَّهُمْ مَسْؤُلُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الصافات ۲۴ TAG_CLOSE:footnote قَالَ اَبُو سَعِيدٍ الْخُدْرِيُّ صَاحِبُ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مَسْئُولُونَ عَنْ وَلاَيَةِ عَلِيِّ بْنِ اَبِي طَالِبٍ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قفوهم","display":"قِفُوهُمْ"},{"kind":"word","token":"انهم","display":"اِنَّهُمْ"},{"kind":"word","token":"مسؤلون","display":"مَسْؤُلُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الصافات","display":"الصافات"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"سعيد","display":"سَعِيدٍ"},{"kind":"word","token":"الخدري","display":"الْخُدْرِيُّ"},{"kind":"word","token":"صاحب","display":"صَاحِبُ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"مسئولون","display":"مَسْئُولُونَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ولايه","display":"وَ