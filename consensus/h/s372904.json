{"members":[{"header_text":"","body_text":"اَللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ كَمَا هَدَيْتَنَا بِهِ اللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ كَمَا اَمَرْتَنَا بِالْاِيمَانِ بِهِ اللَّهُمَّ اِجْعَلْنَا مِمَّنِ اِخْتَرْتَ لِدِينِكَ وَ خَلَقْتَ لِجَنَّتِكَ اللَّهُمَّ <quranic_text>«لاٰ تُزِغْ قُلُوبَنٰا بَعْدَ اِذْ هَدَيْتَنٰا وَ هَبْ لَنٰا مِنْ لَدُنْكَ رَحْمَةً اِنَّكَ اَنْتَ الْوَهّٰابُ»</quranic_text> <footnote>[العمران۸]</footnote> .","translation":"","aligned_body":"اَللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ كَمَا هَدَيْتَنَا بِهِ اللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ كَمَا اَمَرْتَنَا بِالْاِيمَانِ بِهِ اللَّهُمَّ اِجْعَلْنَا مِمَّنِ اِخْتَرْتَ لِدِينِكَ وَ خَلَقْتَ لِجَنَّتِكَ اللَّهُمَّ TAG_OPEN:quranic_text لاٰ تُزِغْ قُلُوبَنٰا بَعْدَ اِذْ هَدَيْتَنٰا وَ هَبْ لَنٰا مِنْ لَدُنْكَ رَحْمَةً اِنَّكَ اَنْتَ الْوَهّٰابُ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۸ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"اللهم","display":"اَللَّهُمَّ"},{"kind":"word","token":"صل","display":"صَلِّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"هديتنا","display":"هَدَيْتَنَا"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"صل","display":"صَلِّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"امرتنا","display":"اَمَرْتَنَا"},{"kind":"word","token":"بالايمان","display":"بِالْاِيمَانِ"},{"kind":"word",