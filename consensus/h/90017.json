{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«اَ رَاَيْتَ الَّذِي يُكَذِّبُ بِالدِّينِ»</quranic_text> <footnote>[الماعون۱]</footnote> قَالَ نَزَلَتْ فِي اَبِي جَهْلٍ وَ كُفَّارِ قُرَيْشٍ <quranic_text>«فَذٰلِكَ الَّذِي يَدُعُّ الْيَتِيمَ»</quranic_text> <footnote>[الماعون۲]</footnote> اَيْ يَدْفَعُهُ يَعْنِي عَنْ حَقِّهِ <quranic_text>«وَ لاٰ يَحُضُّ عَليٰ طَعٰامِ الْمِسْكِينِ»</quranic_text> <footnote>[الماعون۳]</footnote> اَيْ لاَ يَرْغَبُ فِي اِطْعَامِ الْمِسْكِينِ.","translation":"","aligned_body":"TAG_OPEN:quranic_text اَ رَاَيْتَ الَّذِي يُكَذِّبُ بِالدِّينِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الماعون ۱ TAG_CLOSE:footnote قَالَ نَزَلَتْ فِي اَبِي جَهْلٍ وَ كُفَّارِ قُرَيْشٍ TAG_OPEN:quranic_text فَذٰلِكَ الَّذِي يَدُعُّ الْيَتِيمَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الماعون ۲ TAG_CLOSE:footnote اَيْ يَدْفَعُهُ يَعْنِي عَنْ حَقِّهِ TAG_OPEN:quranic_text وَ لاٰ يَحُضُّ عَليٰ طَعٰامِ الْمِسْكِينِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الماعون ۳ TAG_CLOSE:footnote اَيْ لاَ يَرْغَبُ فِي اِطْعَامِ الْمِسْكِينِ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"رايت","display":"رَاَيْتَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يكذب","display":"يُكَذِّبُ"},{"kind":"word","token":"بالدين","display":"بِالدِّينِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الماعون","display":"الماعون"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جهل","display":"جَهْلٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كفار","display":"كُفَّارِ"},{"kind":"word","token":"قريش"