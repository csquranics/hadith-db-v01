{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ تَعَالَي: <quranic_text>«قُلْ هُوَ الْقٰادِرُ عَليٰ اَنْ يَبْعَثَ عَلَيْكُمْ عَذٰاباً مِنْ فَوْقِكُمْ»</quranic_text> <footnote>[الانعام۶۵]</footnote> قَالَ السُّلْطَانُ الْجَائِرُ <quranic_text>«اَوْ مِنْ تَحْتِ اَرْجُلِكُمْ»</quranic_text> <footnote>[الانعام۶۵]</footnote> قَالَ السَّفِلَةُ وَ مَنْ لاَ خَيْرَ فِيهِ <quranic_text>«اَوْ يَلْبِسَكُمْ شِيَعاً»</quranic_text> <footnote>[الانعام۶۵]</footnote> قَالَ الْعَصَبِيَّةُ <quranic_text>«وَ يُذِيقَ بَعْضَكُمْ بَاْسَ بَعْضٍ»</quranic_text> <footnote>[الانعام۶۵]</footnote> قَالَ سُوءُ الْجِوَارِ.","translation":"","aligned_body":"قَوْلُهُ تَعَالَي TAG_OPEN:quranic_text قُلْ هُوَ الْقٰادِرُ عَليٰ اَنْ يَبْعَثَ عَلَيْكُمْ عَذٰاباً مِنْ فَوْقِكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۶۵ TAG_CLOSE:footnote قَالَ السُّلْطَانُ الْجَائِرُ TAG_OPEN:quranic_text اَوْ مِنْ تَحْتِ اَرْجُلِكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۶۵ TAG_CLOSE:footnote قَالَ السَّفِلَةُ وَ مَنْ لاَ خَيْرَ فِيهِ TAG_OPEN:quranic_text اَوْ يَلْبِسَكُمْ شِيَعاً TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۶۵ TAG_CLOSE:footnote قَالَ الْعَصَبِيَّةُ TAG_OPEN:quranic_text وَ يُذِيقَ بَعْضَكُمْ بَاْسَ بَعْضٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۶۵ TAG_CLOSE:footnote قَالَ سُوءُ الْجِوَارِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"القادر","display":"الْقٰادِرُ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يبعث","display":"يَبْعَثَ"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"عذابا","display":"عَذٰاباً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"فوقكم","d