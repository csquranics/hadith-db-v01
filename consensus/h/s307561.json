{"members":[{"header_text":" عَنْ  إِدْرِيسَ اَلْقُمِّيِّ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنِ <quranic_text>«الْبٰاقِيٰاتِ الصّٰالِحٰاتِ»</quranic_text> <footnote>[الكهف۴۶]</footnote> فَقَالَ: هِيَ الصَّلاَةُ فَحَافِظُوا عَلَيْهَا، وَ قَالَ: لاَ تُصَلِّ الظُّهْرَ اَبَداً حَتَّي تَزُولَ الشَّمْسُ.","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنِ TAG_OPEN:quranic_text الْبٰاقِيٰاتِ الصّٰالِحٰاتِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الكهف ۴۶ TAG_CLOSE:footnote فَقَالَ هِيَ الصَّلاَةُ فَحَافِظُوا عَلَيْهَا وَ قَالَ لاَ تُصَلِّ الظُّهْرَ اَبَداً حَتَّي تَزُولَ الشَّمْسُ"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الباقيات","display":"الْبٰاقِيٰاتِ"},{"kind":"word","token":"الصالحات","display":"الصّٰالِحٰاتِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","token":"۴۶","display":"۴۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةُ"},{"kind":"word","token":"فحافظوا","display":"فَحَافِظُوا"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تصل","display":"تُصَلِّ"},{"kind":"word","token":"الظهر","display":"الظُّهْرَ"},{"kind":"word","token":"ابدا","display":"اَبَداً"},{"kind":"wo