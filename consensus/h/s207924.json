{"members":[{"header_text":" اَلْعَيَّاشِيُّ فِي  تَفْسِيرِهِ ، عَنِ  اِبْنِ سِنَانٍ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ <quranic_text>«فِيهِ ايٰاتٌ بَيِّنٰاتٌ»</quranic_text> <footnote>[العمران۹۷]</footnote> فَمَا هَذِهِ الْايَاتُ قَالَ مَقَامُ اِبْرَاهِيمَ عَلَيْهِ السَّلاَمُ [حِينَ قَامَ عَلَيْهِ فَاَثَّرَتْ قَدَمَاهُ فِيهِ] وَ الْحَجَرُ وَ مَنْزِلُ اِسْمَاعِيلَ .","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ TAG_OPEN:quranic_text فِيهِ ايٰاتٌ بَيِّنٰاتٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۹۷ TAG_CLOSE:footnote فَمَا هَذِهِ الْايَاتُ قَالَ مَقَامُ اِبْرَاهِيمَ عَلَيْهِ السَّلاَمُ حِينَ قَامَ عَلَيْهِ فَاَثَّرَتْ قَدَمَاهُ فِيهِ وَ الْحَجَرُ وَ مَنْزِلُ اِسْمَاعِيلَ"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"ايات","display":"ايٰاتٌ"},{"kind":"word","token":"بينات","display":"بَيِّنٰاتٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۹۷","display":"۹۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايات","display":"الْايَاتُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"مقام","display":"مَقَامُ"},{"kind":"word","token":"ابراهيم","