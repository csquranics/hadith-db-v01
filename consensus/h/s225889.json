{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«اَ لَمْ يَاْنِ»</quranic_text> <footnote>[الحديد۱۶]</footnote> يَعْنِي اَ لَمْ يَجِبْ <quranic_text>«اَنْ تَخْشَعَ قُلُوبُهُمْ»</quranic_text> <footnote>[الحديد۱۶]</footnote> يَعْنِي الرَّهَبَ قَوْلُهُ: <quranic_text>«يُؤْتِكُمْ كِفْلَيْنِ مِنْ رَحْمَتِهِ»</quranic_text> <footnote>[الحديد۲۸]</footnote> قَالَ نَصِيبَيْنِ مِنْ رَحْمَتِهِ اَحَدُهُمَا اَنْ لاَ يُدْخِلَهُ النَّارَ وَ الثَّانِيَةُ اَنْ يُدْخِلَهُ الْجَنَّةَ قَوْلُهُ: <quranic_text>«وَ يَجْعَلْ لَكُمْ نُوراً تَمْشُونَ بِهِ»</quranic_text> <footnote>[الحديد۲۸]</footnote> يَعْنِي الْاِيمَانَ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text اَ لَمْ يَاْنِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحديد ۱۶ TAG_CLOSE:footnote يَعْنِي اَ لَمْ يَجِبْ TAG_OPEN:quranic_text اَنْ تَخْشَعَ قُلُوبُهُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحديد ۱۶ TAG_CLOSE:footnote يَعْنِي الرَّهَبَ قَوْلُهُ TAG_OPEN:quranic_text يُؤْتِكُمْ كِفْلَيْنِ مِنْ رَحْمَتِهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحديد ۲۸ TAG_CLOSE:footnote قَالَ نَصِيبَيْنِ مِنْ رَحْمَتِهِ اَحَدُهُمَا اَنْ لاَ يُدْخِلَهُ النَّارَ وَ الثَّانِيَةُ اَنْ يُدْخِلَهُ الْجَنَّةَ قَوْلُهُ TAG_OPEN:quranic_text وَ يَجْعَلْ لَكُمْ نُوراً تَمْشُونَ بِهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحديد ۲۸ TAG_CLOSE:footnote يَعْنِي الْاِيمَانَ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يان","display":"يَاْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحديد","display":"الحديد"},{"kind":"word","token":"۱۶","display":"۱۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display