{"members":[{"header_text":" فِقْهُ <teller> اَلرِّضَا، عَلَيْهِ السَّلاَمُ</teller> فِي كَلاَمٍ لَهُ عَلَيْهِ السَّلاَمُ:","body_text":"فَقَالَ تَعَالَي <quranic_text>«يٰا اَيُّهَا الَّذِينَ امَنُوا اِتَّقُوا اللّٰهَ وَ ذَرُوا مٰا بَقِيَ مِنَ الرِّبٰا»</quranic_text> <footnote>[البقرة۲۷۸]</footnote> عُنِيَ بِذَلِكَ اَنْ يَرُدَّ الْفَضْلَ الَّذِي اَخَذَهُ عَلَي رَاْسِ مَالِهِ حَتَّي اللَّحْمَ الَّذِي عَلَي بَدَنِهِ بِالدُّخُولِ اِلَي الْحَمَّامِ كُلَّ يَوْمٍ عَلَي الرِّيقِ هَذَا اِذَا تَابَ عَنْ اَكْلِ الرِّبَا وَ اَخْذِهِ وَ مُعَامَلَتِهِ.","translation":"","aligned_body":"فَقَالَ تَعَالَي TAG_OPEN:quranic_text يٰا اَيُّهَا الَّذِينَ امَنُوا اِتَّقُوا اللّٰهَ وَ ذَرُوا مٰا بَقِيَ مِنَ الرِّبٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۷۸ TAG_CLOSE:footnote عُنِيَ بِذَلِكَ اَنْ يَرُدَّ الْفَضْلَ الَّذِي اَخَذَهُ عَلَي رَاْسِ مَالِهِ حَتَّي اللَّحْمَ الَّذِي عَلَي بَدَنِهِ بِالدُّخُولِ اِلَي الْحَمَّامِ كُلَّ يَوْمٍ عَلَي الرِّيقِ هَذَا اِذَا تَابَ عَنْ اَكْلِ الرِّبَا وَ اَخْذِهِ وَ مُعَامَلَتِهِ"}],"body_consensus_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذروا","display":"ذَرُوا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"بقي","display":"بَقِيَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الربا","display":"الرِّبٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۷۸","display":"۲۷۸"},{"kind":"tag_close","