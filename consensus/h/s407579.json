{"members":[{"header_text":" عَنِ  اَلْحَلَبِيِّ ، <teller> عَنْهُ (عَلَيْهِ اَلسَّلاَمُ)</teller> :","body_text":"عَنِ اَلرَّجُلِ يُنْكِحُ عَبْدَهُ اَمَتَهُ، قَالَ: «يُفَرِّقُ بَيْنَهُمَا اِذَا شَاءَ بِغَيْرِ طَلاَقٍ، فَاِنَّ اللَّهَ يَقُولُ: <quranic_text>«عَبْداً مَمْلُوكاً لاٰ يَقْدِرُ عَليٰ شَيْءٍ»</quranic_text> <footnote>[النحل۷۵]</footnote> .","translation":"","aligned_body":"عَنِ اَلرَّجُلِ يُنْكِحُ عَبْدَهُ اَمَتَهُ قَالَ يُفَرِّقُ بَيْنَهُمَا اِذَا شَاءَ بِغَيْرِ طَلاَقٍ فَاِنَّ اللَّهَ يَقُولُ TAG_OPEN:quranic_text عَبْداً مَمْلُوكاً لاٰ يَقْدِرُ عَليٰ شَيْءٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote النحل ۷۵ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الرجل","display":"اَلرَّجُلِ"},{"kind":"word","token":"ينكح","display":"يُنْكِحُ"},{"kind":"word","token":"عبده","display":"عَبْدَهُ"},{"kind":"word","token":"امته","display":"اَمَتَهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يفرق","display":"يُفَرِّقُ"},{"kind":"word","token":"بينهما","display":"بَيْنَهُمَا"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"شاء","display":"شَاءَ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"طلاق","display":"طَلاَقٍ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"عبدا","display":"عَبْداً"},{"kind":"word","token":"مملوكا","display":"مَمْلُوكاً"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يقدر","display":"يَقْدِرُ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النحل","display":"النحل"},{"kind":"word","token":"۷۵","display":"۷۵"},{"kind":"tag_close","tag_nam