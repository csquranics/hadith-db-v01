{"members":[{"header_text":" تَفْسِيرِ  اَلْقَطَّانِ قَالَ  اِبْنُ مَسْعُودٍ : ","body_text":"قَالَ عَلِيٌّ يَا رَسُولَ اللَّهِ مَا اَقُولُ فِي السُّجُودِ فِي الصَّلاَةِ فَنَزَلَ <quranic_text>«سَبِّحِ اِسْمَ رَبِّكَ الْاَعْلَي»</quranic_text> <footnote>[الاعلي۱]</footnote> قَالَ فَمَا اَقُولُ فِي الرُّكُوعِ فَنَزَلَ <quranic_text>«فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ»</quranic_text> <footnote>[الواقعة۷۴]</footnote> فَكَانَ اَوَّلَ مَنْ قَالَ ذَلِكَ.","translation":"","aligned_body":"قَالَ عَلِيٌّ يَا رَسُولَ اللَّهِ مَا اَقُولُ فِي السُّجُودِ فِي الصَّلاَةِ فَنَزَلَ TAG_OPEN:quranic_text سَبِّحِ اِسْمَ رَبِّكَ الْاَعْلَي TAG_CLOSE:quranic_text TAG_OPEN:footnote الاعلي ۱ TAG_CLOSE:footnote قَالَ فَمَا اَقُولُ فِي الرُّكُوعِ فَنَزَلَ TAG_OPEN:quranic_text فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الواقعة ۷۴ TAG_CLOSE:footnote فَكَانَ اَوَّلَ مَنْ قَالَ ذَلِكَ"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اقول","display":"اَقُولُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السجود","display":"السُّجُودِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةِ"},{"kind":"word","token":"فنزل","display":"فَنَزَلَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سبح","display":"سَبِّحِ"},{"kind":"word","token":"اسم","display":"اِسْمَ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"الاعلي","display":"الْاَعْلَي"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعلي","display":"الاعلي"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"foo