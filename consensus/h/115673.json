{"members":[{"header_text":" [1378] [مُحَمَّدٌ اَلْحَلَبِيُّ] قَالَ: سَمِعْتُ أَبَا عَبْدِ اَللَّهِ جَعْفَرَ بْنَ مُحَمَّدٍ عَلَيْهِ اَلسَّلاَمُ يَقُولُ:","body_text":"مَنِ اِتَّقَي اللَّهَ [مِنْكُمْ] وَ اَصْلَحَ، فَهُوَ مِنَّا اَهْلَ الْبَيْتِ.","translation":"","aligned_body":"مَنِ اِتَّقَي اللَّهَ مِنْكُمْ وَ اَصْلَحَ فَهُوَ مِنَّا اَهْلَ الْبَيْتِ - - - - - - - - - - - - - - - - - - - - -"},{"header_text":" العيّاشيّ عن الصادق عليه السلام:","body_text":"من اتّقيٰ اللّٰه منكم و اصلح فهو منا اهل البيت قيل منكم اهل البيت قال منّا اهل البيت قال فيها ابراهيم <quranic_text>«فَمَنْ تَبِعَنِي فَاِنَّهُ مِنِّي»</quranic_text> <footnote>[ابراهيم۳۶]</footnote> .","translation":"","aligned_body":"من اتّقيٰ اللّٰه منكم و اصلح فهو منا اهل البيت قيل منكم اهل البيت قال منّا اهل البيت قال فيها ابراهيم TAG_OPEN:quranic_text فَمَنْ تَبِعَنِي فَاِنَّهُ مِنِّي TAG_CLOSE:quranic_text TAG_OPEN:footnote ابراهيم ۳۶ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"اتقي","display":"اتّقيٰ"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"منكم","display":"منكم"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اصلح","display":"اصلح"},{"kind":"word","token":"فهو","display":"فهو"},{"kind":"word","token":"منا","display":"منا"},{"kind":"word","token":"اهل","display":"اهل"},{"kind":"word","token":"البيت","display":"البيت"},{"kind":"word","token":"قيل","display":"قيل"},{"kind":"word","token":"منكم","display":"منكم"},{"kind":"word","token":"اهل","display":"اهل"},{"kind":"word","token":"البيت","display":"البيت"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"منا","display":"منّا"},{"kind":"word","token":"اهل","display":"اهل"},{"kind":"word","token":"البيت","display":"البيت"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"فيها","display":"فيها"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"tag_open","tag_name":"quranic_text"},{