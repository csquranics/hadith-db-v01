{"members":[{"header_text":" تَفْسِيرُ <teller> اَلْإِمَامِ، عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"قَوْلُهُ عَزَّ وَ جَلَّ <quranic_text>«وَ مِمّٰا رَزَقْنٰاهُمْ يُنْفِقُونَ»</quranic_text> <footnote>[البقرة۳]</footnote> قَالَ الْاِمَامُ يَعْنِي وَ مِمَّا رَزَقْنَاهُمْ مِنَ الْاَمْوَالِ وَ الْقُوَي فِي الْاَبْدَانِ وَ الْجَاهِ اِلَي اَنْ قَالَ وَ يُؤَدُّونَ مِنْ قُوَي الْاَبْدَانِ الْمَعُونَاتِ كَالرَّجُلِ يَقُودُ ضَرِيراً وَ يُنَّجِيهِ مِنْ مَهْلَكَةٍ وَ يُعِينُ مُسَافِراً عَلَي حَمْلِ مَتَاعٍ عَلَي دَابَّةٍ قَدْ سَقَطَ عَنْهَا الْخَبَرَ.","translation":"","aligned_body":"قَوْلُهُ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ مِمّٰا رَزَقْنٰاهُمْ يُنْفِقُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۳ TAG_CLOSE:footnote قَالَ الْاِمَامُ يَعْنِي وَ مِمَّا رَزَقْنَاهُمْ مِنَ الْاَمْوَالِ وَ الْقُوَي فِي الْاَبْدَانِ وَ الْجَاهِ اِلَي اَنْ قَالَ وَ يُؤَدُّونَ مِنْ قُوَي الْاَبْدَانِ الْمَعُونَاتِ كَالرَّجُلِ يَقُودُ ضَرِيراً وَ يُنَّجِيهِ مِنْ مَهْلَكَةٍ وَ يُعِينُ مُسَافِراً عَلَي حَمْلِ مَتَاعٍ عَلَي دَابَّةٍ قَدْ سَقَطَ عَنْهَا الْخَبَرَ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مما","display":"مِمّٰا"},{"kind":"word","token":"رزقناهم","display":"رَزَقْنٰاهُمْ"},{"kind":"word","token":"ينفقون","display":"يُنْفِقُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الامام","display":"الْاِمَامُ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مما","display":"