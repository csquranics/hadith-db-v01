{"members":[{"header_text":" فس، ،  [تفسير  القمي ] : ","body_text":" <quranic_text>«لَقَدْ مَنَّ اللّٰهُ عَلَي الْمُؤْمِنِينَ اِذْ بَعَثَ فِيهِمْ رَسُولاً مِنْ اَنْفُسِهِمْ»</quranic_text> <footnote>[العمران۱۶۴]</footnote> فَهَذِهِ الْايَةُ لاِلِ مُحَمَّدٍ عَلَيْهِمُ السَّلاَمُ .","translation":"","aligned_body":"لَقَدْ مَنَّ اللّٰهُ عَلَي الْمُؤْمِنِينَ اِذْ بَعَثَ فِيهِمْ رَسُولاً مِنْ اَنْفُسِهِمْ العمران۱۶۴ فَهَذِهِ الْايَةُ لاِلِ مُحَمَّدٍ عَلَيْهِمُ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"من","display":"مَنَّ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"بعث","display":"بَعَثَ"},{"kind":"word","token":"فيهم","display":"فِيهِمْ"},{"kind":"word","token":"رسولا","display":"رَسُولاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"انفسهم","display":"اَنْفُسِهِمْ"},{"kind":"word","token":"العمران۱۶۴","display":"العمران۱۶۴"},{"kind":"word","token":"فهذه","display":"فَهَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"word","token":"لال","display":"لاِلِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}