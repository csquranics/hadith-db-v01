{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«وَ نَحْشُرُ الْمُجْرِمِينَ يَوْمَئِذٍ زُرْقاً»</quranic_text> <footnote>[طه۱۰۲]</footnote> تَكُونُ اَعْيُنُهُمْ مُزْرَقَّةً لاَ يَقْدِرُونَ اَنْ يَطْرِفُوهَا.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text وَ نَحْشُرُ الْمُجْرِمِينَ يَوْمَئِذٍ زُرْقاً TAG_CLOSE:quranic_text TAG_OPEN:footnote طه ۱۰۲ TAG_CLOSE:footnote تَكُونُ اَعْيُنُهُمْ مُزْرَقَّةً لاَ يَقْدِرُونَ اَنْ يَطْرِفُوهَا"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نحشر","display":"نَحْشُرُ"},{"kind":"word","token":"المجرمين","display":"الْمُجْرِمِينَ"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"زرقا","display":"زُرْقاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"طه","display":"طه"},{"kind":"word","token":"۱۰۲","display":"۱۰۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"تكون","display":"تَكُونُ"},{"kind":"word","token":"اعينهم","display":"اَعْيُنُهُمْ"},{"kind":"word","token":"مزرقه","display":"مُزْرَقَّةً"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يقدرون","display":"يَقْدِرُونَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يطرفوها","display":"يَطْرِفُوهَا"}]}