{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«مٰا نَعْبُدُهُمْ اِلاّٰ لِيُقَرِّبُونٰا اِلَي اللّٰهِ زُلْفيٰ»</quranic_text> <footnote>[الزمر۳]</footnote> وَ ذَلِكَ اَنَّ قُرَيْشاً قَالَتْ اِنَّمَا نَعْبُدُ الْاَصْنَامَ لِيُقَرِّبُونَا اِلَي اللَّهِ زُلْفَي فَاِنَّا لاَ نَقْدِرُ اَنْ نَعْبُدَ اللَّهَ حَقَّ عِبَادَتِهِ فَحَكَي اللَّهُ قَوْلَهُمْ عَلَي لَفْظِ الْخَبَرِ وَ مَعْنَاهُ حِكَايَةٌ عَنْهُمْ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text مٰا نَعْبُدُهُمْ اِلاّٰ لِيُقَرِّبُونٰا اِلَي اللّٰهِ زُلْفيٰ TAG_CLOSE:quranic_text TAG_OPEN:footnote الزمر ۳ TAG_CLOSE:footnote وَ ذَلِكَ اَنَّ قُرَيْشاً قَالَتْ اِنَّمَا نَعْبُدُ الْاَصْنَامَ لِيُقَرِّبُونَا اِلَي اللَّهِ زُلْفَي فَاِنَّا لاَ نَقْدِرُ اَنْ نَعْبُدَ اللَّهَ حَقَّ عِبَادَتِهِ فَحَكَي اللَّهُ قَوْلَهُمْ عَلَي لَفْظِ الْخَبَرِ وَ مَعْنَاهُ حِكَايَةٌ عَنْهُمْ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"نعبدهم","display":"نَعْبُدُهُمْ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"ليقربونا","display":"لِيُقَرِّبُونٰا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"زلفي","display":"زُلْفيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزمر","display":"الزمر"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"قريشا","display":"قُرَيْشاً"},{"kind":"word","token":"قالت","display":"قَالَتْ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"نعبد","display":"نَعْبُدُ"},{"kind":"word","token":"الاصنام","display":"ال