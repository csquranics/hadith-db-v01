{"members":[{"header_text":" وَ مِنْ ذَلِكَ بِإِسْنَادِ  اَلثَّعْلَبِيِّ عَنْ  أَبِي صَالِحٍ عَنِ  اِبْنِ عَبَّاسٍ رَضِيَ اَللَّهُ عَنْهُ:","body_text":"فِي قَوْلِهِ تَعَالَي <quranic_text>«يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ»</quranic_text> <footnote>[المائدة۶۷]</footnote> الْايَةَ قَالَ نَزَلَتْ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ اُمِرَ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَنْ يُبَلِّغَ فِيهِ فَاَخَذَ رَسُولُ اللَّهِ بِيَدِ عَلِيٍّ فَقَالَ مَنْ كُنْتُ مَوْلاَهُ فَعَلِيٌّ مَوْلاَهُ اللَّهُمَّ وَالِ مَنْ وَالاَهُ وَ عَادِ مَنْ عَادَاهُ.","translation":"","aligned_body":"فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۶۷ TAG_CLOSE:footnote الْايَةَ قَالَ نَزَلَتْ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ اُمِرَ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَنْ يُبَلِّغَ فِيهِ فَاَخَذَ رَسُولُ اللَّهِ بِيَدِ عَلِيٍّ فَقَالَ مَنْ كُنْتُ مَوْلاَهُ فَعَلِيٌّ مَوْلاَهُ اللَّهُمَّ وَالِ مَنْ وَالاَهُ وَ عَادِ مَنْ عَادَاهُ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الرسول","display":"الرَّسُولُ"},{"kind":"word","token":"بلغ","display":"بَلِّغْ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"انزل","display":"اُنْزِلَ"},{"kind":"word","token":"اليك","display":"اِلَيْكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۶۷","display":"۶۷"},{"kind":"tag_close","tag_name":"foo