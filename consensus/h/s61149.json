{"members":[{"header_text":" [920]  اَلْكَلْبِيُّ ، عَنْ  أَبِي صَالِحٍ ، عَنِ  اِبْنِ عَبَّاسٍ ، أَنَّهُ قَالَ:","body_text":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ: <quranic_text>«وَ اِتَّقُوا اللّٰهَ الَّذِي تَسٰائَلُونَ بِهِ وَ الْاَرْحٰامَ»</quranic_text> <footnote>[النساء۱]</footnote> قَالَ: نَزَلَتْ فِي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ ذَوِي اَرْحَامِهِ لِاَنَّهُ قَالَ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ: كُلُّ سَبَبٍ وَ نَسَبٍ مُنْقَطِعٌ يَوْمَ الْقِيَامَةِ اِلاَّ سَبَبِي وَ نَسَبِي.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ اِتَّقُوا اللّٰهَ الَّذِي تَسٰائَلُونَ بِهِ وَ الْاَرْحٰامَ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱ TAG_CLOSE:footnote قَالَ نَزَلَتْ فِي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ ذَوِي اَرْحَامِهِ لِاَنَّهُ قَالَ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ كُلُّ سَبَبٍ وَ نَسَبٍ مُنْقَطِعٌ يَوْمَ الْقِيَامَةِ اِلاَّ سَبَبِي وَ نَسَبِي"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"تسائلون","display":"تَسٰائَلُونَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارحام","display":"الْاَرْحٰامَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word",