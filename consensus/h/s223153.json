{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«وَ اَنَّهُ تَعٰاليٰ جَدُّ رَبِّنٰا»</quranic_text> <footnote>[الجن۳]</footnote> قَالَ هُوَ شَيْءٌ قَالَتْهُ الْجِنُّ بِجَهَالَةٍ فَلَمْ يَرْضَهُ اللَّهُ تَعَالَي مِنْهُمْ وَ مَعْنَي جَدُّ رَبِّنَا اَيْ بَخْتُ رَبِّنَا.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text وَ اَنَّهُ تَعٰاليٰ جَدُّ رَبِّنٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الجن ۳ TAG_CLOSE:footnote قَالَ هُوَ شَيْءٌ قَالَتْهُ الْجِنُّ بِجَهَالَةٍ فَلَمْ يَرْضَهُ اللَّهُ تَعَالَي مِنْهُمْ وَ مَعْنَي جَدُّ رَبِّنَا اَيْ بَخْتُ رَبِّنَا"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"تعالي","display":"تَعٰاليٰ"},{"kind":"word","token":"جد","display":"جَدُّ"},{"kind":"word","token":"ربنا","display":"رَبِّنٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الجن","display":"الجن"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"قالته","display":"قَالَتْهُ"},{"kind":"word","token":"الجن","display":"الْجِنُّ"},{"kind":"word","token":"بجهاله","display":"بِجَهَالَةٍ"},{"kind":"word","token":"فلم","display":"فَلَمْ"},{"kind":"word","token":"يرضه","display":"يَرْضَهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"معني","display":"مَعْنَي"},{"kind":"word","token":"جد","display":"جَدُّ"},{"kind":"word","token":"ربنا","display":"رَبِّنَا"},{"kind":"word","token":"اي","displ