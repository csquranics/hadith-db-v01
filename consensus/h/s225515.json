{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«فَلْيَذُوقُوهُ حَمِيمٌ وَ غَسّٰاقٌ»</quranic_text> <footnote>[ص۵۷]</footnote> قَالَ الْغَسَّاقُ وَادٍ فِي جَهَنَّمَ وَ ذَكَرَ مِثْلَهُ وَ زَادَ فِيهِ فِي كُلِّ بَيْتٍ اَرْبَعُونَ زَاوِيَةً فِي كُلِّ زَاوِيَةٍ شُجَاعٌ فِي كُلِّ شُجَاعٍ ثَلاَثُمِائَةٍ وَ ثَلاَثُونَ عَقْرَباً.","translation":"","aligned_body":"TAG_OPEN:quranic_text فَلْيَذُوقُوهُ حَمِيمٌ وَ غَسّٰاقٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote ص ۵۷ TAG_CLOSE:footnote قَالَ الْغَسَّاقُ وَادٍ فِي جَهَنَّمَ وَ ذَكَرَ مِثْلَهُ وَ زَادَ فِيهِ فِي كُلِّ بَيْتٍ اَرْبَعُونَ زَاوِيَةً فِي كُلِّ زَاوِيَةٍ شُجَاعٌ فِي كُلِّ شُجَاعٍ ثَلاَثُمِائَةٍ وَ ثَلاَثُونَ عَقْرَباً"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فليذوقوه","display":"فَلْيَذُوقُوهُ"},{"kind":"word","token":"حميم","display":"حَمِيمٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"غساق","display":"غَسّٰاقٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ص","display":"ص"},{"kind":"word","token":"۵۷","display":"۵۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الغساق","display":"الْغَسَّاقُ"},{"kind":"word","token":"واد","display":"وَادٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"جهنم","display":"جَهَنَّمَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"مثله","display":"مِثْلَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"زاد","display":"زَادَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"بيت","display":"بَيْتٍ"},{"kind":"word","token":"اربعون","display":"اَرْبَعُونَ"},{"kind":"word","token":"زاويه","display":"زَاوِيَةً"},{"k