{"members":[{"header_text":" وَ عَنْ  مُحَمَّدِ بْنِ يَحْيَى عَنْ  أَحْمَدَ بْنِ مُحَمَّدِ بْنِ عِيسَى عَنْ  عَلِيِّ بْنِ اَلْحَكَمِ عَنْ  مَالِكِ بْنِ عَطِيَّةَ عَنْ  يُونُسَ بْنِ عَمَّارٍ قَالَ:","body_text":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اِنَّ هَذَا الَّذِي ظَهَرَ بِوَجْهِي يَزْعُمُ النَّاسُ اَنَّ اللَّهَ لَمْ يَبْتَلِ بِهِ عَبْداً لَهُ فِيهِ حَاجَةٌ قَالَ فَقَالَ لِي لَقَدْ كَانَ مُؤْمِنُ الِ فِرْعَوْنَ مُكَنَّعَ الْاَصَابِعِ فَكَانَ يَقُولُ هَكَذَا وَ يَمُدُّ يَدَيْهِ فَيَقُولُ - <quranic_text>«يٰا قَوْمِ اِتَّبِعُوا الْمُرْسَلِينَ»</quranic_text> <footnote>[يس۲۰]</footnote> الْخَبَرَ.","translation":"","aligned_body":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اِنَّ هَذَا الَّذِي ظَهَرَ بِوَجْهِي يَزْعُمُ النَّاسُ اَنَّ اللَّهَ لَمْ يَبْتَلِ بِهِ عَبْداً لَهُ فِيهِ حَاجَةٌ قَالَ فَقَالَ لِي لَقَدْ كَانَ مُؤْمِنُ الِ فِرْعَوْنَ مُكَنَّعَ الْاَصَابِعِ فَكَانَ يَقُولُ هَكَذَا وَ يَمُدُّ يَدَيْهِ فَيَقُولُ - TAG_OPEN:quranic_text يٰا قَوْمِ اِتَّبِعُوا الْمُرْسَلِينَ TAG_CLOSE:quranic_text TAG_OPEN:footnote يس ۲۰ TAG_CLOSE:footnote الْخَبَرَ"}],"body_consensus_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"ظهر","display":"ظَهَرَ"},{"kind":"word","token":"بوجهي","display":"بِوَجْهِي"},{"kind":"word","token":"يزعم","display":"يَزْعُمُ"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يبتل","display":"يَبْتَلِ"},{"kind":"word","token":"به