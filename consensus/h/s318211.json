{"members":[{"header_text":" وَ رُوِّينَا عَنْ<teller> جَعْفَرِ بْنِ مُحَمَّدٍ صَلَوَاتُ اللَّهِ عَلَيْهِ</teller> أَنَّهُ قَالَ :","body_text":"اِنَّ فَدَكاً كَانَتْ مِنْ مَا اَفَاءَ اللَّهُ عَلَي رَسُولِهِ بِغَيْرِ قِتَالٍ فَلَمَّا اَنْزَلَ اللَّهُ- <quranic_text>«فَاتِ ذَا الْقُرْبيٰ حَقَّهُ»</quranic_text> <footnote>[الروم۳۸]</footnote> اَعْطَي رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَاطِمَةَ صَلَوَاتُ اللَّهِ عَلَيْهَا فَدَكاً.","translation":"","aligned_body":"اِنَّ فَدَكاً كَانَتْ مِنْ مَا اَفَاءَ اللَّهُ عَلَي رَسُولِهِ بِغَيْرِ قِتَالٍ فَلَمَّا اَنْزَلَ اللَّهُ- TAG_OPEN:quranic_text فَاتِ ذَا الْقُرْبيٰ حَقَّهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الروم ۳۸ TAG_CLOSE:footnote اَعْطَي رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَاطِمَةَ صَلَوَاتُ اللَّهِ عَلَيْهَا فَدَكاً"}],"body_consensus_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"فدكا","display":"فَدَكاً"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"افاء","display":"اَفَاءَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"رسوله","display":"رَسُولِهِ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"قتال","display":"قِتَالٍ"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله-","display":"اللَّهُ-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فات","display":"فَاتِ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"القربي","display":"الْقُرْبيٰ"},{"kind":"word","token":"حقه","display":"حَقَّهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الروم","display":"الروم"},{"kind":"word","token":"۳۸","display":"۳۸"},{"kind":"tag_close","tag_nam