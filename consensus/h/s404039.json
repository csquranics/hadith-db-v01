{"members":[{"header_text":" أَبُو عَلِيٍّ اَلطَّبْرِسِيُّ:","body_text":"اُخْتُلِفَ فِي مَعْنَي قَوْلِهِ: <quranic_text>«بِجَهٰالَةٍ»</quranic_text> <footnote>[النساء۱۷]</footnote> عَلَي وُجُوهٍ، اَحَدُهَا اَنَّهُ كُلُّ مَعْصِيَةٍ يَفْعَلُهَا الْعَبْدُ بِجَهَالَةٍ، وَ اِنْ كَانَتْ عَلَي سَبِيلِ الْعَمْدِ، لِاَنَّهُ يَدْعُو اِلَيْهَا الْجَهْلُ وَ يُزَيِّنُهَا لِلْعَبْدِ، قَالَ وَ هُوَ الْمَرْوِيُّ عَنْ اَبِي عَبْدِ اللَّهِ (عَلَيْهِ السَّلاَمُ).","translation":"","aligned_body":"اُخْتُلِفَ فِي مَعْنَي قَوْلِهِ TAG_OPEN:quranic_text بِجَهٰالَةٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۷ TAG_CLOSE:footnote عَلَي وُجُوهٍ اَحَدُهَا اَنَّهُ كُلُّ مَعْصِيَةٍ يَفْعَلُهَا الْعَبْدُ بِجَهَالَةٍ وَ اِنْ كَانَتْ عَلَي سَبِيلِ الْعَمْدِ لِاَنَّهُ يَدْعُو اِلَيْهَا الْجَهْلُ وَ يُزَيِّنُهَا لِلْعَبْدِ قَالَ وَ هُوَ الْمَرْوِيُّ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"اختلف","display":"اُخْتُلِفَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"معني","display":"مَعْنَي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بجهاله","display":"بِجَهٰالَةٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"وجوه","display":"وُجُوهٍ"},{"kind":"word","token":"احدها","display":"اَحَدُهَا"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"معصيه","display":"مَعْصِيَةٍ"},{"kind":"word","token":"يفعلها","display":"يَفْعَلُهَا"},{"kind":"word","token":"العبد","display":"الْعَبْدُ"},{"kind":"word","token":"بجهاله","display":"بِجَهَالَةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"ا