{"members":[{"header_text":" وَ عَنْ  مُوسَى بْنِ أَبِي عَائِشَةَ قَالَ:","body_text":"كَانَ رَجُلٌ يُصَلِّي فَوْقَ بَيْتِهِ وَ كَانَ اِذَا قَرَاَ <quranic_text>«اَ لَيْسَ ذٰلِكَ بِقٰادِرٍ عَليٰ اَنْ يُحْيِيَ الْمَوْتيٰ»</quranic_text> <footnote>[القيامة۴۰]</footnote> قَالَ سُبْحَانَكَ فَبَلَي فَسَاَلُوهُ عَنْ ذَلِكَ فَقَالَ سَمِعْتُهُ مِنْ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ .","translation":"","aligned_body":"كَانَ رَجُلٌ يُصَلِّي فَوْقَ بَيْتِهِ وَ كَانَ اِذَا قَرَاَ اَ لَيْسَ ذٰلِكَ بِقٰادِرٍ عَليٰ اَنْ يُحْيِيَ الْمَوْتيٰ القيامة۴۰ قَالَ سُبْحَانَكَ فَبَلَي فَسَاَلُوهُ عَنْ ذَلِكَ فَقَالَ سَمِعْتُهُ مِنْ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ"}],"body_consensus_columns":[{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"يصلي","display":"يُصَلِّي"},{"kind":"word","token":"فوق","display":"فَوْقَ"},{"kind":"word","token":"بيته","display":"بَيْتِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"بقادر","display":"بِقٰادِرٍ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يحيي","display":"يُحْيِيَ"},{"kind":"word","token":"الموتي","display":"الْمَوْتيٰ"},{"kind":"word","token":"القيامه۴۰","display":"القيامة۴۰"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سبحانك","display":"سُبْحَانَكَ"},{"kind":"word","token":"فبلي","display":"فَبَلَي"},{"kind":"word","token":"فسالوه","display":"فَسَاَلُوهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"سمعته","display"