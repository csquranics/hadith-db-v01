{"members":[{"header_text":" فِي تَفْسِيرِ اَلْعَيَّاشِيِّ عَنْ جَابِرٍ عَنْ أَبِي جَعْفَرٍ عَلَيْهِ اَلسَّلاَمُ حَدِيثٌ طَوِيلٌ يَقُولُ فِي آخِرِهِ:","body_text":"وَ كَيْفَ لاَ يَكُونُ لَهُ مِنَ الْاَمْرِ شَيْءٌ وَ قَدْ فَوَّضَ اللَّهُ اِلَيْهِ اَنْ جَعَلَ مَا اَحَلَّ فَهُوَ حَلاَلٌ، وَ مَا حَرَّمَ فَهُوَ حَرَامٌ قَوْلُهُ: <quranic_text>«مٰا اتٰاكُمُ الرَّسُولُ فَخُذُوهُ وَ مٰا نَهٰاكُمْ عَنْهُ فَانْتَهُوا»</quranic_text> <footnote>[الحشر۷]</footnote> .","translation":"","aligned_body":"وَ كَيْفَ لاَ يَكُونُ لَهُ مِنَ الْاَمْرِ شَيْءٌ وَ قَدْ فَوَّضَ اللَّهُ اِلَيْهِ اَنْ جَعَلَ مَا اَحَلَّ فَهُوَ حَلاَلٌ وَ مَا حَرَّمَ فَهُوَ حَرَامٌ قَوْلُهُ TAG_OPEN:quranic_text مٰا اتٰاكُمُ الرَّسُولُ فَخُذُوهُ وَ مٰا نَهٰاكُمْ عَنْهُ فَانْتَهُوا TAG_CLOSE:quranic_text TAG_OPEN:footnote الحشر ۷ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الامر","display":"الْاَمْرِ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"فوض","display":"فَوَّضَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"جعل","display":"جَعَلَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"احل","display":"اَحَلَّ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"حلال","display":"حَلاَلٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"حرم","display":"حَرَّمَ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"حرام","display":"حَرَامٌ"},{"kin