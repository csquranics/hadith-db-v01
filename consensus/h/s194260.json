{"members":[{"header_text":" وَ عَنْ <teller> أَمِيرِ اَلْمُؤْمِنِينَ عَلَيْهِ اَلسَّلاَمُ</teller> : ","body_text":"فِي قَوْلِهِ <quranic_text>«مِمَّنْ تَرْضَوْنَ مِنَ الشُّهَدٰاءِ»</quranic_text> <footnote>[البقرة۲۸۲]</footnote> ، قَالَ مِمَّنْ تَرْضَوْنَ دِينَهُ وَ اَمَانَتَهُ وَ صَلاَحَهُ وَ عِفَّتَهُ وَ تَيَقُّظَهُ فِيمَا يَشْهَدُ بِهِ وَ تَحْصِيلَهُ وَ تَمْيِيزَهُ فَمَا كُلُّ صَالِحٍ مُمَيِّزاً وَ لاَ مُحَصِّلاً وَ لاَ كُلُّ مُحَصِّلٍ مُمَيِّزٍ صَالِحٌ.","translation":"","aligned_body":"فِي قَوْلِهِ TAG_OPEN:quranic_text مِمَّنْ تَرْضَوْنَ مِنَ الشُّهَدٰاءِ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۸۲ TAG_CLOSE:footnote قَالَ مِمَّنْ تَرْضَوْنَ دِينَهُ وَ اَمَانَتَهُ وَ صَلاَحَهُ وَ عِفَّتَهُ وَ تَيَقُّظَهُ فِيمَا يَشْهَدُ بِهِ وَ تَحْصِيلَهُ وَ تَمْيِيزَهُ فَمَا كُلُّ صَالِحٍ مُمَيِّزاً وَ لاَ مُحَصِّلاً وَ لاَ كُلُّ مُحَصِّلٍ مُمَيِّزٍ صَالِحٌ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ممن","display":"مِمَّنْ"},{"kind":"word","token":"ترضون","display":"تَرْضَوْنَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الشهداء","display":"الشُّهَدٰاءِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۸۲","display":"۲۸۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ممن","display":"مِمَّنْ"},{"kind":"word","token":"ترضون","display":"تَرْضَوْنَ"},{"kind":"word","token":"دينه","display":"دِينَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امانته","display":"اَمَانَتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صلاحه","display":"صَلاَحَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عفته","display":"عِفَّتَهُ"},{"kind":"word","toke