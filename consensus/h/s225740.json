{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ لَوْ لاٰ فَضْلُ اللّٰهِ عَلَيْكُمْ وَ رَحْمَتُهُ»</quranic_text> <footnote>[النساء۸۳]</footnote> قَالَ الْفَضْلُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ الرَّحْمَةُ اَمِيرُ الْمُؤْمِنِينَ صَلَوَاتُ اللَّهِ عَلَيْهِ .","translation":"","aligned_body":"TAG_OPEN:quranic_text وَ لَوْ لاٰ فَضْلُ اللّٰهِ عَلَيْكُمْ وَ رَحْمَتُهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۸۳ TAG_CLOSE:footnote قَالَ الْفَضْلُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ الرَّحْمَةُ اَمِيرُ الْمُؤْمِنِينَ صَلَوَاتُ اللَّهِ عَلَيْهِ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"فضل","display":"فَضْلُ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رحمته","display":"رَحْمَتُهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۸۳","display":"۸۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الفضل","display":"الْفَضْلُ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرحمه","display":"الرَّحْمَةُ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"صلو