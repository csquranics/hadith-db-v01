{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"قَوْلُهُ <quranic_text>«يٰا اَهْلَ الْكِتٰابِ قَدْ جٰاءَكُمْ رَسُولُنٰا يُبَيِّنُ لَكُمْ كَثِيراً مِمّٰا كُنْتُمْ تُخْفُونَ مِنَ الْكِتٰابِ وَ يَعْفُوا عَنْ كَثِيرٍ»</quranic_text> <footnote>[المائدة۱۵]</footnote> قَالَ يُبَيِّنُ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِمَّا اَخْفَيْتُمُوهُ مِمَّا فِي التَّوْرَاةِ مِنْ اَخْبَارِهِ وَ يَدَعُ كَثِيراً لاَ يُبَيِّنُهُ <quranic_text>«قَدْ جٰاءَكُمْ مِنَ اللّٰهِ نُورٌ وَ كِتٰابٌ مُبِينٌ»</quranic_text> <footnote>[المائدة۱۵]</footnote> يَعْنِي بِالنُّورِ اَمِيرَ الْمُؤْمِنِينَ وَ الْاَئِمَّةَ عَلَيْهِمُ السَّلاَمُ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text يٰا اَهْلَ الْكِتٰابِ قَدْ جٰاءَكُمْ رَسُولُنٰا يُبَيِّنُ لَكُمْ كَثِيراً مِمّٰا كُنْتُمْ تُخْفُونَ مِنَ الْكِتٰابِ وَ يَعْفُوا عَنْ كَثِيرٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۱۵ TAG_CLOSE:footnote قَالَ يُبَيِّنُ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِمَّا اَخْفَيْتُمُوهُ مِمَّا فِي التَّوْرَاةِ مِنْ اَخْبَارِهِ وَ يَدَعُ كَثِيراً لاَ يُبَيِّنُهُ TAG_OPEN:quranic_text قَدْ جٰاءَكُمْ مِنَ اللّٰهِ نُورٌ وَ كِتٰابٌ مُبِينٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۱۵ TAG_CLOSE:footnote يَعْنِي بِالنُّورِ اَمِيرَ الْمُؤْمِنِينَ وَ الْاَئِمَّةَ عَلَيْهِمُ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابِ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"جاءكم","display":"جٰاءَكُمْ"},{"kind":"word","token":"رسولنا","display":"رَسُولُنٰا"},{"kind":"word","token":"يبين","display":"يُبَيِّنُ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"كثيرا","display":"كَثِيراً"},{"kind":"word","token":"مما","display":"مِمّٰا"},{"kind":"word","token":"كنتم","display":"كُنْت