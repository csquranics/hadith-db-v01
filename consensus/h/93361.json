{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"قَوْلُهُ: <quranic_text>«مِنْهُمْ اُمَّةٌ مُقْتَصِدَةٌ»</quranic_text> <footnote>[المائدة۶۶]</footnote> قَالَ: قَوْمٌ مِنَ الْيَهُودِ دَخَلُوا فِي الْاِسْلاَمِ فَسَمَّاهُمُ اللَّهُ مُقْتَصِدَةً.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text مِنْهُمْ اُمَّةٌ مُقْتَصِدَةٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۶۶ TAG_CLOSE:footnote قَالَ قَوْمٌ مِنَ الْيَهُودِ دَخَلُوا فِي الْاِسْلاَمِ فَسَمَّاهُمُ اللَّهُ مُقْتَصِدَةً"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"امه","display":"اُمَّةٌ"},{"kind":"word","token":"مقتصده","display":"مُقْتَصِدَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۶۶","display":"۶۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قوم","display":"قَوْمٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"اليهود","display":"الْيَهُودِ"},{"kind":"word","token":"دخلوا","display":"دَخَلُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الاسلام","display":"الْاِسْلاَمِ"},{"kind":"word","token":"فسماهم","display":"فَسَمَّاهُمُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"مقتصده","display":"مُقْتَصِدَةً"}]}