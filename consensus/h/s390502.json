{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"ثُمَّ قَالَ عَزَّ وَ جَلَّ، <quranic_text>«اَ فَغَيْرَ دِينِ اللّٰهِ يَبْغُونَ»</quranic_text> <footnote>[العمران۸۳]</footnote> قَالَ: اَ غَيْرَ هَذَا الدِّينِ قُلْتُ لَكُمْ اَنْ تُقِرُّوا بِمُحَمَّدٍ وَ وَصِيِّهِ.","translation":"","aligned_body":"ثُمَّ قَالَ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text اَ فَغَيْرَ دِينِ اللّٰهِ يَبْغُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۸۳ TAG_CLOSE:footnote قَالَ اَ غَيْرَ هَذَا الدِّينِ قُلْتُ لَكُمْ اَنْ تُقِرُّوا بِمُحَمَّدٍ وَ وَصِيِّهِ"}],"body_consensus_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فغير","display":"فَغَيْرَ"},{"kind":"word","token":"دين","display":"دِينِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"يبغون","display":"يَبْغُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۸۳","display":"۸۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"غير","display":"غَيْرَ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الدين","display":"الدِّينِ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تقروا","display":"تُقِرُّوا"},{"kind":"word","token":"بمحمد","display":"بِمُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وصيه","display":"وَصِيِّهِ"}]}