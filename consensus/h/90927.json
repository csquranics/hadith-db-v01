{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ كَاَيِّنْ مِنْ قَرْيَةٍ»</quranic_text> <footnote>[محمد۱۳]</footnote> الْايَةَ قَالَ اِنَّ الَّذِينَ اَهْلَكْنَاهُمْ مِنَ الْاُمَمِ السَّالِفَةِ كَانُوا اَشَدَّ قُوَّةً مِنْ قَرْيَتِكَ يَعْنِي اَهْلَ مَكَّةَ الَّذِينَ اَخْرَجُوكَ مِنْهَا فَلَمْ يَكُنْ لَهُمْ نَاصِرٌ.","translation":"","aligned_body":"TAG_OPEN:quranic_text وَ كَاَيِّنْ مِنْ قَرْيَةٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote محمد ۱۳ TAG_CLOSE:footnote الْايَةَ قَالَ اِنَّ الَّذِينَ اَهْلَكْنَاهُمْ مِنَ الْاُمَمِ السَّالِفَةِ كَانُوا اَشَدَّ قُوَّةً مِنْ قَرْيَتِكَ يَعْنِي اَهْلَ مَكَّةَ الَّذِينَ اَخْرَجُوكَ مِنْهَا فَلَمْ يَكُنْ لَهُمْ نَاصِرٌ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كاين","display":"كَاَيِّنْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قريه","display":"قَرْيَةٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"محمد","display":"محمد"},{"kind":"word","token":"۱۳","display":"۱۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اهلكناهم","display":"اَهْلَكْنَاهُمْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الامم","display":"الْاُمَمِ"},{"kind":"word","token":"السالفه","display":"السَّالِفَةِ"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"اشد","display":"اَشَدَّ"},{"kind":"word","token":"قوه","display":"قُوَّةً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قريتك","display":"قَرْيَتِكَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"مكه"