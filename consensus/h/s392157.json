{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"وَ قَوْلُهُ: <quranic_text>«اِنَّ اللّٰهَ فٰالِقُ الْحَبِّ وَ النَّويٰ»</quranic_text> <footnote>[الانعام۹۵]</footnote> قَالَ: الْحَبُّ مَا اَحَبَّهُ وَ النَّوَي مَا نَاَي عَنِ الْحَقِّ، وَ قَالَ اَيْضاً فِي قَوْلِهِ: <quranic_text>«اِنَّ اللّٰهَ فٰالِقُ الْحَبِّ وَ النَّويٰ»</quranic_text> <footnote>[الانعام۹۵]</footnote> قَالَ: الْحَبُّ اَنْ يَفْلِقَ الْعِلْمَ مِنَ الْاَئِمَّةِ وَ النَّوَي مَا بَعُدَ عَنْهُ <quranic_text>«يُخْرِجُ الْحَيَّ مِنَ الْمَيِّتِ وَ مُخْرِجُ الْمَيِّتِ مِنَ الْحَيِّ»</quranic_text> <footnote>[الانعام۹۵]</footnote> قَالَ: الْمُؤْمِنَ مِنَ الْكَافِرِ، وَ الْكَافِرَ مِنَ الْمُؤْمِنِ.","translation":"","aligned_body":"وَ قَوْلُهُ TAG_OPEN:quranic_text اِنَّ اللّٰهَ فٰالِقُ الْحَبِّ وَ النَّويٰ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۹۵ TAG_CLOSE:footnote قَالَ الْحَبُّ مَا اَحَبَّهُ وَ النَّوَي مَا نَاَي عَنِ الْحَقِّ وَ قَالَ اَيْضاً فِي قَوْلِهِ TAG_OPEN:quranic_text اِنَّ اللّٰهَ فٰالِقُ الْحَبِّ وَ النَّويٰ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۹۵ TAG_CLOSE:footnote قَالَ الْحَبُّ اَنْ يَفْلِقَ الْعِلْمَ مِنَ الْاَئِمَّةِ وَ النَّوَي مَا بَعُدَ عَنْهُ TAG_OPEN:quranic_text يُخْرِجُ الْحَيَّ مِنَ الْمَيِّتِ وَ مُخْرِجُ الْمَيِّتِ مِنَ الْحَيِّ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۹۵ TAG_CLOSE:footnote قَالَ الْمُؤْمِنَ مِنَ الْكَافِرِ وَ الْكَافِرَ مِنَ الْمُؤْمِنِ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"فالق","display":"فٰالِقُ"},{"kind":"word","token":"الحب","display":"الْحَبِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النوي","display":"النَّويٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word",