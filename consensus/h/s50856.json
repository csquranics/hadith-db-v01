{"members":[{"header_text":" 200 - وَ عَنْ جَابِرِ بْنِ عَبْدِ اَللَّهِ اَلْأَنْصَارِيِّ فِي حَدِيثٍ طَوِيلٍ:","body_text":"اَنَّ عَلِيَّ بْنَ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ تَصَدَّقَ بِخَاتَمِهِ وَ هُوَ رَاكِعٌ فَنَزَلَتْ فِيهِ هَذِهِ الْايَةُ: <quranic_text>«اِنَّمٰا وَلِيُّكُمُ اللّٰهُ وَ رَسُولُهُ وَ الَّذِينَ امَنُوا الَّذِينَ يُقِيمُونَ الصَّلاٰةَ وَ يُؤْتُونَ الزَّكٰاةَ وَ هُمْ رٰاكِعُونَ»</quranic_text> <footnote>[المائدة۵۵]</footnote> .","translation":"","aligned_body":"اَنَّ عَلِيَّ بْنَ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ تَصَدَّقَ بِخَاتَمِهِ وَ هُوَ رَاكِعٌ فَنَزَلَتْ فِيهِ هَذِهِ الْايَةُ TAG_OPEN:quranic_text اِنَّمٰا وَلِيُّكُمُ اللّٰهُ وَ رَسُولُهُ وَ الَّذِينَ امَنُوا الَّذِينَ يُقِيمُونَ الصَّلاٰةَ وَ يُؤْتُونَ الزَّكٰاةَ وَ هُمْ رٰاكِعُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۵۵ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"علي","display":"عَلِيَّ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"تصدق","display":"تَصَدَّقَ"},{"kind":"word","token":"بخاتمه","display":"بِخَاتَمِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"راكع","display":"رَاكِعٌ"},{"kind":"word","token":"فنزلت","display":"فَنَزَلَتْ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"وليكم","display":"وَلِيُّكُمُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رسوله","display":"رَسُولُهُ"},{"kind":"word","token"