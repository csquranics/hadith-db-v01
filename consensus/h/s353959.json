{"members":[{"header_text":"","body_text":"قَوْلُهُ تَعَالَي: <quranic_text>«السّٰابِقُونَ السّٰابِقُونَ اُولٰئِكَ الْمُقَرَّبُونَ»</quranic_text> <footnote>[الواقعة۱۰]</footnote> هُوَ عَلِيٌّ عَلَيْهِ السَّلاَمُ : وَ كَانَ يُنْشِدُ سَبَقْتُكُمْ اِلَي الْاِسْلاَمِ طُرّاًصَغِيراً مَا بَلَغْتُ اَوَانَ حُلُمِي","translation":"","aligned_body":"قَوْلُهُ تَعَالَي TAG_OPEN:quranic_text السّٰابِقُونَ السّٰابِقُونَ اُولٰئِكَ الْمُقَرَّبُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الواقعة ۱۰ TAG_CLOSE:footnote هُوَ عَلِيٌّ عَلَيْهِ السَّلاَمُ وَ كَانَ يُنْشِدُ سَبَقْتُكُمْ اِلَي الْاِسْلاَمِ طُرّاًصَغِيراً مَا بَلَغْتُ اَوَانَ حُلُمِي"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"المقربون","display":"الْمُقَرَّبُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الواقعه","display":"الواقعة"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ينشد","display":"يُنْشِدُ"},{"kind":"word","token":"سبقتكم","display":"سَبَقْتُكُمْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الاسلام","display":"الْاِسْلاَمِ"},{"kind":"word","token":"طراصغيرا","display":"طُرّاًصَغِيراً"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"بلغت","display":"بَلَغْتُ"},{"kind":"word","token":"اوان","display":"اَوَ