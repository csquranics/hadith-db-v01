{"members":[{"header_text":" مُحَمَّدُ بْنُ عَلِيِّ بْنِ اَلْحُسَيْنِ بِإِسْنَادِهِ عَنْ  مُحَمَّدِ بْنِ أَبِي عُمَيْرٍ عَنْ  أَبَانٍ وَ  غَيْرِهِ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ</teller> : ","body_text":"فِي حَدِيثِ الظِّهَارِ قَالَ ثُمَّ اَنْزَلَ اللَّهُ الْكَفَّارَةَ فِي ذَلِكَ فَقَالَ <quranic_text>«وَ الَّذِينَ يُظٰاهِرُونَ مِنْ نِسٰائِهِمْ ثُمَّ يَعُودُونَ لِمٰا قٰالُوا فَتَحْرِيرُ رَقَبَةٍ مِنْ قَبْلِ اَنْ يَتَمَاسّٰا ذٰلِكُمْ تُوعَظُونَ بِهِ وَ اللّٰهُ بِمٰا تَعْمَلُونَ خَبِيرٌ فَمَنْ لَمْ يَجِدْ فَصِيٰامُ شَهْرَيْنِ مُتَتٰابِعَيْنِ مِنْ قَبْلِ اَنْ يَتَمَاسّٰا فَمَنْ لَمْ يَسْتَطِعْ فَاِطْعٰامُ سِتِّينَ مِسْكِيناً»</quranic_text> <footnote>[المجادلة۳]</footnote> .","translation":"","aligned_body":"فِي حَدِيثِ الظِّهَارِ قَالَ ثُمَّ اَنْزَلَ اللَّهُ الْكَفَّارَةَ فِي ذَلِكَ فَقَالَ TAG_OPEN:quranic_text وَ الَّذِينَ يُظٰاهِرُونَ مِنْ نِسٰائِهِمْ ثُمَّ يَعُودُونَ لِمٰا قٰالُوا فَتَحْرِيرُ رَقَبَةٍ مِنْ قَبْلِ اَنْ يَتَمَاسّٰا ذٰلِكُمْ تُوعَظُونَ بِهِ وَ اللّٰهُ بِمٰا تَعْمَلُونَ خَبِيرٌ فَمَنْ لَمْ يَجِدْ فَصِيٰامُ شَهْرَيْنِ مُتَتٰابِعَيْنِ مِنْ قَبْلِ اَنْ يَتَمَاسّٰا فَمَنْ لَمْ يَسْتَطِعْ فَاِطْعٰامُ سِتِّينَ مِسْكِيناً TAG_CLOSE:quranic_text TAG_OPEN:footnote المجادلة ۳ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"حديث","display":"حَدِيثِ"},{"kind":"word","token":"الظهار","display":"الظِّهَارِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"الكفاره","display":"الْكَفَّارَةَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يظاه