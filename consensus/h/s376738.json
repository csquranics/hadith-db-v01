{"members":[{"header_text":"<innocent> اَلْبَاقِرُ</innocent> وَ <teller> اَلصَّادِقُ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"وَ الصَّادِقُ عَلَيْهِ السَّلاَمُ : فِي قَوْلِهِ <quranic_text>«وَ الشَّمْسِ وَ ضُحٰاهٰا»</quranic_text> <footnote>[الشمس۱]</footnote> قَالَ هُوَ رَسُولُ اللَّهِ <quranic_text>«وَ الْقَمَرِ اِذٰا تَلاٰهٰا»</quranic_text> <footnote>[الشمس۲]</footnote> عَلِيُّ بْنُ اَبِي طَالِبٍ <quranic_text>«وَ النَّهٰارِ اِذٰا جَلاّٰهٰا»</quranic_text> <footnote>[الشمس۳]</footnote> الْحَسَنُ وَ الْحُسَيْنُ وَ الُ مُحَمَّدٍ قَالَ <quranic_text>«وَ اللَّيْلِ اِذٰا يَغْشٰاهٰا»</quranic_text> <footnote>[الشمس۴]</footnote> عَتِيقٌ وَ اِبْنُ صُهَاكَ وَ بَنُو اُمَيَّةَ وَ مَنْ تَوَلاَّهُمَا.","translation":"","aligned_body":"وَ الصَّادِقُ عَلَيْهِ السَّلاَمُ فِي قَوْلِهِ TAG_OPEN:quranic_text وَ الشَّمْسِ وَ ضُحٰاهٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الشمس ۱ TAG_CLOSE:footnote قَالَ هُوَ رَسُولُ اللَّهِ TAG_OPEN:quranic_text وَ الْقَمَرِ اِذٰا تَلاٰهٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الشمس ۲ TAG_CLOSE:footnote عَلِيُّ بْنُ اَبِي طَالِبٍ TAG_OPEN:quranic_text وَ النَّهٰارِ اِذٰا جَلاّٰهٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الشمس ۳ TAG_CLOSE:footnote الْحَسَنُ وَ الْحُسَيْنُ وَ الُ مُحَمَّدٍ قَالَ TAG_OPEN:quranic_text وَ اللَّيْلِ اِذٰا يَغْشٰاهٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الشمس ۴ TAG_CLOSE:footnote عَتِيقٌ وَ اِبْنُ صُهَاكَ وَ بَنُو اُمَيَّةَ وَ مَنْ تَوَلاَّهُمَا"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الشمس","display":"الشَّمْسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ضحاها","display":"ضُحٰاهٰا