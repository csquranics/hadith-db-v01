{"members":[{"header_text":" وَ عَنْ <teller> عَلِيٍّ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"اَنَّهُ قُرِئَ <quranic_text>«سَبِّحِ اِسْمَ رَبِّكَ الْاَعْلَي»</quranic_text> <footnote>[الاعلي۱]</footnote> فَقَالَ سُبْحَانَ رَبِّيَ الْاَعْلَي وَ هُوَ فِي الصَّلاَةِ فَقِيلَ لَهُ اَ تَزِيدُ فِي الْقُرْانِ قَالَ لاَ اِنَّمَا اُمِرْنَا بِشَيْءٍ فَقُلْتُهُ.","translation":"","aligned_body":"اَنَّهُ قُرِئَ سَبِّحِ اِسْمَ رَبِّكَ الْاَعْلَي الاعلي۱ فَقَالَ سُبْحَانَ رَبِّيَ الْاَعْلَي وَ هُوَ فِي الصَّلاَةِ فَقِيلَ لَهُ اَ تَزِيدُ فِي الْقُرْانِ قَالَ لاَ اِنَّمَا اُمِرْنَا بِشَيْءٍ فَقُلْتُهُ"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قرئ","display":"قُرِئَ"},{"kind":"word","token":"سبح","display":"سَبِّحِ"},{"kind":"word","token":"اسم","display":"اِسْمَ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"الاعلي","display":"الْاَعْلَي"},{"kind":"word","token":"الاعلي۱","display":"الاعلي۱"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"سبحان","display":"سُبْحَانَ"},{"kind":"word","token":"ربي","display":"رَبِّيَ"},{"kind":"word","token":"الاعلي","display":"الْاَعْلَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةِ"},{"kind":"word","token":"فقيل","display":"فَقِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"تزيد","display":"تَزِيدُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"امرنا","display":"اُمِرْنَا"},{"kind":"word","token":"بشيء","display":"بِشَيْءٍ"},{"kind":"word","token":"فقلته","display":"فَقُلْتُهُ"}]}