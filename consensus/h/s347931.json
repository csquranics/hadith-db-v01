{"members":[{"header_text":" عَنْ<teller> عَلِيِّ بْنِ اَلْحُسَيْنِ زَيْنِ اَلْعَابِدِينَ عَلَيْهِ السَّلاَمُ</teller> :","body_text":"اَنَّهُ قَالَ لِجَدِّي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ فِي كِتَابِ اللَّهِ تَعَالَي اَسْمَاءٌ كَثِيرَةٌ وَ لَكِنْ لاَ تَعْرِفُونَهَا فَقُلْتُ وَ مَا هِيَ قَالَ اَ لَمْ تَسْمَعْ قَوْلَ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«وَ اَذٰانٌ مِنَ اللّٰهِ وَ رَسُولِهِ اِلَي النّٰاسِ يَوْمَ الْحَجِّ الْاَكْبَرِ»</quranic_text> <footnote>[التوبة۳]</footnote> .","translation":"","aligned_body":"اَنَّهُ قَالَ لِجَدِّي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ فِي كِتَابِ اللَّهِ تَعَالَي اَسْمَاءٌ كَثِيرَةٌ وَ لَكِنْ لاَ تَعْرِفُونَهَا فَقُلْتُ وَ مَا هِيَ قَالَ اَ لَمْ تَسْمَعْ قَوْلَ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ اَذٰانٌ مِنَ اللّٰهِ وَ رَسُولِهِ اِلَي النّٰاسِ يَوْمَ الْحَجِّ الْاَكْبَرِ TAG_CLOSE:quranic_text TAG_OPEN:footnote التوبة ۳ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لجدي","display":"لِجَدِّي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتاب","display":"كِتَابِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"اسماء","display":"اَسْمَاءٌ"},{"kind":"word","token":"كثيره","display":"كَثِيرَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لَكِنْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تعرفونها","display":"تَعْرِفُونَهَا"},{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"و","dis