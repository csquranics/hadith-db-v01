{"members":[{"header_text":" وَ قَالَ <teller> اَلصَّادِقُ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"مَنِ اِسْتَغْفَرَ اللَّهَ فِي الْوَتْرِ سَبْعِينَ مَرَّةً كَتَبَهُ اللَّهُ عِنْدَهُ مِنَ <quranic_text>«الْمُسْتَغْفِرِينَ بِالْاَسْحٰارِ»</quranic_text> <footnote>[العمران۱۷]</footnote> وَ صَلِّ رَكْعَتَيِ الْفَجْرِ قَبْلَ الْفَجْرِ وَ عِنْدَهُ وَ بَعْدَهُ.","translation":"","aligned_body":"مَنِ اِسْتَغْفَرَ اللَّهَ فِي الْوَتْرِ سَبْعِينَ مَرَّةً كَتَبَهُ اللَّهُ عِنْدَهُ مِنَ TAG_OPEN:quranic_text الْمُسْتَغْفِرِينَ بِالْاَسْحٰارِ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۱۷ TAG_CLOSE:footnote وَ صَلِّ رَكْعَتَيِ الْفَجْرِ قَبْلَ الْفَجْرِ وَ عِنْدَهُ وَ بَعْدَهُ"}],"body_consensus_columns":[{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"استغفر","display":"اِسْتَغْفَرَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الوتر","display":"الْوَتْرِ"},{"kind":"word","token":"سبعين","display":"سَبْعِينَ"},{"kind":"word","token":"مره","display":"مَرَّةً"},{"kind":"word","token":"كتبه","display":"كَتَبَهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"المستغفرين","display":"الْمُسْتَغْفِرِينَ"},{"kind":"word","token":"بالاسحار","display":"بِالْاَسْحٰارِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صل","display":"صَلِّ"},{"kind":"word","token":"ركعتي","display":"رَكْعَتَيِ"},{"kind":"word","token":"الفجر","display":"الْفَجْرِ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"الفجر","display":"الْفَجْرِ"},{"kind":"word","tok