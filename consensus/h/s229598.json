{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَالَ قُرَيْشٌ قَدِ اِجْتَمَعْنَا لِنَنْتَصِرَ وَ نَقْتُلَكَ يَا مُحَمَّدُ فَاَنْزَلَ اللَّهُ <quranic_text>«اَمْ يَقُولُونَ»</quranic_text> <footnote>[القمر۴۴]</footnote> يَا مُحَمَّدُ <quranic_text>«نَحْنُ جَمِيعٌ مُنْتَصِرٌ سَيُهْزَمُ الْجَمْعُ وَ يُوَلُّونَ الدُّبُرَ»</quranic_text> <footnote>[القمر۴۴]</footnote> يَعْنِي يَوْمَ بَدْرٍ حِينَ هَزَمُوا وَ اُسِرُوا وَ قُتِلُوا.","translation":"","aligned_body":"قَالَ قُرَيْشٌ قَدِ اِجْتَمَعْنَا لِنَنْتَصِرَ وَ نَقْتُلَكَ يَا مُحَمَّدُ فَاَنْزَلَ اللَّهُ TAG_OPEN:quranic_text اَمْ يَقُولُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote القمر ۴۴ TAG_CLOSE:footnote يَا مُحَمَّدُ TAG_OPEN:quranic_text نَحْنُ جَمِيعٌ مُنْتَصِرٌ سَيُهْزَمُ الْجَمْعُ وَ يُوَلُّونَ الدُّبُرَ TAG_CLOSE:quranic_text TAG_OPEN:footnote القمر ۴۴ TAG_CLOSE:footnote يَعْنِي يَوْمَ بَدْرٍ حِينَ هَزَمُوا وَ اُسِرُوا وَ قُتِلُوا"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قريش","display":"قُرَيْشٌ"},{"kind":"word","token":"قد","display":"قَدِ"},{"kind":"word","token":"اجتمعنا","display":"اِجْتَمَعْنَا"},{"kind":"word","token":"لننتصر","display":"لِنَنْتَصِرَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نقتلك","display":"نَقْتُلَكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"فانزل","display":"فَاَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القمر","display":"القمر"},{"kind":"word","token":"۴۴","display":"۴۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"tag_