{"members":[{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، عَنْ <innocent> أَبِي جَعْفَرٍ</innocent> وَ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> أَنَّهُمَا قَالاَ:","body_text":"وَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اَنَّهُمَا قَالاَ: الْمَمْلُوكُ لاَ يَجُوزُ طَلاَقُهُ وَ لاَ نِكَاحُهُ اِلاَّ بِاِذْنِ سَيِّدِهِ وَ اِنْ زَوَّجَهُ السَّيِّدُ قَالَ اللَّهُ جَلَّ ذِكْرُهُ <quranic_text>«عَبْداً مَمْلُوكاً لاٰ يَقْدِرُ عَليٰ شَيْءٍ»</quranic_text> <footnote>[النحل۷۵]</footnote> قَالَ وَ الطَّلاَقُ وَ النِّكَاحُ شَيْءٌ.","translation":"","aligned_body":"وَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اَنَّهُمَا قَالاَ الْمَمْلُوكُ لاَ يَجُوزُ طَلاَقُهُ وَ لاَ نِكَاحُهُ اِلاَّ بِاِذْنِ سَيِّدِهِ وَ اِنْ زَوَّجَهُ السَّيِّدُ قَالَ اللَّهُ جَلَّ ذِكْرُهُ TAG_OPEN:quranic_text عَبْداً مَمْلُوكاً لاٰ يَقْدِرُ عَليٰ شَيْءٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote النحل ۷۵ TAG_CLOSE:footnote قَالَ وَ الطَّلاَقُ وَ النِّكَاحُ شَيْءٌ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"انهما","display":"اَنَّهُمَا"},{"kind":"word","token":"قالا","display":"قَالاَ"},{"kind":"word","token":"المملوك","display":"الْمَمْلُوكُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يجوز","display":"يَجُوزُ"},{"kind":"word","token":"طلاقه","display":"طَلاَقُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"نكاحه","display":"نِكَاحُهُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"باذن","display":"بِاِذْنِ"},{"kind":"word","token":"سيده","display":"سَيِّدِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":