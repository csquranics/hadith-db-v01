{"members":[{"header_text":" فِي غَوَالِي اَللَّئَالِي وَ قَالَ اَلصَّادِقُ عَلَيْهِ اَلسَّلاَمُ:","body_text":"فِي تَفْسِيرِ قَوْلِهِ تَعَالَي: <quranic_text>«وَ ذَا النُّونِ اِذْ ذَهَبَ مُغٰاضِباً»</quranic_text> <footnote>[الانبياء۸۷]</footnote> اِنَّمَا ظَنَّ بِمَعْنَي اِسْتَيْقَنَ اَنَّ اللَّهَ تَعَالَي لَنْ يُضَيِّقَ عَلَيْهِ رِزْقَهُ اَ لاَ تَسْمَعُ قَوْلَ اللَّهِ تَعَالَي: وَ <quranic_text>«اَمّٰا اِذٰا مَا اِبْتَلاٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُ»</quranic_text> <footnote>[الفجر۱۶]</footnote> اَيْ ضَيَّقَ عَلَيْهِ.","translation":"","aligned_body":"فِي تَفْسِيرِ قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text وَ ذَا النُّونِ اِذْ ذَهَبَ مُغٰاضِباً TAG_CLOSE:quranic_text TAG_OPEN:footnote الانبياء ۸۷ TAG_CLOSE:footnote اِنَّمَا ظَنَّ بِمَعْنَي اِسْتَيْقَنَ اَنَّ اللَّهَ تَعَالَي لَنْ يُضَيِّقَ عَلَيْهِ رِزْقَهُ اَ لاَ تَسْمَعُ قَوْلَ اللَّهِ تَعَالَي وَ TAG_OPEN:quranic_text اَمّٰا اِذٰا مَا اِبْتَلاٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الفجر ۱۶ TAG_CLOSE:footnote اَيْ ضَيَّقَ عَلَيْهِ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"النون","display":"النُّونِ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"ذهب","display":"ذَهَبَ"},{"kind":"word","token":"مغاضبا","display":"مُغٰاضِباً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۸۷","display":"۸۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"ظن","display":"ظَنَّ"},{"kind":"word","token":"بمعني","display":"بِمَعْنَي"},{"kind":"wo