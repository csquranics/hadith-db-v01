{"members":[{"header_text":" عَنْ  سُلَيْمَانَ بْنِ مِهْرَانَ أَنَّهُ قَالَ:","body_text":"قُلْتُ لِلصَّادِقِ عَلَيْهِ السَّلاَمُ كَيْفَ صَارَ الْحَلْقُ عَلَي الصَّرُورَةِ وَاجِباً دُونَ مَنْ قَدْ حَجَّ فَقَالَ لِيَصِيرَ بِذَلِكَ مُوسَماً بِسِمَةِ الْامِنِينَ اَ لاَ تَسْمَعُ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ <quranic_text>«لَتَدْخُلُنَّ الْمَسْجِدَ الْحَرٰامَ اِنْ شٰاءَ اللّٰهُ امِنِينَ مُحَلِّقِينَ رُؤُسَكُمْ وَ مُقَصِّرِينَ لاٰ تَخٰافُونَ»</quranic_text> <footnote>[الفتح۲۷]</footnote> .","translation":"","aligned_body":"قُلْتُ لِلصَّادِقِ عَلَيْهِ السَّلاَمُ كَيْفَ صَارَ الْحَلْقُ عَلَي الصَّرُورَةِ وَاجِباً دُونَ مَنْ قَدْ حَجَّ فَقَالَ لِيَصِيرَ بِذَلِكَ مُوسَماً بِسِمَةِ الْامِنِينَ اَ لاَ تَسْمَعُ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ TAG_OPEN:quranic_text لَتَدْخُلُنَّ الْمَسْجِدَ الْحَرٰامَ اِنْ شٰاءَ اللّٰهُ امِنِينَ مُحَلِّقِينَ رُؤُسَكُمْ وَ مُقَصِّرِينَ لاٰ تَخٰافُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الفتح ۲۷ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"للصادق","display":"لِلصَّادِقِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"صار","display":"صَارَ"},{"kind":"word","token":"الحلق","display":"الْحَلْقُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الصروره","display":"الصَّرُورَةِ"},{"kind":"word","token":"واجبا","display":"وَاجِباً"},{"kind":"word","token":"دون","display":"دُونَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"حج","display":"حَجَّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ليصير","display":"لِيَصِيرَ"},{"kind":"word","token":"بذلك","display":"بِذَلِكَ"},{"kind":"word","token":"موسما","display":"مُوسَماً"},{"kind":"word","token":"بسمه","display":"بِسِمَةِ"},{"kind":"word","token":"الامنين","display":"ا