{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"قَوْلُهُ: <quranic_text>«وَ لَقَدْ جَعَلْنٰا فِي السَّمٰاءِ بُرُوجاً»</quranic_text> <footnote>[الحجر۱۶]</footnote> قَالَ: مَنَازِلَ الشَّمْسِ وَ الْقَمَرِ وَ زَيَّنَّاهَا لِلنَّاظِرِينَ بِالْكَوَاكِبِ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text وَ لَقَدْ جَعَلْنٰا فِي السَّمٰاءِ بُرُوجاً TAG_CLOSE:quranic_text TAG_OPEN:footnote الحجر ۱۶ TAG_CLOSE:footnote قَالَ مَنَازِلَ الشَّمْسِ وَ الْقَمَرِ وَ زَيَّنَّاهَا لِلنَّاظِرِينَ بِالْكَوَاكِبِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"جعلنا","display":"جَعَلْنٰا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السماء","display":"السَّمٰاءِ"},{"kind":"word","token":"بروجا","display":"بُرُوجاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"۱۶","display":"۱۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"منازل","display":"مَنَازِلَ"},{"kind":"word","token":"الشمس","display":"الشَّمْسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"القمر","display":"الْقَمَرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"زيناها","display":"زَيَّنَّاهَا"},{"kind":"word","token":"للناظرين","display":"لِلنَّاظِرِينَ"},{"kind":"word","token":"بالكواكب","display":"بِالْكَوَاكِبِ"}]}