{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«اِنَّ الَّذِينَ فَرَّقُوا دِينَهُمْ وَ كٰانُوا شِيَعاً»</quranic_text> <footnote>[الانعام۱۵۹]</footnote> قَالَ فَارَقُوا اَمِيرَ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ وَ صَارُوا اَحْزَاباً.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text اِنَّ الَّذِينَ فَرَّقُوا دِينَهُمْ وَ كٰانُوا شِيَعاً TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۱۵۹ TAG_CLOSE:footnote قَالَ فَارَقُوا اَمِيرَ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ وَ صَارُوا اَحْزَاباً"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"فرقوا","display":"فَرَّقُوا"},{"kind":"word","token":"دينهم","display":"دِينَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كانوا","display":"كٰانُوا"},{"kind":"word","token":"شيعا","display":"شِيَعاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۱۵۹","display":"۱۵۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فارقوا","display":"فَارَقُوا"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صاروا","display":"صَارُوا"},{"kind":"word","token":"احزابا","display":"اَحْزَاباً"}]}