{"members":[{"header_text":" عُيُونِ أَخْبَارِ<teller> اَلرِّضَا عَلَيْهِ السَّلاَمُ</teller> قَالَ اَلْوَشَّاءُ :","body_text":"قَالَ لِي كَيْفَ تَقْرَءُونَ قَالَ يَا نُوحُ اِنَّهُ لَيْسَ مِنْ اَهْلِكَ اِنَّهُ عَمِلَ غَيْرَ صَالِحٍ فَقُلْتُ مِنَ النَّاسِ مَنْ يَقْرَاُ <quranic_text>«اِنَّهُ عَمَلٌ غَيْرُ صٰالِحٍ»</quranic_text> <footnote>[هود۴۶]</footnote> نَفَاهُ عَنْ اَبِيهِ فَقَالَ عَلَيْهِ السَّلاَمُ كَلاَّ لَقَدْ كَانَ اِبْنَهُ وَ لَكِنْ لَمَّا عَصَي اللَّهَ عَزَّ وَ جَلَّ نَفَاهُ عَنْ اَبِيهِ.","translation":"","aligned_body":"قَالَ لِي كَيْفَ تَقْرَءُونَ قَالَ يَا نُوحُ اِنَّهُ لَيْسَ مِنْ اَهْلِكَ اِنَّهُ عَمِلَ غَيْرَ صَالِحٍ فَقُلْتُ مِنَ النَّاسِ مَنْ يَقْرَاُ TAG_OPEN:quranic_text اِنَّهُ عَمَلٌ غَيْرُ صٰالِحٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote هود ۴۶ TAG_CLOSE:footnote نَفَاهُ عَنْ اَبِيهِ فَقَالَ عَلَيْهِ السَّلاَمُ كَلاَّ لَقَدْ كَانَ اِبْنَهُ وَ لَكِنْ لَمَّا عَصَي اللَّهَ عَزَّ وَ جَلَّ نَفَاهُ عَنْ اَبِيهِ"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"تقرءون","display":"تَقْرَءُونَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"نوح","display":"نُوحُ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهلك","display":"اَهْلِكَ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"عمل","display":"عَمِلَ"},{"kind":"word","token":"غير","display":"غَيْرَ"},{"kind":"word","token":"صالح","display":"صَالِحٍ"},{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يقرا","display":"يَقْرَاُ"},{"kind":"tag_open","tag_name":"quranic_te