{"members":[{"header_text":" وَ أَسْنَدَ  اَلثَّعْلَبِيُّ فِي  تَفْسِيرِهِ إِلَى <teller> اَلصَّادِقِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"نَحْنُ حَبْلُ اللَّهِ الَّذِي قَالَ فِيهِ <quranic_text>«وَ اِعْتَصِمُوا بِحَبْلِ اللّٰهِ»</quranic_text> <footnote>[العمران۱۰۳]</footnote> وَ اِذَا اَمَرَ اللَّهُ وَ رَسُولُهُ بِالاِعْتِصَامِ بِهِ فَقَدْ هَلَكَ مَنْ لَمْ يَعْتَصِمْ بِهِ وَ مَنْ تَاَمَّرَ عَلَيْهِ لَمْ يَعْتَصِمْ بِهِ فَهَلَكَ مَنْ تَاَمَّرَ عَلَيْهِ.","translation":"","aligned_body":"نَحْنُ حَبْلُ اللَّهِ الَّذِي قَالَ فِيهِ TAG_OPEN:quranic_text وَ اِعْتَصِمُوا بِحَبْلِ اللّٰهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۱۰۳ TAG_CLOSE:footnote وَ اِذَا اَمَرَ اللَّهُ وَ رَسُولُهُ بِالاِعْتِصَامِ بِهِ فَقَدْ هَلَكَ مَنْ لَمْ يَعْتَصِمْ بِهِ وَ مَنْ تَاَمَّرَ عَلَيْهِ لَمْ يَعْتَصِمْ بِهِ فَهَلَكَ مَنْ تَاَمَّرَ عَلَيْهِ"}],"body_consensus_columns":[{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"حبل","display":"حَبْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعتصموا","display":"اِعْتَصِمُوا"},{"kind":"word","token":"بحبل","display":"بِحَبْلِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۰۳","display":"۱۰۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"امر","display":"اَمَرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رسوله","display":"رَسُولُهُ"},{"kind":"word","token":"بالاعتصام","display":"بِالاِعْ