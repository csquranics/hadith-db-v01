{"members":[{"header_text":" فَإِنَّهُ حَدَّثَنِي أَبِي عَنِ اِبْنِ أَبِي عُمَيْرٍ عَنِ اِبْنِ أُذَيْنَةَ عَنْ زُرَارَةَ عَنْ<teller> أَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ</teller> قَالَ :","body_text":"وَ قَوْلُهُ وَ لَوْ اَنَّهُمْ اِذْ ظَلَمُوا اَنْفُسَهُمْ جٰاؤُكَ فَاسْتَغْفَرُوا اللّٰهَ <quranic_text>«وَ لَوْ اَنَّهُمْ اِذْ ظَلَمُوا اَنْفُسَهُمْ جٰاؤُكَ ۱۰-۱۶ ۶۴:۴»</quranic_text> <footnote>[النساء۶۴]</footnote> يَا عَلِيُّ ۶۴:۴ <quranic_text>«فَاسْتَغْفَرُوا اللّٰهَ وَ اِسْتَغْفَرَ لَهُمُ الرَّسُولُ لَوَجَدُوا اللّٰهَ تَوّٰاباً رَحِيماً ۱۷-۲۶ ۶۴:۴»</quranic_text> <footnote>[النساء۶۴]</footnote> هَكَذَا نَزَلَتْ.","translation":"","aligned_body":"وَ قَوْلُهُ وَ لَوْ اَنَّهُمْ اِذْ ظَلَمُوا اَنْفُسَهُمْ جٰاؤُكَ فَاسْتَغْفَرُوا اللّٰهَ TAG_OPEN:quranic_text وَ لَوْ اَنَّهُمْ اِذْ ظَلَمُوا اَنْفُسَهُمْ جٰاؤُكَ ۱۰- ۱۶ ۶۴ ۴ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۶۴ TAG_CLOSE:footnote يَا عَلِيُّ ۶۴ ۴ TAG_OPEN:quranic_text فَاسْتَغْفَرُوا اللّٰهَ وَ اِسْتَغْفَرَ لَهُمُ الرَّسُولُ لَوَجَدُوا اللّٰهَ تَوّٰاباً رَحِيماً ۱۷- ۲۶ ۶۴ ۴ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۶۴ TAG_CLOSE:footnote هَكَذَا نَزَلَتْ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"انهم","display":"اَنَّهُمْ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"ظلموا","display":"ظَلَمُوا"},{"kind":"word","token":"انفسهم","display":"اَنْفُسَهُمْ"},{"kind":"word","token":"جاؤك","display":"جٰاؤُكَ"},{"kind":"word","token":"فاستغفروا","display":"فَاسْتَغْفَرُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"انهم","display":"اَنَّهُمْ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"ظلموا","display":"