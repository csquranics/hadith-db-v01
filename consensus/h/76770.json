{"members":[{"header_text":"","body_text":"لِقَطْعِ اَلرُّعَافِ، يَقْرَاُ: مِنْهَا خَلَقْنَاكُمْ وَ فِيهَا نُعِيدُكُمْ وَ مِنْهَا نُخْرِجُكُمْ تَارَةً اُخْرَي <quranic_text>«يَوْمَئِذٍ يَتَّبِعُونَ الدَّاعِيَ لاَ عِوَجَ لَهُ وَ خَشَعَتِ الْاَصْوَاتُ لِلرَّحْمَنِ فَلاَ تَسْمَعُ اِلاَّ هَمْساً»</quranic_text> <footnote>[طه۱۰۸]</footnote> يَا هُوَ.","translation":"","aligned_body":"لِقَطْعِ اَلرُّعَافِ يَقْرَاُ مِنْهَا خَلَقْنَاكُمْ وَ فِيهَا نُعِيدُكُمْ وَ مِنْهَا نُخْرِجُكُمْ تَارَةً اُخْرَي يَوْمَئِذٍ يَتَّبِعُونَ الدَّاعِيَ لاَ عِوَجَ لَهُ وَ خَشَعَتِ الْاَصْوَاتُ لِلرَّحْمَنِ فَلاَ تَسْمَعُ اِلاَّ هَمْساً يَا هُوَ"}],"body_consensus_columns":[{"kind":"word","token":"لقطع","display":"لِقَطْعِ"},{"kind":"word","token":"الرعاف","display":"اَلرُّعَافِ"},{"kind":"word","token":"يقرا","display":"يَقْرَاُ"},{"kind":"word","token":"منها","display":"مِنْهَا"},{"kind":"word","token":"خلقناكم","display":"خَلَقْنَاكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"نعيدكم","display":"نُعِيدُكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"منها","display":"مِنْهَا"},{"kind":"word","token":"نخرجكم","display":"نُخْرِجُكُمْ"},{"kind":"word","token":"تاره","display":"تَارَةً"},{"kind":"word","token":"اخري","display":"اُخْرَي"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"يتبعون","display":"يَتَّبِعُونَ"},{"kind":"word","token":"الداعي","display":"الدَّاعِيَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"عوج","display":"عِوَجَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"خشعت","display":"خَشَعَتِ"},{"kind":"word","token":"الاصوات","display":"الْاَصْوَاتُ"},{"kind":"word","token":"للرحمن","display":"لِلرَّحْمَنِ"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"تسمع","display":"تَسْمَعُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{