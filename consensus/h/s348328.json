{"members":[{"header_text":" وَ قَالَ مُجَاهِدٌ:","body_text":"نَزَلَ قَوْلُهُ <quranic_text>«يٰا اَيُّهَا الَّذِينَ امَنُوا لاٰ تَسْئَلُوا عَنْ اَشْيٰاءَ اِنْ تُبْدَ لَكُمْ تَسُؤْكُمْ»</quranic_text> <footnote>[المائدة۱۰۱]</footnote> حِينَ سَاَلُوا عَنْ اَمْرِ الْحَجِّ لَمَّا اَنْزَلَ اللَّهُ <quranic_text>«وَ لِلّٰهِ عَلَي النّٰاسِ حِجُّ الْبَيْتِ»</quranic_text> <footnote>[العمران۹۷]</footnote> فَقَالُوا فِي كُلِّ عَامٍ قَالَ لاَ وَ لَوْ قُلْتُ نَعَمْ لَوَجَبَتْ.","translation":"","aligned_body":"نَزَلَ قَوْلُهُ TAG_OPEN:quranic_text يٰا اَيُّهَا الَّذِينَ امَنُوا لاٰ تَسْئَلُوا عَنْ اَشْيٰاءَ اِنْ تُبْدَ لَكُمْ تَسُؤْكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۱۰۱ TAG_CLOSE:footnote حِينَ سَاَلُوا عَنْ اَمْرِ الْحَجِّ لَمَّا اَنْزَلَ اللَّهُ TAG_OPEN:quranic_text وَ لِلّٰهِ عَلَي النّٰاسِ حِجُّ الْبَيْتِ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۹۷ TAG_CLOSE:footnote فَقَالُوا فِي كُلِّ عَامٍ قَالَ لاَ وَ لَوْ قُلْتُ نَعَمْ لَوَجَبَتْ"}],"body_consensus_columns":[{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تسئلوا","display":"تَسْئَلُوا"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"اشياء","display":"اَشْيٰاءَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"تبد","display":"تُبْدَ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"تسؤكم","display":"تَسُؤْكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۱۰۱","display":"۱۰۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","tok