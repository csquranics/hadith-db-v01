{"members":[{"header_text":" فِي رَوْضَةِ اَلْكَافِي عَلِيُّ بْنُ إِبْرَاهِيمَ عَنْ أَبِيهِ عَنْ عَلِيِّ بْنِ أَسْبَاطٍ عَنْهُمْ عَلَيْهِمُ اَلسَّلاَمُ قَالَ:","body_text":"فِيمَا وَعَظَ اللَّهُ عَزَّ وَ جَلَّ بِهِ عِيسَي عَلَيْهِ السَّلاَمُ: وَ طَاْ رُسُومَ مَنَازِلَ مِنْ قَبْلِكَ وَ اُدْعُهُمْ وَ نَاجِهِمْ <quranic_text>«هَلْ تُحِسُّ مِنْهُمْ مِنْ اَحَدٍ»</quranic_text> <footnote>[مريم۹۸]</footnote> ، وَ خُذْ مَوْعِظَتَكَ مِنْهُمْ، وَ اِعْلَمْ اَنَّكَ سَتَلْحَقُهُمْ فِي اللاَّحِقِينَ.","translation":"","aligned_body":"فِيمَا وَعَظَ اللَّهُ عَزَّ وَ جَلَّ بِهِ عِيسَي عَلَيْهِ السَّلاَمُ وَ طَاْ رُسُومَ مَنَازِلَ مِنْ قَبْلِكَ وَ اُدْعُهُمْ وَ نَاجِهِمْ TAG_OPEN:quranic_text هَلْ تُحِسُّ مِنْهُمْ مِنْ اَحَدٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote مريم ۹۸ TAG_CLOSE:footnote وَ خُذْ مَوْعِظَتَكَ مِنْهُمْ وَ اِعْلَمْ اَنَّكَ سَتَلْحَقُهُمْ فِي اللاَّحِقِينَ"}],"body_consensus_columns":[{"kind":"word","token":"فيما","display":"فِيمَا"},{"kind":"word","token":"وعظ","display":"وَعَظَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"عيسي","display":"عِيسَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طا","display":"طَاْ"},{"kind":"word","token":"رسوم","display":"رُسُومَ"},{"kind":"word","token":"منازل","display":"مَنَازِلَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبلك","display":"قَبْلِكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ادعهم","display":"اُدْعُهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ناجهم","display":"نَاجِهِمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"تحس","di