{"members":[{"header_text":" بِالْإِسْنَادِ اَلْمُتَقَدِّمِ عَنِ<innocent> اَلْإِمَامِ مُوسَى بْنِ جَعْفَرٍ</innocent> عَنْ<teller> أَبِيهِ عَلَيْهِ السَّلاَمُ</teller> قَالَ:","body_text":"عَنْ اَبِيهِ عَلَيْهِ السَّلاَمُ قَالَ: سَمِعْتُ اَبِي مُحَمَّدَ بْنَ عَلِيٍّ صَلَوَاتُ اللَّهِ عَلَيْهِ كَثِيراً مَا يُرَدِّدُ هَذِهِ الْايَةَ <quranic_text>«وَ مَنْ عٰاقَبَ بِمِثْلِ مٰا عُوقِبَ بِهِ ثُمَّ بُغِيَ عَلَيْهِ لَيَنْصُرَنَّهُ اللّٰهُ»</quranic_text> <footnote>[الحج۶۰]</footnote> فَقُلْتُ يَا اَبَتِ جُعِلْتُ فِدَاكَ اَحْسُبُ هَذِهِ الْايَةَ نَزَلَتْ فِي اَمِيرِ الْمُؤْمِنِينَ خَاصَّةً.","translation":"","aligned_body":"عَنْ اَبِيهِ عَلَيْهِ السَّلاَمُ قَالَ سَمِعْتُ اَبِي مُحَمَّدَ بْنَ عَلِيٍّ صَلَوَاتُ اللَّهِ عَلَيْهِ كَثِيراً مَا يُرَدِّدُ هَذِهِ الْايَةَ TAG_OPEN:quranic_text وَ مَنْ عٰاقَبَ بِمِثْلِ مٰا عُوقِبَ بِهِ ثُمَّ بُغِيَ عَلَيْهِ لَيَنْصُرَنَّهُ اللّٰهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحج ۶۰ TAG_CLOSE:footnote فَقُلْتُ يَا اَبَتِ جُعِلْتُ فِدَاكَ اَحْسُبُ هَذِهِ الْايَةَ نَزَلَتْ فِي اَمِيرِ الْمُؤْمِنِينَ خَاصَّةً"}],"body_consensus_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سمعت","display":"سَمِعْتُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"محمد","display":"مُحَمَّدَ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"كثيرا","display":"كَثِيراً"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يردد","display":"يُرَدِّدُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind