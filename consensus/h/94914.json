{"members":[{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، عَنِ <teller> اَلصَّادِقِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"فِي قَوْلِهِ تَعَالَي <quranic_text>«وَ رَبٰائِبُكُمُ اللاّٰتِي»</quranic_text> <footnote>[النساء۲۳]</footnote> الْايَةَ قَالَ هِيَ اِبْنَةُ اِمْرَاَتِهِ عَلَيْهِ حَرَامٌ اِذَا كَانَ دَخَلَ بِاُمِهَّا فَاِنْ لَمْ يَكُنْ دَخَلَ بِاُمِّهَا فَتَزْوِيجُهَا لَهُ حَلاَلٌ وَ قَالَ فِي قَوْلِهِ عَزَّ وَ جَلَّ <quranic_text>«فِي حُجُورِكُمْ»</quranic_text> <footnote>[النساء۲۳]</footnote> قَالَ الْحِجْرُ الْحُرْمَةُ يَقُولُ اللاَّتِي فِي حُرْمَتِكُمْ وَ ذَلِكَ مِثْلُ قَوْلِهِ <quranic_text>«اَنْعٰامٌ وَ حَرْثٌ حِجْرٌ»</quranic_text> <footnote>[الانعام۱۳۸]</footnote> يَقُولُ مُحَرَّمَةٌ.","translation":"","aligned_body":"فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text وَ رَبٰائِبُكُمُ اللاّٰتِي TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۲۳ TAG_CLOSE:footnote الْايَةَ قَالَ هِيَ اِبْنَةُ اِمْرَاَتِهِ عَلَيْهِ حَرَامٌ اِذَا كَانَ دَخَلَ بِاُمِهَّا فَاِنْ لَمْ يَكُنْ دَخَلَ بِاُمِّهَا فَتَزْوِيجُهَا لَهُ حَلاَلٌ وَ قَالَ فِي قَوْلِهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text فِي حُجُورِكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۲۳ TAG_CLOSE:footnote قَالَ الْحِجْرُ الْحُرْمَةُ يَقُولُ اللاَّتِي فِي حُرْمَتِكُمْ وَ ذَلِكَ مِثْلُ قَوْلِهِ TAG_OPEN:quranic_text اَنْعٰامٌ وَ حَرْثٌ حِجْرٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۱۳۸ TAG_CLOSE:footnote يَقُولُ مُحَرَّمَةٌ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ربائبكم","display":"رَبٰائِبُكُمُ"},{"kind":"word","token":"اللاتي","display":"اللاّٰتِي"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۲۳","display":"۲۳"},{"kind":"tag_clos