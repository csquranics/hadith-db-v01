{"members":[{"header_text":" فس، ،  [تفسير  القمي ] : ","body_text":" <quranic_text>«لَنْ تَنٰالُوا الْبِرَّ حَتّٰي تُنْفِقُوا مِمّٰا تُحِبُّونَ»</quranic_text> <footnote>[العمران۹۲]</footnote> اَيْ لَنْ تَنَالُوا الثَّوَابَ حَتَّي تَرُدُّوا عَلَي الِ مُحَمَّدٍ حَقَّهُمْ مِنَ الْاَنْفَالِ وَ الْخُمُسِ وَ الْفَيْءِ.","translation":"","aligned_body":"لَنْ تَنٰالُوا الْبِرَّ حَتّٰي تُنْفِقُوا مِمّٰا تُحِبُّونَ العمران۹۲ اَيْ لَنْ تَنَالُوا الثَّوَابَ حَتَّي تَرُدُّوا عَلَي الِ مُحَمَّدٍ حَقَّهُمْ مِنَ الْاَنْفَالِ وَ الْخُمُسِ وَ الْفَيْءِ"}],"body_consensus_columns":[{"kind":"word","token":"لن","display":"لَنْ"},{"kind":"word","token":"تنالوا","display":"تَنٰالُوا"},{"kind":"word","token":"البر","display":"الْبِرَّ"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"تنفقوا","display":"تُنْفِقُوا"},{"kind":"word","token":"مما","display":"مِمّٰا"},{"kind":"word","token":"تحبون","display":"تُحِبُّونَ"},{"kind":"word","token":"العمران۹۲","display":"العمران۹۲"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"لن","display":"لَنْ"},{"kind":"word","token":"تنالوا","display":"تَنَالُوا"},{"kind":"word","token":"الثواب","display":"الثَّوَابَ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"تردوا","display":"تَرُدُّوا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"حقهم","display":"حَقَّهُمْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الانفال","display":"الْاَنْفَالِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الخمس","display":"الْخُمُسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الفيء","display":"الْفَيْءِ"}]}