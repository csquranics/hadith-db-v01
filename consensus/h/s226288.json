{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«حَتّٰي اِذَا اِسْتَيْاَسَ الرُّسُلُ وَ ظَنُّوا اَنَّهُمْ قَدْ كُذِبُوا جٰاءَهُمْ نَصْرُنٰا»</quranic_text> <footnote>[يوسف۱۱۰]</footnote> - فَاِنَّهُ حَدَّثَنِي اَبِي عَنِ اِبْنِ اَبِي عُمَيْرٍ عَنْ اَبِي بَصِيرٍ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَالَ: وَكَلَهُمْ اللَّهُ اِلَي اَنْفُسِهِمْ فَظَنُّوا اَنَّ الشَّيْطَانَ قَدْ تَمَثَّلَ لَهُمْ فِي صُورَةِ الْمَلاَئِكَةِ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text حَتّٰي اِذَا اِسْتَيْاَسَ الرُّسُلُ وَ ظَنُّوا اَنَّهُمْ قَدْ كُذِبُوا جٰاءَهُمْ نَصْرُنٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote يوسف ۱۱۰ TAG_CLOSE:footnote - فَاِنَّهُ حَدَّثَنِي اَبِي عَنِ اِبْنِ اَبِي عُمَيْرٍ عَنْ اَبِي بَصِيرٍ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَالَ وَكَلَهُمْ اللَّهُ اِلَي اَنْفُسِهِمْ فَظَنُّوا اَنَّ الشَّيْطَانَ قَدْ تَمَثَّلَ لَهُمْ فِي صُورَةِ الْمَلاَئِكَةِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"استياس","display":"اِسْتَيْاَسَ"},{"kind":"word","token":"الرسل","display":"الرُّسُلُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ظنوا","display":"ظَنُّوا"},{"kind":"word","token":"انهم","display":"اَنَّهُمْ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كذبوا","display":"كُذِبُوا"},{"kind":"word","token":"جاءهم","display":"جٰاءَهُمْ"},{"kind":"word","token":"نصرنا","display":"نَصْرُنٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۱۱۰","display":"۱۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"حدثني","display":"حَدّ