{"members":[{"header_text":" اَلطَّبْرِسِيُّ:","body_text":"فِي قَوْلِهِ: <quranic_text>«بِالْبٰاطِلِ»</quranic_text> <footnote>[النساء۲۹]</footnote> ، قَوْلاَنِ: اَحَدُهُمَا اَنَّهُ الرِّبَا، وَ الْقِمَارُ، وَ الْبَخْسُ، وَ الظُّلْمُ. قَالَ: وَ هُوَ الْمَرْوِيُّ عَنِ الْبَاقِرِ (عَلَيْهِ السَّلاَمُ).","translation":"","aligned_body":"فِي قَوْلِهِ TAG_OPEN:quranic_text بِالْبٰاطِلِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۲۹ TAG_CLOSE:footnote قَوْلاَنِ اَحَدُهُمَا اَنَّهُ الرِّبَا وَ الْقِمَارُ وَ الْبَخْسُ وَ الظُّلْمُ قَالَ وَ هُوَ الْمَرْوِيُّ عَنِ الْبَاقِرِ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بالباطل","display":"بِالْبٰاطِلِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قولان","display":"قَوْلاَنِ"},{"kind":"word","token":"احدهما","display":"اَحَدُهُمَا"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"الربا","display":"الرِّبَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"القمار","display":"الْقِمَارُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"البخس","display":"الْبَخْسُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الظلم","display":"الظُّلْمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"المروي","display":"الْمَرْوِيُّ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الباقر","display":"الْبَاقِرِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}