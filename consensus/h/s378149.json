{"members":[{"header_text":"<teller> اَلْبَاقِرُ عَلَيْهِ السَّلاَمُ</teller> قَالَ: ","body_text":" <quranic_text>«هٰذِهِ سَبِيلِي»</quranic_text> <footnote>[يوسف۱۰۸]</footnote> يَعْنِي نَفْسَهُ رَسُولَ اللَّهِ وَ علي [عَلِيّاً] مِنْ شِيعَةِ الِ مُحَمَّدٍ وَ فِي رِوَايَةٍ: يَعْنِي بِالسَّبِيلِ عَلِيّاً وَ لاَ يُنَالُ مَا عِنْدَ اللَّهِ اِلاَّ بِوَلاَيَتِهِ.","translation":"","aligned_body":"TAG_OPEN:quranic_text هٰذِهِ سَبِيلِي TAG_CLOSE:quranic_text TAG_OPEN:footnote يوسف ۱۰۸ TAG_CLOSE:footnote يَعْنِي نَفْسَهُ رَسُولَ اللَّهِ وَ علي عَلِيّاً مِنْ شِيعَةِ الِ مُحَمَّدٍ وَ فِي رِوَايَةٍ يَعْنِي بِالسَّبِيلِ عَلِيّاً وَ لاَ يُنَالُ مَا عِنْدَ اللَّهِ اِلاَّ بِوَلاَيَتِهِ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هذه","display":"هٰذِهِ"},{"kind":"word","token":"سبيلي","display":"سَبِيلِي"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۱۰۸","display":"۱۰۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"نفسه","display":"نَفْسَهُ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"علي"},{"kind":"word","token":"عليا","display":"عَلِيّاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شيعه","display":"شِيعَةِ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"روايه","display":"رِوَايَةٍ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"بالسبيل","display":"بِالسَّبِيلِ"},{"kind":"word","token":"عليا","display":"عَلِيّاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","