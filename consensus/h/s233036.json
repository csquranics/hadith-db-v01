{"members":[{"header_text":" م، ،  [تفسير <teller> الإمام عليه السلام</teller> ] : ","body_text":"قَالَ اَللَّهُ عَزَّ وَ جَلَّ: <quranic_text>«وَ بِالْوٰالِدَيْنِ اِحْسٰاناً»</quranic_text> <footnote>[البقرة۸۳]</footnote> قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَفْضَلُ وَالِدَيْكُمْ وَ اَحَقُّهُمَا لِشُكْرِكُمْ مُحَمَّدٌ وَ عَلِيٌّ .","translation":"","aligned_body":"قَالَ اَللَّهُ عَزَّ وَ جَلَّ وَ بِالْوٰالِدَيْنِ اِحْسٰاناً البقرة۸۳ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَفْضَلُ وَالِدَيْكُمْ وَ اَحَقُّهُمَا لِشُكْرِكُمْ مُحَمَّدٌ وَ عَلِيٌّ"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بالوالدين","display":"بِالْوٰالِدَيْنِ"},{"kind":"word","token":"احسانا","display":"اِحْسٰاناً"},{"kind":"word","token":"البقره۸۳","display":"البقرة۸۳"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"افضل","display":"اَفْضَلُ"},{"kind":"word","token":"والديكم","display":"وَالِدَيْكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"احقهما","display":"اَحَقُّهُمَا"},{"kind":"word","token":"لشكركم","display":"لِشُكْرِكُمْ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"}]}