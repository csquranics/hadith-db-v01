{"members":[{"header_text":" اَلطَّبْرِسِيُّ، قَالَ:","body_text":" <quranic_text>«يُحِبُّونَ اَنْ يَتَطَهَّرُوا»</quranic_text> <footnote>[التوبة۱۰۸]</footnote> بِالْمَاءِ عَنِ الْغَائِطِ وَ الْبَوْلِ. قَالَ: وَ هُوَ الْمَرْوِيُّ عَنِ السَّيِّدَيْنِ الْبَاقِرِ وَ الصَّادِقِ (عَلَيْهِمَا السَّلاَمُ).","translation":"","aligned_body":"TAG_OPEN:quranic_text يُحِبُّونَ اَنْ يَتَطَهَّرُوا TAG_CLOSE:quranic_text TAG_OPEN:footnote التوبة ۱۰۸ TAG_CLOSE:footnote بِالْمَاءِ عَنِ الْغَائِطِ وَ الْبَوْلِ قَالَ وَ هُوَ الْمَرْوِيُّ عَنِ السَّيِّدَيْنِ الْبَاقِرِ وَ الصَّادِقِ عَلَيْهِمَا السَّلاَمُ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يحبون","display":"يُحِبُّونَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتطهروا","display":"يَتَطَهَّرُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۱۰۸","display":"۱۰۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"بالماء","display":"بِالْمَاءِ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الغائط","display":"الْغَائِطِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"البول","display":"الْبَوْلِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"المروي","display":"الْمَرْوِيُّ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"السيدين","display":"السَّيِّدَيْنِ"},{"kind":"word","token":"الباقر","display":"الْبَاقِرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}