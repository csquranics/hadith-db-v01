{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"قَوْلُهُ: <quranic_text>«يَوْمَئِذٍ يَوَدُّ الَّذِينَ كَفَرُوا وَ عَصَوُا الرَّسُولَ لَوْ تُسَوّٰي بِهِمُ الْاَرْضُ وَ لاٰ يَكْتُمُونَ اللّٰهَ حَدِيثاً»</quranic_text> <footnote>[النساء۴۲]</footnote> قَالَ يَتَمَنَّي الَّذِينَ عَصَوْا اَمِيرَ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ اَنْ تَكُونَ الْاَرْضُ اِبْتَلَعَتْهُمْ فِي الْيَوْمِ الَّذِي اِجْتَمَعُوا فِيهِ عَلَي غَصْبِهِ وَ اَنْ لَمْ يَكْتُمُوا مَا قَالَهُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فِيهِ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text يَوْمَئِذٍ يَوَدُّ الَّذِينَ كَفَرُوا وَ عَصَوُا الرَّسُولَ لَوْ تُسَوّٰي بِهِمُ الْاَرْضُ وَ لاٰ يَكْتُمُونَ اللّٰهَ حَدِيثاً TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۴۲ TAG_CLOSE:footnote قَالَ يَتَمَنَّي الَّذِينَ عَصَوْا اَمِيرَ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ اَنْ تَكُونَ الْاَرْضُ اِبْتَلَعَتْهُمْ فِي الْيَوْمِ الَّذِي اِجْتَمَعُوا فِيهِ عَلَي غَصْبِهِ وَ اَنْ لَمْ يَكْتُمُوا مَا قَالَهُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فِيهِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"يود","display":"يَوَدُّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"كفروا","display":"كَفَرُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عصوا","display":"عَصَوُا"},{"kind":"word","token":"الرسول","display":"الرَّسُولَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"تسوي","display":"تُسَوّٰي"},{"kind":"word","token":"بهم","display":"بِهِمُ"},{"kind":"word","token":"الارض","display":"الْاَرْضُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يكتمون","display":"يَكْتُمُونَ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"حديثا","displ