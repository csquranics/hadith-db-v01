{"members":[{"header_text":" كِتَابُ  اَلْعَلاَءِ بْنِ رَزِينٍ ، عَنْ  مُحَمَّدِ بْنِ مُسْلِمٍ قَالَ:","body_text":"هَلْ يُعْرَضُ عَلَي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ قَالَ مَا فِيهِ شَكٌّ قَوْلُهُ عَزَّ وَ جَلَّ - <quranic_text>«فَسَيَرَي اللّٰهُ عَمَلَكُمْ وَ رَسُولُهُ وَ الْمُؤْمِنُونَ»</quranic_text> <footnote>[التوبة۱۰۵]</footnote> قَالَ لِلَّهِ شُهَدَاءُ فِي اَرْضِهِ.","translation":"","aligned_body":"هَلْ يُعْرَضُ عَلَي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ قَالَ مَا فِيهِ شَكٌّ قَوْلُهُ عَزَّ وَ جَلَّ - TAG_OPEN:quranic_text فَسَيَرَي اللّٰهُ عَمَلَكُمْ وَ رَسُولُهُ وَ الْمُؤْمِنُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote التوبة ۱۰۵ TAG_CLOSE:footnote قَالَ لِلَّهِ شُهَدَاءُ فِي اَرْضِهِ"}],"body_consensus_columns":[{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"يعرض","display":"يُعْرَضُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"شك","display":"شَكٌّ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فسيري","display":"فَسَيَرَي"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"عملكم","display":"عَمَلَكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رسوله","display":"رَسُولُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المؤمنون","d