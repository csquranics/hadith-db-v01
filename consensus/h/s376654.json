{"members":[{"header_text":"","body_text":"قَوْلُهُ <quranic_text>«اِنِّي جٰاعِلُكَ لِلنّٰاسِ اِمٰاماً»</quranic_text> <footnote>[البقرة۱۲۴]</footnote> فَقَالَ اِبْرَاهِيمُ مِنْ عِظَمِ خَطَرِ الْاِمَامَةِ عِنْدَهُ <quranic_text>«وَ مِنْ ذُرِّيَّتِي قٰالَ لاٰ يَنٰالُ عَهْدِي الظّٰالِمِينَ»</quranic_text> <footnote>[البقرة۱۲۴]</footnote> وَ فِي خَبَرٍ اَنَّهُ قَالَ وَ مَنِ الظَّالِمُ مِنْ وُلْدِي قَالَ مَنْ سَجَدَ لِصَنَمٍ مِنْ دُونِي فَقَالَ اِبْرَاهِيمُ <quranic_text>«وَ اُجْنُبْنِي وَ بَنِيَّ اَنْ نَعْبُدَ الْاَصْنٰامَ»</quranic_text> <footnote>[ابراهيم۳۵]</footnote> -.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text اِنِّي جٰاعِلُكَ لِلنّٰاسِ اِمٰاماً TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۲۴ TAG_CLOSE:footnote فَقَالَ اِبْرَاهِيمُ مِنْ عِظَمِ خَطَرِ الْاِمَامَةِ عِنْدَهُ TAG_OPEN:quranic_text وَ مِنْ ذُرِّيَّتِي قٰالَ لاٰ يَنٰالُ عَهْدِي الظّٰالِمِينَ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۲۴ TAG_CLOSE:footnote وَ فِي خَبَرٍ اَنَّهُ قَالَ وَ مَنِ الظَّالِمُ مِنْ وُلْدِي قَالَ مَنْ سَجَدَ لِصَنَمٍ مِنْ دُونِي فَقَالَ اِبْرَاهِيمُ TAG_OPEN:quranic_text وَ اُجْنُبْنِي وَ بَنِيَّ اَنْ نَعْبُدَ الْاَصْنٰامَ TAG_CLOSE:quranic_text TAG_OPEN:footnote ابراهيم ۳۵ TAG_CLOSE:footnote -"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"جاعلك","display":"جٰاعِلُكَ"},{"kind":"word","token":"للناس","display":"لِلنّٰاسِ"},{"kind":"word","token":"اماما","display":"اِمٰاماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۲۴","display":"۱۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عظم","display":"عِظَ