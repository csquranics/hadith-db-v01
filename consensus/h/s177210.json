{"members":[{"header_text":" اَلْعَيَّاشِيُّ فِي  تَفْسِيرِهِ عَنْ  مُعَاوِيَةَ بْنِ عَمَّارٍ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ</teller> : ","body_text":"فِي قَوْلِ اللَّهِ <quranic_text>«الْحَجُّ اَشْهُرٌ مَعْلُومٰاتٌ فَمَنْ فَرَضَ فِيهِنَّ الْحَجَّ فَلاٰ رَفَثَ وَ لاٰ فُسُوقَ وَ لاٰ جِدٰالَ فِي الْحَجِّ»</quranic_text> <footnote>[البقرة۱۹۷]</footnote> وَ الرَّفَثُ الْجِمَاعُ وَ الْفُسُوقُ الْكَذِبُ وَ السِّبَابُ وَ الْجِدَالُ قَوْلُ الرَّجُلِ لاَ وَ اللَّهِ وَ بَلَي وَ اللَّهِ.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ TAG_OPEN:quranic_text الْحَجُّ اَشْهُرٌ مَعْلُومٰاتٌ فَمَنْ فَرَضَ فِيهِنَّ الْحَجَّ فَلاٰ رَفَثَ وَ لاٰ فُسُوقَ وَ لاٰ جِدٰالَ فِي الْحَجِّ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۹۷ TAG_CLOSE:footnote وَ الرَّفَثُ الْجِمَاعُ وَ الْفُسُوقُ الْكَذِبُ وَ السِّبَابُ وَ الْجِدَالُ قَوْلُ الرَّجُلِ لاَ وَ اللَّهِ وَ بَلَي وَ اللَّهِ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحج","display":"الْحَجُّ"},{"kind":"word","token":"اشهر","display":"اَشْهُرٌ"},{"kind":"word","token":"معلومات","display":"مَعْلُومٰاتٌ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"فرض","display":"فَرَضَ"},{"kind":"word","token":"فيهن","display":"فِيهِنَّ"},{"kind":"word","token":"الحج","display":"الْحَجَّ"},{"kind":"word","token":"فلا","display":"فَلاٰ"},{"kind":"word","token":"رفث","display":"رَفَثَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"فسوق","display":"فُسُوقَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"جدال","display":"جِدٰالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"tag_close","tag_name":"quranic_te