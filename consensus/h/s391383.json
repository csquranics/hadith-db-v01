{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"قَوْلُهُ <quranic_text>«وَ اِتَّبَعَ مِلَّةَ اِبْرٰاهِيمَ حَنِيفاً»</quranic_text> <footnote>[النساء۱۲۵]</footnote> قَالَ: هِيَ الْحَنِيفَةُ الْعَشَرَةُ الَّتِي جَاءَ بِهَا اِبْرَاهِيمُ الَّتِي لَمْ تُنْسَخْ اِلَي يَوْمِ الْقِيَامَةِ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text وَ اِتَّبَعَ مِلَّةَ اِبْرٰاهِيمَ حَنِيفاً TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۲۵ TAG_CLOSE:footnote قَالَ هِيَ الْحَنِيفَةُ الْعَشَرَةُ الَّتِي جَاءَ بِهَا اِبْرَاهِيمُ الَّتِي لَمْ تُنْسَخْ اِلَي يَوْمِ الْقِيَامَةِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتبع","display":"اِتَّبَعَ"},{"kind":"word","token":"مله","display":"مِلَّةَ"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"word","token":"حنيفا","display":"حَنِيفاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۵","display":"۱۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"الحنيفه","display":"الْحَنِيفَةُ"},{"kind":"word","token":"العشره","display":"الْعَشَرَةُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"جاء","display":"جَاءَ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تنسخ","display":"تُنْسَخْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"يوم","display":"يَوْمِ"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"}]}