{"members":[{"header_text":" فِي أَمَالِي شَيْخِ اَلطَّائِفَةِ قُدِّسَ سِرُّهُ بِإِسْنَادِهِ إِلَى عَلِيِّ بْنِ أَبِي طَالِبٍ عَلَيْهِ اَلسَّلاَمُ قَالَ:","body_text":"قُلْتُ: اَرْبَعٌ اَنْزَلَ اللَّهُ تَعَالَي تَصْدِيقِي بِهَا فِي كِتَابِهِ اِلَي قَوْلِهِ عَلَيْهِ السَّلاَمُ وَ قُلْتُ قَدْراً وَ قَالَ: قِيمَةُ كُلِّ اِمْرِئٍ مَا يُحْسِنُهُ فَاَنْزَلَ اللَّهُ فِي قِصَّةِ طَالُوتَ: <quranic_text>«اِنَّ اللّٰهَ اِصْطَفٰاهُ عَلَيْكُمْ وَ زٰادَهُ بَسْطَةً فِي الْعِلْمِ وَ الْجِسْمِ»</quranic_text> <footnote>[البقرة۲۴۷]</footnote> .","translation":"","aligned_body":"قُلْتُ اَرْبَعٌ اَنْزَلَ اللَّهُ تَعَالَي تَصْدِيقِي بِهَا فِي كِتَابِهِ اِلَي قَوْلِهِ عَلَيْهِ السَّلاَمُ وَ قُلْتُ قَدْراً وَ قَالَ قِيمَةُ كُلِّ اِمْرِئٍ مَا يُحْسِنُهُ فَاَنْزَلَ اللَّهُ فِي قِصَّةِ طَالُوتَ TAG_OPEN:quranic_text اِنَّ اللّٰهَ اِصْطَفٰاهُ عَلَيْكُمْ وَ زٰادَهُ بَسْطَةً فِي الْعِلْمِ وَ الْجِسْمِ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۴۷ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"اربع","display":"اَرْبَعٌ"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"تصديقي","display":"تَصْدِيقِي"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتابه","display":"كِتَابِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"قدرا","display":"قَدْراً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قيمه","display":"قِيمَةُ"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word