{"members":[{"header_text":" وَ رَوَاهُ عَنْ <teller> عَلِيٍّ</teller> أَبُو ذَرٍّ اَلْغِفَارِيُّ قَالَ:","body_text":"وَ كَانَ الْاِنْزَالُ بِسُؤَالِ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ حِينَ قَالَ لِلسَّائِلِ مَنْ اَعْطَاكَ فَقَالَ ذَلِكَ الْمُصَلِّي فَقَالَ يَا رَبِّ اِنَّ مُوسَي سَاَلَكَ اَنْ تَجْعَلَ لَهُ وَزِيراً مِنْ اَهْلِهِ وَ اَنَا اَسْاَلُكَ اَنْ تَجْعَلَ لِي وَزِيراً مِنْ اَهْلِي عَلِيّاً اَخِي <quranic_text>«اُشْدُدْ بِهِ اَزْرِي»</quranic_text> <footnote>[طه۳۱]</footnote> .","translation":"","aligned_body":"وَ كَانَ الْاِنْزَالُ بِسُؤَالِ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ حِينَ قَالَ لِلسَّائِلِ مَنْ اَعْطَاكَ فَقَالَ ذَلِكَ الْمُصَلِّي فَقَالَ يَا رَبِّ اِنَّ مُوسَي سَاَلَكَ اَنْ تَجْعَلَ لَهُ وَزِيراً مِنْ اَهْلِهِ وَ اَنَا اَسْاَلُكَ اَنْ تَجْعَلَ لِي وَزِيراً مِنْ اَهْلِي عَلِيّاً اَخِي TAG_OPEN:quranic_text اُشْدُدْ بِهِ اَزْرِي TAG_CLOSE:quranic_text TAG_OPEN:footnote طه ۳۱ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"الانزال","display":"الْاِنْزَالُ"},{"kind":"word","token":"بسؤال","display":"بِسُؤَالِ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"للسائل","display":"لِلسَّائِلِ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"اعطاك","display":"اَعْطَاكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"المصلي","display":"الْمُصَلِّي"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","tok