{"members":[{"header_text":"","body_text":"لِالاَمِ اَلْكَتِفِ: لِيَقُلْ ثَلاَثاً عِنْدَ النَّوْمِ، وَ مَرَّةً عِنْدَ الاِسْتِيقَاظِ: <quranic_text>«اَ لَمْ تَعْلَمْ اَنَّ اللَّهَ لَهُ مُلْكُ السَّمَاوَاتِ وَ الْاَرْضِ وَ مَا لَكُمْ مِنْ»</quranic_text> <footnote>[البقرة۱۰۷]</footnote> وَلِيٍّ وَ لاَ نَصِيرٍ.","translation":"","aligned_body":"لِالاَمِ اَلْكَتِفِ لِيَقُلْ ثَلاَثاً عِنْدَ النَّوْمِ وَ مَرَّةً عِنْدَ الاِسْتِيقَاظِ اَ لَمْ تَعْلَمْ اَنَّ اللَّهَ لَهُ مُلْكُ السَّمَاوَاتِ وَ الْاَرْضِ وَ مَا لَكُمْ مِنْ وَلِيٍّ وَ لاَ نَصِيرٍ"}],"body_consensus_columns":[{"kind":"word","token":"لالام","display":"لِالاَمِ"},{"kind":"word","token":"الكتف","display":"اَلْكَتِفِ"},{"kind":"word","token":"ليقل","display":"لِيَقُلْ"},{"kind":"word","token":"ثلاثا","display":"ثَلاَثاً"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"النوم","display":"النَّوْمِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مره","display":"مَرَّةً"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الاستيقاظ","display":"الاِسْتِيقَاظِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تعلم","display":"تَعْلَمْ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ملك","display":"مُلْكُ"},{"kind":"word","token":"السماوات","display":"السَّمَاوَاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ولي","display":"وَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"نصير","display":"نَصِيرٍ"}]}