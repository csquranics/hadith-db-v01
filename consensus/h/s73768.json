{"members":[{"header_text":" محمّد بن سليمان قال: حدّثنا عبيد اللّه بن محمّد قال: حدّثنا محمّد بن زكريّا قال: حدّثنا العبّاس بن بكّار قال: حدّثنا أبو بكر الهذلي عن عكرمة: عن ابن عبّاس قال:","body_text":"قال: نزلت هذه الاية: <quranic_text>«يٰا اَيُّهَا الَّذِينَ امَنُوا اِذٰا نٰاجَيْتُمُ الرَّسُولَ فَقَدِّمُوا بَيْنَ يَدَيْ نَجْوٰاكُمْ صَدَقَةً»</quranic_text> <footnote>[المجادلة۱۲]</footnote> [/ ۱۲ / المجادلة: ۵۸] قال: امروا ان لا يناجي النبي صلّي اللّه عليه و اله و سلّم احد حتّي يتصدّق بصدقة فامسك القوم و ذلك قبل ان تنزل الزكاة [و] تصدّق عليّ بدينار ثمّ ناجاه عشر مرّات فكان عليّ يقول: و اللّه لهنّ احبّ اليّ من حمر النعم بصبابتهنّ.","translation":"","aligned_body":"قال نزلت هذه الاية TAG_OPEN:quranic_text يٰا اَيُّهَا الَّذِينَ امَنُوا اِذٰا نٰاجَيْتُمُ الرَّسُولَ فَقَدِّمُوا بَيْنَ يَدَيْ نَجْوٰاكُمْ صَدَقَةً TAG_CLOSE:quranic_text TAG_OPEN:footnote المجادلة ۱۲ TAG_CLOSE:footnote / ۱۲ / المجادلة ۵۸ قال امروا ان لا يناجي النبي صلّي اللّه عليه و اله و سلّم احد حتّي يتصدّق بصدقة فامسك القوم و ذلك قبل ان تنزل الزكاة و تصدّق عليّ بدينار ثمّ ناجاه عشر مرّات فكان عليّ يقول و اللّه لهنّ احبّ اليّ من حمر النعم بصبابتهنّ"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"نزلت","display":"نزلت"},{"kind":"word","token":"هذه","display":"هذه"},{"kind":"word","token":"الايه","display":"الاية"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"ناجيتم","display":"نٰاجَيْتُمُ"},{"kind":"word","token":"الرسول","display":"الرَّسُولَ"},{"kind":"word","token":"فقدموا","display":"فَقَدِّمُوا"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"يدي","display":"يَدَيْ"},{"kind":"word","token":"نجواكم","display":"نَجْوٰاكُمْ"},{"kind":"word","token":"صدقه"