{"members":[{"header_text":" فِقْهُ <teller> اَلرِّضَا، عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"ثُمَّ قَالَ عَزَّ وَ جَلَّ <quranic_text>«ذٰلِكَ لِمَنْ لَمْ يَكُنْ اَهْلُهُ حٰاضِرِي الْمَسْجِدِ الْحَرٰامِ»</quranic_text> <footnote>[البقرة۱۹۶]</footnote> مَكَّةَ وَ مِنْ حَوْلَهَا عَلَي ثَمَانِيَةٍ وَ اَرْبَعِينَ مِيلاً مَنْ كَانَ خَارِجاً عَنْ هَذَا الْحَدِّ فَلاَ يَحُجَّ اِلاَّ مُتَمَتِّعاً بِالْعُمْرَةِ اِلَي الْحَجِّ وَ لاَ يَقْبَلُ اللَّهُ غَيْرَهُ مِنْهُ.","translation":"","aligned_body":"ثُمَّ قَالَ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text ذٰلِكَ لِمَنْ لَمْ يَكُنْ اَهْلُهُ حٰاضِرِي الْمَسْجِدِ الْحَرٰامِ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۹۶ TAG_CLOSE:footnote مَكَّةَ وَ مِنْ حَوْلَهَا عَلَي ثَمَانِيَةٍ وَ اَرْبَعِينَ مِيلاً مَنْ كَانَ خَارِجاً عَنْ هَذَا الْحَدِّ فَلاَ يَحُجَّ اِلاَّ مُتَمَتِّعاً بِالْعُمْرَةِ اِلَي الْحَجِّ وَ لاَ يَقْبَلُ اللَّهُ غَيْرَهُ مِنْهُ"}],"body_consensus_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"اهله","display":"اَهْلُهُ"},{"kind":"word","token":"حاضري","display":"حٰاضِرِي"},{"kind":"word","token":"المسجد","display":"الْمَسْجِدِ"},{"kind":"word","token":"الحرام","display":"الْحَرٰامِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۶","display":"۱۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"مكه","display":"مَكَّةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word