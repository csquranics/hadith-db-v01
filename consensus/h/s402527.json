{"members":[{"header_text":" قَالَ عَلِيُّ بْنُ إِبْرَاهِيمَ:","body_text":"قَوْلُهُ <quranic_text>«فَاِنَّمٰا هُمْ فِي شِقٰاقٍ»</quranic_text> <footnote>[البقرة۱۳۷]</footnote> يَعْنِي فِي كُفْرٍ. وَ رَوَاهُ فِي (مَجْمَعِ الْبَيَانِ) عَنْ اَبِي عَبْدِ اللَّهِ (عَلَيْهِ السَّلاَمُ).","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text فَاِنَّمٰا هُمْ فِي شِقٰاقٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۳۷ TAG_CLOSE:footnote يَعْنِي فِي كُفْرٍ وَ رَوَاهُ فِي مَجْمَعِ الْبَيَانِ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فانما","display":"فَاِنَّمٰا"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"شقاق","display":"شِقٰاقٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۳۷","display":"۱۳۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كفر","display":"كُفْرٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رواه","display":"رَوَاهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"مجمع","display":"مَجْمَعِ"},{"kind":"word","token":"البيان","display":"الْبَيَانِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}