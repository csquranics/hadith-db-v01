{"members":[{"header_text":" 267 - وَ عَنْ عَمَّارٍ اَلسَّابَاطِيِّ عَنْ أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ قَالَ:","body_text":"لاَ تَتْرُكُ الْاَرْضَ بِغَيْرِ اِمَامٍ يُحِلُّ حَلاَلَ اللَّهِ وَ يُحَرِّمُ حَرَامَ اللَّهِ، وَ هُوَ قَوْلُ اللَّهِ تَعَالَي: <quranic_text>«يَوْمَ نَدْعُوا كُلَّ اُنٰاسٍ بِاِمٰامِهِمْ»</quranic_text> <footnote>[الاسراء۷۱]</footnote> ثُمَّ قَالَ: قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ: مَنْ مَاتَ بِغَيْرِ اِمَامٍ مَاتَ مِيتَةً جَاهِلِيَّةً (اَلْحَدِيثَ).","translation":"","aligned_body":"لاَ تَتْرُكُ الْاَرْضَ بِغَيْرِ اِمَامٍ يُحِلُّ حَلاَلَ اللَّهِ وَ يُحَرِّمُ حَرَامَ اللَّهِ وَ هُوَ قَوْلُ اللَّهِ تَعَالَي TAG_OPEN:quranic_text يَوْمَ نَدْعُوا كُلَّ اُنٰاسٍ بِاِمٰامِهِمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الاسراء ۷۱ TAG_CLOSE:footnote ثُمَّ قَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ مَنْ مَاتَ بِغَيْرِ اِمَامٍ مَاتَ مِيتَةً جَاهِلِيَّةً اَلْحَدِيثَ"}],"body_consensus_columns":[{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تترك","display":"تَتْرُكُ"},{"kind":"word","token":"الارض","display":"الْاَرْضَ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"امام","display":"اِمَامٍ"},{"kind":"word","token":"يحل","display":"يُحِلُّ"},{"kind":"word","token":"حلال","display":"حَلاَلَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يحرم","display":"يُحَرِّمُ"},{"kind":"word","token":"حرام","display":"حَرَامَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"ندعوا","display":"نَدْعُوا"},{"kind":"word"