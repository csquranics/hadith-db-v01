{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"وَ قَوْلُهُ: <quranic_text>«لاٰ يُحِبُّ اللّٰهُ الْجَهْرَ بِالسُّوءِ مِنَ الْقَوْلِ اِلاّٰ مَنْ ظُلِمَ»</quranic_text> <footnote>[النساء۱۴۸]</footnote> : اَيْ لاَ يُحِبُّ اَنْ يَجْهَرَ الرَّجُلُ بِالظُّلْمِ وَ السُّوءِ وَ يَظْلِمَ اِلاَّ مَنْ ظَلَمَ فَقَدْ اَطْلَقَ لَهُ اَنْ يُعَارِضَهُ بِالظُّلْمِ.","translation":"","aligned_body":"وَ قَوْلُهُ TAG_OPEN:quranic_text لاٰ يُحِبُّ اللّٰهُ الْجَهْرَ بِالسُّوءِ مِنَ الْقَوْلِ اِلاّٰ مَنْ ظُلِمَ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۴۸ TAG_CLOSE:footnote اَيْ لاَ يُحِبُّ اَنْ يَجْهَرَ الرَّجُلُ بِالظُّلْمِ وَ السُّوءِ وَ يَظْلِمَ اِلاَّ مَنْ ظَلَمَ فَقَدْ اَطْلَقَ لَهُ اَنْ يُعَارِضَهُ بِالظُّلْمِ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يحب","display":"يُحِبُّ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"الجهر","display":"الْجَهْرَ"},{"kind":"word","token":"بالسوء","display":"بِالسُّوءِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"القول","display":"الْقَوْلِ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"ظلم","display":"ظُلِمَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۴۸","display":"۱۴۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يحب","display":"يُحِبُّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يجهر","display":"يَجْهَرَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"بالظلم","display":"بِالظُّلْمِ"},{"kin