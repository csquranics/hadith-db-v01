{"members":[{"header_text":" قَالَ  اِبْنُ أَبِي اَلْحَدِيدِ هَذِهِ اَلرِّوَايَةُ تُوَافِقُ مَا يَذْكُرُهُ: <teller> أَمِيرُ اَلْمُؤْمِنِينَ عَلَيْهِ اَلسَّلاَمُ</teller> فِي كَلاَمِهِ:","body_text":"اِذْ يَقُولُ لِمُعَاوِيَةَ وَ عِنْدِي السَّيْفُ الَّذِي اَعْضَضَتُ بِهِ اَخَاكَ وَ خَالَكَ وَ جَدَّكَ يَوْمَ بَدْرٍ وَ يَقُولُ فِي مَوْضِعٍ اخَرَ قَدْ عَرَفْتُ مَوَاضِعَ نِصَالِهَا فِي اَخِيكَ وَ خَالِكَ وَ جَدِّكَ <quranic_text>«وَ مٰا هِيَ مِنَ الظّٰالِمِينَ بِبَعِيدٍ»</quranic_text> <footnote>[هود۸۳]</footnote> .","translation":"","aligned_body":"اِذْ يَقُولُ لِمُعَاوِيَةَ وَ عِنْدِي السَّيْفُ الَّذِي اَعْضَضَتُ بِهِ اَخَاكَ وَ خَالَكَ وَ جَدَّكَ يَوْمَ بَدْرٍ وَ يَقُولُ فِي مَوْضِعٍ اخَرَ قَدْ عَرَفْتُ مَوَاضِعَ نِصَالِهَا فِي اَخِيكَ وَ خَالِكَ وَ جَدِّكَ TAG_OPEN:quranic_text وَ مٰا هِيَ مِنَ الظّٰالِمِينَ بِبَعِيدٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote هود ۸۳ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"لمعاويه","display":"لِمُعَاوِيَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عندي","display":"عِنْدِي"},{"kind":"word","token":"السيف","display":"السَّيْفُ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"اعضضت","display":"اَعْضَضَتُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"اخاك","display":"اَخَاكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"خالك","display":"خَالَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جدك","display":"جَدَّكَ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"بدر","display":"بَدْرٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"موضع","display":"مَوْضِعٍ"},{"kind":"word","token":"اخر","display":"اخَرَ"},{"kind":"word","token":"قد","display":"قَد