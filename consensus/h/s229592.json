{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ لَمْ يَجْعَلْ لَهُ عِوَجاً قَيِّماً»</quranic_text> <footnote>[الكهف۱]</footnote> قَالَ هَذَا مُقَدَّمٌ وَ مُؤَخَّرٌ لِاَنَّ مَعْنَاهُ الَّذِي اَنْزَلَ عَلَي عَبْدِهِ الْكِتَابَ قَيِّماً وَ لَمْ يَجْعَلْ لَهُ عِوَجاً فَقَدْ قَدَّمَ حَرْفاً عَلَي حَرْفٍ.","translation":"","aligned_body":"TAG_OPEN:quranic_text وَ لَمْ يَجْعَلْ لَهُ عِوَجاً قَيِّماً TAG_CLOSE:quranic_text TAG_OPEN:footnote الكهف ۱ TAG_CLOSE:footnote قَالَ هَذَا مُقَدَّمٌ وَ مُؤَخَّرٌ لِاَنَّ مَعْنَاهُ الَّذِي اَنْزَلَ عَلَي عَبْدِهِ الْكِتَابَ قَيِّماً وَ لَمْ يَجْعَلْ لَهُ عِوَجاً فَقَدْ قَدَّمَ حَرْفاً عَلَي حَرْفٍ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يجعل","display":"يَجْعَلْ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"عوجا","display":"عِوَجاً"},{"kind":"word","token":"قيما","display":"قَيِّماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"مقدم","display":"مُقَدَّمٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مؤخر","display":"مُؤَخَّرٌ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"معناه","display":"مَعْنَاهُ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"عبده","display":"عَبْدِهِ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابَ"},{"kind":"word","token":"قيما","display":"قَيِّماً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","displ