{"members":[{"header_text":" اَلطَّبْرِسِيُّ:","body_text":"فِي قَوْلِهِ تَعَالَي: <quranic_text>«فَاسْعَوْا اِليٰ ذِكْرِ اللّٰهِ»</quranic_text> <footnote>[الجمعة۹]</footnote> ، قَالَ: قَرَاَ عَبْدُ اللَّهِ بْنُ مَسْعُودٍ: «فَامْضُوا اِلَي ذِكْرِ اللَّهِ» قَالَ: وَ رُوِيَ ذَلِكَ عَنْ عَلِيٍّ (عَلَيْهِ السَّلاَمُ)، وَ قَالَ: وَ هُوَ الْمَرْوِيُّ، عَنْ اَبِي جَعْفَرٍ وَ اَبِي عَبْدِ اللَّهِ (عَلَيْهِمَا السَّلاَمُ).","translation":"","aligned_body":"فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text فَاسْعَوْا اِليٰ ذِكْرِ اللّٰهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الجمعة ۹ TAG_CLOSE:footnote قَالَ قَرَاَ عَبْدُ اللَّهِ بْنُ مَسْعُودٍ فَامْضُوا اِلَي ذِكْرِ اللَّهِ قَالَ وَ رُوِيَ ذَلِكَ عَنْ عَلِيٍّ عَلَيْهِ السَّلاَمُ وَ قَالَ وَ هُوَ الْمَرْوِيُّ عَنْ اَبِي جَعْفَرٍ وَ اَبِي عَبْدِ اللَّهِ عَلَيْهِمَا السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاسعوا","display":"فَاسْعَوْا"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"ذكر","display":"ذِكْرِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الجمعه","display":"الجمعة"},{"kind":"word","token":"۹","display":"۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"عبد","display":"عَبْدُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"مسعود","display":"مَسْعُودٍ"},{"kind":"word","token":"فامضوا","display":"فَامْضُوا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ذكر","display":"ذِكْرِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","toke