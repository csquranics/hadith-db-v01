{"members":[{"header_text":" [عَنْ  مُحَمَّدِ بْنِ سَهْلٍ اَلْبَحْرَانِيِّ ] عَنْ  بَعْضِ أَصْحَابِنَا عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> قَالَ:","body_text":"اَلْبَكَّاءُونَ خَمْسَةٌ: ادَمُ وَ يَعْقُوبُ وَ يُوسُفُ وَ فَاطِمَةُ بِنْتُ مُحَمَّدٍ وَ عَلِيُّ بْنُ الْحُسَيْنِ عَلَيْهِمَا السَّلاَمُ وَ اَمَّا يَعْقُوبُ فَبَكَي عَلَي يُوسُفَ حَتَّي ذَهَبَ بَصَرُهُ وَ حَتَّي قِيلَ لَهُ: <quranic_text>«تَفْتَؤُا تَذْكُرُ يُوسُفَ حَتّٰي تَكُونَ حَرَضاً اَوْ تَكُونَ مِنَ الْهٰالِكِينَ»</quranic_text> <footnote>[يوسف۸۵]</footnote> .","translation":"","aligned_body":"اَلْبَكَّاءُونَ خَمْسَةٌ ادَمُ وَ يَعْقُوبُ وَ يُوسُفُ وَ فَاطِمَةُ بِنْتُ مُحَمَّدٍ وَ عَلِيُّ بْنُ الْحُسَيْنِ عَلَيْهِمَا السَّلاَمُ وَ اَمَّا يَعْقُوبُ فَبَكَي عَلَي يُوسُفَ حَتَّي ذَهَبَ بَصَرُهُ وَ حَتَّي قِيلَ لَهُ TAG_OPEN:quranic_text تَفْتَؤُا تَذْكُرُ يُوسُفَ حَتّٰي تَكُونَ حَرَضاً اَوْ تَكُونَ مِنَ الْهٰالِكِينَ TAG_CLOSE:quranic_text TAG_OPEN:footnote يوسف ۸۵ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"البكاءون","display":"اَلْبَكَّاءُونَ"},{"kind":"word","token":"خمسه","display":"خَمْسَةٌ"},{"kind":"word","token":"ادم","display":"ادَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يعقوب","display":"يَعْقُوبُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يوسف","display":"يُوسُفُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةُ"},{"kind":"word","token":"بنت","display":"بِنْتُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"يعقوب",