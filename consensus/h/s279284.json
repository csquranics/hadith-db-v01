{"members":[{"header_text":" شي،  [تفسير  العياشي ] ، عَنْ  يُونُسَ  عَمَّنْ رَفَعَهُ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ <quranic_text>«وَ لَقَدْ اتَيْنٰاكَ سَبْعاً مِنَ الْمَثٰانِي وَ الْقُرْانَ الْعَظِيمَ»</quranic_text> <footnote>[الحجر۸۷]</footnote> قَالَ هِيَ سُورَةُ الْحَمْدِ وَ هِيَ سَبْعُ ايَاتٍ مِنْهَا <quranic_text>«بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ -»</quranic_text> <footnote>[الفاتحة۱]</footnote> وَ اِنَّمَا سُمِّيَتْ لِاَنَّهَا يُثَنَّي فِي الرَّكْعَتَيْنِ.","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ وَ لَقَدْ اتَيْنٰاكَ سَبْعاً مِنَ الْمَثٰانِي وَ الْقُرْانَ الْعَظِيمَ الحجر۸۷ قَالَ هِيَ سُورَةُ الْحَمْدِ وَ هِيَ سَبْعُ ايَاتٍ مِنْهَا بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ - الفاتحة۱ وَ اِنَّمَا سُمِّيَتْ لِاَنَّهَا يُثَنَّي فِي الرَّكْعَتَيْنِ"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"اتيناك","display":"اتَيْنٰاكَ"},{"kind":"word","token":"سبعا","display":"سَبْعاً"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المثاني","display":"الْمَثٰانِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"القران","display":"الْقُرْانَ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمَ"},{"kind":"word","token":"الحجر۸۷","display":"الحجر۸۷"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"سوره","display":"سُورَةُ"},{"kind":"word","token":"الحمد","display":"الْحَمْدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word",