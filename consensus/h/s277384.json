{"members":[{"header_text":" اَلْعَيَّاشِيُّ ، عَنْ  حَمَّادِ بْنِ عُثْمَانَ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"فِي قَوْلِهِ: <quranic_text>«فَمَنِ اُضْطُرَّ غَيْرَ بٰاغٍ وَ لاٰ عٰادٍ»</quranic_text> <footnote>[البقرة۱۷۳]</footnote> - قَالَ الْبَاغِي طَالِبُ الصَّيْدِ وَ الْعَادِي السَّارِقُ لَيْسَ لَهُمَا اَنْ يُقَصِّرَا مِنَ الصَّلاَةِ وَ لَيْسَ لَهُمَا اِذَا اُضْطُرَّا اِلَي الْمَيْتَةِ اَنْ يَاْكُلاَهَا وَ لاَ يَحِلُّ لَهُمَا مَا يَحِلُّ لِلنَّاسِ اِذَا اُضْطُرُّوا.","translation":"","aligned_body":"فِي قَوْلِهِ TAG_OPEN:quranic_text فَمَنِ اُضْطُرَّ غَيْرَ بٰاغٍ وَ لاٰ عٰادٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۷۳ TAG_CLOSE:footnote - قَالَ الْبَاغِي طَالِبُ الصَّيْدِ وَ الْعَادِي السَّارِقُ لَيْسَ لَهُمَا اَنْ يُقَصِّرَا مِنَ الصَّلاَةِ وَ لَيْسَ لَهُمَا اِذَا اُضْطُرَّا اِلَي الْمَيْتَةِ اَنْ يَاْكُلاَهَا وَ لاَ يَحِلُّ لَهُمَا مَا يَحِلُّ لِلنَّاسِ اِذَا اُضْطُرُّوا"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمن","display":"فَمَنِ"},{"kind":"word","token":"اضطر","display":"اُضْطُرَّ"},{"kind":"word","token":"غير","display":"غَيْرَ"},{"kind":"word","token":"باغ","display":"بٰاغٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"عاد","display":"عٰادٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۷۳","display":"۱۷۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الباغي","display":"الْبَاغِي"},{"kind":"word","token":"طالب","display":"طَالِبُ"},{"kind":"word","token":"الصيد","display":"الصَّيْدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"