{"members":[{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، عَنْ <teller> جَعْفَرِ بْنِ مُحَمَّدٍ عَلَيْهِ السَّلاَمُ</teller> أَنَّهُ قَالَ:","body_text":"وَ يُعْطَي الْمُؤْمِنُ مِنَ الزَّكَاةِ مَا يَاْكُلُ مِنْهُ وَ يَشْرَبُ وَ يَكْتَسِي وَ يَتَزَوَّجُ وَ يَحُجُّ وَ يَتَصَدَّقُ وَ يُوفِي دَيْنَهُ:.","translation":"","aligned_body":"- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - وَ يُعْطَي الْمُؤْمِنُ مِنَ الزَّكَاةِ مَا يَاْكُلُ مِنْهُ وَ يَشْرَبُ وَ يَكْتَسِي وَ يَتَزَوَّجُ وَ يَحُجُّ وَ يَتَصَدَّقُ وَ يُوفِي دَيْنَهُ"},{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، عَنْ <teller> جَعْفَرِ بْنِ مُحَمَّدٍ عَلَيْهِ السَّلاَمُ</teller> أَنَّهُ قَالَ:","body_text":"وَ يُعْطَي الْمُؤْمِنُ مِنَ الزَّكَاةِ مَا يَاْكُلُ مِنْهُ وَ يَشْرَبُ وَ يَكْتَسِي وَ يَتَزَوَّجُ وَ يَحُجُّ وَ يَتَصَدَّقُ وَ يُوفِي دَيْنَهُ.","translation":"","aligned_body":"- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - وَ يُعْطَي الْمُؤْمِنُ مِنَ الزَّكَاةِ مَا يَاْكُلُ مِنْهُ وَ يَشْرَبُ وَ يَكْتَسِي وَ يَتَزَوَّجُ وَ يَحُجُّ وَ يَتَصَدَّقُ وَ يُوفِي دَيْنَهُ"},{"header_text":" وَ عَنْ<teller> جَعْفَرِ بْنِ مُحَمَّدٍ صَلَوَاتُ اللَّهِ عَلَيْهِ</teller> :","body_text":"اَنَّهُ سُئِلَ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ- <quranic_text>«اِنَّمَا الصَّدَقٰاتُ لِلْفُقَرٰاءِ وَ الْمَسٰاكِينِ»</quranic_text> <footnote>[التوبة۶۰]</footnote> فَقَالَ الْفَقِيرُ الَّذِي لاَ يَسْاَلُ وَ الْمِسْكِينُ اَجْهَدُ مِنْهُ وَ الْبَائِسُ الْفَقِيرُ اَجْهَدُ مِنْهُمَا حَالاً وَ لاَ يُعْطَي مِنَ الزَّكَاةِ اِلاَّ اَهْلُ الْوَلاَيَةِ مِنَ الْمُؤْمِنِينَ قِيلَ لَهُ فَاِذَا لَمْ يَكُنْ بِالْمَوْضِعِ وَلِيٌّ مُحْتَاجٌ اِلَيْهَا قَالَ يُبْعَثُ بِهَا اِلَي مَوْضِعٍ اخَرَ فَتُقْسَمُ فِي اَهْلِ الْوَلاَيَةِ وَ لاَ تُعْطِ قَوْماً اِنْ دَعَوْتَهُمْ اِلَي اَمْرِكَ لَمْ يُجِيبُوكَ وَ لَوْ كَانَ الذَّبْحُ وَ اَهْوَي بِيَدِهِ اِلَي حَلْقِهِ قِيلَ لَهُ فَاِنْ لَمْ يُوجَدْ مُؤْمِنٌ مُسْتَحِقٌّ قَالَ يُعْطَي الْمُسْتَضْعَفُونَ الَّذِينَ لاَ يَنْصِبُونَ وَ يُعْطَي الْمُؤْمِنُ مِنَ الزَّكَاةِ مَا يَاْكُلُ مِنْهُ وَ يَشْرَبُ وَ يَكْتَسِي وَ يَتَزَوَّجُ وَ يَحُجُّ وَ يَتَصَدَّقُ.","translation":"","aligned_body":"اَنَّهُ سُئِلَ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ- TAG_OPEN:quranic_text اِنَّمَا الصَّدَقٰاتُ لِلْفُقَرٰاءِ وَ الْمَسٰاكِينِ TAG_CLOSE:quranic_text TAG_OPEN:footnote التوبة ۶۰ TAG_CLOSE:footnote فَقَالَ الْفَقِيرُ الَّذِي لاَ يَسْاَلُ وَ الْمِسْكِينُ اَجْهَدُ مِنْهُ وَ الْبَائِسُ الْفَقِيرُ اَجْهَدُ مِنْهُمَا حَالاً وَ لاَ يُعْطَي مِنَ الزَّكَاةِ اِلاَّ اَهْلُ الْوَلاَيَةِ مِنَ الْمُؤْمِنِينَ قِيلَ لَهُ فَاِذَا لَمْ يَكُنْ بِالْمَوْضِعِ وَلِيٌّ مُحْتَاجٌ اِلَيْهَا قَالَ يُبْعَثُ بِهَا اِلَي مَوْضِعٍ اخَرَ فَتُقْسَمُ فِي اَهْلِ الْوَلاَيَةِ وَ لاَ تُعْطِ قَوْماً اِنْ دَعَوْتَهُمْ اِلَي اَمْرِكَ لَمْ يُجِيبُوكَ وَ لَوْ كَانَ الذَّبْحُ وَ اَهْوَي بِيَدِهِ اِلَي حَلْقِهِ قِيلَ لَهُ فَاِنْ لَمْ يُوجَدْ مُؤْمِنٌ مُسْتَحِقٌّ قَالَ يُعْطَي الْمُسْتَضْعَفُونَ الَّذِينَ لاَ يَنْصِبُونَ وَ يُعْطَي الْمُؤْمِنُ مِنَ الزَّكَاةِ مَا يَاْكُلُ مِنْهُ وَ يَشْرَبُ وَ يَكْتَسِي وَ يَتَزَوَّجُ وَ يَحُجُّ وَ يَتَصَدَّقُ - - -"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل-","display":"جَلَّ-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"الصدقات","display":"الصَّدَقٰاتُ"},{"kind":"word","token":"للفقراء","display":"لِلْفُقَرٰاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المساكين","display":"الْمَسٰاكِينِ"