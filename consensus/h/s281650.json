{"members":[{"header_text":" وَ فِي رِوَايَةٍ أُخْرَى: ","body_text":"رَبُّ اَلسَّمَاوَاتِ وَ الْاَرَضِينَ <quranic_text>«عٰالِمُ الْغَيْبِ وَ الشَّهٰادَةِ الْكَبِيرُ الْمُتَعٰالِ»</quranic_text> <footnote>[الرعد۹]</footnote> الْحَنَّانُ الْمَنَّانُ ذُو الْجَلاَلِ وَ الْاِكْرَامِ اَنْ تَفْعَلَ بِي كَذَا وَ كَذَا وَ تَجْعَلَهُ اَنْتَ اَنْ تُصَلِّيَ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ وَ اَنْ تَفْعَلَ بِي كَذَا وَ كَذَا فَاِنَّهُ يُسْتَجَابُ لَكَ اِنْ شَاءَ اللَّهُ هَذَا لَفْظُهُ كَمَا وَجَدْنَاهُ.","translation":"","aligned_body":"رَبُّ اَلسَّمَاوَاتِ وَ الْاَرَضِينَ TAG_OPEN:quranic_text عٰالِمُ الْغَيْبِ وَ الشَّهٰادَةِ الْكَبِيرُ الْمُتَعٰالِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۹ TAG_CLOSE:footnote الْحَنَّانُ الْمَنَّانُ ذُو الْجَلاَلِ وَ الْاِكْرَامِ اَنْ تَفْعَلَ بِي كَذَا وَ كَذَا وَ تَجْعَلَهُ اَنْتَ اَنْ تُصَلِّيَ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ وَ اَنْ تَفْعَلَ بِي كَذَا وَ كَذَا فَاِنَّهُ يُسْتَجَابُ لَكَ اِنْ شَاءَ اللَّهُ هَذَا لَفْظُهُ كَمَا وَجَدْنَاهُ"}],"body_consensus_columns":[{"kind":"word","token":"رب","display":"رَبُّ"},{"kind":"word","token":"السماوات","display":"اَلسَّمَاوَاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارضين","display":"الْاَرَضِينَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"عالم","display":"عٰالِمُ"},{"kind":"word","token":"الغيب","display":"الْغَيْبِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الشهاده","display":"الشَّهٰادَةِ"},{"kind":"word","token":"الكبير","display":"الْكَبِيرُ"},{"kind":"word","token":"المتعال","display":"الْمُتَعٰالِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۹","display":"۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الحنان","display":"الْحَنَّانُ"},{"kind":"word","token":"المنان","display":"الْمَنَّانُ"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","tok