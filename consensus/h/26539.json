{"members":[{"header_text":" شي،  [تفسير  العياشي ] ،  جَعْفَرُ بْنُ أَحْمَدَ عَنْ  عَلِيِّ بْنِ مُحَمَّدِ بْنِ شُجَاعٍ قَالَ رَوَى  أَصْحَابُنَا :","body_text":"قِيلَ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ لِمَ صَارَ الْحَاجُّ لاَ يُكْتَبُ عَلَيْهِ ذَنْبٌ اَرْبَعَةَ اَشْهُرٍ قَالَ اِنَّ اللَّهَ جَلَّ ذِكْرُهُ اَمَرَ الْمُشْرِكِينَ فَقَالَ: <quranic_text>«فَسِيحُوا فِي الْاَرْضِ اَرْبَعَةَ اَشْهُرٍ»</quranic_text> <footnote>[التوبة۲]</footnote> وَ لَمْ يَكُنْ يُقَصِّرُ بِوَفْدِهِ عَنْ ذَلِكَ.","translation":"","aligned_body":"قِيلَ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ لِمَ صَارَ الْحَاجُّ لاَ يُكْتَبُ عَلَيْهِ ذَنْبٌ اَرْبَعَةَ اَشْهُرٍ قَالَ اِنَّ اللَّهَ جَلَّ ذِكْرُهُ اَمَرَ الْمُشْرِكِينَ فَقَالَ TAG_OPEN:quranic_text فَسِيحُوا فِي الْاَرْضِ اَرْبَعَةَ اَشْهُرٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote التوبة ۲ TAG_CLOSE:footnote وَ لَمْ يَكُنْ يُقَصِّرُ بِوَفْدِهِ عَنْ ذَلِكَ"}],"body_consensus_columns":[{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"لم","display":"لِمَ"},{"kind":"word","token":"صار","display":"صَارَ"},{"kind":"word","token":"الحاج","display":"الْحَاجُّ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يكتب","display":"يُكْتَبُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"ذنب","display":"ذَنْبٌ"},{"kind":"word","token":"اربعه","display":"اَرْبَعَةَ"},{"kind":"word","token":"اشهر","display":"اَشْهُرٍ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"ذكره","display":"ذِكْرُهُ"},{"kind":"word","token":"امر","display":"اَمَرَ"},{"kind":"word"