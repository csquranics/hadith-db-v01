{"members":[{"header_text":" [وَ عَنْ]  حَمْدَوَيْهِ قَالَ: قَالَ: حَدَّثَنَا  أَيُّوبُ بْنُ نُوحِ بْنِ دَرَّاجٍ ، عَنْ  مُحَمَّدِ بْنِ اَلْفُضَيْلِ ، عَنْ  أَبِي اَلصَّبَّاحِ قَالَ:","body_text":"قَالَ لِي جَعْفَرُ بْنُ مُحَمَّدٍ : يَا [اَ] بَا الصَّبَّاحِ اَ مَا سَمِعْتَ اللَّهَ يَقُولُ فِي كِتَابِهِ: <quranic_text>«اَمْ يَحْسُدُونَ النّٰاسَ عَليٰ مٰا اتٰاهُمُ اللّٰهُ مِنْ فَضْلِهِ»</quranic_text> <footnote>[النساء۵۴]</footnote> الْايَةَ - قُلْتُ: بَلَي اَصْلَحَكَ اللَّهُ. قَالَ: نَحْنُ وَ اللَّهِ هُمْ، نَحْنُ وَ اللَّهِ الْمَحْسُودُونَ.","translation":"","aligned_body":"قَالَ لِي جَعْفَرُ بْنُ مُحَمَّدٍ يَا اَ بَا الصَّبَّاحِ اَ مَا سَمِعْتَ اللَّهَ يَقُولُ فِي كِتَابِهِ TAG_OPEN:quranic_text اَمْ يَحْسُدُونَ النّٰاسَ عَليٰ مٰا اتٰاهُمُ اللّٰهُ مِنْ فَضْلِهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۵۴ TAG_CLOSE:footnote الْايَةَ - قُلْتُ بَلَي اَصْلَحَكَ اللَّهُ قَالَ نَحْنُ وَ اللَّهِ هُمْ نَحْنُ وَ اللَّهِ الْمَحْسُودُونَ"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"با","display":"بَا"},{"kind":"word","token":"الصباح","display":"الصَّبَّاحِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"سمعت","display":"سَمِعْتَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتابه","display":"كِتَابِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"يحسدون","display":"يَحْسُدُونَ"},{"kind":"word","token":"الناس","display":"النّٰاسَ"},{"kind":"word","token":"علي","display":"عَليٰ"