{"members":[{"header_text":" العيّاشيّ عن <teller> الصادق عليه السلام</teller> قال:","body_text":" <quranic_text>«اِنَّ الْاَرْضَ لِلّٰهِ يُورِثُهٰا مَنْ يَشٰاءُ مِنْ عِبٰادِهِ»</quranic_text> <footnote>[الاعراف۱۲۸]</footnote> قال فما كان للّٰه فهو لرسوله و ما كان لرسول اللّٰه فهو للامام بعد رسول اللّٰه صلّي اللّٰه عليه و اله و سلم.","translation":"","aligned_body":"TAG_OPEN:quranic_text اِنَّ الْاَرْضَ لِلّٰهِ يُورِثُهٰا مَنْ يَشٰاءُ مِنْ عِبٰادِهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الاعراف ۱۲۸ TAG_CLOSE:footnote قال فما كان للّٰه فهو لرسوله و ما كان لرسول اللّٰه فهو للامام بعد رسول اللّٰه صلّي اللّٰه عليه و اله و سلم"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الارض","display":"الْاَرْضَ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"يورثها","display":"يُورِثُهٰا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يشاء","display":"يَشٰاءُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عباده","display":"عِبٰادِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۲۸","display":"۱۲۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"فما","display":"فما"},{"kind":"word","token":"كان","display":"كان"},{"kind":"word","token":"لله","display":"للّٰه"},{"kind":"word","token":"فهو","display":"فهو"},{"kind":"word","token":"لرسوله","display":"لرسوله"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"كان","display":"كان"},{"kind":"word","token":"لرسول","display":"لرسول"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"فهو","display":"فهو"},{"kind":"word","token":"للامام","display":"للامام"},{"kind":"word","token":"بعد","display":"بع