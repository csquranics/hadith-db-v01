{"members":[{"header_text":" مُحَمَّدُ بْنُ مُسْلِمٍ قَالَ:","body_text":"قُلْتُ لَهُ: الصَّلاَةُ الْوُسْطَي؟ قَالَ: <quranic_text>«حٰافِظُوا عَلَي الصَّلَوٰاتِ وَ الصَّلاٰةِ الْوُسْطيٰ وَ قُومُوا لِلّٰهِ قٰانِتِينَ»</quranic_text> <footnote>[البقرة۲۳۸]</footnote> وَ الْوُسْطَي هُوَ الظُّهْرُ، وَ كَانَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ يَقْرَاُهَا هَكَذَا.","translation":"","aligned_body":"قُلْتُ لَهُ الصَّلاَةُ الْوُسْطَي قَالَ TAG_OPEN:quranic_text حٰافِظُوا عَلَي الصَّلَوٰاتِ وَ الصَّلاٰةِ الْوُسْطيٰ وَ قُومُوا لِلّٰهِ قٰانِتِينَ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۳۸ TAG_CLOSE:footnote وَ الْوُسْطَي هُوَ الظُّهْرُ وَ كَانَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ يَقْرَاُهَا هَكَذَا"}],"body_consensus_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةُ"},{"kind":"word","token":"الوسطي","display":"الْوُسْطَي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حافظوا","display":"حٰافِظُوا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الصلوات","display":"الصَّلَوٰاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةِ"},{"kind":"word","token":"الوسطي","display":"الْوُسْطيٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوموا","display":"قُومُوا"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"قانتين","display":"قٰانِتِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۳۸","display":"۲۳۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الوسطي","display":"الْوُسْطَي"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الظهر","display":"الظ