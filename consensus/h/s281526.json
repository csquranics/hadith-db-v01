{"members":[{"header_text":" وَ مِنْهُ عَنْ  أَبِي زُمَيْلٍ قَالَ:","body_text":"سَاَلْتُ اِبْنَ عَبَّاسٍ عَمَّا يَجِدُ الْاِنْسَانُ فِي صَدْرِهِ مِنَ الشَّكِّ فَقَالَ مَا نَجَا مِنْ ذَلِكَ اَحَدٌ وَ قَدْ اَنْزَلَ اللَّهُ فَاِنْ كُنْتَ فِي شَكٍّ اِذَا وَجَدْتَ ذَلِكَ فَقُلْ <quranic_text>«هُوَ الْاَوَّلُ وَ الْاخِرُ وَ الظّٰاهِرُ وَ الْبٰاطِنُ وَ هُوَ بِكُلِّ شَيْءٍ عَلِيمٌ»</quranic_text> <footnote>[الحديد۳]</footnote> .","translation":"","aligned_body":"سَاَلْتُ اِبْنَ عَبَّاسٍ عَمَّا يَجِدُ الْاِنْسَانُ فِي صَدْرِهِ مِنَ الشَّكِّ فَقَالَ مَا نَجَا مِنْ ذَلِكَ اَحَدٌ وَ قَدْ اَنْزَلَ اللَّهُ فَاِنْ كُنْتَ فِي شَكٍّ اِذَا وَجَدْتَ ذَلِكَ فَقُلْ TAG_OPEN:quranic_text هُوَ الْاَوَّلُ وَ الْاخِرُ وَ الظّٰاهِرُ وَ الْبٰاطِنُ وَ هُوَ بِكُلِّ شَيْءٍ عَلِيمٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحديد ۳ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"عباس","display":"عَبَّاسٍ"},{"kind":"word","token":"عما","display":"عَمَّا"},{"kind":"word","token":"يجد","display":"يَجِدُ"},{"kind":"word","token":"الانسان","display":"الْاِنْسَانُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"صدره","display":"صَدْرِهِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الشك","display":"الشَّكِّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"نجا","display":"نَجَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"كنت","display":"كُنْتَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"wo