{"members":[{"header_text":" 713 - وَ عَنْ بُرَيْدِ بْنِ مُعَاوِيَةَ عَنْ أَبِي جَعْفَرٍ عَلَيْهِ اَلسَّلاَمُ:","body_text":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ: <quranic_text>«اِنَّمٰا اَنْتَ مُنْذِرٌ وَ لِكُلِّ قَوْمٍ هٰادٍ»</quranic_text> <footnote>[الرعد۷]</footnote> فَقَالَ: قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ: اَنَا الْمُنْذِرُ وَ فِي كُلِّ زَمَانٍ مِنَّا اِمَامٌ يَهْدِيهِمْ [اَلْحَدِيثَ].","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text اِنَّمٰا اَنْتَ مُنْذِرٌ وَ لِكُلِّ قَوْمٍ هٰادٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۷ TAG_CLOSE:footnote فَقَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ اَنَا الْمُنْذِرُ وَ فِي كُلِّ زَمَانٍ مِنَّا اِمَامٌ يَهْدِيهِمْ اَلْحَدِيثَ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"منذر","display":"مُنْذِرٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"قوم","display":"قَوْمٍ"},{"kind":"word","token":"هاد","display":"هٰادٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":