{"members":[{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، رُوِّيْنَا عَنْ <teller> جَعْفَرِ بْنِ مُحَمَّدٍ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"اَنَّهُ سُئِلَ عَنِ اللَّهْوِ فِي غَيْرِ النِّكَاحِ فَاَنْكَرَهُ وَ تَلاَ قَوْلَ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«وَ مٰا خَلَقْنَا السَّمٰاءَ وَ الْاَرْضَ وَ مٰا بَيْنَهُمٰا لاٰعِبِينَ لَوْ اَرَدْنٰا اَنْ نَتَّخِذَ لَهْواً لاَتَّخَذْنٰاهُ مِنْ لَدُنّٰا»</quranic_text> <footnote>[الانبياء۱۶]</footnote> اِلَي قَوْلِهِ <quranic_text>«تَصِفُونَ»</quranic_text> <footnote>[الانبياء۱۸]</footnote> .","translation":"","aligned_body":"اَنَّهُ سُئِلَ عَنِ اللَّهْوِ فِي غَيْرِ النِّكَاحِ فَاَنْكَرَهُ وَ تَلاَ قَوْلَ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ مٰا خَلَقْنَا السَّمٰاءَ وَ الْاَرْضَ وَ مٰا بَيْنَهُمٰا لاٰعِبِينَ لَوْ اَرَدْنٰا اَنْ نَتَّخِذَ لَهْواً لاَتَّخَذْنٰاهُ مِنْ لَدُنّٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الانبياء ۱۶ TAG_CLOSE:footnote اِلَي قَوْلِهِ TAG_OPEN:quranic_text تَصِفُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانبياء ۱۸ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"اللهو","display":"اللَّهْوِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"غير","display":"غَيْرِ"},{"kind":"word","token":"النكاح","display":"النِّكَاحِ"},{"kind":"word","token":"فانكره","display":"فَاَنْكَرَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تلا","display":"تَلاَ"},{"kind":"word","token":"قول","display":"قَوْلَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"خلقنا","display":"خَلَقْنَا"},{"kind":