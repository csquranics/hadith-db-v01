{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«يُذَبِّحُونَ اَبْنٰاءَكُمْ»</quranic_text> <footnote>[البقرة۴۹]</footnote> اِنَّ فِرْعَوْنَ لَمَّا بَلَغَهُ اَنَّ بَنِي اِسْرَائِيلَ يَقُولُونَ يُولَدُ فِينَا رَجُلٌ يَكُونُ هَلاَكُ فِرْعَوْنَ وَ اَصْحَابِهِ عَلَي يَدِهِ كَانَ يُقَتِّلُ اَوْلاَدَهُمُ الذُّكُورَ وَ يَدَعُ الْاِنَاثَ.","translation":"","aligned_body":"TAG_OPEN:quranic_text يُذَبِّحُونَ اَبْنٰاءَكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۴۹ TAG_CLOSE:footnote اِنَّ فِرْعَوْنَ لَمَّا بَلَغَهُ اَنَّ بَنِي اِسْرَائِيلَ يَقُولُونَ يُولَدُ فِينَا رَجُلٌ يَكُونُ هَلاَكُ فِرْعَوْنَ وَ اَصْحَابِهِ عَلَي يَدِهِ كَانَ يُقَتِّلُ اَوْلاَدَهُمُ الذُّكُورَ وَ يَدَعُ الْاِنَاثَ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يذبحون","display":"يُذَبِّحُونَ"},{"kind":"word","token":"ابناءكم","display":"اَبْنٰاءَكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۴۹","display":"۴۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنَ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"بلغه","display":"بَلَغَهُ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرَائِيلَ"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"word","token":"يولد","display":"يُولَدُ"},{"kind":"word","token":"فينا","display":"فِينَا"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"هلاك","display":"هَلاَكُ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اصحابه","display":"اَصْحَابِهِ"},{"kind":"word","token":"علي","d