{"members":[{"header_text":" اَلْعَيَّاشِيُّ فِي  تَفْسِيرِهِ ، عَنْ  زُرَارَةَ قَالَ:","body_text":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ <quranic_text>«يَوْمَ تُبَدَّلُ الْاَرْضُ غَيْرَ الْاَرْضِ»</quranic_text> <footnote>[ابراهيم۴۸]</footnote> قَالَ تُبَدَّلُ خُبْزَةً نَقِيَّةً يَاْكُلُ النَّاسُ مِنْهَا حَتَّي يَفْرُغَ مِنَ الْحِسَابِ قَالَ اللَّهُ تَعَالَي <quranic_text>«وَ مٰا جَعَلْنٰاهُمْ جَسَداً لاٰ يَاْكُلُونَ الطَّعٰامَ»</quranic_text> <footnote>[الانبياء۸]</footnote> .","translation":"","aligned_body":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ TAG_OPEN:quranic_text يَوْمَ تُبَدَّلُ الْاَرْضُ غَيْرَ الْاَرْضِ TAG_CLOSE:quranic_text TAG_OPEN:footnote ابراهيم ۴۸ TAG_CLOSE:footnote قَالَ تُبَدَّلُ خُبْزَةً نَقِيَّةً يَاْكُلُ النَّاسُ مِنْهَا حَتَّي يَفْرُغَ مِنَ الْحِسَابِ قَالَ اللَّهُ تَعَالَي TAG_OPEN:quranic_text وَ مٰا جَعَلْنٰاهُمْ جَسَداً لاٰ يَاْكُلُونَ الطَّعٰامَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانبياء ۸ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"تبدل","display":"تُبَدَّلُ"},{"kind":"word","token":"الارض","display":"الْاَرْضُ"},{"kind":"word","token":"غير","display":"غَيْرَ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۴۸","display":"۴۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","tok