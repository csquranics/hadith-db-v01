{"members":[{"header_text":" فِقْهُ <teller> اَلرِّضَا، عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"اَرْوِي اَنَّ الدُّعَاءَ يَدْفَعُ مِنَ الْبَلاَءِ مَا قُدِّرَ وَ مَا لَمْ يُقَدَّرْ قِيلَ وَ كَيْفَ يَدْفَعُ مَا لَمْ يُقَدَّرْ قَالَ حَتَّي لاَ يَكُونَ.","translation":"","aligned_body":"- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - اَرْوِي اَنَّ الدُّعَاءَ يَدْفَعُ مِنَ الْبَلاَءِ مَا قُدِّرَ وَ مَا لَمْ يُقَدَّرْ قِيلَ وَ كَيْفَ يَدْفَعُ مَا لَمْ يُقَدَّرْ قَالَ حَتَّي لاَ يَكُونَ"},{"header_text":" ضا،  [فقه <teller> الرضا عليه السلام</teller> ] : ","body_text":"اَرْوِي عَنِ الْعَالِمِ عَلَيْهِ السَّلاَمُ اَنَّهُ قَالَ لِكُلِّ دَاءٍ دَوَاءٌ سَاَلْتُهُ عَنْ ذَلِكَ فَقَالَ لِكُلِّ دَاءٍ دُعَاءٌ فَاِذَا اُلْهِمَ الْعَلِيلُ الدُّعَاءَ فَقَدْ اُذِنَ فِي شِفَائِهِ ثُمَّ قَالَ لِيَ الْعَالِمُ عَلَيْهِ السَّلاَمُ الدُّعَاءُ اَفْضَلُ مِنْ قِرَاءَةِ الْقُرْانِ لِاَنَّ اللَّهَ جَلَّ وَ عَزَّ يَقُولُ <quranic_text>«مٰا يَعْبَؤُا بِكُمْ رَبِّي لَوْ لاٰ دُعٰاؤُكُمْ فَقَدْ كَذَّبْتُمْ فَسَوْفَ يَكُونُ لِزٰاماً»</quranic_text> <footnote>[الفرقان۷۷]</footnote> وَ اَرْوِي اَنَّ الدُّعَاءَ يَدْفَعُ مِنَ الْبَلاَءِ مَا قُدِّرَ وَ مَا لَمْ يُقَدَّرْ قِيلَ وَ كَيْفَ يَدْفَعُ مَا لَمْ يُقَدَّرْ قَالَ حَتَّي لاَ يَكُونَ.","translation":"","aligned_body":"اَرْوِي عَنِ الْعَالِمِ عَلَيْهِ السَّلاَمُ اَنَّهُ قَالَ لِكُلِّ دَاءٍ دَوَاءٌ سَاَلْتُهُ عَنْ ذَلِكَ فَقَالَ لِكُلِّ دَاءٍ دُعَاءٌ فَاِذَا اُلْهِمَ الْعَلِيلُ الدُّعَاءَ فَقَدْ اُذِنَ فِي شِفَائِهِ ثُمَّ قَالَ لِيَ الْعَالِمُ عَلَيْهِ السَّلاَمُ الدُّعَاءُ اَفْضَلُ مِنْ قِرَاءَةِ الْقُرْانِ لِاَنَّ اللَّهَ جَلَّ وَ عَزَّ يَقُولُ TAG_OPEN:quranic_text مٰا يَعْبَؤُا بِكُمْ رَبِّي لَوْ لاٰ دُعٰاؤُكُمْ فَقَدْ كَذَّبْتُمْ فَسَوْفَ يَكُونُ لِزٰاماً TAG_CLOSE:quranic_text TAG_OPEN:footnote الفرقان ۷۷ TAG_CLOSE:footnote وَ اَرْوِي اَنَّ الدُّعَاءَ يَدْفَعُ مِنَ الْبَلاَءِ مَا قُدِّرَ وَ مَا لَمْ يُقَدَّرْ قِيلَ وَ كَيْفَ يَدْفَعُ مَا لَمْ يُقَدَّرْ قَالَ حَتَّي لاَ يَكُونَ"},{"header_text":"وأروي","body_text":"أن الدعاء يدفع من البلاء ما قدر وما لم يقدر. قيل: وكيف يدفع ما لم يقدر؟ قال: حتى لا يكون.","translation":"","aligned_body":"- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - أن الدعاء يدفع من البلاء ما قدر - وما لم يقدر قيل - وكيف يدفع ما لم يقدر قال حتى لا يكون"}],"body_consensus_columns":[{"kind":"word","token":"اروي","display":"اَرْوِي"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"العالم","display":"الْعَالِمِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"داء","display":"دَاءٍ"},{"kind":"word","token":"دواء","display":"دَوَاءٌ"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"داء","display":"دَاءٍ"},{"kind":"word","token":"دعاء","display":"دُعَاءٌ"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"الهم","display":"اُلْهِمَ"},{"kind":"word","token":"العليل","display":"الْعَلِيلُ"},{"kind":"word","token":"الدعاء","display":"الدُّعَاءَ"},{"kind":"word","token":"فقد","display":"فَقَدْ"},{"kind":"word","token":"اذن","display":"اُذِنَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"شفائه","display":"شِفَائِهِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِيَ"},{"kind":"word","token":"العالم","display":"الْعَالِمُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word"