{"members":[{"header_text":" فِي تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ:","body_text":"قَوْلُهُ: <quranic_text>«وَ عَلَي الْوٰارِثِ مِثْلُ ذٰلِكَ»</quranic_text> <footnote>[البقرة۲۳۳]</footnote> قَالَ؛ لاَ يُضَارُّ الْمَرْاَةَ الَّتِي لَهَا وَلَدٌ وَ قَدْ تُوُفِّيَ زَوْجُهَا، فَلاَ يَحِلُّ لِلْوَارِثِ اَنْ يُضَارَّ اُمُّ الْوَلَدِ فِي النَّفَقَةِ فَيَضِيقَ عَلَيْهَا.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text وَ عَلَي الْوٰارِثِ مِثْلُ ذٰلِكَ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۳۳ TAG_CLOSE:footnote قَالَ لاَ يُضَارُّ الْمَرْاَةَ الَّتِي لَهَا وَلَدٌ وَ قَدْ تُوُفِّيَ زَوْجُهَا فَلاَ يَحِلُّ لِلْوَارِثِ اَنْ يُضَارَّ اُمُّ الْوَلَدِ فِي النَّفَقَةِ فَيَضِيقَ عَلَيْهَا"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الوارث","display":"الْوٰارِثِ"},{"kind":"word","token":"مثل","display":"مِثْلُ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۳۳","display":"۲۳۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يضار","display":"يُضَارُّ"},{"kind":"word","token":"المراه","display":"الْمَرْاَةَ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"لها","display":"لَهَا"},{"kind":"word","token":"ولد","display":"وَلَدٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"توفي","display":"تُوُفِّيَ"},{"kind":"word","token":"زوجها","display":"زَوْجُهَا"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"يحل","display":"يَحِلُّ"},{"kind":"word","token":"للوارث","display":"لِ