{"members":[{"header_text":" وَ عَنْ  قَتَادَةَ : ","body_text":"فِي قَوْلِهِ: <quranic_text>«يَخْرُجُ مِنْ بَيْنِ الصُّلْبِ وَ التَّرٰائِبِ»</quranic_text> <footnote>[الطارق۷]</footnote> قَالَ يَخْرُجُ مِنْ بَيْنِ صُلْبِهِ وَ نَحْرِهِ <quranic_text>«اِنَّهُ عَليٰ رَجْعِهِ لَقٰادِرٌ»</quranic_text> <footnote>[الطارق۸]</footnote> قَالَ اِنَّ اللَّهَ عَلَي بَعْثِهِ وَ اِعَادَتِهِ لَقَادِرٌ <quranic_text>«يَوْمَ تُبْلَي السَّرٰائِرُ»</quranic_text> <footnote>[الطارق۹]</footnote> قَالَ اِنَّ هَذِهِ السَّرَائِرَ مُخْتَبَرَةٌ فَاَسِرُّوا خَيْراً وَ اَعْلِنُوهُ <quranic_text>«فَمٰا لَهُ مِنْ قُوَّةٍ»</quranic_text> <footnote>[الطارق۱۰]</footnote> يَمْتَنِعُ بِهَا <quranic_text>«وَ لاٰ نٰاصِرٍ»</quranic_text> <footnote>[الطارق۱۰]</footnote> يَنْصُرُهُ مِنَ اللَّهِ.","translation":"","aligned_body":"فِي قَوْلِهِ TAG_OPEN:quranic_text يَخْرُجُ مِنْ بَيْنِ الصُّلْبِ وَ التَّرٰائِبِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الطارق ۷ TAG_CLOSE:footnote قَالَ يَخْرُجُ مِنْ بَيْنِ صُلْبِهِ وَ نَحْرِهِ TAG_OPEN:quranic_text اِنَّهُ عَليٰ رَجْعِهِ لَقٰادِرٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote الطارق ۸ TAG_CLOSE:footnote قَالَ اِنَّ اللَّهَ عَلَي بَعْثِهِ وَ اِعَادَتِهِ لَقَادِرٌ TAG_OPEN:quranic_text يَوْمَ تُبْلَي السَّرٰائِرُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الطارق ۹ TAG_CLOSE:footnote قَالَ اِنَّ هَذِهِ السَّرَائِرَ مُخْتَبَرَةٌ فَاَسِرُّوا خَيْراً وَ اَعْلِنُوهُ TAG_OPEN:quranic_text فَمٰا لَهُ مِنْ قُوَّةٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الطارق ۱۰ TAG_CLOSE:footnote يَمْتَنِعُ بِهَا TAG_OPEN:quranic_text وَ لاٰ نٰاصِرٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الطارق ۱۰ TAG_CLOSE:footnote يَنْصُرُهُ مِنَ اللَّهِ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يخرج","display":"يَخْرُجُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بين","display":"بَيْنِ"},{"kind":"word","token":"الصلب","d