{"members":[{"header_text":" تَفْسِيرُ  17 عَلِيِّ بْنِ إِبْرَاهِيمَ : ","body_text":" <quranic_text>«يَسْئَلُونَكَ مٰا ذٰا اُحِلَّ لَهُمْ قُلْ اُحِلَّ لَكُمُ الطَّيِّبٰاتُ وَ مٰا عَلَّمْتُمْ مِنَ الْجَوٰارِحِ مُكَلِّبِينَ تُعَلِّمُونَهُنَّ مِمّٰا عَلَّمَكُمُ اللّٰهُ»</quranic_text> <footnote>[المائدة۴]</footnote> وَ هُوَ صَيْدُ الْكِلاَبِ الْمُعَلَّمَةِ خَاصَّةً اَحَلَّهَا اللَّهُ اِذَا اَدْرَكْتَهُ وَ قَدْ قَتَلَهُ لِقَوْلِهِ: <quranic_text>«فَكُلُوا مِمّٰا اَمْسَكْنَ عَلَيْكُمْ»</quranic_text> <footnote>[المائدة۴]</footnote> .","translation":"","aligned_body":"TAG_OPEN:quranic_text يَسْئَلُونَكَ مٰا ذٰا اُحِلَّ لَهُمْ قُلْ اُحِلَّ لَكُمُ الطَّيِّبٰاتُ وَ مٰا عَلَّمْتُمْ مِنَ الْجَوٰارِحِ مُكَلِّبِينَ تُعَلِّمُونَهُنَّ مِمّٰا عَلَّمَكُمُ اللّٰهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۴ TAG_CLOSE:footnote وَ هُوَ صَيْدُ الْكِلاَبِ الْمُعَلَّمَةِ خَاصَّةً اَحَلَّهَا اللَّهُ اِذَا اَدْرَكْتَهُ وَ قَدْ قَتَلَهُ لِقَوْلِهِ TAG_OPEN:quranic_text فَكُلُوا مِمّٰا اَمْسَكْنَ عَلَيْكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۴ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يسئلونك","display":"يَسْئَلُونَكَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ذا","display":"ذٰا"},{"kind":"word","token":"احل","display":"اُحِلَّ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"احل","display":"اُحِلَّ"},{"kind":"word","token":"لكم","display":"لَكُمُ"},{"kind":"word","token":"الطيبات","display":"الطَّيِّبٰاتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"علمتم","display":"عَلَّمْتُمْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الجوارح","display":"الْجَوٰارِحِ"},{"kind":"word","token":"مكلبين","display":"مُكَلِّبِينَ"},{"kind":"word","token":"تعلمونهن","display":"تُعَلِّمُونَهُنَّ"},{"kind":"word","token":"م