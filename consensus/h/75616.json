{"members":[{"header_text":" فِي نَهْجِ اَلْبَلاَغَةِ قَالَ عَلَيْهِ اَلسَّلاَمُ:","body_text":"بَعْدَ اَنْ ذَكَرَ الصَّلاَةَ وَ حَثَّ عَلَيْهَا: مِنَ الْمُؤْمِنِينَ الَّذِينَ لاَ يَشْغَلُهُمْ عَنْهَا زِينَةُ مَتَاعٍ وَ لاَ قُرَّةُ عَيْنٍ مِنْ وَلَدٍ وَ لاَ مَالٍ، يَقُولُ اللَّهُ سُبْحَانَهُ: <quranic_text>«رِجٰالٌ لاٰ تُلْهِيهِمْ تِجٰارَةٌ وَ لاٰ بَيْعٌ عَنْ ذِكْرِ اللّٰهِ وَ اِقٰامِ الصَّلاٰةِ وَ اِيتٰاءِ الزَّكٰاةِ»</quranic_text> <footnote>[النور۳۷]</footnote> .","translation":"","aligned_body":"بَعْدَ اَنْ ذَكَرَ الصَّلاَةَ وَ حَثَّ عَلَيْهَا مِنَ الْمُؤْمِنِينَ الَّذِينَ لاَ يَشْغَلُهُمْ عَنْهَا زِينَةُ مَتَاعٍ وَ لاَ قُرَّةُ عَيْنٍ مِنْ وَلَدٍ وَ لاَ مَالٍ يَقُولُ اللَّهُ سُبْحَانَهُ TAG_OPEN:quranic_text رِجٰالٌ لاٰ تُلْهِيهِمْ تِجٰارَةٌ وَ لاٰ بَيْعٌ عَنْ ذِكْرِ اللّٰهِ وَ اِقٰامِ الصَّلاٰةِ وَ اِيتٰاءِ الزَّكٰاةِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النور ۳۷ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حث","display":"حَثَّ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يشغلهم","display":"يَشْغَلُهُمْ"},{"kind":"word","token":"عنها","display":"عَنْهَا"},{"kind":"word","token":"زينه","display":"زِينَةُ"},{"kind":"word","token":"متاع","display":"مَتَاعٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"قره","display":"قُرَّةُ"},{"kind":"word","token":"عين","display":"عَيْنٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ولد","display":"وَلَدٍ"},{"kind":"word","token":