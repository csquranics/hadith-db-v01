{"members":[{"header_text":" شي،  [تفسير  العياشي ] ، عَنْ  أَبِي بَصِيرٍ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِهِ: <quranic_text>«لاٰ تُبَذِّرْ تَبْذِيراً»</quranic_text> <footnote>[الاسراء۲۶]</footnote> قَالَ بَذَّرَ الرَّجُلُ مَالَهُ وَ يَقْعُدُ لَيْسَ لَهُ مَالٌ قَالَ فَيَكُونُ تَبْذِيرٌ فِي حَلاَلٍ قَالَ نَعَمْ.","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِهِ TAG_OPEN:quranic_text لاٰ تُبَذِّرْ تَبْذِيراً TAG_CLOSE:quranic_text TAG_OPEN:footnote الاسراء ۲۶ TAG_CLOSE:footnote قَالَ بَذَّرَ الرَّجُلُ مَالَهُ وَ يَقْعُدُ لَيْسَ لَهُ مَالٌ قَالَ فَيَكُونُ تَبْذِيرٌ فِي حَلاَلٍ قَالَ نَعَمْ"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تبذر","display":"تُبَذِّرْ"},{"kind":"word","token":"تبذيرا","display":"تَبْذِيراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۲۶","display":"۲۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"بذر","display":"بَذَّرَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"ماله","display":"مَالَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقعد","display":"يَقْعُدُ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"مال","display":"مَالٌ"},{"