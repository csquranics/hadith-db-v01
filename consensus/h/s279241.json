{"members":[{"header_text":" وَ عَنْ  أَبِي هُرَيْرَةَ : ","body_text":"اَنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ كَانَ اِذَا قَرَاَ <quranic_text>«اَ لَيْسَ ذٰلِكَ بِقٰادِرٍ عَليٰ اَنْ يُحْيِيَ الْمَوْتيٰ»</quranic_text> <footnote>[القيامة۴۰]</footnote> قَالَ سُبْحَانَكَ فَبَلَي.","translation":"","aligned_body":"اَنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ كَانَ اِذَا قَرَاَ اَ لَيْسَ ذٰلِكَ بِقٰادِرٍ عَليٰ اَنْ يُحْيِيَ الْمَوْتيٰ القيامة۴۰ قَالَ سُبْحَانَكَ فَبَلَي"}],"body_consensus_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"بقادر","display":"بِقٰادِرٍ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يحيي","display":"يُحْيِيَ"},{"kind":"word","token":"الموتي","display":"الْمَوْتيٰ"},{"kind":"word","token":"القيامه۴۰","display":"القيامة۴۰"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سبحانك","display":"سُبْحَانَكَ"},{"kind":"word","token":"فبلي","display":"فَبَلَي"}]}