{"members":[{"header_text":" اَلشَّيْخُ أَبُو اَلْفُتُوحِ فِي  تَفْسِيرِهِ ، عَنْ  كَعْبِ بْنِ عُجْرَةَ قَالَ:","body_text":"لَمَّا نَزَلَ قَوْلُهُ تَعَالَي <quranic_text>«اِنَّ اللّٰهَ وَ مَلاٰئِكَتَهُ»</quranic_text> <footnote>[الاحزاب۵۶]</footnote> الْايَةَ قُلْتُ يَا رَسُولَ اللَّهِ قَدْ عَلِمْنَا كَيْفَ السَّلاَمُ عَلَيْكَ فَكَيْفَ اُصَلِّي عَلَيْكَ قَالَ قُلِ - اللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ كَمَا صَلَّيْتَ عَلَي اِبْرَاهِيمَ وَ الِ اِبْرَاهِيمَ اِنَّكَ حَمِيْدٌ مَجِيدٌ.","translation":"","aligned_body":"لَمَّا نَزَلَ قَوْلُهُ تَعَالَي TAG_OPEN:quranic_text اِنَّ اللّٰهَ وَ مَلاٰئِكَتَهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الاحزاب ۵۶ TAG_CLOSE:footnote الْايَةَ قُلْتُ يَا رَسُولَ اللَّهِ قَدْ عَلِمْنَا كَيْفَ السَّلاَمُ عَلَيْكَ فَكَيْفَ اُصَلِّي عَلَيْكَ قَالَ قُلِ - اللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ كَمَا صَلَّيْتَ عَلَي اِبْرَاهِيمَ وَ الِ اِبْرَاهِيمَ اِنَّكَ حَمِيْدٌ مَجِيدٌ"}],"body_consensus_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ملائكته","display":"مَلاٰئِكَتَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحزاب","display":"الاحزاب"},{"kind":"word","token":"۵۶","display":"۵۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"علمنا","display":"عَلِمْنَا"},{"k