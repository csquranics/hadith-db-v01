{"members":[{"header_text":" فس، ،  [تفسير  القمي ] : ","body_text":" <quranic_text>«رَفِيعُ الدَّرَجٰاتِ ذُو الْعَرْشِ يُلْقِي الرُّوحَ مِنْ اَمْرِهِ عَليٰ مَنْ يَشٰاءُ مِنْ عِبٰادِهِ»</quranic_text> <footnote>[غافر۱۵]</footnote> قَالَ رُوحُ الْقُدُسِ وَ هُوَ خَاصُّ لِرَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ الْاَئِمَّةِ صَلَوَاتُ اللَّهِ عَلَيْهِمْ.","translation":"","aligned_body":"رَفِيعُ الدَّرَجٰاتِ ذُو الْعَرْشِ يُلْقِي الرُّوحَ مِنْ اَمْرِهِ عَليٰ مَنْ يَشٰاءُ مِنْ عِبٰادِهِ غافر۱۵ قَالَ رُوحُ الْقُدُسِ وَ هُوَ خَاصُّ لِرَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ الْاَئِمَّةِ صَلَوَاتُ اللَّهِ عَلَيْهِمْ"}],"body_consensus_columns":[{"kind":"word","token":"رفيع","display":"رَفِيعُ"},{"kind":"word","token":"الدرجات","display":"الدَّرَجٰاتِ"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"يلقي","display":"يُلْقِي"},{"kind":"word","token":"الروح","display":"الرُّوحَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"امره","display":"اَمْرِهِ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يشاء","display":"يَشٰاءُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عباده","display":"عِبٰادِهِ"},{"kind":"word","token":"غافر۱۵","display":"غافر۱۵"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"روح","display":"رُوحُ"},{"kind":"word","token":"القدس","display":"الْقُدُسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"خاص","display":"خَاصُّ"},{"kind":"word","token":"لرسول","display":"لِرَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","displa