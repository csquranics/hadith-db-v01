{"members":[{"header_text":" و روي عن عليّ - عليه السّلام:","body_text":"- انّه قرا «قول المؤمنين» بالرّفع.","translation":"","aligned_body":"- انّه قرا قول المؤمنين بالرّفع - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"},{"header_text":" وَ رُوِيَ عَنْ عَلِيٍّ عَلَيْهِ اَلسَّلاَمُ:","body_text":"اَنَّهُ قَرَاَ «قَوْلُ الْمُؤْمِنِينَ» بِالرَّفْعِ <quranic_text>«وَ اُولٰئِكَ هُمُ الْمُفْلِحُونَ»</quranic_text> <footnote>[النور۵۱]</footnote> اَيِ الْفَائِزُونَ بِالثَّوَابِ الظَّافِرُونَ بِالْمُرَادِ، وَ رُوِيَ عَنْ اَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ اَنَّ الْمَعْنِيَّ بِالْايَةِ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ.","translation":"","aligned_body":"- اَنَّهُ قَرَاَ قَوْلُ الْمُؤْمِنِينَ بِالرَّفْعِ TAG_OPEN:quranic_text وَ اُولٰئِكَ هُمُ الْمُفْلِحُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote النور ۵۱ TAG_CLOSE:footnote اَيِ الْفَائِزُونَ بِالثَّوَابِ الظَّافِرُونَ بِالْمُرَادِ وَ رُوِيَ عَنْ اَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ اَنَّ الْمَعْنِيَّ بِالْايَةِ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"بالرفع","display":"بِالرَّفْعِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"المفلحون","display":"الْمُفْلِحُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۵۱","display":"۵۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيِ"},{"kind":"word","token":"الفائزون","display":"الْفَائِزُونَ"},{"kind":"word","token":"بالثواب","display":"بِا