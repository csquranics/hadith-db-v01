{"members":[{"header_text":" فس، ،  [تفسير القمي] : ","body_text":" <quranic_text>«اِنَّ الَّذِينَ عِنْدَ رَبِّكَ»</quranic_text> <footnote>[الاعراف۲۰۶]</footnote> يَعْنِي الْاَنْبِيَاءَ وَ الرُّسُلَ وَ الْاَئِمَّةَ عَلَيهِمُ السَّلاَمُ <quranic_text>«لاٰ يَسْتَكْبِرُونَ عَنْ عِبٰادَتِهِ وَ يُسَبِّحُونَهُ وَ لَهُ يَسْجُدُونَ»</quranic_text> <footnote>[الاعراف۲۰۶]</footnote> .","translation":"","aligned_body":"اِنَّ الَّذِينَ عِنْدَ رَبِّكَ الاعراف۲۰۶ يَعْنِي الْاَنْبِيَاءَ وَ الرُّسُلَ وَ الْاَئِمَّةَ عَلَيهِمُ السَّلاَمُ لاٰ يَسْتَكْبِرُونَ عَنْ عِبٰادَتِهِ وَ يُسَبِّحُونَهُ وَ لَهُ يَسْجُدُونَ الاعراف۲۰۶"}],"body_consensus_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"الاعراف۲۰۶","display":"الاعراف۲۰۶"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"الانبياء","display":"الْاَنْبِيَاءَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرسل","display":"الرُّسُلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الائمه","display":"الْاَئِمَّةَ"},{"kind":"word","token":"عليهم","display":"عَلَيهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يستكبرون","display":"يَسْتَكْبِرُونَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"عبادته","display":"عِبٰادَتِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يسبحونه","display":"يُسَبِّحُونَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"يسجدون","display":"يَسْجُدُونَ"},{"kind":"word","token":"الاعراف۲۰۶","display":"الاعراف۲۰۶"}]}