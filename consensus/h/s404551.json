{"members":[{"header_text":" اَلطَّبْرِسِيُّ:","body_text":"فِي قَوْلِهِ تَعَالَي: <quranic_text>«فَتَذَرُوهٰا كَالْمُعَلَّقَةِ»</quranic_text> <footnote>[النساء۱۲۹]</footnote> اَيْ فَتَذَرُوا الَّتِي لاَ تَمِيلُونَ اِلَيْهَا كَالَّتِي هِيَ لاَ ذَاتُ زَوْجٍ، وَ لاَ اَيِّمٌ. قَالَ: وَ هُوَ الْمَرْوِيُّ عَنْ اَبِي جَعْفَرٍ وَ اَبِي عَبْدِ اللَّهِ (عَلَيْهِمَا السَّلاَمُ).","translation":"","aligned_body":"فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text فَتَذَرُوهٰا كَالْمُعَلَّقَةِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۲۹ TAG_CLOSE:footnote اَيْ فَتَذَرُوا الَّتِي لاَ تَمِيلُونَ اِلَيْهَا كَالَّتِي هِيَ لاَ ذَاتُ زَوْجٍ وَ لاَ اَيِّمٌ قَالَ وَ هُوَ الْمَرْوِيُّ عَنْ اَبِي جَعْفَرٍ وَ اَبِي عَبْدِ اللَّهِ عَلَيْهِمَا السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فتذروها","display":"فَتَذَرُوهٰا"},{"kind":"word","token":"كالمعلقه","display":"كَالْمُعَلَّقَةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۹","display":"۱۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"فتذروا","display":"فَتَذَرُوا"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تميلون","display":"تَمِيلُونَ"},{"kind":"word","token":"اليها","display":"اِلَيْهَا"},{"kind":"word","token":"كالتي","display":"كَالَّتِي"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ذات","display":"ذَاتُ"},{"kind":"word","token":"زوج","display":"زَوْجٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ايم","display":"اَ