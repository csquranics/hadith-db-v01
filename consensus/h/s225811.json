{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ: <quranic_text>«وَ كَاَيِّنْ مِنْ ايَةٍ فِي السَّمٰاوٰاتِ وَ الْاَرْضِ»</quranic_text> <footnote>[يوسف۱۰۵]</footnote> قَالَ الْكُسُوفُ وَ الزَّلْزَلَةُ وَ الصَّوَاعِقُ قَوْلُهُ: <quranic_text>«وَ مٰا يُؤْمِنُ اَكْثَرُهُمْ بِاللّٰهِ اِلاّٰ وَ هُمْ مُشْرِكُونَ»</quranic_text> <footnote>[يوسف۱۰۶]</footnote> فَهَذَا شِرْكُ الطَّاعَةِ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text وَ كَاَيِّنْ مِنْ ايَةٍ فِي السَّمٰاوٰاتِ وَ الْاَرْضِ TAG_CLOSE:quranic_text TAG_OPEN:footnote يوسف ۱۰۵ TAG_CLOSE:footnote قَالَ الْكُسُوفُ وَ الزَّلْزَلَةُ وَ الصَّوَاعِقُ قَوْلُهُ TAG_OPEN:quranic_text وَ مٰا يُؤْمِنُ اَكْثَرُهُمْ بِاللّٰهِ اِلاّٰ وَ هُمْ مُشْرِكُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote يوسف ۱۰۶ TAG_CLOSE:footnote فَهَذَا شِرْكُ الطَّاعَةِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كاين","display":"كَاَيِّنْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ايه","display":"ايَةٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السماوات","display":"السَّمٰاوٰاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۱۰۵","display":"۱۰۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الكسوف","display":"الْكُسُوفُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الزلزله","display":"الزَّلْزَلَةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصواعق","display":"الصَّوَاعِقُ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind"