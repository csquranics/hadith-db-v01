{"members":[{"header_text":" وَ رُوِيَ عَنِ<teller> اَلرِّضَا عَلَيْهِ السَّلاَمُ</teller> :","body_text":"لَمَّا سُئِلَ عَنْ رَجُلٍ قَالَ عِنْدَ مَوْتِهِ كُلُّ مَمْلُوكٍ لَهُ قَدِيمٍ فَهُوَ حُرٌّ لِوَجْهِ اللَّهِ فَقَالَ لَهُ نَعَمْ اِنَّ اللَّهَ يَقُولُ فِي كِتَابِهِ - <quranic_text>«حَتّٰي عٰادَ كَالْعُرْجُونِ الْقَدِيمِ»</quranic_text> <footnote>[يس۳۹]</footnote> فَمَا كَانَ مِنْ مَمَالِيكِهِ لَهُ سِتَّةُ اَشْهُرٍ فَهُوَ قَدِيمٌ حُرٌّ.","translation":"","aligned_body":"لَمَّا سُئِلَ عَنْ رَجُلٍ قَالَ عِنْدَ مَوْتِهِ كُلُّ مَمْلُوكٍ لَهُ قَدِيمٍ فَهُوَ حُرٌّ لِوَجْهِ اللَّهِ فَقَالَ لَهُ نَعَمْ اِنَّ اللَّهَ يَقُولُ فِي كِتَابِهِ - TAG_OPEN:quranic_text حَتّٰي عٰادَ كَالْعُرْجُونِ الْقَدِيمِ TAG_CLOSE:quranic_text TAG_OPEN:footnote يس ۳۹ TAG_CLOSE:footnote فَمَا كَانَ مِنْ مَمَالِيكِهِ لَهُ سِتَّةُ اَشْهُرٍ فَهُوَ قَدِيمٌ حُرٌّ"}],"body_consensus_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"موته","display":"مَوْتِهِ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"مملوك","display":"مَمْلُوكٍ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"قديم","display":"قَدِيمٍ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"حر","display":"حُرٌّ"},{"kind":"word","token":"لوجه","display":"لِوَجْهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتابه","display":"كِتَابِ