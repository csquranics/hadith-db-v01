{"members":[{"header_text":" فِي  مَنْ لاَ يَحْضُرُهُ اَلْفَقِيهُ :","body_text":"وَ سُئِلَ الصَّادِقُ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ: <quranic_text>«وَ الْمُحْصَنٰاتُ مِنَ النِّسٰاءِ»</quranic_text> <footnote>[النساء۲۴]</footnote> قَالَ هُنَّ ذَوَاتُ الْاَزْوَاجِ","translation":"","aligned_body":"وَ سُئِلَ الصَّادِقُ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ الْمُحْصَنٰاتُ مِنَ النِّسٰاءِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۲۴ TAG_CLOSE:footnote قَالَ هُنَّ ذَوَاتُ الْاَزْوَاجِ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المحصنات","display":"الْمُحْصَنٰاتُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"النساء","display":"النِّسٰاءِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هن","display":"هُنَّ"},{"kind":"word","token":"ذوات","display":"ذَوَاتُ"},{"kind":"word","token":"الازواج","display":"الْاَزْوَاجِ"}]}