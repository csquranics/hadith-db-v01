{"members":[{"header_text":" رِوَايَةٌ أُخْرَى لِمَنْ كَانَ يَتَفَزَّعُ مِنْ  كِتَابِ اَلْمَشِيخَةِ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> قَالَ:","body_text":"اِذَا كَانَ يَتَفَزَّعُ يَقُولُ عِنْدَ النَّوْمِ لاَ اِلَهَ اِلاَّ اللَّهُ وَحْدَهُ - <quranic_text>«لاٰ شَرِيكَ لَهُ»</quranic_text> <footnote>[الانعام۱۶۳]</footnote> - <quranic_text>«يُحْيِي وَ يُمِيتُ»</quranic_text> <footnote>[العمران۱۵۶]</footnote> وَ يُمِيتُ وَ يُحْيِي وَ هُوَ حَيٌّ لاَ يَمُوتُ عَشْرَ مَرَّاتٍ وَ يُسَبِّحُ تَسْبِيحَ الزَّهْرَاءِ فَاِنَّهُ يَزُولُ ذَلِكَ.","translation":"","aligned_body":"اِذَا كَانَ يَتَفَزَّعُ يَقُولُ عِنْدَ النَّوْمِ لاَ اِلَهَ اِلاَّ اللَّهُ وَحْدَهُ - TAG_OPEN:quranic_text لاٰ شَرِيكَ لَهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۱۶۳ TAG_CLOSE:footnote - TAG_OPEN:quranic_text يُحْيِي وَ يُمِيتُ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۱۵۶ TAG_CLOSE:footnote وَ يُمِيتُ وَ يُحْيِي وَ هُوَ حَيٌّ لاَ يَمُوتُ عَشْرَ مَرَّاتٍ وَ يُسَبِّحُ تَسْبِيحَ الزَّهْرَاءِ فَاِنَّهُ يَزُولُ ذَلِكَ"}],"body_consensus_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يتفزع","display":"يَتَفَزَّعُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"النوم","display":"النَّوْمِ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اله","display":"اِلَهَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"وحده","display":"وَحْدَهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"شريك","display":"شَرِيكَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"