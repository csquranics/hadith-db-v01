{"members":[{"header_text":" فِقْهُ <teller> اَلرِّضَا، عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"فَاِنْ لَمْ يَكُنْ سَمَّي لَهَا صَدَاقاً يُمَتِّعُهَا بِشَيْءٍ قَلَّ اَوْ كَثُرَ عَلَي قَدْرِ يَسَارِهِ فَالْمُوسِعُ يُمَتِّعُ بِخَادِمٍ اَوْ دَابَّةٍ وَ الْوَسَطُ بِثَوْبٍ وَ الْفَقِيرُ بِدِرْهَمٍ قَالَ اللَّهُ تَبَارَكَ وَ تَعَالَي <quranic_text>«وَ مَتِّعُوهُنَّ عَلَي الْمُوسِعِ قَدَرُهُ وَ عَلَي الْمُقْتِرِ قَدَرُهُ مَتٰاعاً بِالْمَعْرُوفِ»</quranic_text> <footnote>[البقرة۲۳۶]</footnote> .","translation":"","aligned_body":"فَاِنْ لَمْ يَكُنْ سَمَّي لَهَا صَدَاقاً يُمَتِّعُهَا بِشَيْءٍ قَلَّ اَوْ كَثُرَ عَلَي قَدْرِ يَسَارِهِ فَالْمُوسِعُ يُمَتِّعُ بِخَادِمٍ اَوْ دَابَّةٍ وَ الْوَسَطُ بِثَوْبٍ وَ الْفَقِيرُ بِدِرْهَمٍ قَالَ اللَّهُ تَبَارَكَ وَ تَعَالَي TAG_OPEN:quranic_text وَ مَتِّعُوهُنَّ عَلَي الْمُوسِعِ قَدَرُهُ وَ عَلَي الْمُقْتِرِ قَدَرُهُ مَتٰاعاً بِالْمَعْرُوفِ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۳۶ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"سمي","display":"سَمَّي"},{"kind":"word","token":"لها","display":"لَهَا"},{"kind":"word","token":"صداقا","display":"صَدَاقاً"},{"kind":"word","token":"يمتعها","display":"يُمَتِّعُهَا"},{"kind":"word","token":"بشيء","display":"بِشَيْءٍ"},{"kind":"word","token":"قل","display":"قَلَّ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"كثر","display":"كَثُرَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"قدر","display":"قَدْرِ"},{"kind":"word","token":"يساره","display":"يَسَارِهِ"},{"kind":"word","token":"فالموسع","display":"فَالْمُوسِعُ"},{"kind":"word","token":"يمتع","display":"يُمَتِّعُ"},{"kind":"word","token":"بخادم","display":"بِخَادِمٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"دابه","display":"دَابَّةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"w