{"members":[{"header_text":" عَنْ  عَبْدِ اَلسَّلاَمِ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ</teller> : ","body_text":"وَ فِي قَوْلِهِ تَعَالَي <quranic_text>«وَ لاٰ جُنٰاحَ عَلَيْكُمْ فِيمٰا تَرٰاضَيْتُمْ بِهِ مِنْ بَعْدِ الْفَرِيضَةِ»</quranic_text> <footnote>[النساء۲۴]</footnote> قُلْتُ اِنْ اَرَادَ اَنْ يَزِيدَهَا وَ يَزْدَادَ قَبْلَ اِنْقِضَاءِ الْاَجَلِ الَّذِي اُجِّلَ قَالَ لاَ بَاْسَ بِاَنْ يَكُونَ ذَلِكَ بِرِضًا مِنْهُ وَ مِنْهَا بِالْاَجَلِ وَ الْوَقْتِ وَ قَالَ يَزِيدُهَا بَعْدَ مَا يَمْضِي الْاَجَلُ.","translation":"","aligned_body":"وَ فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text وَ لاٰ جُنٰاحَ عَلَيْكُمْ فِيمٰا تَرٰاضَيْتُمْ بِهِ مِنْ بَعْدِ الْفَرِيضَةِ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۲۴ TAG_CLOSE:footnote قُلْتُ اِنْ اَرَادَ اَنْ يَزِيدَهَا وَ يَزْدَادَ قَبْلَ اِنْقِضَاءِ الْاَجَلِ الَّذِي اُجِّلَ قَالَ لاَ بَاْسَ بِاَنْ يَكُونَ ذَلِكَ بِرِضًا مِنْهُ وَ مِنْهَا بِالْاَجَلِ وَ الْوَقْتِ وَ قَالَ يَزِيدُهَا بَعْدَ مَا يَمْضِي الْاَجَلُ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"جناح","display":"جُنٰاحَ"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"فيما","display":"فِيمٰا"},{"kind":"word","token":"تراضيتم","display":"تَرٰاضَيْتُمْ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بعد","display":"بَعْدِ"},{"kind":"word","token":"الفريضه","display":"الْفَرِيضَةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"k