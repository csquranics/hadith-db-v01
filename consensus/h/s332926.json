{"members":[{"header_text":" فَرَوَى  اَلْحُسَيْنُ بْنُ جَبْرٍ فِي  نُخَبِهِ مَرْفُوعاً إِلَى <teller> اَلْبَاقِرِ عَلَيْهِ السَّلاَمُ</teller> قَالَ:","body_text":"لَمَّا نَزَلَ قَوْلُهُ تَعَالَي <quranic_text>«وَ كُلَّ شَيْءٍ اَحْصَيْنٰاهُ فِي اِمٰامٍ مُبِينٍ»</quranic_text> <footnote>[يس۱۲]</footnote> قِيلَ يَا رَسُولَ اللَّهِ هُوَ التَّوْرَاةُ وَ الْاِنْجِيلُ اَوِ الْقُرْانُ فَقَالَ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لاَ فَاَقْبَلَ عَلِيٌّ فَقَالَ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ هَذَا هُوَ الْاِمَامُ الْمُبِينُ الَّذِي اَحْصَي اللَّهُ فِيهِ كُلَّ شَيْءٍ.","translation":"","aligned_body":"لَمَّا نَزَلَ قَوْلُهُ تَعَالَي TAG_OPEN:quranic_text وَ كُلَّ شَيْءٍ اَحْصَيْنٰاهُ فِي اِمٰامٍ مُبِينٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote يس ۱۲ TAG_CLOSE:footnote قِيلَ يَا رَسُولَ اللَّهِ هُوَ التَّوْرَاةُ وَ الْاِنْجِيلُ اَوِ الْقُرْانُ فَقَالَ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لاَ فَاَقْبَلَ عَلِيٌّ فَقَالَ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ هَذَا هُوَ الْاِمَامُ الْمُبِينُ الَّذِي اَحْصَي اللَّهُ فِيهِ كُلَّ شَيْءٍ"}],"body_consensus_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"احصيناه","display":"اَحْصَيْنٰاهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"امام","display":"اِمٰامٍ"},{"kind":"word","token":"مبين","display":"مُبِينٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يس","display":"يس"},{"kind":"word","token":"۱۲","display":"۱۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","