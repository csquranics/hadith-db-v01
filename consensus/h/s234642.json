{"members":[{"header_text":" فس، ،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ اَنْذِرْ عَشِيرَتَكَ الْاَقْرَبِينَ»</quranic_text> <footnote>[الشعراء۲۱۴]</footnote> قَالَ نَزَلَتْ وَ رَهْطَكَ مِنْهُمُ الْمُخْلَصِينَ وَ هُمْ عَلِيُّ بْنُ اَبِي طَالِبٍ وَ حَمْزَةُ وَ جَعْفَرٌ وَ الْحَسَنُ وَ الْحُسَيْنُ وَ الُ مُحَمَّدٍ .","translation":"","aligned_body":"وَ اَنْذِرْ عَشِيرَتَكَ الْاَقْرَبِينَ الشعراء۲۱۴ قَالَ نَزَلَتْ وَ رَهْطَكَ مِنْهُمُ الْمُخْلَصِينَ وَهُمْ عَلِيُّ بْنُ اَبِي طَالِبٍ وَ حَمْزَةُ وَ جَعْفَرٌ وَ الْحَسَنُ وَ الْحُسَيْنُ وَ الُ مُحَمَّدٍ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انذر","display":"اَنْذِرْ"},{"kind":"word","token":"عشيرتك","display":"عَشِيرَتَكَ"},{"kind":"word","token":"الاقربين","display":"الْاَقْرَبِينَ"},{"kind":"word","token":"الشعراء۲۱۴","display":"الشعراء۲۱۴"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رهطك","display":"رَهْطَكَ"},{"kind":"word","token":"منهم","display":"مِنْهُمُ"},{"kind":"word","token":"المخلصين","display":"الْمُخْلَصِينَ"},{"kind":"word","token":"وهم","display":"وَهُمْ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حمزه","display":"حَمْزَةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جعفر","display":"جَعْفَرٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"}]}