{"members":[{"header_text":" عَنْ  أَبِي بَصِيرٍ عَنْ <teller> أَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"فِي قَوْلِهِ: <quranic_text>«فَمِنْهُمْ شَقِيٌّ وَ سَعِيدٌ»</quranic_text> <footnote>[هود۱۰۵]</footnote> قَالَ: فِي ذِكْرِ اَهْلِ النَّارِ اِسْتَثْنَي وَ لَيْسَ فِي ذِكْرِ اَهْلِ الْجَنَّةِ اِسْتَثْنَي، <quranic_text>«وَ اَمَّا الَّذِينَ سُعِدُوا فَفِي الْجَنَّةِ خٰالِدِينَ فِيهٰا مٰا دٰامَتِ السَّمٰاوٰاتُ وَ الْاَرْضُ اِلاّٰ مٰا شٰاءَ رَبُّكَ عَطٰاءً غَيْرَ مَجْذُوذٍ»</quranic_text> <footnote>[هود۱۰۸]</footnote> .","translation":"","aligned_body":"فِي قَوْلِهِ TAG_OPEN:quranic_text فَمِنْهُمْ شَقِيٌّ وَ سَعِيدٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote هود ۱۰۵ TAG_CLOSE:footnote قَالَ فِي ذِكْرِ اَهْلِ النَّارِ اِسْتَثْنَي وَ لَيْسَ فِي ذِكْرِ اَهْلِ الْجَنَّةِ اِسْتَثْنَي TAG_OPEN:quranic_text وَ اَمَّا الَّذِينَ سُعِدُوا فَفِي الْجَنَّةِ خٰالِدِينَ فِيهٰا مٰا دٰامَتِ السَّمٰاوٰاتُ وَ الْاَرْضُ اِلاّٰ مٰا شٰاءَ رَبُّكَ عَطٰاءً غَيْرَ مَجْذُوذٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote هود ۱۰۸ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمنهم","display":"فَمِنْهُمْ"},{"kind":"word","token":"شقي","display":"شَقِيٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سعيد","display":"سَعِيدٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"هود","display":"هود"},{"kind":"word","token":"۱۰۵","display":"۱۰۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذكر","display":"ذِكْرِ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"النار","display":"النَّارِ"},{"kind":"word","token":"استثني","display":"اِسْتَثْنَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"wor