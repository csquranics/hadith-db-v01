{"members":[{"header_text":" اَلْحُسَيْنُ بْنُ سَعِيدٍ عَنِ  اِبْنِ أَبِي عُمَيْرٍ وَ  فَضَالَةَ عَنْ  جَمِيلٍ قَالَ:","body_text":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنِ التَّكْبِيرِ فِي الْعِيدَيْنِ قَالَ «سَبْعٌ وَ خَمْسٌ» وَ قَالَ «صَلاَةُ الْعِيدَيْنِ فَرِيضَةٌ» وَ سَاَلْتُهُ مَا يُقْرَاُ فِيهِمَا قَالَ <quranic_text>«وَ الشَّمْسِ وَ ضُحٰاهٰا»</quranic_text> <footnote>[الشمس۱]</footnote> وَ <quranic_text>«هَلْ اَتٰاكَ حَدِيثُ الْغٰاشِيَةِ»</quranic_text> <footnote>[الغاشية۱]</footnote> وَ اَشْبَاهُهُمَا».","translation":"","aligned_body":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنِ التَّكْبِيرِ فِي الْعِيدَيْنِ قَالَ سَبْعٌ وَ خَمْسٌ وَ قَالَ صَلاَةُ الْعِيدَيْنِ فَرِيضَةٌ وَ سَاَلْتُهُ مَا يُقْرَاُ فِيهِمَا قَالَ TAG_OPEN:quranic_text وَ الشَّمْسِ وَ ضُحٰاهٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الشمس ۱ TAG_CLOSE:footnote وَ TAG_OPEN:quranic_text هَلْ اَتٰاكَ حَدِيثُ الْغٰاشِيَةِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الغاشية ۱ TAG_CLOSE:footnote وَ اَشْبَاهُهُمَا"}],"body_consensus_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"التكبير","display":"التَّكْبِيرِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"العيدين","display":"الْعِيدَيْنِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سبع","display":"سَبْعٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"خمس","display":"خَمْسٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صلاه","display":"صَلاَةُ"},{"kind":"word","token":"العيدين","display":"الْعِيدَيْنِ"},{"kind":"word","token":"فريضه","display":"فَرِ