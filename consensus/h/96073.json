{"members":[{"header_text":" فس، ،  [تفسير  القمي ] : ","body_text":" <quranic_text>«لَمْ يَكُنِ الَّذِينَ كَفَرُوا مِنْ اَهْلِ الْكِتٰابِ»</quranic_text> <footnote>[البينة۱]</footnote> يَعْنِي قُرَيْشاً <quranic_text>«وَ الْمُشْرِكِينَ مُنْفَكِّينَ حَتّٰي تَاْتِيَهُمُ الْبَيِّنَةُ»</quranic_text> <footnote>[البينة۱]</footnote> قَالَ هُمْ فِي كُفْرِهِمْ حَتَّي تَاْتِيَهُمُ الْبَيِّنَةُ.","translation":"","aligned_body":"لَمْ يَكُنِ الَّذِينَ كَفَرُوا مِنْ اَهْلِ الْكِتٰابِ البينة۱ يَعْنِي قُرَيْشاً وَ الْمُشْرِكِينَ مُنْفَكِّينَ حَتّٰي تَاْتِيَهُمُ الْبَيِّنَةُ البينة۱ قَالَ هُمْ فِي كُفْرِهِمْ حَتَّي تَاْتِيَهُمُ الْبَيِّنَةُ"}],"body_consensus_columns":[{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنِ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"كفروا","display":"كَفَرُوا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابِ"},{"kind":"word","token":"البينه۱","display":"البينة۱"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"قريشا","display":"قُرَيْشاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المشركين","display":"الْمُشْرِكِينَ"},{"kind":"word","token":"منفكين","display":"مُنْفَكِّينَ"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"تاتيهم","display":"تَاْتِيَهُمُ"},{"kind":"word","token":"البينه","display":"الْبَيِّنَةُ"},{"kind":"word","token":"البينه۱","display":"البينة۱"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كفرهم","display":"كُفْرِهِمْ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"تاتيهم","display":"تَاْتِيَهُمُ"},{"kind":"word","token":"البينه","display":"الْبَيِّنَةُ"}]}