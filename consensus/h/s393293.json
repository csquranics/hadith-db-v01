{"members":[{"header_text":" فِي مِصْبَاحِ اَلشَّرِيعَةِ قَالَ اَلصَّادِقُ عَلَيْهِ اَلسَّلاَمُ:","body_text":"وَ كُلُّ عِبَادَةٍ مُؤَسَّسَةٍ عَلَي غَيْرِ التَّقْوَي فَهِيَ هَبَاءٌ مَنْثُورٌ، قَالَ اللَّهُ عَزَّ وَ جَلَّ: اَ فَمَنْ <quranic_text>«اَسَّسَ بُنْيٰانَهُ عَليٰ تَقْويٰ مِنَ اللّٰهِ وَ رِضْوٰانٍ خَيْرٌ اَمْ مَنْ اَسَّسَ بُنْيٰانَهُ عَليٰ شَفٰا جُرُفٍ هٰارٍ فَانْهٰارَ بِهِ فِي نٰارِ جَهَنَّمَ»</quranic_text> <footnote>[التوبة۱۰۹]</footnote> الْايَةَ وَ تَفْسِيرُ التَّقْوَي تَرْكُ مَا لَيْسَ بِاَخْذِهِ بَاْسٌ حَذَراً عَمَّا بِهِ بَاْسٌ.","translation":"","aligned_body":"وَ كُلُّ عِبَادَةٍ مُؤَسَّسَةٍ عَلَي غَيْرِ التَّقْوَي فَهِيَ هَبَاءٌ مَنْثُورٌ قَالَ اللَّهُ عَزَّ وَ جَلَّ اَ فَمَنْ TAG_OPEN:quranic_text اَسَّسَ بُنْيٰانَهُ عَليٰ تَقْويٰ مِنَ اللّٰهِ وَ رِضْوٰانٍ خَيْرٌ اَمْ مَنْ اَسَّسَ بُنْيٰانَهُ عَليٰ شَفٰا جُرُفٍ هٰارٍ فَانْهٰارَ بِهِ فِي نٰارِ جَهَنَّمَ TAG_CLOSE:quranic_text TAG_OPEN:footnote التوبة ۱۰۹ TAG_CLOSE:footnote الْايَةَ وَ تَفْسِيرُ التَّقْوَي تَرْكُ مَا لَيْسَ بِاَخْذِهِ بَاْسٌ حَذَراً عَمَّا بِهِ بَاْسٌ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"عباده","display":"عِبَادَةٍ"},{"kind":"word","token":"مؤسسه","display":"مُؤَسَّسَةٍ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"غير","display":"غَيْرِ"},{"kind":"word","token":"التقوي","display":"التَّقْوَي"},{"kind":"word","token":"فهي","display":"فَهِيَ"},{"kind":"word","token":"هباء","display":"هَبَاءٌ"},{"kind":"word","token":"منثور","display":"مَنْثُورٌ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اسس","display":