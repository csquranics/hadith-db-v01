{"members":[{"header_text":" وَ عَنْ  أَبِي اَلْجَارُودِ عَنْ <teller> أَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"فِي قَوْلِهِ <quranic_text>«وَ لاٰ تَقْرَبُوا الزِّنيٰ اِنَّهُ كٰانَ فٰاحِشَةً»</quranic_text> <footnote>[الاسراء۳۲]</footnote> يَقُولُ مَعْصِيَةً وَ مَقْتاً يَقُولُ اِنَّ اللَّهَ يَمْقُتُهُ وَ يُبْغِضُهُ قَالَ <quranic_text>«وَ سٰاءَ سَبِيلاً»</quranic_text> <footnote>[الاسراء۳۲]</footnote> هُوَ اَشَدُّ النَّاسِ عَذَاباً وَ الزِّنَي مِنْ اَكْبَرِ الْكَبَائِرِ.","translation":"","aligned_body":"فِي قَوْلِهِ TAG_OPEN:quranic_text وَ لاٰ تَقْرَبُوا الزِّنيٰ اِنَّهُ كٰانَ فٰاحِشَةً TAG_CLOSE:quranic_text TAG_OPEN:footnote الاسراء ۳۲ TAG_CLOSE:footnote يَقُولُ مَعْصِيَةً وَ مَقْتاً يَقُولُ اِنَّ اللَّهَ يَمْقُتُهُ وَ يُبْغِضُهُ قَالَ TAG_OPEN:quranic_text وَ سٰاءَ سَبِيلاً TAG_CLOSE:quranic_text TAG_OPEN:footnote الاسراء ۳۲ TAG_CLOSE:footnote هُوَ اَشَدُّ النَّاسِ عَذَاباً وَ الزِّنَي مِنْ اَكْبَرِ الْكَبَائِرِ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تقربوا","display":"تَقْرَبُوا"},{"kind":"word","token":"الزني","display":"الزِّنيٰ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"فاحشه","display":"فٰاحِشَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۳۲","display":"۳۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"معصيه","display":"مَعْصِيَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مقتا","display":"مَقْتاً"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"ان","display":"اِنَّ"},