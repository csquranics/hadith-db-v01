{"members":[{"header_text":" عَنْ  أَبِي بَصِيرٍ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> قَالَ:","body_text":"سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ <quranic_text>«وَ لاٰ تَقُولَنَّ لِشَيْءٍ اِنِّي فٰاعِلٌ ذٰلِكَ غَداً اِلاّٰ اَنْ يَشٰاءَ اللّٰهُ»</quranic_text> <footnote>[الكهف۲۳]</footnote> قَالَ: هُوَ الرَّجُلُ يَحْلِفُ عَلَي الشَّيْءِ وَ يَنْسَي اَنْ يَسْتَثْنِيَ فَيَقُولَنَّ لَاَفْعَلَنَّ كَذَا وَ كَذَا غَداً اَوْ بَعْدَ غَدٍ عَنْ قَوْلِهِ، [عَنْ قَوْلِ كَذَا] <quranic_text>«وَ اُذْكُرْ رَبَّكَ اِذٰا نَسِيتَ»</quranic_text> <footnote>[الكهف۲۴]</footnote> .","translation":"","aligned_body":"سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ TAG_OPEN:quranic_text وَ لاٰ تَقُولَنَّ لِشَيْءٍ اِنِّي فٰاعِلٌ ذٰلِكَ غَداً اِلاّٰ اَنْ يَشٰاءَ اللّٰهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الكهف ۲۳ TAG_CLOSE:footnote قَالَ هُوَ الرَّجُلُ يَحْلِفُ عَلَي الشَّيْءِ وَ يَنْسَي اَنْ يَسْتَثْنِيَ فَيَقُولَنَّ لَاَفْعَلَنَّ كَذَا وَ كَذَا غَداً اَوْ بَعْدَ غَدٍ عَنْ قَوْلِهِ عَنْ قَوْلِ كَذَا TAG_OPEN:quranic_text وَ اُذْكُرْ رَبَّكَ اِذٰا نَسِيتَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الكهف ۲۴ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تقولن","display":"تَقُولَنَّ"},{"kind":"word","token":"لشيء","display":"لِشَيْءٍ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"فاعل","display":"فٰاعِلٌ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"غدا","display":"غَداً"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يشاء","display":"يَشٰاءَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_c