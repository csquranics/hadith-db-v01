{"members":[{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> أَنَّهُ قَالَ:","body_text":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«وَ لاٰ يَاْبَ الشُّهَدٰاءُ اِذٰا مٰا دُعُوا»</quranic_text> <footnote>[البقرة۲۸۲]</footnote> قَالَ حِينَ يُدْعَوْنَ قَبْلَ الْكِتَابِ لاَ يَنْبَغِي لِاَحَدٍ اَنْ يَقُولَ اِذَا دُعِيَ اِلَي شَهَادَةٍ لاَ اَشْهَدُ لَهُمْ وَ قَالَ اِذَا دُعِيتَ اِلَي الشَّهَادَةِ فَاَجِبْ الْخَبَرَ.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ لاٰ يَاْبَ الشُّهَدٰاءُ اِذٰا مٰا دُعُوا TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۸۲ TAG_CLOSE:footnote قَالَ حِينَ يُدْعَوْنَ قَبْلَ الْكِتَابِ لاَ يَنْبَغِي لِاَحَدٍ اَنْ يَقُولَ اِذَا دُعِيَ اِلَي شَهَادَةٍ لاَ اَشْهَدُ لَهُمْ وَ قَالَ اِذَا دُعِيتَ اِلَي الشَّهَادَةِ فَاَجِبْ الْخَبَرَ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"ياب","display":"يَاْبَ"},{"kind":"word","token":"الشهداء","display":"الشُّهَدٰاءُ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"دعوا","display":"دُعُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۸۲","display":"۲۸۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"يدعون","display":"يُدْعَوْنَ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"k