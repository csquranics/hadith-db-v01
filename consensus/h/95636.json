{"members":[{"header_text":" وَ أَسْنَدَ أَيْضاً إِلَى <teller> اَلْبَاقِرِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"فِي قَوْلِهِ تَعَالَي <quranic_text>«ضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ اَيْنَ مٰا ثُقِفُوا اِلاّٰ بِحَبْلٍ مِنَ اللّٰهِ وَ حَبْلٍ مِنَ النّٰاسِ»</quranic_text> <footnote>[العمران۱۱۲]</footnote> قَالَ عَلَيْهِ السَّلاَمُ حَبْلٌ مِنَ اللَّهِ كِتَابُهُ وَ حَبْلٌ مِنَ النَّاسِ عَلِيُّ بْنُ اَبِي طَالِبٍ .","translation":"","aligned_body":"فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text ضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ اَيْنَ مٰا ثُقِفُوا اِلاّٰ بِحَبْلٍ مِنَ اللّٰهِ وَ حَبْلٍ مِنَ النّٰاسِ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۱۱۲ TAG_CLOSE:footnote قَالَ عَلَيْهِ السَّلاَمُ حَبْلٌ مِنَ اللَّهِ كِتَابُهُ وَ حَبْلٌ مِنَ النَّاسِ عَلِيُّ بْنُ اَبِي طَالِبٍ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ضربت","display":"ضُرِبَتْ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"الذله","display":"الذِّلَّةُ"},{"kind":"word","token":"اين","display":"اَيْنَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ثقفوا","display":"ثُقِفُوا"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"بحبل","display":"بِحَبْلٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حبل","display":"حَبْلٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۱۲","display":"۱۱۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word"