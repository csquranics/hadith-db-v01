{"members":[{"header_text":" فِي  تَفْسِيرِ عَلِيِّ بْنِ إِبْرَاهِيمَ :","body_text":"قَوْلُهُ <quranic_text>«اِنَّ اللّٰهَ لاٰ يَغْفِرُ اَنْ يُشْرَكَ بِهِ وَ يَغْفِرُ مٰا دُونَ ذٰلِكَ لِمَنْ يَشٰاءُ»</quranic_text> <footnote>[النساء۴۸]</footnote> فَاِنَّهُ حَدَّثَنِي اَبِي عَنِ اِبْنِ اَبِي عُمَيْرٍ عَنْ هِشَامٍ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَالَ قُلْتُ لَهُ دَخَلَتِ الْكَبَائِرُ فِي الاِسْتِثْنَاءِ قَالَ: نَعَمْ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text اِنَّ اللّٰهَ لاٰ يَغْفِرُ اَنْ يُشْرَكَ بِهِ وَ يَغْفِرُ مٰا دُونَ ذٰلِكَ لِمَنْ يَشٰاءُ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۴۸ TAG_CLOSE:footnote فَاِنَّهُ حَدَّثَنِي اَبِي عَنِ اِبْنِ اَبِي عُمَيْرٍ عَنْ هِشَامٍ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَالَ قُلْتُ لَهُ دَخَلَتِ الْكَبَائِرُ فِي الاِسْتِثْنَاءِ قَالَ نَعَمْ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يغفر","display":"يَغْفِرُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يشرك","display":"يُشْرَكَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يغفر","display":"يَغْفِرُ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"دون","display":"دُونَ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"يشاء","display":"يَشٰاءُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۴۸","display":"۴۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"حدثني","display":"حَدَّثَنِي"},{"kind":"word"