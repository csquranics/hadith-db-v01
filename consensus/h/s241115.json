{"members":[{"header_text":" وَ عَنْ  سَلاَّمِ بْنِ اَلْمُسْتَنِيرِ عَنْ <teller> أَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"قَوْلُهُ <quranic_text>«قُلْ هٰذِهِ سَبِيلِي»</quranic_text> <footnote>[يوسف۱۰۸]</footnote> الْايَةَ قَالَ عَلِيٌّ عَلَيْهِ السَّلاَمُ وَ زَادَ قَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ - عَلِيٌّ وَ الْاَوْصِيَاءُ مِنْ بَعْدِهِ.","translation":"","aligned_body":"قَوْلُهُ TAG_OPEN:quranic_text قُلْ هٰذِهِ سَبِيلِي TAG_CLOSE:quranic_text TAG_OPEN:footnote يوسف ۱۰۸ TAG_CLOSE:footnote الْايَةَ قَالَ عَلِيٌّ عَلَيْهِ السَّلاَمُ وَ زَادَ قَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ - عَلِيٌّ وَ الْاَوْصِيَاءُ مِنْ بَعْدِهِ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هذه","display":"هٰذِهِ"},{"kind":"word","token":"سبيلي","display":"سَبِيلِي"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۱۰۸","display":"۱۰۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"زاد","display":"زَادَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind"