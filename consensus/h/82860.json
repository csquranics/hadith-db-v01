{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":"قَوْلُهُ تَعَالَي: <quranic_text>«لِمٰا يُحْيِيكُمْ»</quranic_text> <footnote>[الانفال۲۴]</footnote> قَالَ الْحَيَاةُ الْجَنَّةُ <quranic_text>«وَ اِعْلَمُوا اَنَّ اللّٰهَ يَحُولُ بَيْنَ الْمَرْءِ وَ قَلْبِهِ»</quranic_text> <footnote>[الانفال۲۴]</footnote> اَيْ يَحُولُ بَيْنَ مَا يُرِيدُ اللَّهُ وَ بَيْنَ مَا يُرِيدُهُ.","translation":"","aligned_body":"قَوْلُهُ تَعَالَي TAG_OPEN:quranic_text لِمٰا يُحْيِيكُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانفال ۲۴ TAG_CLOSE:footnote قَالَ الْحَيَاةُ الْجَنَّةُ TAG_OPEN:quranic_text وَ اِعْلَمُوا اَنَّ اللّٰهَ يَحُولُ بَيْنَ الْمَرْءِ وَ قَلْبِهِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانفال ۲۴ TAG_CLOSE:footnote اَيْ يَحُولُ بَيْنَ مَا يُرِيدُ اللَّهُ وَ بَيْنَ مَا يُرِيدُهُ"}],"body_consensus_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لما","display":"لِمٰا"},{"kind":"word","token":"يحييكم","display":"يُحْيِيكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الحياه","display":"الْحَيَاةُ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعلموا","display":"اِعْلَمُوا"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"يحول","display":"يَحُولُ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"المرء","display":"الْمَرْءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلبه","display":"قَلْبِهِ"},{"kind":"tag_close","tag_name":