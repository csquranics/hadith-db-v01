{"members":[{"header_text":" و في مجمع البيان :","body_text":" <quranic_text>«لَكُمْ فِيهٰا»</quranic_text> <footnote>[الحج۳۳]</footnote> ، اي: في الشّعائر منافع. فمن تاوّل انّ الشّعائر الهدي قال: انّ منافعها ركوب ظهرها و شرب لبنها، اذا احتيج اليها. و هو المرويّ عن ابي جعفر - عليه السّلام.","translation":"","aligned_body":"TAG_OPEN:quranic_text لَكُمْ فِيهٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الحج ۳۳ TAG_CLOSE:footnote اي في الشّعائر منافع فمن تاوّل انّ الشّعائر الهدي قال انّ منافعها ركوب ظهرها و شرب لبنها اذا احتيج اليها و هو المرويّ عن ابي جعفر - عليه السّلام"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۳۳","display":"۳۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اي"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"الشعائر","display":"الشّعائر"},{"kind":"word","token":"منافع","display":"منافع"},{"kind":"word","token":"فمن","display":"فمن"},{"kind":"word","token":"تاول","display":"تاوّل"},{"kind":"word","token":"ان","display":"انّ"},{"kind":"word","token":"الشعائر","display":"الشّعائر"},{"kind":"word","token":"الهدي","display":"الهدي"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"ان","display":"انّ"},{"kind":"word","token":"منافعها","display":"منافعها"},{"kind":"word","token":"ركوب","display":"ركوب"},{"kind":"word","token":"ظهرها","display":"ظهرها"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"شرب","display":"شرب"},{"kind":"word","token":"لبنها","display":"لبنها"},{"kind":"word","token":"اذا","display":"اذا"},{"kind":"word","token":"احتيج","display":"احتيج"},{"kind":"word","token":"اليها","display":"اليها"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token