{"members":[{"header_text":" وَ عَنْ<teller> جَعْفَرِ بْنِ مُحَمَّدٍ عَلَيْهِ السَّلاَمُ</teller> أَنَّهُ قَالَ :","body_text":"تَقْطَعُ اَلْيَدَ الْيُمْنَي مِنَ السَّارِقِ وَ قَالَ قَرَاَ عَلِيٌّ عَلَيْهِ السَّلاَمُ <quranic_text>«السّٰارِقُ وَ السّٰارِقَةُ فَاقْطَعُوا اَيْدِيَهُمٰا»</quranic_text> <footnote>[المائدة۳۸]</footnote> قَالَ اَبُو عَبْدِ اللَّهِ فَاِنْ كَانَ اَشَلَّ الْيُمْنَي اَوِ الْيُسْرَي قُطِعَتْ يُمْنَي عَلَي اَيِّ حَالٍ كَانَتْ.","translation":"","aligned_body":"تَقْطَعُ اَلْيَدَ الْيُمْنَي مِنَ السَّارِقِ وَ قَالَ قَرَاَ عَلِيٌّ عَلَيْهِ السَّلاَمُ TAG_OPEN:quranic_text السّٰارِقُ وَ السّٰارِقَةُ فَاقْطَعُوا اَيْدِيَهُمٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۳۸ TAG_CLOSE:footnote قَالَ اَبُو عَبْدِ اللَّهِ فَاِنْ كَانَ اَشَلَّ الْيُمْنَي اَوِ الْيُسْرَي قُطِعَتْ يُمْنَي عَلَي اَيِّ حَالٍ كَانَتْ"}],"body_consensus_columns":[{"kind":"word","token":"تقطع","display":"تَقْطَعُ"},{"kind":"word","token":"اليد","display":"اَلْيَدَ"},{"kind":"word","token":"اليمني","display":"الْيُمْنَي"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"السارق","display":"السَّارِقِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"السارق","display":"السّٰارِقُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السارقه","display":"السّٰارِقَةُ"},{"kind":"word","token":"فاقطعوا","display":"فَاقْطَعُوا"},{"kind":"word","token":"ايديهما","display":"اَيْدِيَهُمٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۳۸","display":"۳۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","tok