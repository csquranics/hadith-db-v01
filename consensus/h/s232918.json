{"members":[{"header_text":" فس، ،  [تفسير  القمي ] : ","body_text":"ثُمَّ ذَكَرَ الَ مُحَمَّدٍ فَقَالَ: <quranic_text>«ثُمَّ اَوْرَثْنَا الْكِتٰابَ الَّذِينَ اِصْطَفَيْنٰا مِنْ عِبٰادِنٰا»</quranic_text> <footnote>[فاطر۳۲]</footnote> وَ هُمُ الْاَئِمَّةُ عَلَيْهِمُ السَّلاَمُ قَالَ: <quranic_text>«فَمِنْهُمْ ظٰالِمٌ لِنَفْسِهِ»</quranic_text> <footnote>[فاطر۳۲]</footnote> مِنْ الِ مُحَمَّدٍ غَيْرَ الْاَئِمَّةِ وَ هُوَ الْجَاحِدُ لِلْاِمَامِ <quranic_text>«وَ مِنْهُمْ مُقْتَصِدٌ»</quranic_text> <footnote>[فاطر۳۲]</footnote> وَ هُوَ الْمُقِرُّ بِالْاِمَامِ <quranic_text>«وَ مِنْهُمْ سٰابِقٌ بِالْخَيْرٰاتِ بِاِذْنِ اللّٰهِ»</quranic_text> <footnote>[فاطر۳۲]</footnote> وَ هُوَ الْاِمَامُ.","translation":"","aligned_body":"ثُمَّ ذَكَرَ الَ مُحَمَّدٍ فَقَالَ ثُمَّ اَوْرَثْنَا الْكِتٰابَ الَّذِينَ اِصْطَفَيْنٰا مِنْ عِبٰادِنٰا فاطر۳۲ وَ هُمُ الْاَئِمَّةُ عَلَيْهِمُ السَّلاَمُ قَالَ فَمِنْهُمْ ظٰالِمٌ لِنَفْسِهِ فاطر۳۲ مِنْ الِ مُحَمَّدٍ غَيْرَ الْاَئِمَّةِ وَ هُوَ الْجَاحِدُ لِلْاِمَامِ وَ مِنْهُمْ مُقْتَصِدٌ فاطر۳۲ وَ هُوَ الْمُقِرُّ بِالْاِمَامِ وَ مِنْهُمْ سٰابِقٌ بِالْخَيْرٰاتِ بِاِذْنِ فاطر۳۲ اللّٰهِ فاطر۳۲ وَ هُوَ الْاِمَامُ"}],"body_consensus_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"ال","display":"الَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اورثنا","display":"اَوْرَثْنَا"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اصطفينا","display":"اِصْطَفَيْنٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عبادنا","display":"عِبٰادِنٰا"},{"kind":"word","token":"فاطر۳۲","display":"فاطر۳۲"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"الائمه","display":"الْاَئِمَّةُ"},{"kind":