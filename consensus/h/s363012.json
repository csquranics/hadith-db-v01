{"members":[{"header_text":" عَنْهُ عَنْ  أَبِيهِ عَنْ  عَلِيِّ بْنِ اَلنُّعْمَانِ  عَمَّنْ ذَكَرَهُ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"فِي قَوْلِ اللَّهِ <quranic_text>«اِنَّ عِبٰادِي لَيْسَ لَكَ عَلَيْهِمْ سُلْطٰانٌ»</quranic_text> <footnote>[الحجر۴۲]</footnote> فَقَالَ لَيْسَ عَلَي هَذِهِ الْعِصَابَةِ خَاصَّةً سُلْطَانٌ قُلْتُ وَ كَيْفَ وَ فِيهِمْ مَا فِيهِمْ فَقَالَ لَيْسَ حَيْثُ تَذْهَبُ اِنَّمَا هُوَ لَيْسَ لَكَ عَلَيْهِمْ سُلْطَانٌ اَنْ تُحَبِّبَ اِلَيْهِمُ الْكُفْرَ وَ تُبَغِّضَ اِلَيْهِمُ الْاِيمَانِ.","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ TAG_OPEN:quranic_text اِنَّ عِبٰادِي لَيْسَ لَكَ عَلَيْهِمْ سُلْطٰانٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحجر ۴۲ TAG_CLOSE:footnote فَقَالَ لَيْسَ عَلَي هَذِهِ الْعِصَابَةِ خَاصَّةً سُلْطَانٌ قُلْتُ وَ كَيْفَ وَ فِيهِمْ مَا فِيهِمْ فَقَالَ لَيْسَ حَيْثُ تَذْهَبُ اِنَّمَا هُوَ لَيْسَ لَكَ عَلَيْهِمْ سُلْطَانٌ اَنْ تُحَبِّبَ اِلَيْهِمُ الْكُفْرَ وَ تُبَغِّضَ اِلَيْهِمُ الْاِيمَانِ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"عبادي","display":"عِبٰادِي"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"سلطان","display":"سُلْطٰانٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"۴۲","display":"۴۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"العصابه","display":"الْع