{"members":[{"header_text":"","body_text":"رُوِيَ عَنِ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَنَّهُ سُئِلَ عَنْ قَوْلِهِ تَعَالَي: <quranic_text>«هٰذٰانِ خَصْمٰانِ اِخْتَصَمُوا فِي رَبِّهِمْ»</quranic_text> <footnote>[الحج۱۹]</footnote> ، فَقَالَ: عَلِيٌّ وَ حَمْزَةُ وَ عُبَيْدَةُ وَ عُتْبَةُ وَ شَيْبَةُ وَ الْوَلِيدُ.","translation":"","aligned_body":"رُوِيَ عَنِ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَنَّهُ سُئِلَ عَنْ قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text هٰذٰانِ خَصْمٰانِ اِخْتَصَمُوا فِي رَبِّهِمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الحج ۱۹ TAG_CLOSE:footnote فَقَالَ عَلِيٌّ وَ حَمْزَةُ وَ عُبَيْدَةُ وَ عُتْبَةُ وَ شَيْبَةُ وَ الْوَلِيدُ"}],"body_consensus_columns":[{"kind":"word","token":"روي","display":"رُوِيَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هذان","display":"هٰذٰانِ"},{"kind":"word","token":"خصمان","display":"خَصْمٰانِ"},{"kind":"word","token":"اختصموا","display":"اِخْتَصَمُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ربهم","display":"رَبِّهِمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۱۹","display":"۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"