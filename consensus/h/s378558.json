{"members":[{"header_text":"<teller> اَلصَّادِقُ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"سُئِلَ عَنْ قَوْلِهِ تَعَالَي <quranic_text>«قُلْ اِنِّي لاٰ اَمْلِكُ لَكُمْ ضَرًّا وَ لاٰ رَشَداً»</quranic_text> <footnote>[الجن۲۱]</footnote> فَقَالَ اِنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ دَعَا النَّاسَ اِلَي وَلاَيَةِ عَلِيٍّ عَلَيْهِ السَّلاَمُ فَكَرِهَ ذَلِكَ قَوْمٌ وَ قَالُوا فِيهِ فَاَنْزَلَ اللَّهُ <quranic_text>«قُلْ اِنِّي لاٰ اَمْلِكُ لَكُمْ ضَرًّا وَ لاٰ رَشَداً قُلْ اِنِّي لَنْ يُجِيرَنِي مِنَ اللّٰهِ اَحَدٌ»</quranic_text> <footnote>[الجن۲۱]</footnote> اِنْ عَصَيْتُهُ فِيمَا اَمَرَنِي بِهِ الْايَاتِ.","translation":"","aligned_body":"سُئِلَ عَنْ قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text قُلْ اِنِّي لاٰ اَمْلِكُ لَكُمْ ضَرًّا وَ لاٰ رَشَداً TAG_CLOSE:quranic_text TAG_OPEN:footnote الجن ۲۱ TAG_CLOSE:footnote فَقَالَ اِنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ دَعَا النَّاسَ اِلَي وَلاَيَةِ عَلِيٍّ عَلَيْهِ السَّلاَمُ فَكَرِهَ ذَلِكَ قَوْمٌ وَ قَالُوا فِيهِ فَاَنْزَلَ اللَّهُ TAG_OPEN:quranic_text قُلْ اِنِّي لاٰ اَمْلِكُ لَكُمْ ضَرًّا وَ لاٰ رَشَداً قُلْ اِنِّي لَنْ يُجِيرَنِي مِنَ اللّٰهِ اَحَدٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote الجن ۲۱ TAG_CLOSE:footnote اِنْ عَصَيْتُهُ فِيمَا اَمَرَنِي بِهِ الْايَاتِ"}],"body_consensus_columns":[{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"املك","display":"اَمْلِكُ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"ضرا","display":"ضَرًّا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"رشدا","display":"رَشَداً"},{"kind":"tag_close","tag_name":"qu