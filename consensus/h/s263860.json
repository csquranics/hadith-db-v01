{"members":[{"header_text":" فس،  [تفسير  القمي ] : ","body_text":" <quranic_text>«ظَهَرَ الْفَسٰادُ فِي الْبَرِّ وَ الْبَحْرِ بِمٰا كَسَبَتْ اَيْدِي النّٰاسِ»</quranic_text> <footnote>[الروم۴۱]</footnote> قَالَ فِي الْبَرِّ فَسَادُ الْحَيَوَانِ اِذَا لَمْ يُمْطَرُوا وَ كَذَلِكَ هَلاَكُ دَوَابِّ الْبَحْرِ بِذَلِكَ.","translation":"","aligned_body":"TAG_OPEN:quranic_text ظَهَرَ الْفَسٰادُ فِي الْبَرِّ وَ الْبَحْرِ بِمٰا كَسَبَتْ اَيْدِي النّٰاسِ TAG_CLOSE:quranic_text TAG_OPEN:footnote الروم ۴۱ TAG_CLOSE:footnote قَالَ فِي الْبَرِّ فَسَادُ الْحَيَوَانِ اِذَا لَمْ يُمْطَرُوا وَ كَذَلِكَ هَلاَكُ دَوَابِّ الْبَحْرِ بِذَلِكَ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ظهر","display":"ظَهَرَ"},{"kind":"word","token":"الفساد","display":"الْفَسٰادُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"البر","display":"الْبَرِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"البحر","display":"الْبَحْرِ"},{"kind":"word","token":"بما","display":"بِمٰا"},{"kind":"word","token":"كسبت","display":"كَسَبَتْ"},{"kind":"word","token":"ايدي","display":"اَيْدِي"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الروم","display":"الروم"},{"kind":"word","token":"۴۱","display":"۴۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"البر","display":"الْبَرِّ"},{"kind":"word","token":"فساد","display":"فَسَادُ"},{"kind":"word","token":"الحيوان","display":"الْحَيَوَانِ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يمطروا","display":"يُمْطَرُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كذلك","display":"كَذَلِكَ"},{"kind":"word","token":"هلاك","display":"هَلاَكُ"},{"kind":"word","t