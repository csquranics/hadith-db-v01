{"members":[{"header_text":" ثُمَّ قَالَ وَ رَوَى  عَبْدُ اَللَّهِ اَلْمُزَنِيُّ مُرْسَلاً عَنِ <teller> اَلصَّادِقِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"يَنْبَغِي لِلْعَبْدِ اِذَا صَلَّي اَنْ يُرَتِّلَ قِرَاءَتَهُ وَ اِذَا مَرَّ بِايَةٍ فِيهَا ذِكْرُ الْجَنَّةِ وَ النَّارِ سَاَلَ اللَّهَ الْجَنَّةَ وَ تَعَوَّذَ بِاللَّهِ مِنَ النَّارِ وَ اِذَا مَرَّ بِ‍ <quranic_text>«يٰا اَيُّهَا الَّذِينَ امَنُوا»</quranic_text> <footnote>[البقرة۱۰۴]</footnote> قَالَ لَبَّيْكَ رَبَّنَا.","translation":"","aligned_body":"يَنْبَغِي لِلْعَبْدِ اِذَا صَلَّي اَنْ يُرَتِّلَ قِرَاءَتَهُ وَ اِذَا مَرَّ بِايَةٍ فِيهَا ذِكْرُ الْجَنَّةِ وَ النَّارِ سَاَلَ اللَّهَ الْجَنَّةَ وَ تَعَوَّذَ بِاللَّهِ مِنَ النَّارِ وَ اِذَا مَرَّ بِ‍ TAG_OPEN:quranic_text يٰا اَيُّهَا الَّذِينَ امَنُوا TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۱۰۴ TAG_CLOSE:footnote قَالَ لَبَّيْكَ رَبَّنَا"}],"body_consensus_columns":[{"kind":"word","token":"ينبغي","display":"يَنْبَغِي"},{"kind":"word","token":"للعبد","display":"لِلْعَبْدِ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يرتل","display":"يُرَتِّلَ"},{"kind":"word","token":"قراءته","display":"قِرَاءَتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"مر","display":"مَرَّ"},{"kind":"word","token":"بايه","display":"بِايَةٍ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"ذكر","display":"ذِكْرُ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النار","display":"النَّارِ"},{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعوذ","display":"تَعَوَّذَ"},{"kind":"word","token":"بالله","display":"بِال