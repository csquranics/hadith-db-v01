{"members":[{"header_text":" [685] مُوسَى بْنُ سَلَمَةَ، بِإِسْنَادِهِ:","body_text":"اَنَّهُ لَمَّا اَنْزَلَ اللَّهُ عَزَّ وَ جَلَّ: <quranic_text>«اَ فَمَنْ كٰانَ عَليٰ بَيِّنَةٍ مِنْ رَبِّهِ وَ يَتْلُوهُ شٰاهِدٌ مِنْهُ»</quranic_text> <footnote>[هود۱۷]</footnote> قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ: عَلِيٌّ مِنِّي وَ اَنَا مِنْهُ.","translation":"","aligned_body":"اَنَّهُ لَمَّا اَنْزَلَ اَللَّهُ عَزَّ وَ جَلَّ اَ فَمَنْ كٰانَ عَليٰ بَيِّنَةٍ مِنْ رَبِّهِ وَ يَتْلُوهُ شٰاهِدٌ مِنْهُ هود17 قَالَ رَسُولُ اَللَّهِ صَلَّي اَللَّهُ عَلَيْهِ وَ الِهِ عَلِيٌّ مِنِّي وَ اَنَا مِنْهُ"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"بينه","display":"بَيِّنَةٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يتلوه","display":"يَتْلُوهُ"},{"kind":"word","token":"شاهد","display":"شٰاهِدٌ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"هود17","display":"هود17"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اَللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"