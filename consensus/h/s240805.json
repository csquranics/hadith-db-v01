{"members":[{"header_text":" فر،  [تفسير  فرات بن إبراهيم ] ،  جَعْفَرُ بْنُ مُحَمَّدِ بْنِ هِشَامٍ مُعَنْعَناً عَنِ  اَلْحَسَنِ بْنِ اَلْحُسَيْنِ : ","body_text":"اَنَّهُ عَلَيْهِ السَّلاَمُ حَمِدَ اللَّهَ تَعَالَي وَ اَثْنَي عَلَيْهِ وَ قَالَ - <quranic_text>«اَ فَمَنْ كٰانَ عَليٰ بَيِّنَةٍ مِنْ رَبِّهِ وَ يَتْلُوهُ شٰاهِدٌ مِنْهُ»</quranic_text> <footnote>[هود۱۷]</footnote> وَ اَنَا الَّذِي يَتْلُوهُ.","translation":"","aligned_body":"اَنَّهُ عَلَيْهِ السَّلاَمُ حَمِدَ اللَّهَ تَعَالَي وَ اَثْنَي عَلَيْهِ وَ قَالَ - TAG_OPEN:quranic_text اَ فَمَنْ كٰانَ عَليٰ بَيِّنَةٍ مِنْ رَبِّهِ وَ يَتْلُوهُ شٰاهِدٌ مِنْهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote هود ۱۷ TAG_CLOSE:footnote وَ اَنَا الَّذِي يَتْلُوهُ"}],"body_consensus_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"حمد","display":"حَمِدَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اثني","display":"اَثْنَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"بينه","display":"بَيِّنَةٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يتلوه","display":"يَتْلُوهُ"},{"kind":"word","token":"شاهد","display":"شٰاهِدٌ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"