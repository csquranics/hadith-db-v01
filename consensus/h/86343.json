{"members":[{"header_text":" مَا رَوَاهُ اَلرِّجَالُ مُسْنَداً عَنْ اِبْنِ عَبَّاسٍ أَنَّهُ قَالَ:","body_text":"قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ <quranic_text>«الَّذِينَ امَنُوا وَ تَطْمَئِنُّ قُلُوبُهُمْ بِذِكْرِ اللّٰهِ اَلاٰ بِذِكْرِ اللّٰهِ تَطْمَئِنُّ الْقُلُوبُ»</quranic_text> <footnote>[الرعد۲۸]</footnote> ثُمَّ قَالَ لِي اَ تَدْرِي يَا اِبْنَ اُمِّ سُلَيْمٍ مَنْ هُمْ قَالَ قُلْتُ مَنْ هُمْ يَا رَسُولَ اللَّهِ قَالَ نَحْنُ اَهْلَ الْبَيْتِ وَ شِيعَتُنَا.","translation":"","aligned_body":"قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ TAG_OPEN:quranic_text الَّذِينَ امَنُوا وَ تَطْمَئِنُّ قُلُوبُهُمْ بِذِكْرِ اللّٰهِ اَلاٰ بِذِكْرِ اللّٰهِ تَطْمَئِنُّ الْقُلُوبُ TAG_CLOSE:quranic_text TAG_OPEN:footnote الرعد ۲۸ TAG_CLOSE:footnote ثُمَّ قَالَ لِي اَ تَدْرِي يَا اِبْنَ اُمِّ سُلَيْمٍ مَنْ هُمْ قَالَ قُلْتُ مَنْ هُمْ يَا رَسُولَ اللَّهِ قَالَ نَحْنُ اَهْلَ الْبَيْتِ وَ شِيعَتُنَا"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تطمئن","display":"تَطْمَئِنُّ"},{"kind":"word","token":"قلوبهم","display":"قُلُوبُهُمْ"},{"kind":"word","token":"بذكر","display":"بِذِكْرِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الا","display":"اَلاٰ"},{"kind":"word","token":"بذكر","display":"بِذِكْرِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"تطمئن","display":"تَطْمَئِنُّ"},{"kind":"word","token":"القلوب","