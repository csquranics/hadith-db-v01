{"members":[{"header_text":" شي،  [تفسير  العياشي ] ، عَنِ  اَلْحَلَبِيِّ عَنْ <teller> أَبِي عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> قَالَ:","body_text":"صِيَامُ ثَلاَثَةِ اَيَّامٍ فِي كَفَّارَةِ الْيَمِينِ مُتَتَابِعَاتٌ - لاَ يُفْصَلُ بَيْنَهُنَّ قَالَ وَ قَالَ كُلُّ صِيَامٍ يُفَرَّقُ اِلاَّ صِيَامُ ثَلاَثَةِ اَيَّامٍ فِي كَفَّارَةِ الْيَمِينِ فَاِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ - <quranic_text>«فَصِيٰامُ ثَلاٰثَةِ اَيّٰامٍ»</quranic_text> <footnote>[المائدة۸۹]</footnote> مُتَتَابِعَاتٍ.","translation":"","aligned_body":"صِيَامُ ثَلاَثَةِ اَيَّامٍ فِي كَفَّارَةِ الْيَمِينِ مُتَتَابِعَاتٌ - لاَ يُفْصَلُ بَيْنَهُنَّ قَالَ وَ قَالَ كُلُّ صِيَامٍ يُفَرَّقُ اِلاَّ صِيَامُ ثَلاَثَةِ اَيَّامٍ فِي كَفَّارَةِ الْيَمِينِ فَاِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ - TAG_OPEN:quranic_text فَصِيٰامُ ثَلاٰثَةِ اَيّٰامٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۸۹ TAG_CLOSE:footnote مُتَتَابِعَاتٍ"}],"body_consensus_columns":[{"kind":"word","token":"صيام","display":"صِيَامُ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةِ"},{"kind":"word","token":"ايام","display":"اَيَّامٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كفاره","display":"كَفَّارَةِ"},{"kind":"word","token":"اليمين","display":"الْيَمِينِ"},{"kind":"word","token":"متتابعات","display":"مُتَتَابِعَاتٌ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يفصل","display":"يُفْصَلُ"},{"kind":"word","token":"بينهن","display":"بَيْنَهُنَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"صيام","display":"صِيَامٍ"},{"kind":"word","token":"يفرق","display":"يُفَرَّقُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"صيام","display":"صِيَامُ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةِ"},{"kind":"word","token":"ايام","display":"اَيَّا