{"members":[{"header_text":" العيّاشي :[عن  أبي صالح] عن  ابن عبّاس و  جابر بن عبد اللّه ، قالا:","body_text":"امر اللّه [تعالي نبيّه] محمّدا ان ينصب عليّا [علما] للناس ليخبرهم بولايته، فتخوّف رسول اللّه صلّي اللّه عليه و اله ان يقولوا: جاء بابن عمّه، و ان يطغوا في ذلك عليه، فاوحي اللّه اليه: <quranic_text>«يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ وَ اِنْ لَمْ تَفْعَلْ فَمٰا بَلَّغْتَ رِسٰالَتَهُ وَ اللّٰهُ يَعْصِمُكَ مِنَ النّٰاسِ»</quranic_text> <footnote>[المائدة۶۷]</footnote> . فقام رسول اللّه صلّي اللّه عليه و اله بولايته يوم غدير خمّ.","translation":"","aligned_body":"امر اللّه تعالي نبيّه محمّدا ان ينصب عليّا علما للناس ليخبرهم بولايته فتخوّف رسول اللّه صلّي اللّه عليه و اله ان يقولوا جاء بابن عمّه و ان يطغوا في ذلك عليه فاوحي اللّه اليه TAG_OPEN:quranic_text يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ وَ اِنْ لَمْ تَفْعَلْ فَمٰا بَلَّغْتَ رِسٰالَتَهُ وَ اللّٰهُ يَعْصِمُكَ مِنَ النّٰاسِ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۶۷ TAG_CLOSE:footnote فقام رسول اللّه صلّي اللّه عليه و اله بولايته يوم غدير خمّ"}],"body_consensus_columns":[{"kind":"word","token":"امر","display":"امر"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"تعالي","display":"تعالي"},{"kind":"word","token":"نبيه","display":"نبيّه"},{"kind":"word","token":"محمدا","display":"محمّدا"},{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"ينصب","display":"ينصب"},{"kind":"word","token":"عليا","display":"عليّا"},{"kind":"word","token":"علما","display":"علما"},{"kind":"word","token":"للناس","display":"للناس"},{"kind":"word","token":"ليخبرهم","display":"ليخبرهم"},{"kind":"word","token":"بولايته","display":"بولايته"},{"kind":"word","token":"فتخوف","display":"فتخوّف"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"صلي","display":"صلّي"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"عليه","display":"عليه"},{