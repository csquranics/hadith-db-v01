{"members":[{"header_text":" يب،  [تهذيب الأحكام] ، بِإِسْنَادِهِ عَنْ  أَحْمَدَ بْنِ مُحَمَّدِ بْنِ عِيسَى عَنِ  اَلْحُسَيْنِ بْنِ سَعِيدٍ عَنْ  أَبِي عَلِيٍّ قَالَ:","body_text":"كُنَّا عِنْدَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ فَقَالَ رَجُلٌ جُعِلْتُ فِدَاكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«وَ قُولُوا لِلنّٰاسِ حُسْناً»</quranic_text> <footnote>[البقرة۸۳]</footnote> هُوَ لِلنَّاسِ جَمِيعاً فَضَحِكَ وَ قَالَ لاَ عُنِيَ قُولُوا مُحَمَّدٌ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ عَلَي اَهْلِ بَيْتِهِ .","translation":"","aligned_body":"كُنَّا عِنْدَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ فَقَالَ رَجُلٌ جُعِلْتُ فِدَاكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ قُولُوا لِلنّٰاسِ حُسْناً TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۸۳ TAG_CLOSE:footnote هُوَ لِلنَّاسِ جَمِيعاً فَضَحِكَ وَ قَالَ لاَ عُنِيَ قُولُوا مُحَمَّدٌ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ عَلَي اَهْلِ بَيْتِهِ"}],"body_consensus_columns":[{"kind":"word","token":"كنا","display":"كُنَّا"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"جعلت","display":"جُعِلْتُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قولوا","display":"قُولُوا"},{"kind":"word","token":"للناس","display":"لِلنّٰاسِ"},{"kind":"word","token":"حسنا","display":"حُسْن