{"members":[{"header_text":" وَ عَنِ  اَلرَّبِيعِ بْنِ أَنَسٍ : ","body_text":"فِي قَوْلِهِ تَعَالَي: <quranic_text>«اِنَّهُ لَقُرْانٌ كَرِيمٌ فِي كِتٰابٍ مَكْنُونٍ»</quranic_text> <footnote>[الواقعة۷۷]</footnote> قَالَ الْقُرْانُ الْكَرِيمُ هُوَ الْقُرْانُ وَ الْكِتَابُ الْمَكْنُونُ هُوَ اللَّوْحُ الْمَحْفُوظُ <quranic_text>«لاٰ يَمَسُّهُ اِلاَّ الْمُطَهَّرُونَ»</quranic_text> <footnote>[الواقعة۷۹]</footnote> قَالَ الْمَلاَئِكَةُ هُمُ الْمُطَهَّرُونَ مِنَ الذُّنُوبِ.","translation":"","aligned_body":"فِي قَوْلِهِ تَعَالَي TAG_OPEN:quranic_text اِنَّهُ لَقُرْانٌ كَرِيمٌ فِي كِتٰابٍ مَكْنُونٍ TAG_CLOSE:quranic_text TAG_OPEN:footnote الواقعة ۷۷ TAG_CLOSE:footnote قَالَ الْقُرْانُ الْكَرِيمُ هُوَ الْقُرْانُ وَ الْكِتَابُ الْمَكْنُونُ هُوَ اللَّوْحُ الْمَحْفُوظُ TAG_OPEN:quranic_text لاٰ يَمَسُّهُ اِلاَّ الْمُطَهَّرُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الواقعة ۷۹ TAG_CLOSE:footnote قَالَ الْمَلاَئِكَةُ هُمُ الْمُطَهَّرُونَ مِنَ الذُّنُوبِ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"لقران","display":"لَقُرْانٌ"},{"kind":"word","token":"كريم","display":"كَرِيمٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتاب","display":"كِتٰابٍ"},{"kind":"word","token":"مكنون","display":"مَكْنُونٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الواقعه","display":"الواقعة"},{"kind":"word","token":"۷۷","display":"۷۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"القران","display":"الْقُرْانُ"},{"kind":"word","token":"الكريم","display":"الْكَرِيمُ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"القران","display":"الْقُرْانُ"},{"kind":"word","token