{"members":[{"header_text":" فِي  تَفْسِيرِ اَلْعَيَّاشِيِّ عَنْ  جَابِرٍ عَنْ<teller> أَبِي جَعْفَرٍ عَلَيْهِ اَلسَّلاَمُ</teller> قَالَ:","body_text":"سَاَلْتُهُ عَنْ هَذِهِ- الْايَةِ: <quranic_text>«اِنَّ شَرَّ الدَّوَابِّ عِنْدَ اللّٰهِ الَّذِينَ كَفَرُوا فَهُمْ لاٰ يُؤْمِنُونَ»</quranic_text> <footnote>[الانفال۵۵]</footnote> قَالَ: نَزَلَتْ فِي بَنِي اُمَيَّةَ هُمْ شَرُّ خَلْقِ اللَّهِ هُمُ الَّذِينَ كَفَرُوا فِي بَطْنِ الْقُرْانِ، وَ هُمُ الَّذِينَ لاَ يُؤْمِنُونَ هُمْ شَرُّ خَلْقِ اللَّهِ.","translation":"","aligned_body":"سَاَلْتُهُ عَنْ هَذِهِ- الْايَةِ TAG_OPEN:quranic_text اِنَّ شَرَّ الدَّوَابِّ عِنْدَ اللّٰهِ الَّذِينَ كَفَرُوا فَهُمْ لاٰ يُؤْمِنُونَ TAG_CLOSE:quranic_text TAG_OPEN:footnote الانفال ۵۵ TAG_CLOSE:footnote قَالَ نَزَلَتْ فِي بَنِي اُمَيَّةَ هُمْ شَرُّ خَلْقِ اللَّهِ هُمُ الَّذِينَ كَفَرُوا فِي بَطْنِ الْقُرْانِ وَ هُمُ الَّذِينَ لاَ يُؤْمِنُونَ هُمْ شَرُّ خَلْقِ اللَّهِ"}],"body_consensus_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"هذه-","display":"هَذِهِ-"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"شر","display":"شَرَّ"},{"kind":"word","token":"الدواب","display":"الدَّوَابِّ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"كفروا","display":"كَفَرُوا"},{"kind":"word","token":"فهم","display":"فَهُمْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يؤمنون","display":"يُؤْمِنُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۵۵","display":"۵۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":