{"members":[{"header_text":" عَنْ  حَمَّادِ بْنِ عِيسَى عَنْ  رِبْعِيٍّ عَنْ  مُحَمَّدِ بْنِ مُسْلِمٍ عَنْ <teller> أَبِي جَعْفَرٍ عَلَيْهِ اَلسَّلاَمُ</teller> : ","body_text":"وَ فِي كَفَّارَةِ الْيَمِينِ قَالَ اَطْعَمَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عَشَرَةَ مَسَاكِينَ لِكُلِّ مِسْكِينٍ مُدٌّ مِنْ طَعَامٍ فِي اَمْرِ مَارِيَةَ، وَ هُوَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ <quranic_text>«يٰا اَيُّهَا النَّبِيُّ لِمَ تُحَرِّمُ مٰا اَحَلَّ اللّٰهُ لَكَ»</quranic_text> <footnote>[التحريم۱]</footnote> الْحَدِيثَ.","translation":"","aligned_body":"وَ فِي كَفَّارَةِ الْيَمِينِ قَالَ اَطْعَمَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عَشَرَةَ مَسَاكِينَ لِكُلِّ مِسْكِينٍ مُدٌّ مِنْ طَعَامٍ فِي اَمْرِ مَارِيَةَ وَ هُوَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text يٰا اَيُّهَا النَّبِيُّ لِمَ تُحَرِّمُ مٰا اَحَلَّ اللّٰهُ لَكَ TAG_CLOSE:quranic_text TAG_OPEN:footnote التحريم ۱ TAG_CLOSE:footnote الْحَدِيثَ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كفاره","display":"كَفَّارَةِ"},{"kind":"word","token":"اليمين","display":"الْيَمِينِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اطعم","display":"اَطْعَمَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"عشره","display":"عَشَرَةَ"},{"kind":"word","token":"مساكين","display":"مَسَاكِينَ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"مسكين","display":"مِسْكِينٍ"},{"kind":"word","token":"مد","display":"مُدٌّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"طعام","display":"طَعَامٍ"},{"kind":"word","token":"في","displ