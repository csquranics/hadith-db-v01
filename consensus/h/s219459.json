{"members":[{"header_text":" فِقْهُ <teller> اَلرِّضَا، عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"فَاِذَا اَرَادَ صَاحِبُهُ اَنْ يَشْهَدَ بِمَا اُشْهِدَ فَلاَ يَمْتَنِعْ لِقَوْلِهِ <quranic_text>«وَ مَنْ يَكْتُمْهٰا فَاِنَّهُ اثِمٌ قَلْبُهُ»</quranic_text> <footnote>[البقرة۲۸۳]</footnote> .","translation":"","aligned_body":"فَاِذَا اَرَادَ صَاحِبُهُ اَنْ يَشْهَدَ بِمَا اُشْهِدَ فَلاَ يَمْتَنِعْ لِقَوْلِهِ TAG_OPEN:quranic_text وَ مَنْ يَكْتُمْهٰا فَاِنَّهُ اثِمٌ قَلْبُهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۸۳ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"اراد","display":"اَرَادَ"},{"kind":"word","token":"صاحبه","display":"صَاحِبُهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يشهد","display":"يَشْهَدَ"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"اشهد","display":"اُشْهِدَ"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"يمتنع","display":"يَمْتَنِعْ"},{"kind":"word","token":"لقوله","display":"لِقَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يكتمها","display":"يَكْتُمْهٰا"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"اثم","display":"اثِمٌ"},{"kind":"word","token":"قلبه","display":"قَلْبُهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۸۳","display":"۲۸۳"},{"kind":"tag_close","tag_name":"footnote"}]}