{"members":[{"header_text":" وَ عَنْ  حَمَّادٍ عَنْ  رِبْعِيٍّ عَنْ  مُحَمَّدِ بْنِ مُسْلِمٍ قَالَ:","body_text":"قَرَاَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ وَ لَقَدْ نَادَينَا نُوحاً قُلْتُ <quranic_text>« نُوحٌ »</quranic_text> <footnote>[الصافات۷۵]</footnote> ثُمَّ قُلْتُ جُعِلْتُ فِدَاكَ لَوْ نَظَرْتَ فِي هَذَا اَعْنِي الْعَرَبِيَّةَ فَقَالَ دَعْنِي مِنْ سَهَكِكُمْ.","translation":"","aligned_body":"قَرَاَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ وَ لَقَدْ نَادَينَا نُوحاً قُلْتُ TAG_OPEN:quranic_text نُوحٌ TAG_CLOSE:quranic_text TAG_OPEN:footnote الصافات ۷۵ TAG_CLOSE:footnote ثُمَّ قُلْتُ جُعِلْتُ فِدَاكَ لَوْ نَظَرْتَ فِي هَذَا اَعْنِي الْعَرَبِيَّةَ فَقَالَ دَعْنِي مِنْ سَهَكِكُمْ"}],"body_consensus_columns":[{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"نادينا","display":"نَادَينَا"},{"kind":"word","token":"نوحا","display":"نُوحاً"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"نوح","display":"نُوحٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الصافات","display":"الصافات"},{"kind":"word","token":"۷۵","display":"۷۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"جعلت","display":"جُعِلْتُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"نظرت","display":"نَظَرْتَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"هذا","display":"هَذَا"},{"ki