{"members":[{"header_text":" فس، ،  [تفسير  القمي ] : ","body_text":" <quranic_text>«وَ لاٰ يَحُضُّ عَليٰ طَعٰامِ الْمِسْكِينِ»</quranic_text> <footnote>[الحاقة۳۴]</footnote> حُقُوقُ الِ مُحَمَّدٍ الَّتِي غَصَبُوهَا.","translation":"","aligned_body":"وَ لاٰ يَحُضُّ عَليٰ طَعٰامِ الْمِسْكِينِ الحاقة۳۴ حُقُوقُ الِ مُحَمَّدٍ الَّتِي غَصَبُوهَا"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يحض","display":"يَحُضُّ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"طعام","display":"طَعٰامِ"},{"kind":"word","token":"المسكين","display":"الْمِسْكِينِ"},{"kind":"word","token":"الحاقه۳۴","display":"الحاقة۳۴"},{"kind":"word","token":"حقوق","display":"حُقُوقُ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"غصبوها","display":"غَصَبُوهَا"}]}