{"members":[{"header_text":" دَعَائِمُ اَلْإِسْلاَمِ ، عَنْ <teller> أَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ</teller> فِي حَدِيثٍ أَنَّهُ قَالَ:","body_text":"قَالَ اَللَّهُ عَزَّ وَ جَلَّ <quranic_text>«حٰافِظُوا عَلَي الصَّلَوٰاتِ وَ الصَّلاٰةِ الْوُسْطيٰ»</quranic_text> <footnote>[البقرة۲۳۸]</footnote> وَ هِيَ صَلاَةُ الْجُمُعَةِ وَ الظُّهْرِ فِي سَائِرِ الْاَيَّامِ وَ هِيَ اَوَّلُ صَلاَةٍ صَلاَّهَا رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ هِيَ وَسَطُ صَلاَتَيْنِ بِالنَّهَارِ صَلاَةِ الْغَدَاةِ وَ صَلاَةِ الْعَصْرِ.","translation":"","aligned_body":"قَالَ اَللَّهُ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text حٰافِظُوا عَلَي الصَّلَوٰاتِ وَ الصَّلاٰةِ الْوُسْطيٰ TAG_CLOSE:quranic_text TAG_OPEN:footnote البقرة ۲۳۸ TAG_CLOSE:footnote وَ هِيَ صَلاَةُ الْجُمُعَةِ وَ الظُّهْرِ فِي سَائِرِ الْاَيَّامِ وَ هِيَ اَوَّلُ صَلاَةٍ صَلاَّهَا رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ هِيَ وَسَطُ صَلاَتَيْنِ بِالنَّهَارِ صَلاَةِ الْغَدَاةِ وَ صَلاَةِ الْعَصْرِ"}],"body_consensus_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حافظوا","display":"حٰافِظُوا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الصلوات","display":"الصَّلَوٰاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةِ"},{"kind":"word","token":"الوسطي","display":"الْوُسْطيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۳۸","display":"۲۳۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"صلاه","display":"صَلاَةُ"},{"kind":"word","token":"الجمعه"