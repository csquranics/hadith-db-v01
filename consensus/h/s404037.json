{"members":[{"header_text":" عَنِ  اَلْحَلَبِيِّ ، عَنْ <teller> أَبِي عَبْدِ اَللَّهِ (عَلَيْهِ اَلسَّلاَمُ)</teller> :","body_text":"فِي قَوْلِ اللَّهِ: <quranic_text>«وَ لَيْسَتِ التَّوْبَةُ لِلَّذِينَ يَعْمَلُونَ السَّيِّئٰاتِ حَتّٰي اِذٰا حَضَرَ اَحَدَهُمُ الْمَوْتُ قٰالَ اِنِّي تُبْتُ الْانَ»</quranic_text> <footnote>[النساء۱۸]</footnote> . قَالَ: «هُوَ الْفِرَارُ تَابَ حِينَ لَمْ تَنْفَعْهُ التَّوْبَةُ، وَ لَمْ تُقْبَلْ مِنْهُ».","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ TAG_OPEN:quranic_text وَ لَيْسَتِ التَّوْبَةُ لِلَّذِينَ يَعْمَلُونَ السَّيِّئٰاتِ حَتّٰي اِذٰا حَضَرَ اَحَدَهُمُ الْمَوْتُ قٰالَ اِنِّي تُبْتُ الْانَ TAG_CLOSE:quranic_text TAG_OPEN:footnote النساء ۱۸ TAG_CLOSE:footnote قَالَ هُوَ الْفِرَارُ تَابَ حِينَ لَمْ تَنْفَعْهُ التَّوْبَةُ وَ لَمْ تُقْبَلْ مِنْهُ"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ليست","display":"لَيْسَتِ"},{"kind":"word","token":"التوبه","display":"التَّوْبَةُ"},{"kind":"word","token":"للذين","display":"لِلَّذِينَ"},{"kind":"word","token":"يعملون","display":"يَعْمَلُونَ"},{"kind":"word","token":"السيئات","display":"السَّيِّئٰاتِ"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"حضر","display":"حَضَرَ"},{"kind":"word","token":"احدهم","display":"اَحَدَهُمُ"},{"kind":"word","token":"الموت","display":"الْمَوْتُ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"تبت","display":"تُبْتُ"},{"kind":"word","token":"الان","display":"الْانَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۸","display":"۱۸"},{"kind":"tag_close",