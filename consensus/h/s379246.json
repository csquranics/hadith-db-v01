{"members":[{"header_text":" قَالَ <teller> أَبُو عَبْدِ اَللَّهِ عَلَيْهِ السَّلاَمُ</teller> : ","body_text":"وَ قَدْ ذُكِرَ عِنْدَهُ الْحُسَيْنُ عَلَيْهِ السَّلاَمُ <quranic_text>«وَ الَّذِينَ امَنُوا وَ اِتَّبَعَتْهُمْ ذُرِّيَّتُهُمْ»</quranic_text> <footnote>[الطور۲۱]</footnote> وَ قَالَ عَزَّ وَ جَلَّ <quranic_text>«وَ اَنَّ هٰذٰا صِرٰاطِي مُسْتَقِيماً»</quranic_text> <footnote>[الانعام۱۵۳]</footnote> وَ قَالَ <quranic_text>«وَ هٰذَا النَّبِيُّ وَ الَّذِينَ امَنُوا وَ اللّٰهُ وَلِيُّ الْمُؤْمِنِينَ»</quranic_text> <footnote>[العمران۶۸]</footnote> اَيْ الْاَئِمَّةُ .","translation":"","aligned_body":"وَ قَدْ ذُكِرَ عِنْدَهُ الْحُسَيْنُ عَلَيْهِ السَّلاَمُ TAG_OPEN:quranic_text وَ الَّذِينَ امَنُوا وَ اِتَّبَعَتْهُمْ ذُرِّيَّتُهُمْ TAG_CLOSE:quranic_text TAG_OPEN:footnote الطور ۲۱ TAG_CLOSE:footnote وَ قَالَ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ اَنَّ هٰذٰا صِرٰاطِي مُسْتَقِيماً TAG_CLOSE:quranic_text TAG_OPEN:footnote الانعام ۱۵۳ TAG_CLOSE:footnote وَ قَالَ TAG_OPEN:quranic_text وَ هٰذَا النَّبِيُّ وَ الَّذِينَ امَنُوا وَ اللّٰهُ وَلِيُّ الْمُؤْمِنِينَ TAG_CLOSE:quranic_text TAG_OPEN:footnote العمران ۶۸ TAG_CLOSE:footnote اَيْ الْاَئِمَّةُ"}],"body_consensus_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"ذكر","display":"ذُكِرَ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتبعتهم","display":"اِتَّبَعَتْهُمْ"},{"kind":"word","token":"ذريتهم","display":"ذُرِّيَّتُهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"