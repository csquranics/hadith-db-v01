{"members":[{"header_text":" فس، ،  [تفسير  القمي ] : ","body_text":" <quranic_text>«اُولٰئِكَ كَتَبَ فِي قُلُوبِهِمُ الْاِيمٰانَ»</quranic_text> <footnote>[المجادلة۲۲]</footnote> هُمُ الْاَئِمَّةُ <quranic_text>«وَ اَيَّدَهُمْ بِرُوحٍ مِنْهُ»</quranic_text> <footnote>[المجادلة۲۲]</footnote> قَالَ مَلَكٌ اَعْظَمُ مِنْ جَبْرَئِيلَ وَ مِيكَائِيلَ وَ كَانَ مَعَ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ هُوَ مَعَ الْاَئِمَّةِ عَلَيْهِمُ السَّلاَمُ .","translation":"","aligned_body":"اُولٰئِكَ كَتَبَ فِي قُلُوبِهِمُ الْاِيمٰانَ المجادلة۲۲ هُمُ الْاَئِمَّةُ وَ اَيَّدَهُمْ بِرُوحٍ مِنْهُ المجادلة۲۲ قَالَ مَلَكٌ اَعْظَمُ مِنْ جَبْرَئِيلَ وَ مِيكَائِيلَ وَ كَانَ مَعَ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ و هُوَ مَعَ الْاَئِمَّةِ عَلَيْهِمُ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"كتب","display":"كَتَبَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قلوبهم","display":"قُلُوبِهِمُ"},{"kind":"word","token":"الايمان","display":"الْاِيمٰانَ"},{"kind":"word","token":"المجادله۲۲","display":"المجادلة۲۲"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"الائمه","display":"الْاَئِمَّةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ايدهم","display":"اَيَّدَهُمْ"},{"kind":"word","token":"بروح","display":"بِرُوحٍ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"المجادله۲۲","display":"المجادلة۲۲"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ملك","display":"مَلَكٌ"},{"kind":"word","token":"اعظم","display":"اَعْظَمُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ميكائيل","display":"مِيكَائِيلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token"