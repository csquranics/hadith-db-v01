{"members":[{"header_text":" فِي  اَلْكَافِي أَحْمَدُ بْنُ مُحَمَّدِ بْنِ عَلِيٍّ عَنْ  مُحَمَّدِ بْنِ سِنَانٍ عَنْ<teller> أَبِي اَلْحَسَنِ عَلَيْهِ اَلسَّلاَمُ</teller> :","body_text":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ: <quranic_text>«وَ كٰانَ بَيْنَ ذٰلِكَ قَوٰاماً»</quranic_text> <footnote>[الفرقان۶۷]</footnote> قَالَ: الْقَوَامُ هُوَ الْمَعْرُوفُ عَلَي الْمُوسِعِ قَدَرُهُ وَ عَلَي الْمُقْتِرِ قَدَرُهُ عَلَي قَدْرِ عِيَالِهِ وَ مَؤُنَتِهِمْ الَّتِي هِيَ صَلاَحٌ لَهُ وَ لَهُمْ، <quranic_text>«لاٰ يُكَلِّفُ اللّٰهُ نَفْساً اِلاّٰ مٰا اتٰاهٰا»</quranic_text> <footnote>[الطلاق۷]</footnote> .","translation":"","aligned_body":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ TAG_OPEN:quranic_text وَ كٰانَ بَيْنَ ذٰلِكَ قَوٰاماً TAG_CLOSE:quranic_text TAG_OPEN:footnote الفرقان ۶۷ TAG_CLOSE:footnote قَالَ الْقَوَامُ هُوَ الْمَعْرُوفُ عَلَي الْمُوسِعِ قَدَرُهُ وَ عَلَي الْمُقْتِرِ قَدَرُهُ عَلَي قَدْرِ عِيَالِهِ وَ مَؤُنَتِهِمْ الَّتِي هِيَ صَلاَحٌ لَهُ وَ لَهُمْ TAG_OPEN:quranic_text لاٰ يُكَلِّفُ اللّٰهُ نَفْساً اِلاّٰ مٰا اتٰاهٰا TAG_CLOSE:quranic_text TAG_OPEN:footnote الطلاق ۷ TAG_CLOSE:footnote"}],"body_consensus_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"قواما","display":"قَوٰاماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفرقان","display":"الفرقان"},{"kind":"word","token":"۶۷","display":"۶۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ا