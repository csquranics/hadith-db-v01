{"members":[{"header_text":" وَ رَوَى عَنِ  اِبْنِ جَرِيرٍ بِإِسْنَادِهِ عَنِ  اِبْنِ عَبَّاسٍ : ","body_text":" <quranic_text>«وَ اِنْ لَمْ تَفْعَلْ فَمٰا بَلَّغْتَ رِسٰالَتَهُ»</quranic_text> <footnote>[المائدة۶۷]</footnote> يَعْنِي اِنْ كَتَمْتَ هَذِهِ الْايَةَ <quranic_text>«يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ»</quranic_text> <footnote>[المائدة۶۷]</footnote> مَا نَزَلَ عَلَي رَسُولِ اللَّهِ يَوْمَ غَدِيرِ خُمٍّ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ .","translation":"","aligned_body":"TAG_OPEN:quranic_text وَ اِنْ لَمْ تَفْعَلْ فَمٰا بَلَّغْتَ رِسٰالَتَهُ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۶۷ TAG_CLOSE:footnote يَعْنِي اِنْ كَتَمْتَ هَذِهِ الْايَةَ TAG_OPEN:quranic_text يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ TAG_CLOSE:quranic_text TAG_OPEN:footnote المائدة ۶۷ TAG_CLOSE:footnote مَا نَزَلَ عَلَي رَسُولِ اللَّهِ يَوْمَ غَدِيرِ خُمٍّ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ"}],"body_consensus_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تفعل","display":"تَفْعَلْ"},{"kind":"word","token":"فما","display":"فَمٰا"},{"kind":"word","token":"بلغت","display":"بَلَّغْتَ"},{"kind":"word","token":"رسالته","display":"رِسٰالَتَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۶۷","display":"۶۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كتمت","display":"كَتَمْتَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ا