{"consensus_set_id":"s396834","translation_language":"fa","translation_source":{"hid":"396834"},"segments":[{"source_hadith_segment":"وَ قُرِئَ عِنْدَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ  :  « وَ الَّذِينَ يَقُولُونَ :   <quranic_text> « هَبْ لَنٰا مِنْ اَزْوٰاجِنٰا وَ ذُرِّيّٰاتِنٰا قُرَّةَ اَعْيُنٍ وَ اِجْعَلْنٰا لِلْمُتَّقِينَ اِمٰاماً » </quranic_text>   <footnote> [ الفرقان ۷۴ ] </footnote> فَقَالَ :  قَدْ سَاَلُوا اللَّهَ عَظِيماً اَنْ يَجْعَلَهُمْ لِلْمُتَّقِينَ اَئِمَّةً ،  فَقِيلَ لَهُ : كَيْفَ هَذَا يَا اِبْنَ رَسُولِ اللَّهِ  ؟  قَالَ : اِنَّمَا اَنْزَلَ اللَّهُ :  « اَلَّذِينَ يَقُولُونَ رَبَّنَا هَبْ لَنَا مِنْ اَزْوَاجِنَا وَ ذُرِيَّاتِنَا قُرَّةَ اَعْيُنٍ وَ اِجْعَلْ لَنَا مِنَ الْمُتَّقِينَ اِمَاماً .  »","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قرئ","display":"قُرِئَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هب","display":"هَبْ"},{"kind":"word","token":"لنا","display":"لَنٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ازواجنا","display":"اَزْوٰاجِنٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذرياتنا","display":"ذُرِّيّٰاتِنٰا"},{"kind":"word","token":"قره","display":"قُرَّةَ"},{"kind":"word","token":"اعين","display":"اَعْيُنٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اجعلنا","display":"اِجْعَلْنٰا"},{"kind":"word","token":"للمتقين","display":"لِلْمُتَّقِينَ"},{"kind":"word","token":"اماما","display":"اِمٰاماً"},{"kin