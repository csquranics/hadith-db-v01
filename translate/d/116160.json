{"consensus_set_id":"116160","translation_language":"fa","translation_source":{"hid":"360662"},"segments":[{"source_hadith_segment":"وَ بَكَي بَعْضُهُمْ عِنْدَ الْمَوْتِ فَقِيلَ لَهُ مَا يُبْكِيكَ فَقَالَ ايَةٌ فِي كِتَابِ اللَّهِ تَعَالَي  <quranic_text> « اِنَّمٰا يَتَقَبَّلُ اللّٰهُ مِنَ الْمُتَّقِينَ » </quranic_text>   <footnote> [ المائدة ۲۷ ] </footnote>   .","translation_segment":"یکی از بزرگان موقع مردن گریه می‌کرد، پرسیدند: چرا گریه می‌کنی‌؟ گفت: به خاطر آیه‌ای از قرآن مجید: «إنمٰا یتقبل‌ اللٰه‌ من‌ المتقین‌» یعنی: خداوند فقط‍‌ از پرهیزگاران می‌پذیرد.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بكي","display":"بَكَي"},{"kind":"word","token":"بعضهم","display":"بَعْضُهُمْ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الموت","display":"الْمَوْتِ"},{"kind":"word","token":"فقيل","display":"فَقِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يبكيك","display":"يُبْكِيكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ايه","display":"ايَةٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتاب","display":"كِتَابِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"يتقبل","display":"يَتَقَبَّلُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المتقين","display":"الْمُتَّقِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۲۷","display":"۲۷"},{"kind":"tag_close","tag_name":"footnote"}]}]}