{"consensus_set_id":"s399948","translation_language":"fa","translation_source":{"hid":"399948"},"segments":[{"source_hadith_segment":"وَ اَمَّا الرَّابِعُ وَ الْعِشْرُونَ فَاِنَّ اللَّهَ اَنْزَلَ عَلَي رَسُولِهِ :   <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا اِذٰا نٰاجَيْتُمُ الرَّسُولَ فَقَدِّمُوا بَيْنَ يَدَيْ نَجْوٰاكُمْ صَدَقَةً » </quranic_text>   <footnote> [ المجادلة ۱۲ ] </footnote>  فَكَانَ لِي دِينَارٌ فَبِعْتُهُ بِعَشَرَةِ دَرَاهِمَ فَكُنْتُ اِذَا نَاجَيْتُ رَسُولَ اللَّهِ اَتَصَدَّقُ قَبْلَ ذَلِكَ بِدِرْهَمٍ ،  فَوَ اللَّهِ مَا فَعَلَ هَذَا اَحَدٌ مِنْ اَصْحَابِهِ قَبْلِي وَ لاَ بَعْدِي ،  فَاَنْزَلَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « اَ اَشْفَقْتُمْ اَنْ تُقَدِّمُوا بَيْنَ يَدَيْ نَجْوٰاكُمْ صَدَقٰاتٍ فَاِذْ لَمْ تَفْعَلُوا وَ تٰابَ اللّٰهُ عَلَيْكُمْ » </quranic_text>   <footnote> [ المجادلة ۱۳ ] </footnote>  الْايَةَ فَهَلْ تَكُونُ التَّوْبَةُ اِلاَّ عَنْ ذَلِكَ ؟","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الرابع","display":"الرَّابِعُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"العشرون","display":"الْعِشْرُونَ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"رسوله","display":"رَسُولِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"ناجيتم","display":"نٰاجَيْتُمُ"},{"kind":"word","token":"الرسول","display":"الرَّسُولَ"},{"kind":"word","token":"فقدموا","display":"فَقَدِّمُوا"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"يدي"