ع قول اللّه عزّ و جلّ لنبيّه صلّي اللّه عليه و سلّم :","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<quranic_text> « قُلْ اِنْ كُنْتُمْ تُحِبُّونَ اللّٰهَ فَاتَّبِعُونِي يُحْبِبْكُمُ اللّٰهُ وَ يَغْفِرْ لَكُمْ ذُنُوبَكُمْ » </quranic_text>   <footnote> [ العمران ۳۱ ] </footnote>  و اللّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  لا يطيع اللّه عبد ابدا الاّ ادخل اللّه عليه في طاعته اتّباعنا ؛","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"و لا و اللّه لا يتّبعنا عبد ابدا الاّ احبّه اللّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و لا و اللّه لا يدع احد اتّباعنا ابدا الاّ ابغضنا ؛","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"و لا و اللّه لا يبغضنا احد ابدا الاّ عصي اللّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و من مات عاصيا للّه اخزاه اللّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و اكبّه علي وجهه في النار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و الحمد للّه ربّ العالمين .","translation_segment":"","segment_columns":[]}]}