ر بی‌جانش را به ساحل آورد تا همگان از او عبرت بگیرند. هلاکت فرعون دلیل دیگری نیز داشت و آن اینکه او هنگام غرق شدن، از موسی کمک خواست. خداوند به موسی وحی فرمود: تو آفریننده او نیستی. به فریادش اعتنایی نکن؛ اگر او به درگاه من پناه آورده بود، بی‌گمان به یاریش می‌شتافتم.","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قبل","display":"قَبْلُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كنت","display":"كُنْتَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المفسدين","display":"الْمُفْسِدِينَ"},{"kind":"word","token":"فاليوم","display":"فَالْيَوْمَ"},{"kind":"word","token":"ننجيك","display":"نُنَجِّيكَ"},{"kind":"word","token":"ببدنك","display":"بِبَدَنِكَ"},{"kind":"word","token":"لتكون","display":"لِتَكُونَ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"خلفك","display":"خَلْفَكَ"},{"kind":"word","token":"ايه","display":"ايَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يونس","display":"يونس"},{"kind":"word","token":"۹۱","display":"۹۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قدمه","display":"قَدَمِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قرنه","display":"قَرْنِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحديد","display":"الْحَدِيدِ"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"غرق","display":"غَرِقَ"},{"kind":"word","token":"القاه","display":"اَلْقَاهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ن