{"consensus_set_id":"s351234","translation_language":"fa","translation_source":{"hid":"351234"},"segments":[{"source_hadith_segment":"قُلْتُ لِلرِّضَا عَلَيْهِ السَّلاَمُ لِاَيِّ عِلَّةٍ اَغْرَقَ اللَّهُ فِرْعَوْنَ وَ قَدْ امَنَ بِهِ","translation_segment":"ابراهیم همدانی گوید: از امام رضا علیه السلام پرسیدم:","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"للرضا","display":"لِلرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"لاي","display":"لِاَيِّ"},{"kind":"word","token":"عله","display":"عِلَّةٍ"},{"kind":"word","token":"اغرق","display":"اَغْرَقَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"امن","display":"امَنَ"},{"kind":"word","token":"به","display":"بِهِ"}]},{"source_hadith_segment":"وَ اَقَرَّ بِتَوْحِيدِهِ قَالَ لِاَنَّهُ امَنَ عِنْدَ رُؤْيَةِ الْيَاْسِ[ اَلْبَاْسِ ]وَ الْاِيمَانُ عِنْدَ رُؤْيَةِ الْيَاْسِ[ اَلْبَاْسِ ] غَيْرُ مَقْبُولٍ وَ ذَلِكَ حُكْمُ اللَّهِ فِي السَّلَفِ وَ الْخَلَفِ قَالَ اللَّهُ عَزَّ وَ جَلَّ  <quranic_text> « فَلَمّٰا رَاَوْا بَاْسَنٰا قٰالُوا امَنّٰا بِاللّٰهِ وَحْدَهُ وَ كَفَرْنٰا بِمٰا كُنّٰا بِهِ مُشْرِكِينَ فَلَمْ يَكُ يَنْفَعُهُمْ اِيمٰانُهُمْ لَمّٰا رَاَوْا بَاْسَنٰا » </quranic_text>   <footnote> [ غافر ۸۴ ] </footnote>  وَ هَكَذَا فِرْعَوْنُ لَمَّا اَدْرَكَهُ الْغَرَقُ قَالَ  <quranic_text> « امَنْتُ اَنَّهُ لاٰ اِلٰهَ اِلاَّ الَّذِي امَنَتْ بِهِ بَنُوا اِسْرٰائِيلَ وَ اَنَا مِنَ الْمُسْلِمِينَ » </quranic_text>   <footnote> [ يونس ۹۰ ] </footnote>  فَقِيلَ لَهُ  <quranic_text> « الْانَ وَ قَدْ عَصَيْتَ » </quranic_text>   <footnote> [ يونس ۹۱ ] </footnote>","translation_segment":"چرا فرعون با اینکه به خداوند ایمان آورد هلاک گردید [و سزاوار عذاب خدا شد]؟ آن حضرت فرمودند: او زمانی ایمان آورد که از هرچاره‌ای ناامید شده بود. چنین ایمانی براساس اختیار انسان نیست؛ «فلمٰا رأوا بأسنٰا قٰالوا آمنٰا باللٰه‌ وحده‌ و کفرنٰا بمٰا کنٰا به‌ مشرکین‌ `فلم‌ یک‌ ینفعهم‌ إیمٰانهم‌ لمٰا رأوا بأسنٰا؛ و چون عذاب ما را دیدند گفتند: تنها به خداوند ایمان آوردیم و به آنچه شرک آورده","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اقر","display":"اَقَرَّ"},{"kind":"word","token":"بتوحيده","display":"بِتَوْحِيدِهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لانه","display":"لِاَنَّهُ"},{"kind":"word","token":"امن","display":"امَنَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"رؤيه","display":"رُؤْيَةِ"},{"kind":"word","token":"الياس","display":"الْيَاْسِ"},{"kind":"word","token":"الباس","display":"اَلْبَاْسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الايمان","display":"الْاِيمَانُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"رؤيه","display":"رُؤْيَةِ"},{"kind":"word","token":"الياس","display":"الْيَاْسِ"},{"kind":"word","token":"الباس","display":"اَلْبَاْسِ"},{"kind":"word","token":"غير","display":"غَيْرُ"},{"kind":"word","token":"مقبول","display":"مَقْبُولٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"حكم","display":"حُكْمُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السلف","display":"السَّلَفِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الخلف","display":"الْخَلَفِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلما","display":"فَلَمّٰا"},{"kind":"word","token":"راوا","display":"رَاَوْا"},{"kind":"word","token":"باسنا","displa