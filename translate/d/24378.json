{"consensus_set_id":"24378","translation_language":"fa","translation_source":{"hid":"105041"},"segments":[{"source_hadith_segment":"لَمَّا نَزَلَتْ  <quranic_text> « وَ تَعِيَهٰا اُذُنٌ وٰاعِيَةٌ » </quranic_text>   <footnote> [ الحاقة ۱۲ ] </footnote>  قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ هِيَ اُذُنُكَ يَا عَلِيُّ  .","translation_segment":"امام صادق ع: چون این آیه نازل شد: «و گوشی شنوا آن را حفظ‍‌ کند-۱۲ سوره ۶۹-»، رسول خدا صلی اللٰه علیه و آله فرمود: آن گوش تو است، ای علی.","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعيها","display":"تَعِيَهٰا"},{"kind":"word","token":"اذن","display":"اُذُنٌ"},{"kind":"word","token":"واعيه","display":"وٰاعِيَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحاقه","display":"الحاقة"},{"kind":"word","token":"۱۲","display":"۱۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"اذنك","display":"اُذُنُكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"علي","display":"عَلِيُّ"}]}]}