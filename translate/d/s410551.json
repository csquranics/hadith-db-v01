{"consensus_set_id":"s410551","translation_language":"fa","translation_source":{"hid":"410551"},"segments":[{"source_hadith_segment":"فِي تَفْسِيرِ هَذِهِ الْايَةِ :","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"}]},{"source_hadith_segment":"« نَحْنُ الَّذِينَ شَرَعَ اللَّهُ لَنَا دِينَهُ فِي كِتَابِهِ ،  وَ ذَلِكَ قَوْلُهُ تَعَالَي :   <quranic_text> « شَرَعَ لَكُمْ » </quranic_text>   <footnote> [ الشوري ۱۳ ] </footnote>  يَا الَ مُحَمَّدٍ  <quranic_text> « مِنَ الدِّينِ مٰا وَصّٰي بِهِ نُوحاً وَ الَّذِي اَوْحَيْنٰا اِلَيْكَ وَ مٰا وَصَّيْنٰا بِهِ اِبْرٰاهِيمَ وَ مُوسيٰ وَ عِيسيٰ اَنْ اَقِيمُوا الدِّينَ » </quranic_text>   <footnote> [ الشوري ۱۳ ] </footnote> يَا الَ مُحَمَّدٍ  <quranic_text> « وَ لاٰ تَتَفَرَّقُوا فِيهِ كَبُرَ عَلَي الْمُشْرِكِينَ مٰا تَدْعُوهُمْ اِلَيْهِ » </quranic_text>   <footnote> [ الشوري ۱۳ ] </footnote> مِنْ وَلاَيَةِ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ )  <quranic_text> « اللّٰهُ يَجْتَبِي اِلَيْهِ مَنْ يَشٰاءُ وَ يَهْدِي اِلَيْهِ مَنْ يُنِيبُ » </quranic_text>   <footnote> [ الشوري ۱۳ ] </footnote>  اَيْ مَنْ يُجِيبُكَ اِلَي وَلاَيَةِ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) » .","translation_segment":"","segment_columns":[{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"شرع","display":"شَرَعَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"لنا","display":"لَنَا"},{"kind":"word","token":"دينه","display":"دِينَهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتابه","display":"كِتَابِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"