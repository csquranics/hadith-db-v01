te> [ الفاتحة ۱ ] </footnote>   <quranic_text> « وَ نُرِيدُ اَنْ نَمُنَّ عَلَي الَّذِينَ اُسْتُضْعِفُوا فِي الْاَرْضِ وَ نَجْعَلَهُمْ اَئِمَّةً وَ نَجْعَلَهُمُ الْوٰارِثِينَ وَ نُمَكِّنَ لَهُمْ فِي الْاَرْضِ وَ نُرِيَ فِرْعَوْنَ وَ هٰامٰانَ وَ جُنُودَهُمٰا مِنْهُمْ مٰا كٰانُوا يَحْذَرُونَ » </quranic_text>   <footnote> [ القصص ۵ ] </footnote>  وَ صَلَّي اللَّهُ عَلَي مُحَمَّدٍ الْمُصْطَفَي  ،  وَ عَلِيٍّ الْمُرْتَضَي  ،  وَ فَاطِمَةَ الزَّهْرَاءِ  ،  وَ الْحَسَنِ  ،  وَ الْحُسَيْنِ  ،  وَ عَلِيِّ بْنِ الْحُسَيْنِ  ،  وَ مُحَمَّدِ بْنِ عَلِيٍّ  ،  وَ جَعْفَرِ بْنِ مُحَمَّدٍ  ،  وَ مُوسَي بْنِ جَعْفَرٍ وَ عَلِيِّ بْنِ مُوسَي  ،  وَ مُحَمَّدِ بْنِ عَلِيٍّ  ،  وَ عَلِيِّ بْنِ مُحَمَّدٍ  ،  وَ الْحَسَنِ بْنِ عَلِيٍّ عَلَيْهِمُ السَّلاَمُ","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"اعوذ","display":"اَعُوذُ"},{"kind":"word","token":"بالله","display":"بِاللَّهِ"},{"kind":"word","token":"السميع","display":"السَّمِيعِ"},{"kind":"word","token":"العليم","display":"الْعَلِيمِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الشيطان","display":"الشَّيْطَانِ"},{"kind":"word","token":"الرجيم","display":"الرَّجِيمِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نريد","display":"نُرِيدُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"نمن","display":"نَمُنَّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"wor