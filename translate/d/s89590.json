{"consensus_set_id":"s89590","translation_language":"fa","translation_source":{"hid":"89590"},"segments":[{"source_hadith_segment":"« اِقْرَاْ فِي الرَّكْعَتَيْنِ لِلطَّوَافِ -  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>  وَ  <quranic_text> « قُلْ يٰا اَيُّهَا الْكٰافِرُونَ » </quranic_text>   <footnote> [ الكافرون ۱ ] </footnote>   .","translation_segment":"* *۱۲۱ - ابو عبد الله صادق (ع) گفت: در رکعت اول از نماز طواف سوره قل‌ هو اللٰه‌ أحد و در رکعت دوم سوره قل‌ یٰا أیها الکٰافرون‌ را تلاوت کن.","segment_columns":[{"kind":"word","token":"اقرا","display":"اِقْرَاْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الركعتين","display":"الرَّكْعَتَيْنِ"},{"kind":"word","token":"للطواف","display":"لِلطَّوَافِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاخلاص","display":"الاخلاص"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الكافرون","display":"الْكٰافِرُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكافرون","display":"الكافرون"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"}]}]}