ان نامت که کوه را از جای کندی و بر سر آنها (بنی إسرائیل) مانند سایبانی بود (خواهم) که از من کفایت کنی آنچه را که از آن ترس و بیم دارم، خدایا من بوسیله تو آنها را دفع میکنم و از شرشان بتو پناه","segment_columns":[]},{"source_hadith_segment":"وَ اَعُوذُ بِكَ مِنْ شُرُورِهِمْ وَ اَسْتَجِيرُ بِكَ مِنْهُمْ","translation_segment":"میبرم و بوسیله تو از آنها پناه گیرم، و بکمک تو بر","segment_columns":[]},{"source_hadith_segment":"وَ اَسْتَعِينُ بِكَ عَلَيْهِمْ اللَّهُ اللَّهُ رَبِّي لاَ اُشْرِكُ بِهِ شَيْئاً وَ لاَ اَتَّخِذُ","translation_segment":"آنها کمک گیرم، خدا، خدا، پروردگار من است که چیزی را شریک أو نسازم و جز أو","segment_columns":[]},{"source_hadith_segment":"مِنْ دُونِهِ وَلِيّاً .","translation_segment":"یاوری برای خود نگیرم.","segment_columns":[]}]}