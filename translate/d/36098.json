ion_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  قال :  عليّ الكرّار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  قلت :  و الذي قبله ؟  قال :  محمّد المختار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  قلت :  و الذي حوله ؟  قال :  النبيّون ،  و الصدّيقون ،  و الشهداء ،  و الصالحون ،  و المؤمنون","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  قلت :  انا ما فعلت حتّي امّرك عليّ ؟  قال :  اليه يرجع الامر ،  و حالك حال هؤلاء","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فحقّقت النظر و اذا بعمر بن سعد امير العسكر ،  و قوم لم اعرفهم و اذا بعنقه سلسلة من حديد ،  و النار خارجة من عينيه و اذنيه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فايقنت بالهلاك و باقي القوم منهم مغلّل و منهم مقيّد و منهم مقهور بعضده مثلي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فبينا نحن نسير ،  و اذا برسول اللّه صلّي اللّه عليه و اله الذي وصفه الملك جالس علي كرسيّ عال يزهر اظنّه من اللؤلؤ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و رجلين ذي شيبتين بهيّتين عن يمينه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فسالت الملك عنهما ،  فقال :  نوح و ابراهيم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"و اذا برسول اللّه صلّي اللّه عليه و اله يقول :  ما صنعت يا عليّ ؟  قال :  ما تركت احدا من قاتلي الحسين الاّ و اتيت به","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فحمدت اللّه تعالي علي انّي لم اكن منهم و ردّ الي عقلي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و اذا برسول اللّه صلّي اللّه عليه و اله يقول :  قدّموهم فقدّموهم اليه و جعل يسالهم و يبكي و يبكي كلّ من في الموقف لبكائه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لانّه يقول للرجل :  ما صنعت بطفّ كربلاء بولدي الحسين ؟  فيجيب يا رسول اللّه انا حميت الماء عليه و هذا يقول :  انا قتلته و هذا يقول :  انا وطئت صدره بفرسي ،  و منهم من يقول :  انا ضربت ولده العليل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فصاح رسول اللّه صلّي اللّه عليه و اله :  وا ولداه وا قلّة ناصراه وا حسيناه وا عليّاه هكذا جري عليكم بعدي اهل بيتي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"انظر يا ابي ادم ،  انظر يا اخي نوح ،  كيف خلّفوني في ذرّيّتي ؟  فبكوا حتّي ارتجّ المحشر","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فامر بهم زبانية جهنّم يجرّونهم اوّلا فاوّلا الي النار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و اذا بهم قد اتوا برجل ،  فساله فقال :  ما صنعت شيئا ،  فقال :  ا ما كنت نجّارا ؟  قال :  صدقت يا سيّدي لكنّي ما عملت شيئا الاّ عمود الخيمة لحصين بن نمير لانّه انكسر من ريح عاصف فوصلته","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فبكي و قال :  كثّرت السواد علي ولدي خذوه الي النار و صاحوا لا حكم الاّ للّه و لرسوله و وصيّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال الحدّاد :  فايقنت بالهلاك فامر بي فقدّموني فاستخبرني فاخبرته فامر بي الي النار فما سحبوني الاّ و انتبهت ،  و حكيت لكلّ من لقيته ،  و قد يبس","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لسانه و مات نصفه و تبرّا منه كلّ من يحبّه و مات فقيرا لا رحمه اللّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<quranic_text> « وَ سَيَعْلَمُ الَّذِينَ ظَلَمُوا اَيَّ مُنْقَلَبٍ يَنْقَلِبُونَ » </quranic_text>   <footnote> [ الشعراء ۲۲۷ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال :  و حكي عن السدّي ،  قال :  اضافني رجل في ليلة كنت احبّ الجليس","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فرحّبت به و قرّبته و اكرمته","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و جلسنا نتسامر و اذا به ينطلق بالكلام كالسيل اذا قصد الحضيض","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فطرقت له فانتهي في سمره طفّ كربلاء","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و كان قريب العهد من قتل الحسين عليه السّلام فتاوّهت ( الزفراء ) الصعداء ،  و تزفّرت كملا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"، فقال :  ما بالك ؟  قلت :  ذكرت مصابا يهون عنده كلّ مصاب","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  قال :  ا ما كنت حاضرا يوم الطفّ ؟  قلت :  لا و الحمد للّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  قال :  اراك تحمد علي ايّ شيء ؟  قلت :  علي الخلاص من دم الحسين لانّ جدّه صلّي اللّه عليه و اله","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قال :  انّ من طولب بدم ولدي الحسين يوم القيامة لخفيف الميزان","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال : [ قال :  ] هكذا جدّه ؟  قلت :  نعم ،  و قال صلّي اللّه عليه و اله :  ولدي الحسين يقتل ظلما و عدوانا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  الا و من قتله يدخل في تابوت من نار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و يعذّب بعذاب نصف اهل النار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و قد غلّت يداه و رجلاه و له رائحة يتعوّذ اهل النار منها","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  هو و من شايع و بايع او رضي بذلك","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<quranic_text> « كُلَّمٰا نَضِجَتْ جُلُودُهُمْ بَدَّلْنٰاهُمْ جُلُوداً غَيْرَهٰا لِيَذُوقُوا الْعَذٰابَ » </quranic_text>   <footnote> [ النساء ۵۶ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لا يفتّر عنهم ساعة","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و يسقون من حميم جهنّم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فالويل لهم من عذاب جهنّ