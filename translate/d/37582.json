َكُ الْاَمْرِ خَوَاتِمُهُ وَ شَرُّ الرِّوَايَاتِ رِوَايَاتُ الْكَذِبِ وَ كُلُّ مَا هُوَ اتٍ قَرِيبٌ وَ سِبَابُ الْمُؤْمِنِ فُسُوقٌ وَ قِتَالُهُ كُفْرٌ","translation_segment":"چیزی که بدل درآید یقین است، و تردید هم کفر است، نوحه‌گری از کارهای جاهلیت است، و دزدی از غنیمت شراره دوزخ است، مستی از جهنم است و شعر از ابلیس، می‌همه گناهانست و زنان دامهای شیطانند، جوانی یک نوع دیوانگی است، و بدتر کسب ربا است و بدتر مال خوردن از مال یتیم، سعادتمند آنکه از دیگران پند گرفت و بدبخت آنکه از شکم مادر بدبختی گرفت، همانا یکی از شما چند قدمی پیش رود و باید کار را بپایان رساند. و مناط‍‌ هر کاری همان پایان آنست بدترین روایتها نقل دروغ است. و هر چه خواهد آمد نزدیک است، دشنام بمومن بزهکاریست و جنگ با او کفر است، و بدگوئی از او نافرمانی خدا است، و حرمت مالش چون حرمت خون","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"راس","display":"رَاْسُ"},{"kind":"word","token":"الحكمه","display":"الْحِكْمَةِ"},{"kind":"word","token":"مخافه","display":"مَخَافَةُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"خير","display":"خَيْرُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"القي","display":"اُلْقِيَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القلب","display":"الْقَلْبِ"},{"kind":"word","token":"اليقين","display":"الْيَقِينُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارتياب","display":"الاِرْتِيَابُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الكفر","display":"الْكُفْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النياحه","display":"النِّيَاحَةُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عمل","display":"عَمَلِ"},{"kind":"word","token":"الجاهليه","display":"الْجَاهِلِيَّةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الغلول","display":"الْغُلُولُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word",