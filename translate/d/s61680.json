{"consensus_set_id":"s61680","translation_language":"fa","translation_source":{"hid":"61680"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ تَعَالَي :   <quranic_text> « يٰا عِبٰادِيَ الَّذِينَ اَسْرَفُوا عَليٰ اَنْفُسِهِمْ لاٰ تَقْنَطُوا مِنْ رَحْمَةِ اللّٰهِ اِنَّ اللّٰهَ يَغْفِرُ الذُّنُوبَ جَمِيعاً » </quranic_text>   <footnote> [ الزمر ۵۳ ] </footnote>  اَ خَاصَّةٌ هِيَ اَمْ عَامَّةٌ ؟  قَالَ :  بَلْ هِيَ لَكَ وَ لِاَصْحَابِكَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"عبادي","display":"عِبٰادِيَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اسرفوا","display":"اَسْرَفُوا"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"انفسهم","display":"اَنْفُسِهِمْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تقنطوا","display":"تَقْنَطُوا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"رحمه","display":"رَحْمَةِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"يغفر","display":"يَغْفِرُ"},{"kind":"word","token":"الذنوب","display":"الذُّنُوبَ"},{"kind":"word","token":"جميعا","display":"جَمِيعاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"