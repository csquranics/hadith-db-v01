{"consensus_set_id":"s410439","translation_language":"fa","translation_source":{"hid":"410439"},"segments":[{"source_hadith_segment":"« فَقَوْلُ اَللَّهِ عَزَّ وَ جَلَّ فِي سُورَةِ الْمُؤْمِنِ حِكَايَةً عَنْ قَوْلِ رَجُلٍ مُؤْمِنٍ مِنْ الِ فِرْعَوْنَ : <quranic_text> « وَ قٰالَ رَجُلٌ مُؤْمِنٌ مِنْ الِ فِرْعَوْنَ يَكْتُمُ اِيمٰانَهُ اَ تَقْتُلُونَ رَجُلاً اَنْ يَقُولَ رَبِّيَ اللّٰهُ وَ قَدْ جٰاءَكُمْ بِالْبَيِّنٰاتِ مِنْ رَبِّكُمْ » </quranic_text>   <footnote> [ غافر ۲۸ ] </footnote> ،  وَ كَانَ اِبْنَ خَالِ فِرْعَوْنَ ،  فَنَسَبَهُ اِلَي فِرْعَوْنَ بِنَسَبِهِ ،  وَ لَمْ يُضِفْهُ اِلَيْهِ بِدِينِهِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"فقول","display":"فَقَوْلُ"},{"kind":"word","token":"الله","display":"اَللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"سوره","display":"سُورَةِ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنِ"},{"kind":"word","token":"حكايه","display":"حِكَايَةً"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنَ"},{"kind":"word","token":"يكتم","display":"يَكْتُمُ"},{"kind":"word","token":"ايمانه","display":"اِيمٰانَهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","toke