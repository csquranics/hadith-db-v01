{"consensus_set_id":"91246","translation_language":"fa","translation_source":{"hid":"409263"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « فَهُمْ يُوزَعُونَ » </quranic_text>   <footnote> [ النمل ۱۷ ] </footnote>  قَالَ :  « يُحْبَسُ اَوَّلُهُمْ عَلَي اخِرِهِمْ ،  قَوْلُهُ تَعَالَي :   <quranic_text> « لَاُعَذِّبَنَّهُ عَذٰاباً شَدِيداً » </quranic_text>   <footnote> [ النمل ۲۱ ] </footnote>  يَقُولُ لَاَنْتِفَنَّ رِيشَهُ .  وَ قَوْلُهُ تَعَالَي :   <quranic_text> « اَلاّٰ تَعْلُوا عَلَيَّ » </quranic_text>   <footnote> [ النمل ۳۱ ] </footnote>  يَقُولُ :  لاَ تَعْظُمُوا عَلَيَّ وَ قَوْلُهُ :   <quranic_text> « لاٰ قِبَلَ لَهُمْ بِهٰا » </quranic_text>   <footnote> [ النمل ۳۷ ] </footnote>  يَقُولُ :  لاَ طَاقَةَ لَهُمْ بِهَا .  وَ قَوْلُ سُلَيْمَانَ :   <quranic_text> « لِيَبْلُوَنِي اَ اَشْكُرُ » </quranic_text>   <footnote> [ النمل ۴۰ ] </footnote>  لِمَا اتَانِي مِنَ الْمُلْكِ <quranic_text> « اَمْ اَكْفُرُ » </quranic_text>   <footnote> [ النمل ۴۰ ] </footnote>  اِذَا رَاَيْتُ مَنْ هُوَ اَدْوَنُ مِنِّي اَفْضَلُ مِنِّي عِلْماً ؟  فَعَزَمَ اللَّهُ لَهُ عَلَي الشُّكْرِ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فهم","display":"فَهُمْ"},{"kind":"word","token":"يوزعون","display":"يُوزَعُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النمل","display":"النمل"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يحبس","display":"يُحْبَسُ"},{"kind":"word","token":"اولهم","display":"اَوَّلُهُمْ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اخرهم","display":"اخِرِهِمْ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"}