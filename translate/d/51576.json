{"consensus_set_id":"51576","translation_language":"fa","translation_source":{"hid":"410893"},"segments":[{"source_hadith_segment":"« اَنَا اَلَّذِي ذَكَرَ اللَّهُ اِسْمَهُ فِي التَّوْرَاةِ وَ الْاِنْجِيلِ بِمُؤَازَرَةِ رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  وَ اَنَا اَوَّلُ مَنْ بَايَعَ رَسُولَ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) تَحْتَ الشَّجَرَةِ فِي قَوْلِهِ تَعَالَي :   <quranic_text> « لَقَدْ رَضِيَ اللّٰهُ عَنِ الْمُؤْمِنِينَ اِذْ يُبٰايِعُونَكَ تَحْتَ الشَّجَرَةِ » </quranic_text>   <footnote> [ الفتح ۱۸ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"الذي","display":"اَلَّذِي"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"اسمه","display":"اِسْمَهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"التوراه","display":"التَّوْرَاةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الانجيل","display":"الْاِنْجِيلِ"},{"kind":"word","token":"بمؤازره","display":"بِمُؤَازَرَةِ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"اول","display":"اَوَّلُ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"بايع","display":"بَايَعَ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّ