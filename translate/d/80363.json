{"consensus_set_id":"80363","translation_language":"fa","translation_source":{"hid":"411828"},"segments":[{"source_hadith_segment":"« وَ كَانَ اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) يَقُولُ :   <quranic_text> « فَسَتُبْصِرُ وَ يُبْصِرُونَ بِاَيِّكُمُ الْمَفْتُونُ » </quranic_text>   <footnote> [ القلم ۵ ] </footnote>  فَلَقِيَهُ الثَّانِي ،  فَقَالَ لَهُ :  اَنْتَ الَّذِي تَقُولُ كَذَا وَ كَذَا ،  تَعْرِضُ بِي وَ بِصَاحِبَيَّ ؟  فَقَالَ لَهُ اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) وَ لَمْ يَعْتَذِرْ اِلَيْهِ :  اَ لاَ اُخْبِرُكَ بِمَا نُزِّلَ فِي بَنِي اُمَيَّةَ ؟  نُزِّلَ فِيهِمْ  <quranic_text> « فَهَلْ عَسَيْتُمْ اِنْ تَوَلَّيْتُمْ اَنْ تُفْسِدُوا فِي الْاَرْضِ وَ تُقَطِّعُوا اَرْحٰامَكُمْ » </quranic_text>   <footnote> [ محمد ۲۲ ] </footnote>  قَالَ :  فَكَذَّبَهُ وَ قَالَ لَهُ :  هُمْ خَيْرٌ مِنْكَ وَ اَوْصَلُ لِلرَّحِمِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"مثله","display":"مِثْلَهُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"زاد","display":"زَادَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فستبصر","display":"فَسَتُبْصِرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يبصرون","display":"يُبْصِرُونَ"},{"kind":"word","token":"بايكم","display":"بِاَيِّكُمُ"},{"kind":"word","token":"المفتون","display":"الْمَفْتُونُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open",