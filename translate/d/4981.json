{"consensus_set_id":"4981","translation_language":"fa","translation_source":{"hid":"404651"},"segments":[{"source_hadith_segment":"« كُلُّ شَيْءٍ مِنَ الْحَيَوَانِ غَيْرَ الْخِنْزِيرِ وَ النَّطِيحَةِ وَ الْمَوْقُوذَةِ وَ الْمُتَرَدِّيَةِ ،  وَ مَا اَكَلَ السَّبُعُ [ وَ هُوَ ] قَوْلُ اللَّهِ :   <quranic_text> « اِلاّٰ مٰا ذَكَّيْتُمْ » </quranic_text>   <footnote> [ المائدة ۳ ] </footnote> فَاِنْ اَدْرَكْتَ شَيْئاً مِنْهَا وَ عَيْنٌ تَطْرِفُ ،  اَوْ قَائِمَةٌ تَرْكِضُ ،  اَوْ ذَنَبٌ يُمْصَعُ فَذَبَحْتَ فَقَدْ اَدْرَكْتَ ذَكَاتَهُ ،  فَكُلْهُ - قَالَ - وَ اِنْ ذَبَحْتَ ذَبِيحَةً فَاَجَدْتَ الذَّبْحَ فَوَقَعَتْ فِي النَّارِ ،  اَوْ فِي الْمَاءِ ،  اَوْ مِنْ فَوْقِ بَيْتٍ ،  اَوْ مِنْ فَوْقِ جَبَلٍ اِذَا كُنْتَ قَدْ اَجَدْتَ الذَّبْحَ فَكُلْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"كل","display":"كُلْ"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الحيوان","display":"الْحَيَوَانِ"},{"kind":"word","token":"غير","display":"غَيْرَ"},{"kind":"word","token":"الخنزير","display":"الْخِنْزِيرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النطيحه","display":"النَّطِيحَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الموقوذه","display":"الْمَوْقُوذَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المترديه","display":"الْمُتَرَدِّيَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اكل","display":"اَكَلَ"},{"kind":"word","token":"السبع","display":"السَّبُعُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token"