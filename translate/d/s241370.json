{"consensus_set_id":"s241370","translation_language":"fa","translation_source":{"hid":"241370"},"segments":[{"source_hadith_segment":"<quranic_text> « وَ لاٰ تُفْسِدُوا فِي الْاَرْضِ بَعْدَ اِصْلاٰحِهٰا » </quranic_text>   <footnote> [ الاعراف ۵۶ ] </footnote>  قَالَ اَصْلَحَهَا بِرَسُولِ اللَّهِ وَ بِاَمِيرِ الْمُؤْمِنِينَ فَاَفْسَدُوهَا حِينَ تَرَكُوا اَمِيرَ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ  .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تفسدوا","display":"تُفْسِدُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"اصلاحها","display":"اِصْلاٰحِهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۵۶","display":"۵۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اصلحها","display":"اَصْلَحَهَا"},{"kind":"word","token":"برسول","display":"بِرَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بامير","display":"بِاَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"فافسدوها","display":"فَاَفْسَدُوهَا"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"تركوا","display":"تَرَكُوا"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}