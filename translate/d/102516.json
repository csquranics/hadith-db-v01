{"consensus_set_id":"102516","translation_language":"fa","translation_source":{"hid":"118946"},"segments":[{"source_hadith_segment":"تَلَوْتُ عِنْدَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ  <quranic_text> « ذَوٰا عَدْلٍ مِنْكُمْ » </quranic_text>   <footnote> [ المائدة ۹۵ ] </footnote>  فَقَالَ ذُو عَدْلٍ مِنْكُمْ هَذَا مِمَّا اَخْطَاَتْ فِيهِ الْكُتَّابُ .","translation_segment":"حماد بن عثمان می‌گوید: نزد امام صادق علیه السلام چنین قرائت کردم: (ذوا عدل منکم) حضرت علیه السلام فرمود: بخوان: (ذو عدل) و این از جاهایی است که نگارندگان قرآن در آن خطا کردند.","segment_columns":[{"kind":"word","token":"تلوت","display":"تَلَوْتُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ذوا","display":"ذَوٰا"},{"kind":"word","token":"عدل","display":"عَدْلٍ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۹۵","display":"۹۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"عدل","display":"عَدْلٍ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"word","token":"اخطات","display":"اَخْطَاَتْ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"الكتاب","display":"الْكُتَّابُ"}]}]}