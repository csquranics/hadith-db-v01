{"consensus_set_id":"6869","translation_language":"fa","translation_source":{"hid":"331554"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ عَزَّ وَ جَلَّ :   <quranic_text> « يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ » </quranic_text>   <footnote> [ المائدة ۶۷ ] </footnote>","translation_segment":"عن ابن عباس فی قوله عز و جل‌: «یٰا أیها الرسول‌ بلغ‌ مٰا أنزل‌ إلیک‌ من‌ ربک‌» الآیه؛ قال: نزلت فی علی‌، أمر رسول الله صلی الله علیه أن یبلغ‌","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الرسول","display":"الرَّسُولُ"},{"kind":"word","token":"بلغ","display":"بَلِّغْ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"انزل","display":"اُنْزِلَ"},{"kind":"word","token":"اليك","display":"اِلَيْكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۶۷","display":"۶۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"الْايَةَ ،  [ قَالَ :  ] نَزَلَتْ فِي عَلِيٍّ  ،  اُمِرَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَنْ يُبَلِّغَ فِيهِ ،  فَاَخَذَ رَسُولُ اللَّهِ بِيَدِ عَلِيٍّ فَقَالَ :  مَنْ كُنْتُ مَوْلاَهُ فَعَلِيٌّ مَوْلاَهُ - اللَّهُمَّ وَالِ مَنْ وَالاَهُ وَ عَادِ مَنْ عَادَاهُ .","translation_segment":"فیه فأخذ رسول الله بید علی‌ فقال: من کنت مولاه فعلی‌ مولاه اللهم‌ وال من والاه و عاد من عاداه. ابن عباس گفت: آیه: «یا ایها الرسول بلغ ما انزل الیک من ربک» درباره علی‌ بن ابی طالب (علیه السلام) نازل شده است، پیامبر مأموریت یافت که درباره او ابلاغ کند، پس دست او را گرفت و گفت: هر کس که من مولای اویم علی مولای اوست، خدایا هر کس را که او را دوست بدارد دوست بدار و هر کس را که او را دشمن بدارد دشمن بدار.","segment_columns":[{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يبلغ","display":"يُبَلِّغَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"امر","display":"اُمِرَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"النبي","display":"النبيّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"وسلم","display":"وسلم"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يبلغ","display":"يُبَلِّغَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"فاخذ","display":"فَاَخَذَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"وسلم","display":"وسلم"},{"kind":"word","token":"بيد","display":"بِيَدِ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","