{"consensus_set_id":"6682","translation_language":"fa","translation_source":{"hid":"100597"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « ثُمَّ لْيَقْضُوا تَفَثَهُمْ وَ لْيُوفُوا نُذُورَهُمْ » </quranic_text>   <footnote> [ الحج ۲۹ ] </footnote>  قَالَ « اَلتَّفَثُ حُفُوفُ الرَّجُلِ مِنَ الطِّيبِ فَاِذَا قَضَي نُسُكَهُ حَلَّ لَهُ الطِّيبُ » .","translation_segment":"و حمران از امام باقر علیه السلام در باره معنی قول خدای عز و جل‌: «ثم‌ لیقضوا تفثهم‌» [«و لیوفوا نذورهم‌»] سوال کردم. امام علیه السلام فرمود: تفث بعید العهد شدن مرد از عطر است، پس چون از اداء مناسک خود بپردازد، عطر بر او حلال می‌شود.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"ليقضوا","display":"لْيَقْضُوا"},{"kind":"word","token":"تفثهم","display":"تَفَثَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ليوفوا","display":"لْيُوفُوا"},{"kind":"word","token":"نذورهم","display":"نُذُورَهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"التفث","display":"اَلتَّفَثُ"},{"kind":"word","token":"حفوف","display":"حُفُوفُ"},{"kind":"word","token":"الرجل","display":"الرَّجُلِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الطيب","display":"الطِّيبِ"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"قضي","display":"قَضَي"},{"kind":"word","tok