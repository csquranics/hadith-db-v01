{"consensus_set_id":"s297468","translation_language":"fa","translation_source":{"hid":"297468"},"segments":[{"source_hadith_segment":"عَنِ النَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  ،  فِي قَوْلِهِ  <quranic_text> « يُثَبِّتُ اللّٰهُ الَّذِينَ امَنُوا بِالْقَوْلِ الثّٰابِتِ فِي الْحَيٰاةِ الدُّنْيٰا وَ فِي الْاخِرَةِ » </quranic_text>   <footnote> [ ابراهيم ۲۷ ] </footnote>","translation_segment":"براء بن عازب از پیامبر گرامی صلی الله علیه و اله درباره این آیه «خداوند مومنان را با گفتار ثابت در زندگی دنیا و آخرت پایدار می‌کند.»","segment_columns":[{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يثبت","display":"يُثَبِّتُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"بالقول","display":"بِالْقَوْلِ"},{"kind":"word","token":"الثابت","display":"الثّٰابِتِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحياه","display":"الْحَيٰاةِ"},{"kind":"word","token":"الدنيا","display":"الدُّنْيٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الاخره","display":"الْاخِرَةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۲۷","display":"۲۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ :  فِي الْقَبْرِ اِذَا سُئِلَ الْمَوْتَي .","translation_segment"