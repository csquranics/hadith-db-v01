{"consensus_set_id":"102513","translation_language":"fa","translation_source":{"hid":"118651"},"segments":[{"source_hadith_segment":"مَنْ كَانَ لَهُ مَا يُطْعِمُ فَلَيْسَ لَهُ اَنْ يَصُومَ يُطْعِمُ عَشَرَةَ مَسَاكِينَ مُدّاً مُدّاً  <quranic_text> « فَمَنْ لَمْ يَجِدْ فَصِيٰامُ ثَلاٰثَةِ اَيّٰامٍ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>   .","translation_segment":"ابو خالد قماط‍‌ از امام صادق علیه السلام شنید که می‌فرمود: هرکس که توانایی اطعام دارد، حق ندارد روزه بگیرد؛ ده فقیر را هرکدام یک مد اطعام می‌کند. پس هرکس نتوانست، سه روز، روزه بگیرد.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يطعم","display":"يُطْعِمُ"},{"kind":"word","token":"فليس","display":"فَلَيْسَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يصوم","display":"يَصُومَ"},{"kind":"word","token":"يطعم","display":"يُطْعِمُ"},{"kind":"word","token":"عشره","display":"عَشَرَةَ"},{"kind":"word","token":"مساكين","display":"مَسَاكِينَ"},{"kind":"word","token":"مدا","display":"مُدّاً"},{"kind":"word","token":"مدا","display":"مُدّاً"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يجد","display":"يَجِدْ"},{"kind":"word","token":"فصيام","display":"فَصِيٰامُ"},{"kind":"word","token":"ثلاثه","display":"ثَلاٰثَةِ"},{"kind":"word","token":"ايام","display":"اَيّٰامٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۶","display":"۱۹۶"},{"kind":"tag_close","tag_name":"footnote"}]}]}