{"consensus_set_id":"s402832","translation_language":"fa","translation_source":{"hid":"402832"},"segments":[{"source_hadith_segment":"« اِنَّ اَلْحَجَّ مُتَّصِلٌ بِالْعُمْرَةِ ،  لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « فَاِذٰا اَمِنْتُمْ فَمَنْ تَمَتَّعَ بِالْعُمْرَةِ اِلَي الْحَجِّ فَمَا اِسْتَيْسَرَ مِنَ الْهَدْيِ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote> فَلَيْسَ يَنْبَغِي لِاَحَدٍ اَنْ لاَ يَتَمَتَّعَ ،  لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ اَنْزَلَ ذَلِكَ فِي كِتَابِهِ وَ سُنَّةِ رَسُولِهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الحج","display":"اَلْحَجَّ"},{"kind":"word","token":"متصل","display":"مُتَّصِلٌ"},{"kind":"word","token":"بالعمره","display":"بِالْعُمْرَةِ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاذا","display":"فَاِذٰا"},{"kind":"word","token":"امنتم","display":"اَمِنْتُمْ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"تمتع","display":"تَمَتَّعَ"},{"kind":"word","token":"بالعمره","display":"بِالْعُمْرَةِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"استيسر","display":"اِسْتَيْسَرَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الهدي","display":"الْهَدْيِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۶","display":"۱۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فليس","di