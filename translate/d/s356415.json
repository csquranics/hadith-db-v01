{"consensus_set_id":"s356415","translation_language":"fa","translation_source":{"hid":"356415"},"segments":[{"source_hadith_segment":"وَ قَوْلُهُ تَعَالَي  <quranic_text> « اَلَّذِينَ يُنْفِقُونَ اَمْوٰالَهُمْ بِاللَّيْلِ وَ اَلنَّهٰارِ سِرًّا وَ عَلاٰنِيَةً » </quranic_text>   <footnote> [ البقرة 274 ] </footnote>  نَزَلَتْ فِي عَلِيٍّ عَلَيْهِ السَّلاَمُ كَانَتْ عِنْدَهُ اَرْبَعَةُ دَرَاهِمَ فَتَصَدَّقَ بِدِرْهَمٍ لَيْلاً وَ تَصَدَّقَ بِدِرْهَمٍ نَهَاراً وَ تَصَدَّقَ بِدِرْهَمٍ سِرّاً وَ تَصَدَّقَ بِدِرْهَمٍ عَلاَنِيَةً .","translation_segment":"در باره این آیه مبارکه: «الذین‌ ینفقون‌ أموٰالهم‌ باللیل‌ و النهٰار سرا و علاٰنیه‌» -ابن عباس می‌گوید: این آیه در حق علی (علیه السلام) نازل شده است. او چهار درهم داشت که یک درهم را در شب و یک درهم را در روز و یک درهم را پنهانی و یک درهم را آشکار صدقه داد.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"اَلَّذِينَ"},{"kind":"word","token":"ينفقون","display":"يُنْفِقُونَ"},{"kind":"word","token":"اموالهم","display":"اَمْوٰالَهُمْ"},{"kind":"word","token":"بالليل","display":"بِاللَّيْلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النهار","display":"اَلنَّهٰارِ"},{"kind":"word","token":"سرا","display":"سِرًّا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علانيه","display":"عَلاٰنِيَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"274","display":"274"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word