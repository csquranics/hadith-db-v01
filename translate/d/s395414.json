َةٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَكِنْ كَانَ لَوْحاً مِنْ ذَهَبٍ فِيهِ مَكْتُوبٌ :  عَجِبْتُ لِمَنْ اَيْقَنَ بِالْمَوْتِ كَيْفَ يَفْرَحُ ؟  عَجِبْتُ لِمَنْ اَيْقَنَ بِالْقَدَرِ كَيْفَ يَحْزَنُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  ،  عَجِبْتُ لِمَنْ اَيْقَنَ اَنْ الْبَعْثَ حَقٌّ كَيْفَ يَظْلِمُ ؟  عَجِبْتُ لِمَنْ يَرَي الدُّنْيَا وَ تَصَرُّفَ اَهْلِهَا حَالاً بَعْدَ حَالٍ كَيْفَ يَطْمَئِنُّ اِلَيْهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  وَ  <quranic_text> « كٰانَ اَبُوهُمٰا صٰالِحاً » </quranic_text>   <footnote> [ الكهف ۸۲ ] </footnote>  كَانَ بَيْنَهُمَا وَ بَيْنَ هَذَا الْاَبِ الصَّالِحِ سَبْعُونَ اَباً فَحَفِظَهُمَا اللَّهُ بِصَلاَحِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  ثُمَّ قَالَ :   <quranic_text> « فَاَرٰادَ رَبُّكَ اَنْ يَبْلُغٰا اَشُدَّهُمٰا وَ يَسْتَخْرِجٰا كَنزَهُمٰا » </quranic_text>   <footnote> [ الكهف ۸۲ ] </footnote>  فَتَبَرَّاَ مِنَ الْاَنَانِيَّةِ فِي اخِرِ الْقَصَصِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ نَسَبَ الْاِرَادَةَ كُلِّهَا اِلَي اللَّهِ تَعَالَي ذِكْرُهُ فِي ذَلِكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  لِاَنَّهُ لَمْ يَكُنْ بَقِيَ شَيْءٌ مِمَّا فَعَلَهُ فَيُخْبِرَ بِهِ بَعْدُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ يَصِيرَ مُوسَي عَلَيْهِ السَّلاَمُ بِهِ مُخْبَراً وَ مُصْغِياً اِلَي كَلاَمِهِ تَابِعاً لَهُ ،  فَتَجَرَّدَ مِنَ الْاَنَانِيَّةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ الْاِرَادَةِ تَجَرُّدَ الْعَبْدِ الْمُخْلِصِ ثُمَّ صَارَ مُتَنَصِّلاً مِمَّا اَتَاهُ مِنْ نِسْبَةِ الْاَنَانِيَّةِ فِي اَوَّلِ الْقِصَّةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ مِنِ اِدِّعَاءِ الاِشْتِرَاكِ فِي ثَانِي الْقِصَّةِ فَقَالَ :   <quranic_text> « رَحْمَةً مِنْ رَبِّكَ وَ مٰا فَعَلْتُهُ عَنْ اَمْرِي ذٰلِكَ تَاْوِيلُ » </quranic_text>   <footnote> [ الكهف ۸۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<quranic_text> « مٰا لَمْ تَسْتَطِعْ عَلَيْهِ صَبْراً » </quranic_text>   <footnote> [ الكهف ۷۸ ] </footnote>   .","translation_segment":"","segment_columns":[]}]}