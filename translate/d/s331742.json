{"consensus_set_id":"s331742","translation_language":"fa","translation_source":{"hid":"331742"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « اِنَّ فِي ذٰلِكَ لَايٰاتٍ لِلْمُتَوَسِّمِينَ » </quranic_text>   <footnote> [ الحجر ۷۵ ] </footnote>  قَالَ :  الْمُتَفَرِّسِينَ ،  وَ كَانَ اَبُو جَعْفَرٍ مِنْهُمْ .","translation_segment":"عن الحکم بن عتیبه فی قوله: (إن‌ فی ذلک لآیات للمتوسمین) قال: المتفرسین و کان أبو جعفر منهم. حکم بن عقیبه درباره سخن خداوند: «ان فی ذلک لآیات للمتوسمین» گفت: منظور هوشیارانند و ابو جعفر از آنان بود.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"لايات","display":"لَايٰاتٍ"},{"kind":"word","token":"للمتوسمين","display":"لِلْمُتَوَسِّمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"۷۵","display":"۷۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"المتفرسين","display":"الْمُتَفَرِّسِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"}]}]}