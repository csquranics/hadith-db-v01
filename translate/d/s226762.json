{"consensus_set_id":"s226762","translation_language":"fa","translation_source":{"hid":"226762"},"segments":[{"source_hadith_segment":"<quranic_text> « وَ اِتَّبَعَ مِلَّةَ اِبْرٰاهِيمَ حَنِيفاً » </quranic_text>   <footnote> [ النساء ۱۲۵ ] </footnote>  قَالَ هِيَ الْحَنِيفِيَّةُ الْعَشَرَةُ الَّتِي جَاءَ بِهَا اِبْرَاهِيمُ الَّتِي لَمْ تُنْسَخْ اِلَي يَوْمِ الْقِيَامَةِ .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتبع","display":"اِتَّبَعَ"},{"kind":"word","token":"مله","display":"مِلَّةَ"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"word","token":"حنيفا","display":"حَنِيفاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۵","display":"۱۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"الحنيفيه","display":"الْحَنِيفِيَّةُ"},{"kind":"word","token":"العشره","display":"الْعَشَرَةُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"جاء","display":"جَاءَ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تنسخ","display":"تُنْسَخْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"يوم","display":"يَوْمِ"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"}]}]}