{"consensus_set_id":"5355","translation_language":"fa","translation_source":{"hid":"402700"},"segments":[{"source_hadith_segment":"« صَوْمُ اَلسَّفَرِ وَ الْمَرَضِ ،  اِنَّ الْعَامَّةَ اِخْتَلَفَتْ فِي ذَلِكَ ؛ فَقَالَ قَوْمٌ :  يَصُومُ ،  وَ قَالَ قَوْمٌ :  لاَ يَصُومُ ،  وَ قَالَ قَوْمٌ :  اِنْ شَاءَ صَامَ ،  وَ اِنْ شَاءَ اَفْطَرَ ،  وَ اَمَّا نَحْنُ فَنَقُولُ :  يُفْطِرُ فِي الْحَالَيْنِ جَمِيعاً ؛ فَاِنْ صَامَ فِي السَّفَرِ اَوْ حَالِ الْمَرَضِ فَعَلَيْهِ قَضَاءُ ذَلِكَ ،  فَاِنَّ اللَّهَ يَقُولُ :   <quranic_text> « فَمَنْ كٰانَ مِنْكُمْ مَرِيضاً اَوْ عَليٰ سَفَرٍ فَعِدَّةٌ مِنْ اَيّٰامٍ اُخَرَ » </quranic_text>   <footnote> [ البقرة ۱۸۴ ] </footnote> ،  وَ قَوْلُهُ :   <quranic_text> « يُرِيدُ اللّٰهُ بِكُمُ الْيُسْرَ وَ لاٰ يُرِيدُ بِكُمُ الْعُسْرَ » </quranic_text>   <footnote> [ البقرة ۱۸۵ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"صوم","display":"صَوْمُ"},{"kind":"word","token":"السفر","display":"اَلسَّفَرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المرض","display":"الْمَرَضِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"العامه","display":"الْعَامَّةَ"},{"kind":"word","token":"قد","display":"قَدِ"},{"kind":"word","token":"اختلفت","display":"اِخْتَلَفَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"قوم","display":"قَوْمٌ"},{"kind":"word","token":"يصوم","display":"يَصُومُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قوم","display":"قَوْمٌ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يصوم","display":"يَصُومُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"w