{"consensus_set_id":"s403572","translation_language":"fa","translation_source":{"hid":"403572"},"segments":[{"source_hadith_segment":"« اِجْتَمَعَتِ اَلْاُمَّةُ بَرُّهَا وَ فَاجِرُهَا اَنَّ حَدِيثَ النَّجْرَانِيِّ حِينَ دَعَاهُ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اِلَي الْمُبَاهَلَةِ لَمْ يَكُنْ فِي الْكِسَاءِ اِلاَّ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) وَ عَلِيٌّ وَ فَاطِمَةُ وَ الْحَسَنُ وَ الْحُسَيْنُ ( عَلَيْهِمُ السَّلاَمُ ) ،  فَقَالَ اللَّهُ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « فَمَنْ حَاجَّكَ فِيهِ مِنْ بَعْدِ مٰا جٰاءَكَ مِنَ الْعِلْمِ فَقُلْ تَعٰالَوْا نَدْعُ اَبْنٰاءَنٰا وَ اَبْنٰاءَكُمْ وَ نِسٰاءَنٰا وَ نِسٰاءَكُمْ وَ اَنْفُسَنٰا وَ اَنْفُسَكُمْ » </quranic_text>   <footnote> [ العمران ۶۱ ] </footnote> فَكَانَ تَاْوِيلُ اَبْنَاءَنَا الْحَسَنَ وَ الْحُسَيْنَ ،  وَ نِسَاءَنَا فَاطِمَةَ ،  وَ اَنْفُسَنَا عَلِيَّ بْنَ اَبِي طَالِبٍ ( عَلَيْهِمُ السَّلاَمُ ) »","translation_segment":"","segment_columns":[{"kind":"word","token":"اجتمعت","display":"اِجْتَمَعَتِ"},{"kind":"word","token":"الامه","display":"اَلْاُمَّةُ"},{"kind":"word","token":"برها","display":"بَرُّهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فاجرها","display":"فَاجِرُهَا"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"حديث","display":"حَدِيثَ"},{"kind":"word","token":"النجراني","display":"النَّجْرَانِيِّ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"دعاه","display":"دَعَاهُ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"المباهله","display":"الْمُبَاهَلَةِ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","to