{"consensus_set_id":"s331600","translation_language":"fa","translation_source":{"hid":"331600"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « وَ لِذِي الْقُرْبيٰ » </quranic_text>   <footnote> [ الانفال ۴۱ ] </footnote>  قَالَ :  هُمْ اَقَارِبُ النَّبِيِّ الَّذِينَ لَمْ يَحِلَّ لَهُمُ الصَّدَقَةُ .","translation_segment":"عن مجاهد فی قوله تعالی: (و لذی القربی) قال: هم أقارب النبی الذین لم یحل لهم الصدقه. مجاهد درباره «و لذی القربی» گفت: آن خویشاوندان پیامبر هستند که صدقه برای آنان حلال نیست.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لذي","display":"لِذِي"},{"kind":"word","token":"القربي","display":"الْقُرْبيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۴۱","display":"۴۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"اقارب","display":"اَقَارِبُ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يحل","display":"يَحِلَّ"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"الصدقه","display":"الصَّدَقَةُ"}]}]}