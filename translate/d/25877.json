ment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ عَلِمَ اللَّهُ اَنَّ ذَلِكَ يَظْهَرُ وَ يَبِينُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ :   <quranic_text> « ذٰلِكَ مَبْلَغُهُمْ مِنَ الْعِلْمِ » </quranic_text>   <footnote> [ النجم ۳۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ اِنْكَشَفَ لِاَهْلِ الاِسْتِبْصَارِ عُوَارُهُمْ وَ اِفْتِرَاؤُهُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ الَّذِي بَدَا فِي الْكِتَابِ مِنَ الْاِزْرَاءِ عَلَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِنْ فِرْيَةِ الْمُلْحِدِينَ وَ لِذَلِكَ قَالَ :   <quranic_text> « اِنَّهُمْ لَيَقُولُونَ مُنْكَراً مِنَ الْقَوْلِ وَ زُوراً » </quranic_text>   <footnote> [ المجادلة ۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَيَذْكُرُ جَلَّ ذِكْرُهُ لِنَبِيِّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مَا يُحْدِثُهُ عَدُوُّهُ فِي كِتَابِهِ مِنْ بَعْدِهِ بِقَوْلِهِ :   <quranic_text> « وَ مٰا اَرْسَلْنٰا مِنْ قَبْلِكَ مِنْ رَسُولٍ وَ لاٰ نَبِيٍّ اِلاّٰ اِذٰا تَمَنّٰي اَلْقَي الشَّيْطٰانُ فِي اُمْنِيَّتِهِ فَيَنْسَخُ اللّٰهُ مٰا يُلْقِي الشَّيْطٰانُ ثُمَّ يُحْكِمُ اللّٰهُ ايٰاتِهِ » </quranic_text>   <footnote> [ الحج ۵۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"يَعْنِي اَنَّهُ مَا مِنْ نَبِيٍّ تَمَنَّي مُفَارَقَةَ مَا يُعَايِنُهُ مِنْ نِفَاقِ قَوْمِهِ وَ عُقُوقِهِمْ وَ الاِنْتِقَالَ اِلَي دَارِ الْاِقَامَةِ اِلاَّ اَلْقَي الشَّيْطَانُ الْمُعْرِضُ لِعَدَاوَتِهِ عِنْدَ فَقْدِهِ فِي الْكِتَابِ الَّذِي اُنْزِلَ عَلَيْهِ ذَمَّهُ وَ الْقَدْحَ فِيهِ وَ الطَّعْنَ عَلَيْهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَيَنْسَخُ اللَّهُ ذَلِكَ مِنْ قُلُوبِ الْمُؤْمِنِينَ فَلاَ تَقْبَلُهُ وَ لاَ تُصْغِي اِلَيْهِ غَيْرُ قُلُوبِ الْمُنَافِقِينَ وَ الْجَاهِلِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ يُحْكِمُ اللَّهُ ايَاتِهِ بِاَنْ يَحْمِيَ اَوْلِيَاءَهُ مِنَ الضَّلاَلِ وَ الْعُدْوَانِ وَ مُشَايَعَةِ اَهْلِ الْكُفْرِ وَ الْعُدْوَانِ وَ الطُّغْيَانِ الَّذِينَ لَمْ يَرْضَ اللَّهُ اَنْ يَجْعَلَهُمْ كَالْاَنْعَامِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  حَتَّي قَالَ :   <quranic_text> « بَلْ هُمْ اَضَلُّ سَبِيلاً » </quranic_text>   <footnote> [ الفرقان ۴۴ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَافْهَمْ هَذَا وَ اِعْمَلْ بِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِعْلَمْ اَنَّكَ مَا قَدْ تَرَكْتَ مِمَّا يَجِبُ عَلَيْكَ السُّؤَالُ عَنْهُ اَكْثَرُ مِمَّا سَاَلْتَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِنِّي قَدِ اِقْتَصَرْتُ عَلَي تَفْسِيرٍ يَسِيرٍ مِنْ كَثِيرٍ لِعَدَمِ حَمَلَةِ الْعِلْمِ وَ قِلَّةَ الرَّاغِبِينَ فِي اِلْتِمَاسِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ فِي دُونِ مَا بَيَّنْتُ لَكَ بَلاَغٌ لِذَوِي الْاَلْبَابِ .","translation_segment":"","segment_columns":[]}]}