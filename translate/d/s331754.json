{"consensus_set_id":"s331754","translation_language":"fa","translation_source":{"hid":"331754"},"segments":[{"source_hadith_segment":"لَمَّا نَزَلَتْ هَذِهِ الْايَةُ :   <quranic_text> « فَسْئَلُوا اَهْلَ الذِّكْرِ اِنْ كُنْتُمْ لاٰ تَعْلَمُونَ » </quranic_text>   <footnote> [ النحل ۴۳ ] </footnote>","translation_segment":"عن محمد بن علی قال: لما نزلت هذه الآیه: (فاسألو أهل الذکر إن کنتم لا تعلمون) قال علی ع: نحن أهل الذکر الذی عنانا","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فسئلوا","display":"فَسْئَلُوا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"الذكر","display":"الذِّكْرِ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كنتم","display":"كُنْتُمْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تعلمون","display":"تَعْلَمُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النحل","display":"النحل"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ عَلِيٌّ عَلَيْهِ السَّلاَمُ  :  نَحْنُ اَهْلُ الذِّكْرِ - الَّذِي عَنَانَا اللَّهُ جَلَّ وَ عَلاَ فِي كِتَابِهِ .","translation_segment":"الله جل‌ و علا فی کتابه. محمد بن علی گفت: چون این آیه نازل گردید: «فاسألوا اهل الذکر ان کنتم لا تعملون» علی گفت: ما همان اهل ذکر هستیم خدا در کتاب خود ما را اراده کرده است.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"الذكر","display":"الذِّكْرِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"عنانا","display":"عَنَانَا"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علا","display":"عَلاَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتابه","display":"كِتَابِهِ"}]}]}