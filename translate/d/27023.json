ِهِ ،  فَاشْتَاقَ الْعَرْشُ اِلَي رُؤْيَةِ عَلِيِّ بْنِ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ ) ،  فَخَلَقَ اللَّهُ تَعَالَي هَذَا الْمَلَكَ عَلَي صُورَةِ عَلِيِّ بْنِ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ ) تَحْتَ عَرْشِهِ ،  لِيَنْظُرَ اِلَيْهِ الْعَرْشُ ،  فَيَسْكُنَ شَوْقُهُ ،  وَ جَعَلَ تَسْبِيحَ هَذَا الْمَلَكِ وَ تَقْدِيسَهُ وَ تَحْمِيدَهُ ثَوَاباً لِشِيعَةِ اَهْلِ بَيْتِكَ ،  يَا مُحَمَّدُ » ،  الْخَبَرَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"انس","display":"اَنَسٌ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"ليله","display":"لَيْلَةُ"},{"kind":"word","token":"المعراج","display":"الْمِعْرَاجِ"},{"kind":"word","token":"نظرت","display":"نَظَرْتُ"},{"kind":"word","token":"تحت","display":"تَحْتَ"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"امامي","display":"اَمَامِي"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"بعلي","display":"بِعَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قائم","display":"قَائِمٌ"},{"kind":"word",