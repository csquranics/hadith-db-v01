{"consensus_set_id":"99224","translation_language":"fa","translation_source":{"hid":"398801"},"segments":[{"source_hadith_segment":"اِذَا رَكِبَ الرَّجُلُ اِلَي اَنْ قَالَ :  وَ قَالَ :  مَنْ قَالَ اِذَا رَكِبَ الدَّابَّةَ :  بِسْمِ اللَّهِ لاَ حَوْلَ وَ لاَ قُوَّةَ اِلاَّ بِاللَّهِ  <quranic_text> « اَلْحَمْدُ لِلّٰهِ الَّذِي هَدٰانٰا لِهٰذٰا وَ مٰا كُنّٰا لِنَهْتَدِيَ » </quranic_text>   <footnote> [ الاعراف ۴۳ ] </footnote>  الْايَةَ  <quranic_text> « سُبْحٰانَ الَّذِي سَخَّرَ لَنٰا هٰذٰا وَ مٰا كُنّٰا لَهُ مُقْرِنِينَ » </quranic_text>   <footnote> [ الزخرف ۱۳ ] </footnote>  حُفِظَتْ لَهُ دَابَّتُهُ وَ نَفْسُهُ حَتَّي يَنْزِلَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"ركب","display":"رَكِبَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"ركب","display":"رَكِبَ"},{"kind":"word","token":"الدابه","display":"الدَّابَّةَ"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"حول","display":"حَوْلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"قوه","display":"قُوَّةَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"بالله","display":"بِاللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحمد","display":"اَلْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"هدانا","display":"هَد