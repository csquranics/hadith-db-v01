{"consensus_set_id":"s228888","translation_language":"fa","translation_source":{"hid":"228888"},"segments":[{"source_hadith_segment":"قَالَ اَللَّهُ عَزَّ وَ جَلَّ لِنَبِيِّهِ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  <quranic_text> « اَ لَمْ يَجِدْكَ يَتِيماً فَاويٰ » </quranic_text>   <footnote> [ الضحي ۶ ] </footnote>  يَقُولُ اَ لَمْ يَجِدْكَ وَحِيداً فَاوَي اِلَيْكَ النَّاسَ  <quranic_text> « وَ وَجَدَكَ ضَالاًّ » </quranic_text>   <footnote> [ الضحي ۷ ] </footnote>  يَعْنِي عِنْدَ قَوْمِكَ  <quranic_text> « فَهَديٰ » </quranic_text>   <footnote> [ الضحي ۷ ] </footnote>  اَيْ هَدَاهُمُ اِلَي مَعْرِفَتِكَ  <quranic_text> « وَ وَجَدَكَ عٰائِلاً فَاَغْنيٰ » </quranic_text>   <footnote> [ الضحي ۸ ] </footnote>  يَقُولُ اَغْنَاكَ بِاَنْ جَعَلَ دُعَاءَكَ مُسْتَجَاباً .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"لنبيه","display":"لِنَبِيِّهِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يجدك","display":"يَجِدْكَ"},{"kind":"word","token":"يتيما","display":"يَتِيماً"},{"kind":"word","token":"فاوي","display":"فَاويٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الضحي","display":"الضحي"},{"kind":"word","token":"۶","display":"۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","toke