{"consensus_set_id":"117353","translation_language":"fa","translation_source":{"hid":"338513"},"segments":[{"source_hadith_segment":"عَنْ اَبِيهِ عَنْ جَدِّهِ قَالَ سَمِعْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ يَقُولُ :  عُقُوقُ الْوَالِدَيْنِ مِنَ الْكَبَائِرِ لِاَنَّ اللَّهَ تَعَالَي جَعَلَ الْعَاقَّ  <quranic_text> « عَصِيًّا » </quranic_text>   <footnote> [ مريم ۱۴ ] </footnote>   .  .  .   <quranic_text> « شَقِيًّا » </quranic_text>   <footnote> [ مريم ۴۸ ] </footnote>   .","translation_segment":"محمد بن موسی، از علی بن الحسین سعدآبادی، از احمد بن ابی عبد اللٰه، از عبد العظیم بن عبد اللٰه الحسنی، از محمد بن علی، از پدرش، از جدش نقل کرده که گفت: از حضرت ابا عبد اللٰه علیه السلام شنیدم که می‌فرمودند: عقوق والدین و نافرمانی ایشان از کبائر است زیرا حق تعالی عاق‌ را عاصی و شقی‌ قرار داده است.","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"جده","display":"جَدِّهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سمعت","display":"سَمِعْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"عقوق","display":"عُقُوقُ"},{"kind":"word","token":"الوالدين","display":"الْوَالِدَيْنِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الكبائر","display":"الْكَبَائِرِ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"جعل","display":"جَعَلَ"},{"kind":"word","token":"العاق","display":"الْعَاقَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"عصيا","display":"عَصِيًّا"