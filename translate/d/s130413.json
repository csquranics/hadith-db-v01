,"token":"وجها","display":"وجها"},{"kind":"word","token":"منها","display":"منها"},{"kind":"word","token":"صاحبها","display":"صاحبها"},{"kind":"word","token":"فيها","display":"فيها"},{"kind":"word","token":"بالخيار","display":"بالخيار"}]},{"source_hadith_segment":"ان شاء صام و ان شاء افطر","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"شاء","display":"شاء"},{"kind":"word","token":"صام","display":"صام"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"شاء","display":"شاء"},{"kind":"word","token":"افطر","display":"افطر"}]},{"source_hadith_segment":"و صوم الاذن علي ثلاثة اوجه","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"صوم","display":"صوم"},{"kind":"word","token":"الاذن","display":"الاذن"},{"kind":"word","token":"علي","display":"علي"},{"kind":"word","token":"ثلاثه","display":"ثلاثة"},{"kind":"word","token":"اوجه","display":"اوجه"}]},{"source_hadith_segment":"و صوم التاديب و صوم الاباحة و صوم السفر و المرض","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"صوم","display":"صوم"},{"kind":"word","token":"التاديب","display":"التاديب"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"صوم","display":"صوم"},{"kind":"word","token":"الاباحه","display":"الاباحة"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"صوم","display":"صوم"},{"kind":"word","token":"السفر","display":"السفر"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"المرض","display":"المرض"}]},{"source_hadith_segment":"قلت جعلت فداك فسرهن لي قال اما الواجب فصيام شهر رمضان و صيام شهرين متتابعين في كفارة الظهار لقول اللّٰه تعالي  <quranic_text> « الَّذِينَ يُظٰاهِرُونَ مِنْ نِسٰائِهِمْ ثُمَّ يَعُودُونَ لِمٰا قٰالُوا فَتَحْرِيرُ رَقَبَةٍ مِنْ قَبْلِ اَنْ يَتَمَاسّٰا » </quranic_text>   <footnote> [ المجادلة ۳ ] </footnote>  الي قوله  <quranic_text> « فَمَنْ لَمْ يَجِدْ فَصِيٰامُ شَهْرَيْنِ مُتَتٰابِعَيْنِ » </quranic_text>   <footnote> [ المجادلة ۴ ] </footnote>  و صيام شهرين متتابعين في من افطر يوما من شهر رمضان متعمدا و صيام شهرين متتابعين في قتل الخطا لمن لم يجد العتق واجب - لقول اللّٰه تعالي  <quranic_text> « وَ مَنْ قَتَلَ مُؤْمِناً خَطَاً فَتَحْرِيرُ رَقَبَةٍ مُؤْمِنَةٍ وَ دِيَةٌ مُسَلَّمَةٌ اِليٰ اَهْلِهِ » </quranic_text>   <footnote> [ النساء ۹۲ ] </footnote>  الي قوله تعالي  <quranic_text> « فَمَنْ لَمْ يَجِدْ فَصِيٰامُ شَهْرَيْنِ مُتَتٰابِعَيْنِ تَوْبَةً مِنَ اللّٰهِ وَ كٰانَ اللّٰهُ عَلِيماً حَكِيماً » </quranic_text>   <footnote> [ النساء ۹۲ ] </footnote>  - و صوم ثلاثة ايام في كفارة اليمين واجب لمن لم يجد الاطعام قال اللّٰه تعالي  <quranic_text> « فَمَنْ لَمْ يَجِدْ فَصِيٰامُ ثَلاٰثَةِ اَيّٰامٍ ذٰلِكَ كَفّٰارَةُ اَيْمٰانِكُمْ اِذٰا حَلَفْتُمْ » </quranic_text>   <footnote> [ المائدة ۸۹ ] </footnote>  كل ذلك متتابع و ليس بمتفرق و صيام اذي حلق الراس واجب قال اللّٰه تعالي  <quranic_text> « فَمَنْ كٰانَ مِنْكُمْ مَرِيضاً اَوْ بِهِ اَذيً مِنْ رَاْسِهِ فَفِدْيَةٌ مِنْ صِيٰامٍ اَوْ صَدَقَةٍ اَوْ نُسُكٍ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  - فصاحبها فيها بالخيار فان صام صام ثلاثا - و صوم دم المتعة واجب لمن لم يجد الهدي قال اللّٰه تعالي  <quranic_text> « فَمَنْ تَمَتَّعَ بِالْعُمْرَةِ اِلَي الْحَجِّ فَمَا اِسْتَيْسَرَ مِنَ الْهَدْيِ فَمَنْ لَمْ يَجِدْ فَصِيٰامُ ثَلاٰثَةِ اَيّٰامٍ فِي الْحَجِّ وَ سَبْعَةٍ اِذٰا رَجَعْتُمْ تِلْكَ عَشَرَةٌ كٰامِلَةٌ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  و صوم جزاء الصيد واجب قال اللّٰه تعالي  <quranic_text> « وَ مَنْ قَتَلَهُ مِنْكُمْ مُتَعَمِّداً فَجَزٰاءٌ مِثْلُ مٰا قَتَلَ مِنَ النَّعَمِ يَحْكُمُ بِهِ ذَوٰا عَدْلٍ مِنْكُمْ هَدْياً بٰالِغَ الْكَعْبَةِ اَوْ كَفّٰارَةٌ طَعٰامُ مَسٰاكِينَ اَوْ عَدْلُ ذٰلِكَ صِيٰاماً » </quranic_text>   <footnote> [ المائدة ۹۵ ] </footnote>  - ثم قال ا و تدري كيف يكون عدل ذلك صياما يا زهري قال قلت لا ادري قال يقوم الصيد قيمة عدل ثم تفض تلك القيمة علي البر ثم يكال ذلك البر اصواعا فيصوم لكل نصف صاع يوما و صوم النذر واجب و صوم الاعتكاف واجب و اما الصوم الحرام فصوم يوم الفطر و يوم الاضحي و ثلاثة ايام من ايام التشريق و صوم يوم الشك امرنا به و نهينا عنه امرنا به ان نصومه مع صيام شعبان و نهينا عنه ان ينفرد الرجل بصيامه في اليوم الذي يشك فيه","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قلت"},{"kind":"word","token":"جعلت","display":"جعلت"},{"kind":"word","token":"فداك","display":"فداك"},{"kind":"word","token":"فسرهن","display":"فسرهن"},{"kind":"word","token":"لي","display":"لي"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"اما","display":"اما"},{"kind":"word","token":"الواجب","display":"الواجب"},{"kind":"word","token":"فصيام","display":"فصيام"},{"kind":"word","token":"شهر","display":"شهر"},{"kind":"word","token":"رمضان","display":"رمضان"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"صيام","display":"صيام"},{"kind":"word","token":"شهرين","display":"شهرين"},{"kind":"word","token":"متتابعين","display":"متتابعين"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"كفاره","display":"كفارة"},{"kind":"word","token":"الظهار","display":"الظهار"},{"kind":"word","token":"لقول","display":"لقول"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"تعالي","display":"تعالي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يظاهرون","display":"يُظٰاهِرُونَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"نسائهم","display":"نِسٰائِهِمْ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يعودون","display":"يَعُودُونَ"},{"kind":"word","token":"لما","display":"لِمٰا"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"فتحرير","display":"فَتَحْرِيرُ"},{"kind":"word","token":"رقبه","display":"رَقَبَةٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبل","display":"قَبْلِ"},{"kin