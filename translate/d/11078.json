{"consensus_set_id":"11078","translation_language":"fa","translation_source":{"hid":"388245"},"segments":[{"source_hadith_segment":"سَمِعْتُهُ يَقُولُ :  « اِنَّ الْعَبْدَ اِذَا اُدْخِلَ حُفْرَتَهُ اَتَاهُ مَلَكَانِ اِسْمُهُمَا مُنْكَرٌ وَ نَكِيرٌ ،  فَاَوَّلُ مَا يَسْاَلاَنِهِ عَنْ رَبِّهِ ثُمَّ عَنْ نَبِيِّهِ  ،  ثُمَّ عَنْ وَلِيِّهِ ،  فَاِنْ اَجَابَ نَجَا ،  وَ اِنْ لَمْ يُجِبْ عَذَّبَاهُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"سمعته","display":"سَمِعْتُهُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"العبد","display":"الْعَبْدَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"ادخل","display":"اُدْخِلَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"حفرته","display":"حُفْرَتَهُ"},{"kind":"word","token":"اتاه","display":"اَتَاهُ"},{"kind":"word","token":"ملكان","display":"مَلَكَانِ"},{"kind":"word","token":"اسمهما","display":"اِسْمُهُمَا"},{"kind":"word","token":"منكر","display":"مُنْكَرٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نكير","display":"نَكِيرٌ"},{"kind":"word","token":"فاول","display":"فَاَوَّلُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يسالانه","display":"يَسْاَلاَنِهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"نبيه","display":"نَبِيِّهِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"وليه","display":"وَلِيِّهِ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"اجاب","display":"اَجَابَ"},{"kind":"word","token":"نجا","display":"نَجَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يجب","display":"يُجِبْ"},{"kind":"word","token":"عذباه","display":"عَذَّبَاهُ"}]},{"source_hadith_segment":"فَقَالَ لَهُ رَجُلٌ :  فَمَا حَالُ مَنْ عَرَفَ رَبَّهُ وَ نَبِيَّهُ وَ لَمْ يَعْرِفْ وَلِيَّهُ","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"حال","display":"حَالُ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عرف","display":"عَرَفَ"},{"kind":"word","token":"ربه","display":"رَبَّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نبيه","display":"نَبِيَّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يعرف","display":"يَعْرِفْ"},{"kind":"word","token":"وليه","display":"وَلِيَّهُ"}]},{"source_hadith_segment":"؟  فَقَالَ :  « مُذَبْذَبٌ  <quranic_text> « لاٰ اِليٰ هٰؤُلاٰءِ وَ لاٰ اِليٰ هٰؤُلاٰءِ وَ مَنْ يُضْلِلِ اللّٰهُ فَلَنْ تَجِدَ لَهُ سَبِيلاً » </quranic_text>   <footnote> [ النساء ۱۴۳ ] </footnote> فَذَلِكَ لاَ سَبِيلَ لَهُ .  وَ قَدْ قِيلَ لِلنَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  مَنِ الْوَلِيُّ يَا نَبِيَّ اللَّهِ ؟  فَقَالَ :  وَلِيُّكُمْ فِي هَذَا الزَّمَانِ عَلِيٌّ عَلَيْهِ السَّلاَمُ وَ مِنْ بَعْدِهِ وَصِيُّهُ ،  وَ لِكُلِّ زَمَانٍ عَالِمٌ يَحْتَجُّ اللَّهُ بِهِ لِئَلاَّ يَقُولَ كَمَا قَالَ الضُّلاَّلُ قَبْلَهُمْ حِينَ فَارَقَتْهُمْ اَنْبِيَاؤُهُمْ  <quranic_text> « رَبَّنٰا لَوْ لاٰ اَرْسَلْتَ اِلَيْنٰا رَسُولاً فَنَتَّبِعَ ايٰاتِكَ مِنْ قَبْلِ اَنْ نَذِلَّ وَ نَخْزيٰ » </quranic_text>   <footnote> [ طه ۱۳۴ ] </footnote>  بِمَا كَانَ مِنْ ضَلاَلَتِهِمْ وَ هِيَ جَهَالَتُهُمْ بِالْايَاتِ وَ هُمُ الْاَوْصِيَاءُ ،  فَاَجَابَهُمُ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « قُلْ كُلٌّ مُتَرَبِّصٌ فَتَرَبَّصُوا فَسَتَعْلَمُونَ مَنْ اَصْحٰابُ الصِّرٰاطِ السَّوِيِّ وَ مَنِ اِهْتَديٰ » </quranic_text>   <footnote> [ طه ۱۳۵ ] </footnote> وَ اِنَّمَا كَانَ تَرَبُّصُهُمْ اَنْ قَالُوا :  نَحْنُ فِي سَعَةٍ مِنْ مَعْرِفَةِ الْاَوْصِيَاءِ حَتَّي نَعْرِفَ اِمَاماً ،  فَعَيَّرَهُمُ اللَّهُ بِذَلِكَ .  فَالْاَوْصِيَاءُ هُمْ اَصْحَابُ الصِّرَاطِ وُقُوفاً عَلَيْهِ ،  لاَ يَدْخُلُ الْجَنَّةَ اِلاَّ مَنْ عَرَفَهُمْ وَ عَرَفُوهُ ،  وَ لاَ يَدْخُلُ النَّارَ اِلاَّ مَنْ اَنْكَرَهُمْ وَ اَنْكَرُوهُ ،  لِاَنَّهُمْ عُرَفَاءُ اللَّهِ عَرَّفَهُمْ عَلَيْهِمْ عِنْدَ اَخْذِهِ الْمَوَاثِيقَ عَلَيْهِمْ ،  وَ وَصَفَهُمْ فِي كِتَابِهِ فَقَالَ عَزَّ وَ جَلَّ :   <quranic_text> « وَ عَلَي الْاَعْرٰافِ رِجٰالٌ يَعْرِفُونَ كُلاًّ بِسِيمٰاهُمْ » </quranic_text>   <footnote> [ الاعراف ۴۶ ] </footnote> وَ هُمُ الشُّهَدَاءُ عَلَي اَوْلِيَائِهِمْ ،  وَ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ الشَّهِيدُ عَلَيْهِمْ ،  اَخَذَ لَهُمْ مَوَاثِيقَ الْعِبَادِ بِالطَّاعَةِ ،  وَ اَخَذَ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عَلَيْهِمُ الْمِيثَاقَ بِالطَّاعَةِ ،  فَجَرَتْ نُبُوَّتُهُ عَلَيْهِمْ ،  وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « فَكَيْفَ اِذٰا جِئْنٰا مِنْ كُلِّ اُمَّةٍ بِشَهِيدٍ وَ جِئْنٰا بِكَ عَليٰ هٰؤُلاٰءِ شَهِيداً .  يَوْمَئِذٍ يَوَدُّ الَّذِينَ كَفَرُوا وَ عَصَوُا الرَّسُولَ لَوْ تُسَوّٰي بِهِمُ الْاَرْضُ وَ لاٰ يَكْتُمُونَ اللّٰهَ حَدِيثاً » </quranic_text>   <footnote> [ النساء ۴۱ ] </footnote> .","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"مذبذب","display":"مُذَبْذَبٌ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"مذبذب","display":"مُذَبْذَبٌ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"هؤلاء","display":"هٰؤُلاٰءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"هؤلاء","display":"هٰؤُلاٰءِ"},{"kind":"word","token":"و","display":"وَ"},{"k