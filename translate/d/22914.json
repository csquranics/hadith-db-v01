{"consensus_set_id":"22914","translation_language":"fa","translation_source":{"hid":"405872"},"segments":[{"source_hadith_segment":"،  قَالَ :","translation_segment":"","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« قَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :  مَقَامِي بَيْنَ اَظْهُرِكُمْ خَيْرٌ لَكُمْ ،  فَاِنَّ اللَّهَ يَقُولُ :   <quranic_text> « وَ مٰا كٰانَ اللّٰهُ لِيُعَذِّبَهُمْ وَ اَنْتَ فِيهِمْ » </quranic_text>   <footnote> [ الانفال ۳۳ ] </footnote> وَ مُفَارَقَتِي اِيَّاكُمْ خَيْرٌ لَكُمْ .  فَقَالُوا :  يَا رَسُولَ اللَّهِ مُقَامُكَ بَيْنَ اَظْهُرِنَا خَيْرٌ لَنَا ،  فَكَيْفَ تَكُونُ مُفَارَقَتُكَ خَيْراً لَنَا ؟  قَالَ : اَمَّا اَنَّ مُفَارَقَتِي اِيَّاكُمْ خَيْرٌ لَكُمْ ،  فَاِنَّ اَعْمَالَكُمْ تُعْرَضُ عَلَيَّ كُلَّ خَمِيسٍ وَ اِثْنَيْنِ ،  فَمَا كَانَ مِنْ حَسَنَةٍ حَمِدْتُ اللَّهَ عَلَيْهَا ،  وَ مَا كَانَ مِنْ سَيِّئَةٍ اِسْتَغْفَرْتُ اللَّهَ لَكُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"مقامي","display":"مَقَامِي"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"اظهركم","display":"اَظْهُرِكُمْ"},{"kind":"word","token":"خير","display":"خَيْرٌ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و",