,"token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"رفعه","display":"رَفَعَهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"روزنه","display":"رَوْزَنَةِ"},{"kind":"word","token":"بيته","display":"بَيْتِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"السماء","display":"السَّمَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"القي","display":"اَلْقَي"},{"kind":"word","token":"شبهه","display":"شِبْهَهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"رام","display":"رَامَ"},{"kind":"word","token":"قتله","display":"قَتْلَهُ"},{"kind":"word","token":"فقتل","display":"فَقُتِلَ"},{"kind":"word","token":"بدلا","display":"بَدَلاً"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"المسيح","display":"الْمَسِيحُ"}]},{"source_hadith_segment":".  وَ قَالَ الْاِمَامُ ( عَلَيْهِ السَّلاَمُ ) :  « ثُمَّ وَجَّهَ اللَّهُ عَزَّ وَ جَلَّ الْعَذْلَ نَحْوَ الْيَهُودِ الْمَذْكُورِينَ فِي قَوْلِهِ :   <quranic_text> « ثُمَّ قَسَتْ قُلُوبُكُمْ » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>  فَقَالَ :   <quranic_text> « اَ فَكُلَّمٰا جٰاءَكُمْ رَسُولٌ بِمٰا لاٰ تَهْويٰ اَنْفُسُكُمُ » </quranic_text>   <footnote> [ البقرة ۸۷ ] </footnote>  فَاَخَذَ عُهُودَكُمْ وَ مَوَاثِيقَكُمْ بِمَا لاَ تُحِبُّونَ :  مَنْ بَذَلَ الطَّاعَةَ لاوليائه[ لِاَوْلِيَاءِ ] اللَّهِ الْاَفْضَلِينَ وَ عِبَادِهِ الْمُنْتَجَبِينَ مُحَمَّدٍ وَ الِهِ الطَّيِّبِينَ الطَّاهِرِينَ ،  لَمَّا قَالُوا لَكُمْ ،  كَمَا اَدَّاهُ اِلَيْكُمْ اَسْلاَفُكُمُ الَّذِينَ قِيلَ لَهُمْ :  اِنَّ وَلاَيَةَ مُحَمَّدٍ وَ الِ مُحَمَّدٍ هِيَ الْغَرَضُ الْاَقْصَي وَ الْمُرَادُ الْاَفْضَلُ ،  مَا خَلَقَ اللَّهُ اَحَداً مِنْ خَلْقِهِ وَ لاَ بَعَثَ اَحَداً مِنْ رُسُلِهِ اِلاَّ لِيَدْعُوَهُمْ اِلَي وَلاَيَةِ مُحَمَّدٍ وَ عَلِيٍّ وَ خُلَفَائِهِ ( عَلَيْهِمُ السَّلاَمُ ) ،  وَ يَاْخُذَ بِهَا عَلَيْهِمُ الْعَهْدَ لِيُقِيمُوا عَلَيْهِ ،  وَ لِيَعْمَلَ بِهِ سَائِرُ عَوَامِّ الْاُمَمِ ؛  فَلِهَذَا  <quranic_text> « اِسْتَكْبَرْتُمْ » </quranic_text>   <footnote> [ البقرة ۸۷ ] </footnote>  كَمَا اِسْتَكْبَرَ اَوَائِلُكُمْ حَتَّي قَتَلُوا زَكَرِيَّا وَ يَحْيَي ،  وَ اِسْتَكْبَرْتُمْ اَنْتُمْ حَتَّي رُمْتُمْ قَتْلَ مُحَمَّدٍ وَ عَلِيٍّ ( عَلَيْهِمَا السَّلاَمُ ) ،  فَخَيَّبَ اللَّهُ تَعَالَي سَعْيَكُمْ ،  وَ رَدَّ فِي نُحُورِكُمْ كَيْدَكُمْ .  وَ اَمَّا قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « تَقْتُلُونَ » </quranic_text>   <footnote> [ البقرة ۸۷ ] </footnote>  فَمَعْنَاهُ :  قَتَلْتُمْ ،  كَمَا تَقُولُ لِمَنْ تُوَبِّخُهُ :  وَيْلَكَ كَمْ تَكْذِبُ وَ كَمْ تَخْرِقُ ،  وَ لاَ تُرِيدُ مَا لَمْ يَفْعَلْهُ بَعْدُ ،  وَ اِنَّمَا تُرِيدُ :  كَمْ فَعَلْتَ وَ اَنْتَ عَلَيْهِ مُوَطِّنٌ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الامام","display":"الْاِمَامُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"وجه","display":"وَجَّهَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"العذل","display":"الْعَذْلَ"},{"kind":"word","token":"نحو","display":"نَحْوَ"},{"kind":"word","token":"اليهود","display":"الْيَهُودِ"},{"kind":"word","token":"المذكورين","display":"الْمَذْكُورِينَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"qura