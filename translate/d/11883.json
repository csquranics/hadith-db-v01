{"consensus_set_id":"11883","translation_language":"fa","translation_source":{"hid":"105056"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِهِ تَعَالَي  <quranic_text> « اِئْتُونِي بِكِتٰابٍ مِنْ قَبْلِ هٰذٰا اَوْ اَثٰارَةٍ مِنْ عِلْمٍ اِنْ كُنْتُمْ صٰادِقِينَ » </quranic_text>   <footnote> [ الاحقاف ۴ ] </footnote>  قَالَ عَنَي بِالْكِتَابِ التَّوْرَاةَ وَ الْاِنْجِيلَ وَ اَثَارَةٍ مِنْ عِلْمٍ فَاِنَّمَا عَنَي بِذَلِكَ عِلْمَ اَوْصِيَاءِ الْاَنْبِيَاءِ عَلَيْهِمُ السَّلاَمُ .","translation_segment":"ابو عبیده گوید: از امام باقر ع در باره این آیه پرسیدم: «اگر راست گوئید کتابی پیش از این قرآن یا باقیمانده علمی برای من بیاورید-۴ سوره ۷۲-» فرمود: مقصود از کتاب تورات و انجیل است و مقصود از باقیمانده علم، علم اوصیاء پیغمبرانست.","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ائتوني","display":"اِئْتُونِي"},{"kind":"word","token":"بكتاب","display":"بِكِتٰابٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبل","display":"قَبْلِ"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"اثاره","display":"اَثٰارَةٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"علم","display":"عِلْمٍ"},{"kind":"word","token":