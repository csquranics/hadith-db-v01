 يُخَالِفُونَهُمْ فِي دِينِهِمْ ،  وَ هُمُ الْمُجَابُ دُعَاؤُهُمْ ؛  فَاِنْ كُنْتُمْ - يَا مَعْشَرَ الْيَهُودِ - كَمَا تَزْعُمُونَ ،  فَتَمَنَّوُا الْمَوْتَ لِلْكَاذِبِينَ مِنْكُمْ وَ مِنْ مُخَالِفِيكُمْ  <quranic_text> « اِنْ كُنْتُمْ صٰادِقِينَ » </quranic_text>   <footnote> [ البقرة ۹۴ ] </footnote>  بِاَنَّكُمْ اَنْتُمُ الْمُحِقُّونَ الْمُجَابُ دُعَاؤُكُمْ عَلَي مُخَالِفِيكُمْ ،  فَقُولُوا :  اللَّهُمَّ اَمِتِ الْكَاذِبَ مِنَّا وَ مِنْ مُخَالِفِينَا ؛  لِيَسْتَرِيحَ مِنْهُ الصَّادِقُونَ ،  وَ لِتَزْدَادَ حُجَّتُكُمْ وُضُوحاً بَعْدَ اَنْ صَحَّتْ وَ وَجَبَتْ .  ثُمَّ قَالَ لَهُمْ رَسُولُ اللَّهِ مُحَمَّدٌ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) بَعْدَ مَا عَرَضَ هَذَا عَلَيْهِمْ :  لاَ يَقُولُهَا اَحَدٌ مِنْكُمْ اِلاَّ غَصَّ بِرِيقِهِ فَمَاتَ مَكَانَهُ ؛  وَ كَانَتِ الْيَهُودُ عُلَمَاءَ بِاَنَّهُمْ هُمُ الْكَاذِبُونَ ،  وَ اَنَّ مُحَمَّداً ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نعيمها","display":"نَعِيمُهَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"خالصه","display":"خٰالِصَةً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"دون","display":"دُونِ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۹۴","display":"۹۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الائمه","display":"الْاَئِمَّةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سائر","display":"سَائِرِ"},{"kind":"word","token":"الاصحاب","display":"الْاَصْحَابِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مؤمني","display":"مُؤْمِنِي"