{"consensus_set_id":"s331468","translation_language":"fa","translation_source":{"hid":"331468"},"segments":[{"source_hadith_segment":"عَلِيٌّ الْعَالِمُ بِالْقَضَاءِ ثُمَّ قَالَ :  قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مَنْ يُؤْتَ الْحِكْمَةَ » </quranic_text>   <footnote> [ البقرة ۲۶۹ ] </footnote>  الْايَةَ .","translation_segment":"عن الربیع بن خثیم قال: قال علی‌ العالم بالقضاء ثم قال: قال الله عز و جل: (و من یوت الحکمه) الآیه. ربیع بن خثیم گفت: علی که آگاه به قضاوت بود، چنین گفت، سپس گفت: خداوند می‌فرماید: «و من‌ یوت‌ الحکمه‌»","segment_columns":[{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"العالم","display":"الْعَالِمُ"},{"kind":"word","token":"بالقضاء","display":"بِالْقَضَاءِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يؤت","display":"يُؤْتَ"},{"kind":"word","token":"الحكمه","display":"الْحِكْمَةَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۶۹","display":"۲۶۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"}]}]}