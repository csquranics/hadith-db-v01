{"consensus_set_id":"69936","translation_language":"fa","translation_source":{"hid":"91798"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ عَزَّ وَ جَلَّ  <quranic_text> « يَحْكُمُ بِهِ ذَوٰا عَدْلٍ مِنْكُمْ » </quranic_text>   <footnote> [ المائدة ۹۵ ] </footnote>  « فَالْعَدْلُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ الْاِمَامُ مِنْ بَعْدِهِ يَحْكُمُ بِهِ وَ هُوَ ذُو عَدْلٍ فَاِذَا عَلِمْتَ مَا حَكَمَ بِهِ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ الْاِمَامُ فَحَسْبُكَ وَ لاَ تَسْاَلْ عَنْهُ » .","translation_segment":"* *۷۴ - ابو جعفر باقر (ع) گفت: خداوند عز و جل که درباره کفاره صید می‌گوید: «دو تن عادل باید فتوا بدهند». عادل اول رسول خدا صلوات الله علیه است و عادل دوم امیر المومنین پیشوای بعد از رسول است. بعد از آنکه دانستی فتوای رسول و امیر المومنین بر چه منوال است، کفایت می‌کند و (Ẓدیگر تحقیق و پژوهش لازم نیست.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ايهقران","display":"ايهقران"},{"kind":"word","token":"كريم","display":"كريم"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يحكم","display":"يَحْكُمُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"ذوا","display":"ذَوٰا"},{"kind":"word","token":"عدل","display":"عَدْلٍ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"ذو","display":"ذو"},{"kind":"word","token":"عدل","display":"عدل"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۹۵","display":"۹۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فالعدل","display":"فَالْعَدْلُ"},{"kind":"word","token":"رسول","di