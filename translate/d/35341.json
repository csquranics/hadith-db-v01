{"consensus_set_id":"35341","translation_language":"fa","translation_source":{"hid":"381043"},"segments":[{"source_hadith_segment":"وَ قَدْ رَوَي كَثِيراً مِنْ فَضَائِلِهِ اَضْرَبْتُ عَنْ ذِكْرِهَا لِلاِخْتِصَارِ اِذِ الْقَصْدُ نَفْسُ الدُّعَاءِ وَ هُوَ دُعَاءُ الْقَدَحِ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  بِسْمِ اللَّهِ وَ بِاللَّهِ وَ بِاسْمِهِ الْمُبْتَدَاِ رَبِّ الْاخِرَةِ وَ الْاُولَي لاَ غَايَةَ لَهُ وَ لاَ مُنْتَهَي رَبِّ الْاَرْضِ وَ السَّمَاوَاتِ الْعُلَي  <quranic_text> « الرَّحْمٰنُ عَلَي الْعَرْشِ اِسْتَويٰ .  لَهُ مٰا فِي السَّمٰاوٰاتِ وَ مٰا فِي الْاَرْضِ وَ مٰا بَيْنَهُمٰا وَ مٰا تَحْتَ الثَّريٰ .  وَ اِنْ تَجْهَرْ بِالْقَوْلِ فَاِنَّهُ يَعْلَمُ السِّرَّ وَ اَخْفيٰ » </quranic_text>   <footnote> [ طه ۵ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"روي","display":"رَوَي"},{"kind":"word","token":"كثيرا","display":"كَثِيراً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"فضائله","display":"فَضَائِلِهِ"},{"kind":"word","token":"اضربت","display":"اَضْرَبْتُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ذكرها","display":"ذِكْرِهَا"},{"kind":"word","token":"للاختصار","display":"لِلاِخْتِصَارِ"},{"kind":"word","token":"اذ","display":"اِذِ"},{"kind":"word","token":"القصد","display":"الْقَصْدُ"},{"kind":"word","token":"نفس","display":"نَفْسُ"},{"kind":"word","token":"الدعاء","display":"الدُّعَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"دعاء","display":"دُعَاءُ"},{"kind":"word","token":"القدح","display":"الْقَدَحِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"