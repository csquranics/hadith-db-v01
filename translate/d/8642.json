{"consensus_set_id":"8642","translation_language":"fa","translation_source":{"hid":"105386"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَوْلَ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « فَاصْبِرْ كَمٰا صَبَرَ اُولُوا الْعَزْمِ مِنَ الرُّسُلِ » </quranic_text>   <footnote> [ الاحقاف ۳۵ ] </footnote>","translation_segment":"سماعه بن مهران گوید: قول خدای عز و جل را: «چنان که پیغمبران اولو العزم صبر کردند تو هم صبر کن-۳۵ سوره ۴۶-» بامام صادق","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاصبر","display":"فَاصْبِرْ"},{"kind":"word","token":"كما","display":"كَمٰا"},{"kind":"word","token":"صبر","display":"صَبَرَ"},{"kind":"word","token":"اولوا","display":"اُولُوا"},{"kind":"word","token":"العزم","display":"الْعَزْمِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الرسل","display":"الرُّسُلِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحقاف","display":"الاحقاف"},{"kind":"word","token":"۳۵","display":"۳۵"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"فَقَالَ نُوحٌ وَ اِبْرَاهِيمُ وَ مُوسَي وَ عِيسَي وَ مُحَمَّدٌ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ","translation_segment":"ع عرضکردم. فرمود: پیغمبران اولو العزم: نوح و ابراهیم و موسی و عیسی و محمد صلی ا