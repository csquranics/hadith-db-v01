h_segment":"وَ اِنْ كَانَ عَلَي ظَهْرِهَا لاَ تَفْعَلْ فَاِيَّاكَ اَنْ تَفْعَلَهُ اَوْ تُخَالِفَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاِنَّكَ اِنْ خَالَفْتَ لَقِيتَ عَنَتاً وَ اِنْ تَمَّ لَمْ يَكُنْ لَكَ فِيهِ الْخِيَرَةُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ اِنْ خَرَجَتِ الرُّقْعَةُ الَّتِي لَمْ تَكْتُبْ عَلَي ظَهْرِهَا شَيْئاً فَتَوَقَّفْ اِلَي اَنْ تَحْضُرَ صَلاَةٌ مَفْرُوضَةٌ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ثُمَّ قُمْ فَصَلِّ رَكْعَتَيْنِ كَمَا وَصَفْتُ لَكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ثُمَّ صَلِّ الصَّلاَةَ الْمَفْرُوضَةَ اَوْ صَلِّهِمَا بَعْدَ الْفَرْضِ مَا لَمْ تَكُنِ الْفَجْرَ اَوِ الْعَصْرَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاَمَّا الْفَجْرُ فَعَلَيْكَ بَعْدَهَا بِالدُّعَاءِ اِلَي اَنْ تَنْبَسِطَ الشَّمْسُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ثُمَّ صَلِّهِمَا وَ اَمَّا الْعَصْرُ فَصَلِّهِمَا قَبْلَهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ثُمَّ اُدْعُ اللَّهَ عَزَّ وَ جَلَّ بِالْخِيَرَةِ كَمَا ذَكَرْتُ لَكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ اَعِدِ الرِّقَاعَ وَ اِعْمَلْ بِحَسَبِ مَا يَخْرُجُ لَكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كُلَّمَا خَرَجَتِ الرُّقْعَةُ الَّتِي لَيْسَ فِيهَا شَيْءٌ مَكْتُوبٌ عَلَي ظَهْرِهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَتَوَقَّفْ اِلَي صَلاَةٍ مَكْتُوبَةٍ كَمَا اَمَرْتُكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اِلَي اَنْ يَخْرُجَ لَكَ مَا تَعْمَلُ عَلَيْهِ اِنْ شَاءَ اللَّهُ .","translation_segment":"","segment_columns":[]}]}