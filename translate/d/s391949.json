{"consensus_set_id":"s391949","translation_language":"fa","translation_source":{"hid":"391949"},"segments":[{"source_hadith_segment":"ذَكَرْنَاهُ عِنْدَ قَوْلِهِ :   <quranic_text> « لُعِنَ الَّذِينَ كَفَرُوا » </quranic_text>   <footnote> [ المائدة ۷۸ ] </footnote>  الْايَةِ عَنْ اَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ وَ فِيهِ :  يَقُولُ :  « وَ اَمَّا عِيسَي فَاِنَّهُ لَعَنَ الَّذِينَ اُنْزِلَتْ عَلَيْهِمْ الْمَائِدَةُ ثُمَّ كَفَرُوا بَعْدَ ذَلِكَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"ذكرناه","display":"ذَكَرْنَاهُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لعن","display":"لُعِنَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"كفروا","display":"كَفَرُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۷۸","display":"۷۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"عيسي","display":"عِيسَي"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"لعن","display":"لَعَنَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"انزلت","display":"اُنْزِلَتْ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"المائده","display":"الْمَائِدَةُ