{"consensus_set_id":"1007","translation_language":"fa","translation_source":{"hid":"117480"},"segments":[{"source_hadith_segment":"سُئِلَ عَنْ مَوْلُودٍ لَيْسَ بِذَكَرٍ وَ لاَ اُنْثَي لَيْسَ لَهُ اِلاَّ دُبُرٌ كَيْفَ يُوَرَّثُ قَالَ يَجْلِسُ الْاِمَامُ وَ يَجْلِسُ عِنْدَهُ نَاسٌ مِنَ الْمُسْلِمِينَ فَيَدْعُو اللَّهَ عَزَّ وَ جَلَّ وَ تُجَالُ السِّهَامُ عَلَيْهِ عَلَي اَيِّ مِيرَاثٍ يُوَرِّثُهُ اَ","translation_segment":"یکی از اصحاب ما گوید: از امام صادق علیه السلام پرسیدند: نوزادی نه پسر است و نه دختر و فقط‍‌ سوراخ عقب دارد؛ چگونه ارث می‌برد؟ فرمود: امام علیه السلام می‌نشیند و عده‌ای از مسلمانان نیز نزد او می‌نشینند. آن‌گاه امام خداوند را می‌خواند و برای او قرعه انتخاب","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"مولود","display":"مَوْلُودٍ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"بذكر","display":"بِذَكَرٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"انثي","display":"اُنْثَي"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"دبر","display":"دُبُرٌ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"يورث","display":"يُوَرَّثُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يجلس","display":"يَجْلِسُ"},{"kind":"word","token":"الامام","display":"الْاِمَامُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يجلس","display":"يَجْلِسُ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"ناس","display":"نَاسٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المسلمين","display":"الْمُسْلِمِينَ"},{"kind":"word","token":"فيدعو","display":"فَيَدْعُو"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"w