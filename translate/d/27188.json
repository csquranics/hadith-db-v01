{"consensus_set_id":"27188","translation_language":"fa","translation_source":{"hid":"404223"},"segments":[{"source_hadith_segment":"« اَمَّا قَوْلُهُ :   <quranic_text> « اِنَّ اللّٰهَ لاٰ يَغْفِرُ اَنْ يُشْرَكَ بِهِ » </quranic_text>   <footnote> [ النساء۴۸ ] </footnote>  [ يَعْنِي اَنَّهُ لاَ يَغْفِرُ ] لِمَنْ يَكْفُرُ بِوَلاَيَةِ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ )  .  وَ اَمَّا قَوْلُهُ :   <quranic_text> « وَ يَغْفِرُ مٰا دُونَ ذٰلِكَ لِمَنْ يَشٰاءُ » </quranic_text>   <footnote> [ النساء۴۸ ] </footnote> يَعْنِي لِمَنْ وَالَي عَلِيّاً ( عَلَيْهِ السَّلاَمُ","translation_segment":"","segment_columns":[{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يغفر","display":"يَغْفِرُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يشرك","display":"يُشْرَكَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء۴۸","display":"النساء۴۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يغفر","display":"يَغْفِرُ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"يكفر","display":"يَكْفُرُ"},{"kind":"word","token":"بولايه","display":"بِوَلاَيَةِ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word