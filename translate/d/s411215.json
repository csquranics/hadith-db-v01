{"consensus_set_id":"s411215","translation_language":"fa","translation_source":{"hid":"411215"},"segments":[{"source_hadith_segment":"« فَكَاثَرُوهُ حَتَّي دَخَلُوا الْبَيْتَ ،  فَصَاحَ بِهِ جَبْرَئِيلُ ،  فَقَالَ :  يَا لُوطُ ،  دَعْهُمْ يَدْخُلُوا ،  فَلَمَّا دَخَلُوا اَهْوَي جَبْرَئِيلُ ( عَلَيْهِ السَّلاَمُ ) بِاِصْبَعِهِ نَحْوَهُمْ ،  فَذَهَبَتْ اَعْيُنُهُمْ ،  وَ هُوَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « فَطَمَسْنٰا اَعْيُنَهُمْ » </quranic_text>   <footnote> [ القمر ۳۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"فكاثروه","display":"فَكَاثَرُوهُ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"دخلوا","display":"دَخَلُوا"},{"kind":"word","token":"البيت","display":"الْبَيْتَ"},{"kind":"word","token":"فصاح","display":"فَصَاحَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"لوط","display":"لُوطُ"},{"kind":"word","token":"دعهم","display":"دَعْهُمْ"},{"kind":"word","token":"يدخلوا","display":"يَدْخُلُوا"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"دخلوا","display":"دَخَلُوا"},{"kind":"word","token":"اهوي","display":"اَهْوَي"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"باصبعه","display":"بِاِصْبَعِهِ"},{"kind":"word","token":"نحوهم","display":"نَحْوَهُمْ"},{"kind":"word","token":"فذهبت","display":"فَذَهَبَتْ"},{"kind":"word","token":"اعينهم","display":"اَعْيُنُهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"