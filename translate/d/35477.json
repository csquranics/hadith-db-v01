"source_hadith_segment":"اللَّهُمَّ سَهِّلْ لِي حُزُونَتَهُ وَ كُلَّ حُزُونَةٍ وَ ذَلِّلْ لِي صُعُوبَتَهُ وَ كُلَّ صُعُوبَةٍ وَ اِكْفِنِي مَئُونَتَهُ وَ كُلَّ مَئُونَةٍ وَ اُرْزُقْنِي مَعْرُوفَهُ وَ وُدَّهُ وَ اِصْرِفْ عَنِّي ضَرَّهُ وَ مَعَرَّتَهُ","translation_segment":"","segment_columns":[{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"سهل","display":"سَهِّلْ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"حزونته","display":"حُزُونَتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"حزونه","display":"حُزُونَةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلل","display":"ذَلِّلْ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"صعوبته","display":"صُعُوبَتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"صعوبه","display":"صُعُوبَةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اكفني","display":"اِكْفِنِي"},{"kind":"word","token":"مئونته","display":"مَئُونَتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"مئونه","display":"مَئُونَةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ارزقني","display":"اُرْزُقْنِي"},{"kind":"word","token":"معروفه","display":"مَعْرُوفَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وده","display":"وُدَّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اصرف","display":"اِصْرِفْ"},{"kind":"word","token":"عني","display":"عَنِّي"},{"kind":"word","token":"ضره","display":"ضَرَّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"معرته","display":"مَعَرَّتَهُ"}]},{"source_hadith_segment":"اِنَّكَ تَمْحُو مَا تَشَاءُ وَ تُثْبِتُ وَ عِنْدَكَ اُمُّ الْكِتَابِ-  <quranic_text> « اَلاٰ اِنَّ اَوْلِيٰاءَ اللّٰهِ لاٰ خَوْفٌ عَلَيْهِمْ وَ لاٰ هُمْ يَحْزَنُونَ » </quranic_text>   <footnote> [ يونس ۶۲ ] </footnote>  -  <quranic_text> « اِنّٰا رُسُلُ رَبِّكَ لَنْ يَصِلُوا اِلَيْكَ » </quranic_text>   <footnote> [ هود ۸۱ ] </footnote>   <quranic_text> « طه » </quranic_text>   <footnote> [ طه ۱ ] </footnote>   <quranic_text> « حم » </quranic_text>   <footnote> [ فصلت ۱ ] </footnote>   <quranic_text> « لاٰ يُبْصِرُونَ » </quranic_text>   <footnote> [ البقرة ۱۷ ] </footnote>  وَ  <quranic_text> « جَعَلْنٰا فِي اَعْنٰاقِهِمْ اَغْلاٰلاً فَهِيَ اِلَي الْاَذْقٰانِ فَهُمْ مُقْمَحُونَ .  وَ جَعَلْنٰا مِنْ بَيْنِ اَيْدِيهِمْ سَدًّا وَ مِنْ خَلْفِهِمْ سَدًّا فَاَغْشَيْنٰاهُمْ فَهُمْ لاٰ يُبْصِرُونَ » </quranic_text>   <footnote> [ يس ۸ ] </footnote>  -  <quranic_text> « اُولٰئِكَ الَّذِينَ طَبَعَ اللّٰهُ عَليٰ قُلُوبِهِمْ وَ سَمْعِهِمْ وَ اَبْصٰارِهِمْ وَ اُولٰئِكَ هُمُ الْغٰافِلُونَ » </quranic_text>   <footnote> [ النحل ۱۰۸ ] </footnote>  -  <quranic_text> « لاٰ جَرَمَ اَنَّ اللّٰهَ يَعْلَمُ مٰا يُسِرُّونَ وَ مٰا يُعْلِنُونَ » </quranic_text>   <footnote> [ النحل ۲۳ ] </footnote>  -  <quranic_text> « فَسَيَكْفِيكَهُمُ اللّٰهُ وَ هُوَ السَّمِيعُ الْعَلِيمُ » </quranic_text>   <footnote> [ البقرة ۱۳۷ ] </footnote>  -  <quranic_text> « وَ تَرٰاهُمْ يَنْظُرُونَ اِلَيْكَ وَ هُمْ لاٰ يُبْصِرُونَ » </quranic_text>   <footnote> [ الاعراف ۱۹۸ ] </footnote>  -  <quranic_text> « صُمٌّ بُكْمٌ عُمْيٌ فَهُمْ لاٰ يَرْجِعُونَ » </quranic_text>   <footnote> [ البقرة ۱۸ ] </footnote>  -  <quranic_text> « طسم تِلْكَ ايٰاتُ الْكِتٰابِ الْمُبِينِ .  لَعَلَّكَ بٰاخِعٌ نَفْسَكَ اَلاّٰ يَكُونُوا مُؤْمِنِينَ .  اِنْ نَشَاْ نُنَزِّلْ عَلَيْهِمْ مِنَ السَّمٰاءِ ايَةً فَظَلَّتْ اَعْنٰاقُهُمْ لَهٰا خٰاضِعِينَ » </quranic_text>   <footnote> [ الشعراء ۱ ] </footnote>  الْاَسْمَاءُ- اللَّهُمَّ اِنِّي اَسْاَلُكَ بِالْعَيْنِ الَّتِي لاَ تَنَامُ وَ بِالْعِزِّ الَّذِي لاَ يُرَامُ وَ بِالْمُلْكِ الَّذِي لاَ يُضَامُ وَ بِالنُّورِ الَّذِي لاَ يُطْفَاُ وَ بِالْوَجْهِ الَّذِي لاَ يَبْلَي وَ بِالْحَيَاةِ الَّذِي لاَ تَمُوتُ وَ بِالصَمَدِيَّةِ الَّتِي لاَ ت