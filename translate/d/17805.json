{"consensus_set_id":"17805","translation_language":"fa","translation_source":{"hid":"115016"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنْ رَجُلٍ تَزَوَّجَ اِمْرَاَةً مَمْلُوكَةً ثُمَّ طَلَّقَهَا ثُمَّ اِشْتَرَاهَا بَعْدُ هَلْ تَحِلُّ لَهُ قَالَ لاَ  <quranic_text> « حَتّٰي تَنْكِحَ زَوْجاً غَيْرَهُ » </quranic_text>   <footnote> [ البقرة ۲۳۰ ] </footnote>   .","translation_segment":"سماعه نظیر این روایت را با این تفاوت از امام علیه السلام نقل می‌کند که حضرتش در پاسخ فرمود: نه، نمی‌تواند با او نزدیکی کند تا این‌که با مرد دیگری ازدواج کند.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"تزوج","display":"تَزَوَّجَ"},{"kind":"word","token":"امراه","display":"اِمْرَاَةً"},{"kind":"word","token":"مملوكه","display":"مَمْلُوكَةً"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"طلقها","display":"طَلَّقَهَا"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اشتراها","display":"اِشْتَرَاهَا"},{"kind":"word","token":"بعد","display":"بَعْدُ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"تحل","display":"تَحِلُّ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"تنكح","display":"تَنْكِحَ"},{"kind":"word","token":"زوجا","display":"زَوْجاً"},{"kind":"word","token":"غيره","display":"غَيْرَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۳۰","display":"۲۳۰"},{"kind":"tag_close","tag_name":"footnote"