َلِيٌّ وَ فَاطِمَةُ وَ الْحَسَنُ وَ الْحُسَيْنُ عَلَيْهِمُ السَّلاَمُ حَتَّي شَبِعُوا ،  ثُمَّ رُفِعَتِ الصَّحْفَةُ ،  فَاَكَلُوا مِنْ طَعَامِ الْجَنَّةِ فِي الدُّنْيَا .","translation_segment":"","segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اقبل","display":"اَقْبَلَ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"بنت","display":"بِنْتَ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اني","display":"اَنّٰي"},{"kind":"word","token":"لك","display":"لَكِ"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۳۷","display":"۳۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قالت","display":"قَالَتْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عند","display":"عِنْدِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"يرزق","display":"يَرْزُقُ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يشاء","display":"يَشٰاءُ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"حساب","display":"حِسٰابٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۳۷","display":"۳۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فضحك","display":"فَضَحِكَ"},{"kind":"word","token":"النبي","display":"ال