{"consensus_set_id":"23288","translation_language":"fa","translation_source":{"hid":"105060"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي <quranic_text>«وَ لَقَدْ اُوحِيَ اِلَيْكَ وَ اِلَي الَّذِينَ مِنْ قَبْلِكَ لَئِنْ اَشْرَكْتَ لَيَحْبَطَنَّ عَمَلُكَ»</quranic_text> <footnote>[الزمر۶۵]</footnote> قَالَ يَعْنِي اِنْ اَشْرَكْتَ فِي الْوَلاَيَةِ غَيْرَهُ <quranic_text>«بَلِ اللّٰهَ فَاعْبُدْ وَ كُنْ مِنَ الشّٰاكِرِينَ»</quranic_text> <footnote>[الزمر۶۶]</footnote> يَعْنِي بَلِ اللَّهَ فَاعْبُدْ بِالطَّاعَةِ وَ كُنْ مِنَ الشَّاكِرِينَ اَنْ عَضَدْتُكَ بِاَخِيكَ وَ اِبْنِ عَمِّكَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"اوحي","display":"اُوحِيَ"},{"kind":"word","token":"اليك","display":"اِلَيْكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبلك","display":"قَبْلِكَ"},{"kind":"word","token":"لئن","display":"لَئِنْ"},{"kind":"word","token":"اشركت","display":"اَشْرَكْتَ"},{"kind":"word","token":"ليحبطن","display":"لَيَحْبَطَنَّ"},{"kind":"word","token":"عملك","display":"عَمَلُكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزمر۶۵","display":"الزمر۶۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"اشركت","display":"اَشْرَكْتَ"},{"kind":"word","token":"في","displ