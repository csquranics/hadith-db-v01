{"consensus_set_id":"30540","translation_language":"fa","translation_source":{"hid":"406517"},"segments":[{"source_hadith_segment":"وَ اَبِي عَبْدِ اللَّهِ ( عَلَيْهِمَا السَّلاَمُ )  :  عَنْ قَوْلِهِ :   <quranic_text> « رَبَّنٰا لاٰ تَجْعَلْنٰا فِتْنَةً لِلْقَوْمِ الظّٰالِمِينَ » </quranic_text>   <footnote> [ يونس ۸۵ ] </footnote>   ،  قَالَ :  « لاَ تُسَلِّطْهُمْ عَلَيْنَا فَتَفْتِنَهُمْ بِنَا » .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ربنا","display":"رَبَّنٰا"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تجعلنا","display":"تَجْعَلْنٰا"},{"kind":"word","token":"فتنه","display":"فِتْنَةً"},{"kind":"word","token":"للقوم","display":"لِلْقَوْمِ"},{"kind":"word","token":"الظالمين","display":"الظّٰالِمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يونس","display":"يونس"},{"kind":"word","token":"۸۵","display":"۸۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تسلطهم","display":"تُسَلِّطْهُمْ"},{"kind":"word","token":"علينا","display":"عَلَيْنَا"},{"kind":"word","token":"فتفتنهم","display":"فَتَفْتِنَهُمْ"},{"kind":"word","token":"بنا","display":"بِنَا"}]}]}