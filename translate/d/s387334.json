oken":"بالتزويج","display":"بِالتَّزْوِيجِ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"رسول","display":"رَسُولُ"}]},{"source_hadith_segment":"اللَّهِ اَعْلَمُ ،  وَ ظَنَنْتُ اَنَّهُ يُرِيدُ اَنْ يُزَوِّجَنِي بَعْضَ نِسَاءِ قُرَيْشٍ ،  وَ اِنِّي خَائِفٌ عَلَي فَوْتِ","translation_segment":"","segment_columns":[{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"اعلم","display":"اَعْلَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ظننت","display":"ظَنَنْتُ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"يريد","display":"يُرِيدُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يزوجني","display":"يُزَوِّجَنِي"},{"kind":"word","token":"بعض","display":"بَعْضَ"},{"kind":"word","token":"نساء","display":"نِسَاءِ"},{"kind":"word","token":"قريش","display":"قُرَيْشٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"خائف","display":"خَائِفٌ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"فوت","display":"فَوْتِ"}]},{"source_hadith_segment":"فَاطِمَةَ عَلَيْهَا السَّلاَمُ","translation_segment":"","segment_columns":[{"kind":"word","token":"فاطمه","display":"فَاطِمَةَ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]},{"source_hadith_segment":"،  فَمَا شَعَرْتُ بِشَيْءٍ حَتَّي دَعَانِي رَسُولُ اللَّهِ صَلَّي اللَّهُ","translation_segment":"","segment_columns":[{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"شعرت","display":"شَعَرْتُ"},{"kind":"word","token":"بشيء","display":"بِشَيْءٍ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"دعاني","display":"دَعَانِي"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"}]},{"source_hadith_segment":"عَلَيْهِ وَ الِهِ وَ سَلَّمَ فَاَتَيْتُهُ فِي بَيْتِ اُمِّ سَلَمَةَ ،  فَلَمَّا نَظَرَ اِلَيَّ تَهَلَّلَ وَجْهُهُ وَ تَبَسَّمَ حَتَّي نَظَرْتُ اِلَي بَيَاضِ اَسْنَانِهِ يَبْرُقُ .  فَقَالَ لِي :  يَا عَلِيُّ  !  اَبْشِرْ فَقَدْ كَفَانِيَ اللَّهُ - سُبْحَانَهُ - مَا كَانَ هَمَّنِي مِنْ اَمْرِ تَزْوِيجِكَ .  قُلْتُ :  وَ كَيْفَ [ ذَاكَ ] يَا رَسُولَ اللَّهِ  ؟  !  فَقَالَ :  اَتَانِي جَبْرَئِيلُ عَلَيْهِ السَّلاَمُ وَ مَعَهُ مِنْ سُنْبُلِ الْجَنَّةِ وَ قَرَنْفُلِهَا فَنَاوَلَنِيهِمَا ،  فَاَخَذْتُهُمَا وَ شَمِمْتُهُمَا وَ قُلْتُ :  يَا جَبْرَئِيلُ !  مَا سَبَبُ هَذَا الْقَرَنْفُلُ وَ السُّنْبُلُ ؟  فَقَالَ :  اِنَّ اللَّهَ - تَعَالَي - اَمَرَ سُكَّانَ الْجِنَانِ مِنَ الْمَلاَئِكَةِ وَ غَيْرِهِمْ مِمَّنْ فِيهَا اَنْ يُزَيِّنُوا الْجِنَانَ كُلَّهَا بِمَغَارِسِهَا وَ اَنْهَارِهَا وَ ثِمَارِهَا وَ اَشْجَارِهَا وَ قُصُورِهَا ،  وَ اَمَرَ رِيحاً فَهَبَّتْ بِاَنْوَاعِ الْعِطْرِ وَ الطِّيبِ ،  وَ اَمَرَ الْحُورَ الْعِينَ بِالْقِرَاءَةِ فِيهَا بِسُورَةِ طه وَ طس وَ حم عسق .  ثُمَّ اَمَرَ [ اَللَّهُ - عَزَّ وَ جَلَّ- ] مَلَكاً فَنَادَي :  [ اَلاَ ] يَا مَلاَئِكَتِي وَ سُكَّانَ جَنَّتِي !  اِشْهَدُوا اَنِّي قَدْ زَوَّجْتُ فَاطِمَةَ بِنْتَ مُحَمَّدٍ عَلَيْهَا السَّلاَمُ مِنْ عَلِيِّ بْنِ اَبِي طَالِبٍ رِضًي مِنِّي لِبَعْضِهِمَا بِبَعْضٍ .  ثُمَّ اَمَرَ [ اَللَّهُ - تَبَارَكَ وَ تَعَالَي- ] مَلَكاً فِي الْجَنَّةِ يُقَالُ لَهُ « رَاحِيلُ » ،  وَ لَيْسَ فِي الْمَلاَئِكَةِ اَبْلَغُ مِنْهُ ،  فَخَطَبَ بِخُطْبَةٍ لَمْ يَخْطُبْ بِمِثْلِهَا اَهْلُ السَّمَاءِ وَ لاَ اَهْلُ الْاَرْضِ .  ثُمَّ اَمَرَ مُنَادِياً فَنَادَي :  يَا مَلاَئِكَتِي وَ سُكَّانَ جَنَّتِي !  بَارِكُوا عَلَي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ حَبِيبِ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ وَ فَاطِمَةَ بِنْتِ مُحَمَّدٍ عَلَيْهَا السَّلاَمُ فَاِنِّي قَدْ بَارَكْتُ عَلَيْهِمَا .  فَقَالَ رَاحِيلُ :  [ يَا رَبِّ ] وَ مَا بَرَكَاتُكَ عَلَيْهِمَا - يَا رَبِّ - بِاَكْثَرَ مَا رَاَيْنَا لَهُمَا فِي جَنَّاتِكَ وَ دَارِ كَرَامَتِكَ ؟  فَقَالَ [ اَللَّهُ ] - تَعَالَي- :  يَا رَاحِيلُ !  اِنَّ مِنْ بَرَكَتِي عَلَيْهِمَا اَنْ اَجْمَعَهُمَا عَلَي مَحَبَّتِي وَ اَجْعَلَهُمَا حُجَّتِي عَلَي خَلْقِي ؛  وَ عِزَّتِي وَ جَلاَلِي ،  لَاَخْلُقَنَّ مِنْهُمَا خَلْقاً ،  وَ لَاُنْشِاَنَّ مِنْهُمَا ذُرِّيَّةً ،  اَجْعَلُهُمْ خُزَّانِي فِي اَرْضِي ،  وَ مَعَادِنَ حِكْمَتِي ،  بِهِمْ اَحْتَجُّ عَلَي خَلْقِي بَعْدَ النَّبِيِّينَ وَ الْمُرْسَلِينَ .  فَاَبْشِرْ يَا عَلِيُّ  !  فَقَدْ زَوَّجْتُكَ [ اِبْنَتِي ] فَاطِمَةَ عَلَي مَا زَوَّجَكَ الرَّحْمَنُ ،  وَ قَدْ رَضِيتُ لَكُمَا بِمَا رَضِيَ اللَّهُ بِهِ لَكُمَا ،  فَدُونَكَ اَهْلَكَ فَاَنْتَ اَحَقُّ بِهَا مِنِّي ،  وَ لَقَدْ اَخْبَرَنِي جَبْرَئِيلُ اَنَّ الْجَنَّةَ وَ اَهْلَهَا مُشْتَاقُونَ اِلَيْكُمَا ،  وَ لَوْ لاَ اَنَّ اللَّهَ - تَعَالَي - اَرَادَ اَنْ يَتَّخِذَ مِنْكُمَا مَا يَتَّخِذُ بِهِ عَلَي الْخَلْقِ حُجَّةً لَاَجَابَ فِيكُمَا الْجَنَّةَ وَ اَهْلَهَا ،  فَنِعْمَ الْاَخُ اَنْتَ ،  وَ نِعْمَ الْخَتَنُ اَنْتَ ،  وَ نِعْمَ الصَّاحِبُ اَنْتَ ،  وَ كَفَاكَ بِرِضَي اللَّهِ - عَزَّ وَ جَلَّ - رِضًي .  [ فَ‍ ] قَالَ عَلِيٌّ عَلَيْهِ السَّلاَمُ  :  فَقُلْتُ :   <quranic_text> « رَبِّ اَوْزِعْنِي اَنْ اَشْكُرَ نِعْمَتَكَ الَّتِي اَنْعَمْتَ » </quranic_text>   <footnote> [ النمل ۱۹ ] </footnote>  بِهَا  <quranic_text> « عَلَيَّ » </quranic_text>   <footnote> [ النمل ۱۹ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلم","display":"سَلَّمَ"},{"kind":"word","token":"فاتيته","display":"فَاَتَيْتُهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"بيت","display":"بَيْتِ"},{"kind":"word","token":"ام","display":"اُمِّ"},{"kind":"word","token":"سلمه","display":"سَلَمَةَ"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"نظر","display":"نَظَرَ"},{"kind":"word","token":"الي","display":"اِلَيَّ"},{"kind":"word","token":"تهلل","display":"تَهَلَّل