{"consensus_set_id":"s331558","translation_language":"fa","translation_source":{"hid":"331558"},"segments":[{"source_hadith_segment":"[ وَ سَاقَ ] حَدِيثَ الْمِعْرَاجِ اِلَي اَنْ قَالَ :  وَ اِنِّي لَمْ اَبْعَثْ نَبِيّاً اِلاَّ جَعَلْتُ لَهُ وَزِيراً ،  وَ اِنَّكَ رَسُولُ اللَّهِ وَ اِنَّ عَلِيّاً وَزِيرُكَ","translation_segment":"عن عبد الله بن عباس عن النبی صلی الله علیه و آله و سلم و ساق حدیث المعراج إلی أن قال: و إنی لم أبعث نبیا إلا جعلت له وزیرا، و إنک رسول الله و إن‌ علیا وزیرک. قال ابن عباس: فهبط‍‌ رسول الله فکره أن یحدث الناس بشیء منها إذ","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ساق","display":"سَاقَ"},{"kind":"word","token":"حديث","display":"حَدِيثَ"},{"kind":"word","token":"المعراج","display":"الْمِعْرَاجِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"ابعث","display":"اَبْعَثْ"},{"kind":"word","token":"نبيا","display":"نَبِيّاً"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"جعلت","display":"جَعَلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"وزيرا","display":"وَزِيراً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انك","display":"اِنَّكَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"عليا","display":"عَلِيّاً"},{"kind":"word","token":"وزيرك","display":"وَزِيرُكَ"}]},{"source_hadith_segment":".  قَالَ اِبْنُ عَبَّاسٍ :  فَهَبَطَ رَسُولُ اللَّهِ فَكَرِهَ اَنْ يُحَدِّثَ النَّاسَ بِشَيْءٍ مِنْهَا - اِذْ كَانُوا حَدِيثِي عَهْدٍ بِالْجَاهِلِيَّةِ حَتَّي مَضَي [ مِنْ ] ذَلِكَ سِتَّةُ اَيَّامٍ ،  فَاَنْزَلَ اللَّهُ تَعَالَي :   <quranic_text> « فَلَعَلَّكَ تٰارِكٌ بَعْضَ مٰا يُوحيٰ اِلَيْكَ » </quranic_text>   <footnote> [ هود ۱۲ ] </footnote>  فَاحْتَمَلَ رَسُولُ اللَّهِ [ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ] حَتَّي كَانَ يَوْمُ الثَّامِنَ عَشَرَ ،  اَنْزَلَ اللَّهُ عَلَيْهِ  <quranic_text> « يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ » </quranic_text>   <footnote> [ المائدة ۶۷ ] </footnote>","translation_segment":"کانوا حدیثی عهد بالجاهلیه حتی مضی من ذلک سته أیام، فأنزل الله تعالی: (فلعلک تارک بعض ما یوحی إلیک) فاحتمل رسول الله صلی الله علیه و آله و سلم حتی کان یوم الثامن عشر، أنزل الله علیه (یا أیها الرسول بلغ ما أنزل إلیک من ربک) ثم‌ إن‌ رسول الله صلی الله علیه و آله و سلم أمر بلالا حتی یوذن فی الناس أن لا یبقی غدا أحدا إلا خرج إلی غدیر خم‌، فخرج رسول الله صلی الله علیه و آله و سلم و الناس من الغد؛ فقال: یا أیها الناس إن‌ الله أرسلنی إلیکم برساله و إنی ضقت بها ذرعا مخافه أن تتهمونی و تکذبونی حتی عاتبنی ربی فیها بوعید أنزله علی‌ بعد وعید، ثم‌ أخذ بید علی‌ بن ابی طالب فرفعها حتی رأی الناس بیاض إبطیهما ثم‌ قال: أیها الناس الله مولای و أنا مولاکم فمن کنت مولاه فعلی‌ مولاه اللهم وال من والاه و عاد من عاداه و انصر من نصره و اخذل من خذله. و أنزل الله: (الیوم أکملت لکم دینکم).","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"عباس","display":"عَبَّاسٍ"},{"kind":"word","token":"فهبط","display":"فَهَبَطَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فكره","display":"فَكَرِهَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يحدث","display":"يُحَدِّثَ"},{"kind":"word","token":"الناس","display":"النَّاسَ"},{"kind":"word","token":"بشيء","display":"بِشَيْءٍ"},{"kind":"word","token":"منها","display":"مِنْهَا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"حديثي