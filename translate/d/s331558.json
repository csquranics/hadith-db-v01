:"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الرسول","display":"الرَّسُولُ"},{"kind":"word","token":"بلغ","display":"بَلِّغْ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"انزل","display":"اُنْزِلَ"},{"kind":"word","token":"اليك","display":"اِلَيْكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۶۷","display":"۶۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"ثُمَّ اِنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَمَرَ بِلاَلاً حَتَّي يُؤَذِّنَ فِي النَّاسِ - اَنْ لاَ يَبْقَي غَداً اَحَدٌ اِلاَّ خَرَجَ اِلَي غَدِيرِ خُمٍّ ،  فَخَرَجَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ النَّاسُ مِنَ الْغَدِ ،  فَقَالَ :  يَا اَيُّهَا النَّاسُ اِنَّ اللَّهَ اَرْسَلَنِي اِلَيْكُمْ بِرِسَالَةٍ - وَ اِنِّي ضِقْتُ بِهَا ذَرْعاً مَخَافَةَ اَنْ تَتَّهِمُونِي وَ تُكَذِّبُونِي - حَتَّي عَاتَبَنِي رَبِّي فِيهَا بِوَعِيدٍ اَنْزَلَهُ عَلَيَّ بَعْدَ وَعِيدٍ ،  ثُمَّ اَخَذَ بِيَدِ عَلِيِّ بْنِ اَبِي طَالِبٍ فَرَفَعَهَا حَتَّي رَاَي النَّاسُ بَيَاضَ اِبْطَيْهِمَا [ اِبْطِهِمَا ] ثُمَّ قَالَ :  اَيُّهَا النَّاسُ اللَّهُ مَوْلاَيَ وَ اَنَا مَوْلاَكُمْ - فَمَنْ كُنْتُ مَوْلاَهُ فَعَلِيٌّ مَوْلاَهُ - اللَّهُمَّ وَالِ مَنْ وَالاَهُ وَ عَادِ مَنْ عَادَاهُ - وَ اُنْصُرْ مَنْ نَصَرَهُ وَ اُخْذُلْ مَنْ خَذَلَهُ","translation_segment":"عبد الله بن عباس حدیث معراج را از پیامبر نقل می‌کند تا آنجا که خداوند فرمود: من پیامبری را مبعوث نکردم مگر اینکه برای او وزیری قرار دادم و تو رسول خدا هستی و علی وزیر توست. ابن عباس گفت: پیامبر خدا فرود آمد و دوست نداشت از این موضوع به مردم سخن بگوید، چون آنان به عصر جاهلیت نزدیک بودند تا اینکه شش روز گذشت و خداوند این آیه را نازل کرد: «فلعلک تارک بعض ما یوحی الیک شاید تو ترک کننده قسمتی از آنچه بر تو وحی شده است باشی» پس پیامبر خدا تحمل کرد تا اینکه روز هیجدهم شد و این آیه نازل گردید: «یا ایها الرسول بلغ ما انزل الیک من ربک» آنگاه پیامبر خدا به بلال دستور داد که در میان مردم اعلام کند که فردا کسی نماند مگر اینکه به غدیر خم برود، پیامبر خدا و مردم فردا (به آنجا) رفتند، پیامبر گفت: ای مردم خداوند مرا با پیامی به سوی شما فرستاده است و من در آن درنگ می‌کردم از بیم آنکه مرا متهم و تکذیب کنید تا اینکه پروردگارم با وعیدی پس از وعیدی مرا درباره آن مورد عتاب قرار داد، آنگاه دست علی‌ بن ابی طالب (علیه السلام) را گرفت و او را بلند کرد تا جایی که مردم سفیدی بغل آنها را دیدند سپس گفت: ای مردم! خدا مولای من است و من مولای شمایم، پس هر کس که من مولای اویم علی مولای اوست، خداوندا هر کس را که او","segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"امر","display":"اَمَرَ"},{"kind":"word","token":"بلالا","display":"بِلاَلاً"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"يؤذن","display":"يُؤَذِّنَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يبقي","display":"يَبْقَي"},{"kind":"word","token":"غدا","display":"غَداً"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"خرج","display":"خَرَجَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"غدير","display":"غَدِيرِ"},{"kind":"word","token":"خم","display":"خُمٍّ"},{"kind":"word","tok