on_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَحَمِدَ اَبُو بَكْرٍ اللَّهَ وَ اَثْنَي عَلَيْهِ وَ قَالَ :  اِنَّ اللَّهَ اِبْتَعَثَ لَكُمْ مُحَمَّداً صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ نَبِيّاً ،  وَ لِلْمُؤْمِنِينَ وَلِيّاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَمَنَّ اللَّهُ عَلَيْهِمْ بِكَوْنِهِ بَيْنَ ظَهْرَانَيْهِمْ ،  حَتَّي اِخْتَارَ لَهُ مَا عِنْدَهُ ،  فَخَلَّي عَلَي النَّاسِ اُمُورَهُمْ لِيَخْتَارُوا لِاَنْفُسِهِمْ مُتَّفِقِينَ غَيْرَ مُخْتَلِفِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاخْتَارُونِي عَلَيْهِمْ وَالِياً ،  وَ لِاُمُورِهِمْ رَاعِياً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَتَوَلَّيْتُ ذَلِكَ ،  وَ مَا اَخَافُ بِعَوْنِ اللَّهِ وَ تَسْدِيدِهِ وَهْناً وَ لاَ حَيْرَةً وَ لاَ جُبْناً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،   <quranic_text> « وَ مٰا تَوْفِيقِي اِلاّٰ بِاللّٰهِ عَلَيْهِ تَوَكَّلْتُ وَ اِلَيْهِ اُنِيبُ » </quranic_text>   <footnote> [ هود ۸۸ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ مَا اَنْفَكُّ يَبْلُغُنِي عَنْ طَاعِنٍ يَقُولُ بِخِلاَفِ قَوْلِ عَامَّةِ الْمُسْلِمِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  يَتَّخِذُ لَكُمْ لَجَاً فَتَكُونُوا حِصْنَهُ الْمَنِيعَ ،  وَ خَطْبَهُ الْبَدِيعَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِمَّا دَخَلْتُمْ فِيمَا دَخَلَ فِيهِ النَّاسُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اَوْ صَرَفْتُمُوهُمْ عَمَّا مَالُوا اِلَيْهِ ،  فَقَدْ جِئْنَاكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ نَحْنُ نُرِيدُ اَنْ نَجْعَلَ لَكَ فِي هَذَا الْاَمْرِ نَصِيباً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لِمَنْ بَعْدَكَ مِنْ عَقِبِكَ اِذْ كُنْتَ عَمَّ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِنْ كَانَ الْمُسْلِمُونَ قَدْ رَاَوْا مَكَانَكَ مِنْ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ،  وَ مَكَانَ اَهْلِكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  ثُمَّ عَدَلُوا بِهَذَا الْاَمْرِ عَنْكُمْ وَ عَلَي رِسْلِكُمْ بَنِي هَاشِمٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِنَّا وَ مِنْكُمْ .  فَاعْتَرَضَ كَلاَمَهُ عُمَرُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ خَرَجَ اِلَي مَذْهَبِهِ فِي الْخُشُونَةِ وَ الْوَعِيدِ وَ اِتْيَانِ الْاَمْرِ مِنْ اَصْعَبِ جِهَاتِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ :  اِيْ وَ اللَّهِ ،  وَ اُخْرَي اَنَّا لَمْ نَاْتِكُمْ حَاجَةً اِلَيْكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَكِنْ كَرِهْنَا اَنْ يَكُونَ الطَّعْنُ فِيمَا اِجْتَمَعَ عَلَيْهِ الْمُسْلِمُونَ مِنْكُمْ فَيَتَفَاقَمُ الْخَطْبُ بِكُمْ وَ بِهِمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَانْظُرُوا لِاَنْفُسِكُمْ وَ عَامَّتِهِمْ ،  ثُمَّ سَكَتَ .  فَتَكَلَّمَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"الْعَبَّاسُ ،  فَحَمِدَ اللَّهَ وَ اَثْنَي عَلَيْهِ ثُمَّ قَالَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":":  اِنَّ اللَّهَ اِبْتَعَثَ مُحَمَّداً نَبِيّاً ،  كَمَا وَصَفْتَ ،  وَ وَلِيّاً لِلْمُؤْمِنِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَمَنَّ اللَّهُ بِهِ عَلَي اُمَّتِهِ حَتَّي اِخْتَارَ لَهُ مَا عِنْدَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَخَلَّي النَّاسَ عَلَي اَمْرِهِمْ لِيَخْتَارُوا لِاَنْفُسِهِمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  مُصِيبِينَ لِلْحَقِّ مَائِلِينَ عَنْ زَيْغِ الْهَوَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنْ كُنْتَ بِرَسُولِ اللَّهِ طَلَبْتَ فَحَقَّنَا اَخَذْتَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِنْ كُنْتَ بِالْمُؤْمِنِينَ فَنَحْنُ مِنْهُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ مَا تَقَدَّمْنَا فِي اَمْرِكُمْ فَرَطاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لاَ حَلَلْنَا وَسَطاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لاَ نَزَحْنَا شَحْطاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنْ كَانَ هَذَا الْاَمْرُ يَجِبُ لَكَ بِالْمُؤْمِنِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَمَا وَجَبَ اِذْ كُنَّا كَارِهِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ مَا اَبْعَدَ قَوْلَكَ اِنَّهُمْ طَعَنُوا مِنْ قَوْلِكَ اِنَّهُمْ مَالُوا اِلَيْكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اَمَّا مَا بَذَلْتَ لَنَا فَاِنْ يَكُنْ حَقُّكَ اَعْطَيْتَنَاهُ فَاَمْسِكْهُ عَلَيْكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِنْ يَكُنْ حَقُّ الْمُؤْمِنِينَ فَلَيْسَ لَكَ اَنْ تَحْكُمَ فِيهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِنْ يَكُنْ حَقَّنَا لَمْ نَرْضَ لَكَ بِبَعْضِهِ دُونَ بَعْضٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ مَا اَقُولُ هَذَا اَرُومُ صَرْفَكَ عَمَّا دَخَلْتَ فِيهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَكِنْ لِلْحُجَّةِ نَصِيبُهَا مِنَ الْبَيَانِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اَمَّا قَوْلُكَ ،  اِنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِنَّا وَ مِنْكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِنْ شَجَرَةٍ نَحْنُ اَغْصَانُهَا وَ اَنْتُمْ جِيرَانُهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ اَمَّا قَوْلُكَ يَا عُمَرُ ،  اِنَّكَ تَخَافُ النَّاسَ عَلَيْنَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَهَذَا الَّذِي قَدَّمْتُمُوهُ اَوَّلَ ذَلِكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ بِاللَّهِ الْمُسْتَعَانُ .","translation_segment":"","segment_columns":[]}]}