{"consensus_set_id":"3417","translation_language":"fa","translation_source":{"hid":"104824"},"segments":[{"source_hadith_segment":"لَمَّا قُتِلَ الْحُسَيْنُ عَلَيْهِ السَّلاَمُ اَرْسَلَ مُحَمَّدُ بْنُ الْحَنَفِيَّةِ اِلَي عَلِيِّ بْنِ الْحُسَيْنِ","translation_segment":"امام باقر ع فرمود: چون امام حسین ع کشته شد، محمد بن حنفیه، شخصی را نزد علی ابن","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"زراره","display":"زُرَارَةُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"۴","display":"۴"},{"kind":"word","token":"۵-","display":"۵-"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"قتل","display":"قُتِلَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ارسل","display":"اَرْسَلَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"الحنفيه","display":"الْحَنَفِيَّةِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"}]},{"source_hadith_segment":"عَلَيْهِمَا السَّلاَمُ فَخَلاَ بِهِ فَقَالَ لَهُ يَا اِبْنَ اَخِي قَدْ عَلِمْتَ اَنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ دَفَعَ الْوَصِيَّةَ وَ الْاِمَامَةَ مِنْ بَعْدِهِ اِلَي اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ ثُمَّ اِلَي الْحَسَنِ عَلَيْهِ السَّلاَمُ ثُمَّ اِلَي الْحُسَيْنِ عَلَيْهِ السَّلاَمُ وَ قَدْ قُتِلَ اَبُوكَ رَضِيَ اللَّهُ عَنْهُ وَ صَلَّي عَلَي رُوحِهِ وَ لَمْ يُوصِ وَ اَنَا عَمُّكَ وَ صِنْوُ اَبِيكَ وَ وِلاَدَتِي مِنْ عَلِيٍّ عَلَيْهِ السَّلاَمُ فِي سِنِّي وَ قَدِيمِي اَحَقُّ بِهَا مِنْكَ فِي حَدَاثَتِكَ فَلاَ تُنَازِعْنِي فِي الْوَصِيَّةِ وَ الْاِمَامَةِ وَ لاَ تُحَاجَّنِي فَقَالَ لَهُ عَلِيُّ بْنُ الْحُسَيْنِ عَلَيْهِمَا السَّلاَمُ يَا عَمِّ اِتَّقِ اللَّهَ وَ لاَ تَدَّعِ مَا لَيْسَ لَكَ بِحَقٍّ  <quranic_text> « اِنِّي اَعِظُكَ اَنْ تَكُونَ مِنَ الْجٰاهِلِينَ » </quranic_text>   <footnote> [ هود ۴۶ ] </footnote>  اِنَّ اَبِي يَا عَمِّ صَلَوَاتُ اللَّهِ عَلَيْهِ اَوْصَي اِلَيَّ قَبْلَ اَنْ يَتَوَجَّهَ اِلَي الْعِرَاقِ وَ عَهِدَ اِلَيَّ فِي ذَلِكَ قَبْلَ اَنْ يُسْتَشْهَدَ بِسَاعَةٍ وَ هَذَا سِلاَحُ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عِنْدِي فَلاَ تَتَعَرَّضْ لِهَذَا فَاِنِّي اَخَافُ عَلَيْكَ نَقْصَ الْعُمُرِ وَ تَشَتُّتَ الْحَالِ اِنَّ اللَّهَ عَزَّ وَ جَلَّ جَعَلَ الْوَصِيَّةَ وَ الْاِمَامَةَ فِي عَقِبِ الْحُسَيْنِ عَلَيْهِ السَّلاَمُ فَاِذَا اَرَدْتَ اَنْ تَعْلَمَ ذَلِكَ فَانْطَلِقْ بِنَا اِلَي الْحَجَرِ الْاَسْوَدِ حَتَّي نَتَحَاكَمَ اِلَيْهِ وَ نَسْاَلَهُ عَنْ ذَلِكَ قَالَ اَبُو جَعْفَرٍ عَلَيْهِ السَّلاَمُ وَ كَانَ الْكَلاَمُ بَيْنَهُمَا بِمَكَّةَ فَانْطَلَقَا حَتَّي اَتَيَا الْحَجَرَ الْاَسْوَدَ فَقَالَ عَلِيُّ بْنُ الْحُسَيْنِ لِمُحَمَّدِ بْنِ الْحَنَفِيَّةِ اِبْدَاْ اَنْتَ فَابْتَهِلْ اِلَي اللَّهِ عَزَّ وَ جَلَّ وَ سَلْهُ اَنْ يُنْطِقَ لَكَ الْحَجَرَ ثُمَّ سَلْ فَابْتَهَلَ مُحَمَّدٌ فِي الدُّعَاءِ وَ سَاَلَ اللَّهَ ثُمَّ دَعَا الْحَجَرَ فَلَمْ","translation_segment":"الحسین فرستاد که تقاضا کند با او در خلوت سخن گوید سپس (در خلوت) بآن حضرت چنین گفت: پسر برادرم! میدانی که رسول خدا صلی اللٰه علیه و آله وصیت و امامت را پس از خود بامیر المومنین ع و بعد از او بامام حسن ع و بعد از او بامام حسین ع واگذاشت. و پدر شما - رضی اللٰه عنه و صلی علی روحه - کشته شد و وصیت هم نکرد، و من عموی شما و با پدر شما از یک ریشه‌ام و زاده علی ع هستم. من با این سن و سبقتی که بر شما دارم از شما که جوانید بامامت سزاوارترم، پس با من در امر وصیت و امامت منازعه و مجادله مکن. علی بن الحسین ع باو فرمود: ای عمو از خدا پروا کن و چیزی را که حق نداری ادعا مکن. من ترا موعظه میکنم که مبادا از جاهلان باشی، ای عمو! همانا پدرم صلوات اللٰه علیه پیش از آنکه رهسپار عراق شود بمن وصیت فرمود و ساعتی پیش از شهادتش نسبت بآن با من عهد کرد. و این سلاح رسول خدا صلی اللٰه علیه و آله است نزد من، متعرض این امر مشو که میترسم عمرت کوتاه و حالت پریشان شود. همانا خدای عز و جل امر وصیت و امامت را در نسل حسین ع مقرر داشته است، اگر میخواهی این مطلب را بفهمی بیا نزد حجر الاسود رویم و محاکمه کنیم و این موضوع را از او بپرسیم، امام باقر ع فرماید، این گفتگو میان آنها در مکه بود، پس رهسپار شدند تا بحجر الاسود رسیدند، علی بن الحسین بمحمد بن حنفیه فرمود: تو اول بدرگاه خدای عز و جل تضرع کن و از او بخواه که حجر را برای تو بسخن آورد و سپس بپرس. محمد با تضرع و زاری دعا کرد و از خدا خواست و سپس از","segment_columns":[{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فخلا","display":"فَخَلاَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"اخي","display":"اَخِي"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"علمت","display":"عَلِمْتَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"دف