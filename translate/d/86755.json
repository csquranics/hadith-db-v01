{"consensus_set_id":"86755","translation_language":"fa","translation_source":{"hid":"98441"},"segments":[{"source_hadith_segment":"وَ وَقَفَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عَلَي الْقَتْلَي بِبَدْرٍ","translation_segment":"رسول خدا صلی اللٰه علیه و آله بر سر کشتگان جنگ بدر که آنان را در چاهی یا گودالی جمع کرده","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وقف","display":"وَقَفَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"القتلي","display":"الْقَتْلَي"},{"kind":"word","token":"ببدر","display":"بِبَدْرٍ"}]},{"source_hadith_segment":"وَ قَدْ جَمَعَهُمْ فِي قَلِيبٍ","translation_segment":"بودند (یا محتملا یک قبر که برای همه","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"جمعهم","display":"جَمَعَهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قليب","display":"قَلِيبٍ"}]},{"source_hadith_segment":"فَقَالَ « يَا اَهْلَ الْقَلِيبِ اِنَّا  <quranic_text> « قَدْ وَجَدْنٰا مٰا وَعَدَنٰا رَبُّنٰا حَقًّا فَهَلْ وَجَدْتُمْ مٰا وَعَدَ رَبُّكُمْ حَقًّا » </quranic_text> <footnote> [ الاعراف ۴۴ ] </footnote> فَقَالَ الْمُنَافِقُونَ اِنَّ رَسُولَ اللَّهِ يُكَلِّمُ الْمَوْتَي فَنَظَرَ اِلَيْهِمْ فَقَالَ « لَوْ اُذِنَ لَهُمْ فِي الْكَلاَمِ لَقَالُوا نَعَمْ وَ اِنَّ  <quranic_text> « خَيْرَ الزّٰادِ التَّقْويٰ » </quranic_text>   <footnote> [ البقرة ۱۹۷ ] </footnote>   .","translation_segment":"بصورت دسته جمعی می‌کنند) آمده ایستاد و خطاب بآنان فرمود: ای کسانی که در این گودال فراهم آورده شدید، ما آنچه را که پروردگارمان بما وعده فرموده بود درست یافتیم و تحقق پیدا کرد، آیا شما نیز آنچه پروردگارتان وعده فرموده بود راست یافتید؟ پس منافقان با خود گفتند: همانا رسول خدا با مردگان که از سخن گفتن عاجزند گفتگو میکند، رسول خدا (صلی الله علیه و آله) این معنی را دریافت و به ایشان نگریسته فرمود: اگر ایشان را رخصت سخن گفتن داده میشد حتما پاسخ میدادند: بلی، همانا بهترین توشه راه پرهیزکاری و تقوی است.","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"القليب","display":"الْقَلِيبِ"},{"kind":"word","token":"انا","display":"اِنَّا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"وجدنا","display":"وَجَدْنٰا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"وعدنا","display":"وَعَدَنٰا"},{"kind":"word","token":"ربنا","display":"رَبُّنٰا"},{"kind":"word","token":"حقا","display":"حَقًّا"},{"kind":"word","token":"فهل","display":"فَهَلْ"},{"kind":"word","token":"وجدتم","display":"وَجَدْتُمْ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"وعد","display":"وَعَدَ"},{"kind":"word","token":"ربكم","display":"رَبُّكُمْ"},{"kind":"word","token":"حقا","display":"حَقًّا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۴۴","display":"۴۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"المنافقون","display":"الْمُنَافِقُونَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صلّي"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"},{"kind":"word","to