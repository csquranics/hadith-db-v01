{"consensus_set_id":"101620","translation_language":"fa","translation_source":{"hid":"348986"},"segments":[{"source_hadith_segment":"مَنْ قَرَاَ  <quranic_text> « اِنّٰا اَنْزَلْنٰاهُ فِي لَيْلَةِ الْقَدْرِ » </quranic_text>   <footnote> [ القدر ۱ ] </footnote>  سَبْعَ مَرَّاتٍ قَبْلَ عِشَاءِ الْاخِرَةِ كَانَ فِي ضَمَانِ اللَّهِ تَعَالَي حَتَّي يُصْبِحَ .","translation_segment":"این است که در روایت آمده است: حضرت امام جواد علیه السلام فرمود: «هر کس بعد [یا: قبل] از نماز عشا هفت بار سوره «إنٰا أنزلنٰاه‌ فی لیله‌ القدر» را بخواند، تا صبح در ضمانت خداوند متعال خواهد بود.»","segment_columns":[{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"انزلناه","display":"اَنْزَلْنٰاهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ليله","display":"لَيْلَةِ"},{"kind":"word","token":"القدر","display":"الْقَدْرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القدر","display":"القدر"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"عشاء","display":"عِشَاءِ"},{"kind":"word","token":"الاخره","display":"الْاخِرَةِ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ضمان","display":"ضَمَانِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"يصبح","display":"يُصْبِحَ"}]}]}