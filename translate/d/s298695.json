{"consensus_set_id":"s298695","translation_language":"fa","translation_source":{"hid":"298695"},"segments":[{"source_hadith_segment":"فِي اَلْمُسَاهَمَةِ تُكْتَبُ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>   <quranic_text> « اللّٰهُمَّ فٰاطِرَ السَّمٰاوٰاتِ وَ الْاَرْضِ عٰالِمَ الْغَيْبِ وَ الشَّهٰادَةِ » </quranic_text>   <footnote> [ الزمر ۴۶ ] </footnote>  الرَّحْمَنَ الرَّحِيمَ","translation_segment":"چگونگی قرعه کشی در روایت دیگری نیز به این صورت بیان شده است که به سند خودمان، از عمر و بن ابی المقدام، نقل می‌کنیم. او از امام باقر یا امام صادق علیهما السلام روایت کرده است که راجع به قرعه کشی فرمودند: «می‌نویسی: بسم اللٰه الرحمان الرحیم. «اللٰهم‌ فٰاطر السمٰاوٰات‌ و الأرض‌، عٰالم‌ الغیب‌ و الشهٰاده‌» الرحمان الرحیم، «أنت‌ تحکم‌ بین‌ عبٰادک‌» «فی مٰا کٰانوا فیه‌ یختلفون‌». أسألک بحق‌","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"المساهمه","display":"اَلْمُسَاهَمَةِ"},{"kind":"word","token":"تكتب","display":"تُكْتَبُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اللهم","display":"اللّٰهُمَّ"},{"kind":"word","token":"فاطر","display":"فٰاطِرَ"},{"kind":"word","token":"السماوات","display":"السَّمٰاوٰاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"عالم","display":"عٰالِمَ"},{"kind":"word","token":"الغيب","display":"الْغَيْبِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":