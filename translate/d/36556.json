{"consensus_set_id":"36556","translation_language":"fa","translation_source":{"hid":"297747"},"segments":[{"source_hadith_segment":"،  عَنْ ابَائِهِ ( عَلَيْهِمُ السَّلاَمُ )  ،  قَالَ :  كَانَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اِذَا رَاَي الْهِلاَلَ اِسْتَقْبَلَ الْقِبْلَةَ وَ كَبَّرَ ثُمَّ قَالَ :  \" هِلاَلُ رُشْدٍ","translation_segment":"ابو مریم عبد الغفار بن قاسم از حضرت باقر علیه السلام به نقل از پدرانش علیهم السلام روایت کرده که رسول خدا صلی الله علیه و اله وقتی هلال ماه را می‌دید رو به قبله می‌کرد","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابائه","display":"ابَائِهِ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"راي","display":"رَاَي"},{"kind":"word","token":"الهلال","display":"الْهِلاَلَ"},{"kind":"word","token":"استقبل","display":"اِسْتَقْبَلَ"},{"kind":"word","token":"القبله","display":"الْقِبْلَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كبر","display":"كَبَّرَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هلال","display":"هِلاَلُ"},{"kind":"word","token":"رشد","display":"رُشْدٍ"}]},{"source_hadith_segment":"،  اللَّهُمَّ اَهِلَّهُ عَلَيْنَا بِيُمْنٍ وَ اِيمَانٍ ،  وَ سَلاَمَةٍ وَ اِسْلاَمٍ ،  وَ هُدًي وَ مَغْفِرَةٍ ،  وَ عَافِيَةٍ مُجَلِّلَةٍ","translation_segment":"و می‌فرمود