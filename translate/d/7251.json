{"consensus_set_id":"7251","translation_language":"fa","translation_source":{"hid":"406317"},"segments":[{"source_hadith_segment":"،  عَنْ اَبِيهِ ( عَلَيْهِمَا السَّلاَمُ ) ،  قَالَ :  « اِذَا كَانَ يَوْمُ الْقِيَامَةِ نُصِبَ مِنْبَرٌ عَنْ يَمِينِ الْعَرْشِ لَهُ اَرْبَعٌ وَ عِشْرُونَ مِرْقَاةً ،  وَ يَجِيءُ عَلِيُّ بْنُ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ ) وَ بِيَدِهِ لِوَاءُ الْحَمْدِ فَيَرْتَقِيهِ وَ يَرْكَبُهُ ،  وَ تُعْرَضُ الْخَلاَئِقُ عَلَيْهِ ،  فَمَنْ عَرَفَهُ دَخَلَ الْجَنَّةَ ،  وَ مَنْ اَنْكَرَهُ دَخَلَ النَّارَ ،  وَ تَفْسِيرُ ذَلِكَ فِي كِتَابِ اللَّهِ  <quranic_text> « وَ قُلِ اِعْمَلُوا فَسَيَرَي اللّٰهُ عَمَلَكُمْ وَ رَسُولُهُ وَ الْمُؤْمِنُونَ » </quranic_text>   <footnote> [ التوبة ۱۰۵ ] </footnote> - قَالَ - هُوَ وَ اللَّهِ اَمِيرُ الْمُؤْمِنِينَ عَلِيُّ بْنُ اَبِي طَالِبٍ ( صَلَوَاتُ اللَّهِ عَلَيْهِ )  »","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"حدثني","display":"حَدَّثَنِي"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"حديثا","display":"حَدِيثاً"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"اشرحه","display":"اَشْرَحُهُ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"اجمعه","display":"اَجْمَعُهُ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"بل","display":"بَلْ"},{"kind":"word","token":"اجمعه","display":"اِجْمَعْهُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"باب","display":"بَابُ"},{"kind":"word","token":"هدي","display":"هُدًي"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"تقدمه","display":"تَقَدَّمَهُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"كافرا"