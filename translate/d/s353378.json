{"consensus_set_id":"s353378","translation_language":"fa","translation_source":{"hid":"353378"},"segments":[{"source_hadith_segment":"اَجْمَعَ الُ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عَلَي الْجَهْرِ بِ‍  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  وَ عَلَي اَنْ لاَ يَمْسَحُوا عَلَي الْخُفَّيْنِ .","translation_segment":"از جابر مرویست که اجماع آل رسول اللٰه است بجهر «بسم‌ اللٰه‌ الرحمٰن‌ الرحیم‌»، در نماز و مسح بر خفین نکشیدن،","segment_columns":[{"kind":"word","token":"اجمع","display":"اَجْمَعَ"},{"kind":"word","token":"ال","display":"الُ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الجهر","display":"الْجَهْرِ"},{"kind":"word","token":"ب","display":"بِ‍"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يمسحوا","display":"يَمْسَحُوا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الخفين","display":"الْخُفَّيْنِ"}]}]}