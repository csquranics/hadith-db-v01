ag_name":"footnote"}]},{"source_hadith_segment":"فَاِنَّهُ حَدَّثَنِي اَبِي عَنْ عَبْدِ اللَّهِ بْنِ جُنْدَبٍ قَالَ :  كَتَبْتُ اِلَي اَبِي الْحَسَنِ الرِّضَا صَلَوَاتُ اللَّهِ عَلَيْهِ اَسْاَلُهُ عَنْ تَفْسِيرِ هَذِهِ الْايَةِ","translation_segment":"","segment_columns":[{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"حدثني","display":"حَدَّثَنِي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"جندب","display":"جُنْدَبٍ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كتبت","display":"كَتَبْتُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"اساله","display":"اَسْاَلُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"}]},{"source_hadith_segment":"؟  فَكَتَبَ اِلَيَّ الْجَوَابَ :  اَمَّا بَعْدُ فَاِنَّ مُحَمَّداً صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ كَانَ اَمِينَ اللَّهِ فِي خَلْقِهِ ،  فَلَمَّا قُبِضَ النَّبِيُّ كُنَّا اَهْلَ الْبَيْتِ وَرَثَتَهُ ،  فَنَحْنُ اُمَنَاءُ اللَّهِ فِي اَرْضِهِ عِنْدَنَا عِلْمُ الْمَنَايَا وَ الْبَلاَيَا وَ اَنْسَابُ الْعَرَبِ وَ مَوْلِدُ الْاِسْلاَمِ ،  وَ مَا مِنْ فِئَةٍ تُضِلُّ مِائَةً وَ تَهْدِي مِائَةً اِلاَّ وَ نَحْنُ نَعْرِفُ سَائِقَهَا وَ قَائِدَهَا وَ نَاعِقَهَا ،  وَ اِنَّا لَنَعْرِفُ الرَّجُلَ اِذَا رَاَيْنَاهُ بِحَقِيقَةِ الْاِيمَانِ وَ حَقِيقَةِ النِّفَاقِ ،  وَ اِنَّ شِيعَتَنَا لَمَكْتُوبُونَ بِاَسْمَائِهِمْ وَ اَسْمَاءِ ابَائِهِمْ ،  اَخَذَ اللَّهُ عَزَّ وَ جَلَّ عَلَيْنَا وَ عَلَيْهِمُ الْمِيثَاقَ ،  يَرِدُونَ مَوْرِدَنَا وَ يَدْخُلُونَ مَدْخَلَنَا لَيْسَ عَلَي مِلَّةِ الْاِسْلاَمِ غَيْرُنَا وَ غَيْرُهُمْ اِلَي يَوْمِ الْقِيَامَةِ ،  نَحْنُ الْاخِذُونَ بِحُجْزَةِ نَبِيِّنَا وَ نَبِيُّنَا الْاخِذُ بِحُجْرَةِ رَبِّنَا ،  وَ الْحُجْزَةُ النُّورُ وَ شِيعَتُنَا اخِذُونَ بِحُجْزَتِنَا ،  مَنْ فَارَقَنَا هَلَكَ وَ مَنْ تَبِعَنَا نَجَي ،  وَ الْمُفَارِقُ لَنَا وَ الْجَاحِدُ لِوَلاَيَتِنَا كَافِرٌ ،  وَ مُتَّبِعُنَا وَ تَابِعُ اَوْلِيَائِنَا مُؤْمِنٌ لاَ يُحِبُّنَا كَافِرٌ وَ لاَ يُبْغِضُنَا مُؤْمِنٌ ،  فَمَنْ مَاتَ وَ هُوَ يُحِبُّنَا كَانَ حَقّاً عَلَي اللَّهِ اَنْ يَبْعَثَهُ مَعَنَا ،  نَحْنُ نُورٌ لِمَنْ تَبِعَنَا وَ هُدًي لِمَنِ اِهْتَدَي بِنَا ،  وَ مَنْ لَمْ يَكُنْ مِنَّا فَلَيْسَ مِنَ الْاِسْلاَمِ فِي شَيْءٍ ،  بِنَا فَتَحَ اللَّهُ الدِّينَ وَ بِنَا يَخْتِمُهُ ،  وَ بِنَا اَطْعَمَكُمُ اللَّهُ عُشْبَ الْاَرْضِ وَ بِنَا اَنْزَلَ اللَّهُ قَطْرَ السَّمَاءِ ،  وَ بِنَا امَنَكُمُ اللَّهُ عَزَّ وَ جَلَّ مِنَ الْغَرَقِ فِي بَحْرِكُمْ ،  وَ مِنَ الْخَسْفِ فِي بَرِّكُمْ ،  وَ بِنَا نَفَعَكُمُ اللَّهُ فِي حَيَاتِكُمْ وَ فِي قُبُورِكُمْ وَ فِي مَحْشَرِكُمْ وَ عِنْدَ الصِّرَاطِ وَ عِنْدَ الْمِيزَانِ وَ عِنْدَ دُخُولِكُمُ الْجِنَانَ ،  مَثَلُنَا فِي كِتَابِ اللَّهِ عَزَّ وَ جَلَّ « كَمَثَلِ مِشْكَاةٍ » الْمِشْكَاةُ فِي الْقِنْدِيلِ فَنَحْنُ الْمِشْكَاةُ  <quranic_text> « فِيهٰا مِصْبٰاحٌ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  الْمِصْبَاحُ مُحَمَّدٌ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  <quranic_text> « اَلْمِصْبٰاحُ فِي زُجٰاجَةٍ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  مِنْ عُنْصُرِهِ  <quranic_text> « اَلزُّجٰاجَةُ كَاَنَّهٰا كَوْكَبٌ دُرِّيٌّ يُوقَدُ مِنْ شَجَرَةٍ مُبٰارَكَةٍ زَيْتُونَةٍ لاٰ شَرْقِيَّةٍ وَ لاٰ غَرْبِيَّةٍ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  لاَ دَعِيَّةٍ وَ لاَ مُنْكَرَةٍ  <quranic_text> « يَكٰادُ زَيْتُهٰا يُضِيءُ وَ لَوْ لَمْ تَمْسَسْهُ نٰارٌ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  الْقُرْانُ  <quranic_text> « نُورٌ عَليٰ نُورٍ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  اِمَامٌ بَعْدَ اِمَامٍ  <quranic_text> « يَهْدِي اللّٰهُ لِنُورِهِ مَنْ يَشٰاءُ وَ يَضْرِبُ اللّٰهُ الْاَمْثٰالَ لِلنّٰاسِ وَ اللّٰهُ بِكُلِّ شَيْءٍ عَلِيمٌ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  فَالنُّورُ عَلِيٌّ صَلَوَاتُ اللَّهِ عَلَيْهِ  ،  يَهْدِي لِوَلاَيَتِنَا مَنْ اَحَبَّ وَ حَقٌّ عَلَي اللَّهِ اَنْ يَبْعَثَ وَلِيَّنَا مُشْرِقاً وَجْهُهُ ،  مُنِيراً بُرْهَانُهُ ،  ظَاهِرَةً عِنْدَ اللَّهِ حُجَّتُهُ ،  وَ الْحَدِيثُ طَوِيلٌ اَخَذْنَا مِنْهُ مَوْضِعَ الْحَاجَةِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"فكتب","display":"فَكَتَبَ"},{"kind":"word","token":"الي","display":"اِلَيَّ"},{"kind":"word","token":"الجواب","display":"الْجَوَابَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"بعد","display":"بَعْدُ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"محمدا","display":"مُحَمَّداً"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"امين","display":"اَمِينَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"خلقه","display":"خَلْقِهِ"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"قبض","display":"قُبِضَ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"كنا","display":"كُنَّا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"},{"kind":"word","token":"ورثته","display":"وَرَثَتَهُ"},{"kind":"word","token":"فنحن","display":"فَنَحْنُ"},{"kind":"word","token":"امناء","display":"اُمَنَاءُ"},{"kind":"word","token"