{"consensus_set_id":"95719","translation_language":"fa","translation_source":{"hid":"345628"},"segments":[{"source_hadith_segment":"قَالَ قَالَ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  فِي قَوْلِهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ تَعِيَهٰا اُذُنٌ وٰاعِيَةٌ » </quranic_text>   <footnote> [ الحاقة ۱۲ ] </footnote>  قَالَ دَعَوْتُ اللَّهَ اَنْ يَجْعَلَهَا اُذُنَكَ يَا عَلِيُّ  .","translation_segment":"باسناد سابق از علی (علیه السلام) مروی است که فرمود رسول خدا (صلی الله علیه و آله) فرمود در این آیه شریفه «و تعیهٰا أذن‌ وٰاعیه‌» من از خدای عز و جل درخواستم که این اذن و گوش را گوش تو قرار دهد یا علی.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعيها","display":"تَعِيَهٰا"},{"kind":"word","token":"اذن","display":"اُذُنٌ"},{"kind":"word","token":"واعيه","display":"وٰاعِيَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحاقه","display":"الحاقة"},{"kind":"word","token":"۱۲","display":"۱۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"دعوت","display":"دَعَوْتُ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يجعلها","display":"يَجْعَلَهَا"},{"kind":"