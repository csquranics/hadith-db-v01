{"consensus_set_id":"50983","translation_language":"fa","translation_source":{"hid":"317824"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ-  <quranic_text> « وَ اِذْ قٰالَ رَبُّكَ لِلْمَلاٰئِكَةِ اِنِّي جٰاعِلٌ فِي الْاَرْضِ خَلِيفَةً قٰالُوا اَ تَجْعَلُ فِيهٰا مَنْ يُفْسِدُ فِيهٰا وَ يَسْفِكُ الدِّمٰاءَ وَ نَحْنُ نُسَبِّحُ بِحَمْدِكَ وَ نُقَدِّسُ لَكَ » </quranic_text>   <footnote> [ البقرة ۳۰ ] </footnote>  قَالَ","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل-","display":"جَلَّ-"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"ربك","display":"رَبُّكَ"},{"kind":"word","token":"للملائكه","display":"لِلْمَلاٰئِكَةِ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"جاعل","display":"جٰاعِلٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"خليفه","display":"خَلِيفَةً"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"تجعل","display":"تَجْعَلُ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يفسد","display":"يُفْسِدُ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يسفك","display":"يَسْفِكُ"},{"kind":"word","token":"الدماء","display":"الدِّمٰاءَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"نسبح","display":"نُسَب