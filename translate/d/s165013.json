{"consensus_set_id":"s165013","translation_language":"fa","translation_source":{"hid":"165013"},"segments":[{"source_hadith_segment":"وَ قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَوْلُهُ تَعَالَي  <quranic_text> « اِنَّ الصَّلاٰةَ كٰانَتْ عَلَي الْمُؤْمِنِينَ كِتٰاباً مَوْقُوتاً » </quranic_text>   <footnote> [ النساء ۱۰۳ ] </footnote>   ،  قَالَ كِتَاباً ثَابِتاً الْحَدِيثَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةَ"},{"kind":"word","token":"كانت","display":"كٰانَتْ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"كتابا","display":"كِتٰاباً"},{"kind":"word","token":"موقوتا","display":"مَوْقُوتاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۰۳","display":"۱۰۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كتابا","display":"كِتَاباً"},{"kind":"word","token":"ثابتا","display":"ثَابِتاً"},{"kind":"word","token":"الحديث","display":"الْحَدِيثَ"}]}]}