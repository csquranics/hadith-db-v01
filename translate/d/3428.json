{"consensus_set_id":"3428","translation_language":"fa","translation_source":{"hid":"331556"},"segments":[{"source_hadith_segment":"كُنْتُ عِنْدَ اَبِي جَعْفَرٍ مُحَمَّدِ بْنِ عَلِيٍّ وَ هُوَ يُحَدِّثُ النَّاسَ - اِذْ قَامَ","translation_segment":"عن زیاد بن المنذر قال: کنت عند أبی جعفر محمد بن علی‌ و هو یحدث الناس إذ قام إلیه رجل من أهل البصره یقال له:","segment_columns":[{"kind":"word","token":"كنت","display":"كُنْتُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"محمد","display":"مُحَمَّدِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"بالابطح","display":"بِالْاَبْطَحِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"يحدث","display":"يُحَدِّثُ"},{"kind":"word","token":"الناس","display":"النَّاسَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"قام","display":"قَامَ"}]},{"source_hadith_segment":"اِلَيْهِ رَجُلٌ مِنْ اَهْلِ الْبَصْرَةِ يُقَالُ لَهُ :  عُثْمَانُ الْاَعْشَي","translation_segment":"عثمان الأعشی-کان یروی عن الحسن البصری-فقال له: یا ابن رسول الله جعلنی الله فداک إن‌ الحسن","segment_columns":[{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"البصره","display":"الْبَصْرَةِ"},{"kind":"word","token":"يقال","display":"يُقَالُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"عثمان","display":"عُثْمَانُ"},{"kind":"word","token":"الاعشي","display":"الْاَعْشَي"},{"kind":"word","token":"-","display":"-"}]},{"source_hadith_segment":"كَانَ يَرْوِي عَنِ الْحَسَنِ الْبَصْرِيِّ فَقَالَ لَهُ","translation_segment":"یخبرنا أن‌ هذه الآیه نزلت بسبب رجل و لا یخبرنا من الرجل (یا","segment_columns":[{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يروي","display":"يَرْوِي"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"البصري","display":"الْبَصْرِيِّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"}]},{"source_hadith_segment":":  يَا اِبْنَ رَسُولِ اللَّهِ جَعَلَنِيَ اللَّهُ فِدَاكَ - اِنَّ الْحَسَنَ يُخْبِرُنَا اَنَّ","translation_segment":"أیها الرسول بلغ ما أنزل إلیک من ربک). فقال: لو أراد أن یخبر به لأخبر به، و لکنه یخاف، إن‌ جبرئیل هبط‍‌ علی","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"جعلني","display":"جَعَلَنِيَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الحسن","display":"الْحَسَنَ"},{"kind":"word","token":"البصري","display":"الْبَصْرِيَّ"},{"kind":"word","token":"يحدثنا","display":"يُحَدِّثُنَا"},{"kind":"word","token":"حديثا","display":"حَدِيثاً"},{"kind":"word","token":"يخبرنا","display":"يُخْبِرُنَا"},{"kind":"word","token":"ان","display":"اَنَّ"}]},{"source_hadith_segment":"هَذِهِ الْايَةَ نَزَلَتْ بِسَبَبِ رَجُلٍ - وَ لاَ يُخْبِرُنَا مَنِ الرَّجُلُ  <quranic_text> « يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ » </quranic_text>   <footnote> [ المائدة ۶۷ ] </footnote>   .  فَقَالَ :  لَوْ اَرَادَ اَنْ يُخْبِرَ بِهِ لَاَخْبَرَ بِهِ ،  وَ لَكِنَّهُ يَخَافُ ،  اِنَّ جَبْرَئِيلَ هَبَطَ عَلَي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَقَالَ لَهُ :  اِنَّ اللَّهَ يَاْمُرُكَ اَنْ تَدُلَّ اُمَّتَكَ عَلَي صَلاَتِهِمْ .  فَدُلَّهُمْ عَلَيْهَا ،  ثُمَّ هَبَطَ - فَقَالَ :  اِنَّ اللَّهَ يَاْمُرُكَ اَنْ تَدُلَّ اُمَّتَكَ عَلَي زَكَاتِهِمْ .  فَدُلَّهُمْ عَلَيْهَا ،  ثُمَّ هَبَطَ - فَقَالَ :  اِنَّ اللَّهَ يَاْمُرُكَ اَنْ تَدُلَّ اُمَّتَكَ عَلَي صِيَامِهِمْ .  فَدُلَّهُمْ ،  ثُمَّ هَبَطَ - فَقَالَ :  اِنَّ اللَّهَ يَاْمُرُكَ اَنْ تَدُلَّ اُمَّتَكَ عَلَي حَجِّهِمْ - فَفَعَلَ ،  ثُمَّ هَبَطَ فَقَالَ :  اِنَّ اللَّهَ يَاْمُرُكَ اَنْ تَدُلَّ اُمَّتَكَ عَلَي وَلِيِّهِمْ - عَلَي مِثْلِ مَا دَلَلْتَهُمْ عَلَيْهِ مِنْ صَلاَتِهِمْ وَ زَكَاتِهِمْ وَ صِيَامِهِمْ وَ حَجِّهِمْ - لِيَلْزَمَهُمُ الْحُجَّةُ فِي جَمِيعِ ذَلِكَ .  فَقَالَ رَسُولُ اللَّهِ  :  يَا رَبِّ اِنَّ قَوْمِي قَرِيبُو عَهْدٍ بِالْجَاهِلِيَّةِ وَ فِيهِمْ تَنَافُسٌ وَ فَخْرٌ ،  وَ مَا مِنْهُمْ رَجُلٌ اِلاَّ وَ قَدْ وَتَرَهُ وَلِيُّهُمْ وَ اِنِّي اَخَافُ - فَاَنْزَلَ اللَّهُ تَعَالَي :","translation_segment":"النبی فقال له: إن‌ الله یأمرک أن تدل أمتک علی صلاتهم. فدلهم علیها، ثم‌ هبط‍‌ فقال: إن‌ الله یأمرک أن تدل‌ أمتک علی صیامهم. فدلهم، ثم‌ هبط‍‌ فقال: إن‌ الله یأمرک أن تدل‌ أمتک علی حجهم ففعل، ثم هبط‍‌ فقال: إن‌ الله یأمرک أن تدل‌ أمتک علی ولیهم علی مثل ما دللتهم علیه من صلاتهم و زکاتهم و صیامهم و حجهم لیلزمهم الحجه فی جمیع ذلک. فقال رسول الله: یا رب‌ إن‌ قومی قریبوا عهد بالجاهلیه و فیهم تنافس و فخر، و ما منهم رجل إلا و قد و تره ولیهم و إنی أخاف، فأنزل الله تعالی: (یا أیها الرسول بلغ ما أنزل إلیک من ربک و إن لم تفعل فما بلغت رسالته) یرید فما بلغتها تامه (و الله یعصمک من الناس). فلما ضمن الله له بالعصمه و خوفه، أخذ بید علی‌ بن ابی طالب ثم قال: یا أیها الناس من کنت مولاه فعلی مولاه، اللهم و ال من والاه و عاد من عاداه، و انصر من نصره و اخذل من خذله و أحب‌ من أحبه و أبغض من أبغضه. قال زیاد: فقال عثمان: ما انصرفت إلی بلدی بشیء أحب‌ إلی‌ من هذا الحدیث. زیاد بن منذر گفت: نزد ابو جعفر محمد بن علی بودم و او به مردم حدیث می‌گفت: مردی از اهل بصره به نام عثمان الاعشی که از حسن بصری روایت می‌کرد، بلند شد و گفت: ای پسر رسول خدا، خدا مرا فدای تو کند، حسن به ما می‌گوید که این آیه: «یا ایها الرسول بلغ ما انزل الیک من ربک» درباره مردی نازل شده است ولی نام آن مرد را نمی‌گوید. ابو جعفر گفت: اگر می‌خواست می‌گفت ولی او می‌ترسد. جبرئیل به پیامبر نازل شد و به او گفت: خداوند تو را فرمان می‌دهد که امت خود را به نماز وادار کنی، پس به آن وادار کرد. سپس نازل شد و گفت: خداوند تو را فرمان می‌دهد که امت خود را به زکات وادار کنی، پس به آن وادار کرد، سپس نازل شد و گفت: خداوند تو را فرمان می‌دهد که امت خود","segment_columns":[{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"بسبب","display":"بِسَبَبِ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يخبرنا","display":"يُخْبِرُنَا"},{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الرسول","display":"الرَّسُولُ"},{"kind":"word","token":"بلغ","display":"بَلِّغْ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"انزل","display":"اُنْزِلَ"},{"kind":"word","token":"اليك","display":"اِلَيْكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تفعل","display":"تَفْعَلْ"},{"kind":"word","token":"فما","display":"فَمٰا"},{"kind":"word","token":"بلغت","display":"بَلَّغْتَ"},{"kind":"word","token":"رسالته","display":"رِسٰالَتَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۶