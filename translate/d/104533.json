{"consensus_set_id":"104533","translation_language":"fa","translation_source":{"hid":"210176"},"segments":[{"source_hadith_segment":"« اَلْاَوْصِيَاءُ هُمْ اَصْحَابُ الصِّرَاطِ وُقُوفاً عَلَيْهِ ،  لاَ يَدْخُلُ الْجَنَّةَ اِلاَّ مَنْ عَرَفَهُمْ [ وَ عَرَفُوهُ ،  وَ لاَ يَدْخُلُ النَّارَ اِلاَّ مَنْ اَنْكَرَهُمْ وَ اَنْكَرُوهُ ،  لِاَنَّهُمْ عُرَفَاءُ اللَّهِ عَزَّ وَ جَلَّ عَرَّفَهُمْ عَلَيْهِمْ ] عِنْدَ اَخْذِهِ الْمَوَاثِيقَ عَلَيْهِمْ ،  وَ وَصَفَهُمْ فِي كِتَابِهِ ،  فَقَالَ عَزَّ وَ جَلَّ :   <quranic_text> « يَعْرِفُونَ كُلاًّ بِسِيمٰاهُمْ » </quranic_text>   <footnote> [ الاعراف ۴۶ ] </footnote> وَ هُمُ الشُّهَدَاءُ عَلَي اَوْلِيَائِهِمْ ،  وَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) الشَّهِيدُ عَلَيْهِمْ ،  اَخَذَ لَهُمْ مَوَاثِيقَ الْعِبَادِ بِالطَّاعَةِ ،  وَ اَخَذَ لِلنَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) الْمِيثَاقَ بِالطَّاعَةِ ،  فَجَرَتْ نُبُوَّتُهُ عَلَيْهِمْ ،  وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « فَكَيْفَ اِذٰا جِئْنٰا مِنْ كُلِّ اُمَّةٍ بِشَهِيدٍ وَ جِئْنٰا بِكَ عَليٰ هٰؤُلاٰءِ شَهِيداً » </quranic_text>   <footnote> [ النساء ۴۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"الاوصياء","display":"اَلْاَوْصِيَاءُ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابُ"},{"kind":"word","token":"الصراط","display":"الصِّرَاطِ"},{"kind":"word","token":"وقوفا","display":"وُقُوفاً"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يدخل","display":"يَدْخُلُ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عرفهم","display":"عَرَفَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عرفوه","display":"عَرَفُوهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":