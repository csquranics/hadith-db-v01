{"consensus_set_id":"s351193","translation_language":"fa","translation_source":{"hid":"351193"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي  <quranic_text> « يٰا شُعَيْبُ اَ صَلاٰتُكَ تَاْمُرُكَ اَنْ نَتْرُكَ مٰا يَعْبُدُ ابٰاؤُنٰا اَوْ اَنْ نَفْعَلَ فِي اَمْوٰالِنٰا مٰا نَشٰؤُا » </quranic_text>   <footnote> [ هود ۸۷ ] </footnote>  قَالَ مِمَّا كَانَ نَهَاهُمْ عَنْهُ قَطْعِ الدَّرَاهِمِ .","translation_segment":"برید بن اسلم در تفسیر آیه‌ی «یٰا شعیب‌ أ صلاٰتک‌ تأمرک‌ أن‌ نترک‌ مٰا یعبد آبٰاونٰا …». می‌گوید. یکی از کارهایی که شعیب، مردم را از آن باز می‌داشت بریدن گوشه‌های سکه‌های نقره بود.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"شعيب","display":"شُعَيْبُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"صلاتك","display":"صَلاٰتُكَ"},{"kind":"word","token":"تامرك","display":"تَاْمُرُكَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"نترك","display":"نَتْرُكَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يعبد","display":"يَعْبُدُ"},{"kind":"word","token":"اباؤنا","display":"ابٰاؤُنٰا"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"نفعل","display":"نَفْعَلَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اموالنا","display":"اَمْوٰالِنٰا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"نشؤا","display":"نَشٰؤُا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"هود","display":"هود"},{"kind":"word","token":"۸۷","display":"۸۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"