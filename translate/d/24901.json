{"consensus_set_id":"24901","translation_language":"fa","translation_source":{"hid":"440018"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ -  <quranic_text> « وُجُوهٌ يَوْمَئِذٍ نٰاضِرَةٌ اِليٰ رَبِّهٰا نٰاظِرَةٌ » </quranic_text>   <footnote> [ القيامة ۲۲ ] </footnote>  قَالَ يَعْنِي مُشْرِقَةٌ تَنْتَظِرُ ثَوَابَ رَبِّهَا .","translation_segment":"روز سه شنبه ۶ جمادی الاولی ۳۶۸۱ - امام رضا (علیه السلام) در تفسیر قول خدای عز و جل (قیامت-۲۲ و ۲۳) چهره‌هائی در این روز خرم است و بسوی پروردگار خود نگران است - فرمود یعنی تابان است و منتظر ثواب پروردگار خود است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"وجوه","display":"وُجُوهٌ"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"ناضره","display":"نٰاضِرَةٌ"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"ربها","display":"رَبِّهٰا"},{"kind":"word","token":"ناظره","display":"نٰاظِرَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القيامه","display":"القيامة"},{"kind":"word","token":"۲۲","display":"۲۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"مشرقه","display":"مُشْرِقَةٌ"},{"kind":"word","token":"تنتظر","display":"تَنْتَظِرُ"},{"kind":"word","token":"ثواب","display":"ثَوَابَ"},{"kind":"word","token":"ربها","display":"رَبِّهَا"}]}]}