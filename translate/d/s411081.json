{"consensus_set_id":"s411081","translation_language":"fa","translation_source":{"hid":"411081"},"segments":[{"source_hadith_segment":"« وَ اَمَّا قَوْلُهُ تَعَالَي :   <quranic_text> « اِنَّكُمْ لَفِي قَوْلٍ مُخْتَلِفٍ » </quranic_text>   <footnote> [ الذاريات ۸ ] </footnote> ،  [ فَاِنَّهُ عَلِيٌّ ،  يَعْنِي اِنَّهُ لَمُخْتَلَفٌ عَلَيْهِ ،  وَ قَدِ ] اِخْتَلَفَتِ هَذِهِ الْاُمَّةُ ،  فَمَنِ اِسْتَقَامَ عَلَي وَلاَيَةِ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) ،  دَخَلَ الْجَنَّةَ ،  وَ مَنْ خَالَفَ وَلاَيَةَ عَلِيٍّ اُدْخِلَ النَّارَ ،  وَ اَمَّا قَوْلُهُ تَعَالَي :   <quranic_text> « يُؤْفَكُ عَنْهُ مَنْ اُفِكَ » </quranic_text>   <footnote> [ الذاريات ۹ ] </footnote> - قَالَ - يَعْنِي عَلِيّاً ،  مَنْ اُفِكَ عَنْ وَلاَيَتِهِ اُفِكَ عَنِ الْجَنَّةِ ،  فَذَلِكَ قَوْلُهُ تَعَالَي :   <quranic_text> « يُؤْفَكُ عَنْهُ مَنْ اُفِكَ » </quranic_text>   <footnote> [ الذاريات ۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انكم","display":"اِنَّكُمْ"},{"kind":"word","token":"لفي","display":"لَفِي"},{"kind":"word","token":"قول","display":"قَوْلٍ"},{"kind":"word","token":"مختلف","display":"مُخْتَلِفٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الذاريات","display":"الذاريات"},{"kind":"word","token":"۸","display":"۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"لمختلف","display":"لَمُخْتَلَفٌ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد",