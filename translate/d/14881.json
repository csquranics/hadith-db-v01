"قصه","display":"قِصَّةِ"},{"kind":"word","token":"اخوه","display":"اِخْوَةِ"},{"kind":"word","token":"يوسف","display":"يُوسُفَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قصه","display":"قِصَّةِ"},{"kind":"word","token":"يوسف","display":"يُوسُفَ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"نفسه","display":"نَفْسِهِ"},{"kind":"word","token":"التوبه۱۲۰","display":"التوبة۱۲۰"}]},{"source_hadith_segment":"؟  فَقَالَ :  « اِنَّهُمْ لَمَّا اَصْبَحُوا ،  قَالُوا :  اِنْطَلِقُوا بِنَا حَتَّي نَنْظُرَ مَا حَالُ يُوسُفَ ،  اَمَاتَ اَمْ هُوَ حَيٌّ ؟  فَلَمَّا اِنْتَهَوْا اِلَي الْجُبِّ وَجَدُوا بِحَضْرَةِ الْجُبِّ سَيَّارَةً ،  وَ قَدْ اَرْسَلُوا وَارِدَهُمْ فَاَدْلَي دَلْوَهُ ،  فَمَلَاَ جَذَبَ دَلْوَهُ فَاِذَا هُوَ غُلاَمٌ مُتَعَلِّقٌ بِدَلْوِهِ ،  فَقَالَ لِاَصْحَابِهِ  <quranic_text> « يٰا بُشْريٰ هٰذٰا غُلاٰمٌ » </quranic_text>   <footnote> [ يوسف ۱۹ ] </footnote> فَلَمَّا اَخْرَجُوهُ اَقْبَلَ اِلَيْهِمْ اِخْوَةُ يُوسُفَ ،  فَقَالُوا :  هَذَا عَبْدُنَا سَقَطَ مِنَّا اَمْسِ فِي هَذَا الْجُبِّ ،  وَ جِئْنَا الْيَوْمَ لِنُخْرِجَهُ فَانْتَزَعُوهُ مِنْ اَيْدِيهِمْ ،  وَ تَنَحَّوْا بِهِ نَاحِيَةً ،  فَقَالُوا :  اِمَّا اَنْ تُقِرَّ لَنَا اَنَّكَ عَبْدٌ لَنَا فَنَبِيعَكَ عَلَي بَعْضِ هَذِهِ السَّيَّارَةِ اَنْ تَقْتُلُكَ ؟  فَقَالَ لَهُمْ يُوسُفُ  :  لاَ تَقْتُلُونِي وَ اِصْنَعُوا مَا شِئْتُمْ .  فَاَقْبَلُوا بِهِ اِلَي السَّيَّارَةِ ،  فَقَالُوا :  مَنْ مِنْكَ يَشْتَرِي مِنَّا هَذَا الْعَبْدَ فَاشْتَرَاهُ رَجُلٌ مِنْهُمْ بِعِشْرِينَ دِرْهَماً ،  وَ كَانَ اِخْوَتُهُ فِيهِ مِنَ الزَّاهِدِينَ ،  وَ سَارَ بِهِ الَّذِي اِشْتَرَاهُ مِنَ الْبَدْوِ حَتَّي اَدْخَلَهُ مِصْرَ ،  فَبَاعَهُ الَّذِي اِشْتَرَاهُ مِنَ الْبَدْوِ مِنْ مَلِكِ مِصْرَ ،  وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ قٰالَ الَّذِي اِشْتَرٰاهُ مِنْ مِصْرَ لاِمْرَاَتِهِ اَكْرِمِي مَثْوٰاهُ عَسيٰ اَنْ يَنْفَعَنٰا اَوْ نَتَّخِذَهُ وَلَداً » </quranic_text>   <footnote> [ يوسف ۲۱ ] </footnote> .  قَالَ اَبُو حَمْزَةَ :  فَقُلْتُ لِعَلِيِّ بْنِ الْحُسَيْنِ ( عَلَيْهِ السَّلاَمُ )  :  اِبْنُ كَمْ كَانَ يُوسُفُ يَوْمَ اَلْقَوْهُ فِي الْجُبِّ ؟  فَقَالَ :  كَانَ اِبْنَ تِسْعِ سِنِينَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لها","display":"لها"},{"kind":"word","token":"معاذ","display":"معاذ"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"انهم","display":"اِنَّهُمْ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"اصبحوا","display":"اَصْبَحُوا"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"انطلقوا","display":"اِنْطَلِقُوا"},{"kind":"word","token":"بنا","display":"بِنَا"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"ننظر","display":"نَنْظُرَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"حال","display":"حَالُ"},{"kind":"word","token":"يوسف","display":"يُوسُفَ"},{"kind":"word","token":"امات","display":"اَمَاتَ"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"حي","display":"حَيٌّ"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"انتهوا","display":"اِنْتَهَوْا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الجب","display":"الْجُبِّ"},{"kind":"word","token":"وجدوا","display":"وَجَدُوا"},{"kind":"word","token":"بحضره","display":"بِحَضْرَةِ"},{"kind":"word","token":"الجب","display":"الْجُبِّ"},{"kind":"word","token":"سياره","display":"سَيَّارَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"ارسلوا","display":"اَرْسَلُوا"},{"kind":"word","token":"واردهم","display":"وَارِدَهُمْ"},{"kind":"word","token":"فادلي","display":"فَاَدْلَي"},{"kind":"word","token":"دلوه","display":"دَلْوَهُ"},{"kind":"word","token":"فملا","display":"فَمَ