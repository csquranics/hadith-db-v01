{"consensus_set_id":"s332919","translation_language":"fa","translation_source":{"hid":"332919"},"segments":[{"source_hadith_segment":"اِنْتَهَتْ دَعْوَةُ اِبْرَاهِيمَ عَلَيْهِ السَّلاَمُ وَ هِيَ قَوْلُهُ  <quranic_text> « وَ اُجْنُبْنِي وَ بَنِيَّ اَنْ نَعْبُدَ الْاَصْنٰامَ » </quranic_text>   <footnote> [ ابراهيم ۳۵ ] </footnote>  اِلَيَّ وَ اِلَي عَلِيٍّ فَاَنَا وَ عَلِيٌّ لَمْ يَسْجُدْ اَحَدُنَا لِصَنَمٍ فَاتَّخَذَنِي نَبِيّاً وَ اِتَّخَذَ عَلِيّاً وَصِيّاً .","translation_segment":"","segment_columns":[{"kind":"word","token":"انتهت","display":"اِنْتَهَتْ"},{"kind":"word","token":"دعوه","display":"دَعْوَةُ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اجنبني","display":"اُجْنُبْنِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بني","display":"بَنِيَّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"نعبد","display":"نَعْبُدَ"},{"kind":"word","token":"الاصنام","display":"الْاَصْنٰامَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۳۵","display":"۳۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"اِلَيَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"فانا","display":"فَاَنَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يسجد","display":"يَسْجُدْ"},{"kind":"word"