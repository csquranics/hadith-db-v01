{"consensus_set_id":"s107219","translation_language":"fa","translation_source":{"hid":"107219"},"segments":[{"source_hadith_segment":"اِذَا اَوَيْتَ اِلَي فِرَاشِكَ فَقُلْ بِسْمِ اللَّهِ وَضَعْتُ جَنْبِيَ الْاَيْمَنَ لِلَّهِ عَلَي مِلَّةِ اِبْرَاهِيمَ حَنِيفاً لِلَّهِ مُسْلِماً  <quranic_text> « وَ مٰا اَنَا مِنَ الْمُشْرِكِينَ » </quranic_text>   <footnote> [ الانعام ۷۹ ] </footnote>   .","translation_segment":"خالد بن نجیح گوید: حضرت صادق ع میفرمود: هر گاه ببستر خود رفتی بگو: «بسم اللٰه وضعت جنبی الایمن [للٰه] علی مله ابراهیم حنیفا للٰه مسلما و ما انا من المشرکین»..","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اويت","display":"اَوَيْتَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"فراشك","display":"فِرَاشِكَ"},{"kind":"word","token":"فقل","display":"فَقُلْ"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"وضعت","display":"وَضَعْتُ"},{"kind":"word","token":"جنبي","display":"جَنْبِيَ"},{"kind":"word","token":"الايمن","display":"الْاَيْمَنَ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"مله","display":"مِلَّةِ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمَ"},{"kind":"word","token":"حنيفا","display":"حَنِيفاً"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"مسلما","display":"مُسْلِماً"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المشركين","display":"الْمُشْرِكِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۷۹","display":"۷۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}