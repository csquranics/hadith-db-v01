{"consensus_set_id":"20821","translation_language":"fa","translation_source":{"hid":"406503"},"segments":[{"source_hadith_segment":"« وَجَدْنَا فِي كِتَابِ عَلِيِّ بْنِ الْحُسَيْنِ ( عَلَيْهِ السَّلاَمُ )  :   <quranic_text> « اَلاٰ اِنَّ اَوْلِيٰاءَ اللّٰهِ لاٰ خَوْفٌ عَلَيْهِمْ وَ لاٰ هُمْ يَحْزَنُونَ » </quranic_text>   <footnote> [ يونس ۶۲ ] </footnote> قَالَ :  اِذَا اَدَّوْا فَرَائِضَ اللَّهِ ،  وَ اَخَذُوا بِسُنَنِ رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  ،  وَ تَوَرَّعُوا عَنْ مَحَارِمِ اللَّهِ ،  وَ زَهِدُوا فِي عَاجِلِ زَهْرَةِ الدُّنْيَا ،  وَ رَغِبُوا فِيمَا عِنْدَ اللَّهِ ،  وَ اِكْتَسَبُوا الطَّيِّبَ مِنْ رِزْقِ اللَّهِ ،  لاَ يُرِيدُونَ بِهِ التَّفَاخُرَ وَ التَّكَاثُرَ ،  ثُمَّ اَنْفَقُوا فِيمَا يَلْزَمُهُمْ مِنْ حُقُوقٍ وَاجِبَةٍ ،  فَاُولَئِكَ الَّذِينَ بَارَكَ اللَّهُ لَهُمْ فِيمَا اِكْتَسَبُوا ،  وَ يُثَابُونَ عَلَي مَا قَدَّمُوا لِاخِرَتِهِمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"وجدنا","display":"وَجَدْنَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتاب","display":"كِتَابِ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الا","display":"اَلاٰ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اولياء","display":"اَوْلِيٰاءَ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"خوف","display":"خَوْفٌ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يحزنون","disp