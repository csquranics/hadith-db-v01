{"consensus_set_id":"23171","translation_language":"fa","translation_source":{"hid":"404513"},"segments":[{"source_hadith_segment":"« مَا كَانَ اللَّهُ لِيَفْتَحَ بَابَ الدُّعَاءِ وَ يُغْلِقَ بَابَ الْاِجَابَةِ ،  لِاَنَّهُ يَقُولُ :   <quranic_text> « اُدْعُونِي اَسْتَجِبْ لَكُمْ » </quranic_text>   <footnote> [ غافر ۶۰ ] </footnote> ،  وَ مَا كَانَ لِيَفْتَحَ بَابَ التَّوْبَةِ وَ يُغْلِقَ بَابَ الْمَغْفِرَةِ ،  وَ هُوَ يَقُولُ :   <quranic_text> « وَ مَنْ يَعْمَلْ سُوءاً اَوْ يَظْلِمْ نَفْسَهُ ثُمَّ يَسْتَغْفِرِ اللّٰهَ يَجِدِ اللّٰهَ غَفُوراً رَحِيماً » </quranic_text>   <footnote> [ النساء ۱۱۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"وقال","display":"وقال"},{"kind":"word","token":"صلي","display":"صلى"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"واله","display":"وآله"},{"kind":"word","token":"وسلم","display":"وسلم"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عبد","display":"عَبْدٍ"},{"kind":"word","token":"اذنب","display":"اَذْنَبَ"},{"kind":"word","token":"ذنبا","display":"ذَنْباً"},{"kind":"word","token":"فقام","display":"فَقَامَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"توضا","display":"تَوَضَّاَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"استغفر","display":"اِسْتَغْفَرَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ذنبه","display":"ذَنْبِهِ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"حقيقا","display":"حَقِيقاً"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"ليفتح","display":"لِيَفْتَحَ"},{"kind":"w