{"consensus_set_id":"s406600","translation_language":"fa","translation_source":{"hid":"406600"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا الْحَسَنِ ( عَلَيْهِ السَّلاَمُ ) عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « اَ فَمَنْ كٰانَ عَليٰ بَيِّنَةٍ مِنْ رَبِّهِ وَ يَتْلُوهُ شٰاهِدٌ مِنْهُ » </quranic_text>   <footnote> [ هود ۱۷ ] </footnote>   .  فَقَالَ :  «  اَمِيرُ الْمُؤْمِنِينَ ( صَلَوَاتُ اللَّهِ عَلَيْهِ ) الشَّاهِدُ مِنْ رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  ،  وَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) عَلَي بَيِّنَةٍ مِنْ رَبِّهِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"بينه","display":"بَيِّنَةٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يتلوه","display":"يَتْلُوهُ"},{"kind":"word","token":"شاهد","display":"شٰاهِدٌ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"هود","display":"هود"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"