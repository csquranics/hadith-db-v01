{"consensus_set_id":"92179","translation_language":"fa","translation_source":{"hid":"310160"},"segments":[{"source_hadith_segment":"عَنْ اَبِيهِ عَلَيْهِ السَّلاَمُ قَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فِي بَعْضِ خُطَبِهِ","translation_segment":"حدیث کرد ما را محمد بن حسن بن احمد بن ولید (رضی) گفت که حدیث کردند ما را محمد بن حسن صفار و سعد بن عبد اللٰه هر دو از احمد بن محمد بن عیسی و هیثم بن ابی","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"بعض","display":"بَعْضِ"},{"kind":"word","token":"خطبه","display":"خُطَبِهِ"}]},{"source_hadith_segment":":  الْحَمْدُ لِلَّهِ الَّذِي كَانَ فِي اَوَّلِيَّتِهِ وَحْدَانِيّاً وَ فِي اَزَلِيَّتِهِ مُتَعَظِّماً بِالْاِلَهِيَّةِ مُتَكَبِّراً بِكِبْرِيَائِهِ وَ جَبَرُوتِهِ اِبْتَدَاَ مَا اِبْتَدَعَ وَ اَنْشَاَ مَا خَلَقَ عَلَي غَيْرِ مِثَالٍ","translation_segment":"مسروق نهدی و محمد بن حسین بن ابی الخطاب همه ایشان از حسن بن محبوب از عمرو بن ابی المقدام از اسحق بن غالب از حضرت امام جعفر صادق از پدرش علیهما السلم که فرمود رسول خدا (صلی الله علیه و آله) در بعضی از خطبه‌های خویش فرمود که سپاس و ستایش خدائی را سزا است که در اولویت خود تنها بوده و در ازلیتش بالهیت و خدائی بزرگی","segment_columns":[{"kind":"word","token":"الحمد","display":"الْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"الذي","display":"ال