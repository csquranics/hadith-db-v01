{"consensus_set_id":"s297801","translation_language":"fa","translation_source":{"hid":"297801"},"segments":[{"source_hadith_segment":"اِذَا جَاءَكُمْ مَنْ تَرْضَوْنَ دِينَهُ وَ اَمَانَتَهُ يَخْطُبُ اِلَيْكُمْ فَزَوِّجُوهُ اِلاَّ تَفْعَلُوا  <quranic_text> « تَكُنْ فِتْنَةٌ فِي الْاَرْضِ » </quranic_text>   <footnote> [ الانفال ۷۳ ] </footnote>  وَ فَسَادٌ عَرِيضٌ .","translation_segment":"با همان سند رسول خدا فرمودند: هرگاه کسی به خواستگاری [دخترتان] آمد که از دین و امانتداری او خرسند بودید به او زن بدهید که اگر نکنید در زمین آشوب و تباهی‌ای گسترده پدید می‌آید.","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"جاءكم","display":"جَاءَكُمْ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"ترضون","display":"تَرْضَوْنَ"},{"kind":"word","token":"دينه","display":"دِينَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امانته","display":"اَمَانَتَهُ"},{"kind":"word","token":"يخطب","display":"يَخْطُبُ"},{"kind":"word","token":"اليكم","display":"اِلَيْكُمْ"},{"kind":"word","token":"فزوجوه","display":"فَزَوِّجُوهُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"تفعلوا","display":"تَفْعَلُوا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"تكن","display":"تَكُنْ"},{"kind":"word","token":"فتنه","display":"فِتْنَةٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۷۳","display":"۷۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فساد","display":"فَسَادٌ"},{"kind":"word","token":"عريض","display":"عَرِيضٌ"}]}]}