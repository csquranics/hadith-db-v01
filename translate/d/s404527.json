{"consensus_set_id":"s404527","translation_language":"fa","translation_source":{"hid":"404527"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « فَلَيُبَتِّكُنَّ اذٰانَ الْاَنْعٰامِ » </quranic_text>   <footnote> [ النساء ۱۱۹ ] </footnote>  قِيلَ :  لِيَقْطَعُوا الْاذَانَ مِنْ اَصْلِهَا .  قَالَ :  وَ هُوَ الْمَرْوِيُّ عَنْ اَبِي عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ ) .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فليبتكن","display":"فَلَيُبَتِّكُنَّ"},{"kind":"word","token":"اذان","display":"اذٰانَ"},{"kind":"word","token":"الانعام","display":"الْاَنْعٰامِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۱۹","display":"۱۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"ليقطعوا","display":"لِيَقْطَعُوا"},{"kind":"word","token":"الاذان","display":"الْاذَانَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اصلها","display":"اَصْلِهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"المروي","display":"الْمَرْوِيُّ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}