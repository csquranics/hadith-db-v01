{"consensus_set_id":"31893","translation_language":"fa","translation_source":{"hid":"350902"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ  <quranic_text> « حَتّٰي اِذٰا جٰاءَ اَمْرُنٰا وَ فٰارَ التَّنُّورُ » </quranic_text>   <footnote> [ هود ۴۰ ] </footnote>  فَقَالَ اَمَا وَ اللَّهِ مَا هُوَ تَنُّورُ الْخُبْزِ ثُمَّ اَوْمَاَ بِيَدِهِ اِلَي الشَّمْسِ فَقَالَ طُلُوعِهَا .","translation_segment":"اعمش گوید: در روایتی مرفوع امیر مومنان علی علیه السلام درباره آیه «حتٰی إذٰا جٰاء أمرنٰا و فٰار التنور؛ هنگامی که فرمان ما آمد و آن تنور جوشید» فرموده است: به خدا سوگند مقصود از آن، تنور پخت نان نیست. آنگاه با دستانش به خورشید اشاره نمود و فرمود: مقصود از آن طلوع خورشید است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"جاء","display":"جٰاءَ"},{"kind":"word","token":"امرنا","display":"اَمْرُنٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فار","display":"فٰارَ"},{"kind":"word","token":"التنور","display":"التَّنُّورُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"هود","display":"هود"},{"kind":"word","token":"۴۰","display":"۴۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"اما","display":"اَمَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"تنور","display":"تَنُّورُ"},{"kind":"word","token":"الخبز","display":"الْخُبْزِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اوما","display":"اَوْمَاَ"},{"kind":"word","token":"بيده","display":"بِيَدِهِ"},{"k