َيْهِ وَ عَليٰ اِسْحٰاقَ  » </quranic_text>   <footnote> [ الصافات ۱۱۲ ] </footnote>  يَعْنِي بِذَلِكَ اِسْمَاعِيلَ قَبْلَ الْبِشَارَةِ بِاِسْحَاقَ فَمَنْ زَعَمَ اَنَّ اِسْحَاقَ اَكْبَرُ مِنْ اِسْمَاعِيلَ وَ اَنَّ الذَّبِيحَ اِسْحَاقُ فَقَدْ كَذَّبَ بِمَا اَنْزَلَ اللَّهُ عَزَّ وَ جَلَّ فِي الْقُرْانِ مِنْ نَبَئِهِمَا .","translation_segment":"السلام فرمود: سپس خداوند فرموده: «و بشرنٰاه‌ بإسحٰاق‌ نبیا من‌ الصٰالحین‌`و بٰارکنٰا علیه‌ و علیٰ‌ إسحٰاق‌» (و مژده دادیم او را به اسحاق که پیغمبری باشد از شایستگان، و برکت دادیم بر او و بر اسحاق-صافات ۱۱۲:۳۷» از آن قصد فرموده اسماعیل را، پیش از مژده دادن به اسحاق. پس هر کس که بپندارد، اسحاق بزرگتر است از اسماعیل، و اینکه ذبیح اسحاق بوده، تکذیب نموده است آنچه را خداوند عز و جل‌ در قرآن راجع به آن دو فرموده است.","segment_columns":[{"kind":"word","token":"عظيم","display":"عَظِيمٍ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بشرناه","display":"بَشَّرْنٰاهُ"},{"kind":"word","token":"باسحاق","display":"بِاِسْحٰاقَ"},{"kind":"word","token":"نبيا","display":"نَبِيًّا"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الصالحين","display":"الصّٰالِحِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"باركنا","display":"بٰارَكْنٰا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"اسحاق","display":"اِسْحٰاقَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open"