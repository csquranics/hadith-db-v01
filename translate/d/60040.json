{"consensus_set_id":"60040","translation_language":"fa","translation_source":{"hid":"331853"},"segments":[{"source_hadith_segment":"اِنِّي اُقْسِمُ بِالَّذِي فَلَقَ الْحَبَّةَ وَ بَرَاَ النَّسَمَةَ - وَ اَنْزَلَ الْكِتَابَ عَلَي مُحَمَّدٍ صِدْقاً وَ عَدْلاً","translation_segment":"عن حنش أن علیا ع قال: إنی أقسم بالذی فلق الحبه و برأ النسمه و أنزل الکتاب علی محمد صدقا و عدلا لتعطفن‌ علیکم هذه الآیه: (وعد الله الذین آمنوا","segment_columns":[{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"اقسم","display":"اُقْسِمُ"},{"kind":"word","token":"بالذي","display":"بِالَّذِي"},{"kind":"word","token":"فلق","display":"فَلَقَ"},{"kind":"word","token":"الحبه","display":"الْحَبَّةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"برا","display":"بَرَاَ"},{"kind":"word","token":"النسمه","display":"النَّسَمَةَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صدقا","display":"صِدْقاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عدلا","display":"عَدْلاً"}]},{"source_hadith_segment":"- لَتَعْطِفَنَّ عَلَيْكُمْ هَذِهِ الْايَةُ :   <quranic_text> « وَعَدَ اللّٰهُ الَّذِينَ امَنُوا مِنْكُمْ وَ عَمِلُوا الصّٰالِحٰاتِ - لَيَسْتَخْلِفَنَّهُمْ فِي الْاَرْضِ » </quranic_text>   <footnote> [ النور ۵۵ ] </footnote>  الْايَةَ .","translation_segment":"و عملوا الصالحات لیستخلفنهم فی الأرض). حنش گفت: علی گفت: همانا من به کسی که دانه را شکافت و انسان را آفرید و کتاب را بر اساس راستی و عدل بر محمد نازل کرد، سوگند می‌خورم که (وعده) این آیه بر شما خواهد آمد: «وعد الله الذین آمنوا و عملوا الصالحات لیستخلفنهم فی الارض»","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لتعطفن","display":"لَتَعْطِفَنَّ"},{"kind":"word","token":"عليكم","d