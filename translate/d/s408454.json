{"consensus_set_id":"s408454","translation_language":"fa","translation_source":{"hid":"408454"},"segments":[{"source_hadith_segment":"اَنَّهُ سَاَلَ اَبَاهُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « فَمَنِ اِتَّبَعَ هُدٰايَ فَلاٰ يَضِلُّ وَ لاٰ يَشْقيٰ » </quranic_text>   <footnote> [ طه ۱۲۳ ] </footnote>   .  قَالَ :","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"اباه","display":"اَبَاهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمن","display":"فَمَنِ"},{"kind":"word","token":"اتبع","display":"اِتَّبَعَ"},{"kind":"word","token":"هداي","display":"هُدٰايَ"},{"kind":"word","token":"فلا","display":"فَلاٰ"},{"kind":"word","token":"يضل","display":"يَضِلُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يشقي","display":"يَشْقيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"طه","display":"طه"},{"kind":"word","token":"۱۲۳","display":"۱۲۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« قَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :  يَا اَيُّهَا النَّاسُ ،  اِتَّبِعُوا هُدَي اللَّهِ تَهْتَدُوا وَ تَرْشُدُوا ،  وَ هُوَ هُدَايَ ،  وَ هُدَايَ هُدَي عَلِيِّ بْنِ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ ) ،  فَمَنِ اِتَّبَعَ هُدَاهُ فِي حَيَاتِي وَ بَعْدَ مَوْتِي فَقَدِ اِتَّبَعَ هُدَايَ ،  وَ مَنِ اِتَّبَعَ هُدَايَ فَقَدِ اِتَّبَعَ هُدَي اللَّهِ ،  وَ مَنِ اِتَّبَعَ هُدَي اللَّهِ فَلاَ يَضِلُّ وَ لاَ يَشْقَي ،  قَالَ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مَنْ اَعْرَضَ عَنْ ذِكْرِي فَاِنَّ لَهُ مَعِيشَةً ضَنْكاً وَ نَحْشُرُهُ يَوْمَ الْقِيٰامَةِ اَعْميٰ قٰالَ رَبِّ لِمَ حَشَرْتَنِي اَعْميٰ وَ قَدْ كُنْتُ بَصِيراً قٰالَ كَذٰلِكَ اَتَتْكَ ايٰاتُنٰا فَنَسِيتَهٰا وَ كَذٰلِكَ الْيَوْمَ تُنْسيٰ وَ كَذٰلِكَ نَجْزِي مَنْ اَسْرَفَ » </quranic_text>   <footnote> [ طه ۱۲۴ ] </footnote> فِي عَدَاوَةِ مُحَمَّدٍ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،   <quranic_text> « وَ لَمْ يُؤْمِنْ بِايٰاتِ رَبِّهِ وَ لَعَذٰابُ الْاخِرَةِ اَشَدُّ وَ اَبْقيٰ » </quranic_text>   <footnote> [ طه ۱۲۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"اتبعوا","display":"اِتَّبِعُوا"},{"kind":"word","token":"هدي","display":"هُدَي"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تهتدوا","display":"تَهْتَدُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ترشدوا","display":"تَرْشُدُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"هداي","display":"هُدَايَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هداي","display":"هُدَايَ"},{"kind":"word","token":"هدي","display":"هُدَي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ