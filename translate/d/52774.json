{"consensus_set_id":"52774","translation_language":"fa","translation_source":{"hid":"381989"},"segments":[{"source_hadith_segment":"اَمَّا بَعْدُ فَاِنَّ عَيْنِي بِالْمَغْرِبِ كَتَبَ اِلَيَّ يُعْلِمُنِي اَنَّهُ وُجِّهَ اِلَي الْمَوْسِمِ اُنَاسٌ مِنْ اَهْلِ الشَّامِ الْعُمْيِ الْقُلُوبِ الصُّمِّ الْاَسْمَاعِ الْكُمْهِ الْاَبْصَارِ الَّذِينَ يَلْبِسُونَ  <quranic_text> « الْحَقَّ بِالْبَاطِلِ » </quranic_text>   <footnote> [ البقرة ۴۲ ] </footnote>  وَ يُطِيعُونَ الْمَخْلُوقَ فِي مَعْصِيَةِ الْخَالِقِ وَ يَحْتَلِبُونَ الدُّنْيَا دَرَّهَا بِالدِّينِ وَ يَشْتَرُونَ عَاجِلَهَا بِاجِلِ الْاَبْرَارِ الْمُتَّقِينَ وَ لَنْ يَفُوزَ بِالْخَيْرِ اِلاَّ عَامِلُهُ وَ لاَ يُجْزَي جَزَاءَ الشَّرِّ اِلاَّ فَاعِلُهُ فَاَقِمْ عَلَي مَا فِي يَدَيْكَ قِيَامَ الْحَازِمِ الصَّلِيبِ وَ النَّاصِحِ اللَّبِيبِ التَّابِعِ لِسُلْطَانِهِ الْمُطِيعِ لِاِمَامِهِ وَ اِيَّاكَ وَ مَا يُعْتَذَرُ مِنْهُ وَ لاَ تَكُنْ عِنْدَ النَّعْمَاءِ بَطِراً وَ لاَ عِنْدَ الْبَاْسَاءِ فَشِلاً وَ السَّلاَمُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"بعد","display":"بَعْدُ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"عيني","display":"عَيْنِي"},{"kind":"word","token":"بالمغرب","display":"بِالْمَغْرِبِ"},{"kind":"word","token":"كتب","display":"كَتَبَ"},{"kind":"word","token":"الي","display":"اِلَيَّ"},{"kind":"word","token":"يعلمني","display":"يُعْلِمُنِي"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"وجه","display":"وُجِّهَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الموسم","display":"الْمَوْسِمِ"},{"kind":"word","token":"اناس","display":"اُنَاسٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الشام","display":"الشَّامِ"},{"kind":"word","token":"العمي","display":"الْعُمْيِ"},{"kind":"word","token":"القلوب","display":"الْقُلُوبِ"},{"kind":"word","token":"الصم","display":"الصُّمِّ"},{