{"consensus_set_id":"22912","translation_language":"fa","translation_source":{"hid":"104026"},"segments":[{"source_hadith_segment":"اِذَا بَلَغَتِ النَّفْسُ هَاهُنَا وَ اَشَارَ بِيَدِهِ اِلَي حَلْقِهِ لَمْ يَكُنْ لِلْعَالِمِ تَوْبَةٌ ثُمَّ قَرَاَ  <quranic_text> « اِنَّمَا التَّوْبَةُ عَلَي اللّٰهِ لِلَّذِينَ يَعْمَلُونَ السُّوءَ بِجَهٰالَةٍ » </quranic_text>   <footnote> [ النساء ۱۷ ] </footnote>   .","translation_segment":"و حضرت صادق ع فرمود، چون جان باینجا رسد - با دست بگلویش اشاره کرد - برای عالم توبه‌ای نیست سپس این آیه را قرائت فرمود (۱۷ سوره ۴) قبول توبه بر خدا فقط‍‌ نسبت بکسانی است که از روی نادانی بدی میکنند.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سمعت","display":"سمعت"},{"kind":"word","token":"ابا","display":"أبا"},{"kind":"word","token":"عبد","display":"عبد"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السلام"},{"kind":"word","token":"يقول","display":"يقول"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"بلغت","display":"بَلَغَتِ"},{"kind":"word","token":"النفس","display":"النَّفْسُ"},{"kind":"word","token":"هاهنا","display":"هَاهُنَا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اشار","display":"اَشَارَ"},{"kind":"word","token":"بيده","display":"بِيَدِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"حلقه","display":"حَلْقِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"للعالم","display":"لِلْعَالِمِ"},{"kind":"word","token":"توبه","display":"تَوْبَةٌ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"التوبه","dis