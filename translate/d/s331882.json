{"consensus_set_id":"s331882","translation_language":"fa","translation_source":{"hid":"331882"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اَ فَمَنْ وَعَدْنٰاهُ وَعْداً حَسَناً فَهُوَ لاٰقِيهِ » </quranic_text>   <footnote> [ القصص ۶۱ ] </footnote>  قَالَ :  نَزَلَتْ فِي عَلِيٍّ وَ حَمْزَةَ .   <quranic_text> « كَمَنْ مَتَّعْنٰاهُ مَتٰاعَ الْحَيٰاةِ الدُّنْيٰا » </quranic_text>   <footnote> [ القصص ۶۱ ] </footnote>  يَعْنِي اَبَا جَهْلٍ .","translation_segment":"أبان بن تغلب از مجاهد در باره آیه شریفه «أ فمن‌ وعدنٰاه‌ وعدا حسنا فهو لاٰقیه‌» …گفت؛ این آیه در شأن علی علیه السلام و حمزه نازل شد که پیوسته مورد لطف و عنایت خدای سبحان هستند، و در این آیه وعده نیکو به آنان داده است. و ادامه آیه «کمن‌ متعنٰاه‌ متٰاع‌ الحیٰاه‌ الدنیٰا» در مذمت ابو جهل و توبیخ او نازل شده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"وعدناه","display":"وَعَدْنٰاهُ"},{"kind":"word","token":"وعدا","display":"وَعْداً"},{"kind":"word","token":"حسنا","display":"حَسَناً"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"لاقيه","display":"لاٰقِيهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۶۱","display":"۶۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حمزه","display":"حَمْزَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كمن","display":"كَمَنْ"},{"ki