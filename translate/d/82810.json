{"consensus_set_id":"82810","translation_language":"fa","translation_source":{"hid":"225739"},"segments":[{"source_hadith_segment":"وَ اَبِي جَعْفَرٍ عَلَيْهِمَا السَّلاَمُ قَالاَ :  الْمُصِيبَةُ هِيَ الْخَسْفُ وَ اللَّهِ بِالْفَاسِقِينَ عِنْدَ الْحَوْضِ قَوْلُ اللَّهِ :   <quranic_text> « فَكَيْفَ اِذٰا اَصٰابَتْهُمْ مُصِيبَةٌ » </quranic_text>   <footnote> [ النساء ۶۲ ] </footnote>  الْايَةَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قالا","display":"قَالاَ"},{"kind":"word","token":"المصيبه","display":"الْمُصِيبَةُ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"الخسف","display":"الْخَسْفُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بالفاسقين","display":"بِالْفَاسِقِينَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الحوض","display":"الْحَوْضِ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فكيف","display":"فَكَيْفَ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"اصابتهم","display":"اَصٰابَتْهُمْ"},{"kind":"word","token":"مصيبه","display":"مُصِيبَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۶۲","display":"۶۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"}]}]}