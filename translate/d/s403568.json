{"consensus_set_id":"s403568","translation_language":"fa","translation_source":{"hid":"403568"},"segments":[{"source_hadith_segment":"« اِنَّهُ مَا شُبِّهَ اَمْرُ اَحَدٍ مِنْ اَنْبِيَاءِ اللَّهِ وَ حُجَجِهِ لِلنَّاسِ اِلاَّ اَمْرُ عِيسَي ( عَلَيْهِ السَّلاَمُ ) وَحْدَهُ ،  لِاَنَّهُ رُفِعَ مِنَ الْاَرْضِ حَيّاً وَ قُبِضَ رُوحُهُ بَيْنَ السَّمَاءِ وَ الْاَرْضِ ،  ثُمَّ رُفِعَ اِلَي السَّمَاءِ وَ رُدَّ عَلَيْهِ رُوحُهُ ،  وَ ذَلِكَ قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « اِذْ قٰالَ اللّٰهُ يٰا عِيسيٰ اِنِّي مُتَوَفِّيكَ وَ رٰافِعُكَ اِلَيَّ وَ مُطَهِّرُكَ » </quranic_text>   <footnote> [ العمران ۵۵ ] </footnote>  وَ قَالَ اللَّهُ تَعَالَي حِكَايَةً لِقَوْلِ عِيسَي يَوْمَ الْقِيَامَةِ : <quranic_text> « وَ كُنْتُ عَلَيْهِمْ شَهِيداً مٰا دُمْتُ فِيهِمْ فَلَمّٰا تَوَفَّيْتَنِي كُنْتَ اَنْتَ الرَّقِيبَ عَلَيْهِمْ وَ اَنْتَ عَليٰ كُلِّ شَيْءٍ شَهِيدٌ » </quranic_text>   <footnote> [ المائدة ۱۱۷ ] </footnote> .","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"شبه","display":"شُبِّهَ"},{"kind":"word","token":"امر","display":"اَمْرُ"},{"kind":"word","token":"احد","display":"اَحَدٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"انبياء","display":"اَنْبِيَاءِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حججه","display":"حُجَجِهِ"},{"kind":"word","token":"للناس","display":"لِلنَّاسِ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"امر","display":"اَمْرُ"},{"kind":"word","token":"عيسي","display":"عِيسَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"وحده","display":"وَحْدَهُ"},{"kind":"word","token":"لانه","display":"لِاَنَّهُ"},{"kind":"word","token":"رفع","display":"رُفِعَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الارض",