{"consensus_set_id":"7850","translation_language":"fa","translation_source":{"hid":"404566"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ :   <quranic_text> « وَ قَدْ نَزَّلَ عَلَيْكُمْ فِي الْكِتٰابِ اَنْ اِذٰا سَمِعْتُمْ ايٰاتِ اللّٰهِ يُكْفَرُ بِهٰا وَ يُسْتَهْزَاُ بِهٰا » </quranic_text>   <footnote> [ النساء ۱۴۰ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « اِنَّكُمْ اِذاً مِثْلُهُمْ » </quranic_text>   <footnote> [ النساء ۱۴۰ ] </footnote>   .  قَالَ :  « اِذَا سَمِعْتَ الرَّجُلَ يَجْحَدُ الْحَقَّ وَ يُكَذِّبُ بِهِ وَ يَقَعُ فِي اَهْلِهِ فَقُمْ مِنْ عِنْدِهِ وَ لاَ تُقَاعِدْهُ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"نزل","display":"نَزَّلَ"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"سمعتم","display":"سَمِعْتُمْ"},{"kind":"word","token":"ايات","display":"ايٰاتِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"يكفر","display":"يُكْفَرُ"},{"kind":"word","token":"بها","display":"بِهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يستهزا","display":"يُسْتَهْزَاُ"},{"kind":"word","token":"بها","display":"بِهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۴۰","display":"۱۴۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قول