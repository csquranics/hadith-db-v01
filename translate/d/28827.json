{"consensus_set_id":"28827","translation_language":"fa","translation_source":{"hid":"108628"},"segments":[{"source_hadith_segment":"اَمَّا اَطْفَالُ الْمُؤْمِنِينَ فَيَلْحَقُونَ بِابَائِهِمْ وَ اَوْلاَدُ الْمُشْرِكِينَ يَلْحَقُونَ بِابَائِهِمْ وَ هُوَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « بِاِيمٰانٍ اَلْحَقْنٰا بِهِمْ ذُرِّيَّتَهُمْ » </quranic_text>   <footnote> [ الطور ۲۱ ] </footnote>   .","translation_segment":"در حدیث دیگری امام علیه السلام فرمود: کودکان مومنان به پدران خود و فرزندان مشرکان نیز به پدران خود ملحق خواهند شد و این است معنای گفتار خداوند متعال که می‌فرماید: «فرزندان مومنان را به آنها ملحق خواهیم کرد».","segment_columns":[{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"اطفال","display":"اَطْفَالُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"فانهم","display":"فَاِنَّهُمْ"},{"kind":"word","token":"فيلحقون","display":"فَيَلْحَقُونَ"},{"kind":"word","token":"بابائهم","display":"بِابَائِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اولاد","display":"اَوْلاَدُ"},{"kind":"word","token":"المشركين","display":"الْمُشْرِكِينَ"},{"kind":"word","token":"يلحقون","display":"يَلْحَقُونَ"},{"kind":"word","token":"بابائهم","display":"بِابَائِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بايمان","display":"بِاِيمٰانٍ"},{"kind":"word","token":"الحقنا","display":"اَلْحَقْنٰا"},{"kind":"word","token":"بهم","display":"بِهِمْ"},{"kind":"word","token":"ذريتهم","display":"ذُرِّيَّتَهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"k