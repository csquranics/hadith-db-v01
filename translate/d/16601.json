{"consensus_set_id":"16601","translation_language":"fa","translation_source":{"hid":"107585"},"segments":[{"source_hadith_segment":"عَطَسَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ فَقَالَ :   <quranic_text> « اَلْحَمْدُ لِلّٰهِ رَبِّ الْعٰالَمِينَ » </quranic_text>   <footnote> [ الفاتحة ۲ ] </footnote>  ثُمَّ جَعَلَ اِصْبَعَهُ عَلَي اَنْفِهِ فَقَالَ رَغِمَ اَنْفِي لِلَّهِ رَغْماً دَاخِراً .","translation_segment":"مسمع بن عبد الملک گوید: حضرت صادق ع عطسه زد پس فرمود: «الحمد للٰه رب العالمین.» سپس انگشتش را بر بینی نهاد و فرمود: «رغم انفی للٰه رغما داخرا». (یعنی بینی من برای خدا بزبونی بر خاک است).","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عطس","display":"عَطَسَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحمد","display":"اَلْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"رب","display":"رَبِّ"},{"kind":"word","token":"العالمين","display":"الْعٰالَمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"جعل","display":"جَعَلَ"},{"kind":"word","token":"اصبعه","display":"اِصْبَعَهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"انفه","display":"اَنْفِهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"رغم","display":"رَغِمَ"},{"kind":"word","token":"انفي","display":"اَنْفِي"},{"kind":"word","token":"لله","display":"لِلّ