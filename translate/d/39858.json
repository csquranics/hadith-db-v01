{"consensus_set_id":"39858","translation_language":"fa","translation_source":{"hid":"404051"},"segments":[{"source_hadith_segment":"اَخْبِرْنِي عَمَّنْ تَزَوَّجَ عَلَي اَكْثَرَ مِنْ مَهْرِ السُّنَّةِ ،  اَ يَجُوزُ لَهُ ذَلِكَ ؟  قَالَ :  « اِنْ جَازَ مَهْرُ السُّنَّةِ فَلَيْسَ هَذَا مَهْراً ،  اِنَّمَا هُوَ نَحْلٌ ،  لِاَنَّ اللَّهَ يَقُولُ :   <quranic_text> « وَ اتَيْتُمْ اِحْدٰاهُنَّ قِنْطٰاراً فَلاٰ تَاْخُذُوا مِنْهُ شَيْئاً » </quranic_text>   <footnote> [ النساء ۲۰ ] </footnote> اِنَّمَا عَنَي النَّحْلَ وَ لَمْ يَعْنِ الْمَهْرَ ،  اَ لاَ تَرَي اَنَّهَا اِذَا اَمْهَرَهَا مَهْراً ثُمَّ اِخْتَلَعَتْ ،  كَانَ لَهُ اَنْ يَاْخُذَ الْمَهْرَ كَامِلاً ،  فَمَا زَادَ عَلَي مَهْرِ السُّنَّةِ فَاِنَّمَا هُوَ نَحْلٌ كَمَا اَخْبَرْتُكَ ،  فَمِنْ ثَمَّ وَجَبَ لَهَا مَهْرُ نِسَائِهَا لِعِلَّةٍ مِنَ الْعِلَلِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اخبرني","display":"اَخْبِرْنِي"},{"kind":"word","token":"عمن","display":"عَمَّنْ"},{"kind":"word","token":"تزوج","display":"تَزَوَّجَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اكثر","display":"اَكْثَرَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"مهر","display":"مَهْرِ"},{"kind":"word","token":"السنه","display":"السُّنَّةِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"يجوز","display":"يَجُوزُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"جاز","display":"جَازَ"},{"kind":"word","token":"مهر","display":"مَهْرُ"},{"kind":"word","token":"السنه","display":"الس