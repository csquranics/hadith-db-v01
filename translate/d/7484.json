{"consensus_set_id":"7484","translation_language":"fa","translation_source":{"hid":"338799"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ فَقُلْتُ لَهُ كَيْفَ صَارَ الْمِيرَاثُ  <quranic_text> « لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>","translation_segment":"علی بن احمد بن محمد رضی اللٰه عنه، از محمد بن ابی عبد اللٰه کوفی از موسی بن عمران نخعی از عمویش حسین بن یزید از علی بن سالم، از پدرش نقل کرده که وی گفت: از","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"صار","display":"صَارَ"},{"kind":"word","token":"الميراث","display":"الْمِيرَاثُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"للذكر","display":"لِلذَّكَرِ"},{"kind":"word","token":"مثل","display":"مِثْلُ"},{"kind":"word","token":"حظ","display":"حَظِّ"},{"kind":"word","token":"الانثيين","display":"الْاُنْثَيَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۱","display":"۱۱"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"فَقَالَ لِاَنَّ الْحَبَّاتِ الَّتِي اَكَلَهَا ادَمُ وَ حَوَّاءُ فِي الْجَنَّةِ كَانَتْ ثَمَانِيَةَ عَشَرَ اَكَلَ ادَمُ مِنْهَا اِثْنَتَيْ عَشْرَةَ حَبَّةً وَ اَكَلَتْ حَوَّاءُ سِتّاً فَلِذَلِكَ صَارَ الْمِيرَاثُ  <quranic_text> « لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>   .","translation_segment":"حضرت ابا عبد اللٰه علیه السلام سوال کرده و محضرش عرض کردم: چگونه میراث هر مذکری دو برابر میراث مونث گردیده است‌؟ حضرت فرمودند: به خاطر آنکه حبه‌هایی که آدم و حوا در بهشت از آنها تناول کردند هیجده حبه بود، آدم علیه السلام دوازده تا و حوا شش تا از آن را خورد لذا میراث مذکر دو برابر مونث گردید.","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الحبات","display":"الْحَبَّاتِ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"اكلها","display":"اَكَلَهَا"},{"kind":"word","token":"منها","display":"مِنْهَا"},{"kind":"word","token":"ادم","display":"ادَمُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حواء","display":"حَوَّاءُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"ثمانيه","display":"ثَمَانِيَةَ"},{"kind":"word","token":"عشر","display":"عَشَرَ"},{"kind":"word","token":"حبه","display":"حَبَّةً"},{"kind":"word","token":"اكل","display":"اَكَلَ"},{"kind":"word","token":"منها","display":"منها"},{"kind":"word","token":"ادم","display":"ادَمُ"},{"kind":"word","token":"منها","display":"مِنْهَا"},{"kind":"word","token":"اثنتي","display":"اِثْنَتَيْ"},{"kind":"word","token":"عشره","display":"عَشْرَةَ"},{"kind":"word","token":"حبه","display":"حَبَّةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اكلت","display":"اَكَلَتْ"},{"kind":"word","token":"حواء","display":"حَوَّاءُ"},{"kind":"word","token":"ستا","display":"سِتّاً"},{"kind":"word","token":"فلذلك","display":"فَلِذَلِكَ"},{"kind":"word","token":"صار","display":"صَارَ"},{"kind":"word","token":"الميراث","display":"الْمِيرَاثُ"},{"kind":"ta