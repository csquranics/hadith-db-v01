{"consensus_set_id":"8688","translation_language":"fa","translation_source":{"hid":"104917"},"segments":[{"source_hadith_segment":"لَوْ اَنَّ قَوْماً عَبَدُوا اللَّهَ وَحْدَهُ لاَ شَرِيكَ لَهُ وَ اَقَامُوا الصَّلاَةَ وَ اتَوُا الزَّكَاةَ وَ حَجُّوا الْبَيْتَ وَ صَامُوا شَهْرَ رَمَضَانَ ثُمَّ قَالُوا لِشَيْءٍ صَنَعَهُ اللَّهُ اَوْ صَنَعَهُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَلاَّ صَنَعَ خِلاَفَ الَّذِي صَنَعَ اَوْ وَجَدُوا ذَلِكَ فِي قُلُوبِهِمْ لَكَانُوا بِذَلِكَ مُشْرِكِينَ","translation_segment":"امام صادق ع فرمود: اگر مردمی خدای یگانه بی‌شریک را عبادت کنند و نماز گزارند و زکاه دهند و حج خانه خدا بجا آرند و ماه رمضان را روزه دارند، و پس از همه اینها نسبت بچیزی که خدا یا رسولش کرده بگویند: چرا بر خلاف این نکرد؟ یا این معنی را در دل خود احساس کنند (بی‌آنکه بزبان آورند)","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"ابو","display":"أبو"},{"kind":"word","token":"عبد","display":"عبد"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السلام"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"قوما","display":"قَوْماً"},{"kind":"word","token":"عبدوا","display":"عَبَدُوا"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"وحده","display":"وَحْدَهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"شريك","display":"شَرِيكَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اقاموا","display":"اَقَامُوا"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتوا","display":"اتَوُا"},{"kind":"word","token":"الزكاه","display":"الزَّكَاةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حجوا","display":"حَجُّوا"},{"kind":"word","token":"البيت","display":"الْبَيْتَ"},{"kind