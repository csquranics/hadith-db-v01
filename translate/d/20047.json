يعِ مَا فِيهِ .","translation_segment":"و (در برابر دشمنان خدا و هوای نفس) پایداری کنند و (جان خود و اسبان خویش را) در مرزها و سرحدها به بندند و از خدا پروا کنند. و خدا (در مقابل این امور) بآنها وعده فرمود که زمین مبارک (مدینه یا بیت المقدس) و حرم امن (مکه) را تسلیمشان کند و بیت المعمور (فرشتگان یا خاندان ائمه) را برایشان بیاورد و سقف افراشته (تمام آسمانها و عرش یا برکات آسمان) را بآنها بنمایاند و ایشان را از دشمنشان آسوده کند و هم از آفات زمین که خدا بجهت سلامتی آنها از شرور تبدیل فرموده [و زمینی را که خدا دگرگونش کرده از جمله سلامت است] و آنچه را در زمین است برای آنها سالم دارد و لکه‌ای در آن نباشد - یعنی در زمین ناسازگاری با دشمن وجود نداشته باشد - و هر چه را دوست داشته باشند، در زمین برای آنها موجود باشد. و پیغمبر صلی اللٰه علیه و آله از همه امامان و شیعیانشان این پیمان را گرفت و سلام بر آن حضرت یادآوری این پیمان و تجدید آنست بر خداوند (تا خدا فرستادن سلام را بر آن حضرت تجدید کند) و تا شاید خدای جل و عز در رسیدن وقت این پیمان تعجیل کند و سلامت و سازش را با تمام آنچه در پیمان بود، برای شما بشتاب آماده کند.","segment_columns":[{"kind":"word","token":"شيعتهم","display":"شِيعَتَهُمْ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"الميثاق","display":"الْمِيثَاقَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يصبروا","display":"يَصْبِرُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يصابروا","display":"يُصَابِرُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يرابطوا","display":"يُرَابِطُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتقوا","display":"يَتَّقُوا"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وعدهم","display":"وَعَدَهُمْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يسلم","display":"يُسَلِّمَ"