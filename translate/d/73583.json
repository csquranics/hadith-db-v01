{"consensus_set_id":"73583","translation_language":"fa","translation_source":{"hid":"95110"},"segments":[{"source_hadith_segment":"« لاَ يَحْلِفُ الْيَهُودِيُّ وَ لاَ النَّصْرَانِيُّ وَ لاَ الْمَجُوسِيُّ بِغَيْرِ اللَّهِ اِنَّ اللَّهَ يَقُولُ  <quranic_text> « وَ اَنِ اُحْكُمْ بَيْنَهُمْ بِمٰا اَنْزَلَ اللّٰهُ » </quranic_text>   <footnote> [ المائدة ۴۹ ] </footnote>   .","translation_segment":"* *۵ - ابو عبد الله صادق (ع) گفت: یهودی و نصرانی و مجوسی را جز با نام الله نباید سوگند بدهند. چرا که خداوند عز و جل می‌فرماید: «در میان یهود و نصاری به حکم قرآن داوری کنید».","segment_columns":[{"kind":"word","token":"لام","display":"لام"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يحلف","display":"يَحْلِفُ"},{"kind":"word","token":"اليهودي","display":"الْيَهُودِيُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"النصراني","display":"النَّصْرَانِيُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"المجوسي","display":"الْمَجُوسِيُّ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اَنِ"},{"kind":"word","token":"احكم","display":"اُحْكُمْ"},{"kind":"word","token":"بينهم","display":"بَيْنَهُمْ"},{"kind":"word","token":"بما","display":"بِمٰا"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۴۹","display":"۴۹"},{"kind":"tag_close","