{"consensus_set_id":"82972","translation_language":"fa","translation_source":{"hid":"348802"},"segments":[{"source_hadith_segment":"اَنَّ مَوْلاَنَا زَيْنَ الْعَابِدِينَ وَ هُوَ صَاحِبُ الْمَقَامِ الْمَكِينِ كَانَ اِذَا قَالَ  <quranic_text> « مٰالِكِ يَوْمِ الدِّينِ » </quranic_text>   <footnote> [ الفاتحة ۴ ] </footnote>  يُكَرِّرُهَا فِي قِرَاءَتِهِ حَتَّي يَظُنَّ مَنْ يَرَاهُ اَنَّهُ قَدْ اَشْرَفَ عَلَي مَمَاتِهِ .","translation_segment":"در خبر آمده است که امام سجاد علیه السلام چون به جمله «مٰالک‌ یوم‌ الدین‌» می‌رسید، به قدری آن را تکرار می‌کرد که هرکس او را می‌دید، گمان می‌کرد در شرف مرگ است.","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"مولانا","display":"مَوْلاَنَا"},{"kind":"word","token":"زين","display":"زَيْنَ"},{"kind":"word","token":"العابدين","display":"الْعَابِدِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"صاحب","display":"صَاحِبُ"},{"kind":"word","token":"المقام","display":"الْمَقَامِ"},{"kind":"word","token":"المكين","display":"الْمَكِينِ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"مالك","display":"مٰالِكِ"},{"kind":"word","token":"يوم","display":"يَوْمِ"},{"kind":"word","token":"الدين","display":"الدِّينِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۴","display":"۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يكررها","display":"يُكَرِّرُهَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قراءته","display":"قِرَاءَتِهِ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يظن","display":"يَظُنَّ"},{"kind":"word","token":"من","d