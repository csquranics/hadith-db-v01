{"consensus_set_id":"69129","translation_language":"fa","translation_source":{"hid":"115527"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ حِكَايَةً عَنْ مُوسَي عَلَيْهِ السَّلاَمُ  :   <quranic_text> « رَبِّ اِنِّي لِمٰا اَنْزَلْتَ اِلَيَّ مِنْ خَيْرٍ فَقِيرٌ » </quranic_text>   <footnote> [ القصص ۲۴ ] </footnote>  فَقَالَ سَاَلَ الطَّعَامَ .","translation_segment":"راوی گوید: امام صادق علیه السلام درباره گفتار خداوند که از قول حضرت موسی علیه السلام می‌فرماید: «پروردگارا! من به آن‌چه فرو فرستادی نیازمندم!» فرمود: حضرت موسی علیه السلام از خداوند غذا درخواست نمود.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"حكايه","display":"حِكَايَةً"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"رب","display":"رَبِّ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"لما","display":"لِمٰا"},{"kind":"word","token":"انزلت","display":"اَنْزَلْتَ"},{"kind":"word","token":"الي","display":"اِلَيَّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"خير","display":"خَيْرٍ"},{"kind":"word","token":"فقير","display":"فَقِيرٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"الطعام","display":"الطَّعَامَ"}]}]}