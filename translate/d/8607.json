{"consensus_set_id":"8607","translation_language":"fa","translation_source":{"hid":"403720"},"segments":[{"source_hadith_segment":"لَمَّا نَزَلَتْ هَذِهِ الْايَةُ :   <quranic_text> « يَوْمَ تَبْيَضُّ وُجُوهٌ وَ تَسْوَدُّ وُجُوهٌ » </quranic_text>   <footnote> [ العمران ۱۰۶ ] </footnote>  قَالَ","translation_segment":"","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"تبيض","display":"تَبْيَضُّ"},{"kind":"word","token":"وجوه","display":"وُجُوهٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تسود","display":"تَسْوَدُّ"},{"kind":"word","token":"وجوه","display":"وُجُوهٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۰۶","display":"۱۰۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :  « تَرِدُ عَلَيَّ اُمَّتِي يَوْمَ الْقِيَامَةِ عَلَي خَمْسِ رَايَاتٍ : فَرَايَةٌ مَعَ عِجْلِ هَذِهِ الْاُمَّةِ ،  فَاَسْاَلُهُمْ :  مَا فَعَلْتُمْ بِالثَّقَلَيْنِ مِنْ بَعْدِي ؟  فَيَقُولُونَ :  اَمَّا الْاَكْبَرُ فَحَرَّفْنَاهُ وَ نَبَذْنَاهُ وَرَاءَ ظُهُورِنَا ،  وَ اَمَّا الْاَصْغَرُ فَعَادَيْنَاهُ وَ اَبْغَضْنَاهُ وَ ظَلَمْنَاهُ .  فَاَقُولُ :  رِدُوا اِلَي النَّارِ ظِمَاءً مُظْمَئِينَ مُسْوَدَّةً وُجُوهُكُمْ .  ثُمَّ تَرِدُ عَلَيَّ رَايَةٌ مَعَ فِرْعَوْنِ هَذِهِ الْاُمَّةِ ،  فَاَقُولُ لَهُمْ :  مَا فَعَلْتُمْ بِالثَّقَلَيْنِ مِنْ بَعْدِي ؟  فَيَقُولُونَ :  اَمَّا الْاَكْبَرُ فَحَرَّفْنَاهُ وَ مَزَّقْنَاهُ وَ خَالَفْنَاهُ ،  وَ اَمَّا الْاَصْغَرُ فَعَادَيْنَاهُ وَ قَاتَلْنَاهُ .  فَاَقُولُ :  رِدُوا اِلَي النَّارِ ظِمَاءً مُظْمَئِينَ مُسْوَدَّةً وُجُوهُكُمْ .  ثُمَّ تَرِدُ عَلَيَّ رَايَةٌ مَعَ سَامِرِيِّ هَذِهِ الْاُمَّةِ ،  فَاَقُولُ لَهُمْ :  مَا فَعَلْتُمْ بِالثَّقَلَيْنِ مِنْ بَعْدِي ؟  فَيَقُولُونَ :  اَمَّا الْاَكْبَرُ فَعَصَيْنَاهُ وَ تَرَكْنَاهُ ،  وَ اَمَّا الْاَصْغَرُ فَخَذَلْنَاهُ وَ ضَيَّعْنَاهُ [ وَ صَنَعْنَا بِهِ كُلَّ قَبِيحٍ ] .  فَاَقُولُ :  رِدُوا اِلَي النَّارِ ظِمَاءً مُظْمَئِينَ مُسْوَدَّةً وُجُوهُكُمْ .  ثُمَّ تَرِدُ عَلَيَّ رَايَةُ ذِي الثُّدَيَّةِ مَعَ اَوَّلِ الْخَوَارِجِ وَ اخِرِهِمْ ،  فَاَسْاَلُهُمْ :  مَا فَعَلْتُمْ بِالثَّقَلَيْنِ مِنْ بَعْدِي ؟  فَيَقُولُونَ :  اَمَّا الْاَكْبَرُ فَمَزَّقْنَاهُ فَبَرِئْنَا مِنْهُ ،  وَ اَمَّا الْاَصْغَرُ فَقَاتَلْنَاهُ وَ قَتَلْنَاهُ .  فَاَقُولُ :  رِدُوا اِلَي النَّارِ ظِمَاءً مُظْمَئِينَ مُسْوَدَّةً وُجُوهُكُمْ .  ثُمَّ تَرِدُ عَلَيَّ رَايَةٌ مَعَ اِمَامِ الْمُتَّقِينَ ،  وَ سَيِّدِ الْوَصِيِّينَ  ،  وَ قَائِدِ الْغُرِّ الْمُحَجَّلِينَ ،  وَ وَصِيِّ رَسُولِ رَبِّ الْعَالَمِينَ ،  فَاَقُولُ لَهُمْ :  مَا فَعَلْتُمْ بِالثَّقَلَيْنِ مِنْ بَعْدِي ؟  فَيَقُولُونَ :  اَمَّا الْاَكْبَرُ فَاتَّبَعْنَاهُ وَ اَطَعْنَاهُ ،  وَ اَمَّا الْاَصْغَرُ فَاَحْبَبْنَاهُ وَ وَالَيْنَاهُ وَ وَازَرْنَاهُ وَ نَصَرْنَاهُ حَتَّي اُهَرِيقَتْ فِيهِمْ دِمَاؤُنَا .  فَاَقُولُ :  رِدُوا اِلَي الْجَنَّةِ رِوَاءً مَرْوِيِّينَ ،  مُبْيَضَّةً وُجُوهُكُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ترد","display":"تَرِدُ"},{"kind":"word","token":"علي","display":"عَلَيَّ"},{"kind":"word","token":"امتي","display":"اُمَّتِي"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{