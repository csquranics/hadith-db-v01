{"consensus_set_id":"41535","translation_language":"fa","translation_source":{"hid":"296996"},"segments":[{"source_hadith_segment":"سَمِعْتُ اَبِي ( عَلَيْهِ السَّلاَمُ ) يَقُولُ لِجَمَاعَةٍ مِنْ اَصْحَابِهِ :  وَ اللَّهِ لَوْ اَنَّ عَلَي اَفْوَاهِكُمْ اَوْكِيَةً لَاَخْبَرْتُ كُلَّ رَجُلٍ مِنْكُمْ مَا لاَ يَسْتَوْحِشُ مَعَهُ اِلَي شَيْءٍ ،  وَ لَكِنْ قَدْ سَبَقَتْ فِيكُمُ الْاِذَاعَةُ وَ اللَّهُ بَالِغُ اَمْرِهِ .","translation_segment":"امام صادق علیه السلام فرمود: شنیدم که پدرم علیه السلام به گروهی از یارانش می‌فرماید: به خدا سوگند اگر دهان شما ریسمانی داشت و دهن‌لق نبودید [که سخنان مرا هر جا مطرح کنید] هریک از شما را به چیزی آگاه می‌کردم که به آن از هیچ‌چیز دیگری هراس نیابید. اما از پیش مشاهده کرده‌ام که خبرها را به همه‌جا، پخش می‌کنید. «و خداوند امر خود را به سرانجام می‌رساند.»","segment_columns":[{"kind":"word","token":"بقراءتي","display":"بِقِرَاءَتِي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اخبرنا","display":"اَخْبَرَنَا"},{"kind":"word","token":"السعيد","display":"السَّعِيدُ"},{"kind":"word","token":"الوالد","display":"الْوَالِدُ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"الطوسي","display":"الطُّوسِيُّ"},{"kind":"word","token":"رحمه","display":"رَحِمَهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"حدثني","display":"حَدَّثَنِي"},{"kind":"word","token":"الشيخ","display":"الشَّيْخُ"},{"kind":"word","token":"الفقيه","display":"الْفَقِيهُ"},{"kind":"word","token":"المفيد","display":"الْمُفِيدُ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدِ"},{"kind":"word","token":"بن","d