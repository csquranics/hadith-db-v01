{"consensus_set_id":"s356481","translation_language":"fa","translation_source":{"hid":"356481"},"segments":[{"source_hadith_segment":"قَوْلُهُ تَعَالَي  <quranic_text> « يُعْجِبُ الزُّرّٰاعَ لِيَغِيظَ بِهِمُ الْكُفّٰارَ » </quranic_text>   <footnote> [ الفتح ۲۹ ] </footnote>  عَنِ الصَّادِقِ عَلَيْهِ السَّلاَمُ قَالَ هُوَ عَلِيُّ بْنُ اَبِي طَالِبٍ  .","translation_segment":"امام صادق (علیه السلام) می‌فرماید مقصود از آیه: «یعجب‌ الزرٰاع‌ لیغیظ‍‌ بهم‌ الکفٰار» -علی بن ابی طالب (علیه السلام) است.","segment_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يعجب","display":"يُعْجِبُ"},{"kind":"word","token":"الزراع","display":"الزُّرّٰاعَ"},{"kind":"word","token":"ليغيظ","display":"لِيَغِيظَ"},{"kind":"word","token":"بهم","display":"بِهِمُ"},{"kind":"word","token":"الكفار","display":"الْكُفّٰارَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفتح","display":"الفتح"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الصادق","display":"الصَّادِقِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"}]}]}