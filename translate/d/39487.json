للَّهُ طَوِيلاً ،  وَ اَعَاذَكَ مِنْ عَدُوِّكَ - يَا وَلَدِي ،  فِدَاكَ اَبُوكَ - قَدْ فَسَّرْتُ لَكَ مَالِي وَ اَنَا حَيٌّ سَوِيٌّ ،  رَجَاءَ اَنْ يُنْمِيَكَ اللَّهُ بِالصِّلَةِ لِقَرَابَتِكَ ،  وَ لِمَوَالِي مُوسَي وَ جَعْفَرٍ ( رَضِيَ اللَّهُ عَنْهُمَا ) ،  فَاَمَّا سَعِيدَةُ فَاِنَّهَا اِمْرَاَةٌ قَوِيَّةُ الْجَزْمِ فِي النَّحْلِ ،  وَ الصَّوَابِ فِي دِقَّةِ النَّظَرِ ،  وَ لَيْسَ ذَلِكَ كَذَلِكَ :  قَالَ اللَّهُ :   <quranic_text> « مَنْ ذَا الَّذِي يُقْرِضُ اللّٰهَ قَرْضاً حَسَناً فَيُضٰاعِفَهُ لَهُ اَضْعٰافاً كَثِيرَةً » </quranic_text>   <footnote> [ البقرة ۲۴۵ ] </footnote> ،  وَ قَالَ :   <quranic_text> « لِيُنْفِقْ ذُو سَعَةٍ مِنْ سَعَتِهِ وَ مَنْ قُدِرَ عَلَيْهِ رِزْقُهُ فَلْيُنْفِقْ مِمّٰا اتٰاهُ اللّٰهُ » </quranic_text>   <footnote> [ الطلاق ۷ ] </footnote> وَ قَدْ اَوْسَعَ اللَّهُ عَلَيْكَ كَثِيراً - يَا بُنَيَّ ،  فِدَاكَ اَبُوكَ - لاَ تَسْتُرْ دُونِيَ الْاُمُورَ لِحُبِّهَا فَتُخْطِئَ حَظَّكَ ،  وَ السَّلاَمُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمَنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه۱","display":"الفاتحة۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ابقاك","display":"اَبْقَاكَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"طويلا","display":"طَوِيلاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعاذك","display":"اَعَاذَكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عدوك","display":"عَدُوِّكَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ولدي","display":"وَلَدِي"},{"kind":"word","token":"فد