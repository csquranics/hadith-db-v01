{"consensus_set_id":"5301","translation_language":"fa","translation_source":{"hid":"103737"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ لِاَيِّ عِلَّةٍ صَارَ الْمِيرَاثُ  <quranic_text> « لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>  قَالَ « لِمَا جَعَلَ اللَّهُ لَهَا مِنَ الصَّدَاقِ » .","translation_segment":"و در روایت حمدان بن حسین، از حسین بن ولید، از ابن بکیر، از عبد اللٰه بن سنان آمده است که گفت: به امام صادق ع معروض داشتم که بچه علتی میراث مرد برابر با سهم دو زن شده است‌؟ امام فرمود: این بعلت صداقی است که خدا برای زن مقرر فرموده است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لاي","display":"لِاَيِّ"},{"kind":"word","token":"عله","display":"عِلَّةٍ"},{"kind":"word","token":"صار","display":"صَارَ"},{"kind":"word","token":"الميراث","display":"الْمِيرَاثُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"للذكر","display":"لِلذَّكَرِ"},{"kind":"word","token":"مثل","display":"مِثْلُ"},{"kind":"word","token":"حظ","display":"حَظِّ"},{"kind":"word","token":"الانثيين","display":"الْاُنْثَيَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۱","display":"۱۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لما","display":"لِمَا"},{"kind":"word","token":"جعل","display":"جَعَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"w