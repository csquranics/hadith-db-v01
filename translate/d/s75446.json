{"consensus_set_id":"s75446","translation_language":"fa","translation_source":{"hid":"75446"},"segments":[{"source_hadith_segment":"« ايَةٌ مِنَ الْقُرْانِ لَمْ يعمل بها احد قبلي و لا يَعْمَلْ بِهَا اَحَدٌ بَعْدِي ،  ايَةُ النَّجْوَي ،  كَانَ عِنْدِي دِينَارٌ فَبِعْتُهُ بِعَشَرَةِ دَرَاهِمَ ،  فَكُلَّمَا اَرَدْتُ اَنْ اناجي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ و الِهِ و سلّم تَصَدَّقْتُ بِدِرْهَمٍ ثُمَّ نُسِخَتْ بِقَوْلِهِ :   <quranic_text> « فَاِنْ لَمْ تَجِدُوا فَاِنَّ اللّٰهَ غَفُورٌ رَحِيمٌ » </quranic_text>   <footnote> [ المجادلة ۱۲ ] </footnote>   .","translation_segment":"مجاهد گوید: علی علیه السلام میفرمود: در قرآن آیه‌ای هست که پس از من در مورد احدی صدق نخواهد کرد، و آن آیه نجوی است، جریان آن از این قرار است که: دیناری داشتم و او را بده درهم فروختم، و هر گاه اراده کردم با حضرت رسول خلوت کنم، یک درهم از آن را صدقه میدادم، تا آنگاه که آیه نازل شد و این موضوع را نسخ کرد.","segment_columns":[{"kind":"word","token":"ايه","display":"ايَةٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يعمل","display":"يعمل"},{"kind":"word","token":"بها","display":"بها"},{"kind":"word","token":"احد","display":"احد"},{"kind":"word","token":"قبلي","display":"قبلي"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"لا","display":"لا"},{"kind":"word","token":"يعمل","display":"يَعْمَلْ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"بعدي","display":"بَعْدِي"},{"kind":"word","token":"ايه","display":"ايَةُ"},{"kind":"word","token":"النجوي","display":"النَّجْوَي"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"عندي","display":"عِنْدِي"},{"kind":"word","token":"دينار","display":"دِينَارٌ"},{"kind":"word","token":"فبعته","display":"فَبِعْتُهُ"},{"kind":"word","token":"بعشره","display":"بِعَشَرَةِ"},{"kind":"word","token":"دراهم","display":"دَرَاهِمَ"},