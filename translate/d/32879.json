{"consensus_set_id":"32879","translation_language":"fa","translation_source":{"hid":"101867"},"segments":[{"source_hadith_segment":"وَ سُئِلَ عَلِيٌّ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ عَلَي اللّٰهِ فَلْيَتَوَكَّلِ الْمُتَوَكِّلُونَ » </quranic_text>   <footnote> [ ابراهيم ۱۲ ] </footnote>  قَالَ « اَلزَّارِعُونَ » .","translation_segment":"و از امیر مومنان علیه السلام از سخن خداوند که فرموده: «و علی اللٰه‌ فلیتوکل‌ المتوکلون‌» (ابراهیم:۱۲) پرسیدند، فرمود: مراد از متوکلین (توکل‌کنندگان بر خداوند) کشاورزان باشند","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"فليتوكل","display":"فَلْيَتَوَكَّلِ"},{"kind":"word","token":"المتوكلون","display":"الْمُتَوَكِّلُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۱۲","display":"۱۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الزارعون","display":"اَلزَّارِعُونَ"}]}]}