{"consensus_set_id":"2781","translation_language":"fa","translation_source":{"hid":"112222"},"segments":[{"source_hadith_segment":"وَ سَمِعْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ يَقُولُ وَ سُئِلَ عَنِ الْاَمْرِ بِالْمَعْرُوفِ وَ النَّهْيِ عَنِ الْمُنْكَرِ","translation_segment":"با همین سند گوید: از امام صادق علیه السلام شنیدم که از حضرتش پرسیده شد: آیا امر به معروف و نهی از منکر بر همه واجب","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"بعده","display":"بَعْدَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بهذا","display":"بِهَذَا"},{"kind":"word","token":"الاسناد","display":"الْاِسْنَادِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سمعت","display":"سَمِعْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الامر","display":"الْاَمْرِ"},{"kind":"word","token":"بالمعروف","display":"بِالْمَعْرُوفِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النهي","display":"النَّهْيِ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"المنكر","display":"الْمُنْكَرِ"}]},{"source_hadith_segment":"اَ وَاجِبٌ هُوَ عَلَي الْاُمَّةِ جَمِيعاً فَقَالَ لاَ فَقِيلَ لَهُ وَ لِمَ","translation_segment":"است‌؟ فرمود: نه. عرض شد: چرا؟ فرمود: تنها بر شخص توانا و نیرومندی","segment_columns":[{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"واجب","display":"وَاجِبٌ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الامه","display":"الْاُمَّةِ"},{"kind":"word","token":"جميعا","display":"جَمِيعاً"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"فقيل","display":"فَقِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لِمَ"}]},{"source_hadith_segment":"قَالَ اِنَّمَا هُوَ عَلَي الْقَوِيِّ الْمُطَاعِ الْعَالِمِ بِالْمَعْرُوفِ مِنَ الْمُنْكَرِ لاَ عَلَي الضَّعِيفِ الَّذِي لاَ يَهْتَدِي سَبِيلاً اِلَي اَيٍّ مِنْ اَيٍّ يَقُولُ مِنَ الْحَقِّ اِلَي الْبَاطِلِ وَ الدَّلِيلُ عَلَي ذَلِكَ كِتَابُ اللَّهِ عَزَّ وَ جَلَّ قَوْلُهُ  <quranic_text> « وَ لْتَكُنْ مِنْكُمْ اُمَّةٌ يَدْعُونَ اِلَي الْخَيْرِ وَ يَاْمُرُونَ بِالْمَعْرُوفِ وَ يَنْهَوْنَ عَنِ الْمُنْكَرِ » </quranic_text>   <footnote> [ العمران ۱۰۴ ] </footnote>  فَهَذَا خَاصُّ غَيْرُ عَامٍّ كَمَا قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مِنْ قَوْمِ مُوسيٰ اُمَّةٌ يَهْدُونَ بِالْحَقِّ وَ بِهِ يَعْدِلُونَ » </quranic_text>   <footnote> [ الاعراف ۱۵۹ ] </footnote>  وَ لَمْ يَقُلْ عَلَي اُمَّةِ مُوسَي وَ لاَ عَلَي كُلِّ قَوْمِهِ وَ هُمْ يَوْمَئِذٍ اُمَمٌ مُخْتَلِفَةٌ وَ الْاُمَّةُ وَاحِدَةٌ فَصَاعِداً كَمَا قَالَ اللَّهُ عَزَّ وَ جَلَّ  <quranic_text> « اِنَّ اِبْرٰاهِيمَ كٰانَ اُمَّةً قٰانِتاً لِلّٰهِ » </quranic_text>   <footnote> [ النحل ۱۲۰ ] </footnote>  يَقُولُ مُطِيعاً لِلَّهِ عَزَّ وَ جَلَّ وَ لَيْسَ عَلَي مَنْ يَعْلَمُ ذَلِكَ فِي هَذِهِ الْهُدْنَةِ مِنْ حَرَجٍ اِذَا كَانَ لاَ قُوَّةَ لَهُ وَ لاَ عُذْرَ وَ لاَ طَاعَةَ قَالَ مَسْعَدَةُ وَ سَمِعْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ يَقُولُ وَ سُئِلَ عَنِ الْحَدِيثِ الَّذِي جَاءَ عَنِ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اِنَّ اَفْضَلَ الْجِهَادِ كَلِمَةُ عَدْلٍ عِنْدَ اِمَامٍ جَائِرٍ مَا مَعْنَاهُ قَالَ هَذَا عَلَي اَنْ يَاْمُرَهُ بَعْدَ مَعْرِفَتِهِ وَ هُوَ مَعَ ذَلِكَ يُقْبَلُ مِنْهُ وَ اِلاَّ فَلاَ .","translation_segment":"که از او اطاعت کنند و بپذیرند واجب است که معروف و نیک را بشناسد و از منکر تشخیص بدهد، نه بر ناتوان ضعیفی که را خودش هدایت نشده است و مردم را از حق به باطل می‌برد. دلیل براین مطالب نیز در کتاب خداوند عز و جل‌ آمده است که می‌فرماید: «و باید از میان شما گروهی باشند که دعوت و فراخوان به کار خیر کنند و امر به معروف و نهی از منکر نمایند». پرواضح است که این معنا، خاص است و عام نیست. چنان‌که خداوند عز و جل‌ می‌فرماید: «و از قوم موسی امت (و گروهی) بودند که (مردم را) به حقیقت هدایت و راهنمایی می‌کردند و بین آنان حق و عدالت را اجرا می‌کردند». و نفرمود: «بر امت موسی»؛ و نفرمود: «بر تمام قوم موسی»، که در آن هنگام امت‌های گوناگون بودند، در حالی که امت به معنای یک نفر و بیش از آن آمده است، آن‌جا که خداوند عز و جل‌ می‌فرماید: «در واقع ابراهیم یک امت بود و از خداوند اطاعت می‌کرد». می‌فرماید: او نسبت خداوند عز و جل‌ مطیع بود. البته در این زمان که ما با ستمکاران در حال صلح و آتش‌بس هستیم بر دانایی اگر توان ندارد و بهانه‌ای ندارد و کسی نیز از او فرمان نمی‌برد حرجی نیست و لازم نیست. مسعده گوید: از امام صادق علیه السلام در مورد این حدیث که از پیامبر صلی الله علیه و اله وارد شده است: «در واقع، با فضیلت‌ترین جهاد، سخن عدلی است که نزد پیشوایی جائر و ستمگر گفته شود» پرسیده شد. شنیدم که آن حضرت فرمود: معنای این سخن چنین است که وقتی فهمید به آن جائر دستور بدهد (و امر به حق کند)، به شرطی که او نیز بپذیرد، و گرنه چنین رفتار نکند.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"القوي","display":"الْقَوِيِّ"},{"kind":"word","token":"المطاع","display":"الْمُطَاعِ"},{"kind":"word","token":"العالم","display":"الْعَالِمِ"},{"kind":"word","token":"بالمعروف","display":"بِالْمَعْرُوفِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المنكر","display":"الْمُنْكَرِ"},{"kind":"word","token":"-","disp