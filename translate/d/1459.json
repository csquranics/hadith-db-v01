{"consensus_set_id":"1459","translation_language":"fa","translation_source":{"hid":"90703"},"segments":[{"source_hadith_segment":"يَقُولُ قَالَ اَبِي قَالَ عَلِيٌّ عَلَيْهِ السَّلاَمُ  :  « اُذْكُرُوا اللَّهَ  <quranic_text> « فِي اَيّٰامٍ مَعْلُومٰاتٍ » </quranic_text>   <footnote> [ الحج ۲۸ ] </footnote>  قَالَ قَالَ « عَشْرُ ذِي الْحِجَّةِ وَ  <quranic_text> « اَيّٰامٍ مَعْدُودٰاتٍ » </quranic_text>   <footnote> [ البقرة ۲۰۳ ] </footnote>  قَالَ « اَيَّامُ التَّشْرِيقِ » .","translation_segment":"* *۲۰۴ - جدم علی علیه السلام می‌گفت: حاجیان منی باید در روزهای مشخصی به یاد خدا باشند. این روزهای مشخص دهم و یازدهم و دوازدهم ذیحجه می‌باشد و به تعبیر دیگر در روزهای معدودی باید در مهمانی خدا شرکت کنند و به یاد خدا باشند که روزهای یازدهم و دوازدهم و سیزدهم خواهد بود.","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سمعته","display":"سَمِعْتُهُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذكروا","display":"اُذْكُرُوا"},{"kind":"word","token":"اسم","display":"اِسْمَ"},{"kind":"w