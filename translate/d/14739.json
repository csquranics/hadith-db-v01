{"consensus_set_id":"14739","translation_language":"fa","translation_source":{"hid":"403374"},"segments":[{"source_hadith_segment":"« اِنَّ اَلتَّوْبَةَ مُطَهِّرَةٌ مِنْ دَنَسِ الْخَطِيئَةِ ،  قَالَ تَعَالَي :   <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا اِتَّقُوا اللّٰهَ وَ ذَرُوا مٰا بَقِيَ مِنَ الرِّبٰا اِنْ كُنْتُمْ مُؤْمِنِينَ » </quranic_text>   <footnote> [ البقرة ۲۷۸ ] </footnote> - اِلَي قَوْلِهِ :  -  <quranic_text> « تَظْلِمُونَ » </quranic_text>   <footnote> [ البقرة ۲۷۹ ] </footnote> فَهَذَا مَا دَعَا اللَّهُ اِلَيْهِ عِبَادَهُ مِنَ التَّوْبَةِ ،  وَ وَعَدَ عَلَيْهَا مِنْ ثَوَابِهِ ،  فَمَنْ خَالَفَ مَا اَمَرَ اللَّهُ بِهِ مِنَ التَّوْبَةِ سَخِطَ اللَّهُ عَلَيْهِ ،  وَ كَانَتِ النَّارُ اَوْلَي بِهِ وَ اَحَقَّ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"التوبه","display":"اَلتَّوْبَةَ"},{"kind":"word","token":"مطهره","display":"مُطَهِّرَةٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"دنس","display":"دَنَسِ"},{"kind":"word","token":"الخطيئه","display":"الْخَطِيئَةِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذروا","display":"ذَرُوا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"بقي","display":"بَقِيَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الربا","display":"الرِّبٰا"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كنتم","display":"كُنْتُمْ"},{"kind":"word","token":"مؤمنين","display":"مُؤْمِنِينَ"},{"kin