{"consensus_set_id":"s402253","translation_language":"fa","translation_source":{"hid":"402253"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « وَ اِذْ قٰالَ رَبُّكَ لِلْمَلاٰئِكَةِ اِنِّي جٰاعِلٌ فِي الْاَرْضِ خَلِيفَةً قٰالُوا اَ تَجْعَلُ فِيهٰا مَنْ يُفْسِدُ فِيهٰا وَ يَسْفِكُ الدِّمٰاءَ » </quranic_text>   <footnote> [ البقرة ۳۰ ] </footnote>   :","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"ربك","display":"رَبُّكَ"},{"kind":"word","token":"للملائكه","display":"لِلْمَلاٰئِكَةِ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"جاعل","display":"جٰاعِلٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"خليفه","display":"خَلِيفَةً"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"تجعل","display":"تَجْعَلُ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يفسد","display":"يُفْسِدُ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يسفك","display":"يَسْفِكُ"},{"kind":"word","token":"الدماء","display":"الدِّمٰاءَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۳۰","display":"۳۰"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"« رَدُّوا عَلَي اللَّهِ فَقَالُوا :   <quranic_text> « اَ تَجْعَلُ فِيهٰا مَنْ يُفْسِدُ فِيهٰا وَ يَسْفِكُ الدِّمٰاءَ » </quranic_text>   <footnote> [ البقرة ۳۰ ] </footnote> .  وَ اِنَّمَا قَالُوا ذَلِكَ بِخَلْقٍ مَضَي ،  يَعْنِي الْجَانَّ اَبَا الْجِنِّ .   <quranic_text> « وَ نَحْنُ نُسَبِّحُ بِحَمْدِكَ وَ نُقَدِّسُ لَكَ » </quranic_text>   <footnote> [ البقرة ۳۰ ] </footnote> فَمَنُّوا عَلَي اللَّهِ بِعِبَادَتِهِمْ اِيَّاهُ فَاَعْرَضَ عَنْهُمْ .  ثُمَّ عَلَّمَ ادَمَ الْاَسْمَاءَ كُلَّهَا ،  ثُمَّ قَالَ لِلْمَلاَئِكَةِ  <quranic_text> « اَنْبِئُونِي بِاَسْمٰاءِ هٰؤُلاٰءِ » </quranic_text>   <footnote> [ البقرة ۳۱ ] </footnote> <quranic_text> « قٰالُوا سُبْحٰانَكَ لاٰ عِلْمَ لَنٰا » </quranic_text>   <footnote> [ البقرة ۳۲ ] </footnote> قَالَ  <quranic_text> « يٰا ادَمُ اَنْبِئْهُمْ بِاَسْمٰائِهِمْ » </quranic_text>   <footnote> [ البقرة ۳۳ ] </footnote> فَاَنْبَاَهُمْ ،  ثُمَّ قَالَ لَهُمْ  <quranic_text> « اُسْجُدُوا لِادَمَ  » </quranic_text>   <footnote> [ البقرة ۳۴ ] </footnote> فَسَجَدُوا ،  وَ قَالُوا فِي سُجُودِهِمْ - فِي اَنْفُسِهِمْ- :  مَا كُنَّا نَظُنُّ اَنْ يَخْلُقَ اللَّهُ خَلْقاً اَكْرَمَ عَلَيْهِ مِنَّا ،  نَحْنُ خُزَّانُ اللَّهِ وَ جِيرَانُهُ ،  وَ اَقْرَبُ الْخَلْقِ اِلَيْهِ .  فَلَمَّا رَفَعُوا رُءُوسَهُمْ ،  قَالَ :  اللَّهُ يَعْلَمُ مَا تُبْدُونَ مِنْ رَدِّكُمْ عَلَيَّ وَ مَا كُنْتُمْ تَكْتُمُونَ :  ظَنَنَّا اَنْ لاَ يَخْلُقَ اللَّهُ خَلْقاً اَكْرَمَ عَلَيْهِ مِنَّا .  فَلَمَّا عَرَفَتِ الْمَلاَئِكَةُ اَنَّهَا وَقَعَتْ فِي خَطِيئَةٍ لاَذُوا بِالْعَرْشِ ،  وَ اِنَّهَا كَانَتْ عِصَابَةٌ مِنَ الْمَلاَئِكَةِ ،  وَ هُمُ الَّذِينَ كَانُوا حَوْلَ الْعَرْشِ ،  لَمْ يَكُنْ جَمِيعُ الْمَلاَئِكَةِ الَّذِينَ قَالُوا :  مَا ظَنَنَّا اَنْ يَخْلُقَ خَلْقاً اَكْرَمَ عَلَيْهِ مِنَّا ،  وَ هُمُ الَّذِينَ اُمِرُوا بِالسُّجُودِ ،  فَلاَذُوا بِالْعَرْشِ وَ قَالُوا بِاَيْدِيهِمْ - وَ اَشَارَ بِاِصْبَعِهِ يُدِيرُهَا - فَهُمْ يَلُوذُونَ حَوْلَ الْعَرْشِ اِلَي يَوْمِ الْقِيَامَةِ .  فَلَمَّا اَصَابَ ادَمُ الْخَطِيئَةَ ،  جَعَلَ اللَّهُ هَذَا الْبَيْتَ لِمَنْ اَصَابَ مِنْ وُلْدِهِ الْخَطِيئَةَ [ اَتَاهُ ] فَلاَذَ بِهِ مِنْ وُلْدِ ادَمَ ( عَلَيْهِ السَّلاَمُ ) كَمَا لاَذَ اُولَئِكَ بِالْعَرْشِ .  فَلَمَّا هَبَطَ ادَمُ ( عَلَيْهِ السَّلاَمُ ) اِلَي الْاَرْضِ طَافَ بِالْبَيْتِ ،  فَلَمَّا كَانَ عِنْدَ الْمُسْتَجَارِ دَنَا مِنَ الْبَيْتِ فَرَفَعَ يَدَيْهِ اِلَي السَّمَاءِ ،  فَقَالَ :  يَا رَبِّ ،  اِغْفِرْ لِي .  فَنُودِيَ :  اِنِّي قَدْ غَفَرْتُ لَكَ ،  قَالَ :  يَا رَبِّ ،  وَ لِوُلْدِي ،  قَالَ :  فَنُودِيَ :  يَا ادَمُ  ،  مَنْ جَاءَنِي مِنْ وُلْدِكَ فَبَاءَ بِذَنْبِهِ بِهَذَا الْمَكَانِ ،  غَفَرْتُ لَهُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ردوا","display":"رَدُّوا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فقالوا","display":"فَقَالُوا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"تجعل","display":"تَجْعَلُ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يفسد","display":"يُفْسِدُ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يسفك","display":"يَسْفِكُ"},{"kind":"word","token":"الدماء","display":"الدِّمٰاءَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۳۰","display":"۳۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"بخلق","display":"بِخَلْقٍ"},{"kind":"word","token":"مضي","display":"مَضَي"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"الجان","display":"الْجَانَّ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الجن","display":"الْجِنِّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":