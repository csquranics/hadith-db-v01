{"consensus_set_id":"5092","translation_language":"fa","translation_source":{"hid":"439422"},"segments":[{"source_hadith_segment":"وَ سُئِلَ الصَّادِقُ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ -  <quranic_text> « اَ وَ لَمْ نُعَمِّرْكُمْ مٰا يَتَذَكَّرُ فِيهِ مَنْ تَذَكَّرَ » </quranic_text>   <footnote> [ فاطر ۳۷ ] </footnote>  فَقَالَ تَوْبِيخٌ لاِبْنِ ثَمَانِيَ عَشْرَةَ سَنَةً .","translation_segment":"از امام صادق پرسیدند از قول خدای عز و جل (فاطر ۳۷) آیا بشما عمری ندادیم که متذکر در آن تذکر یابد؟ فرمود سرزنش هیجده ساله است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"نعمركم","display":"نُعَمِّرْكُمْ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يتذكر","display":"يَتَذَكَّرُ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"تذكر","display":"تَذَكَّرَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"فاطر","display":"فاطر"},{"kind":"word","token":"۳۷","display":"۳۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"توبيخ","display":"تَوْبِ