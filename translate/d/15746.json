{"consensus_set_id":"15746","translation_language":"fa","translation_source":{"hid":"409343"},"segments":[{"source_hadith_segment":"« دَخَلَ اَبُو عَبْدِ اللَّهِ الْجَدَلِيُّ عَلَي اَمِيرِ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) ،  فَقَالَ لَهُ : يَا اَبَا عَبْدِ اللَّهِ ،  اَ لاَ اُخْبِرُكَ بِقَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « مَنْ جٰاءَ بِالْحَسَنَةِ » </quranic_text>   <footnote> [ النمل ۸۹ ] </footnote>  اِلَي قَوْلِهِ <quranic_text> « تَعْمَلُونَ » </quranic_text>   <footnote> [ النمل ۹۰ ] </footnote>   ،  قَالَ : بَلَي ،  جُعِلْتُ فِدَاكَ .  قَالَ : « اَلْحَسَنَةُ حُبُّنَا اَهْلَ الْبَيْتِ ،  وَ السَّيِّئَةُ بُغْضُنَا » .","translation_segment":"","segment_columns":[{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"الجدلي","display":"الْجَدَلِيُّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اخبرك","display":"اُخْبِرُكَ"},{"kind":"word","token":"بقول","display":"بِقَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word",