{"consensus_set_id":"7802","translation_language":"fa","translation_source":{"hid":"99868"},"segments":[{"source_hadith_segment":"اَنَّهُ سُئِلَ الصَّادِقُ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ عَلَي الَّذِينَ يُطِيقُونَهُ فِدْيَةٌ طَعٰامُ مِسْكِينٍ » </quranic_text>   <footnote> [ البقرة ۱۸۴ ] </footnote>","translation_segment":"و در روایت ابن بکیر آمده است که از امام صادق علیه السلام در باره قول خدای عز و جل‌: «و علی الذین یطیقونه فدیه طعام مسکین» سوال کردند، امام فرمود: معنی آیه این است که: کسانی","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يطيقونه","display":"يُطِيقُونَهُ"},{"kind":"word","token":"فديه","display":"فِدْيَةٌ"},{"kind":"word","token":"طعام","display":"طَعٰامُ"},{"kind":"word","token":"مسكين","display":"مِسْكِينٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۸۴","display":"۱۸۴"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ « عَلَي الَّذِينَ كَانُوا يُطِيقُونَ الصَّوْمَ ثُمَّ اَصَابَهُمْ كِبَرٌ اَوْ عُطَاشٌ اَوْ شِبْهُ ذَلِكَ فَعَلَيْهِمْ لِكُلِّ يَوْمٍ مُدٌّ » .","translation_segment":"که طاقت روزه