{"consensus_set_id":"16512","translation_language":"fa","translation_source":{"hid":"412154"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اَ اِنّٰا لَمَرْدُودُونَ فِي الْحٰافِرَةِ » </quranic_text>   <footnote> [ النازعات ۱۰ ] </footnote>  يَقُولُ :  « فِي الْخَلْقِ الْجَدِيدِ ،  وَ اَمَّا قَوْلُهُ :   <quranic_text> « فَاِذٰا هُمْ بِالسّٰاهِرَةِ » </quranic_text>   <footnote> [ النازعات ۱۴ ] </footnote>  وَ السَّاهِرَةُ :  الْاَرْضُ ،  كَانُوا فِي الْقُبُورِ ،  فَلَمَّا سَمِعُوا الزَّجْرَةَ خَرَجُوا مِنْ قُبُورِهِمْ فَاسْتَوَوْا عَلَي الْاَرْضِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"لمردودون","display":"لَمَرْدُودُونَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحافره","display":"الْحٰافِرَةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النازعات","display":"النازعات"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الخلق","display":"الْخَلْقِ"},{"kind":"word","token":"الجديد","display":"الْجَدِيدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاذا","display":"فَاِذٰا"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"بالساهره","display":"بِالسّٰاهِرَةِ"},{"kind":"tag_close","tag_name":"qur