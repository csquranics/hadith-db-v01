{"consensus_set_id":"s223133","translation_language":"fa","translation_source":{"hid":"223133"},"segments":[{"source_hadith_segment":"سَاَلَ يَحْيَي بْنُ اَكْثَمَ اَبَا الْحَسَنِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِهِ تَعَالَي :   <quranic_text> « سَبْعَةُ اَبْحُرٍ مٰا نَفِدَتْ كَلِمٰاتُ اللّٰهِ » </quranic_text>   <footnote> [ لقمان ۲۷ ] </footnote>  مَا هِيَ فَقَالَ هِيَ عَيْنُ الْكِبْرِيتِ وَ عَيْنُ الْيَمَنِ وَ عَيْنُ الْبَرَهُوتِ وَ عَيْنُ الطَّبَرِيَّةِ وَ حَمَّةُ ماسيدان [ مَاسَبَذَانَ ] وَ حَمَّةُ اِفْرِيقِيَةَ وَ عَيْنُ بَاجُورَانَ وَ نَحْنُ الْكَلِمَاتُ الَّتِي لاَ تُدْرَكُ فَضَائِلُهَا وَ لاَ تُسْتَقْصَي .","translation_segment":"","segment_columns":[{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"يحيي","display":"يَحْيَي"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"اكثم","display":"اَكْثَمَ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سبعه","display":"سَبْعَةُ"},{"kind":"word","token":"ابحر","display":"اَبْحُرٍ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"نفدت","display":"نَفِدَتْ"},{"kind":"word","token":"كلمات","display":"كَلِمٰاتُ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"لقمان","display":"لقمان"},{"kind":"word","token":"۲۷","display":"۲۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"w