ُلُّ ذَلِكَ يَتَجَلَّي عَنْهُمْ ،  حَتَّي اِذَا اَمِنُوا مَكْرَ اللَّهِ ،  وَ اَمِنُوا عَذَابَهُ ،  وَ ظَنُّوا اَنَّهُمْ قَدِ اِسْتَقَرُّوا ،  صِيحَ فِيهِمْ صَيْحَةٌ لَمْ يَكُنْ لَهُمْ فِيهَا مُنَادٍ يَسْمَعُهُمْ وَ لاَ يَجْمَعُهُمْ ،  وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « حَتّٰي اِذٰا اَخَذَتِ الْاَرْضُ زُخْرُفَهٰا » </quranic_text>   <footnote> [ يونس ۲۴ ] </footnote>  اِلَي قَوْلِهِ  <quranic_text> « لِقَوْمٍ يَتَفَكَّرُونَ » </quranic_text>   <footnote> [ يونس ۲۴ ] </footnote> اَلاَ اِنَّهُ لَيْسَ اَحَدٌ مِنَ الظَّلَمَةِ اِلاَّ وَ لَهُمْ بُقْيَا ،  اِلاَّ الَ فُلاَنٍ فَاِنَّهُمْ لاَ بُقْيَا لَهُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"لال","display":"لِالِ"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"رايه","display":"رَايَةُ"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"فلان","display":"فُلاَنٍ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"ملكا","display":"مُلْكاً"},{"kind":"word","token":"مبطئا","display":"مُبْطِئاً"},{"kind":"word","token":"يقربون","display":"يُقَرِّبُونَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"البعيد","display":"الْبَعِيدَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يبعدون","display":"يُبَعِّدُونَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"القريب","display":"الْقَرِيبَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلطانهم","display":"سُلْطَانُهُمْ"},{"kind":"word","token":"عسر","display":"عُسْرٌ"},{"kind"