{"consensus_set_id":"648","translation_language":"fa","translation_source":{"hid":"110903"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ يَوْمِ  <quranic_text> « اَلْحَجِّ الْاَكْبَرِ » </quranic_text>   <footnote> [ التوبة ۳ ] </footnote>  فَقَالَ هُوَ يَوْمُ النَّحْرِ وَ الْحَجُّ الْاَصْغَرُ الْعُمْرَةُ .","translation_segment":"معاویه بن عمار گوید: از امام صادق علیه السلام پرسیدم: روز حج اکبر چه روزی است‌؟ فرمود: حج اکبر روزی است که مراسم قربانی صورت می‌گیرد. حج اصغر همان عمره است (که روز مشخصی ندارد).","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"يوم","display":"يَوْمِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحج","display":"اَلْحَجِّ"},{"kind":"word","token":"الاكبر","display":"الْاَكْبَرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"يوم","display":"يَوْمُ"},{"kind":"word","token":"النحر","display":"النَّحْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحج","display":"الْحَجُّ"},{"kind":"word","token":"الاصغر","display":"الْاَصْغَرُ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"العمره","display":"الْعُمْرَةُ"}]}]}