{"consensus_set_id":"55746","translation_language":"fa","translation_source":{"hid":"408490"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ ) عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « فَلَمّٰا اَحَسُّوا بَاْسَنٰا اِذٰا هُمْ مِنْهٰا يَرْكُضُونَ » </quranic_text>   <footnote> [ الانبياء ۱۲ ] </footnote>   ،  قَالَ :  « ذَلِكَ عِنْدَ قِيَامِ الْقَائِمِ ( عَجَّلَ اللَّهُ فَرَجَهُ ) » .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلما","display":"فَلَمّٰا"},{"kind":"word","token":"احسوا","display":"اَحَسُّوا"},{"kind":"word","token":"باسنا","display":"بَاْسَنٰا"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"منها","display":"مِنْهٰا"},{"kind":"word","token":"يركضون","display":"يَرْكُضُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۱۲","display":"۱۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"قيام","display":"قِيَامِ"},{"kind":"word","token":"القائم","display":"الْقَائِمِ"},{"kind":"word","token":"عجل","display":"عَجَّلَ"},{"kind":"word","token":"الله","d