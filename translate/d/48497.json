{"consensus_set_id":"48497","translation_language":"fa","translation_source":{"hid":"60255"},"segments":[{"source_hadith_segment":"اَ لَسْتُ اَوْلَي بِكُمْ مِنْكُمْ بِاَنْفُسِكُمْ ؟  لِقَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « اَلنَّبِيُّ اَوْليٰ بِالْمُؤْمِنِينَ مِنْ اَنْفُسِهِمْ » </quranic_text>   <footnote> [ الاحزاب ۶ ] </footnote>   .  فَقَالُوا :  اللَّهُمَّ نَعَمْ .  قَالَ :  فَمَنْ كُنْتُ مَوْلاَهُ فَعَلِيٌّ مَوْلاَهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لست","display":"لَسْتُ"},{"kind":"word","token":"اولي","display":"اَوْلَي"},{"kind":"word","token":"بكم","display":"بِكُمْ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"بانفسكم","display":"بِاَنْفُسِكُمْ"},{"kind":"word","token":"لقول","display":"لِقَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"النبي","display":"اَلنَّبِيُّ"},{"kind":"word","token":"اولي","display":"اَوْليٰ"},{"kind":"word","token":"بالمؤمنين","display":"بِالْمُؤْمِنِينَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"انفسهم","display":"اَنْفُسِهِمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحزاب","display":"الاحزاب"},{"kind":"word","token":"۶","display":"۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقالوا","display":"فَقَالُوا"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"كنت","display":"كُنْتُ"},{"kind":"word","token":"مولاه","display":"مَوْلاَهُ"},{"kind":"word","token":"فعلي","display":"فَعَلِيٌّ"},{"kind