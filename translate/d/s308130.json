egment":"","segment_columns":[{"kind":"word","token":"ف","display":"فَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يغرنكم","display":"يَغُرَّنَّكُمْ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"word","token":"الغرور","display":"الْغَرُورُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"لقمان","display":"لقمان"},{"kind":"word","token":"۳۳","display":"۳۳"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"لَوْ تَعْلَمُونَ مَا لَكُمْ فِي الْقِيَامِ بَيْنَ اَعْدَائِكُمْ وَ صَبْرِكُمْ عَلَي الْاَذَي","translation_segment":"","segment_columns":[{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"تعلمون","display":"تَعْلَمُونَ"}]},{"source_hadith_segment":"لَقَرَّتْ اَعْيُنُكُمْ وَ لَوْ فَقَدْتُمُونِي لَرَاَيْتُمْ اُمُوراً يَتَمَنَّي اَحَدُكُمُ الْمَوْتَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"مِمَّا يَرَي مِنَ الْجَوْرِ [ وَ الْفُجُورِ ] وَ الاِسْتِخْفَافِ بِحَقِّ اللَّهِ وَ الْخَوْفِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاِذَا كَانَ كَذَلِكَ فَ  <quranic_text> « اِعْتَصِمُوا بِحَبْلِ اللّٰهِ جَمِيعاً وَ لاٰ تَفَرَّقُوا » </quranic_text>   <footnote> [ العمران ۱۰۳ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ عَلَيْكُمْ بِالصَّبْرِ وَ الصَّلاَةِ وَ التَّقِيَّةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"[ وَ اِعْلَمُوا اَنَّ اللَّهَ تَبَارَكَ وَ تَعَالَي يُبْغِضُ مِنْ عِبَادِهِ الْمُتَلَوِّنَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَلاَ تَزُولُوا عَنِ الْحَقِّ وَ وَلاَيَةِ ] اَهْلِ الْحَقِّ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاِنَّهُ [ فَاِنَّ ] مَنِ اِسْتَبْدَلَ بِنَا هَلَكَ وَ مَنِ اِتَّبَعَ اَمْرَنَا لَحِقَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ مَنْ سَلَكَ غَيْرَ طَرِيقِنَا غَرِقَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاِنَّ [ وَ اِنَّ ] لِمُحِبِّينا افواج[ اَفْوَاجاً ] مِنْ رَحْمَةِ اللَّهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ اِنَّ لِمُبْغِضِينَا افواج[ اَفْوَاجاً ] مِنْ عَذَابِ [ غَضَبِ ] اللَّهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"طَرِيقُنَا الْقَصْدُ وَ فِي اَمْرِنَا الرُّشْدُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"[ اِنَّ ] اَهْلَ الْجَنَّةِ يَنْظُرُونَ [ اِلَي ] مَنَازِلِ شِيعَتِنَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"كَمَا يُرَي الْكَوْكَبُ الدُّرِّيُّ فِي السَّمَاءِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لاَ يَضِلُّ مَنِ اِتَّبَعَنَا وَ لاَ يَهْتَدِي مَنْ اَنْكَرَنَا وَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لاَ يَنْجُو مَنْ اَعَانَ عَلَيْنَا وَ لاَ يُعَانُ مَنْ اَسْلَمَنَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَلاَ [ ت ] تَخَلَّفُوا عَنَّا لِطَمَعِ دُنْيَا وَ حُطَامٍ زَائِلٍ عَنْكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ تَزُولُونَ عَنْهُ فَاِنَّهُ [ فَاِنَّ ] مَنْ اثَرَ الدُّنْيَا عَلَيْنَا عَظُمَتْ حَسْرَتُهُ [ غَداً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"] وَ كَذَلِكَ قَالَ [ اَللَّهُ تَعَالَي ]  <quranic_text> « يٰا حَسْرَتيٰ عَليٰ مٰا فَرَّطْتُ فِي جَنْبِ اللّٰهِ [ وَ اِنْ كُنْتُ لَمِنَ السّٰاخِرِينَ ] » </quranic_text>   <footnote> [ الزمر ۵۶ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"سِرَاجُ الْمُؤْمِنِ مَعْرِفَةُ حَقِّنَا وَ اَشَدُّ الْعَمَي مَنْ عَمِيَ فَضْلَنَا وَ نَاصَبَنَا الْعَدَاوَةَ بِلاَ ذَنْبٍ اِلاَّ اَنَّا [ اَنْ ] دَعَوْنَاهُ اِلَي الْحَقِّ وَ دَعَاهُ غَيْرُنَا اِلَي الْفِتْنَةِ فَاثَرَهَا عَلَيْنَا لَنَا رَايَةُ الْحَقِّ مَنِ اِسْتَضَاءَ [ اِسْتَظَلَّ ] بِهَا كَنَّتْهُ وَ مَنْ سَبَقَ اِلَيْهَا فَازَ بِعِلْمِهِ اَنْتُمْ عُمَّارُ الْاَرْضِ [ اَلَّذِينَ ] اِسْتَخْلَفَكُمُ اللَّهُ فِيهَا لِيَنْظُرَ كَيْفَ تَعْمَلُونَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَرَاقِبُوا اللَّهَ فِيمَا يَرَي مِنْكُمْ وَ عَلَيْكُمْ بِالْمَحَجَّةِ الْعُظْمَي فَاسْلُكُوهَا  <quranic_text> « سٰابِقُوا اِليٰ مَغْفِرَةٍ مِنْ رَبِّكُمْ » </quranic_text>   <footnote> [ الحديد ۲۱ ] </footnote>  وَ رَحْمَةٍ  <quranic_text> « وَ جَنَّةٍ عَرْضُهَا السَّمٰاوٰاتُ وَ الْاَرْضُ اُعِدَّتْ لِلْمُتَّقِينَ » </quranic_text>   <footnote> [ العمران ۱۳۳ ] </footnote>  وَ اِعْلَمُوا اَنَّكُمْ لَنْ [ لَمْ ] تَنَالُوهَا اِلاَّ بِالتَّقْوَي وَ مَنْ تَرَكَ الْاَخْذَ عَمَّنْ [ مِمَّنْ عن ] اَمَرَ اللَّهُ بِطَاعَتِهِ قَيَّضَ اللَّهُ  <quranic_text> « لَهُ شَيْطٰاناً فَهُوَ لَهُ قَرِينٌ » </quranic_text>   <footnote> [ الزخرف ۳۶ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"مَا بَالُكُمْ قَدْ رَكَنْتُمْ اِلَي الدُّنْيَا وَ رَضِيتُمْ بِالضَّيْمِ وَ فَرَّطْتُمْ فِيهَا فِيهِ عِزُّكُمْ وَ سَعَادَتُكُمْ وَ قُوَّتُكُمْ عَلَي مَنْ بَغَي عَلَيْكُمْ لاَ مِنْ رَبِّكُمْ تَسْتَحْيُونَ وَ لاَ اَنْفُسَكُمْ تَنْظُرُونَ وَ اَنْتُمْ فِي كُلِّ يَوْمٍ تُضَامُونَ وَ لاَ تَنْتَبِهُونَ مِنْ رَقْدَتِكُمْ وَ لاَ يَنْقَضِي [ تَنْقَضِي ] فَتْرَتُكُمْ مَا تَرَوْنَ دِينَكُمْ يَبْلَي وَ اَنْتُمْ فِي غَفْلَةِ الدُّنْيَا قَالَ اللَّهُ عَزَّ ذِكْرُهُ  <quranic_text> « وَ لاٰ تَرْكَنُوا اِلَي الَّذِينَ ظَلَمُوا فَتَمَسَّكُمُ النّٰارُ وَ مٰا لَكُمْ مِنْ دُونِ اللّٰهِ مِنْ اَوْلِيٰاءَ ثُمَّ لاٰ تُنْصَرُونَ » </quranic_text>   <footnote> [ هود ۱۱۳ ] </footnote>   .","translation_segment":"","segment_columns":[]}]}