{"consensus_set_id":"s412183","translation_language":"fa","translation_source":{"hid":"412183"},"segments":[{"source_hadith_segment":"« فَقَالَ :   <quranic_text> « قُلْ لاٰ اَسْئَلُكُمْ عَلَيْهِ اَجْراً اِلاَّ الْمَوَدَّةَ فِي الْقُرْبيٰ » </quranic_text>   <footnote> [ الشوري ۲۳ ] </footnote> ،  ثُمَّ قَالَ :  ( وَ اِذَا الْمَوَدَّةُ سُئِلَتْ بِاَيِّ ذَنْبٍ قُتِلَتْ ) يَقُولُ : اَسْاَلُكُمْ عَنِ الْمَوَدَّةِ الَّتِي اُنْزِلَتْ عَلَيْكُمْ فَضْلُهَا ،  مَوَدَّةِ الْقُرْبَي ،  بِاَيِّ ذَنْبٍ قَتَلْتُمُوهُمْ ؟  »","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"اسئلكم","display":"اَسْئَلُكُمْ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"اجرا","display":"اَجْراً"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"الموده","display":"الْمَوَدَّةَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القربي","display":"الْقُرْبيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الشوري","display":"الشوري"},{"kind":"word","token":"۲۳","display":"۲۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"الموده","display":"الْمَوَدَّةُ"},{"kind":"word","token":"سئلت","display":"سُئِلَتْ"},{"kind":"word","token":"باي","display":"بِاَيِّ"},{"kind":"word","token":"ذنب","display":"ذَنْبٍ"},{"kind":"word","token":"قتلت","display":"قُتِلَتْ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"اسالكم","display":"اَسْاَلُكُمْ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الموده","display":"الْمَوَد