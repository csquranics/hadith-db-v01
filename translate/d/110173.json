{"consensus_set_id":"110173","translation_language":"fa","translation_source":{"hid":"223946"},"segments":[{"source_hadith_segment":"<quranic_text> « فَتَمَنَّوُا الْمَوْتَ اِنْ كُنْتُمْ صٰادِقِينَ » </quranic_text>   <footnote> [ البقرة ۹۴ ] </footnote>  قَالَ اِنَّ فِي التَّوْرَاةِ مَكْتُوبٌ اَوْلِيَاءُ اللَّهِ يَتَمَنَّوْنَ الْمَوْتَ ثُمَّ قَالَ :   <quranic_text> « اِنَّ الْمَوْتَ الَّذِي تَفِرُّونَ مِنْهُ فَاِنَّهُ مُلاٰقِيكُمْ » </quranic_text>   <footnote> [ الجمعة ۸ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فتمنوا","display":"فَتَمَنَّوُا"},{"kind":"word","token":"الموت","display":"الْمَوْتَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كنتم","display":"كُنْتُمْ"},{"kind":"word","token":"صادقين","display":"صٰادِقِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۹۴","display":"۹۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"التوراه","display":"التَّوْرَاةِ"},{"kind":"word","token":"مكتوب","display":"مَكْتُوبٌ"},{"kind":"word","token":"مكتوبا","display":"مَكْتُوباً"},{"kind":"word","token":"اولياء","display":"اَوْلِيَاءُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"يتمنون","display":"يَتَمَنَّوْنَ"},{"kind":"word","token":"الموت","display":"الْمَوْتَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الموت","display":"الْمَوْتَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"تفرون","display":"تَفِرُّونَ"},{"kind":"word","token":"منه","display":"