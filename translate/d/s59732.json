{"consensus_set_id":"s59732","translation_language":"fa","translation_source":{"hid":"59732"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ تَعَالَي :   <quranic_text> « وَ نُيَسِّرُكَ لِلْيُسْريٰ » </quranic_text>   <footnote> [ الاعلي ۸ ] </footnote>   .  قَالَ :  نُعِينُكَ عَلَي تَبْلِيغِ الرِّسَالَةِ بِمَعْرِفَةِ حَقِّ الْاَوْصِيَاءِ عَلَيْهِمُ السَّلاَمُ  .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نيسرك","display":"نُيَسِّرُكَ"},{"kind":"word","token":"لليسري","display":"لِلْيُسْريٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعلي","display":"الاعلي"},{"kind":"word","token":"۸","display":"۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعينك","display":"نُعِينُكَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"تبليغ","display":"تَبْلِيغِ"},{"kind":"word","token":"الرساله","display":"الرِّسَالَةِ"},{"kind":"word","token":"بمعرفه","display":"بِمَعْرِفَةِ"},{"kind":"word","token":"حق","display":"حَقِّ"},{"kind":"word","token":"الاوصياء","display":"الْاَوْصِيَاءِ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}