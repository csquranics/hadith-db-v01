َصَرْتَهُ عَلَي الْاَحْزَابِ وَ هَدَيْتَنَا بِهِ اِلَي دَارِ الْمَابِ وَ بِاَمِيرِ الْمُؤْمِنِينَ عَلِيِّ بْنِ اَبِي طَالِبٍ الْكَرِيمِ النِّصَابِ الْمُتَصَدِّقِ بِخَاتَمِهِ فِي الْمِحْرَابِ وَ بِالْاِمَامِ الْفَاضِلِ مُحَمَّدِ بْنِ عَلِيٍّ عَلَيْهِ السَّلاَمُ الَّذِي سُئِلَ فَوَفَّقْتَهُ لِرَدِّ الْجَوَابِ وَ اُمْتُحِنَ فَعَضَدْتَهُ بِالتَّوْفِيقِ وَ الصَّوَابِ","translation_segment":"","segment_columns":[{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"خالق","display":"خَالِقَ"},{"kind":"word","token":"الانوار","display":"الْاَنْوَارِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مقدر","display":"مُقَدِّرَ"},{"kind":"word","token":"الليل","display":"اللَّيْلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النهار","display":"النَّهَارِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعلم","display":"تَعْلَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"تحمل","display":"تَحْمِلُ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"انثي","display":"اُنْثيٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"تغيض","display":"تَغِيضُ"},{"kind":"word","token":"الارحام","display":"الْاَرْحٰامُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"تزداد","display":"تَزْدٰادُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۸","display":"۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"عندك","display":"عِنْدَكَ"},{"kind":"word","token":"بمقدار","display