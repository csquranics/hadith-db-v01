{"consensus_set_id":"12197","translation_language":"fa","translation_source":{"hid":"107004"},"segments":[{"source_hadith_segment":"قَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  رَحِمَ اللَّهُ عَبْداً طَلَبَ مِنَ اللَّهِ عَزَّ وَ جَلَّ حَاجَةً فَاَلَحَّ فِي الدُّعَاءِ اُسْتُجِيبَ لَهُ اَوْ لَمْ يُسْتَجَبْ لَهُ وَ تَلاَ هَذِهِ الْايَةَ :   <quranic_text> « وَ اَدْعُوا رَبِّي عَسيٰ اَلاّٰ اَكُونَ بِدُعٰاءِ رَبِّي شَقِيًّا » </quranic_text>   <footnote> [ مريم ۴۸ ] </footnote>   .","translation_segment":"حضرت صادق ع فرمود: رسول خدا (صلی الله علیه و آله) فرمود: خدا رحمت کند بنده‌ای را که از خدای عز و جل حاجتی بخواهد و در دعای در باره آن پافشاری و اصرار کند، خواه اجابت شود و خواه اجابت نشود، و این آیه را تلاوت فرمود (که ابراهیم ع فرماید:) «و دعا کنم بدرگاه پروردگار خود شاید بوسیله دعای پروردگارم تیره بخت نباشم» (سوره مریم آیه ۴۸).","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رحم","display":"رَحِمَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عبدا","display":"عَبْداً"},{"kind":"word","token":"طلب","display":"طَلَبَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"حاجه","display":"حَاجَةً"},{"kind":"word","token":"فالح","display":"فَاَلَحَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الدعاء","display":"الدُّعَاءِ"},