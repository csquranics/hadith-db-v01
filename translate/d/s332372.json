{"consensus_set_id":"s332372","translation_language":"fa","translation_source":{"hid":"332372"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي :  ]  <quranic_text> « فَمٰا يُكَذِّبُكَ بَعْدُ بِالدِّينِ » </quranic_text>   <footnote> [ التين ۷ ] </footnote>  [ قَالَ :  يَعْنِي ] وَلاَيَةَ عَلِيِّ بْنِ اَبِي طَالِبٍ  .","translation_segment":"عن موسی بن جعفر فی قوله تعالی: (فما یکذبک بعد بالدین) قال، یعنی ولایه علی بن أبی طالب. موسی بن جعفر درباره سخن خداوند، «فمٰا یکذبک‌ بعد بالدین‌» گفت: یعنی ولایت علی‌ بن ابی طالب.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فما","display":"فَمٰا"},{"kind":"word","token":"يكذبك","display":"يُكَذِّبُكَ"},{"kind":"word","token":"بعد","display":"بَعْدُ"},{"kind":"word","token":"بالدين","display":"بِالدِّينِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التين","display":"التين"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"ولايه","display":"وَلاَيَةَ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"}]}]}