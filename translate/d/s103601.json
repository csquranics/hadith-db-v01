{"consensus_set_id":"s103601","translation_language":"fa","translation_source":{"hid":"103601"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اِمْرَاَةٌ مَاتَتْ وَ تَرَكَتْ زَوْجَهَا وَ اِخْوَتَهَا لِاُمِّهَا وَ اِخْوَتَهَا لِاَبِيهَا فَقَالَ","translation_segment":"و ابن أبی عمیر، از ابن اذینه، از بکیر بن اعین روایت کرده است که گفت: به امام صادق علیه السلام معروض داشتم که زنی مرده است و شوهرش و برادران مادریش و برادران [و","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"امراه","display":"اِمْرَاَةٌ"},{"kind":"word","token":"ماتت","display":"مَاتَتْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تركت","display":"تَرَكَتْ"},{"kind":"word","token":"زوجها","display":"زَوْجَهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اخوتها","display":"اِخْوَتَهَا"},{"kind":"word","token":"لامها","display":"لِاُمِّهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اخوتها","display":"اِخْوَتَهَا"},{"kind":"word","token":"لابيها","display":"لِاَبِيهَا"},{"kind":"word","token":"فقال","display":"فَقَالَ"}]},{"source_hadith_segment":"« لِلزَّوْجِ النِّصْفُ ثَلاَثَةُ اَسْهُمٍ وَ لِلْاِخْوَةِ لِلْاُمِّ الثُّلُثُ الذَّكَرُ وَ الْاُنْثَي فِيهِ سَوَاءٌ وَ بَقِيَ سَهْمٌ فَهُوَ لِلْاِخْوَةِ وَ الْاَخَوَاتِ مِنَ الْاَبِ <quranic_text> « لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>   .","translation_segment":"خواهران] پدریش را بجای گذاشته است. امام فرمود: نصف ترکه: سه سهم برای شوهر، و ثلث آن برای برادران مادری است که بطور مساوی میان پسران و دختران قسمت می‌شود، و سهمی باقی مانده است که آن بقاعده «للذکر مثل‌ حظ‍‌ الأنثیین‌» به برادران و خواهران پدری تعلق میگیرد. تذکر: «[و خواهران] میان کروشه در این کتاب نبود از تهذیب و کافی اخذ شد».","segment_columns":[{"kind":"word","token":"للزوج","display":"لِلزَّوْجِ"},{"kind":"word","token":"النصف","display":"النِّصْفُ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةُ"},{"kind":"word","token":"اسهم","display":"اَسْهُمٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"للاخوه","display":"لِلْاِخْوَةِ"},{"kind":"word","token":"للام","display":"لِلْاُمِّ"},{"kind":"word","token":"الثلث","display":"الثُّلُثُ"},{"kind":"word","token":"الذكر","display":"الذَّكَرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الانثي","display":"الْاُنْثَي"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"سواء","display":"سَوَاءٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بقي","display":"بَقِيَ"},{"kind":"word","token":"سهم","display":"سَهْمٌ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"للاخوه","display":"لِلْاِخْوَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الاخوات","display":"الْاَخَوَاتِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الاب","display":"الْاَبِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"للذكر","display":"لِلذَّكَرِ"},{"kind":"word","token":"مثل","display":"مِثْلُ"},{"kind":"word","token":"حظ","display":"حَظِّ"},{"kind":"word","token":"الانثيين","display":"الْاُنْثَيَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۱","display":"۱۱"},{"kind":"tag_close","tag_name":"footnote"}]}]}