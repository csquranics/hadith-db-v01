{"consensus_set_id":"s385936","translation_language":"fa","translation_source":{"hid":"385936"},"segments":[{"source_hadith_segment":"« اَتَي النَّبِيَّ عَلَيْهِ الصَّلاَةُ وَ السَّلاَمُ رَجُلٌ مِنْ اَهْلِ الْكِتَابِ ،  فَقَالَ :  يَا اَبَا الْقَاسِمِ  :  اَ بَلَغَكَ اَنَّ اللَّهَ يَحْمِلُ السَّمَاوَاتِ عَلَي اِصْبَعٍ ،  وَ الْاَرْضَ عَلَي اِصْبَعٍ ؟  وَ الشَّجَرَ عَلَي اِصْبَعٍ ،  وَ الثَّرَي عَلَي اِصْبَعٍ ،  وَ الْخَلاَئِقَ عَلَي اِصْبَعٍ ،  فَضَحِكَ عَلَيْهِ الصَّلاَةُ وَ السَّلاَمُ مِنْ قَوْلِهِ ،  وَ اَنْزَلَ اللَّهُ سُبْحَانَهُ عَقِيبَ ذَلِكَ : <quranic_text> « وَ مٰا قَدَرُوا اللّٰهَ حَقَّ قَدْرِهِ .  .  .  » </quranic_text>   <footnote> [ الانعام ۹۱ ] </footnote> الْايَةِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"اتي","display":"اَتَي"},{"kind":"word","token":"النبي","display":"النَّبِيَّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"القاسم","display":"الْقَاسِمِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"بلغك","display":"بَلَغَكَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يحمل","display":"يَحْمِلُ"},{"kind":"word","token":"السماوات","display":"السَّمَاوَاتِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اصبع","display":"اِصْبَعٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"