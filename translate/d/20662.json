{"consensus_set_id":"20662","translation_language":"fa","translation_source":{"hid":"101367"},"segments":[{"source_hadith_segment":"وَ سَاَلْتُ اَبَا الْحَسَنِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ دٰاوُدَ وَ سُلَيْمٰانَ اِذْ يَحْكُمٰانِ فِي الْحَرْثِ » </quranic_text>   <footnote> [ الانبياء ۷۸ ] </footnote>","translation_segment":"احمد بن عمر حلبی گوید: از موسی بن جعفر علیهما السلام پرسیدم در مورد این آیه «و دٰاود و سلیمٰان‌ إذ یحکمٰان‌» … تا آخر آیه» فرمود: نظر داود این بود","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"داود","display":"دٰاوُدَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سليمان","display":"سُلَيْمٰانَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"يحكمان","display":"يَحْكُمٰانِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحرث","display":"الْحَرْثِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۷۸","display":"۷۸"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ « كَانَ حُكْمُ دَاوُدَ عَلَيْهِ الس