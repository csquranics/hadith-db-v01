ل به سحر کل ساحر، و بغی کل باغ، و حسد کل حاسد، و یتصدع لعظمته البر و البحر، و یستقل به الفلک، حین یتکلم به الملک فلا یکون للموج علیه سبیل و هو اسمک الاعظم الاعظم، الاجل الاجل النور الاکبر، الذی سمیت به نفسک، و استویت به علی عرشک، و أتوجه الیک بمحمد و أهل بیته، أسألک بک و بهم ان تصلی علی محمد و آل محمد و ان تفعل بی کذا و کذا». (و بجای «کذا و کذا» حاجت خود را ذکر کند).","segment_columns":[{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"اسالك","display":"اَسْاَلُكَ"},{"kind":"word","token":"باسمك","display":"بِاسْمِكَ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمِ"},{"kind":"word","token":"الاعظم","display":"الْاَعْظَمِ"},{"kind":"word","token":"الاجل","display":"الْاَجَلِّ"},{"kind":"word","token":"الاكرم","display":"الْاَكْرَمِ"},{"kind":"word","token":"المخزون","display":"الْمَخْزُونِ"},{"kind":"word","token":"المكنون","display":"الْمَكْنُونِ"},{"kind":"word","token":"النور","display":"النُّورِ"},{"kind":"word","token":"الحق","display":"الْحَقِّ"},{"kind":"word","token":"البرهان","display":"الْبُرْهَانِ"},{"kind":"word","token":"المبين","display":"الْمُبِينِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"نور","display":"نُورٌ"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"نور","display":"نُورٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نور","display":"نُورٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"نور","display":"نُورٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نور","display":"نُورٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"نور","display":"نُورٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"نور","display":"نُورٌ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"كل","display":"كل"},{"kind":"word","token":"نور","display":"نُورٍ"},{"ki