بَرِيَّتِهِ ،  الْقَادِرِ عَلَي اَمْرِهِ ،  الْمَحْمُودِ فِي صُنْعِهِ ،  اللَّطِيفِ بِعِلْمِهِ ،  الرَّءُوفِ بِعِبَادِهِ ،  الْمُسْتَاْثِرِ بِجَبَرُوتِهِ ،  فِي عِزِّهِ وَ جَلاَلِهِ وَ هَيْبَتِهِ .  الْحَمْدُ لِلَّهِ الَّذِي خَلَقَ الْخَلْقَ عَلَي غَيْرِ مِثَالٍ ،  وَ قَهَرَ الْعِبَادَ بِغَيْرِ اَعْوَانٍ ،  وَ رَفَعَ السَّمَاءَ بِغَيْرِ عَمَدٍ ،  وَ بَسَطَ الْاَرْضَ عَلَي الْهَوَاءِ بِغَيْرِ اَرْكَانٍ .  الْحَمْدُ لِلَّهِ عَلَي مَا يُبْدِي وَ مَا يُخْفِي","translation_segment":"","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"احصي","display":"اَحْصيٰ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"عددا","display":"عَدَداً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الجن","display":"الجن"},{"kind":"word","token":"۲۸","display":"۲۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وسع","display":"وَسِعَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"رحمه","display":"رَحْمَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علما","display":"عِلْماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"غافر","display":"غافر"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الحمد","display":"الْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"زين","display":"زَيَّنَ"},{"kind":"word","token":"السماء","display":"السَّمَاءَ"},{"kind":"word","token":"بمصابيح","display":"بِمَصَابِيحَ"},{"kind":"word",