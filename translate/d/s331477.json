{"consensus_set_id":"s331477","translation_language":"fa","translation_source":{"hid":"331477"},"segments":[{"source_hadith_segment":"قَالَ [ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « قُلْ اَ اُنَبِّئُكُمْ بِخَيْرٍ مِنْ ذٰلِكُمْ » </quranic_text>   <footnote> [ العمران ۱۵ ] </footnote>  الْايَةُ كُلُّهَا [ نَزَلَتْ ] فِي عَلِيٍّ وَ حَمْزَةَ وَ عُبَيْدَةَ بْنِ الْحَارِثِ .","translation_segment":"عن ابن عباس قال فی قوله تعالی: (قل أونبئکم بخیر من ذلکم) الآیه کلها نزلت فی علی‌ و حمزه و عبیده بن الحارث. ابن عباس گفت: آیه «قل‌ أ أنبئکم‌ بخیر من‌ ذٰلکم‌» همه‌اش درباره علی و حمزه و عبیده بن حارث نازل شده است.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"انبئكم","display":"اُنَبِّئُكُمْ"},{"kind":"word","token":"بخير","display":"بِخَيْرٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ذلكم","display":"ذٰلِكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۵","display":"۱۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"word","token":"كلها","display":"كُلُّهَا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حمزه","display":"حَمْزَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عبيده","display":"عُبَيْدَةَ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"الحارث","display":"الْحَارِثِ"}]}]}