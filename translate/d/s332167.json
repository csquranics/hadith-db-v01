{"consensus_set_id":"s332167","translation_language":"fa","translation_source":{"hid":"332167"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اَلْقِيٰا فِي جَهَنَّمَ كُلَّ كَفّٰارٍ عَنِيدٍ » </quranic_text>   <footnote> [ ق ۲۴ ] </footnote>  قَالَ :  النَّبِيُّ وَ عَلِيٌّ يُلْقِيَانِ .","translation_segment":"عن عکرمه فی قوله تعالی: (ألقیا فی جهنم کل‌ کفار عنید) قال: النبی و علی‌ یلقیان. عکرمه درباره سخن خداوند: «القیا فی جهنم کل کفار عنید» گفت: پیامبر و علی می‌افکنند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"القيا","display":"اَلْقِيٰا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"جهنم","display":"جَهَنَّمَ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"كفار","display":"كَفّٰارٍ"},{"kind":"word","token":"عنيد","display":"عَنِيدٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ق","display":"ق"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"يلقيان","display":"يُلْقِيَانِ"}]}]}