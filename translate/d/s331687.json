{"consensus_set_id":"s331687","translation_language":"fa","translation_source":{"hid":"331687"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « فَلَوْ لاٰ كٰانَ مِنَ الْقُرُونِ مِنْ قَبْلِكُمْ اُولُوا بَقِيَّةٍ يَنْهَوْنَ عَنِ الْفَسٰادِ فِي الْاَرْضِ » </quranic_text>   <footnote> [ هود ۱۱۶ ] </footnote>  قَالَ :  نَزَلَتْ هَذِهِ فِينَا .","translation_segment":"عن زید بن علی ع فی قوله: (فلو لا کان من القرون من قبلکم أولوا بقیه ینهون عن الفساد فی الأرض) قال: نزلت هذه فینا. زید بن علی درباره سخن خداوند: «فلو لا کان من القرون من قبلکم اولو بقیه» گفت: این آیه درباره ما نازل شده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلو","display":"فَلَوْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"القرون","display":"الْقُرُونِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبلكم","display":"قَبْلِكُمْ"},{"kind":"word","token":"اولوا","display":"اُولُوا"},{"kind":"word","token":"بقيه","display":"بَقِيَّةٍ"},{"kind":"word","token":"ينهون","display":"يَنْهَوْنَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الفساد","display":"الْفَسٰادِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"هود","display":"هود"},{"kind":"word","token":"۱۱۶","display":"۱۱۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"فينا","display":"فِينَا"}]}]}