{"consensus_set_id":"116735","translation_language":"fa","translation_source":{"hid":"332081"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ رَجُلاً سَلَماً لِرَجُلٍ » </quranic_text>   <footnote> [ الزمر ۲۹ ] </footnote>  قَالَ :  اَنَا ذَلِكَ الرَّجُلُ السَّلِيمُ لِرَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  .","translation_segment":"عن محمد بن الحنفیه عن علی‌ ع فی قوله تعالی: (و رجلا سلما لرجل) قال: أنا ذلک الرجل السلیم لرسول الله صلی الله علیه و آله و سلم. محمد بن حنفیه از علی (علیه السلام) درباره سخن خداوند: «و رجلا سلما لرجل» نقل می‌کند که گفت: من همان مردی هستم که تسلیم پیامبر خدا بودم.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"سلما","display":"سَلَماً"},{"kind":"word","token":"لرجل","display":"لِرَجُلٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزمر","display":"الزمر"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"السليم","display":"السَّلِيمُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"لرسول","display":"لِرَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"}]}]}