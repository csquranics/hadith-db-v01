"source_hadith_segment":".  فَتَكَلَّمَ هَانِي بْنُ قَبِيصَةَ فَقَالَ :  يَا اَخَا قُرَيْشٍ قَدْ سَمِعْنَا مَقَالَتَكَ ،  وَ اِنَّا لَنَرَي اَنَّ تَرْكَ دِينِنَا وَ الاِنْتِقَالَ اِلَي دِينِكَ فِي مَجْلِسٍ نَجْلِسُهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَمْ نَنْظُرْ فِيهِ - فِي اَمْرِكَ وَ لَمْ نَرْتَئِي فِي عَاقِبَةِ مَا تَدْعُو اِلَيْهِ لَزَلَّةٌ فِي الرَّاْيِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اَوْ عِجَالٌ فِي النَّظَرِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ الزَّلَّةُ تَكُونُ مَعَ الْعَجَلَةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اَنَّ مِنْ وَرَائِنَا قَوْماً يَكْرَهُونَ اَنْ نَعْقِدَ عَلَيْهِمْ عَقْداً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَكِنْ نَرْجِعُ وَ تَرْجِعُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ تَنْظُرُ وَ نَنْظُرُ - وَ كَاَنَّهُ اَحَبَّ اَنْ يَشْرَكَهُ فِي الْكَلاَمِ الْمُثَنَّي بْنِ حَارِثَةَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"- .  فَقَالَ :  وَ هَذَا الْمُثَنَّي بْنُ حَارِثَةَ وَ هُوَ شَيْخُنَا وَ كَبِيرُنَا وَ صَاحِبُ حَرْبِنَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَتَكَلَّمَ الْمُثَنَّي بْنُ حَارِثَةَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ :  يَا اَخَا قُرَيْشٍ قَدْ سَمِعْتُ مَقَالَتَكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاَمَّا الْجَوَابُ فِي تَرْكِنَا دِينَنَا وَ اِتِّبَاعِنَا اِيَّاكَ عَلَي دِينِكَ فَهُوَ جَوَابُ هَانِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اَمَّا الْجَوَابُ فِي اَنْ نُؤْوِيَكَ وَ نَنْصُرَكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنَّا نَزَلْنَا بَيْنَ صَيْرَيْنِ :  الْيَمَامَةِ وَ السَّمَاوَةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  [ ضَبْطُ الْغَرِيبِ ] قَوْلُهُ :  بَيْنَ صَيْرَيْنِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  الصَّيْرُ - فِي كَلاَمِ الْعَرَبِ - :  الشَّقُّ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ فِي الْحَدِيثِ :  مَنْ نَظَرَ فِي صَيْرِ بَابٍ - اَيْ فِي شَقِّ بَابٍ - فَفُقِئَتْ عَيْنُهُ فَهِيَ هَدَرٌ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ الصَّيْرُ اَيْضاً فِي كَلاَمِهِمْ ،  صَيْرُ الْبَقَرِ :  وَ هُوَ مَوْضِعٌ مَحْدُودٌ كَالْحَظِيرَةِ مِنْ اَغْصَانِ الشَّجَرِ وَ الْحِجَارَةِ وَ نَحْوِهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِذَا كَانَ ذَلِكَ لِلْغَنَمِ ،  قِيلَ زَرِيبَةٌ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ صَيْرُ كُلِّ شَيْءٍ مَصِيرُهُ :  فَقَالَ لَهُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ :  مَا هَذَانِ الصَّيْرَانِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  قَالَ :  مِيَاهُ الْعَرَبِ وَ اَنْهَارُ كِسْرَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاَمَّا مَا كَانَ يَلِي مِيَاهَ الْعَرَبِ فَذَنْبُ صَاحِبِهِ مَغْفُورٌ ،  وَ عُذْرُهُ مَقْبُولٌ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ اَمَّا مَا كَانَ يَلِي اَنْهَارَ كِسْرَي فَذَنْبُ صَاحِبِهِ غَيْرُ مَغْفُورٍ ،  وَ عُذْرُهُ غَيْرُ مَقْبُولٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ اِنَّمَا نَزَلْنَا هُنَالِكَ عَلَي عَهْدٍ اَخَذَهُ عَلَيْنَا كِسْرَي اَلاَّ نُحْدِثَ حَدَثاً وَ لاَ نُؤْوِيَ مُحْدِثاً ،  وَ لَسْنَا نَاْمَنُ مِنْ اَنْ يَكُونَ هَذَا الْاَمْرُ الَّذِي تَدْعُو اِلَيْهِ مِمَّا تَكْرَهُ الْمُلُوكُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنْ اَحْبَبْتَ اَنْ نُؤْوِيَكَ وَ نَنْصُرَكَ مِمَّا يَلِي مِيَاهَ الْعَرَبِ اوَيْنَاكَ وَ نَصَرْنَاكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ الِهِ :  مَا اَسَاْتُمْ فِي الرَّدِّ اِذَا فَصَحْتُمْ بِالصِّدْقِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَيْسَ يَقُومُ بِدِينِ اللَّهِ عَزَّ وَ جَلَّ اِلاَّ مَنْ حَاطَهُ مِنْ جَمِيعِ جَوَانِبِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اَرَيْتُمْ اِنْ لَمْ تَلْبَثُوا اِلاَّ يَسِيراً حَتَّي يَمْنَحَكُمُ اللَّهُ عَزَّ وَ جَلَّ اَمْوَالَهُمْ وَ يُوْرِثَكُمْ دِيَارَهُمْ ،  وَ يُفْرِشَكُمْ نِسَاءَهُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اَ تُسَبِّحُونَ اللَّهَ تَعَالَي وَ تُقَدِّسُونَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  فَقَالَ النُّعْمَانُ بْنُ شَرِيكٍ :  اللَّهُمَّ لَكَ ذَلِكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَتَلاَ عَلَيْهِمْ :   <quranic_text> « يٰا اَيُّهَا النَّبِيُّ اِنّٰا اَرْسَلْنٰاكَ شٰاهِداً وَ مُبَشِّراً وَ نَذِيراً وَ دٰاعِياً اِلَي اللّٰهِ بِاِذْنِهِ وَ سِرٰاجاً مُنِيراً » </quranic_text>   <footnote> [ الاحزاب ۴۵ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ وَثَبَ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَاَخَذَ بِيَدِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ قَالَ لِي :  يَا عَلِيُّ ،  اَيُّ اَحْلاَمٍ فِي الْجَاهِلِيَّةِ يَرُدُّ اللَّهُ عَزَّ وَ جَلَّ بِهَا بَاْسَ بَعْضِهِمْ عَنْ بَعْضٍ وَ يَتَحَاجَزُونَ بِهَا فِي هَذِهِ الدُّنْيَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ كَانَ مِنْ اُولَئِكَ مَنْ اَسْلَمَ وَ وَفَدَ عَلَي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ نَالَ بِمَا وَعَدَهُمْ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مِنْ مَمْلَكَةِ كِسْرَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ نَصَرَ عَلِيّاً عَلَيْهِ السَّلاَمُ فِي حُرُوبِهِ .","translation_segment":"","segment_columns":[]}]}