{"consensus_set_id":"3466","translation_language":"fa","translation_source":{"hid":"337560"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اِنَّ قَوْماً يَرْوُونَ اَنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ قَالَ اِخْتِلاَفُ اُمَّتِي رَحْمَةٌ فَقَالَ","translation_segment":"علی بن احمد رحمه اللٰه علیه می‌گوید: محمد بن ابی عبد اللٰه کوفی، از ابی الخیر صالح بن ابی حماد، از احمد بن هلال، از محمد بن ابی عمیر، از عبد المومن انصاری نقل کرده که وی گفت: محضر امام صادق علیه السلام عرض کردم: گروهی روایت کرده‌اند که رسول خدا صلی اللٰه","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"قوما","display":"قَوْماً"},{"kind":"word","token":"يروون","display":"يَرْوُونَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلّم"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اختلاف","display":"اِخْتِلاَفُ"},{"kind":"word","token":"امتي","display":"اُمَّتِي"},{"kind":"word","token":"رحمه","display":"رَحْمَةٌ"},{"kind":"word","token":"فقال","display":"فَقَالَ"}]},{"source_hadith_segment":"صَدَقُوا فَقُلْتُ اِنْ كَانَ اِخْتِلاَفُهُمْ رَحْمَةً فَاجْتِمَاعُهُمْ عَذَابٌ قَالَ","translation_segment":"علیه و آله فرمودند: اختلاف امت من با هم رحمت است، آیا این روایت صحیح است‌؟ حضرت فرمودند: بلی آنها درست روایت کرده‌اند. عرضه داشتم:","segment_columns":[{"kind":"word","token":"صدقوا","display":"صَدَقُوا"},{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"له","display":"له"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"اختلافهم","display":"اِخْتِلاَفُهُمْ"},{"kind":"word","token":"رحمه","display":"رَحْمَةً"},{"kind":"word","token":"فاجتماعهم","display":"فَاجْتِمَاعُهُمْ"},{"kind":"word","token":"عذاب","display":"عَذَابٌ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"لَيْسَ حَيْثُ تَذْهَبُ وَ ذَهَبُوا وَ اِنَّمَا اَرَادَ قَوْلَ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « فَلَوْ لاٰ نَفَرَ مِنْ كُلِّ فِرْقَةٍ مِنْهُمْ طٰائِفَةٌ لِيَتَفَقَّهُوا فِي الدِّينِ وَ لِيُنْذِرُوا قَوْمَهُمْ اِذٰا رَجَعُوا اِلَيْهِمْ لَعَلَّهُمْ يَحْذَرُونَ » </quranic_text>   <footnote> [ التوبة ۱۲۲ ] </footnote>  فَاَمَرَهُمْ اَنْ يَنْفِرُوا اِلَي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ يَخْتَلِفُوا اِلَيْهِ فَيَتَعَلَّمُوا ثُمَّ يَرْجِعُوا اِلَي قَوْمِهِمْ فَيُعَلِّمُوهُمْ اِنَّمَا اَرَادَ اِخْتِلاَفَهُمْ مِنَ الْبُلْدَانِ لاَ اِخْتِلاَفاً فِي دِينِ اللَّهِ اِنَّمَا الدِّينُ وَاحِدٌ اِنَّمَا الدِّينُ وَاحِدٌ .","translation_segment":"اگر اختلافشان رحمت باشد، پس اجتماعشان عذاب است. حضرت فرمودند: آن معنایی که ذهن تو و دیگران به آن رفته مراد نیست، بلکه مقصود همان معنایی است که خدای عز و جل‌ از آیه ذیل اراده فرموده: «فلو لاٰ نفر من‌ کل‌ فرقه‌ منهم‌ طٰائفه‌ لیتفقهوا فی الدین‌ و لینذروا قومهم‌ إذٰا رجعوا إلیهم‌ لعلهم‌ یحذرون‌». (چرا از هر طائفه‌ای جمعی برای جنگ و گروهی نزد رسول برای آموختن علم مهیا نباشند و علمی را که آموخته‌اند به قوم خویش بیاموزند تا قومشان نیز شاید خدا ترس شده و از نافرمانی حذر کنند). در این آیه شریفه خداوند متعال به مردم امر نموده که کوچ کرده و محضر رسولش صلی اللٰه علیه و آله تردد کرده و از آن حضرت معارف را تعلم نموده و سپس به قوم خویش برگشته و آنها را تعلیم کنند و با توجه به معنای این آیه می‌توان گفت: مراد و مقصود پیامبر اکرم صلی اللٰه علیه و آله از اختلاف امت، اختلافشان از شهرها و رفت و آمدشان برای کسب معارف دینی است نه اختلاف و نزاع در دین و داشتن دین‌های متعدد چه آن که دین یکی بیشتر نیست (و این عبارت را امام علیه السلام دو بار تکرار فرمودند).","segment_columns":[{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"حيث","display":"حَيْثُ"},{"kind":"word","token":"تذهب","display":"تَذْهَبُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذهبوا","display":"ذَهَبُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"اراد","display":"اَرَادَ"},{"kind":"word","token":"قول","display":"قَوْلَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلو","display":"فَلَوْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"نفر","display":"نَفَرَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"فرقه","display":"فِرْقَةٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه۱۲۲","display":"التوبة۱۲۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"الي"},{"kind":"word","token":"قوله-","display":"قوله-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"طائفه","display":"طٰائِفَةٌ"},{"kind":"word","token":"ليتفقهوا","display":"لِيَتَفَقَّهُوا"},{"kind