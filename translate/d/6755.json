اَّ اَنْتَ كُنْتَ اِذْ لَمْ تَكُنْ سَمَاءٌ مَبْنِيَّةٌ وَ لاَ اَرْضٌ مَدْحِيَّةٌ وَ لاَ شَمْسٌ مُضِيئَةٌ وَ لاَ لَيْلٌ مُظْلِمٌ وَ لاَ نَهَارٌ مُضِيءٌ وَ لاَ بَحْرٌ لُجِّيٌّ وَ لاَ جَبَلٌ رَاسٍ وَ لاَ نَجْمٌ سَارٍ وَ لاَ قَمَرٌ مُنِيرٌ وَ لاَ رِيحٌ تَهَبُّ وَ لاَ سَحَابٌ يَسْكُبُ وَ لاَ بَرْقٌ يَلْمَعُ وَ لاَ رَعْدٌ يُسَبِّحُ وَ لاَ رُوحٌ تَتَنَفَّسُ وَ لاَ طَائِرٌ يَطِيرُ وَ لاَ نَارٌ تَتَوَقَّدُ وَ لاَ مَاءٌ يَطْرُدُ كُنْتَ قَبْلَ كُلِّ شئ وَ كَوَّنْتَ كُلَّ شَيْئٍ وَ قَدَّرْتَ كُلَّ شَيْئٍ وَ اِبْتَدَعْتَ كُلَّ شَيْئٍ وَ اَفْقَرْتَ وَ اَغْنَيْتَ وَ اَمَتَّ وَ اَحْيَيْتَ وَ اَضْحَكْتَ وَ اَبْكَيْتَ وَ عَلَي الْعَرْشِ اِسْتَوَيْتَ فَتَبَارَكْتَ يَا اللَّهُ وَ تَعَالَيْتَ اَنْتَ اللَّهُ الَّذِي لاَ اِلَهَ اِلاَّ اَنْتَ الْخَلاَّقُ الْعَلِيمُ اَمْرُكَ غَالِبٌ وَ عِلْمُكَ نَافِذٌ وَ كَيْدُكَ قَرِيبٌ وَ وَعْدُكَ صَادِقٌ وَ قَوْلُكَ حَقٌّ وَ حُكْمُكَ عَدْلٌ وَ كَلاَمُكَ هُدًي وَ وَحْيُكَ نُورٌ وَ رَحْمَتُكَ وَاسِعَةٌ وَ عَفْوُكَ عَظِيمٌ وَ فَضْلُكَ كَبِيرٌ وَ عَطَاؤُكَ جَزِيلٌ وَ حَبْلُكَ مَتِينٌ وَ اِمْكَانُكَ عَتِيدٌ وَ جَارُكَ عَزِيزٌ وَ بَاْسُكَ شَدِيدٌ وَ مَكْرُكَ مَكِيدٌ اَنْتَ يَا رَبِّ مَوْضِعُ كُلِّ شَكْوَي شَاهِدُ كُلِّ نَجْوَي حَاضِرُ كُلِّ مَلاَءٍ مُنْتَهَي كُلِّ حَاجَةٍ فَرَجُ كُلِّ حَزِينٍ غِنَي كُلِّ فَقِيرٍ مِسْكِينٍ حِصْنُ كُلِّ هَارِبٍ اَمَانُ كُلِّ خَائِفٍ حِرْزُ الضُّعَفَاءِ كَنْزُ الْفُقَرَاءِ مُفَرِّجُ الْغَمَّاءِ مُعِينُ الصَّالِحِينَ ذَلِكَ اللَّهُ رَبُّ الْعَالَمِينَ رَبُّنَا لاَ اِلَهَ اِلاَّ هُوَ تَكْفِي مِنْ عِبَادِكَ وَ نَاصِرُ مَنْ تَوَكَّلَ عَلَيْكَ","translation_segment":"چه را بلند کنی دیگری پستش نتواند، هر که را خوار گردانی کسش عزت نتوان داد، و هر که را عزیز کنی کسی خوارش نتواند ساخت، آنچه عطا فرمودی جلوگیر ندارد، و آنچه را ندادی دیگری نتواند بدهد. توئی خدائی که معبودی جز تو نیست، بودی تو در آن هنگامی که نه آسمان ساخته‌ای بود، و نه زمین گسترده‌ای، و نه خورشید درخشنده‌ای، و نه شب تاری و نه روز روشنی، و نه دریای مواجی، و نه کوه استواری، و نه ستاره سیاری، و نه ماه تابانی، و نه باد وزانی و نه ابر ریزانی، و نه برق رخشانی، و نه رعد بتسبیح غرانی، و نه جانی که دم زند، و نه پرنده‌ای که بپرد، و نه آتشی که روشن گردد، و نه آبی که روان شود. پیش از هر چیز بودی، و همه را تو هستی بخشیدی، و بر هر چیز قادر و توانا گشتی، و همه را تو پدید آوردی، توئی که توانگر کنی و فقیر گردانی، و بمیرانی و زنده سازی، بخندانی و بگریانی، و بر عرش استیلاء داری، پس منزهی تو ای خدا و برتری. توئی خدائی که معبودی جز تو نیست آن آفریدگار دانا، فرمانت پیروز و دانشت نافذ، و مکرت نزدیک، و وعده‌ات راست، گفتارت درست، و حکم و دستورت (از روی) عدالت، و کلامت هدایت، و وحی تو نور، و رحمتت پهناور، و گذشتت بس بزرگ، و فضل و کرمت بسیار، و عطایت شایان، و رشته (توسل به) تو محکم، و إمکان (و وسائل جور کردن) تو مهیا، و پناهنده‌ات نیرومند، و کیفرت سخت، و کید و مکرت زیرکانه است. تو ای پروردگار من مرجع هر شکایتی، مطلع از هر سخن در گوشی، و حاضر در هر انجمنی، حد نهائی هر حاجت، و بر طرف‌کننده هر اندوه (یا گشایش هر اندوهگین)، توانگری هر فقیر بینوا، دژ محکم هر گریزان،","segment_columns":[{"kind":"word","token":"اعطيت","display":"اَعْطَيْتَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"معطي","display":"مُعْطِيَ"},{"kind":"word","token":"لما","display":"لِمَا"},{"kind":"word","token":"منعت","display":"مَنَعْتَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اله","display":"اِلَهَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"كنت","display":"كُنْتَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تكن","display":"تَكُنْ"},{"kind":"word","token":"سماء","display":"سَمَاءٌ"},{"kind":"word","token":"مبنيه","display":"مَبْنِيَّةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ارض","display":"اَرْضٌ"},{"kind":"word","token":"مدحيه","displ