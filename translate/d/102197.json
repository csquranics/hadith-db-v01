{"consensus_set_id":"102197","translation_language":"fa","translation_source":{"hid":"110926"},"segments":[{"source_hadith_segment":"عَلَي اَلْمُتَمَتِّعِ  <quranic_text> « بِالْعُمْرَةِ اِلَي الْحَجِّ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  ثَلاَثَةُ اَطْوَافٍ بِالْبَيْتِ وَ يُصَلِّي لِكُلِّ طَوَافٍ رَكْعَتَيْنِ وَ سَعْيَانِ بَيْنَ الصَّفَا وَ الْمَرْوَةِ .","translation_segment":"منصور بن حازم گوید: امام صادق علیه السلام فرمود: کسی که حج‌ و عمره تمتع به جا آورد، باید سه نوبت دور خانه کعبه طواف کند و برای هر طوافی دو رکعت نماز بخواند، و دو نوبت بین صفا و مروه سعی کند.","segment_columns":[{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المتمتع","display":"اَلْمُتَمَتِّعِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بالعمره","display":"بِالْعُمْرَةِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۶","display":"۱۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةُ"},{"kind":"word","token":"اطواف","display":"اَطْوَافٍ"},{"kind":"word","token":"بالبيت","display":"بِالْبَيْتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يصلي","display":"يُصَلِّي"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"طواف","display":"طَوَافٍ"},{"kind":"word","token":"ركعتين","display":"رَكْعَتَيْنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سعيان","display":"سَعْيَانِ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"الصفا","display":"الصَّفَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المروه","display":"الْمَرْوَةِ"}]}]}