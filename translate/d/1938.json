مُ الْبُخْلَ بَلاَءً لاَ يَسْتَطِيعُونَ دَفْعَهُ عَنْ اَنْفُسِهِمْ مِنْ غَيْرِ شَهْوَةٍ اِلَي ذَلِكَ حَتَّي صَارُوا يَطْلُبُونَهُ مِنَ الرِّجَالِ فِي الْبِلاَدِ وَ يُعْطُونَهُمْ عَلَيْهِ الْجُعْلَ فَقُلْتُ لَهُ جُعِلْتُ فِدَاكَ فَهَلْ كَانَ اَهْلُ قَرْيَةِ لُوطٍ كُلُّهُمْ يَفْعَلُونَ فَقَالَ نَعَمْ اِلاَّ اَهْلُ بَيْتٍ مِنْهُمْ مِنَ الْمُسْلِمِينَ اَ مَا تَسْمَعُ لِقَوْلِهِ تَعَالَي  <quranic_text> « فَاَخْرَجْنٰا مَنْ كٰانَ فِيهٰا مِنَ الْمُؤْمِنِينَ فَمٰا وَجَدْنٰا فِيهٰا غَيْرَ بَيْتٍ مِنَ الْمُسْلِمِينَ » </quranic_text>   <footnote> [ الذاريات ۳۵ ] </footnote>  وَ اَنَّ لُوطاً لَبِثَ فِي قَوْمِهِ ثَلاَثِينَ سَنَةً يَدْعُوهُمْ اِلَي اللَّهِ عَزَّ وَ جَلَّ وَ كَانُوا لاَ يَتَنَظَّفُونَ مِنَ الْغَائِطِ وَ لاَ يَتَطَهَّرُونَ مِنَ الْجَنَابَةِ وَ كَانَ لُوطٌ رَجُلاً سَخِيّاً كَرِيماً يُقْرِي الضَّيْفَ اِذَا نَزَلَ بِهِ وَ يُحَذِّرُهُمْ قَوْمَهُ فَلَمَّا رَاَي قَوْمُهُ ذَلِكَ قَالُوا اِنَّنَا نَنْهَاكَ عَنِ الْعَالَمِينَ اِنْ فَعَلْتَ فَضَحْنَاكَ فِي ضَيْفِكَ فَكَانَ لُوطٌ اِذَا نَزَلَ بِهِ الضَّيْفُ كَتَمَ اَمْرَهُ مَخَافَةَ اَنْ يَفْضَحَهُ قَوْمُهُ لِاَنَّهُ لَمْ يَكُنْ لِلُوطٍ عَشِيرَةٌ وَ لَمْ يَزَلْ لُوطٌ وَ اِبْرَاهِيمُ عَلَيْهِمَا السَّلاَمُ يَتَوَقَّعَانِ نُزُولَ الْعَذَابِ عَلَي قَوْمِهِ وَ اَنَّ اللَّهَ كَانَ اِذَا اَرَادَ عَذَابَ قَوْمِ لُوطٍ اَدْرَكَتْهُ مَوَدَّةُ اِبْرَاهِيمَ وَ خَلَّتُهُ وَ مَحَبَّةُ لُوطٍ فَيُؤَخِّرُ عَذَابَهُمْ فَلَمَّا اِشْتَدَّ عَلَيْهِمْ غَضَبُ اللَّهِ وَ اَرَادَ عَذَابَهُمْ وَ قَضَي اَنْ يُعَوَّضَ اِبْرَاهِيمُ مِنْ عَذَابِ قَوْمٍ لُوطٍ بِغُلاَمٍ عَلِيمٍ فَيُسَلَّي بِهِ مُصَابُهُ بِهَلاَكِ قَوْمٍ لُوطٍ فَبَعَثَ اللَّهُ رُسُلاً اِلَي اِبْرَاهِيمَ يُبَشِّرُونَهُ بِاِسْمَاعِيلَ فَدَخَلُوا عَلَيْهِ لَيْلاً فَفَزِعَ وَ خَافَ اَنْ يَكُونُوا سُرَّاقاً فَلَمَّا رَاَتْهُ الرُّسُلُ مَذْعُوراً  <quranic_text> « قٰالُوا سَلاٰماً قٰالَ سَلاٰمٌ » </quranic_text>   <footnote> [ هود ۶۹ ] </footnote>   .  .  .   <quranic_text> « اِنّٰا مِنْكُمْ وَجِلُونَ قٰالُوا لاٰ تَوْجَلْ اِنّٰا نُبَشِّرُكَ بِغُلاٰمٍ عَلِيمٍ » </quranic_text>   <footnote> [ الحجر ۵۲ ] </footnote>  وَ هُوَ اِسْمَاعِيلُ  <quranic_text> « قٰالَ فَمٰا خَطْبُكُمْ » </quranic_text>   <footnote> [ الحجر ۵۷ ] </footnote>  بَعْدَ الْبِشَارَةِ قَالُوا اِنَّا اُرْسِلْنَا اِلَي قَوْمِ لُوطٍ لِنُنْذِرَهُمْ عَذَابَ رَبِّ الْعَالَمِينَ فَقَالَ اِبْرَاهِيمُ لِلرُّسُلِ  <quranic_text> « اِنَّ فِيهٰا لُوطاً قٰالُوا نَحْنُ اَعْلَمُ بِمَنْ فِيهٰا لَنُنَجِّيَنَّهُ وَ اَهْلَهُ » </quranic_text>   <footnote> [ العنكبوت ۳۲ ] </footnote>","translation_segment":"ولی چنان پستی دامنگیرشان شد که اندک‌اندک خود نیز به لواط‍‌ با یکدیگر پرداختند و حتی با مهمانان خود نیز این عمل زشت را انجام می‌دادند و به آنان غرامت می‌پرداختند. تنها گروه اندکی از پیروان لوط‍‌ این کار زشت را انجام نمی‌دادند. همانگونه که قرآن می‌فرماید: «فأخرجنٰا من‌ کٰان‌ فیهٰا من‌ المومنین‌ `فمٰا وجدنٰا فیهٰا غیر بیت‌ من‌ المسلمین‌؛ پس هرکه را از مومنان در آن شهر بود بیرون بردیم ما از مسلمانان جز یک خانه را که همان خانه لوط‍‌ بود در انجا نیافتیم.» قوم لوط‍‌ به طهارت و غسل اعتقاد نداشتند و لوط‍‌ سی سال در میان آنان به پند و اندرز پرداخت ولی ثمری نداشت. لوط‍‌ خود مردی سخاوتمند و مهمان‌دوست بود و هنگامی که قومش را از اعمال زشت‌شان پرهیز می‌داد قومش او را تهدید کردند که اگر از پند و اندرزش دست برندارد او را به فضاحت و رسوایی می‌کشانند. او نیز از ترس تهمت‌های قومش از مهمانان خویش پنهانی پذیرایی می‌کرد. لوط‍‌ و ابراهیم در انتظار فرود آمدن عذاب خداوند بودند ولی خداوند به سبب دوستی و محبت آن دو نفر [ابراهیم و لوط‍‌]، بارها عذاب را به تاخیر انداخت ولی سرانجام عذاب الهی دررسید و خداوند برای آرامش ابراهیم، به دنیا آمدن فرزندش اسماعیل را به او مژده داد. خداوند فرشتگان را شب هنگام به سوی ابراهیم فرستاد تا تولد فرزندش را به او مژده دهند. ابراهیم با دیدن آن مهمانان با ترس گفت: «إنٰا منکم‌ وجلون‌ `قٰالوا لاٰ توجل‌ إنٰا نبشرک‌ بغلاٰم‌ علیم‌؛ گفت ما از شما هراسانیم، گفتند: نترس که ما تو را به تولد پسری دانا مژده می‌دهیم». آنگاه ابراهیم از آنان پرسید: آیا جز این مژده، پیام دیگری نیز دارید؟ «قٰالوا إنٰا أرسلنٰا إلیٰ‌ قوم‌ مجرمین‌؛ گفتند: ما به سوی گروهی بزهکار فرستاده شده‌ایم‌؟ «قٰال‌ إن‌ فیهٰا لوطا قٰالوا نحن‌ أعلم‌ بمن‌ فیهٰا لننجینه‌ و أهله‌ إلا امرأته‌؛","segment_columns":[{"kind":"word","token":"فاورثهم","display":"فَاَوْرَثَهُمُ"},{"kind":"word","token":"البخل","display":"الْبُخْلَ"},{"kind":"word","token":"بلاء","display":"بَلاَءً"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يستطيعون","display":"يَسْتَطِيعُونَ"},{"kind":"word","token":"دفعه","display":"دَفْعَهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"انفسهم","display":"اَنْفُسِهِمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"غير","display":"غَيْرِ"},{"kind":"word","token":"شهوه","display":"شَهْوَةٍ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"صاروا","display":"صَارُوا"},{"kind":"word","token":"يطلبونه","display":"يَطْلُبُونَهُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الرجال","display":"الرِّجَالِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"البلاد","display":"الْبِلاَدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يعطونهم","display":"يُعْطُونَهُمْ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"الجعل","display":"الْجُعْلَ"},{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"جعلت","display":"جُعِلْتُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"فهل","display":"فَهَلْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"قريه","display":"قَرْيَةِ"},{"kind":"word","token":"لوط","display":"لُوطٍ"},{"kind":"word","token":"كلهم","display":"كُلُّهُمْ"},{"kind":"word","token":"يفعلون","display":"يَفْعَلُونَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"الا","display":"اِل