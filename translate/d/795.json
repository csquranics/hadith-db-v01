- قَالَ :  اِنَّ رَهْطاً مِنْ مُسْلِمِي اَهْلِ الْكِتَابِ مِنْهُمْ عَبْدُ اللَّهِ بْنُ سَلاَمٍ وَ اَسَدٌ وَ اُسَيْدٌ وَ ثَعْلَبَةُ ،  لَمَّا اَمَرَهُمُ اللَّهُ اَنْ يَقْطَعُوا مَوَدَّةَ الْيَهُودِ وَ النَّصَارَي فَفَعَلُوا قَالَتْ قُرَيْظَةُ وَ النَّضِيرُ :","translation_segment":"آنها عبد الله بن سلام و اسد و اسید و ثعلبه بودند، خداوند دستور داده بود که دوستی با یهود و نصاری را قطع کنند و آنان نیز چنین کرده بودند. بنی قریظه و بنی نضیر گفتند: ما را","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"رهطا","display":"رَهْطاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"مسلمي","display":"مُسْلِمِي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابِ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"عبد","display":"عَبْدُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"سلام","display":"سَلاَمٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسد","display":"اَسَدٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسيد","display":"اُسَيْدٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ثعلبه","display":"ثَعْلَبَةُ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"۵","display":"۵"},{"kind":"word","token":"امرهم","display":"اَمَرَهُمُ"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"صلي","display":"صلّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلّم"},{"kind":"word","token":"ان","displ