anslation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَمَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ اِلَي حَدِيقَةِ بَنِي النَّجَّارِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ عَلِمَ النَّاسُ بِمَكَانِهِ فَجَاءُوا اِلَيْهِ رَكْضاً وَ قَدْ كَانُوا عَازِمِينَ عَلَي اَنْ يُبَايِعُوا طَلْحَةَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَلَمَّا نَظَرُوا اِلَيْهِ اِرْفَضُّوا مِنْ طَلْحَةَ اِرْفِضَاضَ الْغَنَمِ يَشُدُّ عَلَيْهَا السَّبُعُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَبَايَعَهُ طَلْحَةُ وَ الزُّبَيْرُ فَتَابَعَ الْمُهَاجِرُونَ وَ الْاَنْصَارُ يُبَايِعُونَهُ ،  فَاَقَمْتُ مَعَهُ اَخْدُمُهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ حَضَرْتُ مَعَهُ صِفِّينَ اَوْ قَالَ :  النَّهْرَوَانَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَكُنْتُ عَنْ يَمِينِهِ اِذْ سَقَطَ السَّوْطُ مِنْ يَدِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَانْكَبَبْتُ لِاخُذَهُ وَ اَرْفَعَهُ اِلَيْهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ كَانَ لِجَامُ دَابَّتِهِ حَدِيداً مُدْمَجاً فَشَجَّنِي هَذِهِ الشَّجَّةَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَدَعَانِي اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ فَتَفَلَ فِيهَا وَ اَخَذَ حَفْنَةً مِنْ تُرَابٍ فَتَرَكَهَا عَلَيْهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَوَ اللَّهِ مَا وَجَدْتُ اَلَماً وَ لاَ وَجَعاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  ثُمَّ اَقَمْتُ مَعَهُ حَتَّي قُتِلَ عَلَيْهِ السَّلاَمُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ صَحِبْتُ الْحَسَنَ [ بْنَ عَلِيٍّ عَلَيْهِ السَّلاَمُ ] حَتَّي ضُرِبَ بِالسَّابَاطِ وَ حُمِلَ اِلَي الْمَدَائِنِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":