{"consensus_set_id":"30002","translation_language":"fa","translation_source":{"hid":"408155"},"segments":[{"source_hadith_segment":"عَنْ ابَائِهِ ( عَلَيْهِمُ السَّلاَمُ )  :  « اَنَّ النَّبِيَّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) قَالَ :  اِنَّ اللَّهَ لَيَخْلُفُ الْعَبْدَ الصَّالِحَ مِنْ بَعْدِ مَوْتِهِ فِي اَهْلِهِ وَ مَالِهِ ،  وَ اِنْ كَانَ اَهْلُهُ اَهْلَ سَوْءٍ ،  ثُمَّ قَرَاَ هَذِهِ الْايَةَ اِلَي قَوْلِهِ :   <quranic_text> « وَ كٰانَ اَبُوهُمٰا صٰالِحاً » </quranic_text>   <footnote> [ الكهف ۸۲ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابائه","display":"ابَائِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"النبي","display":"النَّبِيَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"ليخلف","display":"لَيَخْلُفُ"},{"kind":"word","token":"العبد","display":"الْعَبْدَ"},{"kind":"word","token":"الصالح","display":"الصَّالِحَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بعد","display":"بَعْدِ"},{"kind":"word","token":"موته","display":"مَوْتِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اهله","display":"اَهْلِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ماله","display":"مَالِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"wo