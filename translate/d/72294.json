{"consensus_set_id":"72294","translation_language":"fa","translation_source":{"hid":"331775"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اِنّٰا جَعَلْنٰا مٰا عَلَي الْاَرْضِ زِينَةً لَهٰا » </quranic_text>   <footnote> [ الكهف ۷ ] </footnote>  قَالَ :  زِينَةُ الْاَرْضِ الرِّجَالُ وَ زِينَةُ الرِّجَالِ عَلِيُّ بْنُ اَبِي طَالِبٍ  .","translation_segment":"عن عبد الله بن مسعود فی قوله تعالی: (إنا جعلنا ما علی الأرض زینه لها) قال: زینه الأرض الرجال و زینه الرجال علی‌ بن ابی طالب. عبد الله بن مسعود درباره سخن خداوند: «انا جعلنا ما علی الارض زینه لها» گفت: زینت زمین مردان است و زینت مردان علی‌ بن ابی طالب (علیه السلام) است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"جعلنا","display":"جَعَلْنٰا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"زينه","display":"زِينَةً"},{"kind":"word","token":"لها","display":"لَهٰا"},{"kind":"word","token":"لنبلوهم","display":"لِنَبْلُوَهُمْ"},{"kind":"word","token":"ايهم","display":"اَيُّهُمْ"},{"kind":"word","token":"احسن","display":"اَحْسَنُ"},{"kind":"word","token":"عملا","display":"عَمَلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"زينه","display":"زِينَةُ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"الرجال","display":"الرِّجَالُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"زينه","display":"زِينَةُ"},{"kind":"word","token":"ا