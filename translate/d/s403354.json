{"consensus_set_id":"s403354","translation_language":"fa","translation_source":{"hid":"403354"},"segments":[{"source_hadith_segment":"اَنَّهُ كَانَ عِنْدَ عَلِيِّ بْنِ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ ) اَرْبَعَةُ دَرَاهِمَ فِضَّةً ،  فَتَصَدَّقَ بِوَاحِدٍ لَيْلاً ،  وَ بِوَاحِدٍ نَهَاراً ،  وَ بِوَاحِدٍ سِرّاً ،  وَ بِوَاحِدٍ عَلاَنِيَةً ،  فَنَزَلَ :   <quranic_text> « الَّذِينَ يُنْفِقُونَ اَمْوٰالَهُمْ بِاللَّيْلِ وَ النَّهٰارِ سِرًّا وَ عَلاٰنِيَةً » </quranic_text>   <footnote> [ البقرة ۲۷۴ ] </footnote>  فَسَمَّي كُلَّ دِرْهَمٍ مَالاً ،  وَ بَشَّرَهُ بِالْقَبُولِ .  رَوَاهُ النَّطَنْزِيُّ فِي ( اَلْخَصَائِصِ ) .","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اربعه","display":"اَرْبَعَةُ"},{"kind":"word","token":"دراهم","display":"دَرَاهِمَ"},{"kind":"word","token":"فضه","display":"فِضَّةً"},{"kind":"word","token":"فتصدق","display":"فَتَصَدَّقَ"},{"kind":"word","token":"بواحد","display":"بِوَاحِدٍ"},{"kind":"word","token":"ليلا","display":"لَيْلاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بواحد","display":"بِوَاحِدٍ"},{"kind":"word","token":"نهارا","display":"نَهَاراً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بواحد","display":"بِوَاحِدٍ"},{"kind":"word","token":"سرا","display":"سِرّاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بواحد","display":"بِوَاحِدٍ"},{"kind":"word","token":"علانيه","display":"عَلاَنِيَةً"},{"kind":"word","token":"فنزل","display":"فَنَزَلَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind"