{"consensus_set_id":"19758","translation_language":"fa","translation_source":{"hid":"347110"},"segments":[{"source_hadith_segment":"كُنْتُ عِنْدَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ","translation_segment":"عبد اللٰه بن سنان گوید: خدمت امام صادق علیه","segment_columns":[{"kind":"word","token":"كنت","display":"كُنْتُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]},{"source_hadith_segment":"فَسَمِعْتُ رَجُلاً مِنْ هَمْدَانَ يَقُولُ لَهُ اِنَّ هَؤُلاَءِ الْعَامَّةَ يُعَيِّرُونَّا وَ","translation_segment":"السلام بودم و شنیدم که مردی از همدان به آن حضرت می‌گفت: این عامه (","segment_columns":[{"kind":"word","token":"فسمعت","display":"فَسَمِعْتُ"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"همدان","display":"هَمْدَانَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"هؤلاء","display":"هَؤُلاَءِ"},{"kind":"word","token":"العامه","display":"الْعَامَّةَ"},{"kind":"word","token":"يعيرونا","display":"يُعَيِّرُونَّا"},{"kind":"word","token":"و","display":"وَ"}]},{"source_hadith_segment":"يَقُولُونَ لَنَا اِنَّكُمْ تَزْعُمُونَ اَنَّ مُنَادِياً يُنَادِي مِنَ السَّمَاءِ بِاسْمِ صَاحِبِ هَذَا الْاَمْرِ وَ كَانَ مُتَّكِئاً فَغَضِبَ وَ جَلَسَ ثُمَّ قَالَ لاَ تَرْوُوهُ عَنِّي وَ اِرْوُوهُ عَنْ اَبِي وَ لاَ حَرَجَ عَلَيْكُمْ فِي ذَلِكَ اَشْهَدُ اَنِّي قَدْ سَمِعْتُ اَبِي عَلَيْهِ السَّلاَمُ يَقُولُ وَ اللَّهِ اِنَّ ذَلِكَ فِي كِتَابِ اللَّهِ عَزَّ وَ جَلَّ لَبَيِّنٌ حَيْثُ يَقُولُ  <quranic_text> « اِنْ نَشَاْ نُنَزِّلْ عَلَيْهِمْ مِنَ السَّمٰاءِ ايَةً فَظَلَّتْ اَعْنٰاقُهُمْ لَهٰا خٰاضِعِينَ » </quranic_text>   <footnote> [ الشعراء ۴ ] </footnote>  فَلاَ يَبْقَي فِي الْاَرْضِ يَوْمَئِذٍ اَحَدٌ اِلاَّ خَضَعَ وَ ذَلَّتْ رَقَبَتُهُ لَهَا فَيُؤْمِنُ اَهْلُ الْاَرْضِ اِذَا سَمِعُوا الصَّوْتَ مِنَ السَّمَاءِ اَلاَ اِنَّ الْحَقَّ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ وَ شِيعَتِهِ قَالَ فَاِذَا كَانَ مِنَ الْغَدِ صَعِدَ اِبْلِيسُ فِي الْهَوَاءِ حَتَّي يَتَوَارَي عَنْ اَهْلِ الْاَرْضِ ثُمَّ يُنَادِي اَلاَ اِنَّ الْحَقَّ فِي عُثْمَانَ بْنِ عَفَّانَ وَ شِيعَتِهِ فَاِنَّهُ قُتِلَ مَظْلُوماً فَاطْلُبُوا بِدَمِهِ قَالَ فَ  <quranic_text> « يُثَبِّتُ اللّٰهُ الَّذِينَ امَنُوا بِالْقَوْلِ الثّٰابِتِ » </quranic_text>   <footnote> [ ابراهيم ۲۷ ] </footnote>  عَلَي الْحَقِّ وَ هُوَ النِّدَاءُ الْاَوَّلُ وَ يَرْتَابُ يَوْمَئِذٍ  <quranic_text> « الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ » </quranic_text>   <footnote> [ المائدة ۵۲ ] </footnote>  وَ الْمَرَضُ","translation_segment":"اهل تسنن) ما را مورد عیبجوئی و سرزنش قرار می‌دهند و به ما می‌گویند: شما می‌پندارید که نداکننده‌ای از آسمان به نام صاحب این امر آواز خواهد داد، آن حضرت که در این هنگام تکیه داده بود خشمگین شد و به حالت نشسته درآمده، سپس فرمود: آن را از من روایت نکنید بلکه از پدرم روایت کنید و اشکالی بر شما در آن نیست، من گواهی می‌دهم که خود شنیدم از پدرم می‌فرمود: به خدا سوگند که این در کتاب خدای عز و جل‌ کاملا روشن استآنجا که می‌فرماید: «إن‌ نشأ ننزل‌ علیهم‌ من‌ السمٰاء آیه‌» -الخ «اگر بخواهیم نشانه‌ای از آسمان بر ایشان فرو فرستیم که گردنهای ایشان برای آن خاضع و ذلیل گردد» پس در آن هنگام هیچ کس در زمین به جای نماند مگر آنکه در برابر آن خضوع کند و گردن خود فرود آورد، و چون مردم روی زمین آن صدا را بشنوند که از آسمان ندا می‌دهد «آگاه باشید که حق‌ در جانب علی‌ بن ابی طالب [علیه السلام] و پیروان اوست» پس همه ایمان آورند. آن حضرت فرمود: و چون فردا شود ابلیس در فضا بالا رود تا از دیده زمینیان پوشیده گردد سپس آواز سر دهد «بدانید که حق‌ در عثمان بن عفان و پیروان اوست که او مظلومانه کشته شد پس خونخواهی کنید» آن حضرت فرمود: پس خداوند آنان","segment_columns":[{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"word","token":"لنا","display":"لَنَ