{"consensus_set_id":"s307345","translation_language":"fa","translation_source":{"hid":"307345"},"segments":[{"source_hadith_segment":"وَ اَبِي عَبْدِ اللَّهِ عَلَيْهِمَا السَّلاَمُ  :  عَنْ قَوْلِهِ :   <quranic_text> « اِنَّ اِبْرٰاهِيمَ كٰانَ اُمَّةً قٰانِتاً لِلّٰهِ حَنِيفاً » </quranic_text>   <footnote> [ النحل ۱۲۰ ] </footnote>  قَالَ :  شَيْءٌ فَضَّلَ اللَّهُ بِهِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"امه","display":"اُمَّةً"},{"kind":"word","token":"قانتا","display":"قٰانِتاً"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"حنيفا","display":"حَنِيفاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النحل","display":"النحل"},{"kind":"word","token":"۱۲۰","display":"۱۲۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"فضل","display":"فَضَّلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"به","display":"بِهِ"}]}]}