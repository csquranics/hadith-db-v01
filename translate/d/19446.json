{"consensus_set_id":"19446","translation_language":"fa","translation_source":{"hid":"396253"},"segments":[{"source_hadith_segment":"وَ اَمَّا قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مٰا اَرْسَلْنٰا مِنْ قَبْلِكَ مِنْ رَسُولٍ وَ لاٰ نَبِيٍّ » </quranic_text>   <footnote> [ الحج ۵۲ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « وَ اللّٰهُ عَلِيمٌ حَكِيمٌ » </quranic_text>   <footnote> [ الحج ۵۲ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ارسلنا","display":"اَرْسَلْنٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبلك","display":"قَبْلِكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"رسول","display":"رَسُولٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"نبي","display":"نَبِيٍّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۵۲","display":"۵۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"عليم","display":"عَلِيمٌ"},{"kind":"word","token":"حكيم","display":"حَكِيمٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۵۲","display":"۵۲"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"فَاِنَّ الْعَامَّةَ رَوَوْا :  اَنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ كَانَ فِي الصَّلاَةِ ،  فَقَرَاَ سُورَةَ النَّجْمِ فِي الْمَسْجِدِ الْحَرَامِ وَ قُرَيْشٌ يَسْمَعُونَ لِقِرَائَتِهِ ،  فَلَمَّا اِنْتَهَي اِلَي هَذِهِ الْايَةِ :   <quranic_text> « اَ فَرَاَيْتُمُ اللاّٰتَ وَ الْعُزّٰي وَ مَنٰاةَ الثّٰالِثَةَ الْاُخْريٰ » </quranic_text>   <footnote> [ النجم ۱۹ ] </footnote>  اَجْرَي اِبْلِيسُ عَلَي لِسَانِهِ فَاِنَّهَا الْغَرَانِيقُ الْعُلَي وَ اِنَّ شَفَاعَتَهُنَّ لَتُرْتَجَي ،  فَفَرَحْنَ قُرَيْشٌ وَ سَجَدُوا وَ كَانَ فِي الْقَوْمِ الْوَلِيدُ بْنُ الْمُغِيرَةِ الْمَخْزُومِيُّ وَ هُوَ شَيْخٌ كَبِيرٌ فَاَخَذَ كَفّاً مِنْ حَصًي فَسَجَدَ عَلَيْهِ وَ هُوَ قَاعِدٌ ،  فَقَالَتْ قُرَيْشٌ :  قَدْ اَقَرَّ مُحَمَّدٌ بِشَفَاعَةِ اللاَّتِ وَ الْعُزَّي ،  قَالَ :  فَنَزَلَ جَبْرَئِيلُ عَلَيْهِ السَّلاَمُ فَقَالَ لَهُ :  قَرَاْتَ مَا لَمْ اُنْزِلْ عَلَيْكَ وَ اَنْزَلَ عَلَيْهِ :   <quranic_text> « وَ مٰا اَرْسَلْنٰا مِنْ قَبْلِكَ مِنْ رَسُولٍ وَ لاٰ نَبِيٍّ اِلاّٰ اِذٰا تَمَنّٰي اَلْقَي الشَّيْطٰانُ فِي اُمْنِيَّتِهِ فَيَنْسَخُ اللّٰهُ مٰا يُلْقِي الشَّيْطٰانُ » </quranic_text>   <footnote> [ الحج ۵۲ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"العامه","display":"الْعَامَّةَ"},{"kind":"word","token":"رووا","display":"رَوَوْا"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"