و","display":"وَ"},{"kind":"word","token":"العزي","display":"الْعُزَّي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فنزل","display":"فَنَزَلَ"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"قرات","display":"قَرَاْتَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"انزل","display":"اُنْزِلْ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ارسلنا","display":"اَرْسَلْنٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبلك","display":"قَبْلِكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"رسول","display":"رَسُولٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"نبي","display":"نَبِيٍّ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"تمني","display":"تَمَنّٰي"},{"kind":"word","token":"القي","display":"اَلْقَي"},{"kind":"word","token":"الشيطان","display":"الشَّيْطٰانُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"امنيته","display":"اُمْنِيَّتِهِ"},{"kind":"word","token":"فينسخ","display":"فَيَنْسَخُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يلقي","display":"يُلْقِي"},{"kind":"word","token":"الشيطان","display":"الشَّيْطٰانُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۵۲","display":"۵۲"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"وَ اَمَّا الْخَاصَّةُ فَاِنَّهُ رُوِيَ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اَنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَصَابَهُ خَصَاصَةٌ ،  فَجَاءَ اِلَي رَجُلٍ مِنَ الْاَنْصَارِ فَقَالَ لَهُ :  هَلْ عِنْدَكَ مِنْ طَعَامٍ ؟  قَالَ :  نَعَمْ يَا رَسُولَ اللَّهِ  ،  وَ ذَبَحَ لَهُ عَنَاقاً وَ شَوَاهُ ،  فَلَمَّا اَدْنَاهُ مِنْهُ تَمَنَّي رَسُولُ اللَّهِ اَنْ يَكُونَ مَعَهُ عَلِيٌّ وَ فَاطِمَةُ وَ الْحَسَنُ وَ الْحُسَيْنُ صَلَوَاتُ اللَّهِ عَلَيْهِمْ  ،  فَجَاءَ اَبُو بَكْرٍ وَ عُمَرُ ثُمَّ جَاءَ عَلِيٌّ بَعْدَهُمَا ،  فَاَنْزَلَ اللَّهُ عَزَّ وَ جَلَّ فِي ذَلِكَ :   <quranic_text> « وَ مٰا اَرْسَلْنٰا مِنْ قَبْلِكَ مِنْ رَسُولٍ وَ لاٰ نَبِيٍّ » </quranic_text>   <footnote> [ الحج ۵۲ ] </footnote>  وَ لاَ مُحَدَّثٍ  <quranic_text> « اِلاّٰ اِذٰا تَمَنّٰي اَلْقَي الشَّيْطٰانُ فِي اُمْنِيَّتِهِ » </quranic_text>   <footnote> [ الحج ۵۲ ] </footnote>  يَعْنِي اَبَا بَكْرٍ وَ عُمَرَ  <quranic_text> « فَيَنْسَخُ اللّٰهُ مٰا يُلْقِي الشَّيْطٰانُ » </quranic_text>   <footnote> [ الحج ۵۲ ] </footnote>  يَعْنِي لَمَّا جَاءَ عَلِيٌّ صَلَوَاتُ اللَّهِ عَلَيْهِ بَعْدَهُمَا  <quranic_text> « ثُمَّ يُحْكِمُ اللّٰهُ ايٰاتِهِ » </quranic_text>   <footnote> [ الحج ۵۲ ] </footnote>  لِلنَّاسِ » يَعْنِي يَنْصُرُ اللَّهُ اَمِيرَ الْمُؤْمِنِينَ صَلَوَاتُ اللَّهِ عَلَيْهِ ثُمَّ قَالَ :   <quranic_text> « لِيَجْعَلَ مٰا يُلْقِي الشَّيْطٰانُ فِتْنَةً » </quranic_text>   <footnote> [ الحج ۵۳ ] </footnote>  يَعْنِي فُلاَناً وَ فُلاَناً  <quranic_text> « لِلَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ وَ الْقٰاسِيَةِ قُلُوبُهُمْ » </quranic_text>   <footnote> [ الحج ۵۳ ] </footnote>  يَعْنِي اِلَي الْاِمَامِ الْمُسْتَقِيمِ ثُمَّ قَالَ :   <quranic_text> « وَ لاٰ يَزٰالُ الَّذِينَ كَفَرُوا فِي مِرْيَةٍ مِنْهُ » </quranic_text>   <footnote> [ الحج ۵۵ ] </footnote>  اَيْ فِي شَكٍّ مِنْ اَمِيرِ الْمُؤْمِنِينَ صَلَوَاتُ اللَّهِ عَلَيْهِ حَتَّي يَاْتِيَهُمُ السَّاعَةُ بَغْتَةً اَوْ يَاْتِيَهُمْ عَذَابُ يَوْمِ عَقِيمٍ قَالَ :  الْعَقِيمُ :  الَّذِي لَهُ فِي الْاَيَّامِ ثُمَّ قَالَ :   <quranic_text> « الْمُلْكُ يَوْمَئِذٍ لِلّٰهِ يَحْكُمُ بَيْنَهُمْ فَالَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ فِي جَنّٰاتِ النَّعِيمِ وَ الَّذِينَ كَفَرُوا وَ كَذَّبُوا بِايٰاتِنٰا » </quranic_text>   <footnote> [ الحج ۵۶ ] </footnote>  قَالَ :  وَ لَمْ يُؤْمِنُوا بِوَلاَيَةِ اَمِيرِ الْمُؤْمِنِينَ وَ الْاَئِمَّةِ صَلَوَاتُ اللَّهِ عَلَيْهِمْ  <quranic_text> « فَاُولٰئِكَ لَهُمْ عَذٰابٌ مُهِينٌ » </quranic_text>   <footnote> [ الحج ۵۷ ] </footnote>  ثُمَّ ذَكَرَ الْمُؤْمِنِينَ وَ الْمُهَاجِرِينَ مِنْ اَصْحَابِ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَقَالَ جَلَّ ذِكْرُهُ :   <quranic_text> « وَ الَّذِينَ هٰاجَرُوا فِي سَبِيلِ اللّٰهِ ثُمَّ قُتِلُوا اَوْ مٰاتُوا لَيَرْزُقَنَّهُمُ اللّٰهُ رِزْقاً حَسَناً » </quranic_text>   <footnote> [ الحج ۵۸ ] </footnote>  اِلَي قَوْلِهِ تَعَالَي :   <quranic_text> « لَعَلِيمٌ حَلِيمٌ » </quranic_text>   <footnote> [ الحج ۵۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الخاصه","display":"الْخَاصَّةُ"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"روي","display":"رُوِيَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلّ