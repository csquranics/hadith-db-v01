{"consensus_set_id":"s352399","translation_language":"fa","translation_source":{"hid":"352399"},"segments":[{"source_hadith_segment":"تَلاَ هَذِهِ الْايَةَ  <quranic_text> « اِنّٰا لَنَنْصُرُ رُسُلَنٰا وَ الَّذِينَ امَنُوا فِي الْحَيٰاةِ الدُّنْيٰا وَ يَوْمَ يَقُومُ الْاَشْهٰادُ » </quranic_text>   <footnote> [ غافر ۵۱ ] </footnote>  قَالَ الْحُسَيْنُ بْنُ عَلِيٍّ مِنْهُمْ وَ لَمْ يُنْصَرْ بَعْدُ ثُمَّ قَالَ وَ اللَّهِ لَقَدْ قُتِلَ قَتَلَةُ الْحُسَيْنِ عَلَيْهِ السَّلاَمُ وَ لَمْ يُطْلَبْ بِدَمِهِ بَعْدُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"تلا","display":"تَلاَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"لننصر","display":"لَنَنْصُرُ"},{"kind":"word","token":"رسلنا","display":"رُسُلَنٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحياه","display":"الْحَيٰاةِ"},{"kind":"word","token":"الدنيا","display":"الدُّنْيٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"يقوم","display":"يَقُومُ"},{"kind":"word","token":"الاشهاد","display":"الْاَشْهٰادُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"غافر","display":"غافر"},{"kind":"word","token":"۵۱","display":"۵۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word"