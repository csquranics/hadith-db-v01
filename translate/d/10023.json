{"consensus_set_id":"10023","translation_language":"fa","translation_source":{"hid":"117535"},"segments":[{"source_hadith_segment":"فِيقَوْلِ اَللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « يُحْيِ الْاَرْضَ بَعْدَ مَوْتِهٰا » </quranic_text>   <footnote> [ الروم ۱۹ ] </footnote>  قَالَ لَيْسَ يُحْيِيهَا بِالْقَطْرِ وَ لَكِنْ يَبْعَثُ اللَّهُ رِجَالاً فَيُحْيُونَ الْعَدْلَ فَتُحْيَا الْاَرْضُ لِاِحْيَاءِ الْعَدْلِ وَ لَاِقَامَةُ الْحَدِّ لِلَّهِ اَنْفَعُ فِي الْاَرْضِ مِنَ الْقَطْرِ اَرْبَعِينَ صَبَاحاً .","translation_segment":"عبد الرحمان بن حجاج گوید: امام کاظم علیه السلام درباره گفتار خدا که می‌فرماید: «زمین را پس از مرگش زنده می‌کند»، فرمود: زمین را با باران زنده نمی‌کند، بلکه مردانی را بر می‌انگیزاند که عدل را احیا می‌کنند. پس به خاطر احیای عدل، زمین احیا می‌شود و به یقین اقامه حد الهی در زمین از باران چهل صبحگاه مفیدتر است.","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"فيقول","display":"فِيقَوْلِ"},{"kind":"word","token":"الله","display":"اَللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يحي","display":"يُحْيِ"},{"kind":"word","token":"الارض","display":"الْاَرْضَ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"موتها","display":"مَوْتِهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الروم","display":"الروم"},{"kind":"word","token":"۱۹","display":"۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"يحييها","display":"يُحْيِيهَا"},{"kind":"word","token":"بالقطر","display":"بِالْقَطْرِ"},{"kind":"word","token":"و","display":"وَ"