{"consensus_set_id":"14153","translation_language":"fa","translation_source":{"hid":"356751"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « هُديً لِلْمُتَّقِينَ الَّذِينَ يُؤْمِنُونَ بِالْغَيْبِ » </quranic_text>   <footnote> [ البقرة ۲ ] </footnote>  قَالَ مَنْ اَقَرَّ بِقِيَامِ الْقَائِمِ عَلَيْهِ السَّلاَمُ اَنَّهُ حَقٌّ .","translation_segment":"داود بن کثیر رقی از امام ششم در تفسیر قول خدای عز و جل «هدی‌ للمتقین‌`الذین‌ یومنون‌ بالغیب‌» روایت کرده که فرمود کسی است که اقرار کند، قیام قائم علیه السلام حق است..","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هدي","display":"هُديً"},{"kind":"word","token":"للمتقين","display":"لِلْمُتَّقِينَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يؤمنون","display":"يُؤْمِنُونَ"},{"kind":"word","token":"بالغيب","display":"بِالْغَيْبِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"اقر","display":"اَقَرَّ"},{"kind":"word","token":"بقيام","display":"بِقِيَامِ"},{"kind":"word","token":"القائم","display":"الْقَائِمِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"حق","display":"حَقٌّ"}]}]}