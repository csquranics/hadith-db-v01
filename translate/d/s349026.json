{"consensus_set_id":"s349026","translation_language":"fa","translation_source":{"hid":"349026"},"segments":[{"source_hadith_segment":"اَمَانٌ لِاُمَّتِي مِنَ السَّرَقِ  <quranic_text> « قُلِ اُدْعُوا اللّٰهَ اَوِ اُدْعُوا الرَّحْمٰنَ » </quranic_text>   <footnote> [ الاسراء ۱۱۰ ] </footnote>  وَ قَرَاَ الْايَةَ .","translation_segment":"روایت شده که پیامبر اکرم صلی اللٰه علیه و آله فرمود: «قرائت: «قل‌ ادعوا اللٰه‌، أو ادعوا الرحمٰن‌» …برای امت من، مایه ایمنی از شمشیر و کشته شدن [یا: به سرقت رفتن] است.» و آیه شریفه را قرائت فرمود.","segment_columns":[{"kind":"word","token":"امان","display":"اَمَانٌ"},{"kind":"word","token":"لامتي","display":"لِاُمَّتِي"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"السرق","display":"السَّرَقِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلِ"},{"kind":"word","token":"ادعوا","display":"اُدْعُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"او","display":"اَوِ"},{"kind":"word","token":"ادعوا","display":"اُدْعُوا"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۱۱۰","display":"۱۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"الايه","display":"الْايَةَ"}]}]}