{"consensus_set_id":"34183","translation_language":"fa","translation_source":{"hid":"352403"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَبَارَكَ وَ تَعَالَي  <quranic_text> « فَلاٰ عُدْوٰانَ اِلاّٰ عَلَي الظّٰالِمِينَ » </quranic_text>   <footnote> [ البقرة ۱۹۳ ] </footnote>  قَالَ اَوْلاَدُ قَتَلَةِ الْحُسَيْنِ عَلَيْهِ السَّلاَمُ  .","translation_segment":"محمد بن جعفر رزاز، از محمد بن الحسین، از عثمان بن عیسی، از سماعه بن مهران، از حضرت ابی عبد اللٰه علیه السلام در ذیل فرموده حق تبارک و تعالی: «فلاٰ عدوٰان‌ إلاٰ علی الظٰالمین‌». فرمودند: مقصود از «ظالمین» فرزندان کشندگان امام حسین علیه السلام می‌باشد.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلا","display":"فَلاٰ"},{"kind":"word","token":"عدوان","display":"عُدْوٰانَ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الظالمين","display":"الظّٰالِمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۳","display":"۱۹۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اولاد","display":"اَوْلاَدُ"},{"kind":"word","token":"قتله","display":"قَتَلَةِ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}