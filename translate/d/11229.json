{"consensus_set_id":"11229","translation_language":"fa","translation_source":{"hid":"85568"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي  <quranic_text> « سَيَقُولُ السُّفَهٰاءُ مِنَ النّٰاسِ مٰا وَلاّٰهُمْ عَنْ قِبْلَتِهِمُ الَّتِي كٰانُوا عَلَيْهٰا قُلْ لِلّٰهِ الْمَشْرِقُ وَ الْمَغْرِبُ يَهْدِي مَنْ يَشٰاءُ اِليٰ صِرٰاطٍ مُسْتَقِيمٍ » </quranic_text>   <footnote> [ البقرة ۱۴۲ ] </footnote>","translation_segment":"* *۶ - از ابو عبد الله صادق (ع) پرسیدم: خداوند عز و جل می‌گوید: «بزودی نابخردان مردم خواهند گفت چرا به قبله پیشین خود پشت کردند؟ بگو قلمرو شرق و غرب از آن خداست. و خداوند هرکه را بخواهد به راه راست رهبری می‌نماید». من گفتم: واقعا خداوند فرمان داده بود که رو به سوی","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سيقول","display":"سَيَقُولُ"},{"kind":"word","token":"السفهاء","display":"السُّفَهٰاءُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ولاهم","display":"وَلاّٰهُمْ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قبلتهم","display":"قِبْلَتِهِمُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"كانوا","display":"كٰانُوا"},{"kind":"word","token":"عليها","display":"عَلَيْهٰا"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"المشرق","display":"الْمَشْرِقُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"wor