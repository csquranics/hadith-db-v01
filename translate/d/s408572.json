{"consensus_set_id":"s408572","translation_language":"fa","translation_source":{"hid":"408572"},"segments":[{"source_hadith_segment":"« اِنَّ رَسُولَ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) قَالَ : اِنَّ عَلِيّاً وَ شِيعَتَهُ يَوْمَ الْقِيَامَةِ عَلَي كُثْبَانِ الْمِسْكِ الْاَذْفَرِ ،  يَفْزَعُ النَّاسُ وَ لاَ يَفْزَعُونَ ،  وَ يَحْزَنُ النَّاسُ ،  وَ لاَ يَحْزَنُونَ ،  وَ هُوَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ : <quranic_text> « لاٰ يَحْزُنُهُمُ الْفَزَعُ الْاَكْبَرُ وَ تَتَلَقّٰاهُمُ الْمَلاٰئِكَةُ هٰذٰا يَوْمُكُمُ الَّذِي كُنْتُمْ تُوعَدُونَ » </quranic_text>   <footnote> [ الانبياء ۱۰۳ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"عليا","display":"عَلِيّاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شيعته","display":"شِيعَتَهُ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"كثبان","display":"كُثْبَانِ"},{"kind":"word","token":"المسك","display":"الْمِسْكِ"},{"kind":"word","token":"الاذفر","display":"الْاَذْفَرِ"},{"kind":"word","token":"يفزع","display":"يَفْزَعُ"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يفزعون","display":"يَفْزَعُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يحزن","display":"يَحْزَنُ"},{"kind":"word","token":"الناس","displ