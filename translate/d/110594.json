{"consensus_set_id":"110594","translation_language":"fa","translation_source":{"hid":"353949"},"segments":[{"source_hadith_segment":"قَوْلُهُ تَعَالَي :   <quranic_text> « كَفيٰ بِاللّٰهِ شَهِيداً بَيْنِي وَ بَيْنَكُمْ وَ مَنْ عِنْدَهُ عِلْمُ الْكِتٰابِ » </quranic_text>   <footnote> [ الرعد ۴۳ ] </footnote>  قَالَ مُحَمَّدُ اِبْنُ الْحَنَفِيَّةِ رَضِيَ اللَّهُ عَنْهُ هُوَ عَلِيُّ بْنُ اَبِي طَالِبٍ  .","translation_segment":"و دیگر آیت و «کفیٰ‌ باللٰه‌ شهیدا بینی و بینکم‌ و من‌ عنده‌ علم‌ الکتٰاب‌» یعنی پسنده است گواهی میان من و شما بآن که من پیغمبرم بشما و دیگر کسی که نزد اوست علم کتاب که لوح محفوظ‍‌ است یا قرآن، محمد بن حنفیه گفت که آن کس علی بن ابی طالب است (صلی الله علیه و آله).","segment_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"كفي","display":"كَفيٰ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"word","token":"شهيدا","display":"شَهِيداً"},{"kind":"word","token":"بيني","display":"بَيْنِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بينكم","display":"بَيْنَكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"علم","display":"عِلْمُ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"الحنفيه","display":"الْحَنَفِيَّةِ"},{"kind":"word","token":"رضي","display":"رَضِيَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"k