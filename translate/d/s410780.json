{"consensus_set_id":"s410780","translation_language":"fa","translation_source":{"hid":"410780"},"segments":[{"source_hadith_segment":"« قَدْ كَانَ الشَّيْءُ يُنْزَلُ عَلَي رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) فَيُعْمَلُ بِهِ زَمَاناً ،  ثُمَّ يُؤْمَرُ بِغَيْرِهِ فَيَاْمُرُ بِهِ اَصْحَابَهُ وَ اُمَّتَهُ ،  قَالَ اُنَاسٌ :  يَا رَسُولَ اللَّهِ  ،  اِنَّكَ تَاْمُرُنَا بِالشَّيْءِ حَتَّي اِذَا اِعْتَدْنَاهُ وَ جَرَيْنَا عَلَيْهِ ،  اَمَرْتَنَا بِغَيْرِهِ ؟  فَسَكَتَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) عَنْهُمْ ،  فَاَنْزَلَ اللَّهُ عَلَيْهِ :   <quranic_text> « قُلْ مٰا كُنْتُ بِدْعاً مِنَ الرُّسُلِ وَ مٰا اَدْرِي مٰا يُفْعَلُ بِي وَ لاٰ بِكُمْ اِنْ اَتَّبِعُ اِلاّٰ مٰا يُوحيٰ اِلَيَّ وَ مٰا اَنَا اِلاّٰ نَذِيرٌ مُبِينٌ » </quranic_text>   <footnote> [ الاحقاف ۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"الشيء","display":"الشَّيْءُ"},{"kind":"word","token":"ينزل","display":"يُنْزَلُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"فيعمل","display":"فَيُعْمَلُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"زمانا","display":"زَمَاناً"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يؤمر","display":"يُؤْمَرُ"},{"kind":"word","token":"بغيره","display":"بِغَيْرِهِ"},{"kind":"word","token":"فيامر","display":"فَيَاْمُرُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"اصحابه","display":"اَصْحَابَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امته","display