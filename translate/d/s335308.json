{"consensus_set_id":"s335308","translation_language":"fa","translation_source":{"hid":"335308"},"segments":[{"source_hadith_segment":"يَا اِبْنَ مَسْعُودٍ اِنَّهُ قَدْ اُنْزِلَتْ عَلَيَّ ايَةُ  <quranic_text> « وَ اِتَّقُوا فِتْنَةً » </quranic_text>   <footnote> [ الانفال ۲۵ ] </footnote>  الْايَةَ وَ اَنَا مُسْتَوْدِعُكَهَا وَ مُسَمٍّ لَكَ خَاصَّةً الظَّلَمَةَ فَكُنْ لِمَا اَقُولُ لَكَ وَاعِياً وَ عَنِّي لَهُ مُؤَدِّياً مَنْ ظَلَمَ عَلِيّاً مَجْلِسِي هَذَا كَمَنْ جَحَدَ نُبُوَّتِي وَ نُبُوَّةَ مَنْ كَانَ قَبْلِي فَقَالَ لَهُ الرَّاوِي يَا اَبَا عَبْدِ الرَّحْمَنِ اَ سَمِعْتَ هَذَا مِنْ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ قَالَ نَعَمْ قَالَ قُلْتُ فَكَيْفَ وَلَّيْتَ لِلظَّالِمِينَ قَالَ لاَ جَرَمَ جَلَبْتُ عُقُوبَةَ عَمَلِي وَ ذَلِكَ اَنِّي لَمْ اَسْتَاْذِنْ اِمَامِي كَمَا اِسْتَاْذَنَهُ جُنْدَبٌ وَ عَمَّارٌ وَ سَلْمَانُ وَ اَنَا اَسْتَغْفِرُ اللَّهَ وَ اَتُوبُ اِلَيْهِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"مسعود","display":"مَسْعُودٍ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"انزلت","display":"اُنْزِلَتْ"},{"kind":"word","token":"علي","display":"عَلَيَّ"},{"kind":"word","token":"ايه","display":"ايَةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"فتنه","display":"فِتْنَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۲۵","display":"۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"مستودعكها","display":"مُسْتَوْدِعُكَهَا"},{"kind":"word","token":"