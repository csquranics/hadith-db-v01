{"consensus_set_id":"69882","translation_language":"fa","translation_source":{"hid":"85836"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « اُذْكُرُوا اللّٰهَ ذِكْراً كَثِيراً » </quranic_text>   <footnote> [ الاحزاب ۴۱ ] </footnote>  مَا ذَا الذِّكْرُ الْكَثِيرُ قَالَ « اَنْ يُسَبِّحَ فِي دُبُرِ الْمَكْتُوبَةِ ثَلاَثِينَ مَرَّةً » .","translation_segment":"* *۱۷۳ - به ابو عبد الله صادق (ع) گفتم: خداوند عز و جل که می‌گوید: «خدا را یاد کنید فراوان و بسیار» حد و مرز آن کدام است‌؟ ابو عبد الله گفت: از جمله آن‌که بعد از نماز فریضه سی بار خدا را تسبیح کنی.","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اذكروا","display":"اُذْكُرُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"ذكرا","display":"ذِكْراً"},{"kind":"word","token":"كثيرا","display":"كَثِيراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحزاب","display":"الاحزاب"},{"kind":"word","token":"۴۱","display":"۴۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"الذكر","display":"الذِّكْرُ"},{"kind":"word","token":"الكثير","display":"الْكَثِيرُ"},{"kind":"word","t