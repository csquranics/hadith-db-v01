{"consensus_set_id":"s405169","translation_language":"fa","translation_source":{"hid":"405169"},"segments":[{"source_hadith_segment":"قَالَ لِي :  « اَ لَمْ يَنْسُبُوهُ - يَعْنِي رَسُولَ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) - اِلَي الْكَذِبِ فِي قَوْلِهِ اِنَّهُ رَسُولٌ مِنَ اللَّهِ اِلَيْهِمْ ،  حَتَّي اَنْزَلَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ لَقَدْ كُذِّبَتْ رُسُلٌ مِنْ قَبْلِكَ فَصَبَرُوا عَليٰ مٰا كُذِّبُوا وَ اُوذُوا حَتّٰي اَتٰاهُمْ نَصْرُنٰا » </quranic_text>   <footnote> [ الانعام ۳۴ ] </footnote>   ؟  » .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"ينسبوه","display":"يَنْسُبُوهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الكذب","display":"الْكَذِبِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"رسول","display":"رَسُولٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"اليهم","display":"اِلَيْهِمْ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"}