{"consensus_set_id":"104330","translation_language":"fa","translation_source":{"hid":"392063"},"segments":[{"source_hadith_segment":"وَ قَالَ لِصَاحِبِكُمْ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ :   <quranic_text> « قُلْ كَفيٰ بِاللّٰهِ شَهِيداً بَيْنِي وَ بَيْنَكُمْ وَ مَنْ عِنْدَهُ عِلْمُ الْكِتٰابِ » </quranic_text>   <footnote> [ الرعد ۴۳ ] </footnote>  وَ قَالَ اللَّهُ عَزَّ وَ جَلَّ ،   <quranic_text> « وَ لاٰ رَطْبٍ وَ لاٰ يٰابِسٍ اِلاّٰ فِي كِتٰابٍ مُبِينٍ » </quranic_text>   <footnote> [ الانعام ۵۹ ] </footnote>  وَ عِلْمُ هَذَا الْكِتَابِ عِنْدَهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لصاحبكم","display":"لِصَاحِبِكُمْ"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"كفي","display":"كَفيٰ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"word","token":"شهيدا","display":"شَهِيداً"},{"kind":"word","token":"بيني","display":"بَيْنِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بينكم","display":"بَيْنَكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"علم","display":"عِلْمُ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"k