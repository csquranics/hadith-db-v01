d","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عزّ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"جل","display":"جلّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"لا","display":"لا"},{"kind":"word","token":"يكون","display":"يكون"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"قلب","display":"قلب"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"-","display":"-"}]},{"source_hadith_segment":"،  ففرض اللّه عليهم مودّة ذوي القربي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فمن اخذ بها و احبّ رسول اللّه - صلّي اللّه عليه و اله - [ و احبّ اهل بيته","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لم يستطع رسول اللّه - صلّي اللّه عليه و اله- ] ان يبغضه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و من تركها و لم ياخذ بها و ابغض اهل بيته","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فعلي رسول اللّه - صلّي اللّه عليه و اله - ان يبغضه ،  لانّه قد ترك فريضة من فرائض اللّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"- عزّ و جلّ-","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فايّ فضل و ايّ شرف يتقدّم هذا او يدانيه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فانزل اللّه - عزّ و جلّ - هذه الاية علي نبيّه - صلّي اللّه عليه و اله- :   <quranic_text> « قُلْ لاٰ اَسْئَلُكُمْ عَلَيْهِ اَجْراً اِلاَّ الْمَوَدَّةَ فِي الْقُرْبيٰ » </quranic_text>   <footnote> [ الشوري ۲۳ ] </footnote>   .  فقام رسول اللّه - صلّي اللّه عليه و اله - في اصحابه فحمد اللّه و اثني عليه ،  و قال :  يا ايّها النّاس ،  انّ اللّه قد فرض لي عليكم فرضا فهل انتم مؤدّوه ؟  فلم يجبه احد ،  فقال :  ايّها النّاس ،  انّه ليس بذهب و لا فضّة و لا ماكول و لا مشروب .  فقالوا :  هات اذا .  فتلا عليهم هذه الاية .  فقالوا :  امّا هذه ،  فنعم .  فما وفي بها اكثرهم .  و ما بعث اللّه نبيّا الاّ و اوحي اليه ان لا يسال قومه اجرا ،  لانّ اللّه - عزّ و جلّ - يوفّيه اجر الانبياء ،  و محمّد - صلّي اللّه عليه و اله - فرض اللّه طاعته و مودّة قرابته علي امّته ،  و امره ان يجعل اجره فيه ليودّوه في قرابته بمعرفة فضلهم الّذي اوجب اللّه - عزّ و جلّ - لهم ،  فانّ المودّة انّما تكون علي قدر معرفة الفضل .  فلمّا اوجب اللّه ذلك ثقل لثقل وجوب الطّاعة ،  فتمسّك بها قوم قد اخذ اللّه - تعالي - ميثاقهم علي الوفاء ،  و عاند اهل الشّقاوة و النّفاق و الحدوا في ذلك ،  فصرفوه عن حدّه الّذي حدّه اللّه - عزّ و جلّ - فقالوا :  القرابة هم العرب كلّها و اهل دعوته .  فعلي ايّ الحالتين كان فقد علمنا انّ المودّة هي للقرابة ،  فاقربهم من النّبيّ - صلّي اللّه عليه و اله - اولاهم بالمودّة ،  و كلّما قربت القرابة كانت المودّة علي قدرها .  و ما انصفوا نبيّ اللّه - صلّي اللّه عليه و اله - في حيطته و رافته ،  و ما منّ اللّه به علي امّته ممّا تعجز الالسن عن وصف الشّكر عليه ان لا يؤذوه في ذريّته و اهل بيته ،  و ان يجعلوهم فيهم بمنزلة العين من الرّاس حفظا لرسول اللّه - صلّي اللّه عليه و اله - فيهم [ و حبا له ،  فكيف و القران ينطق به و يدعو اليه ،  و الاخبار ثابتة بانّهم اهل المودّة ] و الّذين فرض اللّه - تعالي - مودّتهم و وعد الجزاء عليها ،  فما وفي احد بها ،  فهذه المودّة لا ياتي بها احد مؤمنا مخلصا الاّ استوجب الجنّة لقول اللّه - تعالي - في هذه الاية :   <quranic_text> « وَ الَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ فِي رَوْضٰاتِ الْجَنّٰاتِ لَهُمْ مٰا يَشٰاؤُنَ عِنْدَ رَبِّهِمْ ذٰلِكَ هُوَ الْفَضْلُ الْكَبِيرُ ،  ذٰلِكَ الَّذِي يُبَشِّرُ اللّٰهُ عِبٰادَهُ الَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ قُلْ لاٰ اَسْئَلُكُمْ عَلَيْهِ اَجْراً اِلاَّ الْمَوَدَّةَ فِي الْقُرْبيٰ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ الشوري ۲۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"مفسرا و مبيّنا .","translation_segment":"","segment_columns":[]}]}