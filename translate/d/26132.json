{"consensus_set_id":"26132","translation_language":"fa","translation_source":{"hid":"405547"},"segments":[{"source_hadith_segment":"قُلْتُ :  لِاَبِي جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ )  :  قَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ عَلَي الْاَعْرٰافِ رِجٰالٌ يَعْرِفُونَ كُلاًّ بِسِيمٰاهُمْ » </quranic_text>   <footnote> [ الاعراف ۴۶ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الاعراف","display":"الْاَعْرٰافِ"},{"kind":"word","token":"رجال","display":"رِجٰالٌ"},{"kind":"word","token":"يعرفون","display":"يَعْرِفُونَ"},{"kind":"word","token":"كلا","display":"كُلاًّ"},{"kind":"word","token":"بسيماهم","display":"بِسِيمٰاهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۴۶","display":"۴۶"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"؟  قَالَ :  « يَا سَعْدُ ،  اِنَّهَا اَعْرَافٌ ،  وَ لاَ يَدْخُلُ الْجَنَّةَ اِلاَّ مَنْ عَرَفَهُمْ وَ عَرَفُوهُ ،  وَ لاَ يَدْخُلُ النَّارَ اِلاَّ مَنْ اَنْكَرَهُمْ وَ اَنْكَرُوهُ ،  وَ اَعْرَافٌ لاَ يُعْرَفُ اللَّهُ اِلاَّ بِسَبِيلِ مَعْرِفَتِهِمْ ،  فَلاَ سَوَاءٌ مَنِ اِعْتَصَمَتْ بِهِ الْمُعْتَصِمَةُ ،  وَ مَنْ [ ذَهَبَ مَذْهَبَ النَّاسِ ذَهَبَ النَّاسُ اِلَي عَيْنٍ كَدِرَةٍ ،  يُفْرَغُ بَعْضُهَا فِي بَعْضٍ ،  وَ مَنْ ] اَتَي الَ مُحَمَّدٍ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اَتَي عَيْناً صَافِيَةً تَجْرِي بِعِلْمِ اللَّهِ ،  لَيْسَ لَهَا نَفَادٌ وَ لاَ اِنْقِطَاعٌ ،  ذَلِكَ بِاَنَّ اللَّهَ لَوْ شَاءَ لَاَرَاهُمْ شَخْصَهُ حَتَّي يَاْتُوهُ مِنْ بَابِهِ ،  وَ لَكِنْ جَعَلَ مُحَمَّداً ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) وَ الَ مُحَمَّدٍ ( عَلَيْهِمُ السَّلاَمُ ) اَبْوَابَهُ الَّتِي يُؤْتَي مِنْهَا ،  وَ ذَلِكَ قَوْلُ اللَّهِ :   <quranic_text> « وَ لَيْسَ الْبِرُّ بِاَنْ تَاْتُوا الْبُيُوتَ مِنْ ظُهُورِهٰا وَ لٰكِنَّ الْبِرَّ مَنِ اِتَّقيٰ وَ اْتُوا الْبُيُوتَ مِنْ اَبْوٰابِهٰا » </quranic_text>   <footnote> [ البقرة ۱۸۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"سعد","display":"سَعْدُ"},{"kind":"word","token":"انها","display":"اِنَّهَا"},{"kind":"word","token":"اعراف","display":"اَعْرَافٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يدخل","display":"يَدْخُلُ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عرفهم","display":"عَرَفَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عرفوه","display":"عَرَفُوهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعراف","display":"اَعْرَافٌ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يدخل","display":"يَدْخُلُ"},{"kind":"word","token":"النار","display":"النَّارَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"انكرهم","display":"اَنْكَرَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انكروه","display":"اَنْكَرُوهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعراف","display":"اَعْرَافٌ"},{"kind":"word","token":"لا","display":"ل