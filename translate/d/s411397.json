{"consensus_set_id":"s411397","translation_language":"fa","translation_source":{"hid":"411397"},"segments":[{"source_hadith_segment":"« اِنَّ اَلنَّاسَ يُقَسَّمُ بَيْنَهُمُ النُّورُ يَوْمَ الْقِيَامَةِ عَلَي قَدْرِ اِيمَانِهِمْ ،  وَ يُقْسَمُ لِلْمُنَافِقِ فَيَكُونُ نُورُهُ عَلَي [ قَدْرِ ] اِبْهَامِ رِجْلِهِ الْيُسْرَي ،  فَيَطَاُ نُورَهُ ،  فَيَقُولُ :  مَكَانَكُمْ حَتَّي اَقْتَبِسَ مِنْ نُورِكُمْ .  قِيلَ :   <quranic_text> « اِرْجِعُوا وَرٰاءَكُمْ فَالْتَمِسُوا نُوراً » </quranic_text>   <footnote> [ الحديد ۱۳ ] </footnote> يَعْنِي حَيْثُ قُسِمَ النَّارُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الناس","display":"اَلنَّاسَ"},{"kind":"word","token":"يقسم","display":"يُقَسَّمُ"},{"kind":"word","token":"بينهم","display":"بَيْنَهُمُ"},{"kind":"word","token":"النور","display":"النُّورُ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"قدر","display":"قَدْرِ"},{"kind":"word","token":"ايمانهم","display":"اِيمَانِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقسم","display":"يُقْسَمُ"},{"kind":"word","token":"للمنافق","display":"لِلْمُنَافِقِ"},{"kind":"word","token":"فيكون","display":"فَيَكُونُ"},{"kind":"word","token":"نوره","display":"نُورُهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"قدر","display":"قَدْرِ"},{"kind":"word","token":"ابهام","display":"اِبْهَامِ"},{"kind":"word","token":"رجله","display":"رِجْلِهِ"},{"kind":"word","token":"اليسري","display":"الْيُسْرَي"},{"kind":"word","token":"فيطا","display":"فَيَطَاُ"},{"kind":"word","token":"نوره","display":"نُورَهُ"},{"kind":"word","token":"فيقول","display":"فَيَقُولُ"},{"kind":"word","token":"مكانكم","display":"مَكَانَكُمْ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"اقتبس","display":"اَقْتَبِسَ"},{"kind":"word","token":"م