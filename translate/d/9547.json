d","token":"لانهم","display":"لِاَنَّهُمْ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"صدق","display":"صَدَّقَ"},{"kind":"word","token":"صدقناه","display":"صَدَّقْنَاهُ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"كذب","display":"كَذَّبَ"},{"kind":"word","token":"كذبناه","display":"كَذَّبْنَاهُ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"},{"kind":"word","token":"كذبناه","display":"كذّبناه"}]},{"source_hadith_segment":"قَالَ قُلْتُ فَذَاكَ  <quranic_text> « اِنَّمٰا وَلِيُّكُمُ اللّٰهُ وَ رَسُولُهُ وَ الَّذِينَ امَنُوا الَّذِينَ يُقِيمُونَ الصَّلاٰةَ وَ يُؤْتُونَ الزَّكٰاةَ وَ هُمْ رٰاكِعُونَ » </quranic_text>   <footnote> [ المائدة ۵۵ ] </footnote>  قَالَ اِيَّانَا عَنَي قُلْتُ فَقَوْلُهُ  <quranic_text> « وَ قُلِ اِعْمَلُوا فَسَيَرَي اللّٰهُ عَمَلَكُمْ وَ رَسُولُهُ وَ الْمُؤْمِنُونَ » </quranic_text>   <footnote> [ التوبة ۱۰۵ ] </footnote>  قَالَ اِيَّانَا عَنَي قُلْتُ فَقَوْلُهُ  <quranic_text> « وَ كَذٰلِكَ جَعَلْنٰاكُمْ اُمَّةً وَسَطاً لِتَكُونُوا شُهَدٰاءَ عَلَي النّٰاسِ وَ يَكُونَ الرَّسُولُ عَلَيْكُمْ شَهِيداً » </quranic_text>   <footnote> [ البقرة ۱۴۳ ] </footnote>  قَالَ نَحْنُ الْاُمَّةُ الْوَسَطُ وَ نَحْنُ شُهَدَاءُ اللَّهِ عَلَي خَلْقِهِ وَ حُجَّتُهُ فِي اَرْضِهِ قُلْتُ فَقَوْلُهُ  <quranic_text> « فَقَدْ اتَيْنٰا الَ اِبْرٰاهِيمَ الْكِتٰابَ وَ الْحِكْمَةَ وَ اتَيْنٰاهُمْ مُلْكاً عَظِيماً » </quranic_text>   <footnote> [ النساء ۵۴ ] </footnote>  قَالَ الْمُلْكُ الْعَظِيمُ اَنْ جَعَلَ مِنْهُمْ اَئِمَّةً مَنْ اَطَاعَهُمْ فَقَدْ اَطَاعَ اللَّهَ وَ مَنْ عَصَاهُمْ عَصَي اللَّهَ فَهُوَ الْمُلْكُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"الْعَظِيمُ قُلْتُ فَقَوْلُهُ  <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا اِرْكَعُوا وَ اُسْجُدُوا وَ اُعْبُدُوا رَبَّكُمْ وَ اِفْعَلُوا الْخَيْرَ لَعَلَّكُمْ تُفْلِحُونَ وَ جٰاهِدُوا فِي اللّٰهِ حَقَّ جِهٰادِهِ هُوَ اِجْتَبٰاكُمْ وَ مٰا جَعَلَ عَلَيْكُمْ فِي الدِّينِ مِنْ حَرَجٍ مِلَّةَ اَبِيكُمْ اِبْرٰاهِيمَ هُوَ سَمّٰاكُمُ الْمُسْلِمِينَ » </quranic_text>   <footnote> [ الحج ۷۷ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ اِيَّانَا عَنَي نَحْنُ الْمُجْتَبَوْنَ وَ لَمْ يَجْعَلْ عَلَيْنَا فِي الدِّينِ مِنْ ضِيقٍ وَ الْحَرَجُ اَشَدُّ مِنَ الضِّيقِ  <quranic_text> « مِلَّةَ اَبِيكُمْ اِبْرٰاهِيمَ  » </quranic_text>   <footnote> [ الحج ۷۸ ] </footnote>  قَالَ اِيَّانَا عَنَي خَاصَّةً  <quranic_text> « هُوَ سَمّٰاكُمُ الْمُسْلِمِينَ مِنْ قَبْلُ » </quranic_text>   <footnote> [ الحج ۷۸ ] </footnote>  فِي الْكُتُبِ الَّتِي مَضَتْ  <quranic_text> « فِي هٰذٰا لِيَكُونَ الرَّسُولُ شَهِيداً عَلَيْكُمْ » </quranic_text>   <footnote> [ الحج ۷۸ ] </footnote>  فَرَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ شَهِيدٌ عَلَيْنَا فِيمَا بَلَغَنَا عَنِ اللَّهِ عَزَّ وَ جَلَّ وَ نَحْنُ الشُّهَدَاءُ عَلَي النَّاسِ فَمَنْ صَدَّقَنَا يَوْمَ الْقِيَامَةِ صَدَّقْنَاهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ مَنْ كَذَّبَنَا يَوْمَ الْقِيَامَةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"كَذَّبْنَاهُ قَالَ فَقَوْلُهُ  <quranic_text> « قُلْ كَفيٰ بِاللّٰهِ شَهِيداً بَيْنِي وَ بَيْنَكُمْ وَ مَنْ عِنْدَهُ عِلْمُ الْكِتٰابِ » </quranic_text>   <footnote> [ الرعد ۴۳ ] </footnote>  قَالَ اِيَّانَا عَنَي وَ عَلِيٌّ اَقْضَانَا وَ اَوَّلُنَا وَ خَيْرُنَا بَعْدَ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ قُلْتُ فَقَوْلُهُ  <quranic_text> « وَ اِنَّهُ لَذِكْرٌ لَكَ وَ لِقَوْمِكَ وَ سَوْفَ تُسْئَلُونَ » </quranic_text>   <footnote> [ الزخرف ۴۴ ] </footnote>  قَالَ اِيَّانَا عَنَي نَحْنُ الْمَسْئُولُونَ وَ نَحْنُ اَهْلُ الذِّكْرِ فَقُلْتُ  <quranic_text> « اِنَّمٰا اَنْتَ مُنْذِرٌ وَ لِكُلِّ قَوْمٍ هٰادٍ » </quranic_text>   <footnote> [ الرعد ۷ ] </footnote>  قَالَ الْمُنْذِرُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ فِي كُلِّ زَمَانٍ مِنَّا اِمَامٌ يَهْدِي اِلَي مَا جَاءَ بِهِ نَبِيُّ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ثُمَّ الْهُدَاةُ مِنْ بَعْدِهِ عَلِيُّ بْنُ اَبِي طَالِبٍ وَ الْاَوْصِيَاءُ قُلْتُ فَقَوْلُهُ  <quranic_text> « وَ مٰا يَعْلَمُ تَاْوِيلَهُ اِلاَّ اللّٰهُ وَ الرّٰاسِخُونَ فِي الْعِلْمِ » </quranic_text>   <footnote> [ العمران ۷ ] </footnote>  قَالَ فَرَسُولُ اللَّهِ اَفْضَلُ الرَّاسِخِينَ قَدْ عَلِمَ جَمِيعَ مَا اَنْزَلَ عَلَيْهِ وَ مَا كَادَ لَيُنْزِلُ عَلَيْهِ شَيْئاً لَمْ يَعْلَمْهُ وَ اَوْصِيَاؤُنَا مِنْ بَعْدِهِ يَعْلَمُونَ ذَلِكَ كُلَّهُ فَقَالَ الَّذِينَ لاَ يَعْلَمُونَ مَا يَقُولُ اِذَا لَمْ يَعْلَمْ تَاْوِيلَهُ نَادَي بِهِمُ اللَّهُ  <quranic_text> « يَقُولُونَ امَنّٰا بِهِ كُلٌّ مِنْ عِنْدِ رَبِّنٰا » </quranic_text>   <footnote> [ العمران ۷ ] </footnote>  وَ الْقُرْانُ لَهُ خَاصُّ وَ عَامٌّ وَ نَاسِخٌ وَ مَنْسُوخٌ وَ مُحْكَمٌ وَ مُتَشَابِهٌ وَ الرَّاسِخُونَ فِي الْعِلْمِ يَعْلَمُونَهُ قُلْتُ فَقَوْلُهُ  <quranic_text> « ثُمَّ اَوْرَثْنَا الْكِتٰابَ الَّذِينَ اِصْطَفَيْنٰا مِنْ عِبٰادِنٰا فَمِنْهُمْ ظٰالِمٌ لِنَفْسِهِ وَ مِنْهُمْ مُقْتَصِدٌ وَ مِنْهُمْ سٰابِقٌ بِالْخَيْرٰاتِ بِاِذْنِ اللّٰهِ ذٰلِكَ هُوَ الْفَضْلُ الْكَبِيرُ » </quranic_text>   <footnote> [ فاطر ۳۲ ] </footnote>  قَالَ اِيَّانَا عَنَي فَالسَّابِقُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"الْاِمَامُ وَ الْمُقْتَصِدُ الْعَارِفُ وَ الظَّالِمُ الشَّاكُّ الْوَاقِفُ مِنْهُمْ .","translation_segment":"","segment_columns":[]}]}