{"consensus_set_id":"34443","translation_language":"fa","translation_source":{"hid":"114849"},"segments":[{"source_hadith_segment":"اَلْمُؤْلِي يُوقَفُ بَعْدَ الْاَرْبَعَةِ الْاَشْهُرِ فَاِنْ شَاءَ اِمْسَاكٌ  <quranic_text> « بِمَعْرُوفٍ اَوْ تَسْرِيحٌ بِاِحْسٰانٍ » </quranic_text>   <footnote> [ البقرة ۲۲۹ ] </footnote>  فَاِنْ عَزَمَ الطَّلاَقَ فَهِيَ وَاحِدَةٌ وَ هُوَ اَمْلَكُ بِرَجْعَتِهَا .","translation_segment":"ابو مریم گوید: امام باقر علیه السلام فرمود: شخصی که ایلاء نموده بعد از چهار ماه دستگیر می‌شود. پس اگر بخواهد؛ همسرش را با سازش و مدارا نگه دارد و یا به نیکی آزادش کند و اگر اراده طلاق کند؛ پس این، یک طلاق محسوب می‌شود که مرد به رجوع به او سزاوارتر است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المؤلي","display":"اَلْمُؤْلِي"},{"kind":"word","token":"يوقف","display":"يُوقَفُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الاربعه","display":"الْاَرْبَعَةِ"},{"kind":"word","token":"الاشهر","display":"الْاَشْهُرِ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"شاء","display":"شَاءَ"},{"kind":"word","token":"امساك","display":"اِمْسَاكٌ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بمعروف","display":"بِمَعْرُوفٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"تسريح","display":"تَسْرِيحٌ"},{"kind":"word","token":"باحسان","display":"بِاِحْسٰانٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۲۹","display":"۲۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"عزم","display":"عَزَمَ"},{"kind":"word","token":"الطلاق","display":"الطَّلاَقَ"},{"kind":"word","token":"فهي","display":"فَهِيَ"},{"kind":"word","token":"واحده","display":"وَاحِدَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},