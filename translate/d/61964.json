{"consensus_set_id":"61964","translation_language":"fa","translation_source":{"hid":"311327"},"segments":[{"source_hadith_segment":"قَالَ قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  مَنْ قَرَاَ  <quranic_text> « اَلْهٰاكُمُ التَّكٰاثُرُ » </quranic_text>   <footnote> [ التكاثر ۱ ] </footnote>  عِنْدَ النَّوْمِ وُقِيَ مِنْ فِتْنَةِ الْقَبْرِ .","translation_segment":"از درست واسطی از امام صادق علیه السلام روایت شده است که رسول خدا صلی اللٰه علیه و اله و سلم فرموده: هر کس سوره «ألهٰاکم‌ التکٰاثر»» را هنگام خواب تلاوت کند از فتنه و گرفتاری قبر ایمن باشد.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"وسلم","display":"وسلم"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الهاكم","display":"اَلْهٰاكُمُ"},{"kind":"word","token":"التكاثر","display":"التَّكٰاثُرُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التكاثر","display":"التكاثر"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"النوم","display":"النَّوْمِ"},{"kind":"word","token":"وقي","display":"وُقِيَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"فتنه","display":"فِتْنَةِ"},{"kind":"word","token":"القبر","display":"الْقَبْرِ"}]}]}