{"consensus_set_id":"23525","translation_language":"fa","translation_source":{"hid":"108815"},"segments":[{"source_hadith_segment":"اِذَا كُنْتَ دَخَلْتَ فِي صَلاَتِكَ فَعَلَيْكَ بِالتَّخَشُّعِ وَ الْاِقْبَالِ عَلَي صَلاَتِكَ فَاِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « اَلَّذِينَ هُمْ فِي صَلاٰتِهِمْ خٰاشِعُونَ » </quranic_text>   <footnote> [ المؤمنون ۲ ] </footnote>   .","translation_segment":"حلبی گوید: امام صادق علیه السلام فرمود: هرگاه شروع به نماز کردی، بر تو باد که با خشوع بوده و به آن متوجه باشی، زیرا که خداوند عز و جل‌ می‌فرماید: «به تحقیق آن مومنانی رستگارند که در نماز خویش خاشع و فروتنند».","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"كنت","display":"كُنْتَ"},{"kind":"word","token":"دخلت","display":"دَخَلْتَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"صلاتك","display":"صَلاَتِكَ"},{"kind":"word","token":"فعليك","display":"فَعَلَيْكَ"},{"kind":"word","token":"بالتخشع","display":"بِالتَّخَشُّعِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الاقبال","display":"الْاِقْبَالِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"صلاتك","display":"صَلاَتِكَ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"اَلَّذِينَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"صلاتهم","display":"صَلاٰتِهِمْ"},{"kind":"word","token":"خاشعون","display":"خٰاشِعُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"k