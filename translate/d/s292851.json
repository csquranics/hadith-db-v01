{"consensus_set_id":"s292851","translation_language":"fa","translation_source":{"hid":"292851"},"segments":[{"source_hadith_segment":"فَلَمَّا نَزَلَ قَوْلُهُ تَعَالَي  <quranic_text> « خُذِ الْعَفْوَ وَ اْمُرْ بِالْعُرْفِ وَ اَعْرِضْ عَنِ الْجٰاهِلِينَ » </quranic_text>   <footnote> [ الاعراف ۱۹۹ ] </footnote>  قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَدَّبَنِي رَبِّي بِمَكَارِمِ الْاَخْلاَقِ .","translation_segment":"چون که این آیه بر پیغمبر نازل شد «خذ العفو و أمر بالعرف‌ و أعرض‌ عن‌ الجٰاهلین‌» بگیر خوبیها را و فرمان بخشش بده و از نادان دوری کن رسول خدا فرمود که خداوند مرا باین آیه بتمام خوبیها ادب فرمود.","segment_columns":[{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"خذ","display":"خُذِ"},{"kind":"word","token":"العفو","display":"الْعَفْوَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امر","display":"اْمُرْ"},{"kind":"word","token":"بالعرف","display":"بِالْعُرْفِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعرض","display":"اَعْرِضْ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الجاهلين","display":"الْجٰاهِلِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۹۹","display":"۱۹۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","toke