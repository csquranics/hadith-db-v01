{"consensus_set_id":"41433","translation_language":"fa","translation_source":{"hid":"404307"},"segments":[{"source_hadith_segment":"« مَنْ كَانَتْ بَيْنَهُ وَ بَيْنَ اَخِيهِ مُنَازَعَةٌ فَدَعَاهُ اِلَي رَجُلٍ مِنْ اَصْحَابِهِ يَحْكُمُ بَيْنَهُمَا ،  فَاَبَي اِلاَّ اَنْ يُرَافِعَهُ اِلَي السُّلْطَانِ ،  فَهُوَ كَمَنْ حَاكَمَ اِلَي الْجِبْتِ وَ الطَّاغُوتِ ،  وَ قَدْ قَالَ اللَّهُ :   <quranic_text> « يُرِيدُونَ اَنْ يَتَحٰاكَمُوا اِلَي الطّٰاغُوتِ » </quranic_text>   <footnote> [ النساء ۶۰ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « بَعِيداً » </quranic_text>   <footnote> [ النساء ۶۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"بينه","display":"بَيْنَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"اخيه","display":"اَخِيهِ"},{"kind":"word","token":"منازعه","display":"مُنَازَعَةٌ"},{"kind":"word","token":"فدعاه","display":"فَدَعَاهُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اصحابه","display":"اَصْحَابِهِ"},{"kind":"word","token":"يحكم","display":"يَحْكُمُ"},{"kind":"word","token":"بينهما","display":"بَيْنَهُمَا"},{"kind":"word","token":"فابي","display":"فَاَبَي"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يرافعه","display":"يُرَافِعَهُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"السلطان","display":"السُّلْطَانِ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"كمن","display":"كَمَنْ"},{"kind":"word","token":"حاكم","display":"حَاكَمَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الجبت","display":"الْجِبْتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"