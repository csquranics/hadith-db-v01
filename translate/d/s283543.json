{"consensus_set_id":"s283543","translation_language":"fa","translation_source":{"hid":"283543"},"segments":[{"source_hadith_segment":"اَسْاَلُكَ اَللَّهُمَّ بِاسْمِكَ يَا لاَ اِلَهَ اِلاَّ اَنْتَ الْوَاحِدُ الْفَرْدُ الصَّمَدُ الَّذِي لاَ يَعْدِلُهُ شَيْءٌ فِي الْاَرْضِ وَ لاَ فِي السَّمَاءِ وَ اَسْاَلُكَ بِاسْمِكَ الْعَلِيِّ الْاَعْلَي وَ اَسْاَلُكَ بِاسْمِكَ الْعَظِيمِ الْاَعْظَمِ وَ اَسْاَلُكَ بِاسْمِكَ الْجَلِيلِ الْاَجَلِّ وَ اَسْاَلُكَ بِاسْمِكَ الَّذِي  <quranic_text> « لاٰ اِلٰهَ اِلاّٰ هُوَ عٰالِمُ الْغَيْبِ وَ الشَّهٰادَةِ » </quranic_text>   <footnote> [ الحشر ۲۲ ] </footnote>   .  .  .   <quranic_text> « الرَّحْمٰنُ الرَّحِيمُ » </quranic_text>   <footnote> [ الحشر ۲۲ ] </footnote>  وَ اَسْاَلُكَ بِاسْمِكَ الَّذِي  <quranic_text> « لاٰ اِلٰهَ اِلاّٰ هُوَ » </quranic_text>   <footnote> [ الحشر ۲۳ ] </footnote>  - .  .  .   <quranic_text> « السَّلاٰمُ الْمُؤْمِنُ الْمُهَيْمِنُ الْعَزِيزُ الْجَبّٰارُ الْمُتَكَبِّرُ » </quranic_text>   <footnote> [ الحشر ۲۳ ] </footnote>  سُبْحَانَكَ اللَّهُمَّ عَمَّا يُشْرِكُونَ وَ اَسْاَلُكَ بِاسْمِكَ الْكَرِيمِ الْعَزِيزِ وَ بِاَنَّكَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ -  <quranic_text> « الْخٰالِقُ الْبٰارِئُ الْمُصَوِّرُ » </quranic_text>   <footnote> [ الحشر ۲۴ ] </footnote>  لَكَ الْاَسْمَاءُ الْحُسْنَي يُسَبِّحُ بِحَمْدِكَ مَا فِي السَّمَاوَاتِ وَ الْاَرْضِ وَ اَنْتَ الْعَزِيزُ الْحَكِيمُ وَ اَسْاَلُكَ بِاسْمِكَ الْمَكْنُونِ الْمَخْزُونِ لاَ اِلَهَ اِلاَّ اَنْتَ وَ اَسْاَلُكَ اللَّهُمَّ بِاسْمِكَ الَّذِي اِذَا دُعِيتَ بِهِ اَجَبْتَ وَ اِذَا سُئِلْتَ بِهِ اَعْطَيْتَ وَ اَسْاَلُكَ اللَّهُمَّ بِمَا تُحِبُّ اَنْ اَسْاَلَكَ بِهِ مِنْ مَسْاَلَةٍ وَ اَسْاَلُكَ اللَّهُمَّ بِاسْمِكَ الَّذِي سَاَلَ بِهِ عَبْدُكَ الَّذِي عِنْدَهُ عِلْمٌ مِنَ الْكِتَابِ فَاَتَيْتَهُ بِالْعَرْشِ قَبْلَ اَنْ يَرْتَدَّ اِلَيْهِ طَرْفُهُ وَ اَسْاَلُكَ اللَّهُمَّ بِلاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « الْحَيُّ الْقَيُّومُ - لاٰ تَاْخُذُهُ سِنَةٌ وَ لاٰ نَوْمٌ لَهُ مٰا فِي السَّمٰاوٰاتِ وَ مٰا فِي الْاَرْضِ مَنْ ذَا الَّذِي يَشْفَعُ عِنْدَهُ اِلاّٰ بِاِذْنِهِ يَعْلَمُ مٰا بَيْنَ اَيْدِيهِمْ وَ مٰا خَلْفَهُمْ وَ لاٰ يُحِيطُونَ بِشَيْءٍ مِنْ عِلْمِهِ اِلاّٰ بِمٰا شٰاءَ وَسِعَ كُرْسِيُّهُ السَّمٰاوٰاتِ وَ الْاَرْضَ وَ لاٰ يَؤُدُهُ حِفْظُهُمٰا وَ هُوَ الْعَلِيُّ الْعَظِيمُ » </quranic_text>   <footnote> [ البقرة ۲۵۵ ] </footnote>  وَ اَسْاَلُكَ اللَّهُمَّ لاَ اِلَهَ","translation_segment":"","segment_columns":[{"kind":"word","token":"اسالك","display":"اَسْاَلُكَ"},{"kind":"word","token":"اللهم","display":"اَللَّهُمَّ"},{"kind":"word","token":"باسمك","display":"بِاسْمِكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اله","display":"اِلَهَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"الواحد","display":"الْوَاحِدُ"},{"kind":"word","token":"الفرد","display":"الْفَرْدُ"},{"kind":"word","token":"الصمد","display":"الصَّمَدُ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يعدله","display":"يَعْدِلُهُ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السماء","display":"السَّمَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسالك","display":"اَسْاَلُكَ"},{"kind":"word","token":"باسمك","display":"بِاسْمِكَ"},{"kind":"word","token":"العلي","display":"الْعَلِيِّ"},{"kind":"word","token":"الاعلي","display":"الْاَعْلَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسالك","display":"اَسْاَلُكَ"},{"kind":"word","token":"باسمك","display":"بِاسْمِكَ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمِ"},{"kind":"word","token":"الاعظم","display":"الْاَعْظَمِ"},{"kind":"word","token":"و","display":"وَ"},{