َخِلاَّءِ يَرْفَعُ اللَّهُ بِهِ اَقْوَاماً فَيَجْعَلُهُمْ فِي الْخَيْرِ قَادَةً يُقْتَبَسُ اثَارَهُمْ وَ يُهْتَدَي بِفِعَالِهِمْ وَ يُنْتَهَي اِلَي رَاْيِهِمْ وَ تَرْغَبُ الْمَلاَئِكَةُ فِي خَلَّتِهِمْ وَ بِاَجْنِحَتِهَا تَمْسَحُهُمْ وَ فِي صَلاَتِهِمْ تُبَارِكُ عَلَيْهِمْ وَ يَسْتَغْفِرُ لَهُمْ كُلُّ رَطْبٍ وَ يَابِسٍ حَتَّي حِيتَانُ الْبَحْرِ وَ هَوَامُّهُ - وَ سِبَاعُ الْبَرِّ وَ اَنْعَامُهُ وَ اِنَّ الْعِلْمَ حَيَاةُ الْقُلُوبِ مِنَ الْجَهْلِ وَ ضِيَاءُ الْاَبْصَارِ مِنَ الظُّلْمَةِ وَ قُوَّةُ الْاَبْدَانِ مِنَ الضَّعْفِ يَبْلُغُ بِالْعَبْدِ مَنَازِلَ الْاَخْيَارِ وَ مَجَالِسَ الْاَبْرَارِ وَ الدَّرَجَاتِ الْعُلَي فِي الدُّنْيَا وَ الْاخِرَةِ وَ الْفِكْرَةُ فِيهِ يَعْدِلُ بِالصِّيَامِ وَ مُدَارَسَتُهُ بِالْقِيَامِ وَ بِهِ يُطَاعُ الرَّبُّ عَزَّ وَ جَلَّ وَ يُعْبَدُ وَ بِهِ تُوصَلُ الْاَرْحَامُ وَ يُعْرَفُ الْحَلاَلُ وَ الْحَرَامُ وَ الْعِلْمُ اِمَامُ الْعَمَلِ وَ الْعَمَلُ تَابِعُهُ - يُلْهِمُهُ السُّعَدَاءَ وَ يَحْرِمُهُ الْاَشْقِيَاءَ فَطُوبَي لِمَنْ لاَ يَحْرِمُهُ اللَّهُ مِنْهُ حَظَّهُ .","translation_segment":"جهاد». - «چون یادگیری آن علم اگر برای خدا باشد، حسنه است (و ثواب دارد) و طلب علم عبادت است و گفتگو و بحث در مسائل علمی تسبیح حق می‌باشد و عمل کردن به آن، خود جهاد است» - «و تعلیمه من لا یعلمه صدقه، و بذله لاهله قربه الی اللٰه تبارک و تعالی». - «آموختن علم به نادانان یک نوع صدقه است و بخشیدنش به کسانی که اهلیتش را دارند، موجب نزدیکی و تقرب به خداوند تعالی می‌باشد» - «لانه من معالم الحلال و الحرام، و منار سبیل الجنه، و المونس فی الوحشه، و الصاحب فی الغربه و الوحده، و المحدث فی الخلوه، و الدلیل علی السراء و الضراء، و السلاح علی الاعداء، و الزین علی الاخلاء». - «چون حلال و حرام را به واسطه علم می‌توان تمیز داد، روشنگر راه بهشت است، مونس در وقت وحشت، یار و همراه در غربت و تنهایی، همصحبت در خلوتها، راهنما هنگام خوشحالیها و غمها، سلاح بر علیه دشمن و موجب زینت و زیبایی نزد دوستان می‌باشد» - «خداوند متعال به وسیله علم، اقوامی را برتر می‌سازد و بالا می‌برد تا جایی که آنان را در مقام رهبری قرار می‌دهد که دیگران باید از ایشان پیروی کنند و اعمال اینان را سرمشق خود قرار دهند و در نظرات و آراء به اینان رجوع نمایند» - «ملائکه آرزوی دوستی با ایشان را دارند و بالها را بر آنان می‌مالند و در نمازشان بر اینان درود و تبریک می‌فرستند» - «هر موجودتر و خشکی برای اینان طلب مغفرت و آمرزش می‌کند، حتی ماهیان دریا و درندگان و چهار پایان صحرا» - «علم موجب زنده شدن قلبها از (مرگ) جهالت و نادانی است، روشنی چشمها در تاریکی و سبب قوی شدن بدن در برابر ضعفهاست» - «علم بنده را به درجات برگزیدگان و مجالس نیکان می‌برد و در دنیا و آخرت موجب علو درجات می‌گردد» - «فکر را به علم مشغول داشتن، معادل روزه است و بحث و درسش مساوی با شب‌زنده‌داری». - «بندگی خدای عزیز و جلیل، پیوند خویشاوندان و شناخت حلال و حرام الهی به واسطه دانش است» - «علم پیشوای عمل است و عمل پیرو اوست» - «خداوند سبحان آن را به افراد با سعادت می‌دهد و افراد با شقاوت را از آن محروم می‌دارد» - «پس خوشا به حال کسی که خداوند او را از برکت دانش محروم نکرده باشد».","segment_columns":[{"kind":"word","token":"تعليمه","display":"تَعْلِيمَهُ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"سبحانه","display":"سُبْحَانَهُ"},{"kind":"word","token":"حسنه","display":"حَسَنَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طلبه","display":"طَلَبَهُ"},{"kind":"word","token":"عباده","display":"عِبَادَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المذاكره","display":"الْمُذَاكَرَةَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"تسبيح","display":"تَسْبِيحٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"العمل","display":"الْعَمَلَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"جهاد","display":"جِهَادٌ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعليمه","display":"تَعْلِيمَهُ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يعلمه","display":"يَعْلَمُهُ"},{"kind":"word","token":"صدقه","display":"صَدَقَةٌ"},{"kind":"word","token":"و","dis