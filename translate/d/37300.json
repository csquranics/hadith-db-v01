نَ الْعَلَفِ وَ مِنَ الْبَرَصِ وَ بَلْعِ الرِّيشِ وَ مِنَ الذَّرَبِ وَ مِنْ قَصْرِ الْاَرْسَاغِ وَ مِنَ النَّكْبَةِ وَ النَّمْلَةِ وَ مِنَ الاِمْتِنَاعِ مِنَ الْانِيَةِ وَ الْعَلَفِ وَ السَّرْجِ وَ اللِّجَامِ حَصَّنْتُ جَمِيعَ مَا عُلِّقَ عَلَيْهِ كِتَابِي هَذَا بِاللَّهِ الْعَلِيِّ الْعَظِيمِ مِنْ كُلِّ سَبُعٍ وَ ضَبُعٍ وَ اَسَدٍ وَ اَسْوَدٍ وَ مِنْ شَرِّ كُلِّ ذِي شَرٍّ وَ مِنْ شَرِّ السُّرَّاقِ وَ الطُّرَّاقِ اِلاَّ طَارِقاً يَطْرُقُ بِخَيْرٍ","translation_segment":"و القرده و العزیزی و الحکه و الجرب و الجلد و القصر و الجمرد و الهده فی الظهر و الزوائد و النفاخ و العلاق و الذباب و الزنابیر و الارتعاش و الارتهاش و الظلمه و المغل و الورم و الجدری‌ و الطبوع و من الجمح و الرمح و من الفالج و القولنج و الخداج و قیام العین و الدمعه عند الجری و من التعسر و التبخیل و من معط‍‌ شعر الناصیه و من الامتناع و من العلف و من البرص و بلع الریش و من الذرب و من قصر الأرساغ و من النکبه و النمله و من الامتناع من الآنیه و العلف و السرج و اللجام. حصنت جمیع ما علق علیه کتابی هذا باللٰه العلی‌ العظیم من کل‌ سبع و ضبع و أسد و أسود و من شر کل‌ ذی شر و من السراق و الطراق إلا طارقا یطرق بخیر «قل‌: من‌ یکلوکم‌ باللیل‌ و النهٰار من‌ الرحمٰن‌؟ بل‌ هم‌ عن‌ ذکر ربهم‌ معرضون‌» بل «هو اللٰه‌ الوٰاحد القهٰار». تحصنت بذی العزه و الجبروت و توکلت علی الحی‌ الذی لا یموت نور النور و مقدر النور نور الأنوار مقلب القلوب و الأبصار ذلک اللٰه الملک القهار «فسیکفیکهم‌ اللٰه‌ و هو السمیع‌ العلیم‌» و هو بکل‌ شی محیط‍‌.». «به نام پروردگار بخشاینده‌ی مهربان؛ به پناه خدا می‌برم هر چیزی را که این نوشته‌ی من بر آن آویخته است از اسب و چارپایان، از کمیت و اشقر و ابلق و ادهم و اغر و احوی و چابک و تیزرو و فربه و رنگ‌های مختلف آن، از محجل و زرد. پناه می‌دهم و باز می‌دارم و دور می‌گردانم و گره می‌زنم و جلوگیری می‌کنم آن را که این نوشته‌ی من بر او بسته شده است، از همه‌ی اسب‌ها و چارپایان و حیوانات، از زخم زدن و صدمه وارد کردن و جویدن لگام و دندان درد و درد مهارها و لغزش‌ها و نزدیک بینی و شب کوری و سنگریزه و بغدلیه و درد جگر و ریه و طحال و ورم کردن دست و پا و لغزیدن و مجعد شدن و به هم چسبیدن موی و زخم ران و خارش و گری و بی‌درد شدن از ضرب تازیانه و پیدا شدن خشکی در گردن و جفتک زدن در بند و شکستگی در پشت و بقیه‌ی اعضا و آماس و زالوها و مگس‌ها و زنبورها و لرزش‌ها و سم به یک دیگر زدن و مجروح شدن آن در رفتن و کندن زمین و خوردن خاک گیاه و تورم و آبله و تنبلی و سرکشی و لگد زدن و شل شدن و قولنج و نقص خلقت و دیدن مستقیم و اشک ریزی وقت رفتن و از کند روی و در مسابقه","segment_columns":[{"kind":"word","token":"اعوذ","display":"اَعُوذُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امنع","display":"اَمْنَعُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ازجر","display":"اَزْجُرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعقد","display":"اَعْقِدُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"احبس","display":"اَحْبِسُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"علق","display":"عُلِّقَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"كتابي","display":"كِتَابِي"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"جميع","display":"جَمِيعِ"},{"kind":"word","token":"الخيل","display":"الْخَيْلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"البهائم","display":"الْبَهَائِمِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحيوان","display":"الْحَيَوَانِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الكلام","display":"الْكَلاَمِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصدام","display":"الصِّدَامِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مضغ","display":"مَضْغِ"},{"kind":"word","token":"اللجام","display":"اللِّجَامِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مرض","display":"مَرَضِ"},{"kind":"word","token":"الاسنان","display":"الْاَسْنَانِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token