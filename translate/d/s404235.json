{"consensus_set_id":"s404235","translation_language":"fa","translation_source":{"hid":"404235"},"segments":[{"source_hadith_segment":"حَضَرَ اَلرِّضَا ( عَلَيْهِ السَّلاَمُ ) مَجْلِسَ الْمَاْمُونِ بِمَرْوَ ،  وَ قَدِ اِجْتَمَعَ اِلَيْهِ فِي مَجْلِسِهِ جَمَاعَةٌ مِنْ عُلَمَاءِ اَهْلِ الْعِرَاقِ وَ خُرَاسَانَ - الْحَدِيثُ طَوِيلٌ ،  وَ فِيهِ - قَالَ :  « قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « اَمْ يَحْسُدُونَ النّٰاسَ عَليٰ مٰا اتٰاهُمُ اللّٰهُ مِنْ فَضْلِهِ فَقَدْ اتَيْنٰا الَ اِبْرٰاهِيمَ الْكِتٰابَ وَ الْحِكْمَةَ وَ اتَيْنٰاهُمْ مُلْكاً عَظِيماً » </quranic_text>   <footnote> [ النساء ۵۴ ] </footnote>  ثُمَّ رَدَّ الْمُخَاطَبَةَ فِي اَثَرِ هَذَا اِلَي سَائِرِ الْمُؤْمِنِينَ ،  فَقَالَ :   <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا اَطِيعُوا اللّٰهَ وَ اَطِيعُوا الرَّسُولَ وَ اُولِي الْاَمْرِ مِنْكُمْ » </quranic_text>   <footnote> [ النساء ۵۹ ] </footnote>  يَعْنِي الَّذِينَ قَرَنَهُمْ بِالْكِتَابِ وَ الْحِكْمَةِ وَ حَسَدُوا عَلَيْهِمَا ،  فَقَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « اَمْ يَحْسُدُونَ النّٰاسَ عَليٰ مٰا اتٰاهُمُ اللّٰهُ مِنْ فَضْلِهِ فَقَدْ اتَيْنٰا الَ اِبْرٰاهِيمَ الْكِتٰابَ وَ الْحِكْمَةَ وَ اتَيْنٰاهُمْ مُلْكاً عَظِيماً » </quranic_text>   <footnote> [ النساء ۵۴ ] </footnote> يَعْنِي الطَّاعَةَ لِلْمُصْطَفَيْنَ الطَّاهِرِينَ ،  فَالْمُلِكُ هَاهُنَا الطَّاعَةُ لَهُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"حضر","display":"حَضَرَ"},{"kind":"word","token":"الرضا","display":"اَلرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"مجلس","display":"مَجْلِسَ"},{"kind":"word","token":"المامون","display":"الْمَاْمُونِ"},{"kind":"word","token":"بمرو","display":"بِمَرْوَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدِ"},{"kind":"word","token":"اجتمع","display":"اِجْتَمَعَ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"wor