{"consensus_set_id":"68950","translation_language":"fa","translation_source":{"hid":"106870"},"segments":[{"source_hadith_segment":"مَنْ عَمِلَ سَيِّئَةً اُجِّلَ فِيهَا سَبْعَ سَاعَاتٍ مِنَ النَّهَارِ فَاِنْ قَالَ اَسْتَغْفِرُ اللَّهَ الَّذِي  <quranic_text> « لاٰ اِلٰهَ اِلاّٰ هُوَ الْحَيُّ الْقَيُّومُ » </quranic_text>   <footnote> [ البقرة ۲۵۵ ] </footnote>  ثَلاَثَ مَرَّاتٍ لَمْ تُكْتَبْ عَلَيْهِ .","translation_segment":"حضرت صادق علیه السلام فرمود: هر کس گناهی کند هفت ساعت از روز در باره آنها باو مهلت دهند پس اگر سه بار گفت: «استغفر اللٰه الذی لا اله الا هو الحی القیوم». آن گناه بر او نوشته نشود.","segment_columns":[{"kind":"word","token":"انه","display":"انه"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عمل","display":"عَمِلَ"},{"kind":"word","token":"سيئه","display":"سَيِّئَةً"},{"kind":"word","token":"اجل","display":"اُجِّلَ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"ساعات","display":"سَاعَاتٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"النهار","display":"النَّهَارِ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"استغفر","display":"اَسْتَغْفِرُ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"اله","display":"اِلٰهَ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الحي","display":"الْحَيُّ"},{"kind":"word","token":"القيوم","display":"الْقَيُّومُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۵۵","display":"۲۵۵"},{"kind":"tag_close","tag_name":"footno