{"consensus_set_id":"9988","translation_language":"fa","translation_source":{"hid":"407810"},"segments":[{"source_hadith_segment":"« اِذَا اِجْتَمَعَ الْعِدَّةُ عَلَي قَتْلِ رَجُلٍ ،  حَكَمَ الْوَالِي بِقَتْلِ اَيِّهِمْ شَاءَ ،  وَ لَيْسَ لَهُ اَنْ يَقْتُلَ اَكْثَرَ مِنْ وَاحِدٍ ،  اِنَّ اللَّهَ يَقُولُ :   <quranic_text> « وَ مَنْ قُتِلَ مَظْلُوماً فَقَدْ جَعَلْنٰا لِوَلِيِّهِ سُلْطٰاناً فَلاٰ يُسْرِفْ فِي الْقَتْلِ اِنَّهُ كٰانَ مَنْصُوراً » </quranic_text>   <footnote> [ الاسراء ۳۳ ] </footnote> وَ اِذَا قَتَلَ وَاحِداً ثَلاَثَةٌ ،  خُيِّرَ الْوَالِي اَيَّ الثَّلاَثَةِ شَاءَ اَنْ يَقْتُلَ ،  وَ يُضَمَّنُ الْاخَرَانِ ثُلُثَيِ الدِّيَةِ لِوَرَثَةِ الْمَقْتُولِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اجتمع","display":"اِجْتَمَعَ"},{"kind":"word","token":"العده","display":"الْعِدَّةُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"قتل","display":"قَتْلِ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"حكم","display":"حَكَمَ"},{"kind":"word","token":"الوالي","display":"الْوَالِي"},{"kind":"word","token":"بقتل","display":"بِقَتْلِ"},{"kind":"word","token":"ايهم","display":"اَيِّهِمْ"},{"kind":"word","token":"شاء","display":"شَاءَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يقتل","display":"يَقْتُلَ"},{"kind":"word","token":"اكثر","display":"اَكْثَرَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"واحد","display":"وَاحِدٍ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قتل","display":"قُتِلَ"},{"ki