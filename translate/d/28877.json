َقَةَ جَمِيعاً ؛ يَقْضِي الصَّوْمَ وَ يَتَصَدَّقُ ،  مِنْ اَجْلِ اَنَّهُ ضَيَّعَ ذَلِكَ الصِّيَامَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"تصدق","display":"تَصَدَّقَ"},{"kind":"word","token":"مكان","display":"مَكَانَ"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"يوم","display":"يَوْمٍ"},{"kind":"word","token":"افطر","display":"اَفْطَرَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"مسكين","display":"مِسْكِينٍ"},{"kind":"word","token":"مدا","display":"مُدّاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"طعام","display":"طَعَامٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"حنطه","display":"حِنْطَةٌ"},{"kind":"word","token":"فمد","display":"فَمُدٌّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"تمر","display":"تَمْرٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فديه","display":"فِدْيَةٌ"},{"kind":"word","token":"طعام","display":"طَعٰامُ"},{"kind":"word","token":"مسكين","display":"مِسْكِينٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۸۴","display":"۱۸۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فان","display":"فَاِنِ"},{"kind":"word","token":"استطاع","display":"اِسْتَطَاعَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يصوم","display":"يَصُومَ"},{"kind":"word","token":"رمضان","display":"رَمَضَانَ"},{"kind":"word","token":"الذي","display":"الَّذ