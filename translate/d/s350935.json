{"consensus_set_id":"s350935","translation_language":"fa","translation_source":{"hid":"350935"},"segments":[{"source_hadith_segment":"اِنَّمَا  <quranic_text> « اِتَّخَذَ اللّٰهُ اِبْرٰاهِيمَ خَلِيلاً » </quranic_text>   <footnote> [ النساء ۱۲۵ ] </footnote>  لِاَنَّهُ لَمْ يَرُدَّ اَحَداً قَطُّ وَ لَمْ يَسْاَلْ اَحَداً غَيْرَ اللَّهِ عَزَّ وَ جَلَّ .","translation_segment":"در علل الشرایع آمده است که امام رضا علیه السلام فرمود: خداوند ابراهیم را خلیل خود نامید؛ زیرا در همه زندگی‌اش به کسی جز خداوند روی نیاورد.","segment_columns":[{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اتخذ","display":"اِتَّخَذَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"word","token":"خليلا","display":"خَلِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۵","display":"۱۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"لانه","display":"لِاَنَّهُ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يرد","display":"يَرُدَّ"},{"kind":"word","token":"احدا","display":"اَحَداً"},{"kind":"word","token":"قط","display":"قَطُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يسال","display":"يَسْاَلْ"},{"kind":"word","token":"احدا","display":"اَحَداً"},{"kind":"word","token":"غير","display":"غَيْرَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"}]}]}