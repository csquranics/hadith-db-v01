{"consensus_set_id":"s409959","translation_language":"fa","translation_source":{"hid":"409959"},"segments":[{"source_hadith_segment":"دَخَلَ قَتَادَةُ بْنُ دِعَامَةَ عَلَي اَبِي جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ ) ،  وَ سَاَلَهُ عَنْ قَوْلِهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ لَقَدْ صَدَّقَ عَلَيْهِمْ اِبْلِيسُ ظَنَّهُ فَاتَّبَعُوهُ اِلاّٰ فَرِيقاً مِنَ الْمُؤْمِنِينَ » </quranic_text>   <footnote> [ سبا ۲۰ ] </footnote>   ،  قَالَ :","translation_segment":"","segment_columns":[{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"قتاده","display":"قَتَادَةُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"دعامه","display":"دِعَامَةَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ساله","display":"سَاَلَهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"صدق","display":"صَدَّقَ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"ابليس","display":"اِبْلِيسُ"},{"kind":"word","token":"ظنه","display":"ظَنَّهُ"},{"kind":"word","token":"فاتبعوه","display":"فَاتَّبَعُوهُ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"فريقا","display":"فَرِيقاً"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"سبا","display":"سبا"},{"kind":"word","token":"۲۰","display":"۲۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« لَمَّا اَمَرَ اللَّهُ نَبِيَّهُ اَنْ يَنْصِبَ اَمِيرَ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) لِلنَّاسِ ،  وَ هُوَ قَوْلُهُ :   <quranic_text> « يٰا اَيُّهَا الرَّسُولُ بَلِّغْ مٰا اُنْزِلَ اِلَيْكَ مِنْ رَبِّكَ » </quranic_text>   <footnote> [ المائدة ۶۷ ] </footnote> فِي عَلِيٍّ  <quranic_text> « وَ اِنْ لَمْ تَفْعَلْ فَمٰا بَلَّغْتَ رِسٰالَتَهُ » </quranic_text>   <footnote> [ المائدة ۶۷ ] </footnote> اَخَذَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) بِيَدِ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) يَوْمَ غَدِيرِ خُمٍّ ،  وَ قَالَ :  مَنْ كُنْتُ مَوْلاَهُ فَعَلِيٌّ مَوْلاَهُ ،  حَثَتِ الْاَبَالِسَةُ التُّرَابَ عَلَي رُؤُوسِهَا ،  فَقَالَ لَهُمْ اِبْلِيسُ الْاَكْبَرُ :  مَا لَكُمْ ؟  قَالُوا : قَدْ عَقَدَ هَذَا الرَّجُلُ الْيَوْمَ عُقْدَةً لاَ يَحُلُّهَا اِنْسِيٌّ اِلَي يَوْمِ الْقِيَامَةِ .  فَقَالَ لَهُمْ اِبْلِيسُ :  كَلاَّ ،  اِنَّ الَّذِينَ حَوْلَهُ قَدْ وَعَدُونِي فِيهِ عِدَةً ،  وَ لَنْ يُخْلِفُونِي فِيهَا .  فَاَنْزَلَ اللَّهُ سُبْحَانَهُ هَذِهِ الْايَةَ :   <quranic_text> « وَ لَقَدْ صَدَّقَ عَلَيْهِمْ اِبْلِيسُ ظَنَّهُ فَاتَّبَعُوهُ اِلاّٰ فَرِيقاً مِنَ الْمُؤْمِنِينَ » </quranic_text>   <footnote> [ سبا ۲۰ ] </footnote> يَعْنِي شِيعَةَ اَمِيرِ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) »","translation_segment":"","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"امر","display":"اَمَرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"نبيه","display":"نَبِيَّهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ينصب","display":"يَنْصِبَ"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"للنا