{"consensus_set_id":"25035","translation_language":"fa","translation_source":{"hid":"385073"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « فَمَا اِسْتَكٰانُوا لِرَبِّهِمْ وَ مٰا يَتَضَرَّعُونَ » </quranic_text>   <footnote> [ المؤمنون ۷۶ ] </footnote>  قَالَ :  التَّضَرُّعُ :  رَفْعُ الْيَدَيْنِ [ بِالدُّعَاءِ ] .","translation_segment":"از امام صادق علیه السلام روایت شده است که در باره آیه «فما استکٰانوا لربهم‌ و مٰا یتضرعون‌» [نسبت به پروردگارشان فروتنی نکردند و به زاری در نیامدند]. فرمود: تضرع: [در اینجا] برداشتن دستها به دعاست.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"استكانوا","display":"اِسْتَكٰانُوا"},{"kind":"word","token":"لربهم","display":"لِرَبِّهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يتضرعون","display":"يَتَضَرَّعُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"kind":"word","token":"۷۶","display":"۷۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"التضرع","display":"التَّضَرُّعُ"},{"kind":"word","token":"رفع","display":"رَفْعُ"},{"kind":"word","token":"اليدين","display":"الْيَدَيْنِ"},{"kind":"word","token":"بالدعاء","display":"بِالدُّعَاءِ"}]}]}