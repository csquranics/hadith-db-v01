{"consensus_set_id":"88501","translation_language":"fa","translation_source":{"hid":"353929"},"segments":[{"source_hadith_segment":"قَوْلُهُ تَعَالَي  <quranic_text> « يٰا اَيُّهَا اَلنَّبِيُّ اِذٰا جٰاءَكَ اَلْمُؤْمِنٰاتُ يُبٰايِعْنَكَ » </quranic_text>   <footnote> [ الممتحنة 12 ] </footnote>  سَمِعْتُ رَسُولَ اَللَّهِ صَلَّي اَللَّهُ عَلَيْهِ وَ الِهِ يَدْعُو اَلنِّسَاءَ اِلَي اَلْبَيْعَةِ حِينَ نَزَلَتْ هَذِهِ اَلْايَةُ فَكَانَتْ فَاطِمَةُ بِنْتُ اَسَدٍ اُمُّ عَلِيِّ بْنِ اَبِي طَالِبٍ رَضِيَ اَللَّهُ عَنْهُمَا اَوَّلَ اِمْرَاَةٍ بَايَعَتْ .","translation_segment":"","segment_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"النبي","display":"اَلنَّبِيُّ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"جاءك","display":"جٰاءَكَ"},{"kind":"word","token":"المؤمنات","display":"اَلْمُؤْمِنٰاتُ"},{"kind":"word","token":"يبايعنك","display":"يُبٰايِعْنَكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الممتحنه","display":"الممتحنة"},{"kind":"word","token":"12","display":"12"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"سمعت","display":"سَمِعْتُ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اَللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"يدعو","display":"يَدْعُو"},{"kind":"word","token":"النساء","display":"اَلنِّسَاءَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"البيعه","display":"اَلْبَيْعَةِ"},{"kind":"word","token":"حين","di