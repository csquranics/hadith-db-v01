{"consensus_set_id":"s287470","translation_language":"fa","translation_source":{"hid":"287470"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ هَذِهِ الْايَةِ :   <quranic_text> « وَ لاٰ تُؤْتُوا السُّفَهٰاءَ اَمْوٰالَكُمُ » </quranic_text>   <footnote> [ النساء ۵ ] </footnote>  قَالَ عَلَيْهِ السَّلاَمُ كُلُّ مَنْ يَشْرَبُ الْمُسْكِرَ فَهُوَ سَفِيهٌ .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تؤتوا","display":"تُؤْتُوا"},{"kind":"word","token":"السفهاء","display":"السُّفَهٰاءَ"},{"kind":"word","token":"اموالكم","display":"اَمْوٰالَكُمُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۵","display":"۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يشرب","display":"يَشْرَبُ"},{"kind":"word","token":"المسكر","display":"الْمُسْكِرَ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"سفيه","display":"سَفِيهٌ"}]}]}