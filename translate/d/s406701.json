{"consensus_set_id":"s406701","translation_language":"fa","translation_source":{"hid":"406701"},"segments":[{"source_hadith_segment":"« اِنَّ اِبْرَاهِيمَ ( عَلَيْهِ السَّلاَمُ ) جَادَلَ فِي قَوْمِ لُوطٍ ،  وَ قَالَ :   <quranic_text> « اِنَّ فِيهٰا لُوطاً قٰالُوا نَحْنُ اَعْلَمُ بِمَنْ فِيهٰا » </quranic_text>   <footnote> [ العنكبوت ۳۲ ] </footnote> فَزَادَهُ اِبْرَاهِيمُ ،  فَقَالَ جَبْرَئِيلُ :   <quranic_text> « يٰا اِبْرٰاهِيمُ اَعْرِضْ عَنْ هٰذٰا اِنَّهُ قَدْ جٰاءَ اَمْرُ رَبِّكَ وَ اِنَّهُمْ اتِيهِمْ عَذٰابٌ غَيْرُ مَرْدُودٍ » </quranic_text>   <footnote> [ هود ۷۶ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"جادل","display":"جَادَلَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوم","display":"قَوْمِ"},{"kind":"word","token":"لوط","display":"لُوطٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"لوطا","display":"لُوطاً"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"اعلم","display":"اَعْلَمُ"},{"kind":"word","token":"بمن","display":"بِمَنْ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العنكبوت","display":"العنكبوت"},{"kind":"word","token":"۳۲","display":"۳۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فزاده","display":"فَزَادَهُ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","tok