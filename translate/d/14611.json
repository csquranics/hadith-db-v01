quranic_text> « كَاَنَّهٰا كَوْكَبٌ دُرِّيٌّ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  وَ هُوَ عَلِيُّ بْنُ الْحُسَيْنِ ( عَلَيْهِ السَّلاَمُ ) ،   <quranic_text> « يُوقَدُ مِنْ شَجَرَةٍ مُبٰارَكَةٍ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  مُحَمَّدُ بْنُ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) ،   <quranic_text> « زَيْتُونَةٍ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  جَعْفَرُ بْنُ مُحَمَّدٍ ( عَلَيْهِ السَّلاَمُ )  <quranic_text> « لاٰ شَرْقِيَّةٍ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  مُوسَي بْنِ جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ ) ،   <quranic_text> « وَ لاٰ غَرْبِيَّةٍ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  عَلِيُّ بْنُ مُوسَي ( عَلَيْهِ السَّلاَمُ ) ،   <quranic_text> « يَكٰادُ زَيْتُهٰا يُضِيءُ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  مُحَمَّدُ بْنُ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) ،   <quranic_text> « وَ لَوْ لَمْ تَمْسَسْهُ نٰارٌ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  عَلِيُّ بْنُ مُحَمَّدٍ ( عَلَيْهِ السَّلاَمُ ) ،   <quranic_text> « نُورٌ عَليٰ نُورٍ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  الْحَسَنُ اِبْنُ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) ،   <quranic_text> « يَهْدِي اللّٰهُ لِنُورِهِ مَنْ يَشٰاءُ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>  الْقَائِمُ الْمَهْدِيُّ ( عَلَيْهِ السَّلاَمُ )  <quranic_text> « وَ يَضْرِبُ اللّٰهُ الْاَمْثٰالَ لِلنّٰاسِ وَ اللّٰهُ بِكُلِّ شَيْءٍ عَلِيمٌ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"نور","display":"نُورُ"},{"kind":"word","token":"السماوات","display":"السَّمٰ