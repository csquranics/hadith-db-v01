{"consensus_set_id":"s241202","translation_language":"fa","translation_source":{"hid":"241202"},"segments":[{"source_hadith_segment":"<quranic_text> « اِنَّ الَّذِينَ قٰالُوا رَبُّنَا اللّٰهُ ثُمَّ اِسْتَقٰامُوا فَلاٰ خَوْفٌ عَلَيْهِمْ وَ لاٰ هُمْ يَحْزَنُونَ » </quranic_text>   <footnote> [ الاحقاف ۱۳ ] </footnote>  قَالَ اِسْتَقَامُوا عَلَي وَلاَيَةِ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ  .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"ربنا","display":"رَبُّنَا"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"استقاموا","display":"اِسْتَقٰامُوا"},{"kind":"word","token":"فلا","display":"فَلاٰ"},{"kind":"word","token":"خوف","display":"خَوْفٌ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يحزنون","display":"يَحْزَنُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحقاف","display":"الاحقاف"},{"kind":"word","token":"۱۳","display":"۱۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"استقاموا","display":"اِسْتَقَامُوا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ولايه","display":"وَلاَيَةِ"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}