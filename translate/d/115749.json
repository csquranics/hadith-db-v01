{"consensus_set_id":"115749","translation_language":"fa","translation_source":{"hid":"331673"},"segments":[{"source_hadith_segment":"[ عَلَيْهِ اَلسَّلاَمُ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « اَ فَمَنْ كٰانَ عَليٰ بَيِّنَةٍ مِنْ رَبِّهِ » </quranic_text>   <footnote> [ هود ۱۷ ] </footnote>","translation_segment":"عن عباد بن عبد الله، عن علی‌ ع فی قوله تعالی: (أفمن کان علی بینه من ربه) قال: هو رسول","segment_columns":[{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"اَلسَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"بينه","display":"بَيِّنَةٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"هود","display":"هود"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ :  هُوَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ","translation_segment":"الله صلی الله علیه و آله و سلم: (و یتلوه شاهد منه) قال: و أنا الشاهد منه. عباد بن عبد الله درباره سخن خداوند:","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"}]},{"source_hadith_segm