{"consensus_set_id":"s331995","translation_language":"fa","translation_source":{"hid":"331995"},"segments":[{"source_hadith_segment":"فِي بَيْتِي اُنْزِلَتْ  <quranic_text> « اِنَّمٰا يُرِيدُ اللّٰهُ - لِيُذْهِبَ عَنْكُمُ الرِّجْسَ اَهْلَ الْبَيْتِ  » </quranic_text>   <footnote> [ الاحزاب ۳۳ ] </footnote>  قَالَتْ :  فَاَرْسَلَ رَسُولُ اللَّهِ اِلَي فَاطِمَةَ وَ عَلِيٍّ وَ الْحَسَنِ وَ الْحُسَيْنِ وَ قَالَ :  هَؤُلاَءِ اَهْلِي .  قَالَتْ :  فَقُلْتُ يَا رَسُولَ اللَّهِ اَ مَا اَنَا مِنْ اَهْلِ الْبَيْتِ قَالَ :  بَلَي اِنْ شَاءَ اللَّهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"بيتي","display":"بَيْتِي"},{"kind":"word","token":"انزلت","display":"اُنْزِلَتْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"يريد","display":"يُرِيدُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ليذهب","display":"لِيُذْهِبَ"},{"kind":"word","token":"عنكم","display":"عَنْكُمُ"},{"kind":"word","token":"الرجس","display":"الرِّجْسَ"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحزاب","display":"الاحزاب"},{"kind":"word","token":"۳۳","display":"۳۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قالت","display":"قَالَتْ"},{"kind":"word","token":"فارسل","display":"فَاَرْسَلَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token"