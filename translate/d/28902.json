{"consensus_set_id":"28902","translation_language":"fa","translation_source":{"hid":"89115"},"segments":[{"source_hadith_segment":"فِي رَجُلٍ كَانَ عَلَيْهِ صَوْمُ  <quranic_text> « شَهْرَيْنِ مُتَتٰابِعَيْنِ » </quranic_text>   <footnote> [ المجادلة ۴ ] </footnote>  فِي ظِهَارٍ فَصَامَ ذَا الْقَعْدَةِ وَ دَخَلَ عَلَيْهِ ذُو الْحِجَّةِ","translation_segment":"* *۹۵ - از ابو عبد الله صادق (ع) پرسیدند: در کفاره ظهار که باید دو ماه پی‌درپی روزه بگیرند، اگر کسی ماه ذی قعده را روزه بگیرد، تکلیف او با ماه ذیحجه چه خواهد بود؟ ابو عبد الله گفت: تمام ماه ذیحجه را روزه می‌گیرد به","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"صوم","display":"صَوْمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"شهرين","display":"شَهْرَيْنِ"},{"kind":"word","token":"متتابعين","display":"مُتَتٰابِعَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المجادله","display":"المجادلة"},{"kind":"word","token":"۴","display":"۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ظهار","display":"ظِهَارٍ"},{"kind":"word","token":"فصام","display":"فَصَامَ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"القعده","display":"الْقَعْدَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"الحجه","display":"الْحِجَّةِ"}]},{"source_hadith_segment":"- كَيْفَ يَصْنَعُ قَالَ « يَصُومُ ذَا الْحِجَّةِ كُلَّهُ اِلاَّ اَيَّامَ التَّشْرِيقِ ثُمَّ يَقْضِيهَا فِي اَوَّلِ يَوْمٍ مِنَ الْمُحَرَّمِ حَتَّي يُتِمَّ ثَلاَثَةَ اَيَّامٍ فَيَكُونَ قَدْ صَامَ شَهْرَيْنِ مُتَتَابِعَيْنِ »","translation_segment":"استثنای سه روز عید قربان، سپس از اول ماه محرم تا سه روز بعد قضای آن را خواهد گرفت تا تمام شصت روز روزه پی‌درپی را تمام کرده باشد. ابو عبد الله گفت: ولی نمی‌تواند با همسر خود به بستر برود مگر بعد از سه روز روزه ایام عید قربان که","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"يصنع","display":"يَصْنَعُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يصوم","display":"يَصُومُ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"الحجه","display":"الْحِجَّةِ"},{"kind":"word","token":"كله","display":"كُلَّهُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"ايام","display":"اَيَّامَ"},{"kind":"word","token":"التشريق","display":"التَّشْرِيقِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يقضيها","display":"يَقْضِيهَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اول","display":"اَوَّلِ"},{"kind":"word","token":"يوم","display":"يَوْمٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المحرم","display":"الْمُحَرَّمِ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"يتم","display":"يُتِمَّ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةَ"},{"kind":"word","token":"ايام","display":"اَيَّامٍ"},{"kind":"word","token":"فيكون","display":"فَيَكُونَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"صام","display":"صَامَ"},{"kind":"word","token":"شهرين","display":"شَهْرَيْنِ"},{"kind":"word","token":"متتابعين","display":"مُتَتَابِعَيْنِ"}]},{"source_hadith_segment":"ثُمَّ قَالَ « وَ لاَ يَنْبَغِي لَهُ اَنْ يَقْرَبَ اَهْلَهُ حَتَّي يَقْضِيَ الثَّلاَثَةَ الْاَيَّامِ التَّشْرِيقِ الَّتِي لَمْ يَصُمْهَا وَ لاَ بَاْسَ اِنْ صَامَ شَهْراً ثُمَّ صَامَ مِنَ الشَّهْرِ الَّذِي يَلِيهِ اَيَّاماً ثُمَّ عَرَضَتْ لَهُ عِلَّةٌ اَنْ يَقْطَعَهُ ثُمَّ يَقْضِيَ بَعْدُ تَمَامَ الشَّهْر