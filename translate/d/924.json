":"وَ يَجِبُ اَنْ تَكُونَ فِي هَذِهِ السُّورَةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ عَزَّ وَ جَلَّ  <quranic_text> « اِنْ يَمْسَسْكُمْ قَرْحٌ فَقَدْ مَسَّ الْقَوْمَ قَرْحٌ مِثْلُهُ - وَ تِلْكَ الْاَيّٰامُ نُدٰاوِلُهٰا بَيْنَ النّٰاسِ - وَ لِيَعْلَمَ اللّٰهُ الَّذِينَ امَنُوا وَ يَتَّخِذَ مِنْكُمْ شُهَدٰاءَ » </quranic_text>   <footnote> [ العمران ۱۴۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَخَرَجُوا عَلَي مَا بِهِمْ مِنَ الْاَلَمِ وَ الْجِرَاحِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَلَمَّا بَلَغَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ بِحَمْرَاءِ الْاَسَدِ وَ قُرَيْشٌ قَدْ نَزَلَتِ الرَّوْحَاءَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ عِكْرِمَةُ بْنُ اَبِي جَهْلٍ وَ الْحَارِثُ بْنُ هِشَامٍ وَ عَمْرُو بْنُ عَاصٍ وَ خَالِدُ بْنُ الْوَلِيدِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"نَرْجِعُ فَنُغِيرُ عَلَي الْمَدِينَةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَقَدْ قَتَلْنَا سَرَاتَهُمْ وَ كَبْشَهُمْ يَعْنِي حَمْزَةَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَوَافَاهُمْ رَجُلٌ خَرَجَ مِنَ الْمَدِينَةِ فَسَاَلُوهُ الْخَبَرَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ تَرَكْتُ مُحَمَّداً وَ اَصْحَابَهُ بِحَمْرَاءِ الْاَسَدِ يَطْلُبُونَكُمْ جِدَّ الطَّلَبِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَقَالَ اَبُو سُفْيَانَ هَذَا النَّكَدُ وَ الْبَغْيُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  قَدْ ظَفِرْنَا بِالْقَوْمِ وَ بَغَيْنَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اللَّهِ مَا اَفْلَحَ قَوْمٌ قَطُّ بَغَوْا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَوَافَاهُمْ نُعَيْمُ بْنُ مَسْعُودٍ الْاَشْجَعِيُّ","translation_