:"،  وَ قَدْ كُنْتَ تَعِدُنَا بِالنَّصْرِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاَنْزَلَ اللَّهُ  <quranic_text> « اَ وَ لَمّٰا اَصٰابَتْكُمْ مُصِيبَةٌ - قَدْ اَصَبْتُمْ مِثْلَيْهٰا قُلْتُمْ اَنّٰي هٰذٰا - قُلْ هُوَ مِنْ عِنْدِ اَنْفُسِكُمْ » </quranic_text>   <footnote> [ العمران ۱۶۵ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"بِمَا اِشْتَرَطْتُمْ يَوْمَ بَدْرٍ .","translation_segment":"","segment_columns":[]}]}