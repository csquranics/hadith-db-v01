 <quranic_text> « رَجُلاً مَسْحُوراً » </quranic_text>   <footnote> [ الفرقان ۸ ] </footnote>  ثُمَّ اِنْزِلْ عَلَيْهِ يَا مُحَمَّدُ :   <quranic_text> « قُلْ اِنَّمٰا اَنَا بَشَرٌ » </quranic_text>   <footnote> [ الكهف ۱۱۰ ] </footnote>  يَعْنِي اكُلُ الطَّعَامَ  <quranic_text> « مِثْلُكُمْ يُوحيٰ اِلَيَّ اَنَّمٰا اِلٰهُكُمْ اِلٰهٌ وٰاحِدٌ » </quranic_text>   <footnote> [ الكهف ۱۱۰ ] </footnote>  يَعْنِي قُلْ لَهُمْ اَنَا فِي الْبَشَرِيَّةِ مِثْلُكُمْ ،  وَ لَكِنْ رَبِّي خَصَّنِي بِالنُّبُوَّةِ دُونَكُمْ ،  كَمَا يَخُصُّ بَعْضَ الْبَشَرِ بِالْغِنَي وَ الصِّحَّةِ وَ الْجَمَالِ دُونَ بَعْضٍ مِنَ الْبَشَرِ ،  فَلاَ تُنْكِرُوا اَنْ يَخُصَّنِي اَيْضاً بِالنُّبُوَّةِ ،  و الحديث طويل اخذنا منه موضع الحاجة .","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"السامع","display":"السَّامِعُ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"صوت","display":"صَوْتٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"العالم","display":"الْعَالِمُ"},{"kind":"word","token":"بكل","display":"بِكُلِّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"تعلم","display":"تَعْلَمُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"قاله","display":"قَالَهُ"},{"kind":"word","token":"عبادك","display":"عِبَادُكَ"},{"kind":"word","token":"فانزل","display":"فَاَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"يا","d