{"consensus_set_id":"50105","translation_language":"fa","translation_source":{"hid":"311214"},"segments":[{"source_hadith_segment":"قُلْتُ لِلصَّادِقِ عَلَيْهِ السَّلاَمُ مَا مَعْنَي قَوْلِهِ تَبَارَكَ وَ تَعَالَي -  <quranic_text> « مَنْ ذَا الَّذِي يُقْرِضُ اللّٰهَ قَرْضاً حَسَناً فَيُضٰاعِفَهُ لَهُ اَضْعٰافاً كَثِيرَةً » </quranic_text>   <footnote> [ البقرة ۲۴۵ ] </footnote>  قَالَ صِلَةُ الْاِمَامِ .","translation_segment":"اسحاق بن عمار گوید: از امام صادق علیه السلام پرسیدم چیست معنی آیه شریفه «من‌ ذا الذی یقرض‌ اللٰه‌ قرضا حسنا» (کیست آنکه بخدا قرض الحسن دهد) فرمود: مراد نیکی و احسان کردن بامام است.","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"للصادق","display":"لِلصَّادِقِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"معني","display":"مَعْنَي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يقرض","display":"يُقْرِضُ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"قرضا","display":"قَرْضاً"},{"kind":"word","token":"حسنا","display":"حَسَناً"},{"kind":"word","token":"فيضاعفه","display":"فَيُضٰاعِفَهُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"اضعافا","display":"اَضْعٰافاً"},{"kind":"word","token":"كثيره","display":"كَثِيرَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","t