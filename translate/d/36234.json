d":"word","token":"الدين","display":"الدِّينِ"},{"kind":"word","token":"بل","display":"بَلْ"},{"kind":"word","token":"دينهم","display":"دِينُهُمْ"},{"kind":"word","token":"باطل","display":"بَاطِلٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كفر","display":"كُفْرٌ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يتلون","display":"يَتْلُونَ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره۱۱۳","display":"البقرة۱۱۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"التوراه","display":"التَّوْرَاةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قالت","display":"قٰالَتِ"},{"kind":"word","token":"النصاري","display":"النَّصٰاريٰ"},{"kind":"word","token":"ليست","display":"لَيْسَتِ"},{"kind":"word","token":"اليهود","display":"الْيَهُودُ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۱۳","display":"۱۱۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الدين","display":"الدِّينِ"},{"kind":"word","token":"بل","display":"بَلْ"},{"kind":"word","token":"دينهم","display":"دِينُهُمْ"},{"kind":"word","token":"باطل","display":"بَاطِلٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كفر","display":"كُفْرٌ"},{"kind":"word","token":"لان","display":"لان"},{"kind":"word","token":"كلا","display":"كلاًّ"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"الفريقين","display":"الفريقين"},{"kind":"word","token":"مقلد","display":"مقلّد"},{"kind":"word","token":"بلا","display":"بلا"},{"kind":"word","token":"حجه","display":"حجّة"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يتلون","display":"يَتْلُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۱۳","display":"۱۱۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اليهود","display":"الْيَهُودُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يتلون","display":"يَتْلُونَ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۱۳","display":"۱۱۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"التوراه","display":"التَّوْرَاةَ"},{"kind":"word","token":"-","display":"-"}]},{"source_hadith_segment":".  فَقَالَ :  « هَؤُلاَءِ وَ هَؤُلاَءِ مُقَلِّدُونَ بِلاَ حُجَّةٍ ،  وَ هُمْ يَتْلُونَ الْكِتَابَ فَلاَ يَتَاَمَّلُونَهُ ،  لِيَعْمَلُوا بِمَا يُوجِبُهُ فَيَتَخَلَّصُوا مِنَ الضَّلاَلَةِ ،  ثُمَّ قَالَ :   <quranic_text> « كَذٰلِكَ قٰالَ الَّذِينَ لاٰ يَعْلَمُونَ » </quranic_text>   <footnote> [ البقرة ۱۱۳ ] </footnote>  الْحَقَّ ،  وَ لَمْ يَنْظُرُوا فِيهِ مِنْ حَيْثُ اَمَرَهُمُ اللَّهُ ،  فَقَالَ بَعْضُهُمْ لِبَعْضٍ وَ هُمْ مُخْتَلِفُونَ ،  كَقَوْلِ الْيَهُودِ وَ النَّصَارَي بَعْضُهُمْ لِبَعْضٍ ،  هَؤُلاَءِ يُكَفِّرُ هَؤُلاَءِ ،  وَ هَؤُلاَءِ يُكَفِّرُ هَؤُلاَءِ .  ثُمَّ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « فَاللّٰهُ يَحْكُمُ بَيْنَهُمْ يَوْمَ الْقِيٰامَةِ فِيمٰا كٰانُوا فِيهِ يَخْتَلِفُونَ » </quranic_text>   <footnote> [ البقرة ۱۱۳ ] </footnote>  فِي الدُّنْيَا يُبَيِّنُ ضَلاَلَتَهُمْ وَ فِسْقَهُمْ ،  وَ يُجَازِي كُلَّ وَاحِدٍ مِنْهُمْ بِقَدْرِ اِسْتِحْقَاقِهِ .  وَ قَالَ الْحَسَنُ بْنُ عَلِيِّ بْنِ اَبِي طَالِبٍ ( عَلَيْهِمَا السَّلاَمُ ) :  اِنَّمَا اُنْزِلَتِ الْايَةُ لِاَنَّ قَوْماً مِنَ الْيَهُودِ ،  وَ قَوْماً مِنَ النَّصَارَي جَاءُوا اِلَي رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  فَقَالُوا :  يَا مُحَمَّدُ ،  اِقْضِ بَيْنَنَا .  فَقَالَ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :  قُصُّوا عَلَيَّ قِصَّتَكُمْ .  فَقَالَتِ الْيَهُودُ :  نَحْنُ الْمُؤْمِنُونَ بِالْاِلَهِ الْوَاحِدِ الْحَكِيمِ وَ اَوْلِيَائِهِ ،  وَ لَيْسَتِ النَّصَارَي عَلَي شَيْءٍ مِنَ الدِّينِ وَ الْحَقِّ .  وَ قَالَتِ النَّصَارَي :  بَلْ نَحْنُ الْمُؤْمِنُونَ بِالْاِلَهِ الْوَاحِدِ الْحَكِيمِ وَ اَوْلِيَائِهِ ،  وَ لَيْسَتِ الْيَهُودُ عَلَي شَيْءٍ مِنَ الدِّينِ وَ الْحَقِّ .  فَقَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :  كُلُّكُمْ مُخْطِئُونَ مُبْطِلُونَ ،  فَاسِقُونَ عَنْ دِينِ اللَّهِ وَ اَمْرِهِ .  فَقَالَتِ الْيَهُودُ :  كَيْفَ نَكُونُ كَافِرِينَ وَ فِينَا كِتَابُ اللَّهِ التَّوْرَاةُ نَقْرَؤُهُ ؟  وَ قَالَتِ النَّصَارَي :  كَيْفَ نَكُونُ كَافِرِينَ وَ لَنَا كِتَابُ اللَّهِ الْاِنْجِيلُ نَقْرَؤُهُ ؟  فَقَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :  اِنَّكُمْ خَالَفْتُمْ - اَيُّهَا الْيَهُودُ وَ النَّصَارَي - كِتَابَ اللَّهِ وَ لَمْ تَعْمَلُوا بِهِ ،  فَلَوْ كُنْتُمْ عَامِلِينَ بِالْكِتَابَيْنِ لَمَا كَفَّرَ بَعْضُكُمْ بَعْضاً بِغَيْرِ حُجَّةٍ ،  لِاَنَّ كُتُبَ اللَّهِ اَنْزَلَهَا شِفَاءً مِنَ الْعَمَي ،  وَ بَيَاناً مِنَ الضَّلاَلَةِ ،  يَهْدِي الْعَامِلِينَ بِهَا اِلَي صِرَاطٍ مُسْتَقِيمٍ ،  وَ كِتَابُ اللَّهِ اِذَا لَمْ تَعْمَلُوا بِهِ كَانَ وَبَالاً عَلَيْكُمْ ،  وَ حُجَّةُ اللَّهِ اِذَا لَمْ تَنْقَادُوا لَهَا كُنْتُمْ لِلَّهِ عَاصِينَ ،  وَ لِسَخَطِهِ مُتَعَرِّضِينَ .  ثُمَّ اَقْبَلَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) عَلَي الْيَهُودِ ،  فَقَالَ :  اِحْذَرُوا اَنْ يَنَالَكُمْ بِخِلاَفِ اَمْرِ اللَّهِ وَ بِخِلاَفِ كِتَابِهِ مَا اَصَابَ اَوَائِلَكُمُ الَّذِينَ قَالَ اللَّهُ فِيهِمْ :   <quranic_text> « فَبَدَّلَ الَّذِينَ ظَلَمُوا قَوْلاً غَيْرَ الَّذِي قِيلَ لَهُمْ » </quranic_text>   <footnote> [ البقرة ۵۹ ] </footnote>  وَ اُمِرُوا بِاَنْ يَقُولُوهُ .  قَالَ اللَّهُ تَعَالَي :   <quranic_text> « فَاَنْزَلْنٰا عَلَي الَّذِينَ ظَلَمُوا رِجْزاً مِنَ السَّمٰاءِ » </quranic_text>   <footnote> [ البقرة ۵۹ ] </footnote>  عَذَاباً مِنَ السَّمَاءِ ،  طَاعُوناً نَزَلَ بِهِمْ فَمَاتَ مِنْهُمْ مِائَةٌ وَ عِشْرُونَ اَلْفاً ،  ثُمَّ اَخَذَهُمْ بَعْدَ ذَلِكَ فَمَاتَ مِنْهُمْ مِائَةٌ وَ عِشْرُونَ اَلْفاً اَيْضاً ،  وَ كَانَ خِلاَفُهُمْ اَنَّهُمْ لَمَّا بَلَغُوا الْبَابَ رَاَوْا بَاباً مُرْتَفِعاً ،  فَقَالُوا :  مَا بَالُنَا نَحْتَاجُ اِلَي اَنْ نَرْكَعَ عِنْدَ الدُّخُولِ هَاهُنَا ،  ظَنَنَّا اَنَّهُ بَابٌ مُنْحَطٌّ لاَ بُدَّ مِنَ الرُّكُوعِ فِيهِ ،  وَ هَذَا بَابٌ مُرْتَفَعٌ ،  اِلَي مَتَي يَسْخَرُ بِنَا هَؤُلاَءِ ؟  - يَعْنُونَ مُوسَي وَ يُوشَعَ بْنَ نُونٍ - وَ يُسْجِدُونَنَا فِي الْاَبَاطِيلِ ،  وَ جَعَلُوا اَسْتَاهَهُمْ نَحْوَ الْبَابِ ،  وَ قَالُوا بَدَلَ قَوْلِهِمْ :  حِطَّةٌ ،  الَّذِي اُمِرُوا بِهِ :  هطا سمقانا - يَعْنُونَ حِنْطَةً حَمْرَاءَ - فَذَلِكَ تَبْدِيلُهُمْ .  وَ قَالَ اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) :  فَهَؤُلاَءِ بَنُو اِسْرَائِيلَ نُصِبَ لَهُمْ بَابُ حِطَّةٍ ،  وَ اَنْتُمْ - يَا مَعْشَرَ اُمَّةِ مُحَمَّدٍ - نُصِبَ لَكُمْ بَابُ حِطَّةٍ اَهْلُ بَيْتِ مُحَمَّدٍ ( عَلَيْهِ وَ عَلَيْهِمُ السَّلاَمُ ) ،  وَ اُمِرْتُمْ بِاتِّبَاعِ هُدَاهُمْ وَ لُزُومِ طَرِيقَتِهِمْ ،  لِيَغْفِرَ لَكُمْ بِذَلِكَ خَطَايَاكُمْ وَ ذُنُوبَكُمْ ،  وَ لِيَزْدَادَ الْمُحْسِنُونَ مِنْكُمْ ،  وَ بَابُ حِطَّتِكُمْ اَفْضَلُ مِنْ بَابِ حِطَّتِهِمْ ،  لِاَنَّ ذَلِكَ كَانَ بَابَ خَشَبٍ ،  وَ نَحْنُ النَّاطِقُونَ الصَّادِقُونَ الْمُؤْمِنُونَ الْهَادُونَ الْفَاضِلُونَ ،  كَمَا قَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :  اِنَّ النُّجُومَ فِي السَّمَاءِ اَمَانٌ مِنَ الْغَرَقِ ،  وَ اِنَّ اَهْلَ بَيْتِي اَمَانٌ لِاُمَّتِي مِنَ الضَّلاَلَةِ فِي اَدْيَانِهِمْ ،  لاَ يَهْلِكُونَ فِيهَا مَا دَامَ فِيهِمْ مَنْ يَتَّبِعُونَ هُدَاهُ وَ سُنَّتَهُ .  اَمَا اِنَّ رَسُولَ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) قَدْ قَالَ :  مَنْ اَرَادَ اَنْ يَحْيَا حَيَاتِي ،  وَ اَنْ يَمُوتَ مَمَاتِي ،  وَ اَنْ يَسْكُنَ جَنَّةَ عَدْنٍ الَّتِي وَعَدَنِي رَبِّي ،  وَ اَنْ يُمْسِكَ قَضِيباً غَرَسَهُ بِيَدِهِ ،  وَ قَالَ لَهُ :  كُنْ فَكَانَ ،  فَلْيَتَوَلَّ عَلِيَّ بْنَ اَبِي طَالِبٍ ،  وَ لْيُوَالِ وَلِيَّهُ ،  وَ لْيُعَادِ عَدُوَّهُ ،  وَ لْيَتَوَلَّ ذُرِّيَّتَهُ الْفَاضِلِينَ الْمُطِيعِينَ لِلَّهِ مِنْ بَعْدِهِ ،  فَاِنَّهُمْ خُلِقُوا مِنْ طِينَتِي ،  فَرُزِقُوا فَهْمِي وَ عِلْمِي ،  فَوَيْلٌ لِلْمُكَذِّبِينَ بِفَضْلِهِمْ مِنْ اُمَّتِي الْقَاطِعِينَ فِيهِمْ صِلَتِي ،  لاَ اَنَالَهُمُ اللَّهُ شَفَاعَتِي »","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"هؤلاء","display":"هَؤُلاَءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هؤلاء","display":"هَؤُلاَءِ"},{"kind":"word","token":"مقلدون","display":"مُقَلِّدُونَ"},{"kind":"word","token":"بلا","display":"بِلاَ"},{"kind":"word","token":"حجه","display":"حُجَّةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يتلون","display":"يَتْلُونَ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابَ"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"يتاملونه","display":"يَتَاَمَّلُونَهُ"},{"kind":"word","token":"ليعملوا","display":"لِيَعْمَلُوا"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"يوجبه","display":"يُوجِبُهُ"},{"kind":"word","token":"فيتخلصوا","display":"فَيَتَخَلَّصُوا"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الضلاله","display":"الضَّلاَلَةِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كذلك","display":"كَذٰلِكَ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يعلمون","display":"يَعْلَمُونَ"},{"kind":"tag_close","tag_name":"quranic_