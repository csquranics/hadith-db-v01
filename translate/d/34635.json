{"consensus_set_id":"34635","translation_language":"fa","translation_source":{"hid":"290598"},"segments":[{"source_hadith_segment":"سُئِلَ اَبُو الْحَسَنِ مُوسَي عَلَيْهِ السَّلاَمُ عَنْ مَعْنَي قَوْلِ اللَّهِ تَعَالَي -  <quranic_text> « الرَّحْمٰنُ عَلَي الْعَرْشِ اِسْتَويٰ » </quranic_text>   <footnote> [ طه ۵ ] </footnote>  فَقَالَ اِسْتَوْلَي عَلَي مَا دَقَّ وَ جَلَّ .","translation_segment":"و از حسن بن راشد منقول و مرویست که شخصی از حضرت امام البرایا أبو الحسن موسی علیه التحیه و الثناء از معنی: الرحمٰن‌ علی العرش‌ استویٰ‌ سوال نمود. آن حضرت فرمود که: معنای آن عبارت از استیلای قدرت واحد منان است بر آنچه از روی قدرت و اجلال ایجاد آن نمود.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"معني","display":"مَعْنَي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"استوي","display":"اِسْتَويٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"طه","display":"طه"},{"kind":"word","token":"۵","display":"۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"استولي","display":"اِسْتَوْلَي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ما","display":"مَا"},{"kind