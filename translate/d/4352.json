{"consensus_set_id":"4352","translation_language":"fa","translation_source":{"hid":"110080"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا اَنْفِقُوا مِنْ طَيِّبٰاتِ مٰا كَسَبْتُمْ وَ مِمّٰا اَخْرَجْنٰا لَكُمْ مِنَ الْاَرْضِ وَ لاٰ تَيَمَّمُوا الْخَبِيثَ مِنْهُ تُنْفِقُونَ » </quranic_text>   <footnote> [ البقرة ۲۶۷ ] </footnote>","translation_segment":"ابو بصیر گوید: امام صادق علیه السلام در مورد گفتار خداوند عز و جل که می‌فرماید: «ای کسانی که ایمان آوردند! از بخش‌های پاکیزه اموالی که به دست","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"كان","display":"كان"},{"kind":"word","token":"القوم","display":"القوم"},{"kind":"word","token":"قد","display":"قد"},{"kind":"word","token":"كسبوا","display":"كسبوا"},{"kind":"word","token":"مكاسب","display":"مكاسب"},{"kind":"word","token":"سوء","display":"سوء"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الجاهليه","display":"الجاهلية"},{"kind":"word","token":"فلما","display":"فلما"},{"kind":"word","token":"اسلموا","display":"أسلموا"},{"kind":"word","token":"ارادوا","display":"أرادوا"},{"kind":"word","token":"ان","display":"أن"},{"kind":"word","token":"يخرجوها","display":"يخرجوها"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"اموالهم","display":"أموالهم"},{"kind":"word","token":"ليتصدقوا","display":"ليتصدقوا"},{"kind":"word","token":"بها","display":"بها"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display