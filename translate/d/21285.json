{"consensus_set_id":"21285","translation_language":"fa","translation_source":{"hid":"405205"},"segments":[{"source_hadith_segment":"« لَمَّا نَزَلَتْ  <quranic_text> « فَلاٰ تَقْعُدْ بَعْدَ الذِّكْريٰ مَعَ الْقَوْمِ الظّٰالِمِينَ » </quranic_text>   <footnote> [ الانعام ۶۸ ] </footnote> قَالَ الْمُسْلِمُونَ :  كَيْفَ نَصْنَعُ ؟  اِنْ كَانَ كُلَّمَا اِسْتَهَزَاَ الْمُشْرِكُونَ بِالْقُرْانِ قُمْنَا وَ تَرَكْنَاهُمْ ،  فَلاَ نَدْخُلُ اِذَنْ الْمَسْجِدَ الْحَرَامَ ،  وَ لاَ نَطُوفُ بِالْبَيْتِ الْحَرَامِ !  فَاَنْزَلَ اللَّهُ تَعَالَي  <quranic_text> « وَ مٰا عَلَي الَّذِينَ يَتَّقُونَ مِنْ حِسٰابِهِمْ مِنْ شَيْءٍ » </quranic_text>   <footnote> [ الانعام ۶۹ ] </footnote> اَمَرَهُمْ بِتَذْكِيرِهِمْ [ وَ تَبْصِيرِهِمْ ] مَا اِسْتَطَاعُوا »","translation_segment":"","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلا","display":"فَلاٰ"},{"kind":"word","token":"تقعد","display":"تَقْعُدْ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الذكري","display":"الذِّكْريٰ"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"القوم","display":"الْقَوْمِ"},{"kind":"word","token":"الظالمين","display":"الظّٰالِمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۶۸","display":"۶۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"المسلمون","display":"الْمُسْلِمُونَ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"نصنع","display":"نَصْنَعُ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"كلما","display":"كُلَّمَا"},{"kind":"word","token":"استهزا","display":"اِسْتَهَزَاَ"},{"kind":"word","token":"المشركون","display":"الْمُشْر