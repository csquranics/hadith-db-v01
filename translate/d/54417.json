{"consensus_set_id":"54417","translation_language":"fa","translation_source":{"hid":"103624"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنْ رَجُلٍ تَرَكَ اِخْوَةً وَ اَخَوَاتٍ مِنْ اَبٍ وَ اُمٍّ وَ جَدّاً قَالَ « اَلْجَدُّ كَوَاحِدٍ مِنَ الْاِخْوَةِ الْمَالُ بَيْنَهُمْ  <quranic_text> « لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>   .","translation_segment":"و ابن محبوب، از عبد اللٰه بن سنان، روایت کرده است که گفت: از امام صادق علیه السلام در باره مردی سوال کردم که برادران و خواهرانی ابوینی و جدی از خود بجای گذاشته است، امام فرمود: جد مانند یکی از برادرانست، و مال بقاعده «للذکر مثل‌ حظ‍‌ الأنثیین‌» میان ایشان قسمت می‌شود.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"ترك","display":"تَرَكَ"},{"kind":"word","token":"اخوه","display":"اِخْوَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اخوات","display":"اَخَوَاتٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اب","display":"اَبٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ام","display":"اُمٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جدا","display":"جَدّاً"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الجد","display":"اَلْجَدُّ"},{"kind":"word","token":"كواحد","display":"كَوَاحِدٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الاخوه","display":"الْاِخْوَةِ"},{"kind":"word","token":"المال","display":"الْمَالُ"},{"kind":"word","token":"بينهم","display":"بَيْنَهُمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"للذكر","display":"لِلذَّكَرِ"},{"kind":"word","token":"مثل","display":"مِثْلُ"},{"kind":"word","token":"حظ","display":"حَظِّ"},{"kind":"word","token":"الانثيين","display":"الْاُنْثَيَيْنِ"}