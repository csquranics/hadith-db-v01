{"consensus_set_id":"27477","translation_language":"fa","translation_source":{"hid":"402494"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ ) عَنْ رَجُلٍ نَسِيَ اَنْ يُصَلِّيَ رَكْعَتَيْ طَوَافِ الْفَرِيضَةِ فِي الْحِجْرِ .  قَالَ :  « يُعِيدُهُمَا خَلْفَ الْمَقَامِ ،  لِاَنَّ اللَّهَ يَقُولُ :   <quranic_text> « وَ اِتَّخِذُوا مِنْ مَقٰامِ اِبْرٰاهِيمَ مُصَلًّي » </quranic_text>   <footnote> [ البقرة ۱۲۵ ] </footnote>  يَعْنِي بِذَلِكَ رَكْعَتَيْ طَوَافِ الْفَرِيضَةِ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"نسي","display":"نَسِيَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يصلي","display":"يُصَلِّيَ"},{"kind":"word","token":"ركعتي","display":"رَكْعَتَيْ"},{"kind":"word","token":"طواف","display":"طَوَافِ"},{"kind":"word","token":"الفريضه","display":"الْفَرِيضَةِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحجر","display":"الْحِجْرِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعيدهما","display":"يُعِيدُهُمَا"},{"kind":"word","token":"خلف","display":"خَلْفَ"},{"kind":"word","token":"المقام","display":"الْمَقَامِ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتخذو