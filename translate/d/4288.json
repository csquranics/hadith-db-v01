  فَاَيْنَ اَنْتَ عَنْ عُثْمَانَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ :  لَوْ وَلِيَهَا لَحَمَلَ بَنِي اَبِي مُعَيْطٍ عَلَي رِقَابِ الْمُسْلِمِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَوْ فَعَلَهَا لَقَتَلُوهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ مِنْ طَرِيقٍ اخَرَ :  وَ اَمَّا اَنْتَ يَا عُثْمَانُ فَوَ اللَّهِ لَرَوْثَةٌ خَيْرٌ مِنْكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قِيلَ :  فَمَا يَمْنَعُكَ مِنْ سَعْدٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ :  صَاحِبُ مِقْنَبٍ وَ قِتَالٍ لاَ يَقُومُ بِقَرْيَةٍ لَوْ وَلِيَ اَمْرَهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ مِنْ طَرِيقٍ اخَرَ :  اِنَّهُ صَاحِبُ صَيْدٍ وَ قَنَصٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ هَذَا اَمْرٌ لاَ يَصْلُحُ لِصَاحِبِ صَيْدٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  ثُمَّ قَالَ :  اِنَّ هَذَا الْاَمْرَ لاَ يَصْلُحُ لَهُ اِلاَّ الْقَوِيُّ فِي غَيْرِ عُنْفٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  رَقِيقٌ فِي غَيْرِ ضَعْفٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  جَوَادٌ فِي غَيْرِ سَرَفٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اللَّهِ لَوْ كَانَ سَالِمٌ مَوْلَي اَبِي حُذَيْفَةَ حَيّاً مَا تُخَالِجُنِي فِيهِ الشُّكُوكُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اَوْ :  لَمْ يُخَالِجْنِي فِيهِ شَكٌّ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ فِي بَعْضِ الرِّوَايَاتِ :  لَوْ كَانَ اَبُو عُبَيْدَةَ حَيّاً لَوَلَّيْتُهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ رَدَّ اَمْرَ الصَّلاَةِ اِلَي صُهَيْبٍ ،  وَ قُبِضَ ،  فَاجْتَمَعُوا لِلاِخْتِيَارِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَمْ يَكُنْ سَعْدٌ حَاضِراً فِي رِوَايَةٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ عَبْدُ الرَّحْمَنِ :  اَنَا عَدِيلُ الْغَائِبِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاَيُّكُمْ يَهَبُ سَهْمَهُ فَيَخْتَارُ فَاَمْسِكُوا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ :  اَنَا اَهَبُ سَهْمِي فِي الْاِمَامَةِ عَلَي اَنْ اَخْتَارَ مَنْ شِئْتُ ،  فَاَمْسَكُوا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ :  لاَ بُدَّ مِنْ اَحَدِ الْاَمْرَيْنِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ عَضَدَ الْحَاضِرُونَ قَوْلَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاَجَابَ الْقَوْمُ اِلَي رَدِّ الْاَمْرِ اِلَيْهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اَمْسَكَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ :  - وَ النَّاسُ مَعَهُ - مَا لَكَ يَا اَبَا الْحَسَنِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اِمَّا اَنْ تُسْقِطَ حَقَّكَ مِنَ الْاِمَامَةِ وَ تَخْتَارَ مَنْ شِئْتَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اَوْ تَرْضَي بِمَا رَضِيَ بِهِ اَصْحَابُكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَلَمْ يَجِدْ بُدّاً مِنَ الرِّضَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاسْتَظْهَرَ عَلَي عَبْدِ الرَّحْمَنِ بِاَخْذِ الْمِيثَاقِ لَتَحْكُمَنَّ بِالْكِتَابِ وَ السُّنَّةِ ،  فَبَدَاَ بِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ :  اُمْدُدْ يَدَكَ اُبَايِعْكَ عَلَي اَنْ تَسِيرَ فِينَا بِسِيرَةِ اَبِي بَكْرٍ وَ عُمَرَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَقَالَ عَلَيْهِ السَّلاَمُ :  اُبَايِعُكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"- وَ فِي الرِّوَايَةِ الْاُخْرَي :  اخُذُهَا - عَلَي اَنْ اَسِيرَ فِيكُمْ بِكِتَابِ اللَّهِ وَ سُنَّةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"نَبِيِّهِ  ،  فَرَدَّ يَدَهُ وَ اَتَي عُثْمَانَ ،  فَقَالَ لَهُ مِثْلَ قَوْلِهِ لِعَلِيٍّ عَلَيْهِ السَّلاَمُ ،  فَاَجَابَهُ اِلَيْهِ ،  فَبَايَعَهُ ،  وَ اَخَذَ الْحَاضِرِينَ بِالْبَيْعَةِ لَهُ فَبَايَعُوهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِمْتَنَعَ عَلِيٌّ عَلَيْهِ السَّلاَمُ ،  فَقَالَ لَهُ عَبْدُ الرَّحْمَنِ :  بَايِعْ وَ اِلاَّ ضَرَبْتُ عُنُقَكَ ،  فِي تَارِيخِ الْبَلاذِرِيِّ وَ غَيْرِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ مِنْ طَرِيقٍ اخَرَ :  اَنَّ عَلِيّاً عَلَيْهِ السَّلاَمُ خَرَجَ مُغْضَباً ،  فَلَحِقَهُ اَصْحَابُ الشُّورَي ،  فَقَالُوا لَهُ :  بَايِعْ وَ اِلاَّ جَاهَدْنَاكَ ،  فَقَالَ لَهُ :  يَا عَبْدَ الرَّحْمَنِ خُئُونَةٌ خُنْتَ دَهْراً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ مِنْ طُرُقٍ اُخَرَ عَنِ الطَّبَرِيِّ وَ غَيْرِهِ :  نَصَعَتِ الْخُئُونَةُ يَا اِبْنَ عَوْفٍ ،  لَيْسَ هَذَا اَوَّلَ يَوْمٍ تَظَاهَرْتُمْ عَلَيْنَا فِيهِ ،   <quranic_text> « فَصَبْرٌ جَمِيلٌ وَ اللّٰهُ الْمُسْتَعٰانُ عَليٰ مٰا تَصِفُونَ » </quranic_text>   <footnote> [ يوسف ۱۸ ] </footnote>   ،  وَ اللَّهِ مَا وَلَّيْتُ عُثْمَانَ اِلاَّ لِيَرُدَّ الْاَمْرَ اِلَيْكَ ،  وَ اللَّهُ كُلَّ يَوْمٍ  <quranic_text> « فِي شَاْنٍ » </quranic_text>   <footnote> [ الرحمن ۲۹ ] </footnote>   ،  فَقَالَ لَهُ عَبْدُ الرَّحْمَنِ :  لاَ تَجْعَلْ عَلَي نَفْسِكَ سَبِيلاً ،  اِنِّي قَدْ نَظَرْتُ وَ شَاوَرْتُ النَّاسَ ،  فَاِذَا هُمْ لاَ يَعْدِلُونَ بِعُثْمَانَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ رَوَي الطَّبَرِيُّ :  اَنَّ النَّاسَ لَمَّا بَايَعُوا عُثْمَانَ تَلَكَّاَ عَلِيٌّ عَلَيْهِ السَّلاَمُ ،  فَقَالَ لَهُ عَبْدُ الرَّحْمَنِ :  فَمَنْ يَنْكُثْ  <quranic_text> « فَاِنَّمٰا يَنْكُثُ عَليٰ نَفْسِهِ » </quranic_text>   <footnote> [ الفتح ۱۰ ] </footnote>   ،  فَرَجَعَ عَلِيٌّ عَلَيْهِ السَّلاَمُ فَبَايَعَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ مِنْ غَيْرِ طَرِيقِ الطَّبَرِيِّ :  اَنَّ عَبْدَ الرَّحْمَنِ قَالَ لِعَلِيٍّ عَلَيْهِ السَّلاَمُ :  قَدْ قُلْتُ ذَلِكَ لِعُمَرَ ،  فَقَالَ لَهُ عَلَيْهِ السَّلاَمُ :  اَ وَ لَمْ يَكُنْ ذَلِكَ كَمَا قُلْتَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَلَمَّا يَئِسَ عَلِيٌّ مِنْ رُجُوعِهِمْ اِلَي الْحَقِّ خَطَبَهُمْ ،  فَذَكَرَ مَنَاقِبَهُ وَ ذَرَائِعَهُ اِلَي الْاِمَامَةِ وَ النَّصِّ عَلَيْهَا فِي مَقَامٍ بَعْدَ اخَرَ ،  يُقَرِّرُهُمْ عَلَي كُلِّ فَضِيلَةٍ وَ نَصٍّ وَ يُنَاشِدُهُمْ اللَّهَ تَعَالَي ،  فَيُقِرُّونَ .","translation_segment":"","segment_columns":[]}]}