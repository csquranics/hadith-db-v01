{"consensus_set_id":"59671","translation_language":"fa","translation_source":{"hid":"324544"},"segments":[{"source_hadith_segment":"وَ رَاَي مُوسَي عَلَيْهِ السَّلاَمُ رَجُلاً عِنْدَ الْعَرْشِ فَغَبَطَهُ بِمَكَانِهِ فَسَاَلَ عَنْهُ فَقَالَ كَانَ لاَ يَحْسُدُ  <quranic_text> « النّٰاسَ عَليٰ مٰا اتٰاهُمُ اللّٰهُ مِنْ فَضْلِهِ » </quranic_text>   <footnote> [ النساء ۵۴ ] </footnote>   .","translation_segment":"حضرت موسی (علیه السلام) مردی را کنار عرش دید و بر او غبطه برد و از سبب قرب او پرسید. گفته شد: نسبت به فضیلت و برتری که خداوند به بندگان خود عنایت می‌فرمود، حسد نمی‌برد. و گفته شده است، برای حسود هیچ راحتی نیست و حسود دارای اندوههای طولانی است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"راي","display":"رَاَي"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"فغبطه","display":"فَغَبَطَهُ"},{"kind":"word","token":"بمكانه","display":"بِمَكَانِهِ"},{"kind":"word","token":"فسال","display":"فَسَاَلَ"},{"kind":"word","token":"عنه","display":"عَنْهُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يحسد","display":"يَحْسُدُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الناس","display":"النّٰاسَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"اتاهم","display":"اتٰاهُمُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"فضله","display":"فَضْلِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النسا