tnote> [ الصافات ۳۵ ] </footnote>  حِصْنِي فَمَنْ دَخَلَ حِصْنِي اَمِنَ عَذَابِي","translation_segment":"حضرت علی ع از رسول خدا صلی الله علیه و آله از جبرئیل از خداوند متعال، نقل کرده که حضرت حق فرموده: کلمه (لاٰ إلٰه‌ إلا اللٰه‌) حصن من است (حصار). پس هر کس داخل این حصار توحید بشود، از عذاب من ایمن می‌ماند. وقتی که عماره حرکت کرد، حضرت با صدای بلند به ما فرمود: اما این کلمه توحید مشروط‍‌ دارد که یکی از آنها من هستم (یعنی اعتقاد به امامت). شیخ ابو جعفر ابن بابویه، این حدیث را در ثواب الاعمال و توحید و عیون الاخبار و معانی الاخبار هم با همان سند واحد از محمد بن موسی بن متوکل از ابو الحسن محمد بن جعفر اسدی از محمد بن حسین صوفی از یوسف بن عقیل با بقیه سند ذکر شده، نقل کرده است. و در کتاب عیون الاخبار و توحید، پس از بیان این حدیث گفته: مقصود از کلمه (من از شروط‍‌ این توحید هستم) این است که اقرار به امامت حضرت رضا ع از جانب خداوند می‌باشد که طاعتش بر مسلمانان واجب است. مولف می‌گوید: این معنای شیخ ابو جعفر هنگامی صادق است که نون را در کلمه (انا) با تخفیف بخوانیم، آن وقت ضمیر متکلم وحده می‌شود و تنها شامل امام رضا ع می‌گردد. ولی اگر نون را در کلمه (انا) با تشدید بخوانیم، آن وقت ضمیر","segment_columns":[{"kind":"word","token":"فاطلع","display":"فَاَطْلَعَ"},{"kind":"word","token":"راسه","display":"رَاْسَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام-","display":"السّلام-"},{"kind":"word","token":"سمعت","display":"سَمِعْتُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"سمعت","display":"سَمِعْتُ"},{"kind":