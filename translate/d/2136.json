{"consensus_set_id":"2136","translation_language":"fa","translation_source":{"hid":"115597"},"segments":[{"source_hadith_segment":"اَوْلَمَ اِسْمَاعِيلُ فَقَالَ لَهُ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَلَيْكَ بِالْمَسَاكِينِ فَاَشْبِعْهُمْ فَاِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ  <quranic_text> « وَ مٰا يُبْدِئُ الْبٰاطِلُ وَ مٰا يُعِيدُ » </quranic_text>   <footnote> [ سبا ۴۹ ] </footnote>   .","translation_segment":"حماد بن عثمان گوید: اسماعیل، ولیمه‌ای ترتیب داده بود. امام صادق علیه السلام به او فرمود: مساکین را دریاب و شکم گرسنه آنان را سیر کن که خداوند می‌گوید: «باطل نه نعمت آغازد و نه نعمت رفته را بازآرد».","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"اولم","display":"اَوْلَمَ"},{"kind":"word","token":"اسماعيل","display":"اِسْمَاعِيلُ"},{"kind":"word","token":"ره","display":"ره"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"},{"kind":"word","token":"بالمساكين","display":"بِالْمَسَاكِينِ"},{"kind":"word","token":"فاشبعهم","display":"فَاَشْبِعْهُمْ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يبدئ","d