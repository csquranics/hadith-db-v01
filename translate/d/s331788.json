{"consensus_set_id":"s331788","translation_language":"fa","translation_source":{"hid":"331788"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « سَيَجْعَلُ لَهُمُ الرَّحْمٰنُ وُدًّا » </quranic_text>   <footnote> [ مريم ۹۶ ] </footnote>  قَالَ :  مَحَبَّةً لِعَلِيٍّ  ،  لاَ تَلْقَي مُؤْمِناً اِلاَّ وَ فِي قَلْبِهِ مَحَبَّةٌ لِعَلِيٍّ  .","translation_segment":"عن ابن عباس فی قوله: (سیجعل لهم الرحمان ودا) قال: محبه لعلی، لا تلقی مومنا إلا و فی قلبه محبه لعلی. ابن عباس درباره سخن خداوند: «سیجعل لهم الرحمن ودا» گفت: محبت علی، هیچ مومنی را ملاقات نمی‌کنی مگر اینکه در قلب او محبتی برای علی وجود دارد.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سيجعل","display":"سَيَجْعَلُ"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"ودا","display":"وُدًّا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"مريم","display":"مريم"},{"kind":"word","token":"۹۶","display":"۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"محبه","display":"مَحَبَّةً"},{"kind":"word","token":"لعلي","display":"لِعَلِيٍّ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تلقي","display":"تَلْقَي"},{"kind":"word","token":"مؤمنا","display":"مُؤْمِناً"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قلبه","display":"قَلْبِهِ"},{"kind":"word","token":"محبه","display":"مَحَبَّةٌ"},{"kind":"word","token":"لعلي","display":"لِعَلِيٍّ"}]}]}