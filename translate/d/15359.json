َالَ :   <quranic_text> « اَوْ اَشَدُّ » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ بَيَّنَ فِي الثَّانِي اَنَّ قُلُوبَهُمْ اَشَدُّ قَسْوَةً مِنَ الْحِجَارَةِ لاَ بِقَوْلِهِ :   <quranic_text> « اَوْ اَشَدُّ قَسْوَةً » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ لَكِنْ بِقَوْلِهِ تَعَالَي :   <quranic_text> « وَ اِنَّ مِنَ الْحِجٰارَةِ لَمٰا يَتَفَجَّرُ مِنْهُ الْاَنْهٰارُ » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اَيْ فَهِيَ فِي الْقَسَاوَةِ بِحَيْثُ لاَ يَجِيءُ مِنْهَا الْخَيْرُ [ يَا يَهُودُ ] وَ فِي الْحِجَارَةِ مَا يَتَفَجَّرُ مِنْهُ الْاَنْهَارُ فَيَجِيءُ بِالْخَيْرِ وَ الْغِيَاثِ لِبَنِي ادَمَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".   <quranic_text> « وَ اِنَّ مِنْهٰا » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>  مِنَ الْحِجَارَةِ  <quranic_text> « لَمٰا يَشَّقَّقُ فَيَخْرُجُ مِنْهُ الْمٰاءُ » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ هُوَ مَا يَقْطُرُ مِنْهُ الْمَاءُ فَهُوَ خَيْرٌ مِنْهَا دُونَ الْاَنْهَارِ الَّتِي يَتَفَجَّرُ مِنْ بَعْضِهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ قُلُوبُهُمْ لاَ يَتَفَجَّرُ مِنْهَا الْخَيْرَاتُ وَ لاَ يَشَّقَّقُ فَيَخْرُجُ [ مِنْهَا ] قَلِيلٌ مِنَ الْخَيْرَاتِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِنْ لَمْ يَكُنْ كَثِيراً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  ثُمَّ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « وَ اِنَّ مِنْهٰا » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>  يَعْنِي مِنَ الْحِجَارَةِ  <quranic_text> « لَمٰا يَهْبِطُ مِنْ خَشْيَةِ اللّٰهِ » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>  اِذَا اَقْسَمَ عَلَيْهَا بِاسْمِ اللَّهِ وَ بِاَسَامِي اَوْلِيَائِهِ :  مُحَمَّدٍ وَ عَلِيٍّ وَ فَاطِمَةَ وَ الْحَسَنِ وَ الْحُسَيْنِ وَ الطَّيِّبِينَ مِنْ الِهِمْ صَلَوَاتُ اللَّهِ عَلَيْهِم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لَيْسَ فِي قُلُوبِكُمْ شَيْءٌ مِنْ هَذِهِ الْخَيْرَاتِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".   <quranic_text> « وَ مَا اللّٰهُ بِغٰافِلٍ عَمّٰا تَعْمَلُونَ » </quranic_text>   <footnote> [ البقرة ۷۴ ] </footnote>  بَلْ عَالِمٌ بِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  يُجَازِيكُمْ عَنْهُ بِمَا هُوَ بِهِ عَادِلٌ عَلَيْكُمْ وَ لَيْسَ بِظَالِمٍ لَكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  يُشَدِّدُ حِسَابَكُمْ ،  وَ يُؤْلِمُ عِقَابَكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ هَذَا الَّذِي [ قَدْ ] وَصَفَ اللَّهُ تَعَالَي بِهِ قُلُوبَهُمْ هَاهُنَا نَحْوُ مَا قَالَ فِي سُورَةِ النِّسَاءِ :   <quranic_text> « اَمْ لَهُمْ نَصِيبٌ مِنَ الْمُلْكِ فَاِذاً لاٰ يُؤْتُونَ النّٰاسَ نَقِيراً » </quranic_text>   <footnote> [ النساء ۵۳ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ مَا وَصَفَ بِهِ الْاَحْجَارَ هَاهُنَا نَحْوُ مَا وَصَفَ فِي قَوْلِهِ تَعَالَي :   <quranic_text> « لَوْ اَنْزَلْنٰا هٰذَا الْقُرْانَ عَليٰ جَبَلٍ لَرَاَيْتَهُ خٰاشِعاً مُتَصَدِّعاً مِنْ خَشْيَةِ اللّٰهِ » </quranic_text>   <footnote> [ الحشر ۲۱ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ هَذَا التَّقْرِيعُ مِنَ اللَّهِ تَعَالَي لِلْيَهُودِ وَ النَّوَاصِبِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ الْيَهُودُ جَمَعُوا الْاَمْرَيْنِ وَ اِقْتَرَفُوا الْخَطِيئَتَيْنِ فَغَلُظَ عَلَي الْيَهُودِ مَا وَبَّخَهُمْ بِهِ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالَ جَمَاعَةٌ مِنْ رُؤَسَائِهِمْ ،  وَ ذَوِي الْاَلْسُنِ وَ الْبَيَانِ مِنْهُمْ :  يَا مُحَمَّدُ اِنَّكَ تَهْجُونَا وَ تَدَّعِي عَلَي قُلُوبِنَا مَا اللَّهُ يَعْلَمُ مِنْهَا خِلاَفَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اِنَّ فِيهَا خَيْراً كَثِيراً :  نَصُومُ وَ نَتَصَدَّقُ وَ نُوَاسِي الْفُقَرَاءَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  اِنَّمَا الْخَيْرُ مَا اُرِيدَ بِهِ وَجْهُ اللَّهِ تَعَالَي ،  وَ عُمِلَ عَلَي مَا اَمَرَ اللَّهُ تَعَالَي [ بِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"] .  فَاَمَّا مَا اُرِيدَ بِهِ الرِّيَاءُ وَ السُّمْعَةُ اَوْ مُعَانَدَةُ رَسُولِ اللَّهِ  ،  وَ اِظْهَارُ الْغِنَي لَهُ وَ التَّمَالُكُ وَ التَّشَرُّفُ عَلَيْهِ فَلَيْسَ بِخَيْرٍ ،  بَلْ هُوَ الشَّرُّ الْخَالِصُ ،  وَ وَبَالٌ عَلَي صَاحِبِهِ ،  يُعَذِّبُهُ اللَّهُ بِهِ اَشَدَّ الْعَذَابِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالُوا لَهُ :  يَا مُحَمَّدُ اَنْتَ تَقُولُ هَذَا ،  وَ نَحْنُ نَقُولُ :  بَلْ مَا نُنْفِقُهُ اِلاَّ لِاِبْطَالِ اَمْرِكَ وَ دَفْعِ رِئَاسَتِكَ وَ لِتَفْرِيقِ اَصْحَابِكَ عَنْكَ وَ هُوَ الْجِهَادُ الْاَعْظَمُ ،  نُؤَمِّلُ بِهِ مِنَ اللَّهِ الثَّوَابَ الْاَجَلَّ الْاَجْسَمَ ،  وَ اَقَلُّ اَحْوَالِنَا اَنَّا تَسَاوَيْنَا فِي الدَّعَاوِي ،  فَاَيُّ فَضْلٍ لَكَ عَلَيْنَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  يَا اِخْوَةَ الْيَهُودِ اِنَّ الدَّعَاوِيَ يَتَسَاوَي فِيهَا الْمُحِقُّونَ وَ الْمُبْطِلُونَ وَ لَكِنْ حُجَجُ اللَّهِ وَ دَلاَئِلُهُ تُفَرِّقُ بَيْنَهُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَتَكْشِفُ عَنْ تَمْوِيهِ الْمُبْطِلِينَ وَ تُبَيِّنُ عَنْ حَقَائِقِ الْمُحِقِّينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ رَسُولُ اللَّهِ مُحَمَّدٌ لاَ يَغْتَنِمُ جَهْلَكُمْ وَ لاَ يُكَلِّفُكُمُ التَّسْلِيمَ لَهُ بِغَيْرِ حُجَّةٍ وَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لَكِنْ يُقِيمُ عَلَيْكُمْ حُجَّةَ اللَّهِ تَعَالَي الَّتِي لاَ يُمْكِنُكُمْ دِفَاعُهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ لاَ تُطِيقُونَ الاِمْتِنَاعَ مِنْ مُوجِبِهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ لَوْ ذَهَبَ مُحَمَّدٌ يُرِيكُمْ ايَةً مِنْ عِنْدِهِ لَشَكَكْتُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ قُلْتُمْ :  اِنَّهُ مُتَكَلِّفٌ مَصْنُوعٌ مُحْتَالٌ فِيهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  مَعْمُولٌ اَوْ مُتَوَاطَاٌ عَلَيْهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِذَا اِقْتَرَحْتُمْ اَنْتُمْ فَاَرَاكُمْ مَا تَقْتَرِحُونَ لَمْ يَكُنْ لَكُمْ اَنْ تَقُولُوا مَعْمُولٌ اَوْ مُتَوَاطَاٌ عَلَيْهِ اَوْ مُتَاَتٍّي بِحِيلَةٍ وَ مُقَدِّمَاتٍ ،  فَمَا الَّذِي تَقْتَرِحُونَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَهَذَا رَبُّ الْعَالَمِينَ قَدْ وَعَدَنِي اَنْ يُظْهِرَ لَكُمْ مَا تَقْتَرِحُونَ لِيَقْطَعَ مَعَاذِيرَ الْكَافِرِينَ مِنْكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ يَزِيدَ فِي بَصَائِرِ الْمُؤْمِنِينَ مِنْكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قَالُوا :  قَدْ اَنْصَفْتَنَا يَا مُحَمَّدُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنْ وَفَيْتَ بِمَا وَعَدْتَ مِنْ نَفْسِكَ مِنَ الْاِنْصَافِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِلاَّ فَاَنْتَ اَوَّلُ رَاجِعٍ مِنْ دَعْوَاكَ لِلنُّبُوَّةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ دَاخِلٌ فِي غُمَارِ الْاُمَّةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ مُسَلِّمٌ لِحُكْمِ التَّوْرَاةِ لِعَجْزِكَ عَمَّا نَقْتَرِحُهُ عَلَيْكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ ظُهُورِ الْبَاطِلِ فِي دَعْوَاكَ فِيمَا تَرُومُهُ مِنْ جِهَتِكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  الصِّدْقُ يُنْبِئُ عَنْكُمْ لاَ الْوَعِيدُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اِقْتَرِحُوا مَا تَقْتَرِحُونَ لِيُقْطَعَ مَعَاذِيرُكُمْ فِيمَا تَسْاَلُونَ .","translation_segment":"","segment_columns":[]}]}