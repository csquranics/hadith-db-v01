ith_segment":"،  وَ سَاَلَ مَنْ قِبَلَهُ مِنَ الْقُضَاةِ فَلَمْ يُخْبِرُوهُ مَا هُوَ","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قبله","display":"قِبَلَهُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"القضاه","display":"الْقُضَاةِ"},{"kind":"word","token":"فلم","display":"فَلَمْ"},{"kind":"word","token":"يخبروه","display":"يُخْبِرُوهُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"هو","display":"هُوَ"}]},{"source_hadith_segment":"،  وَ قَدْ كَتَبَ اِلَيَّ اِنْ فَسَّرْتَ ذَلِكَ لَهُ وَ اِلاَّ حَمَلْتُكَ عَلَي الْبَرِيدِ اِلَيْهِ","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كتب","display":"كَتَبَ"},{"kind":"word","token":"الي","display":"اِلَيَّ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"فسرت","display":"فَسَّرْتَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"حملتك","display":"حَمَلْتُكَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"البريد","display":"الْبَرِيدِ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"}]},{"source_hadith_segment":".  فَقَالَ اَبُو عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ )  :  « هَذَا فِي كِتَابِ اللَّهِ بَيِّنٌ ،  اِنَّ اللَّهَ يَقُولُ لَمَّا قَالَ اِبْرَاهِيمُ  :   <quranic_text> « رَبِّ اَرِنِي كَيْفَ تُحْيِ الْمَوْتيٰ » </quranic_text>   <footnote> [ البقرة ۲۶۰ ] </footnote> اِلَي قَوْلِهِ تَعَالَي :   <quranic_text> « ثُمَّ اِجْعَلْ عَليٰ كُلِّ جَبَلٍ مِنْهُنَّ جُزْءاً » </quranic_text>   <footnote> [ البقرة ۲۶۰ ] </footnote> فَكَانَتِ الطَّيْرُ اَرْبَعَةً وَ الْجِبَالُ عَشَرَةً ،  يُخْرِجُ الرَّجُلُ مِنْ كُلِّ عَشَرَةِ اَجْزَاءٍ جُزْءاً وَاحِداً .  وَ اِنَّ اِبْرَاهِيمَ ( عَلَيْهِ السَّلاَمُ ) دَعَا بِمِهْرَاسٍ فَدَقَّ فِيهِ الطُّيُورَ جَمِيعاً ،  وَ حَبَسَ الرُّءُوسَ عِنْدَهُ ،  ثُمَّ اِنَّهُ دَعَا بِالَّذِي اُمِرَ بِهِ ،  فَجَعَلَ يَنْظُرُ اِلَي الرِّيشِ كَيْفَ يَخْرُجُ ،  وَ اِلَي الْعُرُوقِ عِرْقاً عِرْقاً حَتَّي تَمَّ جَنَاحُهُ مُسْتَوِياً ،  فَاَهْوَي نَحْوَ اِبْرَاهِيمَ ( عَلَيْهِ السَّلاَمُ ) فَاَخَذَ اِبْرَاهِيمُ بِبَعْضِ الرُّءُوسِ فَاسْتَقْبَلَهُ بِهِ ،  فَلَمْ يَكُنِ الرَّاْسُ الَّذِي اِسْتَقْبَلَهُ بِهِ لِذَلِكَ الْبَدَنِ حَتَّي اِنْتَقَلَ اِلَيْهِ غَيْرُهُ ،  فَكَانَ مُوَافِقاً لِلرَّاْسِ ،  فَتَمَّتِ الْعِدَّةُ ،  وَ تَمَّتِ الْاَبْدَانُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتاب","display":"كِتَابِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بين","display":"بَيِّنٌ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"رب","display":"رَبِّ"},{"kind":"word","token":"ارني","display":"اَرِنِي"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"تحي","display":"تُحْيِ"},{"kind":"word","token":"الموتي","display":"الْمَوْتيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"}