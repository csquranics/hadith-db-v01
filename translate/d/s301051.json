{"consensus_set_id":"s301051","translation_language":"fa","translation_source":{"hid":"301051"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ كَذٰلِكَ اَوْحَيْنٰا اِلَيْكَ رُوحاً مِنْ اَمْرِنٰا مٰا كُنْتَ تَدْرِي مَا الْكِتٰابُ وَ لاَ الْاِيمٰانُ وَ لٰكِنْ جَعَلْنٰاهُ نُوراً نَهْدِي بِهِ مَنْ نَشٰاءُ مِنْ عِبٰادِنٰا » </quranic_text>   <footnote> [ الشوري ۵۲ ] </footnote>  فَقَالَ اَبُو جَعْفَرٍ عَلَيْهِ السَّلاَمُ مُنْذُ اَنْزَلَ اللَّهِ ذَلِكَ الرُّوحَ عَلَي نَبِيِّهِ مَا صَعِدَ اِلَي السَّمَاءِ وَ اِنَّهُ لَفِينَا .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كذلك","display":"كَذٰلِكَ"},{"kind":"word","token":"اوحينا","display":"اَوْحَيْنٰا"},{"kind":"word","token":"اليك","display":"اِلَيْكَ"},{"kind":"word","token":"روحا","display":"رُوحاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"امرنا","display":"اَمْرِنٰا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"كنت","display":"كُنْتَ"},{"kind":"word","token":"تدري","display":"تَدْرِي"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"الايمان","display":"الْاِيمٰانُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لٰكِنْ"},{"kind":"word","token":"جعلناه","display":"جَعَلْنٰاهُ"},{"kind":"word","token":"نورا","display":"نُوراً"},{"kind":"word","token":"نهدي","display":"نَهْدِي"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word