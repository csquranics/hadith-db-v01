{"consensus_set_id":"s405863","translation_language":"fa","translation_source":{"hid":"405863"},"segments":[{"source_hadith_segment":"« يَا اِبْنَ مَسْعُودٍ ،  قَدْ اُنْزِلَتِ الْايَةُ  <quranic_text> « وَ اِتَّقُوا فِتْنَةً لاٰ تُصِيبَنَّ الَّذِينَ ظَلَمُوا مِنْكُمْ خَاصَّةً » </quranic_text>   <footnote> [ الانفال ۲۵ ] </footnote>  وَ اَنَا مُسْتَوْدِعُكَهَا ،  وَ مُسَمٍّ لَكَ خَاصَّةً الظَّلَمَةَ ،  فَكُنْ لِمَا اَقُولُ وَاعِياً ،  وَ عَنِّي لَهُ مُؤَدِّياً ،  مَنْ ظَلَمَ عَلِيّاً مَجْلِسِي هَذَا كَمَنْ جَحَدَ نُبُوَّتِي وَ نُبُوَّةَ مَنْ كَانَ قَبْلِي »","translation_segment":"","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"مسعود","display":"مَسْعُودٍ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"انزلت","display":"اُنْزِلَتِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"فتنه","display":"فِتْنَةً"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تصيبن","display":"تُصِيبَنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"ظلموا","display":"ظَلَمُوا"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"خاصه","display":"خَاصَّةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۲۵","display":"۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"مستودعكها","display":"مُسْتَوْدِعُكَهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مسم","display":"مُسَمٍّ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"خاصه","display":"خَاصَّةً"},{"kin