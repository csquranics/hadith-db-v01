{"consensus_set_id":"37634","translation_language":"fa","translation_source":{"hid":"331519"},"segments":[{"source_hadith_segment":"،  قَالَ :  اَخْبَرَنِي اَبِي  ،  عَنْ اَبِيهِ جَعْفَرٍ  ،  عَنْ اَبِيهِ مُحَمَّدٍ  ،  عَنْ اَبِيهِ عَلِيٍّ عَنْ اَبِيهِ الْحُسَيْنِ عَنْ اَبِيهِ عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِمُ السَّلاَمُ قَالَ قَالَ :  رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  فِي هَذِهِ الْايَةِ :   <quranic_text> « فَاُولٰئِكَ مَعَ الَّذِينَ اَنْعَمَ اللّٰهُ عَلَيْهِمْ » </quranic_text>   <footnote> [ النساء ۶۹ ] </footnote>  قَالَ :   <quranic_text> « مِنَ النَّبِيِّينَ » </quranic_text>   <footnote> [ النساء ۶۹ ] </footnote>  مُحَمَّدٌ  ،  وَ مِنَ  <quranic_text> « الصِّدِّيقِينَ » </quranic_text>   <footnote> [ النساء ۶۹ ] </footnote>  عَلِيُّ بْنُ اَبِي طَالِبٍ  ،  وَ مِنَ  <quranic_text> « الشُّهَدٰاءِ » </quranic_text>   <footnote> [ النساء ۶۹ ] </footnote>  حَمْزَةُ ،  وَ مِنَ  <quranic_text> « الصّٰالِحِينَ » </quranic_text>   <footnote> [ النساء ۶۹ ] </footnote>  الْحَسَنُ وَ الْحُسَيْنُ  <quranic_text> « وَ حَسُنَ اُولٰئِكَ رَفِيقاً » </quranic_text>   <footnote> [ النساء ۶۹ ] </footnote>  قَالَ :  الْقَائِمُ مِنْ الِ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  .  لَفْظاً سَوَاءً .","translation_segment":"عن علی‌ بن موسی الرضا، قال: أخبرنی أبی، عن أبیه جعفر، عن أبیه محمد، عن أبیه علی عن أبیه الحسین عن أبیه علی‌ بن ابی طالب ع قال: قال رسول الله صلی الله علیه و آله و سلم فی هذه الآیه: (فأولئک الذین أنعم الله علیهم) قال: (من النبیین) محمد، و (من الصدیقین) علی‌ بن ابی طالب، و (من الشهداء) حمزه، و (من الصالحین) الحسن و الحسین (و حسن أولئک رفیقا) قال: القائم من آل محمد صلی الله علیه و آله و سلم. علی‌ بن موسی الرضا از پدرانش نقل می‌کند که پیامبر خدا درباره این آیه گفت: «فاولئک الذین انعم الله علیهم» از پیامبران محمد (صلی الله علیه و آله) و از صدیقین علی‌ بن ابی طالب (علیه السلام) و از شهدا حمزه و از صالحان حسن و حسین هستند «و حسن اولئک رفیقا» قائم آل محمد است.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اخبرني","display":"اَخْبَرَنِي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلّم"},{"kind":"word","token":"فسالته","display":"فسالته"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاولئك","display":"فَاُولٰئِكَ"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"الذين","d