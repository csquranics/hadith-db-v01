{"consensus_set_id":"s394747","translation_language":"fa","translation_source":{"hid":"394747"},"segments":[{"source_hadith_segment":"وَ اَلْاُمَّةُ وَاحِدَةٌ فَصَاعِداً كَمَا قَالَ اللَّهُ سُبْحَانَهُ وَ تَعَالَي :   <quranic_text> « اِنَّ اِبْرٰاهِيمَ كٰانَ اُمَّةً قٰانِتاً لِلّٰهِ » </quranic_text>   <footnote> [ النحل ۱۲۰ ] </footnote>  يَقُولُ :  مُطِيعاً لِلَّهِ ،  و الحديث طويل اخذنا منه موضع الحاجة .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الامه","display":"اَلْاُمَّةُ"},{"kind":"word","token":"واحده","display":"وَاحِدَةٌ"},{"kind":"word","token":"فصاعدا","display":"فَصَاعِداً"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"سبحانه","display":"سُبْحَانَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"امه","display":"اُمَّةً"},{"kind":"word","token":"قانتا","display":"قٰانِتاً"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النحل","display":"النحل"},{"kind":"word","token":"۱۲۰","display":"۱۲۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"مطيعا","display":"مُطِيعاً"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"الحديث","display":"الحديث"},{"kind":"word","token":"طويل","display":"طويل"},{"kind":"word","token":"اخذنا","display":"اخذنا"},{"kind":"word","token":"منه","display":"منه"},{"kind":"word","token":"موضع","display":"موضع"},{"kind":"word