{"consensus_set_id":"22069","translation_language":"fa","translation_source":{"hid":"103502"},"segments":[{"source_hadith_segment":"اَنَّهُ سُئِلَ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « فَاِنْ انَسْتُمْ مِنْهُمْ رُشْداً فَادْفَعُوا اِلَيْهِمْ اَمْوٰالَهُمْ » </quranic_text>   <footnote> [ النساء ۶ ] </footnote>  قَالَ « اِينَاسُ الرُّشْدِ حِفْظُ الْمَالِ » .","translation_segment":"و روایت شده است که از امام صادق علیه السلام در باره قول خدای عز و جل‌: «پس اگر رشدی از ایشان احساس کردید اموالشان را به ایشان تسلیم کنید» سوال کردند. پس فرمود: احساس رشد حفظ‍‌ مالست.","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"انستم","display":"انَسْتُمْ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"رشدا","display":"رُشْداً"},{"kind":"word","token":"فادفعوا","display":"فَادْفَعُوا"},{"kind":"word","token":"اليهم","display":"اِلَيْهِمْ"},{"kind":"word","token":"اموالهم","display":"اَمْوٰالَهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۶","display":"۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ايناس","display":"اِينَاسُ"},{"kind":"word","token":"الرشد","display":"الرُّشْدِ"},{"kind":"word","token":"حفظ","display":"حِفْظُ"},{"kind":"word","token":"المال","display":"الْمَالِ"}]}]}