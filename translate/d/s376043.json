{"consensus_set_id":"s376043","translation_language":"fa","translation_source":{"hid":"376043"},"segments":[{"source_hadith_segment":"تَاْخُذُ قُطْناً وَ تَبُلُّهُ وَ تَضَعُهُ عَلَي الْعَيْنِ وَ تَقُولُ عَيْنُ الشَّمْسِ فِي لُجَّةِ الْبَحْرِ  <quranic_text> « يٰا نٰارُ كُونِي بَرْداً وَ سَلاٰماً عَليٰ اِبْرٰاهِيمَ  » </quranic_text>   <footnote> [ الانبياء ۶۹ ] </footnote>   .","translation_segment":"پنبه‌ای ترکن و بر چشم بنه و بگو: (عین الشمس فی لجه البحر، «یٰا نٰار کونی بردا و سلاٰما علیٰ‌ إبرٰاهیم‌»).","segment_columns":[{"kind":"word","token":"تاخذ","display":"تَاْخُذُ"},{"kind":"word","token":"قطنا","display":"قُطْناً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تبله","display":"تَبُلُّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تضعه","display":"تَضَعُهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"العين","display":"الْعَيْنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تقول","display":"تَقُولُ"},{"kind":"word","token":"عين","display":"عَيْنُ"},{"kind":"word","token":"الشمس","display":"الشَّمْسِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"لجه","display":"لُجَّةِ"},{"kind":"word","token":"البحر","display":"الْبَحْرِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"نار","display":"نٰارُ"},{"kind":"word","token":"كوني","display":"كُونِي"},{"kind":"word","token":"بردا","display":"بَرْداً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلاما","display":"سَلاٰماً"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۶۹","display":"۶۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}