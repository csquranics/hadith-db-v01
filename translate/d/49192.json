{"consensus_set_id":"49192","translation_language":"fa","translation_source":{"hid":"360340"},"segments":[{"source_hadith_segment":"اَبَي اَللَّهُ اَنْ يَرْزُقَ عَبْدَهُ الْمُؤْمِنَ اِلاَّ  <quranic_text> « مِنْ حَيْثُ لاٰ يَحْتَسِبُ » </quranic_text>   <footnote> [ الطلاق ۳ ] </footnote>   .","translation_segment":"پیامبر (صلی الله علیه و آله) فرموده است: خداوند روزی بنده مومنش را نمی‌رساند، مگر از راهی که او خود تصور نمی‌کند!","segment_columns":[{"kind":"word","token":"علي","display":"علي"},{"kind":"word","token":"ابي","display":"اَبَي"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يرزق","display":"يَرْزُقَ"},{"kind":"word","token":"عبده","display":"عَبْدَهُ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"حيث","display":"حَيْثُ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يحتسب","display":"يَحْتَسِبُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الطلاق","display":"الطلاق"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"}]}]}