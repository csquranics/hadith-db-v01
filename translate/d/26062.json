adith_segment":"فَقَالُوا يَا نَبِيَّ اللَّهِ لَقَدْ رَاَيْنَا فِي","translation_segment":"زنی یک چشم و سرکش که آن سخنان را گفته بود.","segment_columns":[{"kind":"word","token":"فقالوا","display":"فَقَالُوا"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"نبي","display":"نَبِيَّ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"راينا","display":"رَاَيْنَا"},{"kind":"word","token":"في","display":"فِي"}]},{"source_hadith_segment":"بَيْتِكَ عَجَباً اِمْرَاَةً شَمْطَاءَ عَوْرَاءَ وَ حَكَوْا لَهُ كَلاَمَهَا فَقَالَ هُودٌ تِلْكَ اِمْرَاَتِي وَ اَنَا اَدْعُو اللَّهَ لَهَا بِطُولِ الْبَقَاءِ فَقَالُوا وَ كَيْفَ ذَلِكَ قَالَ لِاَنَّهُ مَا خَلَقَ اللَّهُ مُؤْمِناً اِلاَّ وَ لَهُ عَدُوٌّ يُؤْذِيهِ وَ هِيَ عَدُوَّتِي فَلَاَنْ يَكُونَ عَدُوِّي مِمَّنْ اَمْلِكُهُ خَيْرٌ مِنْ اَنْ يَكُونَ عَدُوِّي مِمَّنْ يَمْلِكُنِي فَبَقِيَ هُودٌ فِي قَوْمِهِ يَدْعُوهُمْ اِلَي اللَّهِ وَ يَنْهَاهُمْ عَنْ عِبَادَةِ الْاَصْنَامِ حَتَّي تُخْصِبَ بِلاَدُهُمْ وَ هُوَ قَوْلُهُ عَزَّ وَ جَلَّ  <quranic_text> « وَ يٰا قَوْمِ اِسْتَغْفِرُوا رَبَّكُمْ ثُمَّ تُوبُوا اِلَيْهِ يُرْسِلِ السَّمٰاءَ عَلَيْكُمْ مِدْرٰاراً وَ يَزِدْكُمْ قُوَّةً اِليٰ قُوَّتِكُمْ وَ لاٰ تَتَوَلَّوْا مُجْرِمِينَ » </quranic_text>   <footnote> [ هود ۵۲ ] </footnote>  فَ  <quranic_text> « قٰالُوا يٰا هُودُ مٰا جِئْتَنٰا بِبَيِّنَةٍ وَ مٰا نَحْنُ بِتٰارِكِي الِهَتِنٰا عَنْ قَوْلِكَ وَ مٰا نَحْنُ لَكَ بِمُؤْمِنِينَ » </quranic_text>   <footnote> [ هود ۵۳ ] </footnote>","translation_segment":"هود فرمود: من همواره برای طول عمر او دعا می‌کنم؛ زیرا خداوند هیچ مومنی را نمی‌آفریند جز آنکه دشمنی را برای آزار او در کنارش قرار می‌دهد. این زن نیز دشمن من است و چنانچه دشمن، کسی باشد که انسان بر او تسلط‍‌ داشته باشد بهتر از دشمنی است که او بر انسان تسلط‍‌ دارد. هود پیوسته برای قوم خویش دعا کرد تا دوباره سرزمین‌ها سرسبز شدند. «و یٰا قوم‌ استغفروا ربکم‌ ثم‌ توبوا إلیه‌ یرسل‌ السمٰاء علیکم‌ مدرٰارا و یزدکم‌ قوه‌ إلیٰ‌ قوتکم‌ و لاٰ تتولوا مجرمین‌ `قٰالوا یٰا هود مٰا جئتنٰا ببینه‌ و مٰا نحن‌ بتٰارکی آلهتنٰا عن‌ قولک‌ و مٰا نحن‌ لک‌ بمومنین‌؛ و ای قوم من، از پروردگارتان آمرزش خواهید آنگاه به او بازگردید تا باران را بر شما پیاپی و فراوان فرستد و نیرویی بر نیرویتان بیفزاید و بزهکارانه پشت مکنید و روی نگردانید. گفتند: ای هود! برای ما حجتی روشن نیاورده‌ای و ما رهاکننده‌ی خدایان خود به خاطر","segment_columns":[{"kind":"word","token":"بيتك","display":"بَيْتِكَ"},{"kind":"word","token":"عجبا","display":"عَجَباً"},{"kind":"word","token":"امراه","display":"اِمْرَاَةً"},{"kind":"word","token":"شمطاء","display":"شَمْطَاءَ"},{"kind":"word","token":"عوراء","display":"عَوْرَاءَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حكوا","display":"حَكَوْا"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"كلامها","display":"كَلاَمَهَا"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"هود","display":"هُودٌ"},{"kind":"word","token":"تلك","display":"تِلْكَ"},{"kind":"word","token":"امراتي","display":"اِمْرَاَتِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"ادعو","display":"اَدْعُو"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"لها","display":"لَهَا"},{"kind":"word","token":"بطول","display":"بِطُولِ"},{"kind":"word","token":"البقاء","display":"الْبَقَاءِ"},{"kind":"word","token":"فقالوا","display":"فَقَالُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لانه","display":"لِاَنَّهُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"مؤمنا","display":"مُؤْمِناً"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"له","display":"لَ