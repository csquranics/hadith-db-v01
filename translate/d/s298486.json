{"consensus_set_id":"s298486","translation_language":"fa","translation_source":{"hid":"298486"},"segments":[{"source_hadith_segment":"طُوبَي لِمَنْ لَمْ يُبَدِّلْ  <quranic_text> « نِعْمَتَ اللّٰهِ كُفْراً » </quranic_text>   <footnote> [ ابراهيم ۲۸ ] </footnote>  طُوبَي لِلْمُتَحَابِّينَ فِي اللَّهِ .","translation_segment":"محمد بن عجلان گوید: امام صادق (علیه السلام) فرمود: خوشا بحال آن کس که (شکر) نعمت خدا را به ناسپاسی تبدیل نکرد، خوشا بحال کسانی که در راه خدا با هم دوستی می‌کنند.","segment_columns":[{"kind":"word","token":"طوبي","display":"طُوبَي"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يبدل","display":"يُبَدِّلْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"نعمت","display":"نِعْمَتَ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"كفرا","display":"كُفْراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۲۸","display":"۲۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"طوبي","display":"طُوبَي"},{"kind":"word","token":"للمتحابين","display":"لِلْمُتَحَابِّينَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الله","display":"اللَّهِ"}]}]}