{"consensus_set_id":"s391228","translation_language":"fa","translation_source":{"hid":"391228"},"segments":[{"source_hadith_segment":"وَ ذَكَرَ اَنَّ الْكِتَابَ يُصَدِّقُ بَعْضُهُ بَعْضاً وَ اَنَّهُ لاَ اِخْتِلاَفَ فِيهِ فَقَالَ سُبْحَانَهُ  <quranic_text> « وَ لَوْ كٰانَ مِنْ عِنْدِ غَيْرِ اللّٰهِ لَوَجَدُوا فِيهِ اِخْتِلاٰفاً كَثِيراً » </quranic_text>   <footnote> [ النساء ۸۲ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابَ"},{"kind":"word","token":"يصدق","display":"يُصَدِّقُ"},{"kind":"word","token":"بعضه","display":"بَعْضُهُ"},{"kind":"word","token":"بعضا","display":"بَعْضاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اختلاف","display":"اِخْتِلاَفَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"سبحانه","display":"سُبْحَانَهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عند","display":"عِنْدِ"},{"kind":"word","token":"غير","display":"غَيْرِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"لوجدوا","display":"لَوَجَدُوا"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"اختلافا","display":"اِخْتِلاٰفاً"},{"kind":"word","token":"كثيرا","display":"كَثِيراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۸۲","display":"۸۲"},{"kind":"tag_close","tag_name":"footnote"}]}]}