{"consensus_set_id":"116138","translation_language":"fa","translation_source":{"hid":"360141"},"segments":[{"source_hadith_segment":"<quranic_text> « اَلْهٰاكُمُ التَّكٰاثُرُ » </quranic_text>   <footnote> [ التكاثر ۱ ] </footnote>  يَقُولُ اِبْنُ ادَمَ مَالِي مَالِي وَ هَلْ لَكَ مِنْ مَالِكَ اِلاَّ مَا تَصَدَّقْتَ فَاَبْقَيْتَ اَوْ اَكَلْتَ فَاَفْنَيْتَ اَوْ لَبِسْتَ فَاَبْلَيْتَ .","translation_segment":"پیامبر (صلی الله علیه و آله) فرمود: زیاده‌طلبی، شما را به خود مشغول ساخته است، فرزند آدم، می‌گویی: مالم و ثروتم، آیا جز آنچه را که صدقه داده و باقی گذاری، یا بخوری و از بین ببری و یا بپوشی و مندرس کنی، مالک چیزی از مال خود هستی‌؟","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الهاكم","display":"اَلْهٰاكُمُ"},{"kind":"word","token":"التكاثر","display":"التَّكٰاثُرُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التكاثر","display":"التكاثر"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"ادم","display":"ادَمَ"},{"kind":"word","token":"مالي","display":"مَالِي"},{"kind":"word","token":"مالي","display":"مَالِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"مالك","display":"مَالِكَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"تصدقت","display":"تَصَدَّقْتَ"},{"kind":"word","token":"فابقيت","display":"فَاَبْقَيْتَ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"اكلت","display":"اَكَلْتَ"},{"kind":"word","token":"فافنيت","display":"فَاَفْنَيْتَ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"لبست","display":"لَبِسْتَ"},{"kind":