{"consensus_set_id":"175","translation_language":"fa","translation_source":{"hid":"332207"},"segments":[{"source_hadith_segment":"اَلصِّدِّيقُونَ ثَلاَثَةٌ :  حَبِيبٌ النَّجَّارُ مُؤْمِنُ الِ يَاسِينَ [ اَلَّذِي ] قَالَ :   <quranic_text> « يٰا قَوْمِ اِتَّبِعُوا الْمُرْسَلِينَ » </quranic_text>   <footnote> [ يس ۲۰ ] </footnote>","translation_segment":"عن ابی لیلی داود بن بلال قال: قال رسول الله صلی الله علیه و آله و سلم: الصدیقون ثلاثه: حبیب النجار مومن آل یاسین الذی قال: (یا قوم أتبعوا المرسلین) و حزقیل مومن آل فرعون و هو الذی قال: (أتقتلون رجلا","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"صلي","display":"صلى"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"واله","display":"وآله"},{"kind":"word","token":"صلي","display":"صلى"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"واله","display":"وآله"},{"kind":"word","token":"الصديقون","display":"اَلصِّدِّيقُونَ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةٌ"},{"kind":"word","token":"حبيب","display":"حَبِيبٌ"},{"kind":"word","token":"بن","display":"بن"},{"kind":"word","token":"مري","display":"مري"},{"kind":"word","token":"النجار","display":"النَّجَّارُ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنُ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"يس","display":"يس"},{"kind":"word","token":"ياسين","display":"يَاسِينَ"},{"kind":"word","token":"الذي","display":"اَلَّذِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"قوم","display":"قَوْمِ"},{"kind":"word","token":"اتبعوا","display":"اِتَّبِعُوا"},{"kind":"word","token":"المرسلين","display":"الْمُرْسَلِينَ"},{"kind":"tag_close","tag_name":"qur