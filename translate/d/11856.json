{"consensus_set_id":"11856","translation_language":"fa","translation_source":{"hid":"313757"},"segments":[{"source_hadith_segment":"لَمَّا اَرَادَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ الْخُرُوجَ مِنَ الْبَصْرَةِ اِسْتَخْلَفَ عَلَيْهَا عَبْدَ اللَّهِ بْنَ الْعَبَّاسِ","translation_segment":"ابن عباس والی بصره از جمله مسائلی که واقدی از قول رجال خود نقل می‌کند این است که چون امیر المومنین (علیه السلام)","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"اراد","display":"اَرَادَ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"وصيته","display":"وصيته"},{"kind":"word","token":"له","display":"له"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"الخروج","display":"الْخُرُوجَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"البصره","display":"الْبَصْرَةِ"},{"kind":"word","token":"استخلف","display":"اِسْتَخْلَفَ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"عبد","display":"عَبْدَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"العباس","display":"الْعَبَّاسِ"}]},{"source_hadith_segment":"وَ اَوْصَاهُ وَ كَانَ فِي وَصِيَّتِهِ لَهُ اَنْ قَالَ :  « يَا اِبْنَ عَبَّاسٍ عَلَيْكَ بِتَقْوَي اللَّهِ وَ الْعَدْلِ بِمَنْ وُلِّيتَ عَلَيْهِ وَ اَنْ تَبْسُطَ لِلنَّاسِ وَجْهَكَ وَ تُوَسِّعَ عَلَيْهِمْ مَجْلِسَكَ وَ تَسَعَهُمْ بِحِلْمِكَ وَ اِيَّاكَ وَ الْغَضَبَ فَاِنَّهُ طِيَرَةٌ مِنَ الشَّيْطَانِ وَ اِيَّاكَ وَ الْهَوَي فَاِنَّهُ يَصُدُّكَ عَنْ سَبِيلِ اللَّهِ وَ اِعْلَمْ اَنَّ مَا قَرَّبَكَ مِنَ اللَّهِ فَهُوَ مُبَاعِدُكَ مِنَ النَّارِ وَ مَا بَاعَدَكَ مِنَ اللَّهِ فَهُوَ مُقَرِّبُكَ مِنَ النَّارِ وَ اُذْكُرِ اللَّهَ كَثِيراً  <quranic_text> « وَ لاٰ تَكُنْ مِنَ الْغٰافِلِينَ » </quranic_text>   <footnote> [ الاعراف ۲۰۵ ] </footnote>   .","translation_segment":"خواست از بصره برود، عبد الله بن عباس را به حکومت آن شهر گماشت و او را سفارش کرد و اندرز داد و از جمله با او چنین فرمود: «ای ابن عباس! بر تو باد بیم از خداوند و رعایت عدل نسبت به کسانی که بر آنان ولایت داری؛ و بر مردم چهره گشوده داشته باش و مجلس خویش را بر آنان گشاده دار و بردبار باش و از خشم بر حذر باش که سبک مغزی شیطان است، و از هوای نفس بپرهیز که تو را از راه حق بازمی‌دارد و بدان آنچه تو را به خداوند نزدیک کند تو را از آتش دور کند و آنچه تو را از خدا دور می‌کند به آتش نزدیک می‌سازد و خدا را بسیار یاد کن و از غافلان مباش.»","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اوصاه","display":"اَوْصَاهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"وصيته","display":"وَصِيَّتِهِ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"عباس","display":"عَبَّاسٍ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"},{"kind":"word","token":"بتقوي","display":"بِتَقْوَي"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"العدل","display":"الْعَدْلِ"},{"kind":"word","token":"بمن","display":"بِمَنْ"},{"kind":"word","token":"وليت","display":"وُلِّيتَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تبسط","display":"تَبْسُطَ"},{"kind":"word","token":"للناس","display":"لِلنَّاسِ"},{"kind":"word","token":"وجهك","display":"وَجْهَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"توسع","display":"تُوَسِّعَ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"مجلسك","display":"مَجْلِ