ment":"","segment_columns":[]},{"source_hadith_segment":"<quranic_text> « وَ مِنْهُمْ مَنْ يَقُولُ اِئْذَنْ لِي وَ لاٰ تَفْتِنِّي اَلاٰ فِي الْفِتْنَةِ سَقَطُوا - وَ اِنَّ جَهَنَّمَ لَمُحِيطَةٌ بِالْكٰافِرِينَ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ التوبة ۴۹ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ثُمَّ قَالَ الْجَدُّ بْنُ الْقَيْسِ اَ يَطْمَعُ مُحَمَّدٌ اَنَّ حَرْبَ الرُّومِ مِثْلُ حَرْبِ غَيْرِهِمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  لاَ يَرْجِعُ مِنْ هَؤُلاَءِ اَحَدٌ اَبَداً .","translation_segment":"","segment_columns":[]}]}