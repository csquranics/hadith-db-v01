{"consensus_set_id":"s404916","translation_language":"fa","translation_source":{"hid":"404916"},"segments":[{"source_hadith_segment":"وَ مَا اَجَابَ بِهِ اَبُو الْحَسَنِ عَلِيُّ بْنُ مُحَمَّدٍ الْعَسْكَرِيُّ ( عَلَيْهِ السَّلاَمُ ) فِي رِسَالَتِهِ اِلَي اَهْلِ الْاَهْوَازِ حِينَ سَاَلُوهُ عَنِ الْجَبْرِ وَ التَّفْوِيضِ اَنْ قَالَ :","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اجاب","display":"اَجَابَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"العسكري","display":"الْعَسْكَرِيُّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"رسالته","display":"رِسَالَتِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الاهواز","display":"الْاَهْوَازِ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"سالوه","display":"سَاَلُوهُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الجبر","display":"الْجَبْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"التفويض","display":"التَّفْوِيضِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« اِجْتَمَعَتِ الْاُمَّةُ قَاطِبَةً ،  لاَ اِخْتِلاَفَ بَيْنَهُمْ فِي ذَلِكَ ،  اَنَّ الْقُرْانَ حَقٌّ لاَ رَيْبَ فِيهِ عِنْدَ جَمِيعِ فِرَقِهَا ،  فَهُمْ فِي حَالَةِ الاِجْتِمَاعِ عَلَيْهِ مُصِيبُونَ ،  وَ عَلَي تَصْدِيقِ مَا اَنْزَلَ اللَّهُ مُهْتَدُونَ ،  لِقَوْلِ النَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :  لاَ تَجْتَمِعُ اُمَّتِي عَلَي ضَلاَلَةٍ .  فَاَخْبَرَ ( عَلَيْهِ السَّلاَمُ ) اَنَّ مَا اِجْتَمَعَتْ عَلَيْهِ الْاُمَّةُ ،  وَ لَمْ يُخَالِفْ بَعْضُهَا بَعْضاً ،  هُوَ الْحَقُّ ،  فَهَذَا مَعْنَي الْحَدِيثِ ،  لاَ مَا تَاَوَّلَهُ الْجَاهِلُونَ ،  وَ لاَ مَا قَالَهُ الْمُعَانِدُونَ ،  مِنْ اِبْطَالِ حُكْمِ الْكِتَابِ ،  وَ اِتِّبَاعِ اَحْكَامِ الْاَحَادِيثِ الْمُزَوَّرَةِ ،  وَ الرِّوَايَاتِ الْمُزَخْرَفَةِ ،  وَ اِتِّبَاعِ الْاَهْوَاءِ الْمُرْدِيَةِ الْمُهْلِكَةِ ،  الَّتِي تُخَالِفُ نَصَّ الْكِتَابِ ،  وَ تَحْقِيقَ الْايَاتِ الْوَاضِحَاتِ النَّيِّرَاتِ ،  وَ نَحْنُ نَسْاَلُ اللَّهَ اَنْ يُوَفِّقَنَا لِلصَّوَابِ ،  وَ يَهْدِيَنَا اِلَي الرَّشَادِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"اجتمعت","display":"اِجْتَمَعَتِ"},{"kind":"word","token":"الامه","display":"الْاُمَّةُ"},{"kind":"word","token":"قاطبه","display":"قَاطِبَةً"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اختلاف","display":"اِخْتِلاَفَ"},{"kind":"word","token":"بينهم","display":"بَيْنَهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"القران","display":"الْقُرْانَ"},{"kind":"word","token":"حق","display":"حَقٌّ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ريب","display":"رَيْبَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"جميع","display":"جَمِيعِ"},{"kind":"word","token":"فرقها","display":"فِرَقِهَا"},{"kind":"word","token":"فهم","display":"فَهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"حاله","display":"حَالَةِ"},{"kind":"word","token":"الاجتماع","display":"الاِجْتِمَاعِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"مصيبون","display":"مُصِيبُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"تصديق","display":"