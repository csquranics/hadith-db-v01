{"consensus_set_id":"96760","translation_language":"fa","translation_source":{"hid":"325234"},"segments":[{"source_hadith_segment":"ذَكَرَ فِي قَوْلِ اللَّهِ تَبَارَكَ وَ تَعَالَي  <quranic_text> « تُسْقيٰ مِنْ عَيْنٍ انِيَةٍ » </quranic_text>   <footnote> [ الغاشية ۵ ] </footnote>  قَالَ يُسْمَعُ لَهَا اَنِينٌ مِنْ شِدَّةِ حَرِّهَا .","translation_segment":"عاصم بن سلیمان سخن خداوند متعال را: «از چشمه‌ای بسیار داغ به (گنهکاران) نوشانده می‌شود» متذکر شد و اظهار داشت که از سختی حرارتش ناله‌اش شنیده شود.","segment_columns":[{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"تسقي","display":"تُسْقيٰ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عين","display":"عَيْنٍ"},{"kind":"word","token":"انيه","display":"انِيَةٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الغاشيه","display":"الغاشية"},{"kind":"word","token":"۵","display":"۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يسمع","display":"يُسْمَعُ"},{"kind":"word","token":"لها","display":"لَهَا"},{"kind":"word","token":"انين","display":"اَنِينٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شده","display":"شِدَّةِ"},{"kind":"word","token":"حرها","display":"حَرِّهَا"}]}]}