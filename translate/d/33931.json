{"consensus_set_id":"33931","translation_language":"fa","translation_source":{"hid":"312690"},"segments":[{"source_hadith_segment":"مَنِ اُبْتُلِيَ فَصَبَرَ وَ اُعْطِيَ فَشَكَرَ وَ ظُلِمَ فَغَفَرَ وَ ظَلَمَ فَاسْتَغْفَرَ قَالُوا مَا بَالُهُ قَالَ اُولَئِكَ لَهُمُ [ اَلْاَمْنُ ] مِنَ الْعَذَابِ وَ هُمْ مُهْتَدُونَ .","translation_segment":"و فرمود پیغمبر (صلی الله علیه و آله) که هر که مبتلا شود پس صبر کند و عطا کرده شود پس شکر کند و ظلم کرده شود پس بپوشد و ظلم کند پس توبه کند عرضکردند چیست یا رسول اللٰه جزای او فرمود ایشان راست ایمنی و ایشان راه‌یافته‌شدگانند","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"صلي","display":"صلى"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"وسلم","display":"وسلم"},{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"ابتلي","display":"اُبْتُلِيَ"},{"kind":"word","token":"فصبر","display":"فَصَبَرَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعطي","display":"اُعْطِيَ"},{"kind":"word","token":"فشكر","display":"فَشَكَرَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ظلم","display":"ظُلِمَ"},{"kind":"word","token":"فغفر","display":"فَغَفَرَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ظلم","display":"ظَلَمَ"},{"kind":"word","token":"فاستغفر","display":"فَاسْتَغْفَرَ"},{"kind":"word","token":"ثم","display":"ثم"},{"kind":"word","token":"شكر","display":"شكر"},{"kind":"word","token":"ثم","display":"ثم"},{"kind":"word","token":"سكت","display":"سكت"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"له","display":"له"},{"kind":"word","token":"يا","display":"يا"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"باله