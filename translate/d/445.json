هد. امام باقر علیه السلام فرمود: پسرم! آرام باش! عرض کردم: چرا؟ فرمود: خداوند متعال","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"علمت","display":"عَلِمْتَ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"يشرب","display":"يَشْرَبُ"},{"kind":"word","token":"الخمر","display":"الْخَمْرَ"},{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"بلغني","display":"بَلَغَنِي"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"انهم","display":"اَنَّهُمْ"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"صدقهم","display":"صَدِّقْهُمْ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يؤمن","display":"يُؤْمِنُ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يؤمن","display":"يُؤْمِنُ"},{"kind":"word","token":"للمؤمنين","display":"لِلْمُؤْمِنِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۶۱","display":"۶۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":