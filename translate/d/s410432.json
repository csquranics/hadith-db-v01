{"consensus_set_id":"s410432","translation_language":"fa","translation_source":{"hid":"410432"},"segments":[{"source_hadith_segment":"تَفْسِيرِ حُرُوفِ الْمُعْجَمِ - قَالَ :  « فَالْمِيمُ مُلْكُ اللَّهِ [ يَوْمُ الدِّينِ ] يَوْمٌ لاَ مَالِكَ غَيْرُهُ ،  وَ يَقُولُ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « لِمَنِ الْمُلْكُ الْيَوْمَ » </quranic_text>   <footnote> [ غافر ۱۶ ] </footnote>   ،  ثُمَّ تَنْطِقُ اَرْوَاحُ اَنْبِيَائِهِ وَ رُسُلِهِ وَ حُجَجِهِ ،  فَيَقُولُونَ :   <quranic_text> « لِلّٰهِ الْوٰاحِدِ الْقَهّٰارِ » </quranic_text>   <footnote> [ غافر ۱۶ ] </footnote> ،  فَيَقُولُ جَلَّ جَلاَلُهُ :   <quranic_text> « الْيَوْمَ تُجْزيٰ كُلُّ نَفْسٍ بِمٰا كَسَبَتْ لاٰ ظُلْمَ الْيَوْمَ اِنَّ اللّٰهَ سَرِيعُ الْحِسٰابِ » </quranic_text>   <footnote> [ غافر ۱۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"حروف","display":"حُرُوفِ"},{"kind":"word","token":"المعجم","display":"الْمُعْجَمِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فالميم","display":"فَالْمِيمُ"},{"kind":"word","token":"ملك","display":"مُلْكُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"يوم","display":"يَوْمُ"},{"kind":"word","token":"الدين","display":"الدِّينِ"},{"kind":"word","token":"يوم","display":"يَوْمٌ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"مالك","display":"مَالِكَ"},{"kind":"word","token":"غيره","display":"غَيْرُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لمن","display":"لِمَنِ"},{"kind":"word","token":"الملك","display":"الْمُلْكُ"},{"kind":"word","token":"ال