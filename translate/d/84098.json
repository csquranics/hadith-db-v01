,"translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كَانَ عَلَيْهِ السَّلاَمُ يَجْهَرُ بِ‍  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  فِي جَمِيعِ صَلَوَاتِهِ بِاللَّيْلِ وَ النَّهَارِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كَانَ اِذَا قَرَاَ  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>  قَالَ سِرّاً اللَّهُ اَحَدٌ فَاِذَا فَرَغَ مِنْهَا قَالَ كَذَلِكَ اللَّهُ رَبُّنَا ثَلاَثاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كَانَ اِذَا قَرَاَ  <quranic_text> « قُلْ يٰا اَيُّهَا الْكٰافِرُونَ » </quranic_text>   <footnote> [ الكافرون ۱ ] </footnote>  قَالَ فِي نَفْسِهِ سِرّاً يَا اَيُّهَا الْكَافِرُونَ فَاِذَا فَرَغَ مِنْهَا قَالَ رَبِّيَ اللَّهُ وَ دِينِيَ الْاِسْلاَمُ ثَلاَثاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كَانَ اِذَا قَرَاَ وَ التِّينِ وَ الزَّيْتُونِ قَالَ عِنْدَ الْفَرَاغِ مِنْهَا بَلَي وَ اَنَا عَلَي ذَلِكَ مِنَ الشَّاهِدِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كَانَ اِذَا قَرَاَ لاَ اُقْسِمُ بِيَوْمِ الْقِيَامَةِ قَالَ عِنْدَ الْفَرَاغِ مِنْهَا سُبْحَانَكَ اللَّهُمَّ بَلَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كَانَ يَقْرَاُ فِي سُورَةِ الْجُمُعَةِ :   <quranic_text> « قُلْ مٰا عِنْدَ اللّٰهِ خَيْرٌ مِنَ اللَّهْوِ وَ مِنَ التِّجٰارَةِ » </quranic_text>   <footnote> [ الجمعة ۱۱ ] </footnote>  لِلَّذِينَ اِتَّقَوْا  <quranic_text> « وَ اللّٰهُ خَيْرُ الرّٰازِقِينَ » </quranic_text>   <footnote> [ الجمعة ۱۱ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كَانَ اِذَا فَرَغَ مِنَ الْفَاتِحَةِ قَالَ :   <quranic_text> « الْحَمْدُ لِلّٰهِ رَبِّ الْعٰالَمِينَ » </quranic_text>   <footnote> [ الفاتحة ۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاِذَا قَرَاَ سَبِّحِ اِسْمَ رَبِّكَ الْاَعْلَي قَالَ سِرّاً سُبْحَانَ رَبِّيَ الْاَعْلَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ اِذَا قَرَاَ  <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا » </quranic_text>   <footnote> [ البقرة ۱۰۴ ] </footnote>  قَالَ لَبَّيْكَ اللَّهُمَّ لَبَّيْكَ سِرّاً .","translation_segment":"","segment_columns":[]}]}