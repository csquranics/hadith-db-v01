{"consensus_set_id":"2492","translation_language":"fa","translation_source":{"hid":"99631"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « كَذٰلِكَ يُرِيهِمُ اللّٰهُ اَعْمٰالَهُمْ حَسَرٰاتٍ عَلَيْهِمْ » </quranic_text>   <footnote> [ البقرة ۱۶۷ ] </footnote>","translation_segment":"و امام صادق علیه السلام در معنی قول خدای عز و جل‌ «کذلک یریهم اللٰه اعمالهم حسرات علیهم» فرمود: این همان کسی است که مال خود را بجا میگذارد، و در اثر","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كذلك","display":"كَذٰلِكَ"},{"kind":"word","token":"يريهم","display":"يُرِيهِمُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"اعمالهم","display":"اَعْمٰالَهُمْ"},{"kind":"word","token":"حسرات","display":"حَسَرٰاتٍ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۶۷","display":"۱۶۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ « هُوَ الرَّجُلُ يَدَعُ مَالَهُ لاَ يُنْفِقُهُ فِي طَاعَةِ اللَّهِ عَزَّ وَ جَلَّ بُخْلاً ثُمَّ يَمُوتُ فَيَدَعُهُ لِمَنْ يَعْمَلُ فِيهِ بِطَاعَةِ اللَّهِ عَزَّ وَ جَلَّ اَوْ بِمَعْصِيَةِ اللَّهِ فَاِنْ عَمِلَ فِيهِ بِطَاعَةِ اللَّهِ رَاهُ فِي مِيزَانِ غَيْرِهِ فَرَاهُ حَسْرَةً وَ قَدْ كَانَ الْمَالُ لَهُ وَ اِنْ كَانَ عَمِلَ فِيهِ بِمَعْصِيَةِ اللَّهِ عَزَّ وَ جَلَّ قَوَّاهُ بِذَلِكَ الْمَالِ حَتَّي عَمِلَ بِهِ فِي مَعْصِيَةِ اللَّهِ عَزَّ وَ جَلَّ »","translation_segment":"بخل در راه طاعت خدای عز