{"consensus_set_id":"8748","translation_language":"fa","translation_source":{"hid":"449505"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ جُعِلْتُ فِدَاكَ يَا اِبْنَ رَسُولِ اللَّهِ هَلْ يُكْرَهُ","translation_segment":"سدیر گفت: به امام صادق علیه السلام عرض کردم: فدایت شوم ای پسر رسول خدا، آیا مومن از مردن (قبض روحش) کراهت دارد؟","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"جعلت","display":"جُعِلْتُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"يكره","display":"يُكْرَهُ"}]},{"source_hadith_segment":"الْمُؤْمِنُ عَلَي قَبْضِ رُوحِهِ قَالَ لاَ اِذَا اَتَاهُ مَلَكُ الْمَوْتِ لِيَقْبِضَ رُوحَهُ جَزِعَ عِنْدَ ذَلِكَ فَيَقُولُ لَهُ مَلَكُ الْمَوْتِ يَا وَلِيَّ اللَّهِ لاَ تَجْزَعْ فَوَ الَّذِي بَعَثَ مُحَمَّداً بِالْحَقِّ لَاَنَا اَبَرُّ بِكَ وَ اَشْفَقُ عَلَيْكَ مِنَ الْوَالِدِ الرَّحِيمِ لِوَلَدِهِ حِينَ حَضَرَهُ اِفْتَحْ عَيْنَيْكَ وَ اُنْظُرْ قَالَ وَ يُمَثَّلُ لَهُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ اَمِيرُ الْمُؤْمِنِينَ وَ فَاطِمَةُ وَ الْحَسَنُ وَ الْحُسَيْنُ وَ الْاَئِمَّةُ هُمْ رُفَقَاؤُكَ قَالَ فَيَفْتَحُ عَيْنَيْهِ وَ يَنْظُرُ وَ تُنَادَي رُوحُهُ مِنْ قِبَلِ الْعَرْشِ يَا اَيَّتُهَا النَّفْسُ الْمُطْمَئِنَّةُ اِرْجِعِي اِلَي مُحَمَّدٍ وَ اَهْلِ بَيْتِهِ وَ اُدْخُلِي جَنَّتِي قَالَ فَمَا مِنْ شَيْءٍ اَحَبَّ اِلَيْهِ مِنِ اِنْسِلاَلِ رُوحِهِ وَ اللُّحُوقِ بِالْمُنَادِي .","translation_segment":"فرمود: نه، [بلکه] آن زمان که ملک الموت برای قبض روح مومن می‌آید، مومن بی‌تابی می‌کند. ملک الموت به او می‌گوید: ای ولی‌ خدا، بی‌تابی مکن. سوگند به آن خدایی که محمد صلی اللٰه علیه و آله و سلم را به حق‌ به پیامبری مبعوث فرمود، من نسبت به تو، از پدری مهربان نسبت به فرزندش، دلسوزتر و نیکوکارترم. چشمهایت را باز کن و ببین. [در این هنگام] وجود مبارک رسول خدا صلی اللٰه علیه و آله و سلم، امیر المومنین علیه السلام، فاطمه زهرا علیها السلام، امام حسن مجتبی و امام حسین علیهما السلام و سایر ائمه هدی علیهم السلام برایش نمایان می‌شوند و به او گفته می‌شود اینها دوستان تو هستند. پس چشمهایش را می‌گشاید و می‌نگرد و به روحش از جانب عرش ندا داده می‌شود: «ای [صاحب] نفس مطمئنه، به سوی محمد و اهل بیت آن حضرت صلوات اللٰه علیه و آله و سلم باز گرد و به بهشتم داخل شو». [در این لحظه] برای مومن، چیزی خوشایندتر از این نیست که روح از بدنش خارج شود و به آن منادی بپیوندد.","segment_columns":[{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"قبض","display":"قَبْضِ"},{"kind":"word","token":"روحه","display":"رُوحِهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"انه","display":"انّه"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اتاه","display":"اَتَاهُ"},{"kind":"word","token":"ملك","display":"مَلَكُ"},{"kind":"word","token":"الموت","display":"الْمَوْتِ"},{"kind":"word","token":"ليقبض","display":"لِيَقْبِضَ"},{"kind":"word","token":"روحه","display":"رُوحَهُ"},{"kind":"word","token":"جزع","display":"جَزِعَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"فيقول","display":"فَيَقُولُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ملك","display":"مَلَكُ"},