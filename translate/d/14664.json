{"consensus_set_id":"14664","translation_language":"fa","translation_source":{"hid":"408765"},"segments":[{"source_hadith_segment":"،  عَنْ اَبِيهِ ( عَلَيْهِمَا السَّلاَمُ ) ،  عَنِ النَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  قَالَ :","translation_segment":"","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« مِمَّا اَعْطَي اللَّهُ اُمَّتِي وَ فَضَّلَهُمْ بِهِ عَلَي سَائِرِ الْاُمَمِ ،  اَعْطَاهُمْ ثَلاَثَ خِصَالٍ لَمْ يُعْطَهَا اِلاَّ نَبِيٌّ ،  وَ ذَلِكَ اَنَّ اللَّهَ تَبَارَكَ وَ تَعَالَي كَانَ اِذَا بَعَثَ نَبِيّاً ،  قَالَ لَهُ :  اِجْتَهِدْ فِي دِينِكَ ،  وَ لاَ حَرَجَ عَلَيْكَ ،  وَ اِنَّ اللَّهَ تَبَارَكَ وَ تَعَالَي اَعْطَي ذَلِكَ اُمَّتِي ،  حَيْثُ يَقُولُ :   <quranic_text> « مٰا جَعَلَ عَلَيْكُمْ فِي الدِّينِ مِنْ حَرَجٍ » </quranic_text>   <footnote> [ الحج ۷۸ ] </footnote>  يَقُولُ : مِنْ ضِيقٍ .  وَ كَانَ اِذَا بَعَثَ نَبِيّاً قَالَ لَهُ :  اِذَا اَحْزَنَكَ اَمْرٌ تَكْرَهُهُ فَادْعُنِي ،  اَسْتَجِبْ لَكَ ؛  وَ اِنَّهُ اَعْطَي اُمَّتِي ذَلِكَ ،  حَيْثُ يَقُولُ :   <quranic_text> « اُدْعُونِي اَسْتَجِبْ لَكُمْ » </quranic_text>   <footnote> [ غافر ۶۰ ] </footnote> .  وَ كَانَ اِذَا بَعَثَ نَبِيّاً جَعَلَهُ شَهِيداً عَلَي قَوْمِهِ ،  وَ اِنَّ اللَّهَ تَبَارَكَ وَ تَعَالَي جَعَلَ اُمَّتِي شُهَدَاءَ عَلَي الْخَلْقِ ،  حَيْثُ يَقُولُ :   <quranic_text> « لِيَكُونَ الرَّسُولُ شَهِيداً عَلَيْكُمْ وَ تَكُونُوا شُهَدٰ