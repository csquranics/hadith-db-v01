{"consensus_set_id":"51473","translation_language":"fa","translation_source":{"hid":"313994"},"segments":[{"source_hadith_segment":"اَنَّ اِبْنَ الْكَوَّاءِ قَالَ لِعَلِيٍّ عَلَيْهِ السَّلاَمُ بِمَا كُنْتَ وَصِيَّ مُحَمَّدٍ مِنْ بَيْنِ بَنِي عَبْدِ الْمُطَّلِبِ قَالَ اُدْنُ مَا الْخَيْرَ تُرِيدُ","translation_segment":"ابن کواء به علی-علیه السلام-گفت: برای چه از میان فرزندان عبد المطلب، تو وصی پیامبر شده‌ای‌؟ علی-علیه السلام-فرمود:","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"الكواء","display":"الْكَوَّاءِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لعلي","display":"لِعَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"كنت","display":"كُنْتَ"},{"kind":"word","token":"وصي","display":"وَصِيَّ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بين","display":"بَيْنِ"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"المطلب","display":"الْمُطَّلِبِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ادن","display":"اُدْنُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"الخير","display":"الْخَيْرَ"},{"kind":"word","token":"تريد","display":"تُرِيدُ"}]},{"source_hadith_segment":"لَمَّا نَزَلَ عَلَي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  <quranic_text> « وَ اَنْذِرْ عَشِيرَتَكَ الْاَقْرَبِينَ » </quranic_text>   <footnote> [ الشعراء ۲۱۴ ] </footnote>  جَمَعَنَا رَسُولُ اللَّهِ وَ نَحْنُ اَرْبَعُونَ رَجُلاً فَاَمَرَنِي فَاَنْضَجْتُ لَهُ رِجْلَ شَاةٍ وَ صَاعاً مِنْ طَعَامٍ اَمَرَنِي فَطَحَنْتُهُ وَ خَبَزْتُهُ وَ اَمَرَنِي فَاَدْنَيْتُهُ ثُمَّ قَالَ فَقَالَ تَقَدَّمَ عَلَيَّ عَشَرَةٌ عَشَرَةٌ مِنْ اَجِلَّتِهِمْ فَاَكَلُوا حَتَّي صَدَرُوا وَ بَقِيَ الطَّعَامُ كَمَا كَانَ وَ اِنَّ مِنْهُمْ لَمَنْ يَاْكُلُ الْجَذَعَةَ وَ يَشْرَبُ الْفَرَقَ فَاَكَلُوا مِنْهَا كُلُّهُمْ اَجْمَعُونَ فَقَالَ","translation_segment":"می‌خواهی تو را خبر دهم. هنگامی که آیه «و أنذر عشیرتک‌ الأقربین‌» نازل شد، من و رسول خدا-صلی اللٰه علیه و آله-چهل مرد را دعوت کردیم و پیامبر به من دستور داد ران گوسفندی را پختم. و یک صاع نیز نان آماده کردم و آوردم. آن حضرت، نزد هر ده نفر، قسمتی از آن غذا را گذاشت، همه خوردند و سیر شدند اما غذا همان گونه ماند. بعد، ابو لهب گفت: او شما را سحر کرد. آنگاه همه متفرق شدند. بار دوم آنها را دعوت کرد و فرمود: «هر یک از شما دعوتم","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انذر","display":"اَنْذِرْ"},{"kind":"word","token":"عشيرتك","display":"عَشِيرَتَكَ"},{"kind":"word","token":"الاقربين","display":"الْاَقْرَبِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الشعراء","display":"الشعراء"},{"kind":"word","token":"۲۱۴","display":"۲۱۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"جمعنا","display":"جَمَعَنَا"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","dis