{"consensus_set_id":"104193","translation_language":"fa","translation_source":{"hid":"90003"},"segments":[{"source_hadith_segment":"سَاَلَهُ اَبُو حَارِثٍ عَنْ رَجُلٍ  <quranic_text> « تَمَتَّعَ بِالْعُمْرَةِ اِلَي الْحَجِّ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  فَطَافَ وَ سَعَي وَ قَصَّرَ هَلْ عَلَيْهِ طَوَافُ النِّسَاءِ قَالَ « لاَ اِنَّمَا طَوَافُ النِّسَاءِ بَعْدَ الرُّجُوعِ مِنْ مِنًي » .","translation_segment":"* *۲۲ - از ابو الحسن الرضا علیه السلام پرسید: اگر کسی عمره تمتع بجا آورد، بعد از طواف و سعی و تقصیر باید طواف نساء بجا آورد؟ ابو الحسن گفت: نه. طواف نساء را باید بعد از مراجعت از منی انجام دهد.","segment_columns":[{"kind":"word","token":"ساله","display":"سَاَلَهُ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"حارث","display":"حَارِثٍ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"تمتع","display":"تَمَتَّعَ"},{"kind":"word","token":"بالعمره","display":"بِالْعُمْرَةِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۶","display":"۱۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فطاف","display":"فَطَافَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سعي","display":"سَعَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قصر","display":"قَصَّرَ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"طواف","display":"طَوَافُ"},{"kind":"word","token":"النساء","display":"النِّسَاءِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"ط