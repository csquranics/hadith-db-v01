{"consensus_set_id":"57201","translation_language":"fa","translation_source":{"hid":"373624"},"segments":[{"source_hadith_segment":"<quranic_text> « مَنْ كٰانَ يُؤْمِنُ بِاللّٰهِ وَ الْيَوْمِ الْاخِرِ » </quranic_text>   <footnote> [ الطلاق ۲ ] </footnote>  فَلْيَكْتَحِلْ وَ قَالَ وَ عَلَيْكَ بِالْاِثْمِدِ فَاِنَّهُ يَجْلُو الْبَصَرَ وَ يُنْبِتُ الْاَشْفَارَ وَ يُطَيِّبُ النَّكْهَةَ وَ يَزِيدُ فِي الْبَاهِ .","translation_segment":"و نیز از آن حضرت است که هر کس بخدا و آخرت ایمان دارد حتما سرمه بکشد. و نیز فرمود: بر تو باد به سرمه که چشم را جلا می‌دهد و مژگان را می‌رویاند و دهان را خوشبو می‌کند و بر نیروی باه می‌افزاید.","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"يؤمن","display":"يُؤْمِنُ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اليوم","display":"الْيَوْمِ"},{"kind":"word","token":"الاخر","display":"الْاخِرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الطلاق","display":"الطلاق"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فليكتحل","display":"فَلْيَكْتَحِلْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"},{"kind":"word","token":"بالاثمد","display":"بِالْاِثْمِدِ"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"يجلو","display":"يَجْلُو"},{"kind":"word","token":"البصر","display":"الْبَصَرَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ينبت","display":"يُنْبِتُ"},{"kind":"word","token":"الاشفار","display":"الْاَشْفَارَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يطيب","display":"يُطَيِّبُ"},{"kind":"word","