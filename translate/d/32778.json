{"consensus_set_id":"32778","translation_language":"fa","translation_source":{"hid":"404379"},"segments":[{"source_hadith_segment":"« مَا سُئِلَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) شَيْئاً قَطُّ فَقَالَ :  لاَ ،  اِنْ كَانَ عِنْدَهُ اَعْطَاهُ ،  وَ اِنْ لَمْ يَكُنْ عِنْدَهُ قَالَ :  يَكُونُ اِنْ شَاءَ اللَّهُ ،  وَ لاَ كَافَاَ بِالسَّيِّئَةِ قَطُّ ،  وَ مَا لَقِيَ سَرِيَّةً مُذْ نَزَلَتْ عَلَيْهِ <quranic_text> « فَقٰاتِلْ فِي سَبِيلِ اللّٰهِ لاٰ تُكَلَّفُ اِلاّٰ نَفْسَكَ » </quranic_text>   <footnote> [ النساء ۸۴ ] </footnote> اِلاَّ وَلِيَ بِنَفْسِهِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"السلام","display":"السَّلامُ"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"قط","display":"قَطُّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"اعطاه","display":"اَعْطَاهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"شاء","display":"شَاءَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"