{"consensus_set_id":"s73228","translation_language":"fa","translation_source":{"hid":"73228"},"segments":[{"source_hadith_segment":"،  قال :  قال رسول اللّه صلّي اللّه عليه و اله  :","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"صلي","display":"صلّي"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"}]},{"source_hadith_segment":"« قال العزيز الرحيم جلّ ذكره : <quranic_text> « امَنَ الرَّسُولُ بِمٰا اُنْزِلَ اِلَيْهِ مِنْ رَبِّهِ » </quranic_text>   <footnote> [ البقرة ۲۸۵ ] </footnote>   ،  قلت : <quranic_text> « وَ الْمُؤْمِنُونَ » </quranic_text>   <footnote> [ البقرة ۲۸۵ ] </footnote>   ،  قال : صدقت يا محمّد  ،  عليك منّي السلام ،  من خلفت لامّتك من بعدك ؟  قلت :  قد علمت يا ربّ خيرها اهلا ،  قال :  عليّ بن ابي طالب  ؟  قلت : نعم يا ربّ ،  قال : يا محمّد  ،  انّي اطلعت الي الارض اطلاعة فاخترتك منها ،  و شققت لك اسما من اسمائي ،  فانا المحمود و انت محمّد  ،  لا اذكره الاّ ذكرتك معي ،  ثمّ اطلعت اطلاعة فاخترت منها عليّا و فاطمة و الحسن و الحسين اشباح من نوري ،  فعرضت ولايتهم علي السماوات و الارض و اهلها ،  فمن قبلها كان عندي من المقرّبين ،  و من جحدها كان عندي من الكافرين ؛  يا محمّد  ،  لو انّ عبدا عبدني حتّي ينقطع صلبه او يصير كالشّنّ البالي ثمّ اتاني جاحدا لولايتهم لاكببته علي منخريه في النار ؛  يا محمّد  ،  ا تحبّ ان تراهم ؟  قلت : نعم يا ربّ ،  قال : التفت علي يمين العرش ،  فاذا اشباح نور ،  و اذا عليّ و فاطمة و الحسن و الحسين و تسعة من ولد الحسين  ،  حتّي بلغ المهديّ و هو في ضحضاح نورهم ،  قيام يصلّون و المهديّ في وسطهم كانّه كوكب درّيّ ؛  فقال :  يا محمّد  ،  هؤلاء الحجج علي خلقي ،  و هذا الثائر من عترتك  ؛  و عزّتي و جلالي انّه الحجّة الواجبة علي خلقي فاتيهم بذلك ،  و هو المنتقم من اعدائي »","translation_segment":"","