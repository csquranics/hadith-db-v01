{"consensus_set_id":"62158","translation_language":"fa","translation_source":{"hid":"85932"},"segments":[{"source_hadith_segment":"قُلْتُ لَهُ  <quranic_text> « اَلْمُسْتَغْفِرِينَ بِالْاَسْحٰارِ » </quranic_text>   <footnote> [ العمران ۱۷ ] </footnote>  فَقَالَ « اِسْتَغْفَرَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فِي وَتْرِهِ سَبْعِينَ مَرَّةً » .","translation_segment":"* *۲۶۹ - به ابو عبد الله صادق (ع) گفتم: خداوند عزت می‌گوید: «و آنان که در پایان شب از گناهان خود استغفار می‌کنند». آیا استغفار در سحر حد معینی دارد؟ ابو عبد الله گفت: رسول خدا در نماز وتر هفتاد نوبت استغفار کرد و این سنت بر جا ماند.","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"المستغفرين","display":"اَلْمُسْتَغْفِرِينَ"},{"kind":"word","token":"بالاسحار","display":"بِالْاَسْحٰارِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"استغفر","display":"اِسْتَغْفَرَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"وتره","display":"وَتْرِهِ"},{"kind":"word","token":"سبعين","display":"سَبْعِينَ"},{"kind":"word","token":"مره","display":"مَرَّةً"}]}]}