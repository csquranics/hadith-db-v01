{"consensus_set_id":"s350862","translation_language":"fa","translation_source":{"hid":"350862"},"segments":[{"source_hadith_segment":"اِنَّ نُوحاً لَبِثَ فِي قَوْمِهِ  <quranic_text> « اَلْفَ سَنَةٍ اِلاّٰ خَمْسِينَ عٰاماً » </quranic_text>   <footnote> [ العنكبوت ۱۴ ] </footnote>  يَدْعُوهُمْ اِلَي اللَّهِ تَعَالَي فَلاَ يَزْدَادُونَ اِلاَّ طُغْيَاناً وَ مَضَي ثَلاَثَةُ قُرُونٍ مِنْ قَوْمِهِ وَ كَانَ الرَّجُلُ مِنْهُمْ يَاْتِي بِابْنِهِ وَ هُوَ صَغِيرٌ فَيُوقِفُهُ عَلَي","translation_segment":"راوندی در قصص الانبیاء نقل نموده است که شیخ صدوق از وهب روایت نموده است: نوح نهصد و پنجاه سال در میان مردمش دعوت به خداپرستی نمود. اما دعوت او ثمری جز سرکشی قومش نداشت؛ آنگونه که مردان بالای سر [بدن زخمی] نوح گرد می‌آمدند و","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"نوحا","display":"نُوحاً"},{"kind":"word","token":"لبث","display":"لَبِثَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قومه","display":"قَوْمِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الف","display":"اَلْفَ"},{"kind":"word","token":"سنه","display":"سَنَةٍ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"خمسين","display":"خَمْسِينَ"},{"kind":"word","token":"عاما","display":"عٰاماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العنكبوت","display":"العنكبوت"},{"kind":"word","token":"۱۴","display":"۱۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يدعوهم","display":"يَدْعُوهُمْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"يزدادون","display":"يَزْدَادُونَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"طغيانا","display":"طُغْيَاناً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","toke