{"consensus_set_id":"s331849","translation_language":"fa","translation_source":{"hid":"331849"},"segments":[{"source_hadith_segment":"قَرَاَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :   <quranic_text> « فِي بُيُوتٍ اَذِنَ اللّٰهُ اَنْ تُرْفَعَ وَ يُذْكَرَ » </quranic_text>   <footnote> [ النور ۳۶ ] </footnote>  [ وَ ] قَالَ :  هِيَ بُيُوتُ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  .  قِيلَ :  يَا رَسُولَ اللَّهِ [ اَ بَيْتُ ] عَلِيٍّ وَ فَاطِمَةَ مِنْهَا قَالَ :  مِنْ اَفْضَلِهَا .","translation_segment":"","segment_columns":[{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"بيوت","display":"بُيُوتٍ"},{"kind":"word","token":"اذن","display":"اَذِنَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ترفع","display":"تُرْفَعَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يذكر","display":"يُذْكَرَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۳۶","display":"۳۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"بيوت","display":"بُيُوتُ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind