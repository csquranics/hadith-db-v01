nd":"word","token":"الجن","display":"الجن"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"ثُمَّ قُلْ خَمْساً وَ عِشْرِينَ مَرَّةً بَعْدَ الصَّلاَةِ عَلَي مُحَمَّدٍ وَ الِهِ اللَّهُمَّ اِغْفِرْ لِلْمُؤْمِنِينَ وَ الْمُؤْمِنَاتِ وَ الْمُسْلِمِينَ وَ الْمُسْلِمَاتِ الْاَحْيَاءِ مِنْهُمْ وَ الْاَمْوَاتِ وَ سَبْعاً الْحَمْدُ لِلَّهِ عَلَي كُلِّ نِعْمَةٍ كَانَتْ اَوْ هِيَ كَائِنَةٌ وَ خَمْسَ عَشْرَةَ لاَ اِلَهَ اِلاَّ اللَّهُ حَقّاً حَقّاً لاَ اِلَهَ اِلاَّ اللَّهُ اِيمَاناً وَ صِدْقاً لاَ اِلَهَ اِلاَّ اللَّهُ عُبُودِيَّةً وَ رِقّاً وَ اَرْبَعاً الْحَمْدُ لِلَّهِ كَمَا هُوَ اَهْلُهُ وَ مِائَةً التَّسْبِيحَاتِ الْاَرْبَعَ وَ عَشْراً الْبَسْمَلَةَ وَ الْحَوْقَلَةَ وَ مِائَةً لاَ حَوْلَ وَ لاَ قُوَّةَ اِلاَّ بِاللَّهِ وَ عَشْراً لاَ حَوْلَ وَ لاَ قُوَّةَ اِلاَّ بِاللَّهِ لاَ مَلْجَاَ مِنْهُ اِلاَّ اِلَيْهِ وَ مِائَةً لاَ اِلَهَ اِلاَّ اللَّهُ الْمَلِكُ الْحَقُّ الْمُبِينُ وَ عَشْراً لاَ اِلَهَ اِلاَّ اللَّهُ وَ اللَّهُ اَكْبَرُ وَ لاَ حَوْلَ وَ لاَ قُوَّةَ اِلاَّ بِاللَّهِ وَ عَشْراً اَعْدَدْتُ لِكُلِّ هَوْلٍ  <quranic_text> « لاٰ اِلٰهَ اِلاَّ اللّٰهُ » </quranic_text>   <footnote> [ الصافات ۳۵ ] </footnote>  وَ لِكُلِّ هَمٍّ وَ غَمِّ  <quranic_text> « مٰا شٰاءَ اللّٰهُ » </quranic_text>   <footnote> [ الكهف ۳۹ ] </footnote>  وَ لِكُلِّ نِعْمَةٍ  <quranic_text> « الْحَمْدُ لِلّٰهِ » </quranic_text>   <footnote> [ الفاتحة ۲ ] </footnote>  وَ لِكُلِّ رَخَاءٍ الشُّكْرُ لِلَّهِ وَ لِكُلِّ اُعْجُوبَةٍ  <quranic_text> « سُبْحٰانَ اللّٰهِ » </quranic_text>   <footnote> [ يوسف ۱۰۸ ] </footnote>  وَ لِكُلِّ ذَنْبٍ اَسْتَغْفِرُ اللَّهَ وَ لِكُلِّ مُصِيبَةٍ  <quranic_text> « اِنّٰا لِلّٰهِ وَ اِنّٰا اِلَيْهِ رٰاجِعُونَ » </quranic_text>   <footnote> [ البقرة ۱۵۶ ] </footnote>  وَ لِكُلِّ ضِيقٍ  <quranic_text> « حَسْبِيَ اللّٰهُ » </quranic_text>   <footnote> [ التوبة ۱۲۹ ] </footnote>  وَ لِكُلِّ قَضَاءٍ وَ قَدَرٍ  <quranic_text> « تَوَكَّلْتُ عَلَي اللّٰهِ » </quranic_text>   <footnote> [ هود ۵۶ ] </footnote>  وَ لِكُلِّ عَدُوٍّ اِعْتَصَمْتُ بِاللَّهِ وَ لِكُلِّ طَاعَةٍ وَ مَعْصِيَةٍ لاَ حَوْلَ وَ لاَ قُوَّةَ اِلاَّ بِاللَّهِ الْعَلِيِّ الْعَظِيمِ- ثُمَّ قُلْ كُلَّ يَوْمٍ مَرَّةً سُبْحَانَ الدَّائِمِ الْقَائِمِ سُبْحَانَ الْقَائِمِ الدَّائِمِ سُبْحَانَ الْوَاحِدِ الْاَحَدِ سُبْحَانَ الْفَرْدِ الصَّمَدِ سُبْحَانَ الْحَيِّ الْقَيُّومِ سُبْحَانَ اللَّهِ وَ بِحَمْدِهِ سُبْحَانَ  <quranic_text> « الْحَيِّ الَّذِي لاٰ يَمُوتُ » </quranic_text>   <footnote> [ الفرقان ۵۸ ] </footnote>  سُبْحَانَ الْمَلِكِ الْقُدُّوسِ سُبْحَانَ رَبِّ الْمَلاَئِكَةِ وَ الرُّوحِ سُبْحَانَ","translation_segment":"","segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"خمسا","display":"خَمْساً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عشرين","display":"عِشْرِينَ"},{"kind":"word","token":"مره","display":"مَرَّةً"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"اغفر","display":"اِغْفِرْ"},{"kind":"word","token":"للمؤمنين","display":"لِلْمُؤْمِنِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المؤمنات","display":"الْمُؤْمِنَاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المسلمين","display":"الْمُسْلِمِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المسلمات","display":"الْمُسْلِمَاتِ"},{"kind":"word","token":"الاحياء","display":"الْاَحْيَاءِ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الاموات","display":"الْاَمْوَاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سبعا","display":"سَبْعاً"},{"kind":"word","tok