{"consensus_set_id":"s292892","translation_language":"fa","translation_source":{"hid":"292892"},"segments":[{"source_hadith_segment":"وَ جَاءَ فِي تَفْسِيرِ قَوْلِهِ تَعَالَي  <quranic_text> « وَ مٰا قَدَرُوا اللّٰهَ حَقَّ قَدْرِهِ » </quranic_text>   <footnote> [ الانعام ۹۱ ] </footnote>  اَيْ مَا عَرَفُوهُ حَقَّ مَعْرِفَتِهِ وَ لاَ عَظَّمُوهُ حَقَّ عَظَمَتِهِ وَ لاَ عَبَدُوهُ حَقَّ عِبَادَتِهِ .","translation_segment":"و در تفسیر قول خدای تعالی که میفرماید: «و مٰا قدروا اللٰه‌ حق‌ قدره‌» فرمود: و حق معرفت و شناسائی خدا را ادا نکردند و حق بزرگیش بجا نیاوردند و او را پرستش کامل نکردند.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جاء","display":"جَاءَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"قدروا","display":"قَدَرُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"حق","display":"حَقَّ"},{"kind":"word","token":"قدره","display":"قَدْرِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۹۱","display":"۹۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"عرفوه","display":"عَرَفُوهُ"},{"kind":"word","token":"حق","display":"حَقَّ"},{"kind":"word","token":"معرفته","display":"مَعْرِفَتِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"عظموه","display":"عَظَّمُوهُ"},{"kind":"word","token":"حق","display":"حَقَّ"},{"kind":"word","token":"عظمته","display":"عَظَمَتِهِ"},{"kind":"word","token":"و","di