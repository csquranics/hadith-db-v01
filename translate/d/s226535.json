{"consensus_set_id":"s226535","translation_language":"fa","translation_source":{"hid":"226535"},"segments":[{"source_hadith_segment":"اَنَّهُ سَاَلَ الْمَاْمُونُ الرِّضَا عَلَيْهِ السَّلاَمُ عَنْ مَعْنَي قَوْلِ اللَّهِ تَعَالَي -  <quranic_text> « فَلَمّٰا اتٰاهُمٰا صٰالِحاً جَعَلاٰ لَهُ شُرَكٰاءَ فِيمٰا اتٰاهُمٰا » </quranic_text>   <footnote> [ الاعراف ۱۹۰ ] </footnote>  فَقَالَ الرِّضَا عَلَيْهِ السَّلاَمُ اِنَّ حَوَّاءَ وَلَدَتْ لاِدَمَ خَمْسَمِائَةِ بَطْنٍ فِي كُلِّ بَطْنِ ذَكَراً وَ اُنْثَي وَ اِنَّ ادَمَ وَ حَوَّاءَ عَاهَدَا اللَّهَ عَزَّ وَ جَلَّ وَ دَعَوَاهُ وَ قَالاَ  <quranic_text> « لَئِنْ اتَيْتَنٰا صٰالِحاً لَنَكُونَنَّ مِنَ الشّٰاكِرِينَ فَلَمّٰا اتٰاهُمٰا صٰالِحاً » </quranic_text>   <footnote> [ الاعراف ۱۸۹ ] </footnote>  مِنَ النَّسْلِ خَلْقاً سَوِيّاً بَرِيئاً مِنَ الزَّمَانَةِ وَ الْعَاهَةِ كَانَ مَا اتَاهُمَا صِنْفَيْنِ صِنْفاً ذُكْرَاناً وَ صِنْفاً اِنَاثاً فَجَعَلَ الصِّنْفَانِ لِلَّهِ تَعَالَي ذِكْرُهُ :   <quranic_text> « شُرَكٰاءَ فِيمٰا اتٰاهُمٰا » </quranic_text>   <footnote> [ الاعراف ۱۹۰ ] </footnote>  وَ لَمْ يَشْكُرَاهُ كَشُكْرِ اَبَوَيْهِمَا لَهُ عَزَّ وَ جَلَّ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « فَتَعٰالَي اللّٰهُ عَمّٰا يُشْرِكُونَ » </quranic_text>   <footnote> [ الاعراف ۱۹۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"المامون","display":"الْمَاْمُونُ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"معني","display":"مَعْنَي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلما","display":"ف