{"consensus_set_id":"116480","translation_language":"fa","translation_source":{"hid":"375585"},"segments":[{"source_hadith_segment":"ثَلاَثَةُ اَصْوَاتٍ يُحِبُّهَا اللَّهُ عَزَّ وَ جَلَّ صَوْتُ الدِّيكِ وَ صَوْتُ الَّذِي يَقْرَاُ الْقُرْانَ وَ صَوْتُ  <quranic_text> « الْمُسْتَغْفِرِينَ بِالْاَسْحٰارِ » </quranic_text>   <footnote> [ العمران ۱۷ ] </footnote>   .","translation_segment":"و نیز نبی اکرم صلی اللٰه علیه و آله فرمود: سه صدا را خداوند دوست دارد: صدای خروس و صدای قاری قرآن، و صدای استغفارکننده در سحرگاهان.","segment_columns":[{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةُ"},{"kind":"word","token":"اصوات","display":"اَصْوَاتٍ"},{"kind":"word","token":"يحبها","display":"يُحِبُّهَا"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"صوت","display":"صَوْتُ"},{"kind":"word","token":"الديك","display":"الدِّيكِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صوت","display":"صَوْتُ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يقرا","display":"يَقْرَاُ"},{"kind":"word","token":"القران","display":"الْقُرْانَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صوت","display":"صَوْتُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"المستغفرين","display":"الْمُسْتَغْفِرِينَ"},{"kind":"word","token":"بالاسحار","display":"بِالْاَسْحٰارِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"}]}]}