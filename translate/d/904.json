{"consensus_set_id":"904","translation_language":"fa","translation_source":{"hid":"311347"},"segments":[{"source_hadith_segment":"مَنْ اَوْتَرَ بِالْمُعَوِّذَتَيْنِ وَ  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>  قِيلَ لَهُ يَا عَبْدَ اللَّهِ اَبْشِرْ فَقَدْ قَبِلَ اللَّهُ وَتْرَكَ .","translation_segment":"از ابی عبیده حذاء روایت شده است که امام باقر علیه السلام فرمود: هر کس در سه رکعت وتر (یعنی سه رکعت شفع و وتر نماز شب) سوره‌های «قل‌ أعوذ برب‌ الفلق‌»، و «قل‌ أعوذ برب‌ النٰاس‌» را با «قل‌ هو اللٰه‌ أحد» قراءت کند باو خطاب شود ای بنده خدا مژده باد تو را که خداوند وتر تو را قبول کرد.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"اوتر","display":"اَوْتَرَ"},{"kind":"word","token":"بالمعوذتين","display":"بِالْمُعَوِّذَتَيْنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاخلاص","display":"الاخلاص"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"عبد","display":"عَبْدَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ابشر","display":"اَبْشِرْ"},{"kind":"word","token":"فقد","display":"فَقَدْ"},{"kind":"word","token":"قبل","display":"قَبِلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"وترك","display":"وَتْرَكَ"}]}]}