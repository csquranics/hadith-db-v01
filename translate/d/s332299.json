{"consensus_set_id":"s332299","translation_language":"fa","translation_source":{"hid":"332299"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ تَعَالَي :   <quranic_text> « اِلاّٰ اَصْحٰابَ الْيَمِينِ » </quranic_text>   <footnote> [ المدثر ۳۹ ] </footnote>  قَالَ :  نَحْنُ وَ شِيعَتُنَا اَصْحَابُ الْيَمِينِ .","translation_segment":"عن جابر عن أبی جعفر فی قول الله تعالی: (إلا أصحاب الیمین) قال: نحن و شیعتنا أصحاب الیمین. جابر از ابو جعفر نقل می‌کند که درباره سخن خداوند: «الا اصحاب الیمین» گفت: ما و شیعیان ما یاران راست هستیم.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"اصحاب","display":"اَصْحٰابَ"},{"kind":"word","token":"اليمين","display":"الْيَمِينِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المدثر","display":"المدثر"},{"kind":"word","token":"۳۹","display":"۳۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شيعتنا","display":"شِيعَتُنَا"},{"kind":"word","token":"اصحاب","display":"اَصْحَابُ"},{"kind":"word","token":"اليمين","display":"الْيَمِينِ"}]}]}