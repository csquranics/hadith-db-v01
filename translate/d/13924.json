{"consensus_set_id":"13924","translation_language":"fa","translation_source":{"hid":"311953"},"segments":[{"source_hadith_segment":"مَا اِنْتَصَرَ اللَّهُ مِنْ ظَالِمٍ اِلاَّ بِظَالِمٍ وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ كَذٰلِكَ نُوَلِّي بَعْضَ الظّٰالِمِينَ بَعْضاً » </quranic_text>   <footnote> [ الانعام ۱۲۹ ] </footnote>   .","translation_segment":"أبو بصیر گوید: امام باقر علیه السلام فرمود: خداوند (در دنیا) انتقام از ظالمی نکشد مگر بواسطه ظالمی دیگر، و این خود کلام خداوند است که فرموده: «کذٰلک‌ نولی بعض‌ الظٰالمین‌ بعضا» این چنین مسلط‍‌ میسازیم برخی از ستمکاران را بر برخی دیگر.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"انتصر","display":"اِنْتَصَرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ظالم","display":"ظَالِمٍ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"بظالم","display":"بِظَالِمٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كذلك","display":"كَذٰلِكَ"},{"kind":"word","token":"نولي","display":"نُوَلِّي"},{"kind":"word","token":"بعض","display":"بَعْضَ"},{"kind":"word","token":"الظالمين","display":"الظّٰالِمِينَ"},{"kind":"word","token":"بعضا","display":"بَعْضاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۱۲۹","display":"۱۲۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}