{"consensus_set_id":"s77102","translation_language":"fa","translation_source":{"hid":"77102"},"segments":[{"source_hadith_segment":"لما كان رسول اللّٰه صلّي اللّٰه عليه و اله و سلم بمكّة امره اللّٰه عزّ و جلّ ان يتوجه نحو بيت المقدس في صلواته و يجعل الكعبة بينه و بينها اذا امكن و اذا لم يمكن استقبل بيت المقدس كيف كان ،  و كان رسول اللّٰه صلّي اللّٰه عليه و اله و سلم يفعل ذلك طول مقامه بها ثلاث عشرة سنة فلما كان بالمدينة و كان متعبداً باستقبال بيت المقدس استقبله و انحرف عن الكعبة سبعة عشر شهراً و جعل قوم من مردة اليهود يقولون و اللّٰه ما يدري محمّد كيف صلّي حتّي صار يتوجه الي قبلتنا و ياخذ في صلواته بهدانا و نسكنا فاشتد ذلك علي رسول اللّٰهِ صلّي اللّٰه عليه و اله و سلم لما اتصل به عنهم و كره قبلتهم و احبّ الكعبة فجاءه جبرائيل فقال له رسول اللّٰه صلّي اللّٰه عليه و اله و سلم :  يا جبرائيل لوددت لو صرفني اللّٰه عزّ و جلّ عن بيت المقدس الي الكعبة فلقد تاذّيت بما يتّصل بي من قبل اليهود من قبلتهم فقال جبرائيل ع  :  فسل ربك ان يحوّلك اليها فانه لا يردك عن طلبتك و لا يخيبك عن بغيتك فلما استتم دعاؤه صعد جبرائيل ثمّ عاد من ساعته فقال اقرا يا محمد  <quranic_text> « قَدْ نَريٰ تَقَلُّبَ وَجْهِكَ فِي السَّمٰاءِ » </quranic_text>   <footnote> [ البقرة ۱۴۴ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"لما","display":"لما"},{"kind":"word","token":"كان","display":"كان"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"صلي","display":"صلّي"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلم"},{"kind":"word","token":"بمكه","display":"بمكّة"},{"kind":"word","token":"امره","display":"امره"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"عز","display":"عزّ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"جل","display