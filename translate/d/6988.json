{"consensus_set_id":"6988","translation_language":"fa","translation_source":{"hid":"410739"},"segments":[{"source_hadith_segment":"« مَرَّ عَلَيْهِ رَجُلٌ عَدُوٌّ لِلَّهِ وَ لِرَسُولِهِ  ،  فَقَالَ :   <quranic_text> « فَمٰا بَكَتْ عَلَيْهِمُ السَّمٰاءُ وَ الْاَرْضُ وَ مٰا كٰانُوا مُنْظَرِينَ » </quranic_text>   <footnote> [ الدخان ۲۹ ] </footnote> ،  ثُمَّ مَرَّ عَلَيْهِ الْحُسَيْنُ بْنُ عَلِيٍّ ( عَلَيْهِمَا السَّلاَمُ )  ،  فَقَالَ :  لَكِنَّ هَذَا لَتَبْكِيَنَّ عَلَيْهِ السَّمَاءُ وَ الْاَرْضُ ،  وَ قَالَ :  وَ مَا بَكَتِ السَّمَاءُ وَ الْاَرْضُ اِلاَّ عَلَي يَحْيَي بْنِ زَكَرِيَّا وَ الْحُسَيْنِ بْنِ عَلِيٍّ ( عَلَيْهِمُ السَّلاَمُ )  .","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"انّه"},{"kind":"word","token":"مر","display":"مَرَّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"عدو","display":"عَدُوٌّ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لرسوله","display":"لِرَسُولِهِ"},{"kind":"word","token":"صلي","display":"صلّي"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فما","display":"فَمٰا"},{"kind":"word","token":"بكت","display":"بَكَتْ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السماء","display":"السَّمٰاءُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"كانوا","display":"كٰانُوا"},{"kind":"word","token":"منظرين","display":"مُنْظَرِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"f