{"consensus_set_id":"s185778","translation_language":"fa","translation_source":{"hid":"185778"},"segments":[{"source_hadith_segment":"<quranic_text> « لِيَسْتَاْذِنْكُمُ الَّذِينَ مَلَكَتْ اَيْمٰانُكُمْ وَ الَّذِينَ لَمْ يَبْلُغُوا الْحُلُمَ مِنْكُمْ ثَلاٰثَ مَرّٰاتٍ مِنْ قَبْلِ صَلاٰةِ الْفَجْرِ وَ حِينَ تَضَعُونَ ثِيٰابَكُمْ مِنَ الظَّهِيرَةِ وَ مِنْ بَعْدِ صَلاٰةِ الْعِشٰاءِ ثَلاٰثُ عَوْرٰاتٍ لَكُمْ لَيْسَ عَلَيْكُمْ وَ لاٰ عَلَيْهِمْ جُنٰاحٌ بَعْدَهُنَّ طَوّٰافُونَ عَلَيْكُمْ » </quranic_text>   <footnote> [ النور ۵۸ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ليستاذنكم","display":"لِيَسْتَاْذِنْكُمُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"ملكت","display":"مَلَكَتْ"},{"kind":"word","token":"ايمانكم","display":"اَيْمٰانُكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يبلغوا","display":"يَبْلُغُوا"},{"kind":"word","token":"الحلم","display":"الْحُلُمَ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"ثلاث","display":"ثَلاٰثَ"},{"kind":"word","token":"مرات","display":"مَرّٰاتٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبل","display":"قَبْلِ"},{"kind":"word","token":"صلاه","display":"صَلاٰةِ"},{"kind":"word","token":"الفجر","display":"الْفَجْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"تضعون","display":"تَضَعُونَ"},{"kind":"word","token":"ثيابكم","display":"ثِيٰابَكُمْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الظهيره","display":"الظَّهِيرَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بعد","display":"بَعْدِ"},{"kind":"word","token":"صلاه","display":"صَلاٰةِ"},{"kind":"word","token":"العشاء"