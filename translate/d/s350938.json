{"consensus_set_id":"s350938","translation_language":"fa","translation_source":{"hid":"350938"},"segments":[{"source_hadith_segment":"وَ سُئِلَ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ لِمَ  <quranic_text> « اِتَّخَذَ اللّٰهُ اِبْرٰاهِيمَ خَلِيلاً » </quranic_text>   <footnote> [ النساء ۱۲۵ ] </footnote>  قَالَ لِكَثْرَةِ سُجُودِهِ عَلَي الْاَرْضِ .","translation_segment":"از امام صادق علیه السلام پرسیدند که چرا ابراهیم را خلیل الرحمن نامیدند؟ آن حضرت فرمود: او را خلیل نامیدند؛ چون بسیار بر روی زمین سجده می‌کرد.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"لم","display":"لِمَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اتخذ","display":"اِتَّخَذَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"word","token":"خليلا","display":"خَلِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۵","display":"۱۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لكثره","display":"لِكَثْرَةِ"},{"kind":"word","token":"سجوده","display":"سُجُودِهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"}]}]}