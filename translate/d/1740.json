{"consensus_set_id":"1740","translation_language":"fa","translation_source":{"hid":"325190"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنْ اَرْوَاحِ الْمُشْرِكِينَ فَقَالَ فِي النَّارِ يُعَذَّبُونَ وَ يَقُولُونَ رَبَّنَا لاَ تُقِمْ لَنَا السَّاعَةَ وَ لاَ تُنْجِزْ لَنَا مَا وَعَدْتَنَا وَ لاَ تُلْحِقْ اخِرَنَا بِاَوَّلِنَا .","translation_segment":"ابو بصیر گوید: از امام صادق علیه‌ السلام‌ در باره ارواح مشرکان پرسیدم‌؟ فرمود: در آتش به سر می‌برند، عذاب می‌شوند و می‌گویند: ای پروردگار ما! اکنون قیامت را برای ما بر پا نگردان، وعده‌هایی را که به ما داده‌ای اجرا منما، آخرین ما را به اولین (اولیای) ما ملحق نگردان.","segment_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ارواح","display":"اَرْوَاحِ"},{"kind":"word","token":"المشركين","display":"الْمُشْرِكِينَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"النار","display":"النَّارِ"},{"kind":"word","token":"جهنم","display":"جَهَنَّمَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يعذبون","display":"يُعَذَّبُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"غافر۴۶","display":"غافر۴۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"word","token":"ربنا","display":"رَبَّنَا"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تقم","display":"تُقِمْ"},{"kind":"word","token":"لنا","display":"لَنَا"},{"kind":"word","token":"الساعه","display":"السَّاعَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تنجز","display":"تُنْجِزْ"},{"kind":"word","token":"لنا","display":"لَنَا"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"وعدتنا","display":"وَعَدْتَنَا"},{"kind":"