{"consensus_set_id":"84248","translation_language":"fa","translation_source":{"hid":"331892"},"segments":[{"source_hadith_segment":"نَزَلَتْ :   <quranic_text> « اَ فَمَنْ كٰانَ مُؤْمِناً كَمَنْ كٰانَ فٰاسِقاً لاٰ يَسْتَوُونَ » </quranic_text>   <footnote> [ السجده ۱۸ ] </footnote>  يَعْنِي بِالْمُؤْمِنِ عَلِيّاً وَ بِالْفَاسِقِ الْوَلِيدَ بْنَ عُقْبَةَ .","translation_segment":"کلبی از ابی صالح نقل کرده است که ابن عباس در توضیح آیه «أ فمن‌ کٰان‌ مومنا کمن‌ کٰان‌ فٰاسقا لاٰ یستون‌» گفت: منظور از مومن، علی بن ابی طالب علیه السلام و مقصود از فاسق ولید بن عقبه است. که علی علیه السلام سمبل ایمان و ولید بن عقبه معروف در فسق و فجور بود.","segment_columns":[{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"مؤمنا","display":"مُؤْمِناً"},{"kind":"word","token":"كمن","display":"كَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"فاسقا","display":"فٰاسِقاً"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يستوون","display":"يَسْتَوُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"السجده","display":"السجده"},{"kind":"word","token":"۱۸","display":"۱۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"بالمؤمن","display":"بِالْمُؤْمِنِ"},{"kind":"word","token":"عليا","display":"عَلِيّاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بالفاسق","display":"بِالْفَاسِقِ"},{"kind":"word","token":"الوليد","display":"الْوَلِيدَ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"عقبه","display":"عُقْبَةَ"}]}]}