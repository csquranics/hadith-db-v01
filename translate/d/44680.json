{"consensus_set_id":"44680","translation_language":"fa","translation_source":{"hid":"98093"},"segments":[{"source_hadith_segment":"عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « لَهُمْ فِيهٰا اَزْوٰاجٌ مُطَهَّرَةٌ » </quranic_text>   <footnote> [ البقرة ۲۵ ] </footnote>  قَالَ « اَلْاَزْوَاجُ الْمُطَهَّرَةُ اللاَّئِي لَمْ يَحِضْنَ وَ لاَ يُحْدِثْنَ » .","translation_segment":"و از امام صادق علیه السلام سوال شد: در باره فرمایش خدای عز و جل‌: «لهم‌ فیهٰا أزوٰاج‌ مطهره‌» یعنی مومنان را در بهشت همسران پاکیزه خواهد بود. آن حضرت فرمود: آن همسران پاکیزه‌اند که حیض نمی‌بینند و حدثی از آنان سر نمیزند.","segment_columns":[{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"ازواج","display":"اَزْوٰاجٌ"},{"kind":"word","token":"مطهره","display":"مُطَهَّرَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۵","display":"۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الازواج","display":"اَلْاَزْوَاجُ"},{"kind":"word","token":"المطهره","display":"الْمُطَهَّرَةُ"},{"kind":"word","token":"اللائي","display":"اللاَّئِي"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يحضن","display":"يَحِضْنَ"},{"kind":"word","token":"و",