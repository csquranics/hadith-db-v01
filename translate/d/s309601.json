{"consensus_set_id":"s309601","translation_language":"fa","translation_source":{"hid":"309601"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي  <quranic_text> « فَاَمّٰا مَنْ اَعْطيٰ وَ اِتَّقيٰ وَ صَدَّقَ بِالْحُسْنيٰ فَسَنُيَسِّرُهُ لِلْيُسْريٰ » </quranic_text>   <footnote> [ الليل ۵ ] </footnote>  قَالَ :  نَزَلَتْ فِي رَجُلٍ مِنَ الْاَنْصَارِ كَانَتْ لَهُ نَخْلَةٌ فِي دَارِ رَجُلٍ اخَرَ وَ كَانَ يَدْخُلُ عَلَيْهِ بِغَيْرِ اِذْنٍ فَشَكَا ذَلِكَ اِلَي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لِصَاحِبِ النَّخْلَةِ بِعْنِي نَخْلَتَكَ هَذِهِ بِنَخْلَةٍ فِي الْجَنَّةِ فَقَالَ لاَ اَفْعَلُ فَقَالَ :  فَبِعْهَا بِحَدِيقَةٍ فِي الْجَنَّةِ فَقَالَ :  لاَ اَفْعَلُ وَ اِنْصَرَفَ فَمَضَي اِلَيْهِ اِبْنُ [ اَبِي ] الدَّحْدَاحِ وَ اِشْتَرَاهَا مِنْهُ وَ اَتَي اِبْنُ الدَّحْدَاحِ اِلَي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ قَالَ :  يَا رَسُولَ اللَّهِ خُذْهَا وَ اِجْعَلْ لِي فِي الْجَنَّةِ الْحَدِيقَةَ الَّتِي قُلْتَ لِهَذَا فَلَمْ يَقْبَلْهَا ،  فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لَكَ فِي الْجَنَّةِ حَدَائِقُ وَ حَدَائِقُ فَاُنْزِلَ فِي ذَلِكَ :   <quranic_text> « فَاَمّٰا مَنْ اَعْطيٰ وَ اِتَّقيٰ وَ صَدَّقَ بِالْحُسْنيٰ » </quranic_text>   <footnote> [ الليل ۵ ] </footnote>  يَعْنِي اِبْنَ الدَّحْدَاحِ  <quranic_text> « وَ مٰا يُغْنِي عَنْهُ مٰالُهُ اِذٰا تَرَدّٰي » </quranic_text>   <footnote> [ الليل ۱۱ ] </footnote>  يَعْنِي اِذَا مَاتَ  <quranic_text> « اِنَّ عَلَيْنٰا لَلْهُديٰ » </quranic_text>   <footnote> [ الليل ۱۲ ] </footnote>  قَالَ عَلَيْنَا اَنْ نُبَيِّنَ لَهُمْ  <quranic_text> « فَاَنْذَرْتُكُمْ نٰاراً تَلَظّٰي » </quranic_text>   <footnote> [ الليل ۱۴ ] </footnote>  اَيْ تَتَلَهَّبُ عَلَيْهِمْ  <quranic_text> « لاٰ يَصْلاٰهٰا اِلاَّ الْاَشْقَي الَّذِي كَذَّبَ وَ تَوَلّٰي » </quranic_text>   <footnote> [ الليل ۱۵ ] </footnote>  يَعْنِي هَذَا الَّذِي بَخِلَ عَلَي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  <quranic_text> « وَ سَيُجَنَّبُهَا الْاَتْقَي الَّذِي » </quranic_text>   <footnote> [ الليل ۱۷ ] </footnote>  قَالَ اِبْنُ الدَّحْدَاحِ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « وَ مٰا لِاَحَدٍ عِنْدَهُ مِنْ نِعْمَةٍ تُجْزيٰ » </quranic_text>   <footnote> [ الليل ۱۹ ] </footnote>  قَالَ :  لَيْسَ لِاَحَدٍ عِنْدَ اللَّهِ يَدَّعِي رَبَّهُ بِمَا فَعَلَهُ لِنَفْسِهِ وَ اِنْ جَازَاهُ فَبِفَضْلِهِ يَفْعَلُ وَ هُوَ قَوْلُهُ :   <quranic_text> « اِلاَّ اِبْتِغٰاءَ وَجْهِ رَبِّهِ الْاَعْليٰ وَ لَسَوْفَ يَرْضيٰ » </quranic_text>   <footnote> [ الليل ۲۰ ] </footnote>  عَنْ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ [ وَ يَرْضَي عَنْهُ ] .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاما","display":"فَاَمّٰا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"اعطي","display":"اَعْطيٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتقي","display":"اِتَّقيٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صدق","display":"صَدَّقَ"},{"kind":"word","token":"بالحسني","display":"بِالْحُسْنيٰ"},{"kind":"word","token":"فسنيسره","display":"فَسَنُيَسِّرُهُ"},{"kind":"word","token":"لليسري","display":"لِلْيُسْريٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الليل","display":"الليل"},{"kind":"word","token":"۵","display":"۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الانصار","display":"الْاَنْصَارِ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"نخل