{"consensus_set_id":"s331495","translation_language":"fa","translation_source":{"hid":"331495"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « الَّذِينَ اِسْتَجٰابُوا لِلّٰهِ وَ الرَّسُولِ  » </quranic_text>   <footnote> [ العمران ۱۷۲ ] </footnote>  هُمْ اَبُو بَكْرٍ وَ عُمَرُ وَ عَلِيٌّ وَ اِبْنُ مَسْعُودٍ .","translation_segment":"عن ابن عباس فی قوله: (الذین استجابوا لله و الرسول) هم أبو بکر و عمر و علی‌ و ابن مسعود. ابن عباس گفت منظور از «الذین استجابوا لله و الرسول» ابو بکر و عمر و علی و ابن مسعود است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"استجابوا","display":"اِسْتَجٰابُوا"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرسول","display":"الرَّسُولِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۷۲","display":"۱۷۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"بكر","display":"بَكْرٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمر","display":"عُمَرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"مسعود","display":"مَسْعُودٍ"}]}]}