,"display":"عَلَي"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"طالب","display":"طالب"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عنه","display":"عنه"},{"kind":"word","token":"ويخبروه","display":"ويخبروه"},{"kind":"word","token":"ان","display":"أن"},{"kind":"word","token":"طلحه","display":"طلحة"},{"kind":"word","token":"والزبير","display":"والزبير"},{"kind":"word","token":"ومن","display":"ومن"},{"kind":"word","token":"كان","display":"كان"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"بني","display":"بني"},{"kind":"word","token":"اميه","display":"أمية"},{"kind":"word","token":"بالحجاز","display":"بالحجاز"},{"kind":"word","token":"قد","display":"قد"},{"kind":"word","token":"اجتمع","display":"اجتمع"},{"kind":"word","token":"رايهم","display":"رأيهم"},{"kind":"word","token":"واشتملت","display":"واشتملت"},{"kind":"word","token":"عداوتهم","display":"عداوتهم"},{"kind":"word","token":"وهم","display":"وهم"},{"kind":"word","token":"مصرون","display":"مصرون"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلم","display":"سَلَّمَ"}]},{"source_hadith_segment":"« اَمَّا بَعْدُ ،  اَيُّهَا النَّاسُ ،  فَاِنَّا نَحْمَدُ اللَّهَ رَبَّنَا وَ اِلَهَنَا وَ وَلِيَّنَا وَ وَلِيَّ النِّعَمِ عَلَيْنَا ،  الَّذِي اَصْبَحَتْ نِعْمَتُهُ عَلَيْنَا ظَاهِرَةً ،  وَ بَاطِنَةً اِمْتِنَاناً مِنْهُ بِغَيْرِ قَوْلٍ مِنَّا وَ لاَ قُوَّةٍ لِنَشْكُرَ اَمْ نَكْفُرَ ،  فَمَنْ شَكَرَ زَادَهُ ،  وَ مَنْ كَفَرَ عَذَّبَهُ ،  فَاَفْضَلُ النَّاسِ عِنْدَ اللَّهِ مَنْزِلَةً وَ اَقْرَبُهُمْ مِنَ اللَّهِ وَسِيلَةً اَطْوَعُهُمْ لِاَمْرِهِ وَ اَعْلَمُهُمْ بِطَاعَتِهِ وَ اَتْبَعُهُمْ لِسُنَّةِ [ نَبِيِّهِ مُحَمَّدٍ رَسُولِهِ ] صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ،  وَ اَحْيَاهُمْ لِكِتَابِهِ لَيْسَ لِاَحَدٍ عِنْدَنَا فَضْلٌ اِلاَّ بِطَاعَةِ اللَّهِ وَ طَاعَةِ رَسُولِهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ .  هَذَا كِتَابُ اللَّهِ بَيْنَ اَظْهُرِنَا ،  وَ عَهْدُ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ وَ سِيرَتُهُ فِينَا ،  لاَ يَجْهَلُ ذَلِكَ اِلاَّ جَاهِلٌ مُعَانِدٌ عَنِ الْحَقِّ مُنْكِرٌ لِلصِّدْقِ ،  قَالَ اللَّهُ تَعَالَي :   <quranic_text> « يٰا اَيُّهَا النّٰاسُ اِنّٰا خَلَقْنٰاكُمْ مِنْ ذَكَرٍ وَ اُنْثيٰ وَ جَعَلْنٰاكُمْ شُعُوباً وَ قَبٰائِلَ لِتَعٰارَفُوا اِنَّ اَكْرَمَكُمْ عِنْدَ اللّٰهِ اَتْقٰاكُمْ » </quranic_text>   <footnote> [ الحجرات ۱۳ ] </footnote> .  ثُمَّ اِنَّهُ عَلَيْهِ السَّلاَمُ صَاحَ بِاَعْلَي صَوْتِهِ : <quranic_text> « [ يٰا اَيُّهَا الَّذِينَ امَنُوا ] اَطِيعُوا اللّٰهَ وَ اَطِيعُوا الرَّسُولَ وَ اُولِي الْاَمْرِ مِنْكُمْ » </quranic_text>   <footnote> [ النساء ۵۹ ] </footnote> .   <quranic_text> « فَاِنْ تَوَلَّوْا فَاِنَّ اللّٰهَ لاٰ يُحِبُّ الْكٰافِرِينَ » </quranic_text>   <footnote> [ العمران ۳۲ ] </footnote> .  ثُمَّ قَالَ :  يَا مَعْشَرَ الْمُهَاجِرِينَ وَ الْاَنْصَارِ ،  اَ تَمُنُّونَ عَلَي اللَّهِ [ وَ رَسُولِهِ ] بِاِسْلاَمِكُمْ <quranic_text> « بَلِ اللّٰهُ يَمُنُّ عَلَيْكُمْ اَنْ هَدٰاكُمْ لِلْاِيمٰانِ اِنْ كُنْتُمْ صٰادِقِينَ » </quranic_text>   <footnote> [ الحجرات ۱۷ ] </footnote> .  ثُمَّ قَالَ عَلَيْهِ السَّلاَمُ :  اَنَا اَبُو الْحَسَنِ ،  ( وَ كَانَ لاَ يَقُولُهَا اِلاَّ اِذَا غَضِبَ ) .  ثُمَّ قَالَ :  اَلاَ اِنَّ هَذِهِ الدُّنْيَا الَّتِي اَصْبَحْتُمْ تَتَمَنَّوْنَهَا وَ تَرْغَبُونَ فِيهَا ،  وَ اَصْبَحَتْ تُغْضِبُكُمْ وَ تُرْضِيكُمْ لَيْسَتْ بِدَارِكُمْ وَ لاَ مَنْزِلِكُمُ الَّذِي خُلِقْتُمْ لَهُ ،  فَلاَ تَغُرَّنَّكُمْ [ اَلْحَيَوةُ الدُّنْيَا ] فَقَدْ حُذِّرْتُمُوهَا فَاسْتَتِمُّوا نِعَمَ اللَّهِ بِالصَّبْرِ لِاَنْفُسِكُمْ عَلَي طَاعَةِ اللَّهِ ،  وَ الذُّلِّ لِحُكْمِهِ جَلَّ ثَنَاؤُهُ .  فَاَمَّا هَذَا الْفَيْءُ فَلَيْسَ لِاَحَدٍ عَلَي اَحَدٍ فِيهِ اَثَرَةٌ وَ قَدْ فَرَغَ اللَّهُ مِنْ قِسْمَتِهِ فَهُوَ مَالُ اللَّهِ ،  وَ اَنْتُمْ عِبَادُ اللَّهِ الْمُسْلِمُونَ ،  وَ هَذَا كِتَابُ اللَّهِ بِهِ اَقْرَرْنَا وَ لَهُ اَسْلَمْنَا ،  وَ عَهْدُ نَبِيِّنَا بَيْنَ اَظْهُرِنَا فَمَنْ لَمْ يَرْضَ بِهِ فَلْيَتَوَلَّ كَيْفَ شَاءَ فَاِنَّ الْعَامِلَ بِطَاعَةِ اللَّهِ وَ الْحَاكِمَ بِحُكْمِ اللَّهِ لاَ وَحْشَةَ عَلَيْهِ »","translation_segment":"بسته و بر کمانش تکیه داشت به مسجد داخل شد و بر منبر رفت و بعد از حمد و ثنای خدای عز و جل و صلوات بر پیامبر صلی الله علیه و آله و سلم فرمود: «ای مردم! خداوند را سپاس گزاریم که پروردگار و مولا و ولی‌ نعمت ماست او که نعمتهایش را آشکار و پنهان بر ما ارزانی داشته تا بر ما احسان نماید بدون آن که سخنی بر زبان رانده باشیم و یا توانی بر شکر گزاری یا کفران نعمتش داشته باشیم. پس هر کس را که شکرش به جا آرد فزونی دهد و آن را که کفران کند عذابش نماید. از میان مردمان کسی نزد خداوند جایگاهش برتر و وسیله‌اش نزدیک‌تر است که فرمان بردارترینشان نسبت به اوامر الهی و داناترین آنها به اطاعت پروردگار و مطیع‌ترین آنان نسبت به سنت پیامبرش محمد صلی الله علیه و آله و سلم باشد و کتاب خدا را بیش از همه زنده نگه می‌دارد. هیچ کس نزد ما فضیلتی ندارد مگر به طاعت خدا و رسولش صلی الله علیه و آله و سلم. این کتاب خداست که پیش روی ماست و وصیت و سیره رسول خدا صلی الله علیه و آله و سلم در میان ماست و فقط‍‌ نادانی که با حق عناد می‌ورزد و راستی را انکار می‌کند از آن بی خبر است خدای متعال می‌فرماید: «ای مردمان، شما را زن و مرد آفریدیم و طایفه‌ها و قبایل گونه‌گون قرار دادیم تا یکدیگر را بشناسید همانا محترم‌ترین شما نزد خدا پرهیزگارترین شماست». سپس با صدای بلند فریاد برداشت: «از خدا و رسول و اولی الامری که از شماست اطاعت کنید و اگر روی برتابید خداوند کافران را دوست ندارد». سپس فرمود: ای گروه مهاجرین و انصار آیا با اسلام آوردنتان بر خدا و رسول خدا منت می‌گذارید «بلکه خدا بر شما منت می‌گذارد که به ایمان هدایتتان کرد اگر از صادقان باشید». سپس فرمود: من ابو الحسن هستم-و فقط‍‌ وقتی به خشم می‌آمد چنین می‌گفت-و بدانید این دنیایی که در آرزوی آن هستید و به آن دل بسته‌اید و من به سبب آن بر شما خشم می‌گیرم و خشنود می‌شوم، خانه و منزلگاه شما نیست که برای آن آفریده شده‌اید، زندگی دنیا شما را نفریبد که از آن بر حذر داشته شده‌اید. پس با صبر بر طاعت الهی و گردن نهادن به حکمتهای خدای-جل‌ ثنائه-در پی کامل کردن نعمتهای خداوندی بر خودتان باشید. و اما در اموال فیء کسی را بر کسی تقدم نیست بلکه این مال خداست که از تقسیم آن فارغ گشته و شما بندگان مسلمان خدایید. این کتاب خداست که به آن اعتراف داریم و تسلیم او هستیم و وصیت پیامبر پیش روی ماست پس هر کس به آن راضی نشود به هر جا که خواهد رو کند زیرا آن که به طاعت الهی گردن می‌نهد و به احکام خداوند حکم می‌کند","segment_columns":[{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"بعد","display":"بَعْدُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فانا","display":"فَاِنَّا"},{"kind":"word","token":"نحمد","display":"نَحْمَدُ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"ربنا","display":"رَبَّنَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الهنا","display":"اِلَهَنَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ولينا","display":"وَلِيَّنَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ولي","display":"وَلِيَّ"},{"kind":"word","token":"النعم","display":"النِّعَمِ"},{"kind":"word","token":"علينا","display":"عَلَيْنَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"اصبحت","display":"اَصْبَحَتْ"},{"kind":"word","token":"نعمته","display":"نِعْمَتُهُ"},{"kind":"word","token":"علينا","display":"عَلَيْنَا"},{"kind":"word","token":"ظاهره","display":"ظَاهِرَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"باطنه","display":"بَاطِنَةً"},{"kind":"word","token":"امتنانا","display":"اِمْتِنَاناً"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"قول","display":"قَوْلٍ"},{"kind":"word","token":"منا","display":"مِنَّا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا"