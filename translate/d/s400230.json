"،  قُلْتُ :  وَ هَلْ تَعْدُو اَنْ تَكُونَ مُؤْمِنَةً اَوْ كَافِرَةً","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"تعدو","display":"تَعْدُو"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تكون","display":"تَكُونَ"},{"kind":"word","token":"مؤمنه","display":"مُؤْمِنَةً"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"كافره","display":"كَافِرَةً"}]},{"source_hadith_segment":"؟  فَقَالَ :  تَصُومُ وَ تُصَلِّي وَ تَتَّقِي اللَّهَ وَ لاَ تَدْرِي مَا اَمْرُكُمْ","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"تصوم","display":"تَصُومُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تصلي","display":"تُصَلِّي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تتقي","display":"تَتَّقِي"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تدري","display":"تَدْرِي"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"امركم","display":"اَمْرُكُمْ"}]},{"source_hadith_segment":"فَقُلْتُ :  قَدْ قَالَ اللَّهُ عَزَّ وَ جَلَّ :  « وَ  <quranic_text> « هُوَ الَّذِي خَلَقَكُمْ فَمِنْكُمْ كٰافِرٌ وَ مِنْكُمْ مُؤْمِنٌ » </quranic_text>   <footnote> [ التغابن ۲ ] </footnote>  لاَ وَ اللَّهِ لاَ يَكُونُ اَحَدٌ مِنَ النَّاسِ لَيْسَ بِمُؤْمِنٍ وَ لاَ كَافِرٍ قَالَ :  فَقَالَ :  اَبُو جَعْفَرٍ عَلَيْهِ السَّلاَمُ :  قَوْلُ اللَّهِ اَصْدَقُ مِنْ قَوْلِكَ .  يَا زُرَارَةُ اَ رَاَيْتَ قَوْلَ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « خَلَطُوا عَمَلاً صٰالِحاً وَ اخَرَ سَيِّئاً عَسَي اللّٰهُ اَنْ يَتُوبَ عَلَيْهِمْ » </quranic_text>   <footnote> [ التوبة ۱۰۲ ] </footnote> قَالَ :  فَلِمَا قَالَ عَسَي قُلْتُ :  مَا هُمْ اِلاَّ مُؤْمِنِينَ اَوْ كَافِرِينَ قَالَ :  فَقَالَ مَا تَقُولُ فِي قَوْلِهِ عَزَّ وَ جَلَّ :   <quranic_text> « اِلاَّ الْمُسْتَضْعَفِينَ مِنَ الرِّجٰالِ وَ النِّسٰاءِ وَ الْوِلْدٰانِ لاٰ يَسْتَطِيعُونَ حِيلَةً وَ لاٰ يَهْتَدُونَ سَبِيلاً » </quranic_text>   <footnote> [ النساء ۹۸ ] </footnote>  اِلَي الْاِيمَانِ فَقُلْتُ :  مَا هُمْ اِلاَّ مُؤْمِنِينَ اَوْ كَافِرِينَ ،  فَقَالَ :  وَ اللَّهِ مَا هُمْ بِمُؤْمِنِينَ وَ لاَ كَافِرِينَ ،  ثُمَّ اَقْبَلَ عَلَيَّ فَقَالَ :  مَا تَقُولُ فِي اَصْحَابِ الْاَعْرَافِ ؟  فَقُلْتُ :  مَا هُمْ اِلاَّ مُؤْمِنِينَ اَوْ كَافِرِينَ اِنْ دَخَلُوا الْجَنَّةَ فَهُمْ مُؤْمِنُونَ وَ اِنْ دَخَلُوا النَّارَ فَهُمْ كَافِرُونَ ،  فَقَالَ :  وَ اللَّهِ مَا هُمْ بِمُؤْمِنِينَ وَ لاَ كَافِرِينَ وَ لَوْ كَانُوا مُؤْمِنِينَ لَدَخَلُوا الْجَنَّةَ كَمَا دَخَلَهَا الْمُؤْمِنُونَ ،  وَ لَوْ كَانُوا كَافِرِينَ لَدَخَلُوا النَّارَ كَمَا دَخَلَهَا الْكَافِرُونَ ،  وَ لَكِنَّهُمْ قَدِ اِسْتَوَتْ حَسَنَاتُهُمْ وَ سَيِّئَاتُهُمْ فَقَصُرَتْ بِهِمُ الْاَعْمَالُ ،  وَ اِنَّهُمْ لَكُمَا قَالَ اللَّهُ عَزَّ وَ جَلَّ ،  و الحديث طويل اخذنا منه موضع الحاجة .","translation_segment":"","segment_columns":[{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"خلقكم","display":"خَلَقَكُمْ"},{"kind":"word","token":"فمنكم","display":"فَمِنْكُمْ"},{"kind":"word","token":"كافر","display":"كٰافِرٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"