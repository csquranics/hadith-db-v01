{"consensus_set_id":"s357893","translation_language":"fa","translation_source":{"hid":"357893"},"segments":[{"source_hadith_segment":"قَالَ سُبْحَانَهُ  <quranic_text> « الَّذِينَ قٰالَ لَهُمُ النّٰاسُ اِنَّ النّٰاسَ قَدْ جَمَعُوا لَكُمْ فَاخْشَوْهُمْ فَزٰادَهُمْ اِيمٰاناً وَ قٰالُوا حَسْبُنَا اللّٰهُ وَ نِعْمَ الْوَكِيلُ » </quranic_text>   <footnote> [ العمران ۱۷۳ ] </footnote>","translation_segment":"فرمود آیه ۱۷۳-آل عمران: «الذین‌ قٰال‌ لهم‌ النٰاس‌ إن‌ النٰاس‌ قد جمعوا لکم‌ فاخشوهم‌ فزٰادهم‌ إیمٰانا و قٰالوا حسبنا اللٰه‌ و نعم‌ الوکیل‌». یعنی آنان که گفتند براشان مردم راستی مردم برای شما","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سبحانه","display":"سُبْحَانَهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"الناس","display":"النّٰاسُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الناس","display":"النّٰاسَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"جمعوا","display":"جَمَعُوا"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"فاخشوهم","display":"فَاخْشَوْهُمْ"},{"kind":"word","token":"فزادهم","display":"فَزٰادَهُمْ"},{"kind":"word","token":"ايمانا","display":"اِيمٰاناً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"حسبنا","display":"حَسْبُنَا"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نعم","display":"نِعْمَ"},{"kind":"word","token":"الوكيل","display":"الْوَكِيلُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۷۳","display":"۱۷۳"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment