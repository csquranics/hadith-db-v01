{"consensus_set_id":"s237342","translation_language":"fa","translation_source":{"hid":"237342"},"segments":[{"source_hadith_segment":"وَ اَبِي عَبْدِ اللَّهِ عَلَيْهِمَا السَّلاَمُ :  قَوْلُهُ :   <quranic_text> « وَ مِنَ النّٰاسِ مَنْ يَتَّخِذُ مِنْ دُونِ اللّٰهِ اَنْدٰاداً يُحِبُّونَهُمْ كَحُبِّ اللّٰهِ وَ الَّذِينَ امَنُوا اَشَدُّ حُبًّا لِلّٰهِ » </quranic_text>   <footnote> [ البقرة ۱۶۵ ] </footnote>  قَالَ :  هُمْ الُ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يتخذ","display":"يَتَّخِذُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"دون","display":"دُونِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"اندادا","display":"اَنْدٰاداً"},{"kind":"word","token":"يحبونهم","display":"يُحِبُّونَهُمْ"},{"kind":"word","token":"كحب","display":"كَحُبِّ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"اشد","display":"اَشَدُّ"},{"kind":"word","token":"حبا","display":"حُبًّا"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۶۵","display