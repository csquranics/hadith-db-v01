{"consensus_set_id":"57391","translation_language":"fa","translation_source":{"hid":"388339"},"segments":[{"source_hadith_segment":"قَالَ اَبُو جَعْفَرٍ عَلَيْهِ السَّلاَمُ  :  « اَيَّ شَيْءٍ تَقُولُ النَّاسُ فِي هَذِهِ الْايَةِ :   <quranic_text> « وَ اِذٰا وَقَعَ الْقَوْلُ عَلَيْهِمْ اَخْرَجْنٰا لَهُمْ دَابَّةً مِنَ الْاَرْضِ تُكَلِّمُهُمْ » </quranic_text>   <footnote> [ النمل ۸۲ ] </footnote> فَقَالَ :  « هُوَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ  » .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اي","display":"اَيَّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"تقول","display":"تَقُولُ"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"وقع","display":"وَقَعَ"},{"kind":"word","token":"القول","display":"الْقَوْلُ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"اخرجنا","display":"اَخْرَجْنٰا"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"دابه","display":"دَابَّةً"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"تكلمهم","display":"تُكَلِّمُهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النمل","display":"النمل"},{"kind":"word","token":"۸۲","display":"۸۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ