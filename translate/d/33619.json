{"consensus_set_id":"33619","translation_language":"fa","translation_source":{"hid":"331411"},"segments":[{"source_hadith_segment":"اَلصِّرَاطُ اَلَّذِي قَالَ اِبْلِيسُ :   <quranic_text> « لَاَقْعُدَنَّ لَهُمْ صِرٰاطَكَ الْمُسْتَقِيمَ » </quranic_text>   <footnote> [ الاعراف ۱۶ ] </footnote>  فَهُوَ عَلِيٌّ  .","translation_segment":"أبو بصیر، عن أبی عبد الله قال: الصراط‍‌ الذی قال إبلیس: (لأقعدن لهم صراطک المستقیم) [الأعراف:۱۶] فهو علی. ابو بصیر از ابو عبد الله (امام صادق) نقل می‌کند که گفت: آن راهی که شیطان گفت: «لاقعدن‌ لهم صراط‍‌ المستقیم من بر سر راه مستقیم تو در برابر آنان می‌نشینم.» آن علی است.","segment_columns":[{"kind":"word","token":"الصراط","display":"اَلصِّرَاطُ"},{"kind":"word","token":"الذي","display":"اَلَّذِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابليس","display":"اِبْلِيسُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لاقعدن","display":"لَاَقْعُدَنَّ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"صراطك","display":"صِرٰاطَكَ"},{"kind":"word","token":"المستقيم","display":"الْمُسْتَقِيمَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"لاتينهم","display":"لَاتِيَنَّهُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بين","display":"بَيْنِ"},{"kind":"word","token":"ايديهم","display":"اَيْدِيهِمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۶","display":"۱۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}