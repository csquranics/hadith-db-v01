{"consensus_set_id":"111131","translation_language":"fa","translation_source":{"hid":"366926"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ تَبَارَكَ وَ تَعَالَي -  <quranic_text> « وَ مٰا يُؤْمِنُ اَكْثَرُهُمْ بِاللّٰهِ اِلاّٰ وَ هُمْ مُشْرِكُونَ » </quranic_text>   <footnote> [ يوسف ۱۰۶ ] </footnote>  قَالَ يُطِيعَ الشَّيْطَانَ مِنْ حَيْثُ يُشْرِكُ .","translation_segment":"امام صادق علیه السلام در مورد قول خداوند تبارک و تعالی (اکثر آنها به خدا ایمان نیاورند در حالی که آنها مشرک هستند) فرمود: آنان از هر طریقی که شرک می‌ورزند از همان طریق فرمانبردار شیطان می‌باشند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يؤمن","display":"يُؤْمِنُ"},{"kind":"word","token":"اكثرهم","display":"اَكْثَرُهُمْ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"مشركون","display":"مُشْرِكُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۱۰۶","display":"۱۰۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يطيع","display":"يُطِيعَ"},{"kind":"word","token":"الشيطان","display":"الشَّيْطَانَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"حيث","display":"حَيْثُ"},{"kind":"word","token":"يشرك","display":"يُشْرِكُ"}]}]}