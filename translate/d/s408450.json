quranic_text> « اِنَّ اللّٰهَ اِصْطَفيٰ ادَمَ وَ نُوحاً وَ الَ اِبْرٰاهِيمَ وَ الَ عِمْرٰانَ عَلَي الْعٰالَمِينَ » </quranic_text>   <footnote> [ العمران ۳۳ ] </footnote>   .  الْحَدِيثَ بِطُولِهِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ويحك","display":"وَيْحَكَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"اتق","display":"اِتَّقِ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تنسب","display":"تَنْسُبَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"انبياء","display":"اَنْبِيَاءِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"الفواحش","display":"الْفَوَاحِشَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تتاول","display":"تَتَاَوَّلْ"},{"kind":"word","token":"كتاب","display":"كِتَابَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"برايك","display":"بِرَاْيِكَ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يعلم","display":"يَعْلَمُ"},{"kind":"word","token":"تاويله","displ