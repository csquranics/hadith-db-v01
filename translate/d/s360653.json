{"consensus_set_id":"s360653","translation_language":"fa","translation_source":{"hid":"360653"},"segments":[{"source_hadith_segment":"وَ حُكِيَ عَنْ هَارُونَ الرَّشِيدِ اَنَّهُ اِنْتَقَي اَكْفَانَهُ عِنْدَ الْمَوْتِ بِيَدِهِ وَ كَانَ يَنْظُرُ اِلَيْهَا وَ يَقُولُ  <quranic_text> « مٰا اَغْنيٰ عَنِّي مٰالِيَهْ هَلَكَ عَنِّي سُلْطٰانِيَهْ » </quranic_text>   <footnote> [ الحاقة ۲۸ ] </footnote>   .","translation_segment":"آورده‌اند که هارون الرشید، موقع مردن، کفن خویش را با دست خود، انتخاب و آماده کرد، و همواره به آن نگاه می‌کرد و می‌گفت: «مال و ثروتم مرا بی‌نیاز نکرد، و قدرت و سلطنتم از بین رفت.»","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حكي","display":"حُكِيَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"هارون","display":"هَارُونَ"},{"kind":"word","token":"الرشيد","display":"الرَّشِيدِ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"انتقي","display":"اِنْتَقَي"},{"kind":"word","token":"اكفانه","display":"اَكْفَانَهُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الموت","display":"الْمَوْتِ"},{"kind":"word","token":"بيده","display":"بِيَدِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ينظر","display":"يَنْظُرُ"},{"kind":"word","token":"اليها","display":"اِلَيْهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"اغني","display":"اَغْنيٰ"},{"kind":"word","token":"عني","display":"عَنِّي"},{"kind":"word","token":"ماليه","display":"مٰالِيَهْ"},{"kind":"word","token":"هلك","display":"هَلَكَ"},{"kind":"word","token":"عني","display":"عَنِّي"},{"kind":"word","token":"سلطانيه","display":"سُلْطٰانِيَهْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحاقه"