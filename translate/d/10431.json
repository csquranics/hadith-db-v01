سَّمٰاءِ مٰاءً لِيُطَهِّرَكُمْ بِهِ وَ يُذْهِبَ عَنْكُمْ رِجْزَ الشَّيْطٰانِ وَ لِيَرْبِطَ عَليٰ قُلُوبِكُمْ وَ يُثَبِّتَ بِهِ الْاَقْدٰامَ » </quranic_text>   <footnote> [ الانفال ۱۱ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  مَا مِنْ دَاءٍ اِلاَّ وَ فِي الْحَبَّةِ السَّوْدَاءِ مِنْهُ شِفَاءٌ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اِلاَّ السَّامَ لُحُومُ الْبَقَرِ دَاءٌ وَ اَلْبَانُهَا دَوَاءٌ وَ اَسْمَانُهَا شِفَاءٌ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"مَا تَاْكُلُ الْحَامِلُ مِنْ شَيْءٍوَ لاَ يُتَدَاوَي بِهِ اَفْضَلَ مِنَ الرُّطَبِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ اللَّهُ تَعَالَي لِمَرْيَمَ  <quranic_text> « وَ هُزِّي اِلَيْكِ بِجِذْعِ النَّخْلَةِ تُسٰاقِطْ عَلَيْكِ رُطَباً جَنِيًّا فَكُلِي وَ اِشْرَبِي وَ قَرِّي عَيْناً » </quranic_text>   <footnote> [ مريم ۲۵ ] </footnote>  حَنِّكُوا اَوْلاَدَكُمْ بِالتَّمْرِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ هَكَذَا فَعَلَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ بِالْحَسَنِ وَ الْحُسَيْنِ عَلَيْهِمَا السَّلاَمُ الْحُقْنَةُ مِنَ الْاَرْبَعِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اِنَّ اَفْضَلَ مَا تَدَاوَيْتُمْ بِهِ الْحُقْنَةُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ هِيَ تُعْظِمُ الْبَطْنَ وَ تُنَقِّي دَاءَ الْجَوْفِ وَ تُقَوِّي الْبَدَنَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اُسْعُطُوا بِالْبَنَفْسَجِ وَ عَلَيْكُمْ بِالْحِجَامَةِ .","translation_segment":"","segment_columns":[]}]}