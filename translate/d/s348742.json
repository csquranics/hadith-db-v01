{"consensus_set_id":"s348742","translation_language":"fa","translation_source":{"hid":"348742"},"segments":[{"source_hadith_segment":"وَ يَقُولُ عِنْدَ الْغُسْلِ اللَّهُمَّ","translation_segment":"مستحب‌ است هنگام غسل کردن بگوید: «اللهم‌، طهرنی،","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الغسل","display":"الْغُسْلِ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"}]},{"source_hadith_segment":"طَهِّرْنِي وَ طَهِّرْ قَلْبِي وَ اِشْرَحْ صَدْرِي وَ اَجْرِ عَلَي لِسَانِي ذِكْرَكَ وَ مِدْحَتَكَ وَ الثَّنَاءَ عَلَيْكَ","translation_segment":"و طهر قلبی، و اشرح صدری، و أجر علی لسانی ذکرک و مدحتک و الثناء علیک. اللهم‌، اجعله لی طهورا و شفاء و نورا، إنک علی کل‌ شیء قدیر.». -خداوندا، مرا","segment_columns":[{"kind":"word","token":"طهرني","display":"طَهِّرْنِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طهر","display":"طَهِّرْ"},{"kind":"word","token":"قلبي","display":"قَلْبِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اشرح","display":"اِشْرَحْ"},{"kind":"word","token":"صدري","display":"صَدْرِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اجر","display":"اَجْرِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"لساني","display":"لِسَانِي"},{"kind":"word","token":"ذكرك","display":"ذِكْرَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مدحتك","display":"مِدْحَتَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الثناء","display":"الثَّنَاءَ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"}]},{"source_hadith_segment":"اللَّهُمَّ اِجْعَلْهُ لِي طَهُوراً وَ شِفَاءً وَ نُوراً  <quranic_text> « اِنَّكَ عَليٰ كُلِّ شَيْءٍ قَدِيرٌ » </quranic_text>   <footnote> [ العمران ۲۶ ] </footnote>   .","translation_segment":"پاکیزه بگردان، و قلبم را پاک نما، و سینه و دلم را بگشای، و یاد و مدح و ثنایت را بر زبانم جاری گردان، خدایا، این [غسل کردن] را برای من مایه پاکیزگی و بهبودی و نور قرار ده، براستی که تو بر هر چیز توانا هستی.","segment_columns":[{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"اجعله","display":"اِجْعَلْهُ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"طهورا","display":"طَهُوراً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شفاء","display":"شِفَاءً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نورا","display":"نُوراً"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انك","display":"اِنَّكَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"قدير","display":"قَدِيرٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۲۶","display":"۲۶"},{"kind":"tag_close","tag_name":"footnote"}]}]}