":"اَيُّهَا النَّاسُ اِنِّي اِبْنُ عَمِّ نَبِيِّكُمْ وَ اَوْلاَكُمْ بِاللَّهِ وَ رَسُولِهِ فَاسْاَلُونِي ثُمَّ اِسْاَلُونِي فَكَاَنَّكُمْ بِالْعِلْمِ قَدْ نَفِدَ وَ اِنَّهُ لاَ يَهْلِكُ عَالِمٌ اِلاَّ هَلَكَ مَعَهُ بَعْضُ عِلْمِهِ وَ اِنَّمَا الْعُلَمَاءُ فِي النَّاسِ كَالْبَدْرِ فِي السَّمَاءِ يُضِيءُ نُورُهُ عَلَي سَائِرِ الْكَوَاكِبِ","translation_segment":"ستم و از خدا بترسید که همانا خداوند در عقوبت سخت است، ای گروه مردم من پسر عموی پیغمبر شما هستم و سزاوارترین شمایم بخدا و رسولش پس از من پرسش کنید و پس از آن پرسش کنید، که گویا شما می‌نگرید بدانش و علم که برطرف گردیده و نابود شده، و براستی هیچ دانشمندی هلاک نگردد جز اینکه برخی از دانشش با او برود، جز این نیست که دانشمندان در میان مردم مانند ماه در آسمان هستند که نورش بر ستارگان","segment_columns":[{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"عم","display":"عَمِّ"},{"kind":"word","token":"نبيكم","display":"نَبِيِّكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اولاكم","display":"اَوْلاَكُمْ"},{"kind":"word","token":"بالله","display":"بِاللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رسوله","display":"رَسُولِهِ"},{"kind":"word","token":"فاسالوني","display":"فَاسْاَلُونِي"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اسالوني","display":"اِسْاَلُونِي"},{"kind":"word","token":"فكانكم","display":"فَكَاَنَّكُمْ"},{"kind":"word","token":"بالعلم","display":"بِالْعِلْمِ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"نفد","display":"نَفِدَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يهلك","display":"يَهْلِكُ"},{"kind":"word","token":"عالم","display":"عَالِمٌ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"wor