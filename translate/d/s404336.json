{"consensus_set_id":"s404336","translation_language":"fa","translation_source":{"hid":"404336"},"segments":[{"source_hadith_segment":"« اَعِينُونَا بِالْوَرَعِ فَاِنَّهُ مَنْ لَقِيَ اللَّهَ عَزَّ وَ جَلَّ مِنْكُمْ بِالْوَرَعِ كَانَ لَهُ عِنْدَ اللَّهِ فَرَجاً ،  وَ اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « وَ مَنْ يُطِعِ اللّٰهَ وَ الرَّسُولَ فَاُولٰئِكَ مَعَ الَّذِينَ اَنْعَمَ اللّٰهُ عَلَيْهِمْ مِنَ النَّبِيِّينَ وَ الصِّدِّيقِينَ وَ الشُّهَدٰاءِ وَ الصّٰالِحِينَ وَ حَسُنَ اُولٰئِكَ رَفِيقاً » </quranic_text>   <footnote> [ النساء ۶۹ ] </footnote> فَمِنَّا النَّبِيُّ  ،  وَ مِنَّا الصِّدِّيقُ ،  وَ مِنَّا الشُّهَدَاءُ ،  وَ مِنَّا الصَّالِحُونَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"اعينونا","display":"اَعِينُونَا"},{"kind":"word","token":"بالورع","display":"بِالْوَرَعِ"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"لقي","display":"لَقِيَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"بالورع","display":"بِالْوَرَعِ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فرجا","display":"فَرَجاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word