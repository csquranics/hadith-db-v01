splay":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمار","display":"عَمَّارَ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"ياسر","display":"يَاسِرٍ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الكوفه","display":"الْكُوفَةِ"},{"kind":"word","token":"ليستنفرا","display":"لِيَسْتَنْفِرَا"},{"kind":"word","token":"اهلها","display":"اَهْلَهَا"}]},{"source_hadith_segment":"،  فَاَتَوْهُ بِذِي قَارٍ [ اَيْ اَهْلَ الْكُوفَةِ","translation_segment":"یاسر را به نزد کوفیان فرستاد تا آنان","segment_columns":[{"kind":"word","token":"فاتوه","display":"فَاَتَوْهُ"},{"kind":"word","token":"بذي","display":"بِذِي"},{"kind":"word","token":"قار","display":"قَارٍ"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"الكوفه","display":"الْكُوفَةِ"}]},{"source_hadith_segment":"] ،  فَاَخَذَ عَلَيْهِمُ الْبَيْعَةَ","translation_segment":"را مهیا کنند کوفیان به ذی قار","segment_columns":[{"kind":"word","token":"فاخذ","display":"فَاَخَذَ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"البيعه","display":"الْبَيْعَةَ"}]},{"source_hadith_segment":"،  ثُمَّ قَامَ فِيهِمْ خَطِيباً","translation_segment":"نزد او آمدند و امیر المومنین","segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قام","display":"قَامَ"},{"kind":"word","token":"فيهم","display":"فِيهِمْ"},{"kind":"word","token":"خطيبا","display":"خَطِيباً"}]},{"source_hadith_segment":"،  فَحَمِدَ اللَّهَ وَ اَثْنَي عَلَيْهِ","translation_segment":"پس از گرفتن بیعت از ایشان به","segment_columns":[{"kind":"word","token":"فحمد","display":"فَحَمِدَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اثني","display":"اَثْنَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"}]},{"source_hadith_segment":"،  وَ صَلَّي عَلَي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ ،  ثُمَّ قَالَ :  اَمَّا بَعْدُ ،  اَيُّهَا النَّاسُ :","translation_segment":"بیان خطبه‌ای پرداخت و بعد از حمد و ثنای الهی و صلوات بر رسول خدا صلی الله علیه و آله و سلم فرمود: «ای","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلم","display":"سَلَّمَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"بعد","display":"بَعْدُ"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الناس","display":"النَّاسُ"}]},{"source_hadith_segment":"« قَدْ جَرَتْ عَلَيْنَا اُمُورٌ صَبَرْنَا عَلَيْهَا - وَ فِي اَعْيُنِنَا الْقَذَي ،  وَ فِي الْقَلْبِ شَجًي - تَسْلِيماً لِاَمْرِ اللَّهِ تَعَالَي فِيمَا اِمْتَحَنَ بِهِ عَبْدَهُ ،  رَجَاءَ الثَّوَابِ عَلَي ذَلِكَ ،  فَكَانَ الصَّبْرُ عَلَيْهَا اَمْثَلَ مِنْ اَنْ يَتَفَرَّقَ الْمُسْلِمُونَ ،  وَ تُسْفَكَ دِمَاؤُهُمْ ،  فَنَحْنُ اَهْلُ بَيْتِ النُّبُوَّةِ ،  وَ عِتْرَةُ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ ،  وَ اَحَقُّ النَّاسِ بِسُلْطَانِ الرِّسَالَةِ ،  وَ مَعْدِنِ الْكَرَامَةِ ،  الَّتِي اِبْتَدَاَنَا اللَّهُ تَعَالَي بِهَا ،   <quranic_text> « ذٰلِكَ فَضْلُ اللّٰهِ يُؤْتِيهِ مَنْ يَشٰاءُ وَ اللّٰهُ ذُو الْفَضْلِ الْعَظِيمِ » </quranic_text>   <footnote> [ الحديد ۲۱ ] </footnote> .  يَا اَهْلَ الْكُوفَةِ :  اِنَّكُمْ مِنْ اَكْرَمِ الْمُسْلِمِينَ ،  [ وَ اَصْدَقِهِمْ تَقْوَي ] ،  وَ اَعْدَلِهِمْ سُنَّةً ،  وَ اَفْضَلِهِمْ سَهْماً فِي الْاِسْلاَمِ ،  وَ اَجْوَدِهِمْ فِي الْقُرْبِ مَرْكَباً وَ نِصَاباً ،  اَنْتُمْ اَشَدُّ الْقُرْبِ لِلنَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ وَ لِاَهْلِ بَيْتِهِ ،  وَ اِنَّمَا جِئْتُكُمْ ثِقَةً - بَعْدَ اللَّهِ - بِكُمْ لِلَّذِي بَذَلْتُمْ مِنْ اَنْفُسِكُمْ عِنْدَ نَقْضِ طَلْحَةَ وَ الزُّبَيْرِ وَ خَلْعِهِمَا طَاعَتِي [ وَ اِقْبَالِهِمَا بِعَائِشَةَ لِلْفِتْنَةِ ] .  [ خَرَجَا مُحْتَالاَنِ[ مُحْتَالَيْنِ ] عَلَي فَسَادِ الْعِبَادِ وَ اِخْرَابِ الْبِلاَدِ ،  اَلاَ وَ اِنَّهُمَا قَدْ بَايَعَا لِي طَائِعَيْنِ رَاغِبَيْنِ مُخْتَارَيْنِ ،  ثُمَّ اسْتَاْذَنَانِي فِي الذَّهَابِ اِلَي الْعُمْرَةِ ،  فَاَذِنْتُ لَهُمَا ،  فَاَكْثَرَا الْقَوْلَ عَلَيْهَا [ اَيْ عَائِشَةَ ] ،  حَتَّي اَخْرَجَاهَا مِنْ بَيْتِهَا يَجُرَّانِهَا كَمَا تُجَرُّ الْاَمَةُ عِنْدَ شِرَائِهَا ،  حَتَّي قَدِمَا بِهَا الْبَصْرَةَ ،  فَحَبَسَا [ نِسَاءَهُمْ فِي بُيُوتِهِمْ ] ،  وَ اَبْرَزَا حَبِيسَ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ لَهُمَا وَ لِغَيْرِهِمَا فِي جَيْشٍ ،  فَضَرَبُوا عَامِلِي بِهَا وَ اَسَرُوهُ ،  وَ خُزَّانَ بَيْتِ مَالِ الْمُسْلِمِينَ الَّذِي بِيَدِي ،  وَ عَلَي اَهْلِ الْمِصْرِ [ اَلَّذِينَ ] كُلُّهُمْ فِي طَاعَتِي وَ عَلَي بَيْعَتِي ،  فَشَتَّتُوا شَمْلَهُمْ ،  وَ فَرَّقُوا كَلِمَتَهُمْ ،  وَ اَفْسَدُوا عَلَي جَمَاعَتِهِمْ ،  وَ وَثَبُوا عَلَي شِيعَتِي فَقَتَلُوا طَاِئفَةً مِنْهُمْ ،  وَ طَائِفَةً ،  عَضُّوا عَلَي اَسْيَافِهِمْ وَ ضَارَبُوا بِهَا حَتَّي لَقُوا اللَّهَ صَادِقِينَ فِي اللَّهِ .  لَوْ لَمْ يُصِيبُوا مِنَ الْمُسْلِمِينَ اِلاَّ رَجُلاً وَاحِداً مُعْتَمِدِينَ لِقَتْلِهِ بِلاَ جُرْمٍ ،  لَحَلَّ قَتْلُ ذَلِكَ الْجَيْشِ كُلِّهِ ،  اِذْ حَضَرُوهُ فَلَمْ يُنْكِرُوا وَ لَمْ يَدْفَعُوا عَنْهُ بِلِسَانٍ وَ لاَ يَدٍ ،  مَعَ مَا اَنَّهُمْ قَتَلُوا مِنَ الْمُسْلِمِينَ الْعِدَّةَ الَّتِي دَخَلُوا بِهَا عَلَيْهِمْ .  فَالَّذِي قُتِلَ مِنَ السَّبَابِجَةِ اَرْبَعُمِائَةِ رَجُلٍ ،  وَ عَزَّرُوا بِوُلاَتِهَا ] .  اللَّهُمَّ ،  اِنَّهُمَا قَطَعَانِي وَ ظَلَمَانِي وَ نَكَثَا بَيْعَتِي ،  وَ اَلَّبَا النَّاسَ عَلَيَّ ،  فَاحْلُلْ مَا عَقَدَا ،  وَ لاَ تُحْكِمْ مَا اَبْرَمَا ،  وَ اَرِهِمَا الْمَسَاءَةَ فِيمَا عَمِلاَ .  فَقَالَ لَهُ اَهْلُ الْكُوفَةِ :  « يَا اَمِيرَ الْمُؤْمِنِينَ ،  اِنَّا نَحْمَدُ اللَّهَ عَزَّ وَ جَلَّ الَّذِي مَنَّ عَلَيْنَا بِرُؤْيَاكَ ،  وَ خَصَّنَا بِجِوَارِكَ ،  وَ جَعَلَنَا مِنْ شِيعَتِكَ وَ اَنْصَارِكَ وَ اَعْوَانِكَ عَلَي اَعْدَائِكَ ،  وَ لَوْ دَعَوْتَنَا اِلَي اَضْعَافِهِمْ اِحْتَسَبْنَا الْخَيْرَ وَ رَجَوْنَا الشَّهَادَةَ بَيْنَ يَدَيْكَ ،  فَطِبْ نَفْساً وَ قَرَّ عَيْناً بِظَفَرِكَ عَلَي اَعْدَائِكَ اِنْ شَاءَ اللَّهُ تَعَالَي » .  قَالَ :  فَلَمْ يَزَلِ الْكُوفِيُّونَ وَ غَيْرُهُمْ يُقَدِّمُونَ اِلَيْهِ زُمَراً ،  زُمَراً ،  وَ هُوَ عَلَيْهِ السَّلاَمُ مُقِيمٌ بِذِي قَارٍ .","translation_segment":"مردم اموری بر ما گذشت که ما به جهت تسلیم شدن در برابر امر خدای تعالی که بندگانش را به آن می‌آزماید و به سبب امیدواری به پاداش آخرت، بر این امور صبر کردیم در حالی که خاری در چشم و استخوانی در قلب داشتیم اما صبر کردن بر آنها بهتر از این بود که مسلمانان از یکدیگر پراکنده شوند و خونهایشان ریخته شود. ما اهل بیت نبوت و عترت رسول خدا و سزاوارترین مردم به پادشاهی اسلام و معدن کرامت هستیم که خدای تعالی خلقتمان را با آن آغاز کرده است «و این فضل خداست که به هر کس بخواهد می‌دهد و خداوند فضل عظیمی دارد». ای مردم کوفه، شما از محترم‌ترین مسلمانان هستید و تقوایتان صادقانه‌تر و سنتتان عادلانه‌تر و سهم شما در اسلام بیشتر و جوانمردترین آنها در خویشاوندی هستید و نزدیکترین مردم به پیامبر و اهل بیتش می‌باشید من فقط‍‌ به جهت اعتماد به شما-بعد از خدا-به نزدتان آمدم به سبب جانفشانی که به هنگام پیمان شکنی طلحه و زبیر و خلع طاعت من و روی آوردن به عایشه برای فتنه انگیزی، انجام دادید. آن دو حیله گرانه برای به تباهی کشیدن بندگان خدا و نابودی شهرها خروج کردند. آگاه باشید که آنها با میل و رغبت و اختیار خودشان بیعت کردند سپس برای رفتن به عمره از من اجازه خواستند و من اجازه دارم. اما آنقدر در گوش عایشه خواندند تا او را از خانه‌اش در آوردند و همانند کنیزکانی که برای فروش می‌برند او را به دنبال خود بردند تا به بصره رسیدند. زنانشان را در خانه‌هاشان محبوس کردند ولی پرده نشین رسول خدا صلی الله علیه و آله و سلم را در میان لشکر در برابر چشم‌های خودشان و دیگران ظاهر ساختند. پس از آن کارگزار من در بصره را زدند و اسیرش کردند و بر خزانه داران بیت المال مسلمین که در دست من بود و بر مردم شهر که همگی در طاعت و بیعت من بودند هجوم بردند و اتحادشان را گسستند و میانشان تفرقه افکندند و جماعتشان را به تباهی کشیدند و بر شیعیان من یورش بردند [تاختند] و عده‌ای را کشتند و عده‌ای شمشیرهایشان را محکم گرفتند و نبرد کردند تا با ایمانی راستین به دیدار خدا شتافتند. اگر چنین گزندی فقط‍‌ به یکی از مسلمانان بی گناه رسیده بود و در کشتن او تعمد داشتند کشتن تمام این سپاه جایز بود زیرا در این واقعه حضور داشتند اما با زبان یا دستشان از آن جلوگیری نکردند و باز نداشته بودند چه رسد به این که آنها شماری از مسلمانان را کشتند که در شهر به دیدارشان آمده بودند. و عده‌ای از سبابجه را که چهارصد نفر بودند کشتند و والیان شهر را به شدت کتک زدند. خدایا، آنها از من بریدند و بر من ستم کردند و بیعتم را شکستند و مردم را علیه من بر انگیختند. پس آن چه بهم بسته‌اند از هم بگشا و آن چه را محکم کرده‌اند تو سست گردان و به سبب اعمالشان سرنوشت بدی نصیبشان کن. مردم کوفه گفتند: ای امیر مومنان خدای عز و جل را سپاسگزاریم که با دیدار تو بر ما منت نهاد و ما را به همسایگی [همجواری] تو مخصوص گردانید و از شیعیان و یاران و یاوران تو علیه دشمنانت قرار داد اگر ما را به ستیز با چندین برابر ایشان فراخوانی آن را خیر و صلاح خود بر می‌شمریم و شهادت در خدمت تو را آرزومندیم پس خاطرت آسوده باشد و چشمت به پیروزی بر دشمنانت روشن گردد. انشاء الله» در همین زمان که امیر المومنین علیه السلام در ذی قار مقیم بود کوفیان و دیگران گروه گروه به نزد او می‌آمدند.","segment_columns":[{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"جرت","display":"جَرَتْ"},{"kind":"word","token":"علينا","display":"عَلَيْنَا"},{"kind":"word","token":"امور","display":"اُمُورٌ"},{"kind":"word","token":"صبرنا","display":"صَبَرْنَا"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","t