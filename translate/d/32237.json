{"consensus_set_id":"32237","translation_language":"fa","translation_source":{"hid":"114032"},"segments":[{"source_hadith_segment":"اِذَا اَرَادَ الرَّجُلُ اَنْ يَتَزَوَّجَ الْمَرْاَةَ فَلْيَقُلْ اَقْرَرْتُ بِالْمِيثَاقِ الَّذِي اَخَذَ اللَّهُ اِمْسَاكٌ  <quranic_text> « بِمَعْرُوفٍ اَوْ تَسْرِيحٌ بِاِحْسٰانٍ » </quranic_text>   <footnote> [ البقرة ۲۲۹ ] </footnote>   .","translation_segment":"عبد الرحمان بن اعین گوید: از امام صادق علیه السلام شنیدم که می‌فرمود: هنگامی که مردی می‌خواهد با زنی ازدواج کند بگوید: «أقررت بالمیثاق الذی أخذ الله إمساک بمعروف أو تسریح بإحسان».","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اراد","display":"اَرَادَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتزوج","display":"يَتَزَوَّجَ"},{"kind":"word","token":"المراه","display":"الْمَرْاَةَ"},{"kind":"word","token":"فليقل","display":"فَلْيَقُلْ"},{"kind":"word","token":"اقررت","display":"اَقْرَرْتُ"},{"kind":"word","token":"بالميثاق","display":"بِالْمِيثَاقِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"امساك","display":"اِمْسَاكٌ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فامساك","display":"فَاِمْسٰاكٌ"},{"kind":"word","token":"بمعروف","display":"بِمَعْرُوفٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"تسريح","display":"تَسْرِيحٌ"},{"kind":"word","token":"باحسان","display":"بِاِحْسٰانٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۲۹","display":"۲۲۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}