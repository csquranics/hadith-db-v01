{"consensus_set_id":"s406641","translation_language":"fa","translation_source":{"hid":"406641"},"segments":[{"source_hadith_segment":"« اِنَّ اَللَّهَ عَزَّ وَ جَلَّ اَوْحَي اِلَي نُوحٍ ( عَلَيْهِ السَّلاَمُ ) - وَ ذَكَرَ الْحَدِيثَ وَ قَالَ فِيهِ - ثُمَّ وَرَدَ اِلَي بَابِ الْكُوفَةِ ،  فِي وَسَطِ مَسْجِدِهَا ،  فَفِيهَا قَالَ اللَّهُ تَعَالَي لِلْاَرْضِ :   <quranic_text> « اِبْلَعِي مٰاءَكِ » </quranic_text>   <footnote> [ هود ۴۴ ] </footnote> فَبَلَعَتْ مَاءَهَا مِنْ مَسْجِدِ الْكُوفَةِ ،  كَمَا بَدَاَ الْمَاءُ مِنْهُ ،  وَ تَفَرَّقَ الْجَمْعُ الَّذِي كَانَ مَعَ نُوحٍ ( عَلَيْهِ السَّلاَمُ ) فِي السَّفِينَةِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اَللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"اوحي","display":"اَوْحَي"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"نوح","display":"نُوحٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"الحديث","display":"الْحَدِيثَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"ورد","display":"وَرَدَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"باب","display":"بَابِ"},{"kind":"word","token":"الكوفه","display":"الْكُوفَةِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"وسط","display":"وَسَطِ"},{"kind":"word","token":"مسجدها","display":"مَسْجِدِهَا"},{"kind":"word","token":"ففيها","display":"فَفِيهَا"},{"kind":"word","tok