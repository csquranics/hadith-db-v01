{"consensus_set_id":"3651","translation_language":"fa","translation_source":{"hid":"114208"},"segments":[{"source_hadith_segment":"فِي قَوْمِ لُوطٍ عَلَيْهِ السَّلاَمُ :   <quranic_text> « اِنَّكُمْ لَتَاْتُونَ الْفٰاحِشَةَ مٰا سَبَقَكُمْ بِهٰا مِنْ اَحَدٍ مِنَ الْعٰالَمِينَ » </quranic_text>   <footnote> [ العنكبوت ۲۸ ] </footnote>","translation_segment":"ابا بصیر گوید: امام (باقر علیه السلام و یا امام صادق علیه السلام) در خصوص قوم لوط‍‌ که خداوند می‌فرماید: «شما گناهی را انجام می‌دهید که کسی از جهانیان آن را انجام نداده و بر شما پیشی نگرفته است»، فرمود: روزی","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوم","display":"قَوْمِ"},{"kind":"word","token":"لوط","display":"لُوطٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انكم","display":"اِنَّكُمْ"},{"kind":"word","token":"لتاتون","display":"لَتَاْتُونَ"},{"kind":"word","token":"الفاحشه","display":"الْفٰاحِشَةَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"سبقكم","display":"سَبَقَكُمْ"},{"kind":"word","token":"بها","display":"بِهٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"احد","display":"اَحَدٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"العالمين","display":"الْعٰالَمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العنكبوت","display":"العنكبوت"},{"kind":"word","token":"۲۸","display":"۲۸"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"فَقَالَ اِنَّ اِبْلِيسَ اَتَاهُمْ فِي صُورَةٍ حَسَنَةٍ فِيهِ تَاْنِيثٌ عَلَيْهِ ثِيَابٌ حَسَنَةٌ فَجَاءَ اِلَي شَبَابٍ مِنْهُمْ فَاَمَرَهُمْ اَنْ يَقَعُوا بِهِ فَلَوْ طَلَبَ اِلَيْهِمْ اَنْ يَقَعَ بِهِمْ لَاَبَوْا عَلَيْهِ وَ لَكِنْ طَلَبَ اِلَيْهِمْ اَنْ يَقَعُوا بِهِ فَلَمَّا وَقَعُوا بِهِ اِلْتَذُّوهُ ثُمَّ ذَهَبَ عَنْهُمْ وَ تَرَكَهُمْ فَاَحَالَ بَعْضَهُمْ عَلَي بَعْضٍ .","translation_segment":"ابلیس با صورتی زیبا که حالتی زنانه داشت و لباس‌های زیبایی بر اندامش بود نزد قوم لوط‍‌ آمد و به سراغ جوانان آنها رفت. پس به آنان دستور داد که با او نزدیکی کنند - اگر ابلیس از آنان می‌خواست خودش با آنان نزدیکی کند، آنان امتناع می‌کردند. اما از آنان درخواست نمود که آن‌ها با او نزدیکی کنند - پس هنگامی که آن جوان‌ها با او نزدیکی کردند، لذت بردند. سپس ابلیس از نزد آنان رفت و آن‌ها را ترک نمود. پس برخی از آنها با برخی دیگر نزدیکی می‌نمودند.","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ابليس","display":"اِبْلِيسَ"},{"kind":"word","token":"اتاهم","display":"اَتَاهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"صوره","display":"صُورَةٍ"},{"kind":"word","token":"حسنه","display":"حَسَنَةٍ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"تانيث","display":"تَاْنِيثٌ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"ثياب","display":"ثِيَابٌ"},{"kind":"word","token":"حسنه","display":"حَسَنَةٌ"},{"kind":"word","token":"فجاء","display":"فَجَاءَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"شباب","display":"شَبَابٍ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"فامرهم","display":"فَاَمَرَهُمْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يقعوا","display":"يَقَعُوا"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فلو","display":"فَلَوْ"},{"kind":"word","token":"طلب","display":"طَلَبَ"},{"kind":"word","token":"اليهم","display":"اِلَيْهِمْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يقع","display":"يَقَعَ"},{"kind":"word","token":"بهم","display":"بِهِمْ"},{"kind":"word","token":"لابوا","displa