{"consensus_set_id":"35519","translation_language":"fa","translation_source":{"hid":"73729"},"segments":[{"source_hadith_segment":"اوّل من شري نفسه ابتغاء مرضاة اللّه/  ۳۰ /ا/ابي ثمّ قرا  <quranic_text> « وَ مِنَ النّٰاسِ مَنْ يَشْرِي نَفْسَهُ اِبْتِغٰاءَ مَرْضٰاتِ اللّٰهِ » </quranic_text>   <footnote> [ البقرة ۲۰۷ ] </footnote>  [  ۲۰۷ /البقرة :   ۲ ] و انّ لعليّ في القران اسما ما يعرفونه .  قال :  قلت :  و قد قرات القران فما رايت له فيه اسما !  قال :   <quranic_text> « وَ اَذٰانٌ مِنَ اللّٰهِ وَ رَسُولِهِ اِلَي النّٰاسِ يَوْمَ الْحَجِّ الْاَكْبَرِ » </quranic_text>   <footnote> [ التوبة ۳ ] </footnote>  فمن كان الاذان ؟  .  قال :  و قال [ عليّ ] رضي اللّه [ تعالي ] عنه :  وقيت بنفسي خير من وطا الحصيو من طاف بالبيت العتيق و بالحجر يخاف رسول اللّه ان يمكروا بهفنجّاه ذو الطول الاله من المكر و بات رسول اللّه في الغار امنامن الضرّ في حفظ الاله و في ستر اراعيهم فيما يبيّتوننيو قد طبت نفسي علي القتل و الاسر .   ۳۰ /ا/ابي ثمّ قرا  <quranic_text> « وَ مِنَ النّٰاسِ مَنْ يَشْرِي نَفْسَهُ اِبْتِغٰاءَ مَرْضٰاتِ اللّٰهِ » </quranic_text>   <footnote> [ البقرة ۲۰۷ ] </footnote>  [  ۲۰۷ /البقرة :   ۲ ] و انّ لعليّ في القران اسما ما يعرفونه .  قال :  قلت :  و قد قرات القران فما رايت له فيه اسما !  قال :   <quranic_text> « وَ اَذٰانٌ مِنَ اللّٰهِ وَ رَسُولِهِ اِلَي النّٰاسِ يَوْمَ الْحَجِّ الْاَكْبَرِ » </quranic_text>   <footnote> [ التوبة ۳ ] </footnote>  فمن كان الاذان ؟  .  قال :  و قال [ عليّ ] رضي اللّه [ تعالي ] عنه :  وقيت بنفسي خير من وطا الحصيو من طاف بالبيت العتيق و بالحجر يخاف رسول اللّه ان يمكروا بهفنجّاه ذو الطول الاله من المكر و بات رسول اللّه في الغار امنامن الضرّ في حفظ الاله و في ستر اراعيهم فيما يبيّتوننيو قد طبت نفسي علي القتل و الاسر .","translation_segment":"","segment_columns":[{"kind":"word","token":"اول","display":"اوّل"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"شري","display":"شري"},{"kind":"word","token":"نفسه","display":"نفسه"},{"kind":"word","token":"ابتغاء","display":"ابتغاء"},{"kind":"word","token":"مرضاه","display":"مرضاة