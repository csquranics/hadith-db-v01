{"consensus_set_id":"s224446","translation_language":"fa","translation_source":{"hid":"224446"},"segments":[{"source_hadith_segment":"<quranic_text> « يَوْمَ نَطْوِي السَّمٰاءَ كَطَيِّ السِّجِلِّ لِلْكُتُبِ » </quranic_text>   <footnote> [ الانبياء ۱۰۴ ] </footnote>  قَالَ السِّجِلُّ اِسْمُ الْمَلَكِ الَّذِي يَطْوِي الْكُتُبَ وَ مَعْنَي نَطْوِيهَا اَيْ نَفْنِيهَا فَتَتَحَوَّلُ دُخَاناً وَ الْاَرْضُ نِيرَاناً .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"نطوي","display":"نَطْوِي"},{"kind":"word","token":"السماء","display":"السَّمٰاءَ"},{"kind":"word","token":"كطي","display":"كَطَيِّ"},{"kind":"word","token":"السجل","display":"السِّجِلِّ"},{"kind":"word","token":"للكتب","display":"لِلْكُتُبِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۱۰۴","display":"۱۰۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"السجل","display":"السِّجِلُّ"},{"kind":"word","token":"اسم","display":"اِسْمُ"},{"kind":"word","token":"الملك","display":"الْمَلَكِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يطوي","display":"يَطْوِي"},{"kind":"word","token":"الكتب","display":"الْكُتُبَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"معني","display":"مَعْنَي"},{"kind":"word","token":"نطويها","display":"نَطْوِيهَا"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"نفنيها","display":"نَفْنِيهَا"},{"kind":"word","token":"فتتحول","display":"فَتَتَحَوَّلُ"},{"kind":"word","token":"دخانا","display":"دُخَاناً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضُ"},{"kind":"word","token":"نيرانا","display":"نِيرَاناً"}]}]}