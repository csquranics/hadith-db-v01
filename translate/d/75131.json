{"consensus_set_id":"75131","translation_language":"fa","translation_source":{"hid":"403446"},"segments":[{"source_hadith_segment":"« يَا اِبْنَ مَسْعُودٍ ،  اِذَا قِيلَ لَكَ :  اِتَّقِ اللَّهَ فَلاَ تَغْضَبْ ،  فَاِنَّهُ يَقُولُ :   <quranic_text> « وَ اِذٰا قِيلَ لَهُ اِتَّقِ اللّٰهَ اَخَذَتْهُ الْعِزَّةُ بِالْاِثْمِ فَحَسْبُهُ جَهَنَّمُ » </quranic_text>   <footnote> [ البقرة ۲۰۶ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"مسعود","display":"مَسْعُودٍ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"اتق","display":"اِتَّقِ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"تغضب","display":"تَغْضَبْ"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"اتق","display":"اِتَّقِ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"اخذته","display":"اَخَذَتْهُ"},{"kind":"word","token":"العزه","display":"الْعِزَّةُ"},{"kind":"word","token":"بالاثم","display":"بِالْاِثْمِ"},{"kind":"word","token":"فحسبه","display":"فَحَسْبُهُ"},{"kind":"word","token":"جهنم","display":"جَهَنَّمُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۰۶","display":"۲۰۶"},{"kind":"tag_close","tag_name":"footnote"}]}]}