 وَ حِكْمَةٍ » </quranic_text>   <footnote> [ العمران ۸۱ ] </footnote>  اِلَي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ اَنَا مَعَكُمْ مِنَ الشّٰاهِدِينَ » </quranic_text>   <footnote> [ العمران ۸۱ ] </footnote> فَيَوْمَئِذٍ يَدْفَعُ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اللِّوَاءَ اِلَي عَلِيِّ بْنِ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ )  ،  فَيَكُونُ اَمِيرَ الْخَلاَئِقِ كُلِّهِمْ اَجْمَعِينَ ،  يَكُونُ الْخَلاَئِقُ كُلُّهُمْ تَحْتَ لِوَائِهِ ،  وَ يَكُونُ هُوَ اَمِيرَهُمْ ،  فَهَذَا تَاْوِيلُهُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"جاء","display":"جَاءَ"},{"kind":"word","token":"جمع","display":"جَمَعَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"امامه","display":"اَمَامَهُ"},{"kind":"word","token":"النبيين","display":"النَّبِيِّينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"ينصروه","display":"يَنْصُرُوهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تعالي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"ميثاق","display":"مِيثٰاقَ"},{"kind":"word","token":"النبيين","display":"النَّبِيِّينَ"},{"kind":"word","token":"لما","display":"لَمٰا"},{"kind":"word","token":"اتيتكم","display":"اتَيْتُكُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"كتاب","display":"كِتٰابٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حكمه","disp