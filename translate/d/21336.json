{"consensus_set_id":"21336","translation_language":"fa","translation_source":{"hid":"405981"},"segments":[{"source_hadith_segment":"اَنَّهُ لَمَّا دَخَلَ هِشَامُ بْنُ الْوَلِيدِ الْمَدِينَةَ اَتَاهُ بَنُو الْعَبَّاسِ","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"خبر","display":"خَبَرٍ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"هشام","display":"هِشَامُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"الوليد","display":"الْوَلِيدِ"},{"kind":"word","token":"المدينه","display":"الْمَدِينَةَ"},{"kind":"word","token":"اتاه","display":"اَتَاهُ"},{"kind":"word","token":"بنو","display":"بَنُو"},{"kind":"word","token":"العباس","display":"الْعَبَّاسِ"}]},{"source_hadith_segment":"،  وَ شَكَوْا اِلَيْهِ مِنَ الصَّادِقِ ( عَلَيْهِ السَّلاَمُ ) اَنَّهُ اَخَذَ تَرِكَاتِ مَاهِرٍ الْخَصِيِّ دُونَنَا","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شكوا","display":"شَكَوْا"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"تركات","display":"تَرِكَاتِ"},{"kind":"word","token":"ماهر","display":"مَاهِرٍ"},{"kind":"word","token":"الخصي","display":"الْخَصِيِّ"},{"kind":"word","token":"دوننا","display":"دُونَنَا"}]},{"source_hadith_segment":"،  فَخَطَبَ اَبُو عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ","translation_segment":"","segment_columns":[{"kind":"word","token":"فخطب","display":"فَخَطَبَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]},{"source_hadith_segment":") فَكَانَ مِمَّا قَالَ :  « اِنَّ اللَّهَ تَعَالَي لَمَّا بَعَثَ رَسُولَ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) كَانَ اَبُونَا اَبُو طَالِبٍ الْمُوَاسِيَ لَهُ بِنَفْسِهِ ،  وَ النَّاصِرَ لَهُ ،  وَ اَبُوكُمُ الْعَبَّاسُ وَ اَبُو لَهَبٍ يُكَذِّبَانِهِ وَ يُوَلِّيَانِ عَلَيْهِ شَيَاطِينَ الْكُفْرِ ،  وَ اَبُوكُمْ يَبْغِي لَهُ الْغَوَائِلَ ،  وَ يَقُودُ اِلَيْهِ القَبَائِلَ فِي بَدْرٍ ،  وَ كَانَ فِي اَوَّلِ رَعِيلِهَا ،  وَ صَاحِبَ خَيْلِهَا وَ رَجِلِهَا ،  الْمُطْعِمَ يَوْمَئِذٍ ،  وَ النَّاصِبَ الْحَرْبَ لَهُ - ثُمَّ قَالَ- :  فَكَانَ اَبُوكُمْ طَلِيقَنَا وَ عَتِيقَنَا ،  وَ اَسْلَمَ كَارِهاً تَحْتَ سُيُوفِنَا ،  لَمْ يُهَاجِرْ اِلَي اللَّهِ وَ رَسُولِهِ هِجْرَةً قَطُّ ،  فَقَطَعَ اللَّهُ وَلاَيَتَهُ مِنَّا بِقَوْلِهِ تَعَالَي :   <quranic_text> « وَ الَّذِينَ امَنُوا وَ لَمْ يُهٰاجِرُوا مٰا لَكُمْ مِنْ وَلاٰيَتِهِمْ مِنْ شَيْءٍ » </quranic_text>   <footnote> [ الانفال ۷۲ ] </footnote> .  فِي كَلاَمٍ لَهُ - ثُمَّ قَالَ- :  « هَذَا مَوْلًي لَنَا مَاتَ فَحُزْنَا تُرَاثَهُ ،  اِذْ كَانَ مَوْلاَنَا ،  وَ لِاَنَّا وُلْدُ رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) وَ اُمُّنَا فَاطِمَةُ اَحْرَزَتْ مِيرَاثَهُ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"فكان","display":"فَكَانَ"},{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"بعث","display":"بَعَثَ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"