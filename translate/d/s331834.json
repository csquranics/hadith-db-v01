{"consensus_set_id":"s331834","translation_language":"fa","translation_source":{"hid":"331834"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ بَشِّرِ الْمُخْبِتِينَ » </quranic_text>   <footnote> [ الحج ۳۴ ] </footnote>  قَالَ :  نَزَلَتْ فِي عَلِيٍّ وَ سَلْمَانَ .","translation_segment":"عن ابن عباس فی قوله تعالی: (و بشر المخبتین) قال: نزلت فی علی‌ و سلمان. ابن عباس درباره سخن خداوند: «و بشر المخبتین» گفت: راجع به علی و سلمان نازل شده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بشر","display":"بَشِّرِ"},{"kind":"word","token":"المخبتين","display":"الْمُخْبِتِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۳۴","display":"۳۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلمان","display":"سَلْمَانَ"}]}]}