{"consensus_set_id":"s331400","translation_language":"fa","translation_source":{"hid":"331400"},"segments":[{"source_hadith_segment":"مَا كَانَ فِي الْقُرْانِ :   <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا » </quranic_text>   <footnote> [ البقرة ۱۰۴ ] </footnote>  فَاِنَّ لِعَلِيٍّ سَابِقَةَ ذَلِكَ وَ فَضِيلَتَهُ .","translation_segment":"عن مجاهد قال: ما کان فی القرآن: (یا أیها الذین آمنوا) فإن لعلی سابقه ذلک و فضیلته. مجاهد گفت: هر چه در قرآن «یا ایها الذین آمنوا» آمده سابقه و فضیلت آن برای علی است.","segment_columns":[{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۰۴","display":"۱۰۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"لعلي","display":"لِعَلِيٍّ"},{"kind":"word","token":"سابقه","display":"سَابِقَةَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فضيلته","display":"فَضِيلَتَهُ"}]}]}