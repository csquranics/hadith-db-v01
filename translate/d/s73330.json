{"consensus_set_id":"s73330","translation_language":"fa","translation_source":{"hid":"73330"},"segments":[{"source_hadith_segment":"كتب ابو الحسن الرضا عليه السّلام رسالة","translation_segment":"","segment_columns":[{"kind":"word","token":"كتب","display":"كتب"},{"kind":"word","token":"ابو","display":"ابو"},{"kind":"word","token":"الحسن","display":"الحسن"},{"kind":"word","token":"الرضا","display":"الرضا"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"رساله","display":"رسالة"}]},{"source_hadith_segment":"و اقريتها ،  قال :  « قال عليّ بن الحسين عليهما السّلام :  « انّ رسول اللّه صلّي اللّه عليه و اله كان امين اللّه في ارضه ،  فلمّا قبض كنّا اهل البيت ورثته ،  فنحن امناء اللّه في ارضه ،  عندنا علم البلايا و المنايا ،  و انشاء العرب ،  و مواليد الاسلام ؛  و انّا لنعرف الرجل اذا رايناه لحقيقة الايمان و حقيقة النفاق ،  و شيعتنا مكتوبون باسمائهم و اسماء ابائهم ،  اخذ اللّه علينا و عليهم الميثاق ،  يردون موردنا ،  و يدخلون مدخلنا ؛ و نحن نجباء اللّه في ارضه ،  و افراطنا افراط الانبياء ،  و نحن امنا الاوصياء ،  و نحن المخصّصون في كتاب اللّه ،  و نحن اولي بالناس برسول اللّه صلّي اللّه عليه و اله ،  و نحن اولي الناس بكتاب اللّه ،  و اولي الناس بدين اللّه ،  و نحن الذين شرع اللّه دينه لنا و قال تعالي :   <quranic_text> « شَرَعَ لَكُمْ مِنَ الدِّينِ مٰا وَصّٰي بِهِ نُوحاً وَ الَّذِي اَوْحَيْنٰا اِلَيْكَ وَ مٰا وَصَّيْنٰا بِهِ اِبْرٰاهِيمَ وَ مُوسيٰ وَ عِيسيٰ » </quranic_text>   <footnote> [ الشوري ۱۳ ] </footnote>   ،  علّمنا ما علّمهم ،  و استودعنا ما استودعهم ،  فنحن ورثة الانبياء و ورثة اولي العزم من الرسل ،  كبر علي المشركين ما تدعوهم اليه من ولاية عليّ عليه السّلام » .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اقريتها","display":"اقريتها"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"علي","display":"عليّ"},{"kind":"word","token":"بن","display":"بن"},{"kind":"