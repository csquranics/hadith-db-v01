{"consensus_set_id":"s252676","translation_language":"fa","translation_source":{"hid":"252676"},"segments":[{"source_hadith_segment":"<quranic_text> « وَ الْمَلَكُ عَليٰ اَرْجٰائِهٰا وَ يَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمٰانِيَةٌ يَوْمَئِذٍ تُعْرَضُونَ » </quranic_text>   <footnote> [ الحاقة ۱۷ ] </footnote>  قَالَ حَمَلَةُ الْعَرْشِ ثَمَانِيَةٌ لِكُلِّ وَاحِدٍ ثَمَانِيَةُ اَعْيُنٍ كُلُّ عَيْنٍ طِبَاقُ الدُّنْيَا .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الملك","display":"الْمَلَكُ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ارجائها","display":"اَرْجٰائِهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يحمل","display":"يَحْمِلُ"},{"kind":"word","token":"عرش","display":"عَرْشَ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"فوقهم","display":"فَوْقَهُمْ"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"ثمانيه","display":"ثَمٰانِيَةٌ"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"تعرضون","display":"تُعْرَضُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحاقه","display":"الحاقة"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"حمله","display":"حَمَلَةُ"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"ثمانيه","display":"ثَمَانِيَةٌ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"واحد","display":"وَاحِدٍ"},{"kind":"word","token":"ثمانيه","display":"ثَمَانِيَةُ"},{"kind":"word","token":"اعين","display":"اَعْيُنٍ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"عين","display":"عَيْنٍ"},{"kind":"word","token":"طباق","display":"طِبَاقُ"},{"k