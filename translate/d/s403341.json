{"consensus_set_id":"s403341","translation_language":"fa","translation_source":{"hid":"403341"},"segments":[{"source_hadith_segment":"« اَلْحِكْمَةُ ضِيَاءُ الْمَعْرِفَةِ ،  وَ مِيزَانُ التَّقْوَي ،  وَ ثَمَرَةُ الصِّدْقِ ،  وَ مَا اَنْعَمَ اللَّهُ عَلَي عِبَادِهِ بِنِعْمَةٍ اَعْظَمَ وَ اَنْعَمَ وَ اَرْفَعَ وَ اَجْزَلَ وَ اَبْهَي مِنَ الْحِكْمَةِ لِلْقَلْبِ ؛ قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « يُؤْتِي الْحِكْمَةَ مَنْ يَشٰاءُ وَ مَنْ يُؤْتَ الْحِكْمَةَ فَقَدْ اُوتِيَ خَيْراً كَثِيراً وَ مٰا يَذَّكَّرُ اِلاّٰ اُولُوا الْاَلْبٰابِ » </quranic_text>   <footnote> [ البقرة ۲۶۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"الحكمه","display":"اَلْحِكْمَةُ"},{"kind":"word","token":"ضياء","display":"ضِيَاءُ"},{"kind":"word","token":"المعرفه","display":"الْمَعْرِفَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ميزان","display":"مِيزَانُ"},{"kind":"word","token":"التقوي","display":"التَّقْوَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ثمره","display":"ثَمَرَةُ"},{"kind":"word","token":"الصدق","display":"الصِّدْقِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"انعم","display":"اَنْعَمَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"عباده","display":"عِبَادِهِ"},{"kind":"word","token":"بنعمه","display":"بِنِعْمَةٍ"},{"kind":"word","token":"اعظم","display":"اَعْظَمَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انعم","display":"اَنْعَمَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ارفع","display":"اَرْفَعَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اجزل","display":"اَجْزَلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابهي","display":"اَبْهَي"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الحكمه","display":"الْحِ