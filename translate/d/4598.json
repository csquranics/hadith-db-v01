{"consensus_set_id":"4598","translation_language":"fa","translation_source":{"hid":"115248"},"segments":[{"source_hadith_segment":"اِسْتَوْصُوا بِالصِّنِينَاتِ خَيْراً يَعْنِي الْخُطَّافَ فَاِنَّهُنَّ انَسُ طَيْرِ النَّاسِ بِالنَّاسِ ثُمَّ قَالَ وَ تَدْرُونَ مَا تَقُولُ الصِّنِينَةُ اِذَا مَرَّتْ وَ تَرَنَّمَتْ تَقُولُ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ الْحَمْدُ لِلّٰهِ رَبِّ الْعٰالَمِينَ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  حَتَّي قَرَاَ اُمَّ الْكِتَابِ فَاِذَا كَانَ اخِرُ تَرَنُّمِهَا قَالَتْ  <quranic_text> « وَ لاَ الضّٰالِّينَ » </quranic_text>   <footnote> [ الفاتحة ۷ ] </footnote>","translation_segment":"جعفر گوید: پیامبر خدا صلی الله علیه و اله فرمود: درباره پرستو به نیکی سفارش کنید، چرا که آن‌ها، انس گیرنده‌ترین پرندگان با مردم هستند. سپس فرمود: می‌دانید که پرستو به هنگام آواز چه می‌گوید؟ می‌گوید «بسم الله الرحمن الرحیم الحمد لله رب العالمین» تا این‌که حضرت صلی الله علیه و اله سوره حمد را قرائت","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"استوصوا","display":"اِسْتَوْصُوا"},{"kind":"word","token":"بالصنينات","display":"بِالصِّنِينَاتِ"},{"kind":"word","token":"2","display":"2"},{"kind":"word","token":"خيرا","display":"خَيْراً"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"الخطاف","display":"الْخُطَّافَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فانهن","display":"فَاِنَّهُنَّ"},{"kind":"word","token":"انس","display":"انَسُ"},{"kind":"word","token