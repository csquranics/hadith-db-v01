{"consensus_set_id":"s312153","translation_language":"fa","translation_source":{"hid":"312153"},"segments":[{"source_hadith_segment":"اِذَا قَالَ الْعَبْدُ عِنْدَ مَنَامِهِ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ - » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  يَقُولُ اللَّهُ يَا مَلاَئِكَةِ اُكْتُبُوا بِالْحَسَنَاتِ نَفَسَهُ اِلَي الصَّبَاحِ .","translation_segment":"فرمود پیغمبر (صلی الله علیه و آله) چون بنده نزد خواب بگوید بسم اللٰه الرحمن الرحیم. گوید خدای تعالی که‌ای فرشتگان من بنویسید نفس او را تا صباح.","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"العبد","display":"الْعَبْدُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"منامه","display":"مَنَامِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ملائكه","display":"مَلاَئِكَةِ"},{"kind":"word","token":"اكتبوا","display":"اُكْتُبُوا"},{"kind":"word","token":"بالحسنات","display":"بِالْحَسَنَاتِ"},{"kind":"word","token":"نفسه","display":"نَفَسَهُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الصباح","display":"الصَّبَاحِ"}]}]}