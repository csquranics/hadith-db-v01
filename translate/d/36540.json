{"consensus_set_id":"36540","translation_language":"fa","translation_source":{"hid":"441139"},"segments":[{"source_hadith_segment":"تَلاَ هَذِهِ الْايَةَ - بِمَعْنَي  <quranic_text> « هُوَ اَهْلُ التَّقْويٰ وَ اَهْلُ الْمَغْفِرَةِ » </quranic_text>   <footnote> [ المدثر ۵۶ ] </footnote>","translation_segment":"باز هم طبرسی در همان کتاب از انس روایت کرده که گفت: حضرت پیامبر صلی الله علیه و آله این آیه را تلاوت کرد: (او اهل تقوا و اهل معرفت","segment_columns":[{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"النبي","display":"النبي"},{"kind":"word","token":"ص","display":"ص"},{"kind":"word","token":"تلا","display":"تَلاَ"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"صلي","display":"صلى"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"وسلم","display":"وسلم"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"بمعني","display":"بِمَعْنَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"التقوي","display":"التَّقْويٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"المغفره","display":"الْمَغْفِرَةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المدثر","display":"المدثر"},{"kind":"word","token":"۵۶","display":"۵۶"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"- فَقَالَ :  قَالَ اللَّهُ سُبْحَانَهُ :  اَنَا اَهْلٌ اَنْ اُتَّقَي فَلاَ يُجْعَلُ مَعِي اِلَهٌ ،  فَمَنِ اِتَّقَي اَنْ يَجْعَلَ مَعِي اِلَهاً فَاَنَا اَهْلٌ اَنْ اَغْفِرَ ل