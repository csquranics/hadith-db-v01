ِلاَّ اَنَّكَ مِنْ اَمْرِكَ عَلَي اِدِّعَاءٍ وَ شُبْهَةٍ وَ اَنَا عَلَي يَقِينٍ وَ ثِقَةٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لِاَنِّي لاَ اَرَي حَوَاسِّيَ الْخَمْسَ اَدْرَكَتْهُ وَ مَا لَمْ تُدْرِكْهُ حَوَاسِّي فَلَيْسَ عِنْدِي بِمَوْجُودٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قُلْتُ اِنَّهُ لَمَّا عَجَزَتْ حَوَاسُّكَ عَنْ اِدْرَاكِ اللَّهِ اَنْكَرْتَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ اَنَا لَمَّا عَجَزَتْ حَوَاسِّي عَنْ اِدْرَاكِ اللَّهِ تَعَالَي صَدَّقْتُ بِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ وَ كَيْفَ ذَلِكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قُلْتُ لِاَنَّ كُلَّ شَيْءٍ جَرَي فِيهِ اَثَرُ تَرْكِيبٍ لَجِسْمٌ اَوْ وَقَعَ عَلَيْهِ بَصَرٌ لَلَوْنٌ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَمَا اَدْرَكَتْهُ الْاَبْصَارُ وَ نَالَتْهُ الْحَوَاسُّ فَهُوَ غَيْرُ اللَّهِ سُبْحَانَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لِاَنَّهُ لاَ يُشْبِهُ الْخَلْقَ وَ اَنَّ هَذَا الْخَلْقَ يَنْتَقِلُ بِتَغْيِيرٍ وَ زَوَالٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كُلُّ شَيْءٍ اَشْبَهَ التَّغْيِيرَ وَ الزَّوَالَ فَهُوَ مِثْلُهُ وَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لَيْسَ الْمَخْلُوقُ كَالْخَالِقِ وَ لاَ الْمُحْدَثُ كَالْمُحْدِثِ .","translation_segment":"","segment_columns":[]}]}