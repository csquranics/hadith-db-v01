text>   <footnote> [ النحل ۳۹ ] </footnote> يَعْنِي فِي الرَّجْعَةِ ،  يَرُدُّهُمْ فَيَقْتُلُهُمْ وَ يَشْفِي صُدُورَ الْمُؤْمِنِينَ مِنْهُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الكفار","display":"الْكُفَّارَ"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يحلفون","display":"يَحْلِفُونَ"},{"kind":"word","token":"بالله","display":"بِاللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوم","display":"قَوْمٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"امه","display":"اُمَّةِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"ترجعون","display":"تُرْجَعُونَ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الموت","display":"الْمَوْتِ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"يوم","display":"يوم"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"},{"kind":"word","token":"فحلفوا","display":"فَحَلَفُوا"},{"kind":"word","token":"انهم","display":"اَنَّهُمْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يرجعون","display":"يَرْجِعُونَ"},{"kind":"word","token":"فرد","display":"فَرَدَّ"},{"kind":"word","to