t>   <footnote> [ العمران ۱۷۳ ] </footnote>   .","translation_segment":"نیته من اخواننا أدام اللٰه تعالی سعادتهم بأن‌ محمد بن علی‌ المعروف بالشلمغانی عجل اللٰه له النقمه و لا أمهله قد ارتد عن الاسلام و فارقه و ألحد فی دین اللٰه و ادعی ما کفر معه الی الخالق جل‌ و تعالی و افتری کذبا و وزرا و قال بهتانا و اثما عظیما کذب العادلون باللٰه و ضلوا ضلالا بعیدا و خسروا خسرانا مبینا. و انا برئنا الی اللٰه تعالی و الی رسوله صلوات اللٰه و سلامه و رحمته و برکاته منه و لعناه علیه لعاین اللٰه تتری فی الظاهر منا و الباطن فی السرو الجهر فی کل‌ وقت و علی کل‌ حال و علی من شایعه و تابعه و بلغه هذا القول منا فأقام علی تولیته بعده. و أعلمهم تولاک اللٰه اننا فی التوقی و المحاوره منه علی مثل ما کنا علیه مما تقدمه من نظرائه من السریعی و النمیری و الهلالی و البلالی و الشلمغانی و غیرهم و عاده اللٰه جل‌ ثناوه مع ذلک قبله و بعده عندنا جمیله و به نثق و إیاه نستعین و هو حسبنا فی کل‌ امورنا و نعم الوکیل.","segment_columns":[{"kind":"word","token":"كذب","display":"كَذَبَ"},{"kind":"word","token":"العادلون","display":"الْعَادِلُونَ"},{"kind":"word","token":"بالله","display":"بِاللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ضلوا","display":"ضَلُّوا"},{"kind":"word","token":"ضلالا","display":"ضَلاٰلاً"},{"kind":"word","token":"بعيدا","display":"بَعِيداً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۶۷","display":"۱۶۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"خسروا","display":"خَسِرُوا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"خسرانا","display":"خُسْرٰاناً"},{"kind":"word","token":"مبينا","display":"مُبِيناً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۱۹","display":"۱۱۹"},{"kind":"tag_clos