{"consensus_set_id":"13278","translation_language":"fa","translation_source":{"hid":"410522"},"segments":[{"source_hadith_segment":"« صَافِحْ عَدُوَّكَ وَ اِنْ كَرِهَ ،  فَاِنَّهُ مِمَّا اَمَرَ اللَّهُ عَزَّ وَ جَلَّ بِهِ عِبَادَهُ ،  يَقُولُ :   <quranic_text> « اِدْفَعْ بِالَّتِي هِيَ اَحْسَنُ » </quranic_text>   <footnote> [ فصلت ۳۴ ] </footnote>  السَّيِّئَةَ <quranic_text> « فَاِذَا الَّذِي بَيْنَكَ وَ بَيْنَهُ عَدٰاوَةٌ كَاَنَّهُ وَلِيٌّ حَمِيمٌ وَ مٰا يُلَقّٰاهٰا اِلاَّ الَّذِينَ صَبَرُوا وَ مٰا يُلَقّٰاهٰا اِلاّٰ ذُو حَظٍّ عَظِيمٍ » </quranic_text>   <footnote> [ فصلت ۳۴ ] </footnote> مَا تُكَافِئُ عَدُوَّكَ بِشَيْءٍ اَشَدَّ مِنْ اَنْ تُطِيعَ اللَّهَ فِيهِ ،  وَ حَسْبُكَ اَنْ تَرَي عَدُوَّكَ يَعْمَلُ بِمَعَاصِي اللَّهِ عَزَّ وَ جَلَّ فِي الدُّنْيَا »","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"لقيتم","display":"لَقِيتُمْ"},{"kind":"word","token":"اخوانكم","display":"اِخْوَانَكُمْ"},{"kind":"word","token":"فتصافحوا","display":"فَتَصَافَحُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اظهروا","display":"اَظْهِرُوا"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"البشاشه","display":"الْبَشَاشَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"البشر","display":"الْبِشْرَ"},{"kind":"word","token":"تفرقوا","display":"تَفَرَّقُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الاوزار","display":"الْاَوْزَارِ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"ذهب","display":"ذَهَبَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"صافح","display":"صَافِحْ"},{"kind":"