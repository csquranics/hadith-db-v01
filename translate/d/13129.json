{"consensus_set_id":"13129","translation_language":"fa","translation_source":{"hid":"316493"},"segments":[{"source_hadith_segment":"شَهْرُ رَمَضَانَ ثَلاَثُونَ يَوْماً لِقَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ لِتُكْمِلُوا الْعِدَّةَ » </quranic_text>   <footnote> [ البقرة ۱۸۵ ] </footnote>  وَ الْكَامِلَةُ التَّامَّةُ .","translation_segment":"امام ششم (علیه السلام) در ضمن حدیثی طولانی فرمود ماه رمضان سی روز است برای آنکه خدای عز و جل میفرماید شماره را کامل کنید و کامل ماه تمام است.","segment_columns":[{"kind":"word","token":"شهر","display":"شَهْرُ"},{"kind":"word","token":"رمضان","display":"رَمَضَانَ"},{"kind":"word","token":"ثلاثون","display":"ثَلاَثُونَ"},{"kind":"word","token":"يوما","display":"يَوْماً"},{"kind":"word","token":"لقول","display":"لِقَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لتكملوا","display":"لِتُكْمِلُوا"},{"kind":"word","token":"العده","display":"الْعِدَّةَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۸۵","display":"۱۸۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الكامله","display":"الْكَامِلَةُ"},{"kind":"word","token":"التامه","display":"التَّامَّةُ"}]}]}