 يا اصحاب الشّجرة الي اين تفرّون هذا رسول اللّٰه  .  ثمّ رفع رسول اللّٰه صليَّ اللّٰه عليه و اله و سلم يده فقال اللّهم لك الحمد و اليك المشتكيٰ و انت المستعان فنزل عليه جبرئيل فقال يا رسول اللّٰه دعوت بما دعا به موسيٰ ع حيث فلق اللّٰه البحر و نجّاه من فرعون ثمّ قال رسول اللّٰه صليَّ اللّٰه عليه و اله و سلم لابي سفيان بن الحارث ناولني كفّاً من حصي فناوله فرماه في وجوه المشركين ثمّ قال شاهت الوجوه ثمّ رفع راسه الي السماءِ و قال اللّهُمّ ان تهلك هذه العصابة لم تعبد و ان شئت ان لا تعبد لا تعبد . فلما سمعت الانصار نداء العباس عطفوا و كسروا جفون سيوفهم و هم يقولون لبّيك و مرّوا برسول اللّٰه صليَّ اللّٰه عليه و اله و سلم و استحيُوا ان يَرجعُوا اليه و لحقوا بالرّاية فقال رسول اللّٰه صليَّ اللّٰه عليه و اله و سلم للعبّاس من هٰؤلاءِ يا ابا الفضل فقال يا رسول اللّٰه هٰؤلاءِ الانصار فقال رسول اللّٰه صليَّ اللّٰه عليه و اله و سلم الان حمي الوَطيس و نزل النّصر من اللّٰه و انهزمت الهوازن و كانوا يسمعون قعقعة السلاح في الجّو و انهزموا في كلّ وجه","translation_segment":"","segment_columns":[{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلم"},{"kind":"word","token":"اجتماع","display":"اجتماع"},{"kind":"word","token":"هوازن","display":"هوازن"},{"kind":"word","token":"باوطاس","display":"باوطاس"},{"kind":"word","token":"فجمع","display":"فجمع"},{"kind":"word","token":"القبائل","display":"القبائل"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"رغبهم","display":"رغبهم"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"الجهاد","display":"الجهاد"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"وعدهم","display":"وعدهم"},{"kind":"word","token":"النصر","display":"النصر"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"قد","display":"قد"},{"kind":"word","token