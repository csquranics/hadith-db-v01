{"consensus_set_id":"50334","translation_language":"fa","translation_source":{"hid":"354017"},"segments":[{"source_hadith_segment":"عَنْ ابَائِهِ عَلَيْهِمُ السَّلاَمُ  :   <quranic_text> «   <footnote> [ ایهقران کریم ] </footnote>  قَوْلُهُ تَعَالَي تَرٰاهُمْ رُكَّعاً سُجَّداً اَنَّهَا نَزَلَتْ فِي عَلِيٍّ عَلَيْهِ السَّلاَمُ  .  » </quranic_text>","translation_segment":"و دیگر «ترٰاهم‌ رکعا سجدا» موسی بن جعفر از آبای بزرگوار خود (علیه السلام) روایت کرده که این آیت در شأن علی بن ابی طالب نازل شده.","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابائه","display":"ابَائِهِ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ایهقران","display":"ایهقران"},{"kind":"word","token":"کریم","display":"کریم"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"تراهم","display":"تَرٰاهُمْ"},{"kind":"word","token":"ركعا","display":"رُكَّعاً"},{"kind":"word","token":"سجدا","display":"سُجَّداً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفتح29","display":"الفتح29"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"انها","display":"اَنَّهَا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_close","tag_name":"quranic_text"}]}]}