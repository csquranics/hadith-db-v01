خی انکار نمودند، آنگاه بولایت ما دعوتشان کرد، بخدا کسی بدان اقرار کرد که خدایش دوست داشت و آنکه را دشمن داشت، انکار کرد اینست گفتار خدا: «بآنچه از پیش (در عالم ذر) تکذیب کرده‌اند، ایمان نخواهند آورد-۷۴ سوره ۱۰-» سپس امام باقر ع فرمود: تکذیب آنها در آنجا (عالم ذر) بود.","segment_columns":[{"kind":"word","token":"دعاهم","display":"دَعَاهُمْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ولايتنا","display":"وَلاَيَتِنَا"},{"kind":"word","token":"فاقر","display":"فَاَقَرَّ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"احب","display":"اَحَبَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انكرها","display":"اَنْكَرَهَا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"ابغض","display":"اَبْغَضَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فما","display":"فَمٰا"},{"kind":"word","token":"كانوا","display":"كٰانُوا"},{"kind":"word","token":"ليؤمنوا","display":"لِيُؤْمِنُوا"},{"kind":"word","token":"بما","display":"بِمٰا"},{"kind":"word","token":"كذبوا","display":"كَذَّبُوا"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبل","display":"قَبْلُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يونس","display":"يونس"},{"kind":"word","token":"۷۴","display":"۷۴"},{"kind":"tag_