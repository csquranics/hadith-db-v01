{"consensus_set_id":"845","translation_language":"fa","translation_source":{"hid":"105078"},"segments":[{"source_hadith_segment":"وَ عَنْ عُقْبَةَ عَنْ اَبِي جَعْفَرٍ عَلَيْهِ السَّلاَمُ قَالَ :  اِنَّ اللَّهَ خَلَقَ الْخَلْقَ فَخَلَقَ مَا اَحَبَّ مِمَّا اَحَبَّ وَ كَانَ مَا اَحَبَّ اَنْ خَلَقَهُ مِنْ طِينَةِ الْجَنَّةِ وَ خَلَقَ مَا اَبْغَضَ مِمَّا اَبْغَضَ وَ كَانَ مَا اَبْغَضَ اَنْ خَلَقَهُ مِنْ طِينَةِ النَّارِ ثُمَّ بَعَثَهُمْ","translation_segment":"عقبه گوید: امام باقر ع فرمود: خدا مخلوق را آفرید، و هر مخلوقی را که دوست میداشت از ماده‌ای که دوست داشت آفرید، و آنچه را دوست داشت از گل بهشت آفرید. و هر مخلوقی را که دوست نداشت از ماده‌ای که دوست نداشت آفرید، و آنچه را دوست نداشت از گل دوزخ آفرید، سپس آنها","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"عقبه","display":"عُقْبَةَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"الخلق","display":"الْخَلْقَ"},{"kind":"word","token":"فخلق","display":"فَخَلَقَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"احب","display":"اَحَبَّ"},{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"word","token":"احب","display":"اَحَبَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word",