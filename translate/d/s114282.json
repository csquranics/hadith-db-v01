{"consensus_set_id":"s114282","translation_language":"fa","translation_source":{"hid":"114282"},"segments":[{"source_hadith_segment":"سُئِلَ عَنِ الْفَوَاحِشِ  <quranic_text> « مٰا ظَهَرَ مِنْهٰا وَ مٰا بَطَنَ » </quranic_text>   <footnote> [ الانعام ۱۵۱ ] </footnote>  قَالَ مَا ظَهَرَ نِكَاحُ اِمْرَاَةِ الْاَبِ وَ مَا بَطَنَ الزِّنَا .","translation_segment":"ابو مقدام گوید: از امام سجاد علیه السلام درباره فواحش آشکار و پنهان پرسیدند. فرمود: منظور فاحشه آشکار: ازدواج با همسر پدر است و منظور فاحشه پنهان: همان زناست.","segment_columns":[{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الفواحش","display":"الْفَوَاحِشِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ظهر","display":"ظَهَرَ"},{"kind":"word","token":"منها","display":"مِنْهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"بطن","display":"بَطَنَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۱۵۱","display":"۱۵۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"ظهر","display":"ظَهَرَ"},{"kind":"word","token":"نكاح","display":"نِكَاحُ"},{"kind":"word","token":"امراه","display":"اِمْرَاَةِ"},{"kind":"word","token":"الاب","display":"الْاَبِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"بطن","display":"بَطَنَ"},{"kind":"word","token":"الزنا","display":"الزِّنَا"}]}]}