عَي بِرَاحِلَتِهِ فَرَكِبَهَا ،  فَلَمَّا صَارَ بِظَهْرِ الْمَدِينَةِ اَتَتْهُ جَنْدَلَةٌ فَرَضَّتْ هَامَتَهُ فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لِمَنْ حَوْلَهُ مِنَ الْمُنَافِقِينَ اِنْطَلِقُوا اِلَي صَاحِبِكُمْ فَقَدْ اَتَاهُ مَا اِسْتَفْتَحَ بِهِ ،  قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ اِسْتَفْتَحُوا وَ خٰابَ كُلُّ جَبّٰارٍ عَنِيدٍ » </quranic_text>   <footnote> [ ابراهيم ۱۵ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فغضب","display":"فَغَضِبَ"},{"kind":"word","token":"الحارث","display":"الْحَارِثُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"عمرو","display":"عَمْرٍو"},{"kind":"word","token":"الفهري","display":"الْفِهْرِيُّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اللهم","display":"اَللّٰهُمَّ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الحق","display":"الْحَقَّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عندك","display":"عِنْدِكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۳۲","display":"۳۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"هاشم","display":"هَاشِمٍ"},{"kind":"word","token":"يتوارثون","display":"يَتَوَارَثُونَ"},{"kind":"word","token":"هرقل","display":"هِرَقْلَ"},{"kind":"word","token":"فارسل","display":"فَاَرْسِلْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"علينا","dis