{"consensus_set_id":"s322294","translation_language":"fa","translation_source":{"hid":"322294"},"segments":[{"source_hadith_segment":"كَانَ اَبُو عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ ) اِذَا رَاَي الْفُضَيْلَ بْنَ يَسَارٍ قَالَ :   <quranic_text> « بَشِّرِ الْمُخْبِتِينَ » </quranic_text>   <footnote> [ الحج ۳۴ ] </footnote>  مَنْ اَحَبَّ اَنْ يَرَي رَجُلاً مِنْ اَهْلِ الْجَنَّةِ فَلْيَنْظُرْ اِلَي هَذَا .","translation_segment":"","segment_columns":[{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"راي","display":"رَاَي"},{"kind":"word","token":"الفضيل","display":"الْفُضَيْلَ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"يسار","display":"يَسَارٍ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بشر","display":"بَشِّرِ"},{"kind":"word","token":"المخبتين","display":"الْمُخْبِتِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۳۴","display":"۳۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"احب","display":"اَحَبَّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يري","display":"يَرَي"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"فلينظر","display":"فَلْيَنْظُرْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"هذا","display":"هَذَا"}]}]}