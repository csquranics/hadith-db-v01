{"consensus_set_id":"s331655","translation_language":"fa","translation_source":{"hid":"331655"},"segments":[{"source_hadith_segment":"فِي هَذِهِ الْايَةِ :   <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا اِتَّقُوا اللّٰهَ - وَ كُونُوا مَعَ الصّٰادِقِينَ » </quranic_text>   <footnote> [ التوبة ۱۱۹ ] </footnote>   .  قَالَ :  مَعَ عَلِيٍّ وَ اَصْحَابِ عَلِيٍّ  .","translation_segment":"عن ابن عباس، فی هذه الآیه: (یا أیها الذین آمنوا اتقوا الله و کونوا مع الصادقین). قال: مع علی‌ و أصحاب علی‌. ابن عباس درباره این آیه: «اتقوا الله و کونوا مع الصادقین» گفت: با علی و اصحاب علی باشید.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كونوا","display":"كُونُوا"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"الصادقين","display":"الصّٰادِقِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۱۱۹","display":"۱۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابِ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"}]}]}