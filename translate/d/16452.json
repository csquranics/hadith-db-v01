{"consensus_set_id":"16452","translation_language":"fa","translation_source":{"hid":"407777"},"segments":[{"source_hadith_segment":"« لَمَّا اَنْزَلَ اللَّهُ تَعَالَي  <quranic_text> « وَ اتِ ذَا الْقُرْبيٰ حَقَّهُ وَ الْمِسْكِينَ » </quranic_text>   <footnote> [ الاسراء ۲۶ ] </footnote> قَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :  يَا جَبْرَئِيلُ ،  قَدْ عَرَفْتُ الْمِسْكِينَ ،  فَمَنْ ذُو الْقُرْبَي ؟  قَالَ :  هُمْ اَقَارِبُكَ ،  فَدَعَا حَسَناً وَ حُسَيْناً وَ فَاطِمَةَ ،  فَقَالَ :  اِنَّ رَبِّي اَمَرَنِي اَنْ اُعْطِيَكُمْ مِمَّا اَفَاءَ عَلَيَّ - قَالَ - اَعْطَيْتُكُمْ فَدَكَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ات","display":"اتِ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"القربي","display":"الْقُرْبيٰ"},{"kind":"word","token":"حقه","display":"حَقَّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المسكين","display":"الْمِسْكِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۲۶","display":"۲۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلم"},{