{"consensus_set_id":"s332389","translation_language":"fa","translation_source":{"hid":"332389"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اُولٰئِكَ هُمْ خَيْرُ الْبَرِيَّةِ » </quranic_text>   <footnote> [ البينة ۷ ] </footnote>  [ قَالَ :  ] نَزَلَتْ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ  .","translation_segment":"عن ابن عباس فی قوله تعالی: (ألئک هم خیر البریه) قال: نزلت فی علی‌ بن أبی طالب. ابن عباس گفت: «أولٰئک‌ هم‌ خیر البریه‌» درباره علی نازل شده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"خير","display":"خَيْرُ"},{"kind":"word","token":"البريه","display":"الْبَرِيَّةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البينه","display":"البينة"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"}]}]}