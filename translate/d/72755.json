{"consensus_set_id":"72755","translation_language":"fa","translation_source":{"hid":"375021"},"segments":[{"source_hadith_segment":"لِطَلَبِ اَلْوَلَدِ قَالَ اِذَا اَرَدْتَ الْمُبَاشَرَةَ فَلْتَقْرَاْ ثَلاَثَ مَرَّاتٍ  <quranic_text> « وَ ذَا النُّونِ اِذْ ذَهَبَ مُغٰاضِباً » </quranic_text>   <footnote> [ الانبياء ۸۷ ] </footnote>  الْايَةَ .","translation_segment":"و از آن حضرت روایت است که برای طلب فرزند، در وقتی که اراده آمیزش داری این آیه را سه بار بخوان: «و ذا النون‌ إذ ذهب‌» …» (انبیاء-۸۷)","segment_columns":[{"kind":"word","token":"لطلب","display":"لِطَلَبِ"},{"kind":"word","token":"الولد","display":"اَلْوَلَدِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اردت","display":"اَرَدْتَ"},{"kind":"word","token":"المباشره","display":"الْمُبَاشَرَةَ"},{"kind":"word","token":"فلتقرا","display":"فَلْتَقْرَاْ"},{"kind":"word","token":"ثلاث","display":"ثَلاَثَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"النون","display":"النُّونِ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"ذهب","display":"ذَهَبَ"},{"kind":"word","token":"مغاضبا","display":"مُغٰاضِباً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۸۷","display":"۸۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"}]}]}