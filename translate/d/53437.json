{"consensus_set_id":"53437","translation_language":"fa","translation_source":{"hid":"353926"},"segments":[{"source_hadith_segment":"قَوْلُهُ تَعَالَي :   <quranic_text> « لَقَدْ رَضِيَ اللّٰهُ عَنِ الْمُؤْمِنِينَ اِذْ يُبٰايِعُونَكَ تَحْتَ الشَّجَرَةِ » </quranic_text>   <footnote> [ الفتح ۱۸ ] </footnote>  نَزَلَتْ فِي اَهْلِ الْحُدَيْبِيَةِ","translation_segment":"و آیت «لقد رضی‌ اللٰه‌ عن‌ المومنین‌ إذ یبٰایعونک‌ تحت‌ الشجره‌» در شأن أهل حدیبیه سمت نزول یافت جابر گوید که: ما در آن روز هزار و چهار صد کس،","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"رضي","display":"رَضِيَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"يبايعونك","display":"يُبٰايِعُونَكَ"},{"kind":"word","token":"تحت","display":"تَحْتَ"},{"kind":"word","token":"الشجره","display":"الشَّجَرَةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفتح","display":"الفتح"},{"kind":"word","token":"۱۸","display":"۱۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الحديبيه","display":"الْحُدَيْبِيَةِ"}]},{"source_hadith_segment":"قَالَ جَابِرٌ كُنَّا يَوْمَئِذٍ اَلْفاً وَ اَرْبَعَمِائَةٍ فَقَالَ لَنَا النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَنْتُمُ الْيَوْمَ خِيَارُ اَهْلِ الْاَرْضِ فَبَايَعْنَا تَحْتَ الشَّجَرَةِ عَلَي الْمَوْتِ فَمَا نَكَثَ اِلاَّ جُزْءُ بْنُ قَيْسٍ وَ كَانَ مُنَافِقاً وَ اَوْلَي النَّاسِ بِهَذِهِ الْايَةِ عَلِيُّ بْنُ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ لِاَنَّهُ تَعَالَي قَالَ :   <quranic_text> « وَ اَثٰابَهُمْ فَتْحاً قَرِيباً » </quranic_text>   <footnote> [ الفتح ۱۸ ] </footnote>  يَعْنِي فَتَحَ خَيْبَرَ وَ كَانَ ذَلِكَ عَلَي يَدِ عَلِيِّ بْنِ اَبِي طَالِبٍ صَلَوَاتُ اللَّهِ عَلَيْهِ  .","translation_segment":"بودیم که پیغمبر (صلی الله علیه و آله) گفت بما که: شما امروز بهترین أهل زمینید که ما بیعت کردیم در زیر درخت سمره بر موت که نگریزیم و کسی نقض آن عهد نکرد مگر جزء «حرب خ» بن قیس که منافق شد و اولی مردمان باین آیت علی بن ابی طالب (علیه السلام) است زیرا که حقتعالی فرمود که «و أثٰابهم‌ فتحا قریبا» یعنی و پاداش داد ایشان را بفتح نزدیک که فتح خیبر است و آن بر دست امیر المومنین (علیه السلام) شد.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"جابر","display":"جَابِرٌ"},{"kind":"word","token":"كنا","display":"كُنَّا"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"الحديبيه","display":"الْحُدَيْبِيَةِ"},{"kind":"word","token":"الفا","display":"اَلْفاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اربعمائه","display":"اَرْبَعَمِائَةٍ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لنا","display":"لَنَا"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"انتم","display":"اَنْتُمُ"},{"kind":"word","token":"اليوم","display":"الْيَوْمَ"},{"kind":"word","token":"خيار","display":"خِيَارُ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"فبايعنا","display":"فَبَايَعْنَا"},{"kind":"word","token":"تحت","display":"تَحْتَ"},{"kind":"word","token":"الشجره","display":"الشَّجَرَةِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word",