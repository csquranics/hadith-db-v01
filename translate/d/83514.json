{"consensus_set_id":"83514","translation_language":"fa","translation_source":{"hid":"305460"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَحَدَهُمَا عَنْ قَوْلِهِ :   <quranic_text> « وَسِعَ كُرْسِيُّهُ السَّمٰاوٰاتِ وَ الْاَرْضَ » </quranic_text>   <footnote> [ البقرة ۲۵۵ ] </footnote>  اَيُّهُمَا وَسِعَ الْاخَرَ قَالَ :  الْاَرَضُونَ كُلُّهَا وَ السَّمَاوَاتُ كُلُّهَا وَ جَمِيعُ مَا خَلَقَ اللَّهُ فِي الْكُرْسِيِّ .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"احدهما","display":"اَحَدَهُمَا"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"وسع","display":"وَسِعَ"},{"kind":"word","token":"كرسيه","display":"كُرْسِيُّهُ"},{"kind":"word","token":"السماوات","display":"السَّمٰاوٰاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۵۵","display":"۲۵۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ايهما","display":"اَيُّهُمَا"},{"kind":"word","token":"وسع","display":"وَسِعَ"},{"kind":"word","token":"الاخر","display":"الْاخَرَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الارضون","display":"الْاَرَضُونَ"},{"kind":"word","token":"كلها","display":"كُلُّهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السماوات","display":"السَّمَاوَاتُ"},{"kind":"word","token":"كلها","display":"كُلُّهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جميع","display":"جَمِيعُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الك