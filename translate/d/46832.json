{"consensus_set_id":"46832","translation_language":"fa","translation_source":{"hid":"282856"},"segments":[{"source_hadith_segment":"عَلَي اَلَّذِي اَفْطَرَ الْقَضَاءُ لِاَنَّ اللَّهَ تَعَالَي يَقُولُ  <quranic_text> « ثُمَّ اَتِمُّوا الصِّيٰامَ اِلَي اللَّيْلِ » </quranic_text>   <footnote> [ البقرة ۱۸۷ ] </footnote>  فَمَنْ اَكَلَ قَبْلَ اَنْ يَدْخُلَ اللَّيْلُ فَعَلَيْهِ قَضَاؤُهُ لِاَنَّهُ اَكَلَ مُتَعَمِّداً .","translation_segment":"","segment_columns":[{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الذي","display":"اَلَّذِي"},{"kind":"word","token":"افطر","display":"اَفْطَرَ"},{"kind":"word","token":"القضاء","display":"الْقَضَاءُ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اتموا","display":"اَتِمُّوا"},{"kind":"word","token":"الصيام","display":"الصِّيٰامَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الليل","display":"اللَّيْلِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۸۷","display":"۱۸۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"اكل","display":"اَكَلَ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يدخل","display":"يَدْخُلَ"},{"kind":"word","token":"الليل","display":"اللَّيْلُ"},{"kind":"word","token":"فعليه","display":"فَعَلَيْهِ"},{"kind":"word","token":"قضاؤه","display":"قَضَاؤُهُ"},{"kind":"word","token":"لانه","display":"لِاَنَّهُ"},{"kind":"word","token":"اكل","display":"اَكَلَ"},{"kind":"word","token":"متعمدا","display":"مُتَعَمِّداً"}]}]}