{"consensus_set_id":"116935","translation_language":"fa","translation_source":{"hid":"331854"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « وَعَدَ اللّٰهُ الَّذِينَ امَنُوا » </quranic_text>   <footnote> [ النور ۵۵ ] </footnote>  اِلَي اخِرِ الْايَةِ ،  قَالَ :  نَزَلَتْ فِي الِ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  .","translation_segment":"عن ابن عباس فی قوله: (وعد الله الذین آمنوا) إلی آخر الآیه؛ قال: نزلت فی آل محمد (صلی الله علیه و آله). ابن عباس درباره سخن خداوند: «وعد الله الذین آمنوا» گفت: درباره آل محمد نازل شده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"وعد","display":"وَعَدَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عملوا","display":"عَمِلُوا"},{"kind":"word","token":"الصالحات","display":"الصّٰالِحٰاتِ"},{"kind":"word","token":"ليستخلفنهم","display":"لَيَسْتَخْلِفَنَّهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۵۵","display":"۵۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"اخر","display":"اخِرِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word"