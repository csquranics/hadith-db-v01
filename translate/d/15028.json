{"consensus_set_id":"15028","translation_language":"fa","translation_source":{"hid":"94154"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ رَجُلٍ ظَاهَرَ مِنِ اِمْرَاَتِهِ ثُمَّ طَلَّقَهَا","translation_segment":"* *۲۶ - از ابو جعفر باقر (ع) پرسیدم: اگر کسی با همسر خود ظهار کند و سپس او را","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"ظاهر","display":"ظَاهَرَ"},{"kind":"word","token":"من","display":"مِنِ"},{"kind":"word","token":"امراته","display":"اِمْرَاَتِهِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"طلقها","display":"طَلَّقَهَا"}]},{"source_hadith_segment":"تَطْلِيقَةً فَقَالَ « اِذَا طَلَّقَهَا تَطْلِيقَةً فَقَدْ بَطَلَ الظِّهَارُ وَ هَدَمَ الطَّلاَقُ الظِّهَارَ » قَالَ","translation_segment":"طلاق بدهد، باز هم باید کفاره بپردازد؟ ابو جعفر گفت: در اثر طلاق، ظهار باطل می‌شود و کفاره لازم","segment_columns":[{"kind":"word","token":"تطليقه","display":"تَطْلِيقَةً"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"طلقها","display":"طَلَّقَهَا"},{"kind":"word","token":"تطليقه","display":"تَطْلِيقَةً"},{"kind":"word","token":"فقد","display":"فَقَدْ"},{"kind":"word","token":"بطل","display":"بَطَلَ"},{"kind":"word","token":"الظهار","display":"الظِّهَارُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هدم","display":"هَدَمَ"},{"kind":"word","token":"الطلاق","display":"الطَّلاَقُ"},{"kind":"word","token":"الظهار","display":"الظِّهَارَ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"فَقُلْتُ لَهُ فَلَهُ اَنْ يُرَاجِعَهَا قَالَ « نَعَمْ هِيَ اِمْرَاَتُهُ »","translation_segment":"نیست. من گفتم: آیا شوهر حق رجوع دارد؟ ابو","segment_columns":[{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"فله","display":"فَلَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يراجعها","display":"يُرَاجِعَهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"امراته","display":"اِمْرَاَتُهُ"}]},{"source_hadith_segment":"قَالَ « فَاِنْ رَاجَعَهَا وَجَبَ عَلَيْهِ مَا يَجِبُ عَلَي الْمُظَاهِرِ  <quranic_text> « مِنْ قَبْلِ اَنْ يَتَمَاسّٰا » </quranic_text>   <footnote> [ المجادلة ۳ ] </footnote> قُلْتُ فَاِنْ تَرَكَهَا حَتَّي يَخْلُوَ اَجَلُهَا وَ تَمْلِكَ نَفْسَهَا ثُمَّ يَتَزَوَّجُهَا بَعْدُ هَلْ يَلْزَمُهُ الظِّهَارُ قَبْلَ اَنْ يَمَسَّهَا قَالَ « لاَ قَدْ بَانَتْ مِنْهُ وَ مَلَكَتْ نَفْسَهَا » قُلْتُ فَاِنْ ظَاهَرَ مِنْهَا وَ لَمْ يَمَسَّهَا وَ تَرَكَهَا لاَ يَمَسُّهَا اِلاَّ اَنَّهُ يَرَاهَا مُتَجَرِّدَةً مِنْ غَيْرِ اَنْ يَمَسَّهَا هَلْ يَلْزَمُهُ شَيْءٌ فَقَالَ « هِيَ اِمْرَاَتُهُ وَ لَيْسَ بِمُحَرَّمٍ عَلَيْهِ مُجَامَعَتُهَا وَ لَكِنْ يَجِبُ عَلَيْهِ مَا يَجِبُ عَلَي الْمُظَاهِرِ قَبْلَ اَنْ يُجَامِعَهَا وَ هِيَ اِمْرَاَتُهُ » قُلْتُ فَاِنْ رَفَعَتْهُ اِلَي السُّلْطَانِ فَقَالَتْ هَذَا زَوْجِي قَدْ ظَاهَرَ مِنِّي وَ قَدْ اَمْسَكَنِي لاَ يَمَسُّنِي مَخَافَةَ اَنْ يَجِبَ عَلَيْهِ مَا يَجِبُ عَلَي الْمُظَاهِرِ قَالَ فَقَالَ « لَيْسَ يَجِبُ عَلَيْهِ اَنْ يُجْبَرَ عَلَي الْعِتْقِ وَ الصِّيَامِ وَ الْاِطْعَامِ اِذَا لَمْ يَكُنْ لَهُ مَا يُعْتِقُ وَ لَمْ يَقْوَ عَلَي الصِّيَامِ وَ لَمْ يَجِدْ مَا يَتَصَدَّقُ بِهِ » وَ قَالَ « فَاِنْ كَانَ يَقْدِرُ عَلَي اَنْ يُعْتِقَ فَاِنَّ عَلَي الْاِمَامِ اَنْ يُجْبِرَهُ عَلَي الْعِتْقِ وَ الصَّدَقَةِ مِنْ قَبْلِ اَنْ يَمَسَّهَا وَ مِنْ بَعْدِ مَا يَمَسُّهَا » .","translation_segment":"جعفر گفت: بلی. این خانم همسر او است. ولی اگر رجوع کند، باید قبل از مباشرت کفاره بپردازد. من گفتم: اگر رجوع نکند و خانم را وابنهد تا عده طلاق بسر آید و مجددا او را عقد کند، آیا قبل از عروسی باید کفاره بپردازد؟ ابو جعفر گفت: نه. بعد از طلاق، ازدواج آنان منتفی می‌گردد و خانم صاحب اختیار خویشتن خواهد شد. من گفتم: اگر ظهار کرده باشد و بعد از ظهار مباشرت نکند و مانند سابق به اندام عریان او بنگرد، چه‌صورت دارد؟ ابو جعفر گفت: این خانم همسر او است و مقاربت با او تحریم نشده است فقط‍‌ باید قبل از مباشرت کفاره بپردازد. من گفتم: اگر خانم به نزد قاضی شکایت کند و بگوید: شوهرم با من ظهار کرده و چون نمی‌خواهد کفاره بپردازد، مرا به صورت عاریه در منزل نگه داشته است، آیا قاضی می‌تواند شوهر او را مجبور کند تا کفاره بپردازد؟ ابو جعفر گفت: اگر شوهر او قدرت مالی و جسمانی نداشته باشد قاضی نمی‌تواند او را مجبور کند که حتما یک برده آزاد کند و یا دوماه پی‌درپی روزه بگیرد و یا به شصت مسکین بیکار خوراک بدهد. البته اگر شوهر او قدرت مالی داشته باشد او را مجبور می‌کنند که یک برده آزاد کند و یا به شصت مسکین خوراک بدهد: خواه با همسرش مباشرت کرده باشد و یا مباشرت نکرده باشد.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"راجعها","display":"رَاجَعَهَا"},{"kind":"word","token":"وجب","display":"وَجَبَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يجب","display":"يَجِبُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المظاهر","display":"الْمُظَاهِرِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبل","display":"قَبْلِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتماسا","display":"يَتَمَاسّٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المجادله","display":"المجادلة"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name