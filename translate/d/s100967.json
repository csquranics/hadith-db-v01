{"consensus_set_id":"s100967","translation_language":"fa","translation_source":{"hid":"100967"},"segments":[{"source_hadith_segment":"اَنَّهُ سُئِلَ عَنِ الْحَصْبَةِ فَقَالَ « كَانَ اَبِي عَلَيْهِ السَّلاَمُ يَنْزِلُ الْاَبْطَحَ قَلِيلاً ثُمَّ يَدْخُلُ الْبُيُوتَ مِنْ غَيْرِ اَنْ يَنَامَ بِالْاَبْطَحِ »","translation_segment":"ابان از ابو مریم (عبد الغفار بن قاسم) از امام صادق علیه السلام روایت کرده است، که آن حضرت را در باره حصبه سوال کردند، پس فرمود: پدرم علیه السلام اندکی در ابطح منزل میگزید،","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الحصبه","display":"الْحَصْبَةِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ينزل","display":"يَنْزِلُ"},{"kind":"word","token":"الابطح","display":"الْاَبْطَحَ"},{"kind":"word","token":"قليلا","display":"قَلِيلاً"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يدخل","display":"يَدْخُلُ"},{"kind":"word","token":"البيوت","display":"الْبُيُوتَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"غير","display":"غَيْرِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ينام","display":"يَنَامَ"},{"kind":"word","token":"بالابطح","display":"بِالْاَبْطَحِ"}]},{"source_hadith_segment":"فَقُلْتُ لَهُ اَ رَاَيْتَ مَنْ  <quranic_text> « تَعَجَّلَ فِي يَوْمَيْنِ » </quranic_text>   <footnote> [ البقرة ۲۰۳ ] </footnote>  عَلَيْهِ اَنْ يُحَصِّبَ قَالَ « لاَ » .","translation_segment":"و آنگاه بخانه‌ها داخل میشد، بی‌آنکه در ابطح بخوابد. راوی گفت: پس معروض داشتم که بنظر شما آیا کسی که پس از دو روز از منی کوچ کرده مکلف است که در حصبه فرود آید؟ فرمود: نه.","segment_columns":[{"kind":"word","token":"فقلت","display