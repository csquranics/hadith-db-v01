{"consensus_set_id":"s403468","translation_language":"fa","translation_source":{"hid":"403468"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ :   <quranic_text> « هُوَ الَّذِي اَنْزَلَ عَلَيْكَ الْكِتٰابَ مِنْهُ ايٰاتٌ مُحْكَمٰاتٌ » </quranic_text>   <footnote> [ العمران ۷ ] </footnote>  قَالَ :  «  اَمِيرُ الْمُؤْمِنِينَ وَ الْاَئِمَّةُ ( عَلَيْهِمُ السَّلاَمُ )  <quranic_text> « وَ اُخَرُ مُتَشٰابِهٰاتٌ » </quranic_text>   <footnote> [ العمران ۷ ] </footnote> فُلاَنٌ وَ فُلاَنٌ  <quranic_text> « فَاَمَّا الَّذِينَ فِي قُلُوبِهِمْ زَيْغٌ » </quranic_text>   <footnote> [ العمران ۷ ] </footnote> اَصْحَابُهُمْ وَ اَهْلُ وَلاَيَتِهِمْ <quranic_text> « فَيَتَّبِعُونَ مٰا تَشٰابَهَ مِنْهُ اِبْتِغٰاءَ الْفِتْنَةِ وَ اِبْتِغٰاءَ تَاْوِيلِهِ » </quranic_text>   <footnote> [ العمران ۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابَ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"ايات","display":"ايٰاتٌ"},{"kind":"word","token":"محكمات","display":"مُحْكَمٰاتٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الائمه","display":"الْاَئِمَّةُ"},{"kind":"word","token":"عليهم","display":"عَل