d","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"مدينه","display":"مَدِينَةً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"مدائن","display":"مَدَائِنِ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنَ"}]},{"source_hadith_segment":"<quranic_text> « عَليٰ حِينِ غَفْلَةٍ مِنْ اَهْلِهٰا » </quranic_text>   <footnote> [ القصص ۱۵ ] </footnote>","translation_segment":". آن حضرت فرمودند: موسی نیمه‌شب","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"حين","display":"حِينِ"},{"kind":"word","token":"غفله","display":"غَفْلَةٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهلها","display":"اَهْلِهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۱۵","display":"۱۵"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"وَ ذَلِكَ بَيْنَ الْمَغْرِبِ وَ الْعِشَاءِ","translation_segment":"وارد یکی از شهرهای مصر شد و","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"المغرب","display":"الْمَغْرِبِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"العشاء","display":"الْعِشَاءِ"}]},{"source_hadith_segment":"<quranic_text> « فَوَجَدَ فِيهٰا رَجُلَيْنِ يَقْتَتِلاٰنِ هٰذٰا مِنْ شِيعَتِهِ وَ هٰذٰا مِنْ عَدُوِّهِ فَاسْتَغٰاثَهُ الَّذِي مِنْ شِيعَتِهِ عَلَي الَّذِي مِنْ عَدُوِّهِ » </quranic_text>","translation_segment":"در همان آغاز شهر، دو مرد را دید که با","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فوجد","display":"فَوَجَدَ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"رجلين","display":"رَجُلَيْنِ"},{"kind":"word","token":"يقتتلان","display":"يَقْتَتِلاٰنِ"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شيعته","display":"شِيعَتِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عدوه","display":"عَدُوِّهِ"},{"kind":"word","token":"فاستغاثه","display":"فَاسْتَغٰاثَهُ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شيعته","display":"شِيعَتِهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عدوه","display":"عَدُوِّهِ"},{"kind":"tag_close","tag_name":"quranic_text"}]},{"source_hadith_segment":"<footnote> [ القصص ۱۵ ] </footnote>","translation_segment":"یکدیگر جدال می‌کنند، یکی از آن‌دو پیرو موسی و","segment_columns":[{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۱۵","display":"۱۵"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"فَقَضَي مُوسَي عَلَي الْعَدُوِّ بِحُكْمِ اللَّهِ تَعَالَي ذِكْرُهُ  <quranic_text> « فَوَكَزَهُ » </quranic_text>   <footnote> [ القصص ۱۵ ] </footnote>  فَمَاتَ قَالَ هَذَا مِنْ عَمَلِ الاِقْتِتَالِ الَّذِي كَانَ وَقَعَ بَيْنَ الرِّجْلَيْنِ لاَ مَا فَعَلَهُ مُوسَي عَلَيْهِ السَّلاَمُ مِنْ قَتْلِهِ  <quranic_text> « اِنَّهُ » </quranic_text>   <footnote> [ القصص ۱۵ ] </footnote>  يَعْنِي الشَّيْطَانَ  <quranic_text> « عَدُوٌّ مُضِلٌّ مُبِينٌ » </quranic_text>   <footnote> [ القصص ۱۵ ] </footnote>  قَالَ الْمَاْمُونُ فَمَا مَعْنَي قَوْلِ مُوسَي  <quranic_text> « رَبِّ اِنِّي ظَلَمْتُ نَفْسِي فَاغْفِرْ لِي » </quranic_text>   <footnote> [ القصص ۱۶ ] </footnote>  قَالَ يَقُولُ اِنِّي وَضَعْتُ نَفْسِي غَيْرَ مَوْضِعِهَا بِدُخُولِي هَذِهِ الْمَدِينَةَ  <quranic_text> « فَاغْفِرْ لِي » </quranic_text>   <footnote> [ القصص ۱۶ ] </footnote>  اَيْ اُسْتُرْنِي مِنْ اَعْدَائِكَ لِئَلاَّ يَظْفَرُوا بِي فَيَقْتُلُونِي  <quranic_text> « فَغَفَرَ لَهُ اِنَّهُ هُوَ الْغَفُورُ الرَّحِيمُ قٰالَ » </quranic_text>   <footnote> [ القصص ۱۶ ] </footnote>  مُوسَي عَلَيْهِ السَّلاَمُ  <quranic_text> « رَبِّ بِمٰا اَنْعَمْتَ عَلَيَّ » </quranic_text>   <footnote> [ القصص ۱۷ ] </footnote>  مِنَ الْقُوَّةِ حَتَّي قَتَلْتُ رَجُلاً بِوَكْزَةٍ  <quranic_text> « فَلَنْ اَكُونَ ظَهِيراً لِلْمُجْرِمِينَ » </quranic_text>   <footnote> [ القصص ۱۷ ] </footnote>  بَلْ اُجَاهِدُ فِي سَبِيلِكَ بِهَذِهِ الْقُوَّةِ حَتَّي تَرْضَي  <quranic_text> « فَاَصْبَحَ » </quranic_text>   <footnote> [ القصص ۱۸ ] </footnote>  مُوسَي  <quranic_text> « فِي الْمَدِينَةِ خٰائِفاً يَتَرَقَّبُ فَاِذَا الَّذِي اِسْتَنْصَرَهُ بِالْاَمْسِ يَسْتَصْرِخُهُ » </quranic_text>   <footnote> [ القصص ۱۸ ] </footnote>  عَلَي اخَرَ  <quranic_text> « قٰالَ لَهُ مُوسيٰ اِنَّكَ لَغَوِيٌّ مُبِينٌ » </quranic_text>   <footnote> [ القصص ۱۸ ] </footnote>  قَاتَلْتَ رَجُلاً بِالْاَمْسِ وَ تُقَاتِلُ هَذَا الْيَوْمَ لَاُؤَدِّبَنَّكَ وَ اَرَادَ اَنْ يَبْطِشَ بِهِ فَاَرَادَ  <quranic_text> « اَنْ يَبْطِشَ بِالَّذِي هُوَ عَدُوٌّ لَهُمٰا » </quranic_text>   <footnote> [ القصص ۱۹ ] </footnote>  وَ هُوَ مِنْ شِيعَتِهِ  <quranic_text> « قٰالَ يٰا مُوسيٰ  » </quranic_text>   <footnote> [ القصص ۱۹ ] </footnote>   .  .  .   <quranic_text> « تُرِيدُ اَنْ تَقْتُلَنِي كَمٰا قَتَلْتَ نَفْساً بِالْاَمْسِ اِنْ تُرِيدُ [ اِلاّٰ ] اَنْ تَكُونَ جَبّٰاراً فِي الْاَرْضِ وَ مٰا تُرِيدُ اَنْ تَكُونَ مِنَ الْمُصْلِحِينَ » </quranic_text>   <footnote> [ القصص ۱۹ ] </footnote>  قَالَ الْمَاْمُونُ جَزَاكَ اللَّهُ خَيْراً يَا اَبَا الْحَسَنِ فَمَا مَعْنَي قَوْلِ مُوسَي لِفِرْعَوْنَ  <quranic_text> « فَعَلْتُهٰا اِذاً وَ اَنَا مِنَ الضّٰالِّينَ » </quranic_text>   <footnote> [ الشعراء ۲۰ ] </footnote>  قَالَ الرِّضَا عَلَيْهِ السَّلاَمُ اِنَّ فِرْعَوْنَ قَالَ لِمُوسَي لَمَّا اَتَاهُ  <quranic_text> « فَعَلْتَ فَعْلَتَكَ الَّتِي فَعَلْتَ وَ اَنْتَ مِنَ الْكٰافِرِينَ » </quranic_text>   <footnote> [ الشعراء ۱۹ ] </footnote>","translation_segment":"دیگری دشمنش بود. موسی در این میان بر آن مرد قبطی کافر مشتی زد و او همان دم جان سپرد، در این هنگام امام رضا علیه السلام فرمودند: در حقیقت جدال و ستیز آن‌دو، مرگ آن کافر را پیش آورد نه مشت حضرت موسی. آنگاه مأمون از آن حضرت پرسید: چرا موسی پس از کشتن آن کافر اینگونه گفت: «رب‌ إنی ظلمت‌ نفسی فاغفر لی». آن حضرت فرمودند: در حقیقت ستمی را که موسی بر خود روا داشته بود این است که وارد شهر شده و در ستیز میان آن‌دو دخالت کرده است که کارش با مرگ مرد قبطی همراه شد و این‌که موسی به خداوند عرضه داشت: «فاغفرلی» به معنای آن است که خداوندا مرا از دست دشمنانت دور نگاه دار. آن‌گاه موسی گفت: «رب‌ بمٰا أنعمت‌ علی‌» یعنی خداوندا به سبب نیرویی که به من ارزانی داشتی تا آن مرد کافر را بکشم، پیوسته در راه تو با دشمنان ستیز خواهم کرد تا خشنودی تو را به دست آورم و هیچگاه پشتیبان ستم‌پیشگان نخواهم بود. سپس مأمون از آن حضرت پرسید: مقصود از آیه «فعلتهٰا إذا و أنا من‌ الضٰالین‌» پرسید. آن حضرت فرمودند: این جمله را موسی زمانی گفت که فرعون او را به کشتن مرد قبطی متهم ساخت. و باید گفت مقصود از «الضالین» به معنای گمراه نیست بلکه به معنای سرگشته است. یعنی مقصود موسی این بود که من پس از خروج از قصر فرعون، سرگردان بودم و سرانجام به شهری رسیدم که آن دو نفر باهم ستیز می‌کردند و","segment_columns":[{"kind":"word","token":"فقضي","display":"فَقَضَي"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"العدو","display":"الْعَدُوِّ"},{"kind":"word","token":"بحكم","display":"بِحُكْمِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token