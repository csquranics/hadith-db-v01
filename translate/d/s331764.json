{"consensus_set_id":"s331764","translation_language":"fa","translation_source":{"hid":"331764"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « اُولٰئِكَ الَّذِينَ يَدْعُونَ يَبْتَغُونَ اِليٰ رَبِّهِمُ الْوَسِيلَةَ » </quranic_text>   <footnote> [ الاسراء ۵۷ ] </footnote>  قَالَ :  هُمُ النَّبِيُّ وَ عَلِيٌّ وَ فَاطِمَةُ وَ الْحَسَنُ وَ الْحُسَيْنُ عَلَيْهِمُ السَّلاَمُ  .","translation_segment":"عن عکرمه فی قوله: (أولئک الذین یدعون یبتغون إلی ربهم الوسیله) قال: هم النبی و علی‌ و فاطمه و الحسن و الحسین ع. عکرمه درباره سخن خداوند: «اولئک الذین یدعون یبتغون الی ربهم الوسیله» گفت: آنان پیامبر و علی و فاطمه و حسن و حسین هستند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يدعون","display":"يَدْعُونَ"},{"kind":"word","token":"يبتغون","display":"يَبْتَغُونَ"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"ربهم","display":"رَبِّهِمُ"},{"kind":"word","token":"الوسيله","display":"الْوَسِيلَةَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۵۷","display":"۵۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"عليهم","displ