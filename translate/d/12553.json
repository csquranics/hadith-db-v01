{"consensus_set_id":"12553","translation_language":"fa","translation_source":{"hid":"403990"},"segments":[{"source_hadith_segment":"« اِنَّ فَاطِمَةَ ( صَلَوَاتُ اللَّهِ عَلَيْهَا ) اِنْطَلَقَتْ اِلَي اَبِي بَكْرٍ فَطَلَبَتْ مِيرَاثَهَا مِنْ نَبِيِّ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  ،  فَقَالَ :  اِنَّ نَبِيَّ اللَّهِ لاَ يُوَرِّثُ ،  فَقَالَتْ :  اَ كَفَرْتَ بِاللَّهِ وَ كَذَّبْتَ بِكِتَابِهِ ؟  قَالَ اللَّهُ :   <quranic_text> « يُوصِيكُمُ اللّٰهُ فِي اَوْلاٰدِكُمْ لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"انطلقت","display":"اِنْطَلَقَتْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"بكر","display":"بَكْرٍ"},{"kind":"word","token":"فطلبت","display":"فَطَلَبَتْ"},{"kind":"word","token":"ميراثها","display":"مِيرَاثَهَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"نبي","display":"نَبِيِّ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلم"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"نبي","display":"نَبِيَّ"},{"kind":"word","token":"الله