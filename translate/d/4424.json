{"consensus_set_id":"4424","translation_language":"fa","translation_source":{"hid":"101672"},"segments":[{"source_hadith_segment":"وَ قَالَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ « مَا فَعَلَ عُمَرُ بْنُ مُسْلِمٍ »","translation_segment":"علی بن عبد العزیز گوید: امام صادق علیه السلام از من سوال فرمود: عمر بن مسلم","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"فعل","display":"فَعَلَ"},{"kind":"word","token":"عمر","display":"عُمَرُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"مسلم","display":"مُسْلِمٍ"}]},{"source_hadith_segment":"قُلْتُ جُعِلْتُ فِدَاكَ اَقْبَلَ عَلَي الْعِبَادَةِ وَ تَرَكَ التِّجَارَةَ","translation_segment":"چه می‌کند؟ عرض کردم فدایت شوم به عبادت رو کرده و دست از کسب و کار","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"جعلت","display":"جُعِلْتُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"اقبل","display":"اَقْبَلَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"العباده","display":"الْعِبَادَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ترك","display":"تَرَكَ"},{"kind":"word","token":"التجاره","display":"التِّجَارَةَ"}]},{"source_hadith_segment":"فَقَالَ « وَيْحَهُ اَ مَا عَلِمَ اَنَّ تَارِكَ الطَّلَبِ لاَ يُسْتَجَابُ لَهُ دَعْوَةٌ ،  اِنَّ قَوْماً مِنْ اَصْحَابِ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لَمَّا نَزَلَتْ :   <quranic_text> « وَ مَنْ يَتَّقِ اللّٰهَ يَجْعَلْ لَهُ مَخْرَجاً وَ يَرْزُقْهُ مِنْ حَيْثُ لاٰ يَحْتَسِبُ » </quranic_text>   <footnote> [ الطلاق ۲ ] </footnote>  اَغْلَقُوا الْاَبْوَابَ وَ اَقْبَلُوا عَلَي الْعِبَادَةِ وَ قَالُوا قَدْ كُفِينَا فَبَلَغَ ذَلِكَ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَاَرْسَلَ اِلَيْهِمْ فَقَالَ « مَا حَمَلَكُمْ عَلَي مَا صَنَعْتُمْ » قَالُوا يَا رَسُولَ اللَّهِ تَكَفَّلَ اللَّهُ عَزَّ وَ جَلَّ بِاَرْزَاقِنَا فَاَقْبَلْنَا عَلَي الْعِبَادَةِ فَقَالَ « اِنَّهُ مَنْ فَعَلَ ذَلِكَ لَمْ يَسْتَجِبِ اللَّهُ لَهُ عَلَيْكُمْ بِالطَّلَبِ » ثُمَّ قَالَ « اِنِّي لَاُبْغِضُ الرَّجُلَ فَاغِراً فَاهُ اِلَي رَبِّهِ يَقُولُ اُرْزُقْنِي وَ يَتْرُكُ الطَّلَبَ » » .","translation_segment":"کشیده است، فرمود: ای وای! آیا نمی‌داند کسی که کار را رها کند هیچ دعائی از او به اجابت نمی‌رسد، بعد فرمود: جماعتی از اصحاب رسول خدا صلی اللٰه علیه و آله هنگامی که آیه شریفه «و من‌ یتق‌ اللٰه‌ یجعل‌ له‌ مخرجا» - الخ» نازل شد مغازه‌های خود را بستند و در مسجد به عبادت رو آوردند و با خود می‌گفتند که خداوند ما را کفایت کرد، و این موضوع به گوش رسول خدا صلی اللٰه علیه و آله رسید نزد آنها فرستاد و پرسید چه چیز شما را بدین کار که کرده‌اید واداشت‌؟ گفتند: یا رسول اللٰه خداوند خود روزی ما را تکفل فرموده لذا ما به عبادت و پرستش او رو کرده‌ایم، فرمود: براستی که هر کس چنین کند دعایش را خداوند اجابت نفرماید، بر شما باد که طلب روزی کنید و به کار و حرفه‌ای بپردازید، سپس فرمود: من دشمن دارم آن کس را که کار را ترک کند و دهان به روی آسمان بگشاید و بگوید: خداوندا، مرا روزی ده، و کوشش را رها کند.","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ويحه","display":"وَيْحَهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"علم","display":"عَلِمَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"تارك","display":"تَارِكَ"},{"kind":"word","token":"الطلب","display":"الطَّلَبِ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يستجاب","display":"يُسْتَجَابُ"},{"kind":"word","token":"له","disp