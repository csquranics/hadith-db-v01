{"consensus_set_id":"45494","translation_language":"fa","translation_source":{"hid":"98833"},"segments":[{"source_hadith_segment":"وَ كَانَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَتَمَّ النَّاسِ صَلاَةً وَ اَوْجَزَهُمْ كَانَ اِذَا دَخَلَ فِي صَلاَةٍ قَالَ « اَللَّهُ اَكْبَرُ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>   .","translation_segment":"و نماز جماعت رسول خدا صلی اللٰه علیه و آله از همه مردم کاملتر و کوتاه‌تر و مرسوم آن حضرت چنان بود که چون به نماز می‌ایستاد میفرمود: اللٰه أکبر بسم اللٰه الرحمن الرحیم.","segment_columns":[{"kind":"word","token":"قد","display":"قد"},{"kind":"word","token":"تجزئ","display":"تجزئ"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"الافتتاح","display":"الافتتاح"},{"kind":"word","token":"تكبيره","display":"تكبيرة"},{"kind":"word","token":"واحده","display":"واحدة"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"اتم","display":"اَتَمَّ"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"word","token":"صلاه","display":"صَلاَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اوجزهم","display":"اَوْجَزَهُمْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"صلاه","display":"صَلاَةٍ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"اكبر","display":"اَكْبَرُ"},{"kind