c_text>   <footnote> [ البقرة ۲۴۸ ] </footnote>  قَالَ","translation_segment":"بر دور پایه‌های کعبه می‌گردید و ابراهیم ستون‌های آن را می‌گذاشت. به آن حضرت عرض شد: آیا این سکینه از همان سکینه‌ای است که خداوند عز و جل‌ فرموده است: فیه‌ سکینه‌ من‌ ربکم‌ و بقیه‌ ممٰا ترک‌ آل‌ موسیٰ‌ و آل‌ هٰارون‌؟ فرمود:","segment_columns":[{"kind":"word","token":"الاساطين","display":"الْاَسَاطِينَ"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"سكينه","display":"سَكِينَةٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربكم","display":"رَبِّكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بقيه","display":"بَقِيَّةٌ"},{"kind":"word","token":"مما","display":"مِمّٰا"},{"kind":"word","token":"ترك","display":"تَرَكَ"},{"kind":"word","token":"ال","display":"الُ"},{"kind":"word","token":"موسي","display":"مُوسيٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الُ"},{"kind":"word","token":"هارون","display":"هٰارُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۴۸","display":"۲۴۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"تِلْكَ السَّكِينَةُ فِي التَّابُوتِ وَ كَانَتْ فِيهِ طَشْتٌ تُغْسَلُ فِيهَا قُلُوبُ الْاَنْبِيَاءِ وَ كَانَ التَّابُوتُ يَدُورُ فِي بَنِي اِسْرَائِيلَ مَعَ الْاَنْبِيَاءِ ثُمَّ اَقْبَلَ عَلَيْنَا","translation_segment":"آن سکینه در تابوت بود و در آن تشتی بود که دل‌های انبیا (به هنگام برانگیخته شدن) در آن شست‌وشو می‌شد. آن تابوت به همراه پیامبران می‌گردید (یعنی هرجا که آن‌ها بودند، تابوت نیز","segment_columns":[{"kind":"word","token":"تلك","display":"تِلْكَ"},{"kind":"word","token":"السكينه","display":"السَّكِينَةُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"التابوت","display":"التَّابُوتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"طشت","display":"طَشْتٌ"},{"kind":"word","token":"تغسل","display":"تُغْسَلُ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"قلوب","display":"قُلُوبُ"},{"kind":"word","token":"الانبياء","display":"الْاَنْبِيَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"التابوت","display":"التَّابُوتُ"},{"kind":"word","token":"يدور","display":"يَدُورُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرَائِيلَ"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"الانبياء","display":"الْاَنْبِيَاءِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اقبل","display":"اَقْبَلَ"},{"kind":"word","token":"علينا","display":"عَلَيْنَا"}]},{"source_hadith_segment":"فَقَالَ مَا تَابُوتُكُمْ قُلْنَا السِّلاَحُ قَالَ صَدَقْتُمْ هُوَ تَابُوتُكُمْ وَ اِنْ خَرَجْتَ بَرّاً فَقُلِ الَّذِي قَالَ اللَّهُ عَزَّ وَ جَلَّ  <quranic_text> « سُبْحٰانَ الَّذِي سَخَّرَ لَنٰا هٰذٰا وَ مٰا كُنّٰا لَهُ مُقْرِنِينَ .  وَ اِنّٰا اِليٰ رَبِّنٰا لَمُنْقَلِبُونَ » </quranic_text>   <footnote> [ الزخرف ۱۳ ] </footnote>  فَاِنَّهُ لَيْسَ مِنْ عَبْدٍ يَقُولُهَا عِنْدَ رُكُوبِهِ فَيَقَعَ مِنْ بَعِيرٍ اَوْ دَابَّةٍ فَيُصِيبَهُ شَيْءٌ بِاِذْنِ اللَّهِ ثُمَّ قَالَ","translation_segment":"بود). سپس حضرتش رو به ما کرد و فرمود: تابوت شما (شیعیان) چیست‌؟ عرض کردیم: سلاح (رسول خدا صلی الله علیه و اله). فرمود: راست گفتید، این همان تابوت شماست، و هرگاه به راه خشکی رفتی، کلام خداوند عز و جل‌ را بخوان: سبحٰان‌ الذی سخر لنٰا هٰذٰا و مٰا کنٰا له‌ مقرنین‌ `و إنٰا إلیٰ‌ ربنٰا لمنقلبون‌. به راستی هربنده‌ای که به هنگام سوار شدن به مرکب این آیات را بخواند و از شتر یا چهارپا (و هرمرکب سواری) بر زمین افتد، هرچه به او برسد به","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"تابوتكم","display":"تَابُوتُكُمْ"},{"kind":"word","token":"قلنا","display":"قُلْنَا"},{"kind":"word","token":"السلاح","display":"السِّلاَحُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صدقتم","display":"صَدَقْتُمْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"تابوتكم","display":"تَابُوتُكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"خرجت","display":"خَرَجْتَ"},{"kind":"word","token":"برا","display":"بَرّاً"},{"kind":"word","token":"فقل","display":"فَقُلِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سبحان","display":"سُبْحٰانَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"سخر","display":"سَخَّرَ"},{"kind":"word","token":"لنا","display":"لَنٰا"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"كنا","display":"كُنّٰا"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"مقرنين","display":"مُقْرِنِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"ربنا","display":"رَبِّنٰا"},{"kind":"word","token":"لمنقلبون","display":"لَمُنْقَلِبُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزخرف","display":"الزخرف"},{"kind":"word","token":"۱۳","display":"۱۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عبد","display":"عَبْدٍ"},{"kind":"word","token":"يقولها","display":"يَقُولُهَا"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ركوبه","display":"رُكُوبِهِ"},{"kind":"word","token":"فيقع","display":"فَيَقَعَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بعير","display":"بَعِيرٍ"}]},{"source_hadith_segment":"فَاِذَا خَرَجْتَ مِنْ مَنْزِلِكَ فَقُلْ بِسْمِ اللَّهِ امَنْتُ بِاللَّهِ تَوَكَّلْتُ عَلَي اللَّهِ لاَ حَوْلَ وَ لاَ قُوَّةَ اِلاَّ بِاللَّهِ فَاِنَّ الْمَلاَئِكَةَ تَضْرِبُ وُجُوهَ الشَّيَاطِينِ وَ يَقُولُونَ قَدْ سَمَّي اللَّهَ وَ امَنَ بِاللَّهِ وَ تَوَكَّلَ عَلَي اللَّهِ وَ قَالَ لاَ حَوْلَ وَ لاَ قُوَّةَ اِلاَّ بِاللَّهِ .","translation_segment":"اجازه و رخصت خداوند خواهد بود. آن‌گاه فرمود: هرگاه از خانه‌ات بیرون آمدی، بگو: «بسم الله آمنت بالله توکلت علی الله لا حول و لا قوه إلا بالله»؛ چرا که فرشتگان به صورت شیاطین می‌زنند و می‌گویند: او نام خدا را برد، به او ایمان آورد و بر او توکل کرد و گفت: هیچ قوت و نیرویی نیست مگر از جانب خداوند متعال.","segment_columns":[]}]}