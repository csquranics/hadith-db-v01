{"consensus_set_id":"34464","translation_language":"fa","translation_source":{"hid":"118104"},"segments":[{"source_hadith_segment":"مَنْ قَتَلَ عَبْدَهُ مُتَعَمِّداً فَعَلَيْهِ اَنْ يُعْتِقَ رَقَبَةً وَ اَنْ يُطْعِمَ سِتِّينَ مِسْكِيناً وَ يَصُومَ  <quranic_text> « شَهْرَيْنِ مُتَتٰابِعَيْنِ » </quranic_text>   <footnote> [ النساء ۹۲ ] </footnote>   .","translation_segment":"ابو بصیر گوید: امام صادق علیه السلام فرمود: هرکس بنده خود را از روی عمد بکشد باید یک برده آزاد کند، شصت فقیر را اطعام کند و دو ماه پیاپی روزه بگیرد.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قتل","display":"قَتَلَ"},{"kind":"word","token":"عبده","display":"عَبْدَهُ"},{"kind":"word","token":"متعمدا","display":"مُتَعَمِّداً"},{"kind":"word","token":"فعليه","display":"فَعَلَيْهِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يعتق","display":"يُعْتِقَ"},{"kind":"word","token":"رقبه","display":"رَقَبَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يطعم","display":"يُطْعِمَ"},{"kind":"word","token":"ستين","display":"سِتِّينَ"},{"kind":"word","token":"مسكينا","display":"مِسْكِيناً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يصوم","display":"يَصُومَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"شهرين","display":"شَهْرَيْنِ"},{"kind":"word","token":"متتابعين","display":"مُتَتٰابِعَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۹۲","display":"۹۲"},{"kind":"tag_close","tag_name":"footnote"}]}]}