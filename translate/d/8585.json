d","token":"سماواتك","display":"سماواتك"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"هجعت","display":"هجعت"},{"kind":"word","token":"عيون","display":"عيون"},{"kind":"word","token":"انامك","display":"انامك"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"ابوابك","display":"ابوابك"},{"kind":"word","token":"بك","display":"بك"},{"kind":"word","token":"مفتحات","display":"مفتّحات"},{"kind":"word","token":"للسائلين","display":"للسائلين"},{"kind":"word","token":"جئتك","display":"جئتك"},{"kind":"word","token":"لتغفر","display":"لتغفر"},{"kind":"word","token":"لي","display":"لي"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"ترحمني","display":"ترحمني"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"تريني","display":"تريني"},{"kind":"word","token":"وجه","display":"وجه"},{"kind":"word","token":"جدي","display":"جدّي"},{"kind":"word","token":"محمد","display":"محمّد"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صلي"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"عرصات","display":"عرصات"},{"kind":"word","token":"القيامه","display":"القيامة"}]},{"source_hadith_segment":".  ثمّ بكي","translation_segment":"","segment_columns":[{"kind":"word","token":"ثم","display":"ثمّ"},{"kind":"word","token":"بكي","display":"بكي"}]},{"source_hadith_segment":"و قال : « و عزّتك و جلالك ما اردت بمعصيتي مخالفتك ،  و ما عصيتك اذ عصيتك و انا بك شاكّ ،  و لا بنكالك جاهل ،  و لا لعقوبتك متعرّض ،  و لكن سوّلت لي نفسي و اعانني علي ذلك سترك المرخي به عليّ ،  فانا الان من عذابك من يستنقذني ،  و بحبل من اعتصم ان قطعت حبلك عنّي ؟  فوا سواتاه غدا من الوقوف بين يديك ؛ اذا قيل للمخفّين جوزوا ،  و للمثقلين حطّوا ،  ا مع المخفّين اجوز ؟  ام مع المثقلين احطّ ؟  ويلي كلّما طال عمري كثرت خطاياي و لم اتب ،  ا ما ان لي [ ان ] استحي من ربّي ؟  ثمّ بكي و انشا يقول :  ا تحرقني بالنار يا غاية المنيفاين رجائي ثمّ اين محبّتي اتيت باعمال قباح زريّة و ما في الوري خلق جني كجنايتي ثمّ بكي و قال « سبحانك تعصي كانّك لا تري ،  و تحلم كانّك لم تعص ،  تتودّد الي خلقك بحسن الصنيع كانّ بك الحاجة اليهم ،  و انت يا سيّدي الغنيّ عنهم » ثمّ خرّ الي الارض ساجدا .  ( قال ) : فدنوت منه و شلت ( ب ) راسه و وضعته علي ركبتيّ و بكيت حتي جرت دموعي علي خدّه ،  فاستوي جالسا و قال :  من [ ذا ] الذي اشغلني عن ذكر ربّي ؟  !  فقلت :  انا طاوس يا ابن رسول اللّه ما هذا الجزع و الفزع ؟  !  و نحن يلزمنا ان نفعل مثل هذا و نحن عاصون جانون ، ابوك الحسين بن عليّ و امّك فاطمة الزهراء ،  و جدّك رسول اللّه صلي اللّه عليه و اله .  قال :  فالتفت اليّ و قال :  هيهات هيهات يا طاوس ،  دع عنّي حديث ابي و امّي و جدّي ،  خلق اللّه الجنّة لمن اطاعه و احسن و لو كان ( عبدا ) حبشيّا ،  و خلق النار لمن عصاه و لو كان سيّدا قرشيّا ،  ا ما سمعت قوله تعالي :   <quranic_text> « فَاِذٰا نُفِخَ فِي الصُّورِ فَلاٰ اَنْسٰابَ بَيْنَهُمْ يَوْمَئِذٍ وَ لاٰ يَتَسٰاءَلُونَ » </quranic_text>   <footnote> [ المؤمنون ۱۰۱ ] </footnote> و اللّه لا ينفعك غدا الاّ تقدمة تقدّمها من عمل صالح .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"عزتك","display":"عزّتك"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"جلالك","display":"جلالك"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"اردت","display":"اردت"},{"kind":"word","token":"بمعصيتي","display":"بمعصيتي"},{"kind":"word","token":"مخالفتك","display":"مخالفتك"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"عصيتك","display":"عصيتك"},{"kind":"word","token":"اذ","display":"اذ"},{"kind":"word","token":"عصيتك","display":"عصيتك"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"انا","display"