{"consensus_set_id":"12122","translation_language":"fa","translation_source":{"hid":"402515"},"segments":[{"source_hadith_segment":"سُئِلَ اَبُو عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ ) عَنِ الْبَيْتِ","translation_segment":"","segment_columns":[{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"}]},{"source_hadith_segment":"،  اَ كَانَ يُحَجُّ قَبْلَ اَنْ يُبْعَثَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ","translation_segment":"","segment_columns":[{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يحج","display":"يُحَجُّ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يبعث","display":"يُبْعَثَ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]},{"source_hadith_segment":")  ؟  قَالَ :  « نَعَمْ ،  وَ تَصْدِيقُهُ فِي الْقُرْانِ قَوْلُ شُعَيْبٍ حِينَ قَالَ لِمُوسَي ( عَلَيْهِمَا السَّلاَمُ ) حَيْثُ تَزَوَّجَ :   <quranic_text> « عَليٰ اَنْ تَاْجُرَنِي ثَمٰانِيَ حِجَجٍ » </quranic_text>   <footnote> [ القصص ۲۷ ] </footnote>  وَ لَمْ يَقُلْ ثَمَانِيَ سِنِينَ ،  وَ اِنَّ ادَمَ وَ نُوحاً ( عَلَيْهِمَا السَّلاَمُ ) حَجَّا ،  وَ سُلَيْمَانَ بْنَ دَاوُدَ ( عَلَيْهِمَا السَّلاَمُ ) قَدْ حَجَّ الْبَيْتَ بِالْجِنِّ وَ الْاِنْسِ وَ الطَّيْرِ وَ الرِّيحِ ،  وَ حَجَّ مُوسَي ( عَلَيْهِ السَّلاَمُ ) عَلَي جَمَلٍ اَحْمَرَ ،  يَقُولُ :  لَبَّيْكَ لَبَّيْكَ .  وَ اِنَّهُ كَمَا قَالَ اللَّهُ :   <quranic_text> « اِنَّ اَوَّلَ بَيْتٍ وُضِعَ لِلنّٰاسِ لَلَّذِي بِبَكَّةَ مُبٰارَكاً وَ هُديً لِلْعٰالَمِينَ » </quranic_text>   <footnote> [ العمران ۹۶ ] </footnote> وَ قَالَ :   <quranic_text> « وَ اِذْ يَرْفَعُ اِبْرٰاهِيمُ الْقَوٰاعِدَ مِنَ الْبَيْتِ وَ اِسْمٰاعِيلُ  » </quranic_text>   <footnote> [ البقرة ۱۲۷ ] </footnote> وَ قَالَ :   <quranic_text> « اَنْ طَهِّرٰا بَيْتِيَ لِلطّٰائِفِينَ وَ الْعٰاكِفِينَ وَ الرُّكَّعِ السُّجُودِ » </quranic_text>   <footnote> [ البقرة ۱۲۵ ] </footnote> وَ اِنَّ اللَّهَ اَنْزَلَ الْحَجَرَ لِادَمَ وَ كَانَ الْبَيْتُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يعلمون","display":"يَعْلَمُونَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الناس","display":"النَّاسَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"يحجون","display":"يَحُجُّونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تصديقه","display":"تَصْدِيقُهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"شعيب","display":"شُعَيْبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لموسي","display":"لِمُوسَي"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"حيث","display":"حَيْثُ"},{"kind":"word","token":"تزوج","display":"تَزَوَّجَ"},{"kind":"tag_open",