{"consensus_set_id":"13030","translation_language":"fa","translation_source":{"hid":"408916"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « وَ لاٰ يُبْدِينَ زِينَتَهُنَّ اِلاّٰ مٰا ظَهَرَ مِنْهٰا » </quranic_text>   <footnote> [ النور ۳۱ ] </footnote>  قَالَ :  « هِيَ الثِّيَابُ ،  وَ الْكُحْلُ ،  وَ الْخَاتَمُ ،  وَ خِضَابُ الْكَفِّ ،  وَ السِّوَارُ ؛  وَ الزِّينَةُ ثَلاَثَةٌ :  زِينَةٌ لِلنَّاسِ ،  وَ زِينَةٌ لِلْمَحْرَمِ ،  وَ زِينَةٌ لِلزَّوْجِ ؛  فَاَمَّا زِينَةُ النَّاسِ ،  فَقَدْ ذَكَرْنَاهُ ،  وَ اَمَّا زِينَةُ الْمَحْرَمِ :  فَمَوْضِعُ الْقِلاَدَةِ فَمَا فَوْقَهَا ،  وَ الدُّمْلُجُ وَ مَا دُونَهُ ،  وَ الْخَلْخَالُ وَ مَا اَسْفَلَ مِنْهُ ،  وَ اَمَّا زِينَةُ الزَّوْجِ :  فَالْجَسَدُ كُلُّهُ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يبدين","display":"يُبْدِينَ"},{"kind":"word","token":"زينتهن","display":"زِينَتَهُنَّ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ظهر","display":"ظَهَرَ"},{"kind":"word","token":"منها","display":"مِنْهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۳۱","display":"۳۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"الثياب","display":"الثِّيَابُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الكحل","display":"الْكُحْلُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الخاتم","display":"الْخَاتَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"خضاب","display":"خِضَابُ"},{"kind":"word