{"consensus_set_id":"s313685","translation_language":"fa","translation_source":{"hid":"313685"},"segments":[{"source_hadith_segment":"وَ لَمَّا نَزَلَ الْحَسَنُ عَلَيْهِ السَّلاَمُ وَ عَمَّارٌ وَ قَيْسٌ الْكُوفَةَ وَ مَعَهُمْ كِتَابُ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ","translation_segment":"چون حسن (علیه السلام) و عمار و قیس همراه نامه امیر المومنین علی (علیه السلام) به کوفه رسیدند، امام حسن برای","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمار","display":"عَمَّارٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قيس","display":"قَيْسٌ"},{"kind":"word","token":"الكوفه","display":"الْكُوفَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"معهم","display":"مَعَهُمْ"},{"kind":"word","token":"كتاب","display":"كِتَابُ"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]},{"source_hadith_segment":"قَامَ فِيهِمُ الْحَسَنُ عَلَيْهِ السَّلاَمُ فَقَالَ « اَيُّهَا النَّاسُ قَدْ كَانَ مِنْ اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ مَا يَكْفِيكُمْ جُمْلَتُهُ وَ قَدْ اَتَيْنَاكُمْ مُسْتَنْفِرِينَ لَكُمْ لِاَنَّكُمْ جَبْهَةُ الْاَنْصَارِ وَ سَنَامُ الْعَرَبِ وَ قَدْ نَقَضَ طَلْحَةُ وَ الزُّبَيْرُ بَيْعَتَهُمَا وَ خَرَجَا بِعَائِشَةَ وَ هِيَ مِنَ النِّسَاءِ وَ ضَعْفُ رَاْيِهِنَّ كَمَا قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « الرِّجٰالُ قَوّٰامُونَ عَلَي النِّسٰاءِ » </quranic_text>   <footnote> [ النساء ۳۴ ] </footnote> وَ اَيْمُ اللَّهِ لَئِنْ لَمْ تَنْصُرُوهُ  <quranic_text> « لَيَنْصُرَنَّهُ اللّٰهُ » </quranic_text>   <footnote> [ الحج ۶۰ ] </footnote>  عَزَّ وَ جَلَّ بِمَنْ يَتْبَعُهُ مِنَ الْمُهَاجِرِينَ وَ الْاَنْصَارِ وَ سَائِرِ النَّاسِ فَانْصُرُوا رَبَّكُمْ يَنْصُرْكُمْ .","translation_segment":"سخنرانی برخاست و چنین فرمود: «ای مردم! فضائل امیر المومنین علی (علیه السلام) چنان است که اندکی از آن شما را بسنده است و اینک ما آمده‌ایم و از شما تقاضای حرکت داریم که شما بهترین یاری‌دهندگان و مهتران عرب هستید و همانا که طلحه و زبیر بیعت خود را شکسته و عایشه را همراه خود بیرون آورده‌اند و به هر حال عایشه زن است و ضعف رأی آنان چنان است که خداوند متعال فرموده است: مردان را بر زنان تسلط‍‌ و حق نگهبانی است. و همانا به خدا سوگند که اگر شما او را یاری ندهید خداوند او را یاری خواهد داد و مهاجران و انصار و دیگر مردم او را پیروی خواهند کرد و شما خدای خود را یاری دهید تا شما را یاری دهد.»","segment_columns":[{"kind":"word","token":"قام","display":"قَامَ"},{"kind":"word","token":"فيهم","display":"فِيهِمُ"},{"kind":"word","token":"الحسن","display":"الْحَسَنُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يكفيكم","display":"يَكْفِيكُمْ"},{"kind":"word","token":"جملته","display":"جُمْلَتُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"اتيناكم","display":"اَتَيْنَاكُمْ"},{"kind":"word","token":"مستنفرين","display":"مُسْتَنْفِرِينَ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"ki