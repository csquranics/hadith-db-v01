{"consensus_set_id":"s408527","translation_language":"fa","translation_source":{"hid":"408527"},"segments":[{"source_hadith_segment":"« كَانَ فِرْعَوْنُ اِبْرَاهِيمَ وَ اَصْحَابُهُ لِغَيْرِ رِشْدَةٍ ،  فَاِنَّهُمْ قَالُوا لِنُمْرُودَ :   <quranic_text> « حَرِّقُوهُ وَ اُنْصُرُوا الِهَتَكُمْ اِنْ كُنْتُمْ فٰاعِلِينَ » </quranic_text>   <footnote> [ الانبياء ۶۸ ] </footnote> وَ كَانَ فِرْعَوْنُ مُوسَي وَ اَصْحَابُهُ لِرِشْدَةٍ ،  فَاِنَّهُ لَمَّا اِسْتَشَارَ اَصْحَابَهُ فِي مُوسَي قَالُوا :   <quranic_text> « اَرْجِهْ وَ اَخٰاهُ وَ اِبْعَثْ فِي الْمَدٰائِنِ حٰاشِرِينَ يَاْتُوكَ بِكُلِّ سَحّٰارٍ عَلِيمٍ » </quranic_text>   <footnote> [ الشعراء ۳۶ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنُ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اصحابه","display":"اَصْحَابُهُ"},{"kind":"word","token":"لغير","display":"لِغَيْرِ"},{"kind":"word","token":"رشده","display":"رِشْدَةٍ"},{"kind":"word","token":"فانهم","display":"فَاِنَّهُمْ"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"لنمرود","display":"لِنُمْرُودَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حرقوه","display":"حَرِّقُوهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انصروا","display":"اُنْصُرُوا"},{"kind":"word","token":"الهتكم","display":"الِهَتَكُمْ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كنتم","display":"كُنْتُمْ"},{"kind":"word","token":"فاعلين","display":"فٰاعِلِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۶۸","display":"۶۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","toke