d","token":"فقال","display":"فقال"},{"kind":"word","token":"ويحك","display":"ويحك"},{"kind":"word","token":"ان","display":"انّ"},{"kind":"word","token":"داود","display":"داود"},{"kind":"word","token":"انما","display":"انّما"},{"kind":"word","token":"ظن","display":"ظنّ"},{"kind":"word","token":"ان","display":"انّ"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"خلق","display":"خلق"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عزّ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"جل","display":"جلّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"خلقا","display":"خلقا"},{"kind":"word","token":"هو","display":"هو"},{"kind":"word","token":"اعلم","display":"اعلم"},{"kind":"word","token":"منه","display":"منه"}]},{"source_hadith_segment":".  فبعث اللّه - عزّ و جلّ - الملكين « فتسوّروا المحراب فقالوا  <quranic_text> « خَصْمٰانِ بَغيٰ بَعْضُنٰا عَليٰ بَعْضٍ فَاحْكُمْ بَيْنَنٰا بِالْحَقِّ وَ لاٰ تُشْطِطْ وَ اِهْدِنٰا اِليٰ سَوٰاءِ الصِّرٰاطِ اِنَّ هٰذٰا اَخِي لَهُ تِسْعٌ وَ تِسْعُونَ نَعْجَةً وَ لِيَ نَعْجَةٌ وٰاحِدَةٌ فَقٰالَ اَكْفِلْنِيهٰا وَ عَزَّنِي فِي الْخِطٰابِ » </quranic_text>   <footnote> [ ص ۲۲ ] </footnote> .  فعجل داود - عليه السّلام - علي المدّعي عليه ،  فقال :   <quranic_text> « لَقَدْ ظَلَمَكَ بِسُؤٰالِ نَعْجَتِكَ اِليٰ نِعٰاجِهِ » </quranic_text>   <footnote> [ ص ۲۴ ] </footnote> و لم يسال المدّعي البيّنة علي ذلك ،  و لم يقبل علي المدّعي عليه فيقول له :  ما تقول ؟  فكان هذا خطيئة رسم حكمه ،  لا ما ذهبتم اليه .  الا تسمع اللّه - عزّ و جلّ - يقول :   <quranic_text> « يٰا دٰاوُدُ اِنّٰا جَعَلْنٰاكَ خَلِيفَةً فِي الْاَرْضِ فَاحْكُمْ بَيْنَ النّٰاسِ بِالْحَقِّ » </quranic_text>   <footnote> [ ص ۲۶ ] </footnote> ( الي اخر الاية ) .  فقال : يا ابن رسول اللّه ،  فما قصّته مع اوريا ؟  قال الرّضا - عليه السّلام- :  انّ المراة في ايّام داود كانت اذا مات بعلها او قتل ،  لا تتزوّج بعده ابدا .  فاوّل من اباح اللّه - عزّ و جلّ - له ان يتزوّج بامراة قتل بعلها ،  داود .  فتزوّج بامراة اوريا ،  لمّا قتل ،  و انقضت عدّتها منه .  فذلك الّذي شقّ [ علي النّاس من قبل ] اوريا .","translation_segment":"","segment_columns":[{"kind":"word","token":"فبعث","display":"فبعث"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عزّ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"جل","display":"جلّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"الملكين","display":"الملكين"},{"kind":"word","token":"فتسوروا","display":"فتسوّروا"},{"kind":"word","token":"المحراب","display":"المحراب"},{"kind":"word","token":"فقالوا","display":"فقالوا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"خصمان","display":"خَصْمٰانِ"},{"kind":"word","token":"بغي","display":"بَغيٰ"},{"kind":"word","token":"بعضنا","display":"بَعْضُنٰا"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"بعض","display":"بَعْضٍ"},{"kind":"word","token":"فاحكم","display":"فَاحْكُمْ"},{"kind":"word","token":"بيننا","display":"بَيْنَنٰا"},{"kind":"word","token":"بالحق","display":"بِالْحَقِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تشطط","display":"تُشْطِطْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اهدنا","display":"اِهْدِنٰا"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"سواء","display":"سَوٰاءِ"},{"kind":"word","token":"الصراط","display":"الصِّرٰاطِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"word","token":"اخي","display":"اَخِي"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"تسع","display":"تِسْعٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تسعون","display":"تِسْعُونَ"},{"kind":"word","token":"نعجه","display":"نَعْجَةً"},{"kind":"word","token":"و","display":"وَ"},{"ki