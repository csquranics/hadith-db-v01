{"consensus_set_id":"37011","translation_language":"fa","translation_source":{"hid":"402870"},"segments":[{"source_hadith_segment":"« مَنْ جَادَلَ فِي الْحَجِّ فَعَلَيْهِ اِطْعَامُ سِتَّةِ مَسَاكِينَ ،  لِكُلِّ مِسْكِينٍ نِصْفُ صَاعٍ ،  اِنْ كَانَ صَادِقاً اَوْ كَاذِباً ،  فَاِنْ عَادَ مَرَّتَيْنِ ؛  فَعَلَي الصَّادِقِ شَاةٌ ،  وَ عَلَي الْكَاذِبِ بَقَرَةٌ ،  لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « فَلاٰ رَفَثَ وَ لاٰ فُسُوقَ وَ لاٰ جِدٰالَ فِي الْحَجِّ » </quranic_text>   <footnote> [ البقرة ۱۹۷ ] </footnote> وَ الرَّفَثُ :  الْجِمَاعُ ،  وَ الْفُسُوقُ :  الْكَذِبُ ،  وَ الْجِدَالُ :  قَوْلُ الرَّجُلِ :  لاَ وَ اللَّهِ ،  وَ بَلَي وَ اللَّهِ .  وَ الْمُفَاخَرَةُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"جادل","display":"جَادَلَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"word","token":"فعليه","display":"فَعَلَيْهِ"},{"kind":"word","token":"اطعام","display":"اِطْعَامُ"},{"kind":"word","token":"سته","display":"سِتَّةِ"},{"kind":"word","token":"مساكين","display":"مَسَاكِينَ"},{"kind":"word","token":"لكل","display":"لِكُلِّ"},{"kind":"word","token":"مسكين","display":"مِسْكِينٍ"},{"kind":"word","token":"نصف","display":"نِصْفُ"},{"kind":"word","token":"صاع","display":"صَاعٍ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"صادقا","display":"صَادِقاً"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"كاذبا","display":"كَاذِباً"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"عاد","display":"عَادَ"},{"kind":"word","token":"مرتين","display":"مَرَّتَيْنِ"},{"kind":"word","token":"فعلي","display":"فَعَلَي"},{"kind":"word","token":"الصادق","display":"الصَّادِقِ"},{"kind":"word","token":"شاه","display":"شَاةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind