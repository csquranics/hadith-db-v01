{"consensus_set_id":"s403857","translation_language":"fa","translation_source":{"hid":"403857"},"segments":[{"source_hadith_segment":"« خَطَبَ اَمِيرُ الْمُؤْمِنِينَ عَلِيُّ بْنُ اَبِي طَالِبٍ ( صَلَوَاتُ اللَّهِ عَلَيْهِ ) بِالْكُوفَةِ مُنْصَرَفَهُ مِنَ النَّهْرَوَانِ ،  - وَ ذَكَرَ خُطْبَةً فِيهَا اَسْمَاؤُهُ مِنْ كِتَابِ اللَّهِ سُبْحَانَهُ ،  قَالَ فِيهَا - وَ اَنَا الذَّاكِرُ ،  يَقُولُ اللَّهُ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « الَّذِينَ يَذْكُرُونَ اللّٰهَ قِيٰاماً وَ قُعُوداً وَ عَليٰ جُنُوبِهِمْ » </quranic_text>   <footnote> [ العمران ۱۹۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"خطب","display":"خَطَبَ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"بالكوفه","display":"بِالْكُوفَةِ"},{"kind":"word","token":"منصرفه","display":"مُنْصَرَفَهُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"النهروان","display":"النَّهْرَوَانِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"خطبه","display":"خُطْبَةً"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"اسماؤه","display":"اَسْمَاؤُهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"كتاب","display":"كِتَابِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"سبحانه","display":"سُبْحَانَهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"-","display":"-