{"consensus_set_id":"43544","translation_language":"fa","translation_source":{"hid":"404122"},"segments":[{"source_hadith_segment":"كَانَ اَلرَّجُلُ يَحْمِلُ عَلَي الْمُشْرِكِينَ وَحْدَهُ ،  حَتَّي يَقْتُلَ اَوْ يُقْتَلَ ،  فَاَنْزَلَ اللَّهُ هَذِهِ الْايَةَ :   <quranic_text> « وَ لاٰ تَقْتُلُوا اَنْفُسَكُمْ اِنَّ اللّٰهَ كٰانَ بِكُمْ رَحِيماً » </quranic_text>   <footnote> [ النساء ۲۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"الرجل","display":"اَلرَّجُلُ"},{"kind":"word","token":"يحمل","display":"يَحْمِلُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المشركين","display":"الْمُشْرِكِينَ"},{"kind":"word","token":"وحده","display":"وَحْدَهُ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"يقتل","display":"يَقْتُلَ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"يقتل","display":"يُقْتَلَ"},{"kind":"word","token":"فانزل","display":"فَاَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تقتلوا","display":"تَقْتُلُوا"},{"kind":"word","token":"انفسكم","display":"اَنْفُسَكُمْ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"بكم","display":"بِكُمْ"},{"kind":"word","token":"رحيما","display":"رَحِيماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}