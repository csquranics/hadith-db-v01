{"consensus_set_id":"5703","translation_language":"fa","translation_source":{"hid":"102522"},"segments":[{"source_hadith_segment":"وَ قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ يَتَزَوَّجُ الرَّجُلُ الْاَمَةَ بِغَيْرِ عِلْمِ اَهْلِهَا قَالَ « هُوَ زِنًي اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « فَانْكِحُوهُنَّ بِاِذْنِ اَهْلِهِنَّ » </quranic_text>   <footnote> [ النساء ۲۵ ] </footnote>   .","translation_segment":"فضل بن عبد الملک بقباق گوید: بامام صادق علیه السلام عرض کردم مردی با کنیزی بدون آگاهی و اجازه اربابش ازدواج کرد، فرمود: این در حکم زنا است زیرا خداوند عز و جل‌ می‌فرماید: «فانکحوهن‌ بإذن‌ أهلهن‌»» (با کنیزان نکاح کنید با اجازه اربابشان - نساء:۲۵).","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"يتزوج","display":"يَتَزَوَّجُ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"الامه","display":"الْاَمَةَ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"علم","display":"عِلْمِ"},{"kind":"word","token":"اهلها","display":"اَهْلِهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"زني","display":"زِنًي"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"