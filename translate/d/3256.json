{"consensus_set_id":"3256","translation_language":"fa","translation_source":{"hid":"117052"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « فَمَنْ بَدَّلَهُ بَعْدَ مٰا سَمِعَهُ فَاِنَّمٰا اِثْمُهُ عَلَي الَّذِينَ يُبَدِّلُونَهُ » </quranic_text>   <footnote> [ البقرة ۱۸۱ ] </footnote>","translation_segment":"محمد بن سوقه گوید: از امام باقر علیه السلام پرسیدم: خداوند عز و جل می‌فرماید: «هرکس وصیت را استماع کند سپس آن را تغییر دهد، مسئولیت آن بر عهده همان کسانی است که وصیت را تغییر داده‌اند» فرمود: کلیت آن در","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"بدله","display":"بَدَّلَهُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"سمعه","display":"سَمِعَهُ"},{"kind":"word","token":"فانما","display":"فَاِنَّمٰا"},{"kind":"word","token":"اثمه","display":"اِثْمُهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يبدلونه","display":"يُبَدِّلُونَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","d