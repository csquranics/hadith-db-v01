{"consensus_set_id":"26424","translation_language":"fa","translation_source":{"hid":"337726"},"segments":[{"source_hadith_segment":"نَزَلَ جَبْرَئِيلُ عَلَيْهِ السَّلاَمُ عَلَي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ بِصَحِيفَةٍ مِنَ السَّمَاءِ لَمْ يُنْزِلِ اللَّهُ","translation_segment":"پدرم رحمه اللٰه علیه فرمود: عبد اللٰه بن جعفر حمیری از ابو القاسم هاشمی، از عبید بن قیس انصاری، از حسن بن سماعه، از حضرت ابی عبد اللٰه علیه السلام نقل","segment_columns":[{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"بصحيفه","display":"بِصَحِيفَةٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"السماء","display":"السَّمَاءِ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"ينزل","display":"يُنْزِلِ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"}]},{"source_hadith_segment":"تَعَالَي كِتَاباً قَبْلَهُ وَ لاَ بَعْدَهُ وَ فِيهِ خَوَاتِيمُ مِنَ الذَّهَبِ فَقَالَ لَهُ يَا مُحَمَّدُ هَذِهِ وَصِيَّتُكَ اِلَي النَّجِيبِ مِنْ اَهْلِكَ","translation_segment":"کرده که آن جناب فرمودند: جبرئیل علیه السلام به رسول خدا صلی اللٰه علیه و آله نازل شد و صفحه و ورقی را از آسمان با خود آورد که نه قبلا و نه بعدا مشابه آن نازل نگردید،","segment_columns":[{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"كتابا","display":"كِتَاباً"},{"kind":"word","token":"مثلها","display":"مِثْلَهَا"},{"kind":"word","token":"قط","display":"قَطُّ"},{"kind":"word","token":"قبله","display":"قَبْلَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"بعده","display":"بَعْدَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"خواتيم","display":"خَوَاتِيمُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الذهب","display":"الذَّهَبِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"وصيتك","display":"وَصِيَّتُكَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"النجيب","display":"النَّجِيبِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهلك","display":"اَهْلِكَ"}]},{"source_hadith_segment":"فَقَالَ لَهُ يَا جَبْرَئِيلُ مَنِ النَّجِيبُ مِنْ اَهْلِي قَالَ عَلِيُّ بْنُ اَبِي طَالِبٍ مُرْهُ اِذَا تُوُفِّيتَ اَنْ يَفُكَّ خَاتَمَهَا وَ يَعْمَلَ بِمَا فِيهِ فَلَمَّا قُبِضَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَكَّ عَلِيٌّ عَلَيْهِ السَّلاَمُ خَاتَماً ثُمَّ عَمِلَ بِمَا فِيهِ وَ مَا تَعَدَّاهُ ثُمَّ دَفَعَهَا اِلَي الْحَسَنِ بْنِ عَلِيٍّ عَلَيْهِ السَّلاَمُ فَفَكَّ خَاتَماً وَ عَمِلَ بِمَا فِيهِ وَ مَا تَعَدَّاهُ ثُمَّ دَفَعَهَا اِلَي الْحُسَيْنِ بْنِ عَلِيٍّ عَلَيْهِ السَّلاَمُ فَفَكَّ خَاتَماً فَوَجَدَ فِيهِ اُخْرُجْ بِقَوْمٍ اِلَي الشَّهَادَةِ لَهُمْ مَعَكَ وَ اِشْرِ نَفْسَكَ لِلَّهِ فَعَمِلَ بِمَا فِيهِ وَ مَا تَعَدَّاهُ ثُمَّ دَفَعَهَا اِلَي رَجُلٍ بَعْدَهُ فَفَكَّ خَاتَماً فَوَجَدَ فِيهِ اَطْرِقْ وَ اُصْمُتْ وَ اِلْزَمْ مَنْزِلَكَ  <quranic_text> « وَ اُعْبُدْ رَبَّكَ حَتّٰي يَاْتِيَكَ الْيَقِينُ » </quranic_text>   <footnote> [ الحجر ۹۹ ] </footnote>  ثُمَّ دَفَعَهَا اِلَي رَجُلٍ بَعْدَهُ فَفَكَّ خَاتَماً فَوَجَدَ فِيهِ اَنْ حَدِّثِ النَّاسَ وَ اَفْتِهِمْ وَ اُنْشُرْ عِلْمَ ابَائِكَ فَعَمِلَ بِمَا","translation_segment":"در آن صفحه مهرهایی از طلا بود، جبرئیل به رسول خدا صلی اللٰه علیه و آله عرض کرد: ای محمد این وصیت تو است به نجیب و برگزیده از اهلت. حضرت فرمود: ای جبرئیل نجیب از اهل من کیست‌؟ عرضه داشت: علی بن ابی طالب، به او امر کن پس از آن که رحلت و وفات نمودید مهر این صفحه را بشکند و به آنچه در آن نوشته عمل نماید. پس از رحلت رسول خدا صلی اللٰه علیه و آله علی علیه السلام مهر از نامه برداشت و به آنچه در آن نوشته بود عمل نمود و سپس هنگام رحلت آن را به حسن بن علی علیهما السلام داد، آن جناب مهر بعدی را شکست و به آنچه در آن نوشته بود عمل کرد و در وقت وفات ورقه را به حسین بن علی علیهما السلام داد، آن حضرت مهر بعدی را برداشت در نامه نوشته بود: قوم و خویشانت را با خود به سمت شهادت ببر و خود را قربانی خدا کن، حضرت به آنچه در آن بود عمل فرمود و سپس در وقت ارتحال از این عالم ورقه را به امام بعدی مسترد فرمود، آن حضرت مهر بعدی را شکست در آن نوشته بود خاموش و ساکت و ملازم منزل باش و پروردگارت را عبادت کن تا زمان رحلت فرا رسد سپس آن حضرت ورقه را به امام بعد از خود سپرد آن حضرت نیز مهر از آن برداشت در صفحه نوشته بود: برای مردم حدیث بگو و فتوی بده و علم پدرانت را منتشر نما، حضرت به آنچه در آن نوشته بود عمل نمود","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلُ"},{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"النجيب","display":"النَّجِيبُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهلي","display":"اَهْلِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"مر