{"consensus_set_id":"s410424","translation_language":"fa","translation_source":{"hid":"410424"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ ) عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « الَّذِينَ يَحْمِلُونَ الْعَرْشَ وَ مَنْ حَوْلَهُ » </quranic_text>   <footnote> [ غافر ۷ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يحملون","display":"يَحْمِلُونَ"},{"kind":"word","token":"العرش","display":"الْعَرْشَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"حوله","display":"حَوْلَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"غافر","display":"غافر"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"،  قَالَ :  « يَعْنِي الْمَلاَئِكَةَ  <quranic_text> « يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ » </quranic_text>   <footnote> [ غافر ۷ ] </footnote> .  .  .   <quranic_text> « وَ يَسْتَغْفِرُونَ لِلَّذِينَ امَنُوا » </quranic_text>   <footnote> [ غافر ۷ ] </footnote>  يَعْنِي شِيعَةَ مُحَمَّدٍ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) وَ الِ مُحَمَّدٍ ( عَلَيْهِمُ السَّلاَمُ )  <quranic_text> « رَبَّنٰا وَسِعْتَ كُلَّ شَيْءٍ رَحْمَةً وَ عِلْماً فَاغْفِرْ لِلَّذِينَ تٰابُوا » </quranic_text>   <footnote> [ غافر ۷ ] </footnote>  مِنْ وَلاَيَةِ الطَّوَاغِيتِ الثَّلاَثَةِ وَ مِنْ بَنِي اُمَيَّةَ <quranic_text> « وَ اِتَّبَعُوا سَبِيلَكَ » </quranic_text>   <footnote> [ غافر ۷ ] </footnote>  يَعْنِي وَلاَيَةَ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) ،  وَ هُوَ السَّبِيلُ .  وَ قَوْلُهُ تَعَالَي :   <quranic_text> « وَ قِهِمُ السَّيِّئٰاتِ » </quranic_text>   <footnote> [ غافر ۹ ] </footnote>  يَعْنِي الثَّلاَثَةَ <quranic_text> « وَ مَنْ تَقِ السَّيِّئٰاتِ يَوْمَئِذٍ فَقَدْ رَحِمْتَهُ » </quranic_text>   <footnote> [ غافر ۹ ] </footnote> ،  وَ قَوْلُهُ تَعَالَي :   <quranic_text> « اِنَّ الَّذِينَ كَفَرُوا » </quranic_text>   <footnote> [ غافر ۱۰ ] </footnote>  يَعْنِي بَنِي اُمَيَّةَ <quranic_text> « يُنٰادَوْنَ لَمَقْتُ اللّٰهِ اَكْبَرُ مِنْ مَقْتِكُمْ اَنْفُسَكُمْ اِذْ تُدْعَوْنَ اِلَي الْاِيمٰانِ » </quranic_text>   <footnote> [ غافر ۱۰ ] </footnote>  يَعْنِي وَلاَيَةَ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) ،  وَ هِيَ الْاِيمَانُ <quranic_text> « فَتَكْفُرُونَ » </quranic_text>   <footnote> [ غافر ۱۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"الملائكه","display":"الْمَلاَئِكَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يسبحون","display":"يُسَبِّحُونَ"},{"kind":"word","token":"بحمد","display":"بِحَمْدِ"},{"kind":"word","token":"ربهم","display":"رَبِّهِمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"غافر","display":"غافر"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يستغفرون","display":"يَسْتَغْفِرُونَ"},{"kind":"word","token":"للذين","display":"لِلَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag