{"consensus_set_id":"6782","translation_language":"fa","translation_source":{"hid":"404559"},"segments":[{"source_hadith_segment":"قُلْتُ لِمُحَمَّدِ بْنِ عَلِيٍّ ( عَلَيْهِمَا السَّلاَمُ )  ،  قَوْلُ اللَّهِ فِي كِتَابِهِ :   <quranic_text> « الَّذِينَ امَنُوا ثُمَّ كَفَرُوا » </quranic_text>   <footnote> [ النساء ۱۳۷ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لمحمد","display":"لِمُحَمَّدِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتابه","display":"كِتَابِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"كفروا","display":"كَفَرُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۳۷","display":"۱۳۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"؟  قَالَ :  « هُمَا ،  وَ الثَّالِثُ ،  وَ الرَّابِعُ ،  وَ عَبْدُ الرَّحْمَنِ ،  وَ طَلْحَةُ ،  وَ كَانُوا سَبْعَةَ عَشَرَ رَجُلاً »","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هما","display":"هُمَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الثالث","display":"الثَّالِثُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرابع","display":"الرَّابِعُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عبد","display":"عَبْدُ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمَنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طلحه","display":"طَلْحَةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"سبعه","display":"سَبْعَةَ"},{"kind":"word","token":"عشر","display":"عَشَرَ"},{"kind":"word","token":"رجلا","display":"رَجُلاً"}]},{"source_hadith_segment":".  قَالَ :  « لَمَّا وَجَّهَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) عَلِيَّ بْنَ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ ) وَ عَمَّارَ بْنَ يَاسِرٍ ( رَحِمَهُ اللَّهُ ) اِلَي اَهْلِ مَكَّةَ ،  قَالُوا :  بَعَثَ هَذَا الصَّبِيَّ ،  وَ لَوْ بَعَثَ غَيْرَهُ اِلَي اَهْلِ مَكَّةَ ،  وَ فِي مَكَّةَ صَنَادِيدُهَا .  وَ كَانُوا يُسَمُّونَ عَلِيّاً ( عَلَيْهِ السَّلاَمُ ) الصَّبِيَّ ،  لِاَنَّهُ كَانَ اِسْمُهُ فِي كِتَابِ اللَّهِ الصَّبِيَّ لِقَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مَنْ اَحْسَنُ قَوْلاً مِمَّنْ دَعٰا اِلَي اللّٰهِ وَ عَمِلَ صٰالِحاً » </quranic_text>   <footnote> [ فصلت ۳۳ ] </footnote>  وَ هُوَ صَبِيٌّ  <quranic_text> « وَ قٰالَ اِنَّنِي مِنَ الْمُسْلِمِينَ » </quranic_text>   <footnote> [ فصلت ۳۳ ] </footnote>  فَقَالُوا :  وَ اللَّهِ الْكُفْرُ بِنَا اَوْلَي مِمَّا نَحْنُ فِيهِ .  فَسَارُوا ،  فَقَالُوا :  لَهُمَا وَ خَوَّفُوهُمَا بِاَهْلِ مَكَّةَ ،  فَعَرَضُوا لَهُمَا ،  وَ غَلَّظُوا عَلَيْهِمَا الْاَمْرَ ،  فَقَالَ عَلِيٌّ ( صَلَوَاتُ اللَّهِ عَلَيْهِ )  :  حَسْبُنَا اللَّهُ وَ نِعْمَ الْوَكِيلُ ،  وَ مَضَي .  فَلَمَّا دَخَلاَ مَكَّةَ اَخْبَرَ اللَّهُ نَبِيَّهُ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) بِقَوْلِهِمْ لِعَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) وَ بِقَوْلِ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) لَهُمْ ،  فَاَنْزَلَ اللَّهُ بِاَسْمَائِهِمْ فِي كِتَابِهِ ،  وَ ذَلِكَ قَوْلُ اللَّهِ :  اَ لَمْ تَرَ اِلَي  <quranic_text> « الَّذِينَ قٰالَ لَهُمُ النّٰاسُ اِنَّ النّٰاسَ قَدْ جَمَعُوا لَكُمْ فَاخْشَوْهُمْ فَزٰادَهُمْ اِيمٰاناً وَ قٰالُوا حَسْبُنَا اللّٰهُ وَ نِعْمَ الْوَكِيلُ » </quranic_text>   <footnote> [ العمران ۱۷۳ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « وَ اللّٰهُ ذُو فَضْلٍ عَظِيمٍ » </quranic_text>   <footnote> [ العمران ۱۷۴ ] </footnote> .  وَ اِنَّمَا نَزَلَتْ :  ( اَ لَمْ تَرَ اِلَي فُلاَنٍ وَ فُلاَنٍ لَقُوا عَلِيّاً وَ عَمَّاراً فَقَالاَ :  اِنَّ اَبَا سُفْيَانَ وَ عَبْدَ اللَّهِ بْنَ عَامِرٍ وَ اَهْلَ مَكَّةَ قَدْ جَمَعُوا لَكُمْ فَاخْشَوْهُمْ فَقَالُوا :  حَسْبُنَا اللَّهُ وَ نِعْمَ الْوَكِيلُ ) وَ هُمَا اللَّذَانِ قَالَ اللَّهُ :   <quranic_text> « اِنَّ الَّذِينَ امَنُوا ثُمَّ كَفَرُوا » </quranic_text>   <footnote> [ النساء ۱۳۷ ] </footnote>  اِلَي اخِرِ الْايَةِ ،  فَهَذَا اَوَّلُ كُفْرِهِمْ ،  وَ الْكُفْرُ الثَّانِي حِينَ قَالَ النَّبِيُّ ( عَلَيْهِ وَ الِهِ السَّلاَمُ )  :  يَطْلُعُ عَلَيْكُمْ مِنْ هَذَا الشِّعْبِ رَجُلٌ ،  فَيَطْلُعُ عَلَيْكُمْ بِوَجْهِهِ ،  فَمَثَلُهُ عِنْدَ اللَّهِ كَمَثَلِ عِيسَي .  لَمْ يَبْقَ مِنْهُمْ اَحَدٌ اِلاَّ تَمَنَّي اَنْ يَكُونَ بَعْضَ اَهْلِهِ ،  فَاِذَا بِعَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) قَدْ خَرَجَ وَ طَلَعَ بِوَجْهِهِ ،  وَ قَالَ :  هُوَ هَذَا !  فَخَرَجُوا غُضَّاباً ،  وَ قَالُوا :  مَا بَقِيَ اِلاَّ اَنْ يَجْعَلَهُ نَبِيّاً ،  وَ اللَّهِ الرُّجُوعُ اِلَي الِهَتِنَا خَيْرٌ مِمَّا نَسْمَعُ مِنْهُ فِي اِبْنِ عَمِّهِ ،  وَ لَيَصِدُّنَا عَلِيٌّ اِنْ دَامَ هَذَا .  فَاَنْزَلَ اللَّهُ  <quranic_text> « وَ لَمّٰا ضُرِبَ اِبْنُ مَرْيَمَ مَثَلاً اِذٰا قَوْمُكَ مِنْهُ يَصِدُّونَ » </quranic_text>   <footnote> [ الزخرف ۵۷ ] </footnote>  الْايَةَ ،  فَهَذَا الْكُفْرُ الثَّانِي ،  وَ زِيَادَةُ الْكُفْرِ حِينَ قَالَ اللَّهُ :   <quranic_text> « اِنَّ الَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ اُولٰئِكَ هُمْ خَيْرُ الْبَرِيَّةِ » </quranic_text>   <footnote> [ البينة ۷ ] </footnote> فَقَالَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :  يَا عَلِيُّ اَصْبَحْتَ وَ اَمْسَيْتَ خَيْرَ الْبَرِيَّةِ .  فَقَالَ لَهُ النَّاسُ :  هُوَ خَيْرٌ مِنْ ادَمَ وَ نُوحٍ وَ مِنْ اِبْرَاهِيمَ وَ مِنَ الْاَنْبِيَاءِ ؟  فَاَنْزَلَ اللَّهُ  <quranic_text> « اِنَّ اللّٰهَ اِصْطَفيٰ ادَمَ وَ نُوحاً وَ الَ اِبْرٰاهِيمَ  » </quranic_text>   <footnote> [ العمران ۳۳ ] </footnote>  اِلَي  <quranic_text> « سَمِيعٌ عَلِيمٌ » </quranic_text>   <footnote> [ العمران ۳۴ ] </footnote> قَالُوا :  فَهُوَ خَيْرٌ مِنْكَ يَا مُحَمَّدُ ؟  وَ قَالَ اللَّهُ :   <quranic_text> « قُلْ يٰا اَيُّهَا النّٰاسُ اِنِّي رَسُولُ اللّٰهِ اِلَيْكُمْ جَمِيعاً » </quranic_text>   <footnote> [ الاعراف ۱۵۸ ] </footnote>  وَ لَكِنَّهُ خَيْرٌ مِنْكُمْ ،  وَ ذُرِّيَّتُهُ خَيْرٌ مِنْ ذُرِّيَّتِكُمْ ،  وَ مَنِ اِتَّبَعَهُ خَيْرٌ مِمَّنِ اِتَّبَعَكُمْ .  فَقَامُوا غُضَّاباً ،  وَ قَالُوا زِيَادَةً :  الرُّجُوعُ اِلَي الْكُفْرِ اَهْوَنُ عَلَيْنَا مِمَّا يَقُولُ فِي اِبْنِ عَمِّهِ .  وَ ذَلِكَ قَوْلُ اللَّهِ :   <quranic_text> « ثُمَّ اِزْدٰادُوا كُفْراً » </quranic_text>   <footnote> [ النساء ۱۳۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"وجه","display":"وَجَّهَ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"علي","display":"عَلِيَّ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمار","display":"عَمَّارَ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"ياسر","display":"يَاسِرٍ"},{"kind":"word","token":"رحمه","display":"رَحِمَهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token