{"consensus_set_id":"12528","translation_language":"fa","translation_source":{"hid":"114712"},"segments":[{"source_hadith_segment":"فِي اَلرَّجُلِ يُطَلِّقُ اِمْرَاَتَهُ اَ يُمَتِّعُهَا قَالَ نَعَمْ اَ مَا يُحِبُّ اَنْ يَكُونَ مِنَ الْمُحْسِنِينَ اَ مَا يُحِبُّ اَنْ يَكُونَ مِنَ الْمُتَّقِينَ .","translation_segment":"حفص بن بختری گوید: از امام صادق علیه السلام پرسیدم: مردی زن خود را طلاق می‌دهد، آیا وظیفه دارد که با آن زن مقداری کالای زندگی هدیه کند؟ فرمود: آری. آیا دوست ندارد که در شمار نیکوکاران باشد؟ آیا دوست ندارد که در شمار پرهیزگاران درآید؟","segment_columns":[{"kind":"word","token":"سئل","display":"سئل"},{"kind":"word","token":"الصادق","display":"الصادق"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الرجل","display":"اَلرَّجُلِ"},{"kind":"word","token":"يطلق","display":"يُطَلِّقُ"},{"kind":"word","token":"امراته","display":"اِمْرَاَتَهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"يمتعها","display":"يُمَتِّعُهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يحب","display":"يُحِبُّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يكون","display":"يَكُونَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"المحسنين","display":"الْمُحْسِنِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره۲۳۶","display":"البقرة۲۳۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يحب","display":"يُحِبُّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يكون","display":"يَكُونَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","t