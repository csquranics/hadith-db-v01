{"consensus_set_id":"15867","translation_language":"fa","translation_source":{"hid":"407370"},"segments":[{"source_hadith_segment":"« اِنَّ عَلِيَّ بْنَ الْحُسَيْنِ ( عَلَيْهِ السَّلاَمُ ) اِذَا اَتَي الْمُلْتَزَمَ ،  قَالَ :  اللَّهُمَّ اِنَّ عِنْدِي اَفْوَاجاً مِنْ ذُنُوبٍ وَ اَفْوَاجاً مِنْ خَطَايَا ،  وَ عِنْدَكَ اَفْوَاجاً مِنْ رَحْمَةٍ وَ اَفْوَاجاً مِنْ مَغْفِرَةٍ ،  يَا مَنِ اِسْتَجَابَ لِاَبْغَضِ خَلْقِهِ اِلَيْهِ اِذْ قَالَ :   <quranic_text> « فَاَنْظِرْنِي اِليٰ يَوْمِ يُبْعَثُونَ » </quranic_text>   <footnote> [ الحجر ۳۶ ] </footnote>  اِسْتَجِبْ لِي ،  وَ اِفْعَلْ بِي كَذَا وَ كَذَا »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"علي","display":"عَلِيَّ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اتي","display":"اَتَي"},{"kind":"word","token":"الملتزم","display":"الْمُلْتَزَمَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"عندي","display":"عِنْدِي"},{"kind":"word","token":"افواجا","display":"اَفْوَاجاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ذنوب","display":"ذُنُوبٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"افواجا","display":"اَفْوَاجاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"خطايا","display":"خَطَايَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عندك","display":"عِنْدَكَ"},{"kind":"word","token":"افواجا","display":"اَفْوَاجاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"رحمه","display":"رَحْمَةٍ"},{"kind":"word","token":"و","display":"وَ"}