{"consensus_set_id":"s331647","translation_language":"fa","translation_source":{"hid":"331647"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ [ تَعَالَي ] :   <quranic_text> « السّٰابِقُونَ الْاَوَّلُونَ » </quranic_text>   <footnote> [ التوبة ۱۰۰ ] </footnote>  قَالَ :  عَلِيُّ بْنُ اَبِي طَالِبٍ  ،  وَ حَمْزَةُ وَ عَمَّارٌ ،  وَ اَبُو ذَرٍّ ،  وَ سَلْمَانُ وَ مِقْدَادٌ .","translation_segment":"عن ابن عباس فی قوله تعالی: (السابقون الأولون) قال: علی‌ بن ابی طالب، و حمزه و عمار، و أبو ذر، و سلمان و مقداد. ابن عباس درباره سخن خداوند: «السابقون الاولون» گفت: آنان علی‌ بن ابی طالب (علیه السلام) و حمزه و عمار و ابو ذر و سلمان و مقداد بودند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"word","token":"الاولون","display":"الْاَوَّلُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۱۰۰","display":"۱۰۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حمزه","display":"حَمْزَةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمار","display":"عَمَّارٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"ذر","display":"ذَرٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلمان","display":"سَلْمَانُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مقداد","display":"مِقْدَادٌ"}]}]}