{"consensus_set_id":"s400558","translation_language":"fa","translation_source":{"hid":"400558"},"segments":[{"source_hadith_segment":"وَ قَدْ سَاَلَهُ رَجُلٌ عَمَّا اِشْتَبَهَ عَلَيْهِ مِنْ ايَاتِ","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"ساله","display":"سَاَلَهُ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"عما","display":"عَمَّا"},{"kind":"word","token":"اشتبه","display":"اِشْتَبَهَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ايات","display":"ايَاتِ"}]},{"source_hadith_segment":"الْكِتَابِ وَ اَمَّا قَوْلُهُ :   <quranic_text> « يَوْمَ يَقُومُ الرُّوحُ وَ الْمَلاٰئِكَةُ صَفًّا لاٰ يَتَكَلَّمُونَ اِلاّٰ مَنْ اَذِنَ لَهُ الرَّحْمٰنُ وَ قٰالَ صَوٰاباً » </quranic_text>   <footnote> [ النبا ۳۸ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"الكتاب","display":"الْكِتَابِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"يقوم","display":"يَقُومُ"},{"kind":"word","token":"الروح","display":"الرُّوحُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الملائكه","display":"الْمَلاٰئِكَةُ"},{"kind":"word","token":"صفا","display":"صَفًّا"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يتكلمون","display":"يَتَكَلَّمُونَ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"اذن","display":"اَذِنَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"صوابا","display":"صَوٰاباً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النبا","display":"النبا"},{"kind":"word","token":"۳۸","display":"۳۸"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"وَ قَوْلُهُ :  « وَ  <quranic_text> « اللّٰهِ رَبِّنٰا مٰا كُنّٰا مُشْرِكِينَ » </quranic_text>   <footnote> [ الانعام ۲۳ ] </footnote>  وَ قَوْلُهُ « وَ  <quranic_text> « يَوْمَ الْقِيٰامَةِ يَكْفُرُ بَعْضُكُمْ بِبَعْضٍ وَ يَلْعَنُ بَعْضُكُمْ بَعْضاً » </quranic_text>   <footnote> [ العنكبوت ۲۵ ] </footnote>  وَ قَوْلُهُ :   <quranic_text> « اِنَّ ذٰلِكَ لَحَقٌّ تَخٰاصُمُ اَهْلِ النّٰارِ » </quranic_text>   <footnote> [ ص ۶۴ ] </footnote>  وَ قَوْلُهُ :   <quranic_text> « لاٰ تَخْتَصِمُوا لَدَيَّ وَ قَدْ قَدَّمْتُ اِلَيْكُمْ بِالْوَعِيدِ » </quranic_text>   <footnote> [ ق ۲۸ ] </footnote>  وَ قَوْلُهُ :   <quranic_text> « اَلْيَوْمَ نَخْتِمُ عَليٰ اَفْوٰاهِهِمْ وَ تُكَلِّمُنٰا اَيْدِيهِمْ وَ تَشْهَدُ اَرْجُلُهُمْ بِمٰا كٰانُوا يَكْسِبُونَ » </quranic_text>   <footnote> [ يس ۶۵ ] </footnote>   :  فَاِنَّ ذَلِكَ فِي مَوَاطِنَ غَيْرِ وَاحِدٍ مِنْ مَوَاطِنِ ذَلِكَ الْيَوْمِ الَّذِي كَانَ مِقْدَارُهُ خَمْسِينَ اَلْفَ سَنَةٍ يَجْمَعُ اللَّهُ عَزَّ وَ جَلَّ الْخَلاَئِقَ فِي مَوَاطِنَ يَتَفَرَّقُونَ وَ يُكَلِّمُ بَعْضُهُمْ بَعْضاً وَ يَسْتَغْفِرُ بَعْضُهُمْ لِبَعْضٍ اُولَئِكَ الَّذِينَ كَانَ مِنْهُمُ الطَّاعَةُ فِي دَارِ الدُّنْيَا الرُّؤَسَاءَ وَ الْاَتْبَاعَ وَ يَلْعَنُ بَعْضُ اَهْلِ الْمَعَاصِي الَّذِينَ بَدَتْ مِنْهُمُ الْبَغْضَاءُ وَ تَعَاوَنُوا عَلَي الْاِثْمِ وَ الْعُدْوَانِ فِي دَارِ الدُّنْيَا الْمُسْتَكْبِرِينَ وَ الْمُسْتَضْعَفِينَ يُكَفِّرَ بَعْضُهُمْ بِبَعْضٍ وَ يَلْعَنُ بَعْضُهُمْ بَعْضاً وَ الْكُفْرُ فِي هَذِهِ الْايَةِ الْبَرَاءَةُ يَقُولُ :  فَيَبْرَاُ بَعْضُهُمْ مِنْ بَعْضٍ وَ نَظِيرُهَا فِي سُورَةِ اِبْرَاهِيمَ قَوْلُ الشَّيْطَانِ  <quranic_text> « اِنِّي كَفَرْتُ بِمٰا اَشْرَكْتُمُونِ مِنْ قَبْلُ » </quranic_text>   <footnote> [ ابراهيم ۲۲ ] </footnote>  وَ قَوْلُ اِبْرَاهِيمَ خَلِيلِ الرَّحْمَنِ :   <quranic_text> « كَفَرْنٰا بِكُمْ » </quranic_text>   <footnote> [ الممتحنة ۴ ] </footnote>  اَيْ تَبَرَّاْنَا مِنْكُمْ ثُمَّ يَجْتَمِعُونَ فِي مَوْطِنٍ اخَرَ يَبْكُونَ فَلَوْ اَنَّ تِلْكَ الْاَصْوَاتِ بَدَتْ لِاَهْلِ الدُّنْيَا لَاَذْهَلَتْ جَمِيعَ الْخَلْقِ عَنْ مَعَايِشِهِمْ ،  وَ لَتَصَدَّعَتْ قُلُوبُهُمْ اِلاَّ مَا شَاءَ اللَّهُ ،  فَلاَ يَزَالُونَ يَبْكُونَ الدَّمَ ،  ثُمَّ يَجْتَمِعُونَ فِي مَوْطِنٍ اخَرَ فَيَسْتَنْطِقُونَ فِيهِ فَيَقُولُونَ :   <quranic_text> « وَ اللّٰهِ رَبِّنٰا مٰا كُنّٰا مُشْرِكِينَ » </quranic_text>   <footnote> [ الانعام ۲۳ ] </footnote> فَيَخْتِمُ اللَّهُ تَبَارَكَ وَ تَعَالَي عَلَي اَفْوَاهِهِمْ وَ يَسْتَنْطِقُ الْاَيْدِيَ وَ الْاَرْجُلَ وَ الْجُلُودَ ،  فَتَشْهَدُ بِكُلِّ مَعْصِيَةٍ كَانَتْ مِنْهُمْ ،  ثُمَّ يُرْفَعُ عَنْ اَلْسِنَتِهِمُ الْخَتْمُ فَيَقُولُونَ لِجُلُودِهِمْ :   <quranic_text> « لِمَ شَهِدْتُمْ عَلَيْنٰا قٰالُوا اَنْطَقَنَا اللّٰهُ الَّذِي اَنْطَقَ كُلَّ شَيْءٍ » </quranic_text>   <footnote> [ فصلت ۲۱ ] </footnote>  ثُمَّ يَجْتَمِعُونَ فِي مَوْطِنٍ اخَرَ فَيُسْتَنْطَقُونَ فَيَفِرُّ بَعْضُهُمْ مِنْ بَعْضٍ ،  فَذَلِكَ قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « يَوْمَ يَفِرُّ الْمَرْءُ مِنْ اَخِيهِ وَ اُمِّهِ وَ اَبِيهِ وَ صٰاحِبَتِهِ وَ بَنِيهِ » </quranic_text>   <footnote> [ عبس ۳۴ ] </footnote> فَيُسْتَنْطَقُونَ  <quranic_text> « لاٰ يَتَكَلَّمُونَ اِلاّٰ مَنْ اَذِنَ لَهُ الرَّحْمٰنُ وَ قٰالَ صَوٰاباً » </quranic_text>   <footnote> [ النبا ۳۸ ] </footnote> فَيَقُومُ الرُّسُلُ صَلَوَاتُ اللَّهِ عَلَيْهِمْ فَيَشْهَدُونَ فِي هَذَا الْمَوْطِنِ ،  فَذَلِكَ قَوْلُهُ تَعَالَي :   <quranic_text> « فَكَيْفَ اِذٰا جِئْنٰا مِنْ كُلِّ اُمَّةٍ بِشَهِيدٍ وَ جِئْنٰا بِكَ عَليٰ هٰؤُلاٰءِ شَهِيداً » </quranic_text>   <footnote> [ النساء ۴۱ ] </footnote> ثُمَّ يَجْتَمِعُونَ فِي مَوْطِنٍ اخَرَ فَيَكُونُ فِيهِ مَقَامُ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ هُوَ الْمَقَامُ الْمَحْمُودُ ،  فَيُثْنِي عَلَي اللَّهِ تَبَارَكَ وَ تَعَالَي بِمَا لَمْ يُثْنِ عَلَيْهِ اَحَدٌ قَبْلَهُ ،  ثُمَّ يُثْنِي عَلَي الْمَلاَئِكَةِ كُلِّهِمْ فَلاَ يَبْقَي مَلَكٌ اِلاَّ اَثْنَي عَلَيْهِ مُحَمَّدٌ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ثُمَّ يُثْنِي عَلَي الرُّسُلِ بِمَا لَمْ يُثْنِ عَلَيْهِمْ اَحَدٌ مِثْلَهُ ،  ثُمَّ يُثْنِي عَلَي كُلِّ مُؤْمِنٍ وَ مُؤْمِنَةٍ يَبْدَاُ بِالصِّدِّيقِينَ ثُمَّ الشُّهَدَاءِ ثُمَّ الصَّالِحِينَ ،  فَيَحْمَدُهُ اَهْلُ السَّمَاوَاتِ وَ اَهْلُ الْاَرْضِ وَ ذَلِكَ قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « عَسيٰ اَنْ يَبْعَثَكَ رَبُّكَ مَقٰاماً مَحْمُوداً » </quranic_text>   <footnote> [ الاسراء ۷۹ ] </footnote> فَطُوبَي لِمَنْ كَانَ لَهُ فِي ذَلِكَ الْمَقَامِ حَقٌّ ،  وَ وَيْلٌ لِمَنْ لَمْ يَكُنْ لَهُ فِي ذَلِكَ الْمَقَامِ حَظٌّ وَ لاَ نَصِيبٌ ،  ثُمَّ يَجْتَمِعُونَ فِي مَوْطِنٍ اخَرَ وَ يُدَانُ بَعْضُهُمْ مِنْ بَعْضٍ ؛ وَ هَذَا كُلُّهُ قَبْلَ الْحِسَابِ فَاِذَا اَخَذَ فِي الْحِسَابِ شُغِلَ كُلُّ اِنْسَانٍ بِمَا لَدَيْهِ ،  نَسْاَلُ اللَّهَ بَرَكَةَ ذَاتِ الْيَوْمِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"ربنا","display":"رَبِّنٰا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"كنا","display":"كُنّٰا"},{"kind":"word","token":"مشركين","display":"مُشْرِكِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۲۳","display":"۲۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"القيامه","display":"الْقِيٰامَةِ"},{"kind":"word","token":"يكفر","display":"يَكْفُرُ"},{"kind":"word","token":"بعضكم","display":"بَعْضُكُمْ