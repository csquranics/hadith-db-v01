{"consensus_set_id":"22523","translation_language":"fa","translation_source":{"hid":"324992"},"segments":[{"source_hadith_segment":"اِنَّ اَلْعَمَلَ الصَّالِحَ لَيَذْهَبُ اِلَي الْجَنَّةِ فَيُسَهِّلُ لِصَاحِبِهِ كَمَا يَبْعَثُ الرَّجُلُ غُلاَماً فَيَفْرِشُ لَهُ ثُمَّ قَرَاَ اَمَّا الَّذِينَ امَنُوا وَ عَمِلُوا الصَّالِحَاتِ  <quranic_text> « فَلِاَنْفُسِهِمْ يَمْهَدُونَ » </quranic_text>   <footnote> [ الروم ۴۴ ] </footnote>   .","translation_segment":"امام صادق علیه‌ السلام‌ فرمود: همانا عمل صالح وارد بهشت می‌شود و بهشت برای صاحبش مهیا می‌گرداند، همان گونه که انسان غلام خود را می‌فرستد تا محلی (مورد نظر را) برایش آماده سازد و فرش پهن نماید، سپس حضرت (این کلام خداوند را) خواند: «کسانی که ایمان آورده و عمل صالح انجام دهند، برای خویشتن آماده سازی کرده‌اند».","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"العمل","display":"اَلْعَمَلَ"},{"kind":"word","token":"الصالح","display":"الصَّالِحَ"},{"kind":"word","token":"ليذهب","display":"لَيَذْهَبُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"فيسهل","display":"فَيُسَهِّلُ"},{"kind":"word","token":"لصاحبه","display":"لِصَاحِبِهِ"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"يبعث","display":"يَبْعَثُ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"غلاما","display":"غُلاَماً"},{"kind":"word","token":"فيفرش","display":"فَيَفْرِشُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عملوا","display":"عَمِلُوا"},{"kind":"word","token":"الصالحات","display":"الصَّالِحَاتِ"},{"kind":"tag_open","tag_na