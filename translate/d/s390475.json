{"consensus_set_id":"s390475","translation_language":"fa","translation_source":{"hid":"390475"},"segments":[{"source_hadith_segment":"وَ قَوْلُهُ :   <quranic_text> « اِنَّ الَّذِينَ يَشْتَرُونَ بِعَهْدِ اللّٰهِ وَ اَيْمٰانِهِمْ ثَمَناً قَلِيلاً » </quranic_text>   <footnote> [ العمران ۷۷ ] </footnote>  قَالَ :  يَتَقَرَّبُونَ اِلَي النَّاسِ بِاَنَّهُمْ مُسْلِمُونَ ،  فَيَاْخُذُونَ مِنْهُمْ وَ يَخُونُونَهُمْ ،  وَ مَا هُمْ بِمُسْلِمِينَ عَلَي الْحَقِيقَةِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يشترون","display":"يَشْتَرُونَ"},{"kind":"word","token":"بعهد","display":"بِعَهْدِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ايمانهم","display":"اَيْمٰانِهِمْ"},{"kind":"word","token":"ثمنا","display":"ثَمَناً"},{"kind":"word","token":"قليلا","display":"قَلِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۷۷","display":"۷۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يتقربون","display":"يَتَقَرَّبُونَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"word","token":"بانهم","display":"بِاَنَّهُمْ"},{"kind":"word","token":"مسلمون","display":"مُسْلِمُونَ"},{"kind":"word","token":"فياخذون","display":"فَيَاْخُذُونَ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يخونونهم","display":"يَخُونُونَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"هم