"source_hadith_segment":"فَقَالَ :  رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  يَا فَاطِمَةُ اَطْعِمِي اِبْنَيَّ - فَقَالَتْ :  مَا فِي الْبَيْتِ اِلاَّ بَرَكَةُ رَسُولِ اللَّهِ فَالْتَقَاهُمَا رَسُولُ اللَّهِ بِرِيقِهِ حَتَّي شِبَعَا وَ نَامَا - وَ اِقْتَرَضَا لِرَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ثَلاَثَةَ اَقْرَاصٍ مِنْ شَعِيرٍ ،  فَلَمَّا اَفْطَرَ وَضَعَاهَا بَيْنَ يَدَيْهِ فَجَاءَ سَائِلٌ فَقَالَ :  اَطْعِمُونِي مِمَّا رَزَقَكُمُ اللَّهُ .  فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  يَا عَلِيُّ قُمْ فَاَعْطِهِ .  قَالَ :  فَاَخَذْتُ قُرْصاً فَاَعْطَيْتُهُ ،  ثُمَّ جَاءَ ثَانٍ فَقَالَ :  رَسُولُ اللَّهِ قُمْ يَا عَلِيُّ فَاَعْطِهِ .  فَقُمْتُ فَاَعْطَيْتُهُ ،  فَجَاءَ ثَالِثٌ فَقَالَ :  قُمْ يَا عَلِيُّ فَاَعْطِهِ .  [ قَالَ :  ] فَاَعْطَيْتُهُ","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةُ"},{"kind":"word","token":"اطعمي","display":"اَطْعِمِي"},{"kind":"word","token":"ابني","display":"اِبْنَيَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فقالت","display":"فَقَالَتْ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"بركه","display":"بَرَكَةُ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فالتقاهما","display":"فَالْتَقَاهُمَا"},{"kind":"word","token":"رسول","display":"رَسُو