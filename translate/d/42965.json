 ؟  فقالا :  سمعنا رسول اللّه صلي اللّه عليه و اله و سلم يقول :  انّ فاطمة سيّدة نساء اهل الجنّة .  ثمّ قالت امّ ايمن :  فمن كانت سيّدة نساء اهل الجنّة تدّعي ما ليس لها !  ؟  و انا امراة من اهل الجنّة ما كنت لاشهد الاّ بما سمعت من رسول اللّه صلي اللّه عليه و اله و سلم .  فقال عمر :  دعينا يا امّ ايمن ،  من هذه القصص ،  بايّ شيء تشهدان ؟  فقالت :  كنت جالسة في بيت فاطمة عليها السّلام و رسول اللّه صلي اللّه عليه و اله و سلم جالس حتّي نزل عليه جبرئيل فقال :  يا محمّد قم فانّ اللّه تبارك و تعالي امرني ان اخطّ لك فدكا بجناحي ،  فقام رسول اللّه صلي اللّه عليه و اله و سلم مع جبرئيل عليه السّلام فما لبثت ان رجع ؛  فقالت فاطمة عليها السّلام :  يا ابة ،  اين ذهبت ؟  فقال :  خطّ جبرئيل عليه السّلام لي فدكا بجناحه ،  و حدّ لي حدودها فقالت :  يا ابة ،  انّي اخاف العيلة و الحاجة من بعدك فصدّق بها عليّ .  فقال :  هي صدقة عليك .  فقبضتها ،  قالت :  نعم .  فقال رسول اللّه صلي اللّه عليه و اله و سلم :  يا امّ ايمن ،  اشهدي ،  و يا عليّ ،  اشهد","translation_segment":"","segment_columns":[{"kind":"word","token":"عمر","display":"عمر"},{"kind":"word","token":"انت","display":"انت"},{"kind":"word","token":"معلمه","display":"معلّمة"},{"kind":"word","token":"قالت","display":"قالت"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"كنت","display":"كنت"},{"kind":"word","token":"معلمه","display":"معلّمة"},{"kind":"word","token":"فانما","display":"فانّما"},{"kind":"word","token":"علمني","display":"علّمني"},{"kind":"word","token":"ابن","display":"ابن"},{"kind":"word","token":"عمي","display":"عمّي"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"بعلي","display":"بعلي"},{"kind":"word","token":"فقال","display":"فقال"},{"kind":"word","token":"ابو","display":"ابو"},{"kind":"word","token":"بكر","display":"بكر"},{"kind":"word","token":"فان","display":"فانّ"},{"kind":"word","token":"عائشه","display":"عائشة"},{"kind":"word","token":"تشهد","display":"تشهد"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"عمر",