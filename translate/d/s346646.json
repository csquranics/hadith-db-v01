{"consensus_set_id":"s346646","translation_language":"fa","translation_source":{"hid":"346646"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ هَلْ فِي كِتَابِ اللَّهِ مَثَلٌ لِلْقَائِمِ عَلَيْهِ السَّلاَمُ فَقَالَ نَعَمْ ايَةُ صَاحِبِ الْحِمَارِ  <quranic_text> « فَاَمٰاتَهُ اللّٰهُ [ مِائَةَ عٰامٍ ] ثُمَّ بَعَثَهُ » </quranic_text>   <footnote> [ البقرة ۲۵۹ ] </footnote>   .","translation_segment":"/۳-علی بن خطاب از موذن مسجد احمر روایت کرده که او گفته است: از امام صادق علیه السلام پرسیدم: آیا در کتاب خدا مثلی برای قائم علیه السلام هست‌؟ حضرت فرمودند: بله مثل او مانند صاحب حمار است که خداوند او را یک‌صد سال میراند و سپس زنده نمود.","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتاب","display":"كِتَابِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"مثل","display":"مَثَلٌ"},{"kind":"word","token":"للقائم","display":"لِلْقَائِمِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"ايه","display":"ايَةُ"},{"kind":"word","token":"صاحب","display":"صَاحِبِ"},{"kind":"word","token":"الحمار","display":"الْحِمَارِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاماته","display":"فَاَمٰاتَهُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"مائه","display":"مِائَةَ"},{"kind":"word","token":"عام","display":"عٰامٍ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"بعثه