{"consensus_set_id":"s367807","translation_language":"fa","translation_source":{"hid":"367807"},"segments":[{"source_hadith_segment":"عَلَيْكُمْ بِالْاِخْوَانِ فَاِنَّهُمْ عُدَّةٌ لِلدُّنْيَا وَ عُدَّةٌ لِلْاخِرَةِ اَ لاَ تَسْمَعُ اِلَي قَوْلِ اَهْلِ النَّارِ -  <quranic_text> « فَمٰا لَنٰا مِنْ شٰافِعِينَ وَ لاٰ صَدِيقٍ حَمِيمٍ » </quranic_text>   <footnote> [ الشعراء ۱۰۰ ] </footnote>   .","translation_segment":"علی علیه السلام فرمود: شما به برادران خود توجه کنید که آنها برای دنیا و آخرت شما سودمند خواهند بود، مگر نشنیده‌اید که خداوند در قرآن از قول اهل دوزخ می‌فرماید: (در این روز سخت نه شفیعی داریم و نه دوستی که حمایتمان کند).","segment_columns":[{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"بالاخوان","display":"بِالْاِخْوَانِ"},{"kind":"word","token":"فانهم","display":"فَاِنَّهُمْ"},{"kind":"word","token":"عده","display":"عُدَّةٌ"},{"kind":"word","token":"للدنيا","display":"لِلدُّنْيَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عده","display":"عُدَّةٌ"},{"kind":"word","token":"للاخره","display":"لِلْاخِرَةِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تسمع","display":"تَسْمَعُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"النار","display":"النَّارِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فما","display":"فَمٰا"},{"kind":"word","token":"لنا","display":"لَنٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شافعين","display":"شٰافِعِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"صديق","display":"صَدِيقٍ"},{"kind":"word","token":"حميم","display":"حَمِيمٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":