{"consensus_set_id":"59028","translation_language":"fa","translation_source":{"hid":"411327"},"segments":[{"source_hadith_segment":"« اِنَّ اَسِرَّتَهَا مِنْ دُرٍّ وَ يَاقُوتٍ ،  وَ ذَلِكَ قَوْلُ اللَّهِ :   <quranic_text> « عَليٰ سُرُرٍ مَوْضُونَةٍ » </quranic_text>   <footnote> [ الواقعة ۱۵ ] </footnote> ،  يَعْنِي اَوْسَاطَ السُّرُرِ [ مِنْ ] قُضْبَانِ الدُّرِّ وَ الْيَاقُوتِ مَضْرُوبَةً عَلَيْهَا الْحِجَالُ ،  وَ الْحِجَالُ مِنْ دُرٍّ وَ يَاقُوتٍ ،  اَخَفُّ مِنَ الرِّيشِ وَ اَلْيَنُ مِنَ الْحَرِيرِ ،  وَ عَلَي السُّرُرِ مِنَ الْفُرُشِ عَلَي قَدْرِ سِتِّينَ غُرْفَةً مِنْ غُرَفِ الدُّنْيَا ،  بَعْضُهَا فَوْقَ بَعْضٍ ،  وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ فُرُشٍ مَرْفُوعَةٍ » </quranic_text>   <footnote> [ الواقعة ۳۴ ] </footnote> وَ قَوْلُهُ تَعَالَي :   <quranic_text> « عَلَي الْاَرٰائِكِ يَنْظُرُونَ » </quranic_text>   <footnote> [ المطففين ۲۳ ] </footnote> يَعْنِي بِالْاَرَائِكِ السُّرُرَ الْمَوْضُونَةَ عَلَيْهَا الْحِجَالُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اسرتها","display":"اَسِرَّتَهَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"در","display":"دُرٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ياقوت","display":"يَاقُوتٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"سرر","display":"سُرُرٍ"},{"kind":"word","token":"موضونه","display":"مَوْضُونَةٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الواقعه","display":"الواقعة"},{"kind":"word","token":"۱۵","display":"۱۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","to