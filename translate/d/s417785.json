سْئَلُكُمْ عَلَيْهِ اَجْراً اِلاَّ الْمَوَدَّةَ فِي الْقُرْبيٰ » </quranic_text>   <footnote> [ الشوري ۲۳ ] </footnote>   .  و هذه خصوصيّة للنّبيّ - صلّي اللّٰه عليه و اله - الي يوم القيامة ،  و خصوصيّة للال دون غيرهم .  و ذلك انّ اللّٰه - تعالي - حكي ذكر نوح - عليه السّلام - في كتابه :   <quranic_text> « يٰا قَوْمِ لاٰ اَسْئَلُكُمْ عَلَيْهِ مٰالاً ،  اِنْ اَجرِيَ اِلاّٰ عَلَي اللّٰهِ ،  وَ مٰا اَنَا بِطٰارِدِ الَّذِينَ امَنُوا ،  اِنَّهُمْ مُلاٰقُوا رَبِّهِمْ وَ لٰكِنِّي اَرٰاكُمْ قَوْماً تَجْهَلُونَ » </quranic_text>   <footnote> [ هود ۲۹ ] </footnote>   .  و حكي - عزّ و جلّ - عن هود - عليه السّلام - انّه قال :   <quranic_text> « لاٰ اَسْئَلُكُمْ عَلَيْهِ اَجْراً ،  اِنْ اَجْرِيَ اِلاّٰ عَلَي الَّذِي فَطَرَنِي ،  اَ فَلاٰ تَعْقِلُونَ » </quranic_text>   <footnote> [ هود ۵۱ ] </footnote>   .  و قال - عزّ و جلّ - لنبيّه محمّد - صلّي اللّٰه عليه و اله- :  قل يا محمّد :   <quranic_text> « لاٰ اَسْئَلُكُمْ عَلَيْهِ اَجْراً اِلاَّ الْمَوَدَّةَ فِي الْقُرْبيٰ » </quranic_text>   <footnote> [ الشوري ۲۳ ] </footnote>   .  و لم يفرض اللّٰه - تعالي - مودّتهم الاّ و قد علم انّهم لا يرتدّون عن الدّين ابدا ،  و لا يرجعون الي الضّلال بعد الايمان .","translation_segment":"","segment_columns":[{"kind":"word","token":"فاول","display":"فاوّل"},{"kind":"word","token":"ذلك","display":"ذلك"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"الي","display":"الي"},{"kind":"word","token":"قوله-","display":"قوله-"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"الايه","display":"الاية"},{"kind":"word","token":"السادسه","display":"السّادسة"},{"kind":"word","token":"قول","display":"قول"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عزّ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"جل-","display":"جلّ-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word