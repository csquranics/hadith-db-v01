{"consensus_set_id":"7489","translation_language":"fa","translation_source":{"hid":"103254"},"segments":[{"source_hadith_segment":"« دِيَةُ اَلْيَدِ اِذَا قُطِعَتْ خَمْسُونَ مِنَ الْاِبِلِ فَمَا كَانَ جُرُوحاً دُونَ الاِصْطِلاَمِ فَيَحْكُمُ بِهِ ذَوَا عَدْلٍ مِنْكُمْ  <quranic_text> « وَ مَنْ لَمْ يَحْكُمْ بِمٰا اَنْزَلَ اللّٰهُ فَاُولٰئِكَ هُمُ الْكٰافِرُونَ » </quranic_text>   <footnote> [ المائدة ۴۴ ] </footnote>","translation_segment":"عبد اللٰه بن سنان گوید: امام صادق علیه السلام فرمود: دیه دست اگر قطع شود، پنجاه شتر است، و هر چه را که بدون زخم و پارگی التیام پیدا کرد، یعنی تمام عضو قطع نشد، باید ارزش آن را دو عادل مسلمان معین دارند، و هر کس به غیر ما أنزل اللٰه حکم راند پس آنان کافران باشند.","segment_columns":[{"kind":"word","token":"۱","display":"۱"},{"kind":"word","token":"۶-۴-","display":"۶-۴-"},{"kind":"word","token":"قضي","display":"قَضَي"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ديه","display":"دِيَةُ"},{"kind":"word","token":"الانف","display":"الْاَنْفِ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"استؤصل","display":"اُسْتُؤْصِلَ"},{"kind":"word","token":"مائه","display":"مِائَةٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الابل","display":"الْاِبِلِ"},{"kind":"word","token":"ثلاثون","display":"ثَلاَثُونَ"},{"kind":"word","token":"حقه","display":"حِقَّةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ثلاثون","display":"ثَلاَثُونَ"},{"kind":"word","token":"بنت","display":"بِنْتَ"},{"kind":"word","token":"لبون","display":"لَبُونٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عشرون","display":"عِشْرُونَ"},{"kind":"word","token":"بنت","display":"بِنْتَ"},{"kind":"word","token":"مخاض","display":"مَخَاضٍ"},{"kind"