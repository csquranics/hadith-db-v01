{"consensus_set_id":"57471","translation_language":"fa","translation_source":{"hid":"410856"},"segments":[{"source_hadith_segment":"« لَمَّا نَصَبَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  عَلِيّاً ( عَلَيْهِ السَّلاَمُ ) يَوْمَ غَدِيرِ خُمٍّ قَالَ قَوْمٌ :  مَا بَالُهُ يَرْفَعُ بِضَبْعِ اِبْنِ عَمِّهِ !  فَاَنْزَلَ اللَّهُ تَعَالَي :   <quranic_text> « اَمْ حَسِبَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ اَنْ لَنْ يُخْرِجَ اللّٰهُ اَضْغٰانَهُمْ » </quranic_text>   <footnote> [ محمد ۲۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نصب","display":"نَصَبَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"عليا","display":"عَلِيّاً"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"غدير","display":"غَدِيرِ"},{"kind":"word","token":"خم","display":"خُمٍّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قوم","display":"قَوْمٌ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"باله","display":"بَالُهُ"},{"kind":"word","token":"يرفع","display":"يَرْفَعُ"},{"kind":"word","token":"بضبع","display":"بِضَبْعِ"},{"kind":"word","token":"ابن","display":"اِبْنِ"},{"kind":"word","token":"عمه","display":"عَمِّهِ"},{"kind":"word","token":"فانزل","display":"فَاَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"حسب","display":"حَ