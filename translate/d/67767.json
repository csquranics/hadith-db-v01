{"consensus_set_id":"67767","translation_language":"fa","translation_source":{"hid":"372036"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ -  <quranic_text> « وَ مٰا كٰانَ صَلاٰتُهُمْ عِنْدَ الْبَيْتِ اِلاّٰ مُكٰاءً وَ تَصْدِيَةً » </quranic_text>   <footnote> [ الانفال ۳۵ ] </footnote>  قَالَ التَّصْفِيرُ وَ التَّصْفِيقُ .","translation_segment":"یمانی با یک واسطه از امام صادق علیه السلام روایت نموده که در معنی قول خداوند: «و مٰا کٰان‌ صلاٰتهم‌ عند البیت‌ إلاٰ مکٰاء و تصدیه‌» (و نباشد نمازشان نزد آن خانه (کعبه) مگر سوت زدن و بانکی و دست بر دست کوفتنی-أنفال ۳۵:۸) فرمود: سوت زدن و دست بر هم کوفتن چندان که صدا دهد.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"صلاتهم","display":"صَلاٰتُهُمْ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"مكاء","display":"مُكٰاءً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تصديه","display":"تَصْدِيَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۳۵","display":"۳۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"التصفير","display":"التَّصْفِيرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"التصفيق","display":"التَّصْفِيقُ"}]}]}