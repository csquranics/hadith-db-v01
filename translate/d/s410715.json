{"consensus_set_id":"s410715","translation_language":"fa","translation_source":{"hid":"410715"},"segments":[{"source_hadith_segment":"فِي اَهْلِ النَّارِ - قَالَ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :  « فَاِذَا يَئِسُوا مِنْ خَزَنَةِ جَهَنَّمَ ؛  رَجَعُوا اِلَي مَالِكٍ مُقَدِّمِ الْخُزَّانِ ،  وَ اَمَّلُوا اَنْ يُخَلِّصَهُمْ مِنْ ذَلِكَ الْهَوَانِ ،  قَالَ اللَّهُ جَلَّ جَلاَلُهُ :   <quranic_text> « وَ نٰادَوْا يٰا مٰالِكُ لِيَقْضِ عَلَيْنٰا رَبُّكَ » </quranic_text>   <footnote> [ الزخرف ۷۷ ] </footnote> ،  قَالَ :  فَيُحْبَسُ عَنْهُمُ الْجَوَابُ اَرْبَعِينَ سَنَةً وَ هُمْ فِي الْعَذَابِ ،  ثُمَّ يُجِيبُهُمْ كَمَا قَالَ اللَّهُ تَعَالَي فِي كِتَابِهِ الْمَكْنُونِ :   <quranic_text> « قٰالَ اِنَّكُمْ مٰاكِثُونَ » </quranic_text>   <footnote> [ الزخرف ۷۷ ] </footnote> ،  قَالَ :  فَاِذَا يَئِسُوا مِنْ مَوْلاَهُمْ رَبِّ الْعَالَمِينَ الَّذِي كَانَ اَهْوَنَ شَيْءٍ عِنْدَهُمْ فِي دُنْيَاهُمْ ،  وَ كَانَ قَدْ اثَرَ كُلُّ وَاحِدٍ مِنْهُمْ هَوَاهُ عَلَيْهِ مُدَّةَ الْحَيَاةِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"النار","display":"النَّارِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"يئسوا","display":"يَئِسُوا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"خزنه","display":"خَزَنَةِ"},{"kind":"word","token":"جهنم","display":"جَهَنَّمَ"},{"kind":"word","token":"رجعوا","display":"رَجَعُوا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"مالك","display":"مَالِكٍ"},{"kind":"word","token":"مقدم","display":"مُقَدِّمِ"},{"kind":"word","token":"الخز