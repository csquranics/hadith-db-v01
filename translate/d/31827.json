{"consensus_set_id":"31827","translation_language":"fa","translation_source":{"hid":"106769"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مٰا يُؤْمِنُ اَكْثَرُهُمْ بِاللّٰهِ اِلاّٰ وَ هُمْ مُشْرِكُونَ » </quranic_text>   <footnote> [ يوسف ۱۰۶ ] </footnote>  قَالَ يُطِيعُ الشَّيْطَانَ مِنْ حَيْثُ لاَ يَعْلَمُ فَيُشْرِكُ .","translation_segment":"حضرت صادق علیه السلام در گفتار خدای عز و جل: «و ایمان نیاورند بیشتر آنان بخدا جز اینکه ایشانند مشرکان» (سوره یوسف آیه ۱۰۶) فرمود: شیطان را ندانسته پیروی کند پس مشرک گردد.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يؤمن","display":"يُؤْمِنُ"},{"kind":"word","token":"اكثرهم","display":"اَكْثَرُهُمْ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"مشركون","display":"مُشْرِكُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۱۰۶","display":"۱۰۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يطيع","display":"يُطِيعُ"},{"kind":"word","token":"الشيطان","display":"الشَّيْطَانَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"حيث","display":"حَيْثُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يعلم","display":"يَعْلَمُ"},{"kind":"word","token":"فيشرك","display":"فَيُشْرِكُ"}]}]}