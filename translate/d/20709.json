{"consensus_set_id":"20709","translation_language":"fa","translation_source":{"hid":"402464"},"segments":[{"source_hadith_segment":"« اَنْزَلَ اَللَّهُ هَذِهِ الْايَةَ فِي التَّطَوُّعِ خَاصَّةً <quranic_text> « فَاَيْنَمٰا تُوَلُّوا فَثَمَّ وَجْهُ اللّٰهِ اِنَّ اللّٰهَ وٰاسِعٌ عَلِيمٌ » </quranic_text>   <footnote> [ البقرة ۱۱۵ ] </footnote> وَ صَلَّي رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اِيمَاءً عَلَي رَاحِلَتِهِ اَيْنَمَا تَوَجَّهَتْ بِهِ حِينَ خَرَجَ اِلَي خَيْبَرَ ،  وَ حِينَ رَجَعَ مِنْ مَكَّةَ ،  وَ جَعَلَ الْكَعْبَةَ خَلْفَ ظَهْرِهِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"التطوع","display":"التَّطَوُّعِ"},{"kind":"word","token":"خاصه","display":"خَاصَّةً"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاينما","display":"فَاَيْنَمٰا"},{"kind":"word","token":"تولوا","display":"تُوَلُّوا"},{"kind":"word","token":"فثم","display":"فَثَمَّ"},{"kind":"word","token":"وجه","display":"وَجْهُ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"واسع","display":"وٰاسِعٌ"},{"kind":"word","token":"عليم","display":"عَلِيمٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۱۵","display":"۱۱۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"}