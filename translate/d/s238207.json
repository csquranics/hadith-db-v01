{"consensus_set_id":"s238207","translation_language":"fa","translation_source":{"hid":"238207"},"segments":[{"source_hadith_segment":"<quranic_text> « فَهَلْ عَسَيْتُمْ اِنْ تَوَلَّيْتُمْ » </quranic_text>   <footnote> [ محمد ۲۲ ] </footnote>  الْايَةَ .  قَالَ :  كَيْفَ رَاَيْتُمُ الْقَوْمَ حِينَ تَوَلَّوْا عَنْ كِتَابِ اللَّهِ ،  اَ لَمْ يَسْفِكُوا الدَّمَ الْحَرَامَ ،  وَ قَطَّعُوا الْاَرْحَامَ ،  وَ عَصَوُا الرَّحْمَنَ ؟  !  .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فهل","display":"فَهَلْ"},{"kind":"word","token":"عسيتم","display":"عَسَيْتُمْ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"توليتم","display":"تَوَلَّيْتُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"محمد","display":"محمد"},{"kind":"word","token":"۲۲","display":"۲۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"رايتم","display":"رَاَيْتُمُ"},{"kind":"word","token":"القوم","display":"الْقَوْمَ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"تولوا","display":"تَوَلَّوْا"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"كتاب","display":"كِتَابِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يسفكوا","display":"يَسْفِكُوا"},{"kind":"word","token":"الدم","display":"الدَّمَ"},{"kind":"word","token":"الحرام","display":"الْحَرَامَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قطعوا","display":"قَطَّعُوا"},{"kind":"word","token":"الارحام","display":"الْاَرْحَامَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عصوا","display":"عَصَوُا"},{"kind":"word","token":"الرحم