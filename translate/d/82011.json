{"consensus_set_id":"82011","translation_language":"fa","translation_source":{"hid":"411594"},"segments":[{"source_hadith_segment":"قَرَاْتُ عَلَي عَلِيِّ بْنِ اَحْمَدَ الْوَاحِدِيِّ حَدِيثاً مَرْفُوعاً اِلَي النَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ","translation_segment":"","segment_columns":[{"kind":"word","token":"قرات","display":"قَرَاْتُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"احمد","display":"اَحْمَدَ"},{"kind":"word","token":"الواحدي","display":"الْوَاحِدِيِّ"},{"kind":"word","token":"حديثا","display":"حَدِيثاً"},{"kind":"word","token":"مرفوعا","display":"مَرْفُوعاً"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"-","display":"-"}]},{"source_hadith_segment":") اَنَّهُ قَالَ :  « لَمُبَارَزَةُ عَلِيٍّ لِعَمْرِو بْنِ عَبْدِ وُدٍّ اَفْضَلُ مِنْ عَمَلِ اُمَّتِي اِلَي يَوْمِ الْقِيَامَةِ ،  وَ هِيَ التِّجَارَةُ الْمُرْبِحَةُ الْمُنْجِيَةُ مِنَ الْعَذَابِ الْاَلِيمِ ،  يَقُولُ اللَّهُ تَعَالَي :   <quranic_text> « هَلْ اَدُلُّكُمْ عَليٰ تِجٰارَةٍ تُنْجِيكُمْ مِنْ عَذٰابٍ اَلِيمٍ تُؤْمِنُونَ بِاللّٰهِ وَ رَسُولِهِ وَ تُجٰاهِدُونَ فِي سَبِيلِ اللّٰهِ بِاَمْوٰالِكُمْ وَ اَنْفُسِكُمْ ذٰلِكُمْ خَيْرٌ لَكُمْ اِنْ كُنْتُمْ تَعْلَمُونَ يَغْفِرْ لَكُمْ ذُنُوبَكُمْ وَ يُدْخِلْكُمْ جَنّٰاتٍ تَجْرِي مِنْ تَحْتِهَا الْاَنْهٰارُ وَ مَسٰاكِنَ طَيِّبَةً فِي جَنّٰاتِ عَدْنٍ ذٰلِكَ الْفَوْزُ الْعَظِيمُ » </quranic_text>   <footnote> [ الصف ۱۰ ] </footnote> .","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قال","display":"