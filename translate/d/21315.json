{"consensus_set_id":"21315","translation_language":"fa","translation_source":{"hid":"85785"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ الْقِرَاءَةُ فِي الصَّلاَةِ فِيهَا شَيْءٌ مُوَقَّتٌ","translation_segment":"* *۱۲۲ - به ابو عبد الله صادق (ع) گفتم: در قرائت نمازها","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"القراءه","display":"الْقِرَاءَةُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةِ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"موقت","display":"مُوَقَّتٌ"}]},{"source_hadith_segment":"قَالَ « لاَ اِلاَّ الْجُمُعَةَ تُقْرَاُ بِالْجُمُعَةِ وَ الْمُنَافِقِينَ »","translation_segment":"سوره معینی مقرر شده است‌؟ ابو عبد","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"الجمعه","display":"الْجُمُعَةَ"},{"kind":"word","token":"تقرا","display":"تُقْرَاُ"},{"kind":"word","token":"فيها","display":"فيها"},{"kind":"word","token":"بالجمعه","display":"بِالْجُمُعَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المنافقين","display":"الْمُنَافِقِينَ"},{"kind":"word","token":"التهذيب","display":"التهذيب"}]},{"source_hadith_segment":"قُلْتُ لَهُ فَاَيُّ السُّوَرِ تُقْرَاُ فِي الصَّلَوَاتِ","translation_segment":"الله گفت: نه. مگر در نماز جمعه","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"فاي","display":"فَاَيُّ"},{"kind":"word","token":"السور","display":"السُّوَرِ"},{"kind":"word","token":"تقرا","display":"تُقْرَاُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الصلوات","display":"الصَّلَوَاتِ"}]},{"source_hadith_segment":"قَالَ « اَمَّا الظُّهْرُ وَ الْعِشَاءُ الْاخِرَةُ تُقْرَاُ فِيهِمَا سَوَاءً وَ الْعَصْرُ وَ الْمَغْرِبُ سَوَاءً وَ اَمَّا الْغَدَاةُ فَاَطْوَلُ وَ اَمَّا الظُّهْرُ وَ الْعِشَاءُ الْاخِرَةُ - فَ‍  <quranic_text> « سَبِّحِ اِسْمَ رَبِّكَ الْاَعْلَي » </quranic_text>   <footnote> [ الاعلي ۱ ] </footnote>  وَ  <quranic_text> « اَلشَّمْسِ وَ ضُحٰاهٰا » </quranic_text>   <footnote> [ الشمس ۱ ] </footnote>  وَ نَحْوُهُمَا وَ اَمَّا الْعَصْرُ وَ الْمَغْرِبُ - فَ‍  <quranic_text> « اِذٰا جٰاءَ نَصْرُ اللّٰهِ » </quranic_text>   <footnote> [ النصر ۱ ] </footnote>  وَ  <quranic_text> « اَلْهٰاكُمُ التَّكٰاثُرُ » </quranic_text>   <footnote> [ التكاثر ۱ ] </footnote>  وَ نَحْوُهُمَا وَ اَمَّا الْغَدَاةُ فَ‍  <quranic_text> « عَمَّ يَتَسٰاءَلُونَ » </quranic_text>   <footnote> [ النبا ۱ ] </footnote>  وَ  <quranic_text> « هَلْ اَتٰاكَ حَدِيثُ الْغٰاشِيَةِ » </quranic_text>   <footnote> [ الغاشية ۱ ] </footnote>  وَ  <quranic_text> « لاٰ اُقْسِمُ بِيَوْمِ الْقِيٰامَةِ » </quranic_text>   <footnote> [ القيامة ۱ ] </footnote>  وَ  <quranic_text> « هَلْ اَتيٰ عَلَي الْاِنْسٰانِ حِينٌ مِنَ الدَّهْرِ » </quranic_text>   <footnote> [ الانسان ۱ ] </footnote>   .","translation_segment":"که باید سوره جمعه و سوره منافقون تلاوت بشود. من گفتم: در سایر نمازها چه سوره‌ای را توصیه می‌فرمائید؟ ابو عبد الله گفت: در نماز ظهر و در نماز عشاء سوره‌های مشابه تلاوت کن و در نماز عصر و نماز مغرب نیز سوره‌های مشابه، ولی در نماز صبح، قدری سوره‌های طولانیتر انتخاب کن: مثلا در نماز ظهر و نماز عشاء سوره «سبح اسم ربک الاعلی» و سوره «و الشمس و ضحاها» و سوره‌هائی همسان و همانند آن. و در نماز عصر و مغرب سوره «اذا جاء نصر الله» و سوره «الهاکم التکاثر» و همانند آن. و در نماز صبح سوره «عم یتساءلون» و سوره «هل أتاک حدیث الغاشیه» و سوره «لا اقسم بیوم القیامه» و سوره «هل أتی علی الانسان حین من الدهر».","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الظهر","display":"الظُّهْرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"العشاء","display":"الْعِشَاءُ"},{"kind":"word","token":"الاخره","display":"الْاخِرَةُ"},{"kind":"word","token":"تقرا","display":"تُقْرَاُ"},{"kind":"word","token":"فيهما","display":"فِيهِمَا"},{"kind":"word","token":"سواء","display":"سَوَاءً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"العصر","display":"الْعَصْرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المغرب","display":"الْمَغْرِبُ"},{"kind":"word","token":"سواء","display":"سَوَاءً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الغداه","display":"الْغَدَاةُ"},{"kind":"word","token":"فاطول","display":"فَاَطْوَلُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الظهر","display":"الظُّهْرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"العشاء","display":"الْعِشَاءُ"},{"kind":"word","token":"الاخره","display":"الْاخِرَةُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ف","display":"فَ‍"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سبح","display":"سَبِّحِ"},{"kind":"word","token":"اسم","display":"اِسْمَ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"الاعلي","display":"الْاَعْلَي"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعلي","display":"الاعلي"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الشمس","display":"اَلشَّمْسِ"},{"kind":"word","token":"و","display":"وَ"