{"consensus_set_id":"s331881","translation_language":"fa","translation_source":{"hid":"331881"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اَ فَمَنْ وَعَدْنٰاهُ وَعْداً حَسَناً فَهُوَ لاٰقِيهِ » </quranic_text>   <footnote> [ القصص ۶۱ ] </footnote>  قَالَ :  نَزَلَتْ فِي عَلِيٍّ وَ حَمْزَةَ وَ اَبِي جَهْلٍ قَالَ شُعْبَةُ :  فَسَاَلْتُ السُّدِّيَّ فَقَالَهُ فِيهِمْ .","translation_segment":"عن مجاهد فی قوله تعالی: (أفمن وعدناه وعدا حسنا فهو لاقیه) قال: نزلت فی علی و حمزه و أبی جهل. مجاهد درباره سخن خداوند: «ا فمن وعدناه وعدا حسنا فهو لاقیه» گفت: درباره علی و حمزه و ابو جهل نازل شده است. شعبه می‌گوید: از سدی پرسیدم، گفت: درباره آنهاست.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"وعدناه","display":"وَعَدْنٰاهُ"},{"kind":"word","token":"وعدا","display":"وَعْداً"},{"kind":"word","token":"حسنا","display":"حَسَناً"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"لاقيه","display":"لاٰقِيهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۶۱","display":"۶۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حمزه","display":"حَمْزَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جهل","display":"جَهْلٍ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"شعبه","display":"شُعْبَ