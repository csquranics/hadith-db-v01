{"consensus_set_id":"48396","translation_language":"fa","translation_source":{"hid":"404053"},"segments":[{"source_hadith_segment":"اَلْمِيثَاقُ اَلْغَلِيظُ هُوَ الْعَهْدُ الْمَاْخُوذُ عَلَي الزَّوْجِ حَالَةَ الْعَقْدِ مِنْ اِمْسَاكٍ بِمَعْرُوفٍ اَوْ تَسْرِيحٍ بِاِحْسَانٍ .  قَالَ :  وَ هُوَ الْمَرْوِيُّ عَنْ اَبِي جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ ) .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الميثاق","display":"اَلْمِيثَاقُ"},{"kind":"word","token":"الغليظ","display":"اَلْغَلِيظُ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"العهد","display":"الْعَهْدُ"},{"kind":"word","token":"الماخوذ","display":"الْمَاْخُوذُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الزوج","display":"الزَّوْجِ"},{"kind":"word","token":"حاله","display":"حَالَةَ"},{"kind":"word","token":"العقد","display":"الْعَقْدِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"امساك","display":"اِمْسَاكٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بمعروف","display":"بِمَعْرُوفٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"تسريح","display":"تَسْرِيحٍ"},{"kind":"word","token":"باحسان","display":"بِاِحْسَانٍ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"المروي","display":"الْمَرْوِيُّ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره۲۲۹","display":"البقرة۲۲۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}