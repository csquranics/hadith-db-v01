 يوسف ۹۶ ] </footnote>  وَ كَانَ اَهْلُهُ وَ اَقْرِبَاؤُهُ يُفَنِّدُونَهُ عَلَي ذِكْرِهِ لِيُوسُفَ حَتَّي اَنَّهُ لَمَّا وَجَدَ رِيحَ يُوسُفَ قَالَ :   <quranic_text> « اِنِّي لَاَجِدُ رِيحَ يُوسُفَ لَوْ لاٰ اَنْ تُفَنِّدُونِ قٰالُوا تَاللّٰهِ اِنَّكَ لَفِي ضَلاٰلِكَ الْقَدِيمِ فَلَمّٰا اَنْ جٰاءَ الْبَشِيرُ » </quranic_text>   <footnote> [ يوسف ۹۴ ] </footnote>  وَ هُوَ يَهُودَا اِبْنُهُ وَ اَلْقَي قَمِيصَ يُوسُفَ  <quranic_text> « عَليٰ وَجْهِهِ فَارْتَدَّ بَصِيراً قٰالَ اَ لَمْ اَقُلْ لَكُمْ اِنِّي اَعْلَمُ مِنَ اللّٰهِ مٰا لاٰ تَعْلَمُونَ » </quranic_text>   <footnote> [ يوسف ۹۶ ] </footnote>","translation_segment":"یوسف زنده است و نمرده است و خدای تعالی ذکره پس از دوره غیبت او را محققا ظاهر مینماید و بپسرانش میگفت براستی من از طرف خدا چیزی میدانم که شماها نمیدانید و خاندان و خویشانش در یاد یوسف و انتظار او ویرا غلط‍‌ کار میدانستند تا آنگاه هم که بوی یوسف را شنید و فرمود من بوی یوسف را دریافتم اگر مرا بغلط‍‌ نسبت ندهید گفتند بخدا تو هنوز در بیراهه دیرین خود هستی و چون بشیر آمد که همان پسرش یهودا بودو پیراهن یوسف را برویش","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"لبنيه","display":"لِبَنِيهِ"},{"kind":"word","token":"اني","display":"انّي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"اعلم","display":"اَعْلَمُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تعلمون","display":"تَعْلَمُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۹۶","display":"۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display"