{"consensus_set_id":"19729","translation_language":"fa","translation_source":{"hid":"104433"},"segments":[{"source_hadith_segment":"سَاَلَ الْهَيْثَمُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ وَ اَنَا عِنْدَهُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ عَلاٰمٰاتٍ وَ بِالنَّجْمِ هُمْ يَهْتَدُونَ » </quranic_text>   <footnote> [ النحل ۱۶ ] </footnote>  فَقَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ النَّجْمُ وَ الْعَلاَمَاتُ هُمُ الْاَئِمَّةُ عَلَيْهِمُ السَّلاَمُ  .","translation_segment":"هیثم از امام صادق ع راجع به قول خدای عز و جل «و علاماتی گذاشت و بوسیله ستاره هدایت شوند» پرسید، امام فرمود: رسول خدا صلی اللٰه علیه و آله ستاره است و علامات ائمه ع ‌اند.","segment_columns":[{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"الهيثم","display":"الْهَيْثَمُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علامات","display":"عَلاٰمٰاتٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بالنجم","display":"بِالنَّجْمِ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يهتدون","display":"