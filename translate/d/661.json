م :  « اِي و الَّذِي بَعَثَنِي بِالنُّبُوَّةِ انّهم لَيَسْتَضِيئُونَ بِنُورِهِ و يَنْتَفِعُونَ بِوَلاَيَتِهِ فِي غَيْبَتِهِ كَانْتِفَاعِ النَّاسِ بِالشَّمْسِ و اِنْ تَجَلاَّهَا سَحَابٌ ،  يَا جَابِرُ :  هَذَا مِنْ مَكْنُونِ سِرِّ اللَّهِ و مَخْزُونِ عِلْمِ اللَّهِ فَاكْتُمْهُ اِلاَّ عَنْ اَهْلِهِ » اِلَي اخِرِ الْخَبَرِ .","translation_segment":"داده باشند کسی در امامت او باقی نخواهد ماند، به خداوندی که مرا براستی برانگیخته شیعیان از غیبت او استفاده خواهند کرد و از تابش انوار او مستفیض خواهند شد همان طور که از خورشید استضائه میکنند و لو در زیر ابر باشد، ای جابر این مطالب از اسرار خداوند است که در گنجینه‌های علم محفوظ‍‌ مانده و آنها را جز به اهلش اطلاع نده.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"جابر","display":"جابر"},{"kind":"word","token":"فقلت","display":"فقلت"},{"kind":"word","token":"له","display":"له"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فهل","display":"فَهَلْ"},{"kind":"word","token":"يقع","display":"يَقَعُ"},{"kind":"word","token":"لشيعته","display":"لِشِيعَتِهِ"},{"kind":"word","token":"الانتفاع","display":"الاِنْتِفَاعُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"غيبته","display":"غَيْبَتِهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلّم"},{"kind":"word","token":"اي","display":"اِي"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"بعثني","display":"بَعَثَنِي"},{"kind":"word","token":"بالنبوه","display":"بِ