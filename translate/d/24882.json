{"consensus_set_id":"24882","translation_language":"fa","translation_source":{"hid":"114121"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ الْقَوٰاعِدُ مِنَ النِّسٰاءِ اللاّٰتِي لاٰ يَرْجُونَ نِكٰاحاً » </quranic_text>   <footnote> [ النور ۶۰ ] </footnote>  مَا الَّذِي يَصْلُحُ لَهُنَّ اَنْ يَضَعْنَ مِنْ ثِيَابِهِنَّ قَالَ الْجِلْبَابُ .","translation_segment":"محمد بن مسلم گوید: از امام باقر علیه السلام درباره آیه: «و زنان وانشسته‌ای که امیدی به ازدواج ندارند» چه لباسی را جایز است بردارند؟ فرمود: جلباب (را می‌توانند بردارند).","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"القواعد","display":"الْقَوٰاعِدُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"النساء","display":"النِّسٰاءِ"},{"kind":"word","token":"اللاتي","display":"اللاّٰتِي"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يرجون","display":"يَرْجُونَ"},{"kind":"word","token":"نكاحا","display":"نِكٰاحاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۶۰","display":"۶۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يصلح","display":"يَصْلُحُ"},{"kind":"word","token":"لهن","display":"لَهُنَّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يضعن","display":"يَضَعْنَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ثيابهن","display":"ثِيَابِ