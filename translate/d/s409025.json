{"consensus_set_id":"s409025","translation_language":"fa","translation_source":{"hid":"409025"},"segments":[{"source_hadith_segment":"« جَاءَتِ اِمْرَاَةٌ اِلَي النَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) فَسَاَلَتْهُ عَنْ حَقِّ الزَّوْجِ عَلَي الْمَرْاَةِ ،  فَخَبَّرَهَا ،  ثُمَّ قَالَتْ :  فَمَا حَقُّهَا عَلَيْهِ ؟  قَالَ :  لاَ ،  قَالَتْ :  لاَ وَ اللَّهِ ،  لاَ تَزَوَّجْتُ اَبَداً .  ثُمَّ وَلَّتْ ،  فَقَالَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :  اِرْجِعِي .  فَرَجَعَتْ ،  فَقَالَ :  اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « وَ اَنْ يَسْتَعْفِفْنَ خَيْرٌ لَهُنَّ » </quranic_text>   <footnote> [ النور ۶۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"جاءت","display":"جَاءَتِ"},{"kind":"word","token":"امراه","display":"اِمْرَاَةٌ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"فسالته","display":"فَسَاَلَتْهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"حق","display":"حَقِّ"},{"kind":"word","token":"الزوج","display":"الزَّوْجِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المراه","display":"الْمَرْاَةِ"},{"kind":"word","token":"فخبرها","display":"فَخَبَّرَهَا"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قالت","display":"قَالَتْ"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"حقها","display":"حَقُّهَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"قالت","display":"قَالَتْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"و","d