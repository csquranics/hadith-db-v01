{"consensus_set_id":"72828","translation_language":"fa","translation_source":{"hid":"181032"},"segments":[{"source_hadith_segment":"شَفَاعَتُنَا لِاَهْلِ الْكَبَائِرِ مِنْ شِيعَتِنَا فَاَمَّا التَّائِبُونَ فَاِنَّ اللَّهَ يَقُولُ  <quranic_text> « مٰا عَلَي الْمُحْسِنِينَ مِنْ سَبِيلٍ » </quranic_text>   <footnote> [ التوبة ۹۱ ] </footnote>   .","translation_segment":"امام صادق علیه السلام فرمود: شفاعت ما برای انجام دهندگان گناهان کبیره از شیعیانمان است، ولی در باره توبه‌کنندگان خداوند می‌گوید: و بر نیکوکاران راهی نیست (عتاب و گناهی نیست) و خداوند آمرزنده و مهربان است. (توبه/۹۴)","segment_columns":[{"kind":"word","token":"شفاعتنا","display":"شَفَاعَتُنَا"},{"kind":"word","token":"لاهل","display":"لِاَهْلِ"},{"kind":"word","token":"الكبائر","display":"الْكَبَائِرِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شيعتنا","display":"شِيعَتِنَا"},{"kind":"word","token":"فاما","display":"فَاَمَّا"},{"kind":"word","token":"التائبون","display":"التَّائِبُونَ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المحسنين","display":"الْمُحْسِنِينَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"سبيل","display":"سَبِيلٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۹۱","display":"۹۱"},{"kind":"tag_close","tag_name":"footnote"}]}]}