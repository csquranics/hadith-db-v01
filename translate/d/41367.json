{"consensus_set_id":"41367","translation_language":"fa","translation_source":{"hid":"358013"},"segments":[{"source_hadith_segment":"بَلَغَنَا اَنَّ مِنْ كَلاَمِ اللَّهِ تَعَالَي الَّذِي اَنْزَلَهُ عَلَي بَنِي اِسْرَائِيلَ اِنِّي اَنَا اللَّهُ لاَ اِلَهَ اِلاَّ اَنَا ذُو [ بَكَّةَ ] مُفْقِرُ الزُّنَاةِ وَ تَارِكٌ تَارِكِي الصَّلاَةِ عُرَاةً .","translation_segment":"بما خبر رسیده که از سخنان خدا تعالی که به بنی اسرائیل فرو فرستاده اینست که: منم خدا، نیست شایسته پرستشی جز من دارای مهلت هستم، مستمند کن زنا کارم و بی‌نمازها را رها نکنم جز برهنه و لخت.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بلغنا","display":"بَلَغَنَا"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"كلام","display":"كَلاَمِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"انزله","display":"اَنْزَلَهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرَائِيلَ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اله","display":"اِلَهَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"طه۱۴","display":"طه۱۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"بكه","display":"بَكَّةَ"},{"kind":"word","token":"مفقر","display":"مُفْقِرُ"},{"kind":"word","token":"الزناه","display":"الزُّنَاةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"