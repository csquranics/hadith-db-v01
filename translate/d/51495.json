ْ » </quranic_text>   <footnote> [ البقرة ۱۷۲ ] </footnote> وَ قَالَ :   <quranic_text> « يٰا اَيُّهَا الرُّسُلُ كُلُوا مِنَ الطَّيِّبٰاتِ وَ اِعْمَلُوا صٰالِحاً » </quranic_text>   <footnote> [ المؤمنون ۵۱ ] </footnote> ،  وَ قَالَ رَسُولُ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) لِبَعْضِ نِسَائِهِ : مَا لِي اَرَاكِ شَعْثَاءَ مَرْهَاءَ سَلْتَاءَ ؟  »","translation_segment":"","segment_columns":[{"kind":"word","token":"ويحك","display":"وَيْحَكَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"عاصم","display":"عَاصِمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"تري","display":"تَرَي"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"اباح","display":"اَبَاحَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"اللذات","display":"اللَّذَّاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"يكره","display":"يَكْرَهُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اخذت","display":"اَخَذْتَ"},{"kind":"word","token":"منها","display":"مِنْهَا"},{"kind":"word","token":"لانت","display":"لَاَنْتَ"},{"kind":"word","token":"اهون","display":"اَهْوَنُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"سمعته","display":"سَمِعْتَهُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"مرج","display":"مَرَجَ"},{"kind":"word","token":"البحرين","display":"الْبَحْرَيْنِ"},{"kind":"word","token":"يلتقيان","display":"يَلْتَقِيٰانِ"},{"kind":"tag_close","tag_name":"qurani