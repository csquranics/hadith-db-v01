t>   <footnote> [ طه ۱, طه ۲ ] </footnote>  وَ  <quranic_text> «  يس  .  وَ الْقُرْانِ الْحَكِيمِ .  اِنَّكَ لَمِنَ الْمُرْسَلِينَ عَليٰ صِرٰاطٍ مُسْتَقِيمٍ » </quranic_text>   <footnote> [ يس ۱, يس ۲, يس ۳, يس ۴ ] </footnote>  وَ  <quranic_text> «  ن وَ الْقَلَمِ وَ مٰا يَسْطُرُونَ .  مٰا اَنْتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍ » </quranic_text>   <footnote> [ القلم ۱ ] </footnote>  وَ  <quranic_text> « يٰا اَيُّهَا الْمُدَّثِّرُ  » </quranic_text>   <footnote> [ المدثر ۱ ] </footnote>  وَ  <quranic_text> « يٰا اَيُّهَا الْمُزَّمِّلُ  » </quranic_text>   <footnote> [ المزمل ۱ ] </footnote>  وَ قَوْلُهُ :   <quranic_text> « فَاتَّقُوا اللّٰهَ يٰا اُولِي الْاَلْبٰابِ الَّذِينَ امَنُوا قَدْ اَنْزَلَ اللّٰهُ اِلَيْكُمْ ذِكْراً .  رَسُولاً » </quranic_text>   <footnote> [ الطلاق ۱۰ ] </footnote>  فَالذِّكْرُ اِسْمٌ مِنْ اَسْمَاءِ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  ،  وَ نَحْنُ اَهْلُ الذِّكْرِ ،  فَاسْاَلْ يَا كَلْبِيُّ عَمَّا بَدَا لَكَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةٌ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"كلبي","display":"كَلْبِيُّ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"عشره","display":"عَشَرَةُ"},{"kind":"word","token":"اسماء","display":"اَسْمَاءٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"محمد","display":"مُحَمَّدٌ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"رسول","display":"رَسُولٌ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"خلت","display":"خَلَتْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبله","display":"قَبْلِهِ"},{"kind":"word","token":"الرسل","display":"الرُّسُلُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","toke