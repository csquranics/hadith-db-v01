{"consensus_set_id":"s408856","translation_language":"fa","translation_source":{"hid":"408856"},"segments":[{"source_hadith_segment":"« لَقَدْ قَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) لِبَنِي عَبْدِ الْمُطَّلِبِ :  اِئْتُونِي بِاَعْمَالِكُمْ ،  لاَ بِاَنْسَابِكُمْ وَ اَحْسَابِكُمْ ،  قَالَ اللَّهُ تَعَالَي :   <quranic_text> « فَاِذٰا نُفِخَ فِي الصُّورِ فَلاٰ اَنْسٰابَ بَيْنَهُمْ يَوْمَئِذٍ وَ لاٰ يَتَسٰاءَلُونَ » </quranic_text>   <footnote> [ المؤمنون ۱۰۱ ] </footnote> اِلَي قَوْلِهِ تَعَالَي :   <quranic_text> « خٰالِدُونَ » </quranic_text>   <footnote> [ المؤمنون ۱۰۳ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"لبني","display":"لِبَنِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"المطلب","display":"الْمُطَّلِبِ"},{"kind":"word","token":"ائتوني","display":"اِئْتُونِي"},{"kind":"word","token":"باعمالكم","display":"بِاَعْمَالِكُمْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"بانسابكم","display":"بِاَنْسَابِكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"احسابكم","display":"اَحْسَابِكُمْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاذا","display":"فَاِذٰا"},{"kind":"word","token":"نفخ","display":"نُفِخَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الصور","display":"الصُّورِ"},{"kind":"word"