{"consensus_set_id":"67711","translation_language":"fa","translation_source":{"hid":"303887"},"segments":[{"source_hadith_segment":"وَ قِيلَ لَهُ فِيكَ عَظَمَةٌ فَقَالَ عَلَيْهِ السَّلاَمُ بَلْ فِيَّ عِزَّةٌ قَالَ اللَّهُ  <quranic_text> « وَ لِلّٰهِ الْعِزَّةُ وَ لِرَسُولِهِ وَ لِلْمُؤْمِنِينَ » </quranic_text>   <footnote> [ المنافقون ۸ ] </footnote>   .","translation_segment":"گفتند: در وجود شما عظمت و بزرگواری هست، فرمود: آنچه در وجود من است عزت است. خداوند فرماید: «عزت از آن خدا و پیغمبر و مومنان است.»","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"فيك","display":"فِيكَ"},{"kind":"word","token":"عظمه","display":"عَظَمَةٌ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"بل","display":"بَلْ"},{"kind":"word","token":"في","display":"فِيَّ"},{"kind":"word","token":"عزه","display":"عِزَّةٌ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"العزه","display":"الْعِزَّةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لرسوله","display":"لِرَسُولِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"للمؤمنين","display":"لِلْمُؤْمِنِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المنافقون","display":"المنافقون"},{"kind":"word","token":"۸","display":"۸"},{"kind":"tag_close","tag_name":"footnote"}]}]}