{"consensus_set_id":"s409481","translation_language":"fa","translation_source":{"hid":"409481"},"segments":[{"source_hadith_segment":"« وَ لَكِنَّ اللَّهَ عَزَّ وَ جَلَّ يَخْتَبِرُ عَبِيدَهُ بِاَنْوَاعِ الشَّدَائِدِ ،  وَ يَتَعَبَّدُهُمْ بِاَنْوَاعِ الْمَجَاهِدِ ،  وَ يَبْتَلِيهِمْ بِضُرُوبِ الْمَكَارِهِ ،  اِخْرَاجاً لِلتَّكَبُّرِ مِنْ قُلُوبِهِمْ ،  وَ اِسْكَاناً لِلتَّذَلُّلِ فِي اَنْفُسِهِمْ ،  وَ لِيَجْعَلَ ذَلِكَ اَبْوَاباً اِلَي فَضْلِهِ ،  وَ اَسْبَاباً وَ دَلِيلاً لِعَفْوِهِ وَ فِتْنَتِهِ ،  كَمَا قَالَ :   <quranic_text> « الَمَ اَ حَسِبَ النّٰاسُ اَنْ يُتْرَكُوا اَنْ يَقُولُوا امَنّٰا وَ هُمْ لاٰ يُفْتَنُونَ وَ لَقَدْ فَتَنَّا الَّذِينَ مِنْ قَبْلِهِمْ فَلَيَعْلَمَنَّ اللّٰهُ الَّذِينَ صَدَقُوا وَ لَيَعْلَمَنَّ الْكٰاذِبِينَ » </quranic_text>   <footnote> [ العنكبوت ۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لَكِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يختبر","display":"يَخْتَبِرُ"},{"kind":"word","token":"عبيده","display":"عَبِيدَهُ"},{"kind":"word","token":"بانواع","display":"بِاَنْوَاعِ"},{"kind":"word","token":"الشدائد","display":"الشَّدَائِدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يتعبدهم","display":"يَتَعَبَّدُهُمْ"},{"kind":"word","token":"بانواع","display":"بِاَنْوَاعِ"},{"kind":"word","token":"المجاهد","display":"الْمَجَاهِدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يبتليهم","display":"يَبْتَلِيهِمْ"},{"kind":"word","token":"بضروب","display":"بِضُرُوبِ"},{"kind":"word","token":"المكاره","display":"الْمَكَارِهِ"},{"kind":"word","token":"اخراجا","display":"اِخْرَاجاً"},{"kind":"word","token":"للتكبر","display":"لِلتَّكَبُّرِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قلوبهم","display":"