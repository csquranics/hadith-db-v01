{"consensus_set_id":"70172","translation_language":"fa","translation_source":{"hid":"331739"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اِنَّ فِي ذٰلِكَ لَايٰاتٍ لِلْمُتَوَسِّمِينَ » </quranic_text>   <footnote> [ الحجر ۷۵ ] </footnote>  قَالَ :  كَانَ وَ اللَّهِ مُحَمَّدُ بْنُ عَلِيٍّ مِنْهُمْ .","translation_segment":"عن الحکم فی قوله تعالی: (إن‌ فی ذلک لآیات للمتوسمین) قال: کان و الله محمد بن علی‌ منهم. حکم درباره سخن خداوند: «ان‌ فی ذلک لآیات للمتوسمین» گفت: به خدا سوگند که محمد بن علی از آنان بود.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"لايات","display":"لَايٰاتٍ"},{"kind":"word","token":"للمتوسمين","display":"لِلْمُتَوَسِّمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"۷۵","display":"۷۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"}]}]}