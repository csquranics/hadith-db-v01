{"consensus_set_id":"103430","translation_language":"fa","translation_source":{"hid":"102172"},"segments":[{"source_hadith_segment":"وَ سُئِلَ الصَّادِقُ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ طَعٰامُ الَّذِينَ اُوتُوا الْكِتٰابَ حِلٌّ لَكُمْ » </quranic_text>   <footnote> [ المائدة ۵ ] </footnote>  قَالَ « يَعْنِي الْحُبُوبَ » .","translation_segment":"از امام صادق علیه السلام سوال شد از معنی گفتار خداوند عزیز «طعٰام‌ الذین‌ أوتوا الکتٰاب‌ حل‌ لکم‌» مائده:۸ (طعام کسانی که از ملیین‌اند و خداپرستان که دارای کتاب‌اند برای شما حلال است) فرمود: مراد حبوبات است. (یعنی خواربار بلکه مطلق هر چیز که تذکیه نخواهد).","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طعام","display":"طَعٰامُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اوتوا","display":"اُوتُوا"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابَ"},{"kind":"word","token":"حل","display":"حِلٌّ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۵","display":"۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"الحبوب","display":"الْحُبُوبَ"}]}]}