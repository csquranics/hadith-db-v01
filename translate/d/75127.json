{"consensus_set_id":"75127","translation_language":"fa","translation_source":{"hid":"403883"},"segments":[{"source_hadith_segment":"« يَا اِبْنَ مَسْعُودٍ ،  اِذَا تَلَوْتَ كِتَابَ اللَّهِ تَعَالَي فَاَتَيْتَ عَلَي ايَةٍ فِيهَا اَمْرٌ وَ نَهْيٌ ،  فَرَدِّدْهَا نَظَراً وَ اِعْتِبَاراً فِيهَا ،  وَ لاَ تَسْهُ عَنْ ذَلِكَ ،  فَاِنَّ نَهْيَهُ يَدُلُّ عَلَي تَرْكِ الْمَعَاصِي ،  وَ اَمْرَهُ يَدُلُّ عَلَي عَمَلِ الْبِرِّ وَ الصَّلاَحِ ،  فَاِنَّ اللَّهَ تَعَالَي يَقُولُ :   <quranic_text> « فَكَيْفَ اِذٰا جَمَعْنٰاهُمْ لِيَوْمٍ لاٰ رَيْبَ فِيهِ وَ وُفِّيَتْ كُلُّ نَفْسٍ مٰا كَسَبَتْ وَ هُمْ لاٰ يُظْلَمُونَ » </quranic_text>   <footnote> [ العمران ۲۵ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"مسعود","display":"مَسْعُودٍ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"تلوت","display":"تَلَوْتَ"},{"kind":"word","token":"كتاب","display":"كِتَابَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"فاتيت","display":"فَاَتَيْتَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ايه","display":"ايَةٍ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"امر","display":"اَمْرٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نهي","display":"نَهْيٌ"},{"kind":"word","token":"فرددها","display":"فَرَدِّدْهَا"},{"kind":"word","token":"نظرا","display":"نَظَراً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعتبارا","display":"اِعْتِبَاراً"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تسه","display":"تَسْهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"فان","display":"فَاِنَّ