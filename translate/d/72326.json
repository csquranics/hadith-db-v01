{"consensus_set_id":"72326","translation_language":"fa","translation_source":{"hid":"331424"},"segments":[{"source_hadith_segment":"يَا ( اَ ) بَا الْحَسَنِ قَلَّمَا اَقْبَلْتَ اَنْتَ وَ اَنَا عِنْدَ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اِلاَّ قَالَ :  يَا سَلْمَانُ هَذَا وَ حِزْبُهُ هُمُ الْمُفْلِحُونَ يَوْمَ الْقِيَامَةِ .","translation_segment":"همین مضمون با سندهای دیگر نیز نقل شده است.","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"با","display":"بَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"قلما","display":"قَلَّمَا"},{"kind":"word","token":"اقبلت","display":"اَقْبَلْتَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"سلمان","display":"سَلْمَانُ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حزبه","display":"حِزْبُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"المفلحون","display":"الْمُفْلِحُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المجادله۲۲","display":"المجادلة۲۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"wor