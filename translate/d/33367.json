{"consensus_set_id":"33367","translation_language":"fa","translation_source":{"hid":"109576"},"segments":[{"source_hadith_segment":"كَانَ عَلِيٌّ عَلَيْهِ السَّلاَمُ اِذَا هَالَهُ شَيْءٌ فَزِعَ اِلَي الصَّلاَةِ ثُمَّ تَلاَ هَذِهِ الْايَةَ :   <quranic_text> « وَ اِسْتَعِينُوا بِالصَّبْرِ وَ الصَّلاٰةِ » </quranic_text>   <footnote> [ البقرة ۴۵ ] </footnote>   .","translation_segment":"ابو بصیر گوید: امام صادق علیه السلام فرمود: امیر مومنان علی علیه السلام همواره و هرگاه چیزی او را می‌ترسانید، به نماز روی می‌آورد. سپس این آیه را تلاوت می‌فرمود: و استعینوا بالصبر و الصلاٰه‌.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"هاله","display":"هَالَهُ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"فزع","display":"فَزِعَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"تلا","display":"تَلاَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"استعينوا","display":"اِسْتَعِينُوا"},{"kind":"word","token":"بالصبر","display":"بِالصَّبْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۴۵","display":"۴۵"},{"kind":"tag_close","tag_name":"footnote"}]}]}