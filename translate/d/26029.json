olumns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تقول","display":"تَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"اله","display":"اِلٰهَ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الحي","display":"الْحَيُّ"},{"kind":"word","token":"القيوم","display":"الْقَيُّومُ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تاخذه","display":"تَاْخُذُهُ"},{"kind":"word","token":"سنه","display":"سِنَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"نوم","display":"نَوْمٌ"},{"kind":"tag_close","tag_name":"quranic_text"}]},{"source_hadith_segment":"اِلَي اخِرِ الْايَةِ وَ تَقُولُ  <quranic_text> « وَ لَقَدْ ذَرَاْنٰا لِجَهَنَّمَ كَثِيراً مِنَ الْجِنِّ وَ الْاِنْسِ لَهُمْ قُلُوبٌ لاٰ يَفْقَهُونَ بِهٰا وَ لَهُمْ اَعْيُنٌ لاٰ يُبْصِرُونَ بِهٰا وَ لَهُمْ اذٰانٌ لاٰ يَسْمَعُونَ بِهٰا اُولٰئِكَ كَالْاَنْعٰامِ بَلْ هُمْ اَضَلُّ اُولٰئِكَ هُمُ الْغٰافِلُونَ » </quranic_text>   <footnote> [ الاعراف ۱۷۹ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « سَوٰاءٌ عَلَيْكُمْ اَ دَعَوْتُمُوهُمْ اَمْ اَنْتُمْ صٰامِتُونَ اِنَّ الَّذِينَ تَدْعُونَ مِنْ دُونِ اللّٰهِ عِبٰادٌ اَمْثٰالُكُمْ فَادْعُوهُمْ فَلْيَسْتَجِيبُوا لَكُمْ اِنْ كُنْتُمْ صٰادِقِينَ اَ لَهُمْ اَرْجُلٌ يَمْشُونَ بِهٰا اَمْ لَهُمْ اَيْدٍ يَبْطِشُونَ بِهٰا اَمْ لَهُمْ اَعْيُنٌ يُبْصِرُونَ بِهٰا اَمْ لَهُمْ اذٰانٌ يَسْمَعُونَ بِهٰا » </quranic_text>   <footnote> [ الاعراف ۱۹۳ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « اِنَّ وَلِيِّيَ اللّٰهُ الَّذِي نَزَّلَ الْكِتٰابَ وَ هُوَ يَتَوَلَّي الصّٰالِحِينَ » </quranic_text>   <footnote> [ الاعراف ۱۹۶ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « وَ اِنْ تَدْعُوهُمْ اِلَي الْهُديٰ لاٰ يَسْمَعُوا وَ تَرٰاهُمْ يَنْظُرُونَ اِلَيْكَ وَ هُمْ لاٰ يُبْصِرُونَ » </quranic_text>   <footnote> [ الاعراف ۱۹۸ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « اُولٰئِكَ الَّذِينَ طَبَعَ اللّٰهُ عَليٰ قُلُوبِهِمْ وَ سَمْعِهِمْ وَ اَبْصٰارِهِمْ وَ اُولٰئِكَ هُمُ الْغٰافِلُونَ » </quranic_text>   <footnote> [ النحل ۱۰۸ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « اِنّٰا جَعَلْنٰا عَليٰ قُلُوبِهِمْ اَكِنَّةً اَنْ يَفْقَهُوهُ وَ فِي اذٰانِهِمْ وَقْراً وَ اِنْ تَدْعُهُمْ اِلَي الْهُديٰ فَلَنْ يَهْتَدُوا اِذاً اَبَداً » </quranic_text>   <footnote> [ الكهف ۵۷ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « فَاَوْجَسَ فِي نَفْسِهِ خِيفَةً مُوسيٰ قُلْنٰا لاٰ تَخَفْ اِنَّكَ اَنْتَ الْاَعْليٰ وَ اَلْقِ مٰا فِي يَمِينِكَ تَلْقَفْ مٰا صَنَعُوا اِنَّمٰا صَنَعُوا كَيْدُ سٰاحِرٍ وَ لاٰ يُفْلِحُ السّٰاحِرُ حَيْثُ اَتيٰ » </quranic_text>   <footnote> [ طه ۶۷ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « اَ فَلَمْ يَسِيرُوا فِي الْاَرْضِ فَتَكُونَ لَهُمْ قُلُوبٌ يَعْقِلُونَ بِهٰا اَوْ اذٰانٌ يَسْمَعُونَ بِهٰا فَاِنَّهٰا لاٰ تَعْمَي الْاَبْصٰارُ وَ لٰكِنْ تَعْمَي الْقُلُوبُ الَّتِي فِي الصُّدُورِ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ الحج ۴۶ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ طسم تِلْكَ ايٰاتُ الْكِتٰابِ الْمُبِينِ لَعَلَّكَ بٰاخِعٌ نَفْسَكَ اَلاّٰ يَكُونُوا مُؤْمِنِينَ اِنْ نَشَاْ نُنَزِّلْ عَلَيْهِمْ مِنَ السَّمٰاءِ ايَةً فَظَلَّتْ اَعْنٰاقُهُمْ لَهٰا خٰاضِعِينَ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ الشعراء ۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « قٰالَ اَ وَ لَوْ جِئْتُكَ بِشَيْءٍ مُبِينٍ قٰالَ فَاْتِ بِهِ اِنْ كُنْتَ مِنَ الصّٰادِقِينَ فَاَلْقيٰ عَصٰاهُ فَاِذٰا هِيَ ثُعْبٰانٌ مُبِينٌ وَ نَزَعَ يَدَهُ فَاِذٰا هِيَ بَيْضٰاءُ لِلنّٰاظِرِينَ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ الشعراء ۳۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « قٰالَ كَلاّٰ اِنَّ مَعِي رَبِّي سَيَهْدِينِ » </quranic_text>   <footnote> [ الشعراء ۶۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « يٰا مُوسيٰ لاٰ تَخَفْ اِنِّي لاٰ يَخٰافُ لَدَيَّ الْمُرْسَلُونَ » </quranic_text>   <footnote> [ النمل ۱۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « اللّٰهُ لاٰ اِلٰهَ اِلاّٰ هُوَ رَبُّ الْعَرْشِ الْعَظِيمِ » </quranic_text>   <footnote> [ النمل ۲۶ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « يٰا مُوسيٰ اَقْبِلْ وَ لاٰ تَخَفْ اِنَّكَ مِنَ الْامِنِينَ » </quranic_text>   <footnote> [ القصص ۳۱ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « قٰالَ سَنَشُدُّ عَضُدَكَ بِاَخِيكَ وَ نَجْعَلُ لَكُمٰا سُلْطٰاناً فَلاٰ يَصِلُونَ اِلَيْكُمٰا بِايٰاتِنٰا اَنْتُمٰا وَ مَنِ اِتَّبَعَكُمَا الْغٰالِبُونَ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ القصص ۳۵ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « وَ لَقَدْ مَنَنّٰا عَليٰ مُوسيٰ وَ هٰارُونَ وَ نَجَّيْنٰاهُمٰا وَ قَوْمَهُمٰا مِنَ الْكَرْبِ الْعَظِيمِ وَ نَصَرْنٰاهُمْ فَكٰانُوا هُمُ الْغٰالِبِينَ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ الصافات ۱۱۴ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « وَ اَلْقَيْتُ عَلَيْكَ مَحَبَّةً مِنِّي وَ لِتُصْنَعَ عَليٰ عَيْنِي اِذْ تَمْشِي اُخْتُكَ فَتَقُولُ هَلْ اَدُلُّكُمْ عَليٰ مَنْ يَكْفُلُهُ فَرَجَعْنٰاكَ اِليٰ اُمِّكَ كَيْ تَقَرَّ عَيْنُهٰا وَ لاٰ تَحْزَنَ وَ قَتَلْتَ نَفْساً فَنَجَّيْنٰاكَ مِنَ الْغَمِّ وَ فَتَنّٰاكَ فُتُوناً » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ طه ۳۹ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « وَ حَرَّمْنٰا عَلَيْهِ الْمَرٰاضِعَ مِنْ قَبْلُ فَقٰالَتْ هَلْ اَدُلُّكُمْ عَليٰ اَهْلِ بَيْتٍ يَكْفُلُونَهُ لَكُمْ وَ هُمْ لَهُ نٰاصِحُونَ فَرَدَدْنٰاهُ اِليٰ اُمِّهِ كَيْ تَقَرَّ عَيْنُهٰا وَ لاٰ تَحْزَنَ وَ لِتَعْلَمَ اَنَّ وَعْدَ اللّٰهِ حَقٌّ وَ لٰكِنَّ اَكْثَرَهُمْ لاٰ يَعْلَمُونَ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ القصص ۱۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « وَ قٰالَ الْمَلِكُ اِئْتُونِي بِهِ اَسْتَخْلِصْهُ لِنَفْسِي فَلَمّٰا كَلَّمَهُ قٰالَ اِنَّكَ الْيَوْمَ لَدَيْنٰا مَكِينٌ اَمِينٌ » </quranic_text>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<footnote> [ يوسف ۵۴ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"-  <quranic_text> « اِنِّي تَوَكَّلْتُ عَلَي اللّٰهِ رَبِّي وَ رَبِّكُمْ مٰا مِنْ دَابَّةٍ اِلاّٰ هُوَ اخِذٌ بِنٰاصِيَتِهٰا اِنَّ رَبِّي عَليٰ صِرٰاطٍ مُسْتَقِيمٍ » </quranic_text>   <footnote> [ هود ۵۶ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".","translation_segment":"","segment_columns":[]}]}