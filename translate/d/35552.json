 کٰانوا» یعنی نمیباشد و واقع نمیشود از راز گفتن سه کس مگر آنکه خدا چهارم ایشان است و نه راز گفتن پنج کس مگر آنکه او ششم ایشان است و نه پست‌تر و کمتر از این که دو باشد یا چهار و نه بیشتر از این که از شش است تا آنچه نهایت ندارد مگر آنکه او با ایشان است در هر جا که باشند از اقطار آسمانها و نواحی زمین یعنی علم آن جناب رفیق آنها است و محیط‍‌ و مطلع بر ایشان نه باعتبار ذات مقدس و او است اول که پیش از او چیزی نیست و آنکه بعد از او چیزی نه و اوست که قدیم است و آنچه غیر او است محدث و موجود است که خدا آن را پدید آورده و مخلوقی که آفریده شده و او برتر است از صفات آفریدگان برتری بزرگ","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"نجوي","display":"نَجْويٰ"},{"kind":"word","token":"ثلاثه","display":"ثَلاٰثَةٍ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"رابعهم","display":"رٰابِعُهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"خمسه","display":"خَمْسَةٍ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"سادسهم","display":"سٰادِسُهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"ادني","display":"اَدْنيٰ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"اكثر","display":"اَكْثَرَ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"معهم","display":"مَعَهُمْ"},{"kind":"word","token":"اين","display":"اَيْنَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind"