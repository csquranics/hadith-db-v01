{"consensus_set_id":"s301128","translation_language":"fa","translation_source":{"hid":"301128"},"segments":[{"source_hadith_segment":"<quranic_text> « اِنَّ اللّٰهَ يَاْمُرُكُمْ اَنْ تُؤَدُّوا الْاَمٰانٰاتِ اِليٰ اَهْلِهٰا وَ اِذٰا حَكَمْتُمْ بَيْنَ النّٰاسِ اَنْ تَحْكُمُوا بِالْعَدْلِ » </quranic_text>   <footnote> [ النساء ۵۸ ] </footnote>  فِيمَنْ نَزَلَتْ قُلْتُ يَقُولُونَ فِي النَّاسِ قَالَ اَ فَكُلُّ النَّاسِ يَحْكُمُ بَيْنَ النَّاسِ اِعْقِلْ فِيمَنْ نَزَلَتْ .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"يامركم","display":"يَاْمُرُكُمْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تؤدوا","display":"تُؤَدُّوا"},{"kind":"word","token":"الامانات","display":"الْاَمٰانٰاتِ"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"اهلها","display":"اَهْلِهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"حكمتم","display":"حَكَمْتُمْ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تحكموا","display":"تَحْكُمُوا"},{"kind":"word","token":"بالعدل","display":"بِالْعَدْلِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۵۸","display":"۵۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فيمن","display":"فِيمَنْ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ا","d