{"consensus_set_id":"20666","translation_language":"fa","translation_source":{"hid":"101254"},"segments":[{"source_hadith_segment":"وَ « اَقِيمُوا الشَّهَادَةَ عَلَي الْوَالِدَيْنِ وَ الْوَلَدِ وَ لاَ تُقِيمُوهَا عَلَي الْاَخِ فِي الدِّيْنِ الضَّيْرَ »","translation_segment":"داود بن حصین گوید: از امام صادق علیه السلام شنیدم که فرمود: شهادت دهید در مورد پدر و مادر و فرزند، ولی","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اقيموا","display":"اَقِيمُوا"},{"kind":"word","token":"الشهاده","display":"الشَّهَادَةَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الوالدين","display":"الْوَالِدَيْنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الولد","display":"الْوَلَدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تقيموها","display":"تُقِيمُوهَا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الاخ","display":"الْاَخِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الدين","display":"الدِّيْنِ"},{"kind":"word","token":"الضير","display":"الضَّيْرَ"}]},{"source_hadith_segment":"قُلْتُ وَ مَا الضَّيْرُ قَالَ « اِذَا تَعَدَّي فِيهِ صَاحِبُ الْحَقِّ الَّذِي يَدَّعِيهِ قِبَلَهُ خِلاَفَ مَا اَمَرَ اللَّهُ عَزَّ وَ جَلَّ وَ رَسُولُهُ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ مَثَلُ ذَلِكَ اَنْ يَكُونَ لِرَجُلٍ عَلَي اخَرَ دَيْنٌ وَ هُوَ مُعْسِرٌ وَ قَدْ اَمَرَ اللَّهُ تَعَالَي بِاِنْظَارِهِ حَتَّي يَيْسَرَ فَقَالَ  <quranic_text> « فَنَظِرَةٌ اِليٰ مَيْسَرَةٍ » </quranic_text>   <footnote> [ البقرة ۲۸۰ ] </footnote> وَ يَسْاَلُكَ اَنْ تُقِيمَ الشَّهَادَةَ وَ اَنْتَ تَعْرِفُهُ بِالْعُسْرِ فَلاَ يَحِلُّ لَكَ اَنْ تُقِيمَ الشَّهَادَةَ فِي حَالِ الْعُسْرِ »","translation_segment":"در باره برادر علیله برادر هنگامی که یکی از آن دو در بدهی ضیر است، شهادت ندهید. پرسیدم: «ضیر» چیست‌؟ فرمود: هر گاه شخصی از دیگری طلبکار باشد اما بدهکار، معسر ( ندار) باشد، در این صورت خداوند فرموده باید طلبکار صبر کند تا بدهکار توانائی پرداخت مال را پیدا کند و فرمود: «و إن‌ کٰان‌ ذو عسره‌ فنظره‌ إلیٰ‌ میسره‌» (بقره - آیه ۲۸۰) و طلبکار از تو می‌خواهد که برای","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"الضير","display":"الضَّيْرُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"تعدي","display":"تَعَدَّي"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"صاحب","display":"صَاحِبُ"},{"kind":"word","token":"الحق","display":"الْحَقِّ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يدعيه","display":"يَدَّعِيهِ"},{"kind":"word","token":"قبله","display":"قِبَلَهُ"},{"kind":"word","token":"خلاف","display":"خِلاَفَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"امر","display":"اَمَرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رسوله","display":"رَسُولُهُ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مثل","display":"مَثَلُ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يكون","display":"يَكُونَ"},{"kind":"word","token":"لرجل","display":"لِرَجُلٍ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اخر","display":"اخَرَ"},{"kind":"word","token":"دين","display":"دَيْنٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","disp