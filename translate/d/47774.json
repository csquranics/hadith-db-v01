{"consensus_set_id":"47774","translation_language":"fa","translation_source":{"hid":"305958"},"segments":[{"source_hadith_segment":"اِنَّ لِكُلٍّ كَلَباً يَبْغِي الشَّرَّ فَاجْتَنِبُوهُ يَكْفِكُمُ اللَّهُ قَوْماً فَاجْتَنِبُوا بِغَيْرِكُمْ اِنَّ اللَّهَ يَقُولُ :   <quranic_text> « وَ اللّٰهُ اَشَدُّ بَاْساً وَ اَشَدُّ تَنْكِيلاً » </quranic_text>   <footnote> [ النساء ۸۴ ] </footnote>  لاَ تُعْلِمُوا بِالشَّرِّ .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"لكل","display":"لِكُلٍّ"},{"kind":"word","token":"كلبا","display":"كَلَباً"},{"kind":"word","token":"يبغي","display":"يَبْغِي"},{"kind":"word","token":"الشر","display":"الشَّرَّ"},{"kind":"word","token":"فاجتنبوه","display":"فَاجْتَنِبُوهُ"},{"kind":"word","token":"يكفكم","display":"يَكْفِكُمُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"قوما","display":"قَوْماً"},{"kind":"word","token":"فاجتنبوا","display":"فَاجْتَنِبُوا"},{"kind":"word","token":"بغيركم","display":"بِغَيْرِكُمْ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"اشد","display":"اَشَدُّ"},{"kind":"word","token":"باسا","display":"بَاْساً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اشد","display":"اَشَدُّ"},{"kind":"word","token":"تنكيلا","display":"تَنْكِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۸۴","display":"۸۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تعلموا","display":"تُعْلِمُوا"},{"kind":"word","token":"بالشر","display":"بِالشَّرِّ"}]}]}