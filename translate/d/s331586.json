{"consensus_set_id":"s331586","translation_language":"fa","translation_source":{"hid":"331586"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي ]  <quranic_text> « وَ اِتَّقُوا فِتْنَةً - لاٰ تُصِيبَنَّ الَّذِينَ ظَلَمُوا مِنْكُمْ خَاصَّةً » </quranic_text>   <footnote> [ الانفال ۲۵ ] </footnote>","translation_segment":"عن السدی فی قوله تعالی (و اتقوا فتنه لا تصیبن‌ الذین ظلموا منکم خاصه) قال: هم أهل الجمل. سدی درباره آیه: «و اتقوا فتنه لا تصیبن الذین","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"فتنه","display":"فِتْنَةً"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تصيبن","display":"تُصِيبَنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"ظلموا","display":"ظَلَمُوا"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"خاصه","display":"خَاصَّةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۲۵","display":"۲۵"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ :  هُمْ اَهْلُ الْجَمَلِ .","translation_segment":"ظلموا منکم خاصه» گفت: آنان اهل جمل هستند.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"الجمل","display":"الْجَمَلِ"}]}]}