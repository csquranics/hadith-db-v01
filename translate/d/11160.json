{"consensus_set_id":"11160","translation_language":"fa","translation_source":{"hid":"104893"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ اَ كَانَ عِيسَي اِبْنُ مَرْيَمَ عَلَيْهِ السَّلاَمُ حِينَ تَكَلَّمَ فِي الْمَهْدِ حُجَّةَ اللَّهِ","translation_segment":"یزید کناسی گوید: از امام باقر ع پرسیدم که آیا عیسی بن مریم زمانی که در گهواره سخن گفت، حجت خدا بود بر اهل","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"عيسي","display":"عِيسَي"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"مريم","display":"مَرْيَمَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"تكلم","display":"تَكَلَّمَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"المهد","display":"الْمَهْدِ"},{"kind":"word","token":"حجه","display":"حُجَّةَ"},{"kind":"word","token":"الله","display":"اللَّهِ"}]},{"source_hadith_segment":"عَلَي اَهْلِ زَمَانِهِ فَقَالَ كَانَ يَوْمَئِذٍ نَبِيّاً حُجَّةَ اللَّهِ غَيْرَ مُرْسَلٍ اَ مَا تَسْمَعُ لِقَوْلِهِ حِينَ قَالَ  <quranic_text> « اِنِّي عَبْدُ اللّٰهِ اتٰانِيَ الْكِتٰابَ وَ جَعَلَنِي نَبِيًّا .  وَ جَعَلَنِي مُبٰارَكاً اَيْنَ مٰا كُنْتُ وَ اَوْصٰانِي بِالصَّلاٰةِ وَ الزَّكٰاةِ مٰا دُمْتُ حَيًّا » </quranic_text>   <footnote> [ مريم ۳۰ ] </footnote>  قُلْتُ","translation_segment":"زمانش‌؟ فرمود: او آن زمان پیغمبر و حجت غیر مرسل خدا بود (یعنی در آن زمان مأمور بتبلیغ و دعوت نبود) مگر نمیشنوی گفته خود او را که میگوید «من بنده خدایم (تا مردم نگویند عیسی خداست) خدا بمن کتاب دا