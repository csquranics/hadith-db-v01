{"consensus_set_id":"s254157","translation_language":"fa","translation_source":{"hid":"254157"},"segments":[{"source_hadith_segment":"اِذَا تَمَّتِ النُّطْفَةُ اَرْبَعَةَ اَشْهُرٍ بُعِثَ اِلَيْهَا مَلَكٌ فَنَفَخَ فِيهَا الرُّوحَ فِي الظُّلُمَاتِ الثَّلاَثِ فَذَلِكَ قَوْلُهُ :   <quranic_text> « ثُمَّ اَنْشَاْنٰاهُ خَلْقاً اخَرَ » </quranic_text>   <footnote> [ المؤمنون ۱۴ ] </footnote>  يَعْنِي نَفَخَ الرُّوحَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"تمت","display":"تَمَّتِ"},{"kind":"word","token":"النطفه","display":"النُّطْفَةُ"},{"kind":"word","token":"اربعه","display":"اَرْبَعَةَ"},{"kind":"word","token":"اشهر","display":"اَشْهُرٍ"},{"kind":"word","token":"بعث","display":"بُعِثَ"},{"kind":"word","token":"اليها","display":"اِلَيْهَا"},{"kind":"word","token":"ملك","display":"مَلَكٌ"},{"kind":"word","token":"فنفخ","display":"فَنَفَخَ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"الروح","display":"الرُّوحَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الظلمات","display":"الظُّلُمَاتِ"},{"kind":"word","token":"الثلاث","display":"الثَّلاَثِ"},{"kind":"word","token":"فذلك","display":"فَذَلِكَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"انشاناه","display":"اَنْشَاْنٰاهُ"},{"kind":"word","token":"خلقا","display":"خَلْقاً"},{"kind":"word","token":"اخر","display":"اخَرَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"kind":"word","token":"۱۴","display":"۱۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"نفخ","display":"نَفَخَ"},{"kind":"word","token":"الروح","display":"الرُّوحَ"}]}]}