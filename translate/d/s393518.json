{"consensus_set_id":"s393518","translation_language":"fa","translation_source":{"hid":"393518"},"segments":[{"source_hadith_segment":"سَاَلَ اَلْمَاْمُونُ اَبَا الْحَسَنِ عَلِيَّ بْنَ مُوسَي الرِّضَا عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ جَلَّ ثَنَاؤُهُ :   <quranic_text> « وَ لَوْ شٰاءَ رَبُّكَ لَامَنَ مَنْ فِي الْاَرْضِ كُلُّهُمْ جَمِيعاً اَ فَاَنْتَ تُكْرِهُ النّٰاسَ حَتّٰي يَكُونُوا مُؤْمِنِينَ وَ مٰا كٰانَ لِنَفْسٍ اَنْ تُؤْمِنَ اِلاّٰ بِاِذْنِ اللّٰهِ » </quranic_text>   <footnote> [ يونس ۹۹ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"المامون","display":"اَلْمَاْمُونُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"علي","display":"عَلِيَّ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"ثناؤه","display":"ثَنَاؤُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"شاء","display":"شٰاءَ"},{"kind":"word","token":"ربك","display":"رَبُّكَ"},{"kind":"word","token":"لامن","display":"لَامَنَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"كلهم","display":"كُلُّهُمْ"},{"kind":"word","token":"جميعا","display":"جَمِيعاً"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فانت","display":"فَاَنْتَ"},{"kind":"word","token":"تكره","display":"