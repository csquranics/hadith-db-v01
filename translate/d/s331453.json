{"consensus_set_id":"s331453","translation_language":"fa","translation_source":{"hid":"331453"},"segments":[{"source_hadith_segment":"اِنَّ اَوَّلَ مَنْ شَرَي  <quranic_text> « نَفْسَهُ اِبْتِغٰاءَ مَرْضٰاتِ اللّٰهِ » </quranic_text>   <footnote> [ البقرة ۲۰۷ ] </footnote>  عَلِيُّ بْنُ اَبِي طَالِبٍ  .","translation_segment":"عن علی‌ بن الحسین قال: إن أول من شری نفسه ابتغاء مرضاه الله علی‌ بن ابی طالب. علی‌ بن الحسین گفت: نخستین کسی که جان خود را در برابر خوشنودی‌های خداوند فروخت، علی‌ بن ابی طالب بود.","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اول","display":"اَوَّلَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"شري","display":"شَرَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"نفسه","display":"نَفْسَهُ"},{"kind":"word","token":"ابتغاء","display":"اِبْتِغٰاءَ"},{"kind":"word","token":"مرضات","display":"مَرْضٰاتِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۰۷","display":"۲۰۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"}]}]}