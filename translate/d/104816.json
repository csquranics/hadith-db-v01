{"consensus_set_id":"104816","translation_language":"fa","translation_source":{"hid":"374002"},"segments":[{"source_hadith_segment":"مَنْ كَانَ نَقْشُ خَاتَمِهِ  <quranic_text> « مٰا شٰاءَ اللّٰهُ لاٰ قُوَّةَ اِلاّٰ بِاللّٰهِ » </quranic_text>   <footnote> [ الكهف ۳۹ ] </footnote>  اَسْتَغْفِرُ اللَّهَ فَذَكَرَ فِي ذَلِكَ ثَوَاباً عَظِيماً .","translation_segment":"علی (علیه السلام) فرمود: هر کس نقش انگشترش باشد: «ما شاء اللٰه لا قوه الا باللٰه استغفر اللٰه». در آن ثوابی بس بزرگ خواهد بود.","segment_columns":[{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"نقش","display":"نَقْشُ"},{"kind":"word","token":"خاتمه","display":"خَاتَمِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"شاء","display":"شٰاءَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"قوه","display":"قُوَّةَ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","token":"۳۹","display":"۳۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"استغفر","display":"اَسْتَغْفِرُ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"فذكر","display":"فَذَكَرَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"ثوابا","display":"ثَوَاباً"},{"kind":"word","token":"عظيما","display":"عَظِيماً"}]}]}