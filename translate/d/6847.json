ُمَّ قَالَ لَهُمْ :  اِنِّي اَنَا اللَّهُ لاَ اِلَهَ اِلاَّ اَنَا ،  وَ اَنَا الرَّحْمَنُ الرَّحِيمُ ،  فَاَقَرُّوا لَهُ بِالطَّاعَةِ وَ الرُّبُوبِيَّةِ وَ مَيَّزَ الرُّسُلَ وَ الْاَنْبِيَاءَ وَ الْاَوْصِيَاءَ وَ اَمَرَ الْخَلْقَ بِطَاعَتِهِمْ ،  فَاَقَرُّوا بِذَلِكَ فِي الْمِيثَاقِ [ وَ اَشْهَدَهُمْ عَلَي اَنْفُسِهِمْ ] ،  وَ اَشْهَدَ الْمَلاَئِكَةَ عَلَيْهِمْ اَنْ يَقُولُوا يَوْمَ الْقِيَامَةِ :   <quranic_text> « اِنّٰا كُنّٰا عَنْ هٰذٰا غٰافِلِينَ » </quranic_text>   <footnote> [ الاعراف ۱۷۲ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فثقل","display":"فَثَقُلَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ابن","display":"اِبْنِ"},{"kind":"word","token":"الكواء","display":"الْكَوَّاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يعرفه","display":"يَعْرِفْهُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"تقرا","display":"تَقْرَاُ"},{"kind":"word","token":"كتاب","display":"كِتَابَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"لنبيه","display":"لِنَبِيِّهِ"},{"k