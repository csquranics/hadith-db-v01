{"consensus_set_id":"29648","translation_language":"fa","translation_source":{"hid":"100205"},"segments":[{"source_hadith_segment":"عَنِ اَلذَّبِيحِ مَنْ كَانَ فَقَالَ «  اِسْمَاعِيلُ عَلَيْهِ السَّلاَمُ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ ذَكَرَ قِصَّتَهُ فِي كِتَابِهِ ثُمَّ قَالَ  <quranic_text> « وَ بَشَّرْنٰاهُ بِاِسْحٰاقَ نَبِيًّا مِنَ الصّٰالِحِينَ » </quranic_text>   <footnote> [ الصافات ۱۱۲ ] </footnote>   .","translation_segment":"و امام صادق علیه السلام را پرسیدند که: ذبیح چه کسی بود؟ فرمود: اسماعیل علیه السلام بود زیرا خداوند نخست داستان او را در کتاب خود ذکر کرده است، و سپس گفته است: «و ما ابراهیم را بوجود اسحاق بعنوان پیمبری از صالحین بشارت دادیم».","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سئل","display":"سئل"},{"kind":"word","token":"الصادق","display":"الصّادق"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عن"},{"kind":"word","token":"الذبيح","display":"الذبيح"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"كان","display":"كان"},{"kind":"word","token":"فقال","display":"فقال"},{"kind":"word","token":"اسماعيل","display":"اسماعيل"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"لان","display":"لانّ"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تعالي","display":"تعالي"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الذبيح","display":"اَلذَّبِيحِ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"اسماعيل","display":"اِسْمَاعِيلُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word