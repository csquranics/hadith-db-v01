{"consensus_set_id":"1116","translation_language":"fa","translation_source":{"hid":"91318"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ","translation_segment":"* *۸ - به ابو عبد الله صادق (ع) گفتم: یک نفر از","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"}]},{"source_hadith_segment":"السَّلاَمُ الرَّجُلُ مِنَّا يَكُونُ عِنْدَهُ الشَّيْءُ يَتَبَلَّغُ بِهِ وَ عَلَيْهِ دَيْنٌ","translation_segment":"شیعیان ما وامدار است و موجودی ناچیزی دارد که از آن مخارج روزمره خود را می‌گذراند. آیا موجودی خود را به مصرف","segment_columns":[{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"منا","display":"مِنَّا"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"الشيء","display":"الشَّيْءُ"},{"kind":"word","token":"يتبلغ","display":"يَتَبَلَّغُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"دين","display":"دَيْنٌ"},{"kind":"word","token":"-","display":"-"}]},{"source_hadith_segment":"اَ يُطْعِمُهُ عِيَالَهُ حَتَّي يَاْتِيَ اللَّهُ عَزَّ وَ جَلَّ بِيُسْرِهِ","translation_segment":"قوت خاندانش برساند و منتظر بماند تا آن روز که خداوند عز و جل به او وسعت بدهد و قرض خود","segment_columns":[{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"يطعمه","display":"يُطْعِمُهُ"},{"kind":"word","token":"عياله","display":"عِيَالَهُ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"ياتي","display":"يَاْتِيَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"بيسره","display":"بِيُسْرِهِ"},{"kind":"word","token":"او","display":"اَوْ"}]},{"source_hadith_segment":"فَيَقْضِيَ دَيْنَهُ اَوْ يَسْتَقْرِضُ عَلَي ظَهْرِهِ فِي خُبْثِ الزَّمَانِ وَ شِدَّةِ الْمَكَاسِبِ","translation_segment":"را ادا کند؟ یا اینکه قرض خود را از همین موجودی حاضر ادا کند و برای تأمین مخارج زندگی مجددا از شخص دیگری قرض بگیرد با","segment_columns":[{"kind":"word","token":"فيقضي","display":"فَيَقْضِيَ"},{"kind":"word","token":"دينه","display":"دَيْنَهُ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"يستقرض","display":"يَسْتَقْرِضُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ظهره","display":"ظَهْرِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"خبث","display":"خُبْثِ"},{"kind":"word","token":"الزمان","display":"الزَّمَانِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شده","display":"شِدَّةِ"},{"kind":"word","token":"المكاسب","display":"الْمَكَاسِبِ"}]},{"source_hadith_segment":"اَوْ يَقْبَلُ الصَّدَقَةَ قَالَ « يَقْضِي بِمَا عِنْدَهُ دَيْنَهُ وَ لاَ يَاْكُلْ اَمْوَالَ النَّاسِ اِلاَّ وَ عِنْدَهُ مَا يُؤَدِّي اِلَيْهِمْ حُقُوقَهُمْ اِنَّ اللَّهَ تَعَالَي يَقُولُ  <quranic_text> « لاٰ تَاْكُلُوا اَمْوٰالَكُمْ بَيْنَكُمْ بِالْبٰاطِلِ اِلاّٰ اَنْ تَكُونَ تِجٰارَةً عَنْ تَرٰاضٍ مِنْكُمْ » </quranic_text>   <footnote> [ النساء ۲۹ ] </footnote>  وَ لاَ يَسْتَقْرِضْ عَلَي ظَهْرِهِ اِلاَّ وَ عِنْدَهُ وَفَاءٌ وَ لَوْ طَافَ عَلَي اَبْوَابِ النَّاسِ فَرَدُّوهُ بِاللُّقْمَةِ وَ اللُّقْمَتَيْنِ وَ التَّمْرَةِ وَ التَّمْرَتَيْنِ اِلاَّ اَنْ يَكُونَ لَهُ وَلِيٌّ يَقْضِي مِنْ بَعْدِهِ وَ لَيْسَ مِنَّا مِنْ مَيِّتٍ يَمُوتُ اِلاَّ جَعَلَ اللَّهُ عَزَّ وَ جَلَّ لَهُ وَلِيّاً يَقُومُ فِي عِدَتِهِ وَ دَيْنِهِ فَيَقْضِي عِدَتَهُ وَ دَيْنَهُ »","translation_segment":"آنکه چهره زمانه سخت پلید است و کار و کاسبی دشوار، بی‌آنکه امیدی به آینده نزدیک موجود باشد؟ یا نه. (Ẓقرض خود را بپردازد و برای تأمین هزینه زندگی زکات بگیرد؟ ابو عبد الله گفت: باید با موجودی حاضرش قرض خود را بپردازد و مال مردم را هزینه زندگی نسازد، مگر موقعی که زمینه پرداخت آن را داشته باشد. خداوند عز و جل می‌گوید: «ای مومنان. اموال یکدیگر را با دستاویزهای باطل مخورید، مگر به صورت تجارت و با رضایت خاطر باشد». مومن نمی‌تواند وامی را برعهده خود بگیرد، مگر موقعی که وثیقه ادای آن را داشته باشد، گرچه مجبور شود بر در خانه‌ها به دریوزگی برود و او را با یک لقمه و دو لقمه یا یک دانه خرما و دو دانه خرما از در خانه خود برگردانند، جز در یک صورت که فرزندی رشید از خود بجا بگذارد که بعد از مرگ پدر قرض او را بپردازد. از خاندان ما هرکسی که بمیرد، خداوند عز و جل برای او جانشینی قرار می‌دهد که وعده‌های او را با وامهای او کارسازی نماید، و ازاین‌رو است که برخی از ما خاندان","segment_columns":[{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"يقبل","display":"يَقْبَلُ"},{"kind":"word","token":"الصدقه","display":"الصَّدَقَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقضي","display":"يَقْضِي"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"دينه","display":"دَيْنَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقبل","display":"يَقْبَلُ"},{"kind":"word","token":"الصدقه","display":"الصَّدَقَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يقضي","display":"يَقْضِي"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"دينه","display":"دَيْنَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقبل","display":"يَقْبَلُ"},{"kind":"word","token":"الصدقه","display":"الصَّدَقَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word