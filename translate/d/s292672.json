{"consensus_set_id":"s292672","translation_language":"fa","translation_source":{"hid":"292672"},"segments":[{"source_hadith_segment":"وَ جَاءَ فِي تَاْوِيلِ قَوْلِهِ تَعَالَي  <quranic_text> « قُلْ اِنَّمٰا حَرَّمَ رَبِّيَ الْفَوٰاحِشَ مٰا ظَهَرَ مِنْهٰا وَ مٰا بَطَنَ » </quranic_text>   <footnote> [ الاعراف ۳۳ ] </footnote>  الْحَسَدُ .","translation_segment":"و در تاویل گفته‌ی خدای تعالی چنین آمده «قل‌ إنمٰا حرم‌ ربی‌ الفوٰاحش‌ مٰا ظهر منهٰا و مٰا بطن‌» بگو ای پیامبر که پروردگار من حرام کرده بدیها را آنچه ظاهر باشد و آنچه پنهان. گفته شده که مراد از فواحش نهان حسد است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جاء","display":"جَاءَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تاويل","display":"تَاْوِيلِ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"حرم","display":"حَرَّمَ"},{"kind":"word","token":"ربي","display":"رَبِّيَ"},{"kind":"word","token":"الفواحش","display":"الْفَوٰاحِشَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ظهر","display":"ظَهَرَ"},{"kind":"word","token":"منها","display":"مِنْهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"بطن","display":"بَطَنَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۳۳","display":"۳۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الحسد","display":"الْحَسَدُ"}]}]}