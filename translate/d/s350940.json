{"consensus_set_id":"s350940","translation_language":"fa","translation_source":{"hid":"350940"},"segments":[{"source_hadith_segment":"مَا  <quranic_text> « اِتَّخَذَ اللّٰهُ اِبْرٰاهِيمَ خَلِيلاً » </quranic_text>   <footnote> [ النساء ۱۲۵ ] </footnote>  اِلاَّ لِاِطْعَامِهِ الطَّعَامَ وَ صَلَوَاتِهِ بِاللَّيْلِ وَ النَّاسُ نِيَامٌ .","translation_segment":"پیامبر صلی الله علیه و آله و سلم نیز فرموده‌اند: خداوند ابراهیم را خلیل نامید؛ زیرا بسیار دیگران را به غذا مهمان می‌کرد و هنگامی که همگان در خواب بودند به نماز می‌پرداخت.","segment_columns":[{"kind":"word","token":"ما","display":"مَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اتخذ","display":"اِتَّخَذَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"word","token":"خليلا","display":"خَلِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۵","display":"۱۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"لاطعامه","display":"لِاِطْعَامِهِ"},{"kind":"word","token":"الطعام","display":"الطَّعَامَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صلواته","display":"صَلَوَاتِهِ"},{"kind":"word","token":"بالليل","display":"بِاللَّيْلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"نيام","display":"نِيَامٌ"}]}]}