{"consensus_set_id":"37434","translation_language":"fa","translation_source":{"hid":"410048"},"segments":[{"source_hadith_segment":"« لاَ يَتَمَكَّنُ الشَّيْطَانُ بِالْوَسْوَسَةِ مِنَ الْعَبْدِ اِلاَّ وَ قَدْ اَعْرَضَ عَنْ ذِكْرِ اللَّهِ تَعَالَي ،  وَ اِسْتَهَانَ وَ سَكَنَ اِلَي نَهْيِهِ ،  وَ نَسِيَ اِطِّلاَعَهُ عَلَي سِرِّهِ ،  فَالْوَسْوَسَةُ مَا تَكُونُ مِنْ خَارِجِ الْقَلْبِ بِاِشَارَةِ مَعْرِفَةِ الْعَقْلِ وَ مُجَاوَرَةِ الطَّبْعِ ،  وَ اَمَّا اِذَا تَمَكَّنَ فِي الْقَلْبِ فَذَلِكَ غَيٌّ وَ ضَلاَلَةٌ وَ كُفْرٌ ،  وَ اللَّهُ عَزَّ وَ جَلَّ دَعَا عِبَادَهُ بِلُطْفِ دَعْوَتِهِ وَ عَرَّفَهُمْ عَدَاوَةَ اِبْلِيسَ ،  فَقَالَ تَعَالَي :   <quranic_text> « اِنَّ الشَّيْطٰانَ لَكُمْ عَدُوٌّ فَاتَّخِذُوهُ عَدُوًّا » </quranic_text>   <footnote> [ فاطر ۶ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يتمكن","display":"يَتَمَكَّنُ"},{"kind":"word","token":"الشيطان","display":"الشَّيْطَانُ"},{"kind":"word","token":"بالوسوسه","display":"بِالْوَسْوَسَةِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"العبد","display":"الْعَبْدِ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"اعرض","display":"اَعْرَضَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ذكر","display":"ذِكْرِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"استهان","display":"اِسْتَهَانَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سكن","display":"سَكَنَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"نهيه","display":"نَهْيِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نسي","display":"نَسِيَ"},{"kind":"word","token":"اطلاعه","display":"اِطِّلاَعَهُ"},{"kind":"word","token"