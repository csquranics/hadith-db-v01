{"consensus_set_id":"23210","translation_language":"fa","translation_source":{"hid":"94203"},"segments":[{"source_hadith_segment":"قُلْتُ لَهُ رَجُلٌ طَلَّقَ اِمْرَاَتَهُ طَلاَقاً لاَ تَحِلُّ لَهُ حَتَّي تَنْكِحَ زَوْجاً غَيْرَهُ","translation_segment":"* *۲۲ - به ابو عبد الله صادق (ع) گفتم: اگر شوهری از همسر خود با طلاق سوم جدا شود و شوهر دوم او را به ازدواج","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"طلق","display":"طَلَّقَ"},{"kind":"word","token":"امراته","display":"اِمْرَاَتَهُ"},{"kind":"word","token":"طلاقا","display":"طَلاَقاً"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تحل","display":"تَحِلُّ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"تنكح","display":"تَنْكِحَ"},{"kind":"word","token":"زوجا","display":"زَوْجاً"},{"kind":"word","token":"غيره","display":"غَيْرَهُ"}]},{"source_hadith_segment":"فَتَزَوَّجَهَا رَجُلٌ مُتْعَةً اَ تَحِلُّ لِلْاَوَّلِ قَالَ","translation_segment":"موقت خود درآورد، آیا برای شوهر اول حلال می‌شود؟ ابو عبد الله گفت: نه.","segment_columns":[{"kind":"word","token":"فتزوجها","display":"فَتَزَوَّجَهَا"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"متعه","display":"مُتْعَةً"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"تحل","display":"تَحِلُّ"},{"kind":"word","token":"للاول","display":"لِلْاَوَّلِ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« لاَ لِاَنَّ اللَّهَ تَعَالَي يَقُولُ  <quranic_text> « فَاِنْ طَلَّقَهٰا فَلاٰ تَحِلُّ لَهُ مِنْ بَعْدُ حَتّٰي تَنْكِحَ زَوْجاً غَيْرَهُ فَاِنْ طَلَّقَهٰا » </quranic_text>   <footnote> [ البقرة ۲۳۰ ] </footnote>  وَ الْمُتْعَةُ لَيْسَ فِيهَا طَلاَقٌ » .","translation_segment":"زیرا خداوند تعالی می‌گوید: «اگر شوهر اول، همسر خود را ب