{"consensus_set_id":"s397126","translation_language":"fa","translation_source":{"hid":"397126"},"segments":[{"source_hadith_segment":"« قَالَ :   <quranic_text> « اُرِيدُ اَنْ اُنْكِحَكَ اِحْدَي اِبْنَتَيَّ هٰاتَيْنِ عَليٰ اَنْ تَاْجُرَنِي ثَمٰانِيَ حِجَجٍ فَاِنْ اَتْمَمْتَ عَشْراً فَمِنْ عِنْدِكَ » </quranic_text>   <footnote> [ القصص ۲۷ ] </footnote> فَرُوِيَ :  اَنَّهُ قَضَي اَتَمَّهُمَا لِاَنَّ الْاَنْبِيَاءَ عَلَيْهِمُ السَّلاَمُ لاَ تَاْخُذُ اِلاَّ بِالْفَضْلِ وَ التَّمَامِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اريد","display":"اُرِيدُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"انكحك","display":"اُنْكِحَكَ"},{"kind":"word","token":"احدي","display":"اِحْدَي"},{"kind":"word","token":"ابنتي","display":"اِبْنَتَيَّ"},{"kind":"word","token":"هاتين","display":"هٰاتَيْنِ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تاجرني","display":"تَاْجُرَنِي"},{"kind":"word","token":"ثماني","display":"ثَمٰانِيَ"},{"kind":"word","token":"حجج","display":"حِجَجٍ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"اتممت","display":"اَتْمَمْتَ"},{"kind":"word","token":"عشرا","display":"عَشْراً"},{"kind":"word","token":"فمن","display":"فَمِنْ"},{"kind":"word","token":"عندك","display":"عِنْدِكَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۲۷","display":"۲۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فروي","display":"فَرُوِيَ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قضي","display":"قَضَي"},{"kind":"word","token":"اتمهما","display":"اَتَمَّهُمَا"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الانبياء","display":"الْاَنْبِيَاءَ"},{"kin