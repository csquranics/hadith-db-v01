{"consensus_set_id":"44912","translation_language":"fa","translation_source":{"hid":"338435"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ طَيْرٍ اَهْلِيٍّ اَقْبَلَ فَدَخَلَ الْحَرَمَ فَقَالَ لاَ يُمَسُّ اِنَّ اللَّهَ تَعَالَي يَقُولُ  <quranic_text> « وَ مَنْ دَخَلَهُ كٰانَ امِناً » </quranic_text>   <footnote> [ العمران ۹۷ ] </footnote>   .","translation_segment":"و با همین اسناد از حسین بن سعید، از فضاله و حماد از معاویه، وی گفت: از حضرت ابی عبد اللٰه علیه السلام پرسیدم: پرنده‌ای اهلی روی به حرم آورده و داخل آن گشت وظیفه ما نسبت به آن چیست‌؟ حضرت فرمودند: نباید آن را بگیرید زیرا خدای متعال فرموده: هر موجودی که داخل حرم شد در امان است.","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"طير","display":"طَيْرٍ"},{"kind":"word","token":"اهلي","display":"اَهْلِيٍّ"},{"kind":"word","token":"اقبل","display":"اَقْبَلَ"},{"kind":"word","token":"فدخل","display":"فَدَخَلَ"},{"kind":"word","token":"الحرم","display":"الْحَرَمَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يمس","display":"يُمَسُّ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"دخله","display":"دَخَلَهُ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"امنا","display":"امِناً"},{"kind":"tag_close","tag_name":"quranic