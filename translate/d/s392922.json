{"consensus_set_id":"s392922","translation_language":"fa","translation_source":{"hid":"392922"},"segments":[{"source_hadith_segment":"وَ اَبِي عَبْدِ اللَّهِ ( عَلَيْهِمَا السَّلاَمُ ) قَالَ :  سَاَلْتُهُمَا عَنْ قَوْلِهِ :   <quranic_text> « وَ الَّذِينَ امَنُوا وَ لَمْ يُهٰاجِرُوا مٰا لَكُمْ مِنْ وَلاٰيَتِهِمْ مِنْ شَيْءٍ حَتّٰي يُهٰاجِرُوا » </quranic_text>   <footnote> [ الانفال ۷۲ ] </footnote>   ؟  قَالَ :  اِنَّ اَهْلَ مَكَّةَ لاَ يُوَلُّونَ اَهْلَ الْمَدِينَةِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سالتهما","display":"سَاَلْتُهُمَا"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يهاجروا","display":"يُهٰاجِرُوا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ولايتهم","display":"وَلاٰيَتِهِمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"يهاجروا","display":"يُهٰاجِرُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۷۲","display":"۷۲"},{"kind":"tag_close","tag_name":"footnot