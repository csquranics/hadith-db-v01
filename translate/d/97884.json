{"consensus_set_id":"97884","translation_language":"fa","translation_source":{"hid":"297523"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ ( تَعَالَي )  <quranic_text> « وَ اَسْبَغَ عَلَيْكُمْ نِعَمَهُ ظٰاهِرَةً وَ بٰاطِنَةً » </quranic_text>   <footnote> [ لقمان ۲۰ ] </footnote>   .  قَالَ :  الظَّاهِرَةُ الْاِسْلاَمُ ،  وَ الْبَاطِنَةُ سَتْرُ الذُّنُوبِ .","translation_segment":"از ابن عباس روایت شده که درباره این آیه: «و نعمت‌هایش را بر شما ارزانی داشت نمایان و نهان» [لقمان: آیه ۲۰] گفت: نمایان، اسلام است و نهان، پوشیدن گناهان.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسبغ","display":"اَسْبَغَ"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"نعمه","display":"نِعَمَهُ"},{"kind":"word","token":"ظاهره","display":"ظٰاهِرَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"باطنه","display":"بٰاطِنَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"لقمان","display":"لقمان"},{"kind":"word","token":"۲۰","display":"۲۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الظاهره","display":"الظَّاهِرَةُ"},{"kind":"word","token":"الاسلام","display":"الْاِسْلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الباطنه","display":"الْبَاطِنَةُ"},{"kind":"word","token":"ستر","display":"سَتْرُ"},{"kind":"word","token":"الذنوب","display":"الذُّنُوبِ"}]}]}