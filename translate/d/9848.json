{"consensus_set_id":"9848","translation_language":"fa","translation_source":{"hid":"119031"},"segments":[{"source_hadith_segment":"لَيْسَ مِنْ بَاطِلٍ يَقُومُ بِاِزَاءِ الْحَقِّ اِلاَّ غَلَبَ الْحَقُّ الْبَاطِلَ وَ ذَلِكَ قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « بَلْ نَقْذِفُ بِالْحَقِّ عَلَي الْبٰاطِلِ فَيَدْمَغُهُ فَاِذٰا هُوَ زٰاهِقٌ » </quranic_text>   <footnote> [ الانبياء ۱۸ ] </footnote>   .","translation_segment":"یونس بن عبد الرحمن در حدیث مرفوعی از امام صادق علیه السلام روایت کرده که فرمود: هیچ باطلی نیست که در برابر حق بایستد مگر آنکه حق بر باطل چیرگی یابد و دلیل آن این گفتار پروردگار است که: «بل‌ نقذف‌ بالحق‌ علی البٰاطل‌ فیدمغه‌ فإذٰا هو زٰاهق‌».","segment_columns":[{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"باطل","display":"بَاطِلٍ"},{"kind":"word","token":"يقوم","display":"يَقُومُ"},{"kind":"word","token":"بازاء","display":"بِاِزَاءِ"},{"kind":"word","token":"الحق","display":"الْحَقِّ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"غلب","display":"غَلَبَ"},{"kind":"word","token":"الحق","display":"الْحَقُّ"},{"kind":"word","token":"الباطل","display":"الْبَاطِلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بل","display":"بَلْ"},{"kind":"word","token":"نقذف","display":"نَقْذِفُ"},{"kind":"word","token":"بالحق","display":"بِالْحَقِّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الباطل","display":"الْبٰاطِلِ"},{"kind":"word","token":"فيدمغه","display":"فَيَدْمَغُهُ"},{"kind":"word","token":"فاذا","display":"فَاِذٰا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"زاهق","display":"زٰاهِقٌ"},{"kind":"