{"consensus_set_id":"50892","translation_language":"fa","translation_source":{"hid":"404218"},"segments":[{"source_hadith_segment":"« نَزَلَتْ هَذِهِ الْايَةُ عَلَي مُحَمَّدٍ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) هَكَذَا :  يَا اَيُّهَا الَّذِينَ اُوتُوا الْكِتَابَ امِنُوا بِمَا اُنْزِلَتْ فِي عَلِيٍّ مُصَدِّقاً لِمَا مَعَكُمْ مِنْ قَبْلِ اَنْ نَطْمِسَ وُجُوهاً فَنَرُدَّهَا عَلَي اَدْبَارِهَا اَوْ نَلْعَنَهُمْ ،  اِلَي قَوْلِهِ :  مَفْعُولاً .  وَ اَمَّا قَوْلُهُ :   <quranic_text> « مُصَدِّقاً لِمٰا مَعَكُمْ » </quranic_text>   <footnote> [ النساء ۴۷ ] </footnote> يَعْنِي مُصَدِّقاً بِرَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  »","translation_segment":"","segment_columns":[{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"هكذا","display":"هَكَذَا"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اوتوا","display":"اُوتُوا"},{"kind":"word","token":"الكتاب","display":"الْكِتَابَ"},{"kind":"word","token":"امنوا","display":"امِنُوا"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"انزلت","display":"اُنْزِلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"مصدقا","display":"مُصَدِّقاً"},{"kind":"word","token":"لما","display":"لِمَا"},{"kind":"word","token":"معكم","display":"مَعَكُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبل","display":"قَبْلِ"}