{"consensus_set_id":"14699","translation_language":"fa","translation_source":{"hid":"371759"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ -  <quranic_text> « اِلاَّ الْمُسْتَضْعَفِينَ مِنَ الرِّجٰالِ وَ النِّسٰاءِ وَ الْوِلْدٰانِ » </quranic_text>   <footnote> [ النساء ۹۸ ] </footnote>  الْايَةَ قَالَ يَا سُلَيْمَانُ فِي هَؤُلاَءِ الْمُسْتَضْعَفِينَ مَنْ هُوَ","translation_segment":"سلیمان بن خالد گوید: از امام صادق علیه السلام پرسیدم، تفسیر این فرموده خدای عز و جل‌ «إلا المستضعفین‌ من‌ الرجٰال‌ و النسٰاء و الولدٰان‌» -تا آخر آیه» (نسا-۹۸) چیست‌؟ فرمود: ای سلیمان در میان آن مستضعفان افرادی هستند که قوی‌تر از تو می‌باشند، آنان گروهی هستند","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"المستضعفين","display":"الْمُسْتَضْعَفِينَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الرجال","display":"الرِّجٰالِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النساء","display":"النِّسٰاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الولدان","display":"الْوِلْدٰانِ"},{"kind":"tag_close","tag_name"