ِرٌ اِلَي عَلِيِّ بْنِ الْحُسَيْنِ ( عَلَيْهِمَا السَّلاَمُ ) وَ لَيْسَ يُغْنِي فِيهِ مِنْ قَوْلٍ يَسْتَمِيلُهُ مِنَ الْجَهْدِ وَ التَّعَبِ اِلَي الْقَصْدِ ،  قَالَ لَهُ :  يَا اِبْنَ رَسُولِ اللَّهِ  ،  الْبُقْيَا عَلَي نَفْسِكَ","translation_segment":"خداوند گناهان پیشین و پسین جدم رسول خدا صلی الله علیه و اله را آمرزیده ولی ایشان کوشش را ترک نکرد و-پدر و مادرم به فدایش-چنان عبادت کرد که ساق‌هایش آماسید و پاهایش ورم کرد. به ایشان گفتند: درحالی که خداوند گناه پیشین و پسین تو را آمرزیده چنین می‌کنید؟! فرمودند: آیا نباید بنده‌ای سپاسگزار باشم. وقتی جابر به حضرت سجاد علیه السلام نگریست دیگر سخنی برای گفتن نداشت که ایشان را از کوشش و خستگی به میانه‌روی برگرداند، پس گفت: ای پسر رسول خدا خودتان را حفظ‍‌ کنید؛ زیرا شما از خانواده‌ای هستید که به سبب ایشان بلا برطرف و سختی برداشته می‌شود و به سبب","segment_columns":[]},{"source_hadith_segment":"،  فَاِنَّكَ لَمِنْ اُسْرَةٍ بِهِمْ يُسْتَدْفَعُ الْبَلاَءُ ،  وَ تُسْتَكْشَفُ اللَّاْوَاءُ ،  وَ بِهِمْ تُسْتَمْطَرُ السَّمَاءُ .  فَقَالَ :","translation_segment":"ایشان است که آسمان می‌بارد. حضرت فرمود: ای جابر من پیوسته به روش دو پدرم -درود خداوند بر آن دو باد-هستم","segment_columns":[]},{"source_hadith_segment":"يَا جَابِرُ ،  لاَ اَزَالُ عَلَي مِنْهَاجِ اَبَوَيَّ مُؤْتَسِياً بِهِمَا ( صَلَوَاتُ اللَّهِ عَلَيْهِمَا ) حَتَّي اَلْقَاهُمَا ،  فَاَقْبَلَ","translation_segment":"و از ایشان دنباله‌روی می‌کنم تا به دیدارشان بروم. در این هنگام جابر به کسانی که در آن‌جا حاضر بودند","segment_columns":[]},{"source_hadith_segment":"جَابِرٌ عَلَي مَنْ حَضَرَ فَقَالَ لَهُمْ :  وَ اللَّهِ مَا اَرَي فِي اَوْلاَدِ الْاَنْبِيَاءِ مِثْلَ عَلِيِّ بْنِ الْحُسَيْنِ اِلاَّ يُوسُفَ بْنَ","translation_segment":"رو کرد و گفت: به خدا سوگند در میان فرزندان پیامبران مانند حضرت سجاد علیه السلام جز یوسف بن یعقوب علیه السلام","segment_columns":[]},{"source_hadith_segment":"يَعْقُوبَ ( عَلَيْهِمَا السَّلاَمُ )  ،  وَ اللَّهِ لَذُرِّيَّةُ عَلِيِّ بْنِ الْحُسَيْنِ ( عَلَيْهِمَا السَّلاَمُ ) اَفْضَلُ مِنْ ذُرِّيَّةِ يُوسُفَ بْنِ يَعْقُوبَ","translation_segment":"را ندیده‌ام و به خدا سوگند فرزندان حضرت سجاد علیه السلام برتر از فرزندان یوسف بن یعقوب‌اند. همانا در میان ایشان کسی است","segment_columns":[]},{"source_hadith_segment":"،  اِنَّ مِنْهُمْ لَمَنْ يَمْلَاُ الْاَرْضَ عَدْلاً كَمَا مُلِئَتْ جَوْراً .","translation_segment":"که زمین را از عدل پر می‌کند چنان‌که از ستم پر شده است.","segment_columns":[]}]}