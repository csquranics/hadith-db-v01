{"consensus_set_id":"s366794","translation_language":"fa","translation_source":{"hid":"366794"},"segments":[{"source_hadith_segment":"سُئِلَ الرِّضَا عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ لِاِبْرَاهِيمَ صَلَوَاتُ اللَّهِ عَلَيْهِ  <quranic_text> « اَ وَ لَمْ تُؤْمِنْ قٰالَ بَليٰ وَ لٰكِنْ لِيَطْمَئِنَّ قَلْبِي » </quranic_text>   <footnote> [ البقرة ۲۶۰ ] </footnote>  اَ","translation_segment":"از امام رضا علیه السلام در باره قول خداوند متعال به حضرت ابراهیم (صلوات اللٰه علیه) سوال شد که فرمود: (آیا ایمان نیاورده‌ای گفت چرا ولی برای اطمینان قلبم می‌پرسم) آیا در قلب او شکی بود؟","segment_columns":[{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"لابراهيم","display":"لِاِبْرَاهِيمَ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تؤمن","display":"تُؤْمِنْ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"بلي","display":"بَليٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لٰكِنْ"},{"kind":"word","token":"ليطمئن","display":"لِيَطْمَئِنَّ"},{"kind":"word","token":"قلبي","display":"قَلْبِي"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۶۰","display":"۲۶۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ا","display":