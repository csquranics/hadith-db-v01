{"consensus_set_id":"104563","translation_language":"fa","translation_source":{"hid":"99319"},"segments":[{"source_hadith_segment":"« اَنَّ مَنْ قَرَاَ فِي الْوَتْرِ بِالْمُعَوِّذَتَيْنِ وَ  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>  قِيلَ لَهُ اَبْشِرْ يَا عَبْدَ اللَّهِ فَقَدْ قَبِلَ اللَّهُ وَتْرَكَ » .","translation_segment":"و نیز روایت کرده‌اند که هر کس در نماز وتر معوذتین (قل اعوذ برب‌ الفلق و قل اعوذ برب‌ الناس) و سوره توحید را بخواند، (فرشتگان) به او گویند: ای بنده خدا تو را بشارت باد که خداوند سبحان نماز وتر تو را قبول کرد.","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الوتر","display":"الْوَتْرِ"},{"kind":"word","token":"بالمعوذتين","display":"بِالْمُعَوِّذَتَيْنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاخلاص","display":"الاخلاص"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ابشر","display":"اَبْشِرْ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"عبد","display":"عَبْدَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فقد","display":"فَقَدْ"},{"kind":"word","token":"قبل","display":"قَبِلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"وترك","display":"وَتْرَكَ"}]}]}