{"consensus_set_id":"56811","translation_language":"fa","translation_source":{"hid":"90242"},"segments":[{"source_hadith_segment":"فِي اَلْمُحْرِمِ يَقَعُ عَلَي اَهْلِهِ قَالَ « يُفَرَّقُ بَيْنَهُمَا وَ لاَ يَجْتَمِعَانِ فِي خِبَاءٍ اِلاَّ اَنْ يَكُونَ مَعَهُمَا غَيْرُهُمَا  <quranic_text> « حَتّٰي يَبْلُغَ الْهَدْيُ مَحِلَّهُ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>   .","translation_segment":"* *۱۳ - از ابو عبد الله صادق (ع) پرسیدند: اگر کسی در حال احرام با همسر خود همبستر شود، چه صورت دارد؟ ابو عبد الله گفت: باید بین زن و شوهر جدایی بیندازند. آنان حق ندارند در یک اطاق و یا در یک چادر تنها بمانند، مگر آنکه شخص ثالثی با آنان باشد. این جدایی باید تا آخرین لحظه‌ای که قربانی به قربانگاه می‌رسد، ادامه یابد.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"المحرم","display":"اَلْمُحْرِمِ"},{"kind":"word","token":"يقع","display":"يَقَعُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اهله","display":"اَهْلِهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يفرق","display":"يُفَرَّقُ"},{"kind":"word","token":"بينهما","display":"بَيْنَهُمَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يجتمعان","display":"يَجْتَمِعَانِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"خباء","display":"خِبَاءٍ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يكون","display":"يَكُونَ"},{"kind":"word","token":"معهما","display":"مَعَهُمَا"},{"kind":"word","token":"غيرهما","display":"غَيْرُهُمَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حتي","display":"حَتّٰي"},{"kind":"word","token":"يبلغ","display":"يَبْلُغَ"},{"kind":"word","token":"الهدي","display":"الْهَدْيُ"},{"kind":"word","token":"محله","display":"مَحِلَّهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footno