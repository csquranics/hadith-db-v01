د و همان سرزمین احقاف و ماسه‌ها است. قوم عاد سرزمینی پربرکت داشتند. ولی خدا را نافرمانی کردند و به خشکسالی گرفتار شدند و پس آنگاه به وسیله بادی سهمگین و سرد به هلاکت درافتادند. هنگامی که باد سیاه در آسمان قوم عاد پدیدار شد آنان شادمان شدند که باران خواهد آمد اما دیری نگذشت که هود فرارسیدن عذاب الهی را به آنان گوشزد کرد. گردباد آغاز شد و چنان شد که مردم جز خانه‌های خود چیز دیگری نمی‌دیدند. هلاکت قوم عاد عبرتی برای برحذر بودن امت حضرت محمد صلوات الله علیه و آله است.","segment_columns":[{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"بلادهم","display":"بِلاَدُهُمْ"},{"kind":"word","token":"كثيره","display":"كَثِيرَةَ"},{"kind":"word","token":"الخير","display":"الْخَيْرِ"},{"kind":"word","token":"فحبس","display":"فَحَبَسَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عنهم","display":"عَنْهُمُ"},{"kind":"word","token":"المطر","display":"الْمَطَرَ"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"سنين","display":"سِنِينَ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"اجدبوا","display":"اَجْدَبُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذهب","display":"ذَهَبَ"},{"kind":"word","token":"خيرهم","display":"خَيْرُهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"هود","display":"هُودٌ"},{"kind":"word","token":"يدعوهم","display":"يَدْعُوهُمْ"},{"kind":"word","token":"فلم","display":"فَلَمْ"},{"kind":"word","token":"يؤمنوا","display":"يُؤْمِنُوا"},{"kind":"word","token":"فاوحي","display":"فَاَوْحَي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"هود","display":"هُودٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ياتيهم","display":"يَاْتِيَهُمُ"},{"kind":"word","toke