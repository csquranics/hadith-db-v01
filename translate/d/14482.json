{"consensus_set_id":"14482","translation_language":"fa","translation_source":{"hid":"227470"},"segments":[{"source_hadith_segment":"قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ ظَلَّلْنٰا عَلَيْكُمُ الْغَمٰامَ وَ اَنْزَلْنٰا عَلَيْكُمُ الْمَنَّ وَ السَّلْويٰ كُلُوا مِنْ طَيِّبٰاتِ مٰا رَزَقْنٰاكُمْ وَ مٰا ظَلَمُونٰا وَ لٰكِنْ كٰانُوا اَنْفُسَهُمْ يَظْلِمُونَ » </quranic_text>   <footnote> [ البقرة ۵۷ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ظللنا","display":"ظَلَّلْنٰا"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمُ"},{"kind":"word","token":"الغمام","display":"الْغَمٰامَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انزلنا","display":"اَنْزَلْنٰا"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمُ"},{"kind":"word","token":"المن","display":"الْمَنَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السلوي","display":"السَّلْويٰ"},{"kind":"word","token":"كلوا","display":"كُلُوا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"طيبات","display":"طَيِّبٰاتِ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"ظلموا","display":"ظَلَمُوا"},{"kind":"word","token":"قولا","display":"قَوْلاً"},{"kind":"word","token":"غير","display":"غَيْرَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"البقره۵۹","display":"البقرة۵۹"},{"kind":"word","token":"انهم","display":"اِنَّهُمْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يسجدوا","display":"يَسْجُدُوا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"رزقناكم","display":"رَزَقْنٰاكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ظلمونا","display":"ظَلَمُونٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لٰكِنْ"},{"kind":"word","token":"كانوا","display":"كٰانُوا"},{"kind":"word","token":"انفسهم","display":"اَنْفُسَهُمْ"},{"kind":"word","token":"يظلمون","display":"يَظْلِمُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۵۷","display":"۵۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ الْاِمَامُ عَلَيْهِ السَّلاَمُ قَالَ اللَّهُ عَزَّ وَ جَلَّ وَ اُذْكُرُوا يَا بَنِي اِسْرَائِيلَ اِذْ  <quranic_text> « ظَلَّلْنٰا عَلَيْكُمُ الْغَمٰامَ » </quranic_text>   <footnote> [ البقرة ۵۷ ] </footnote>  لَمَّا كُنْتُمْ فِي التِّيهِ تَقِيكُمْ حَرَّ الشَّمْسِ وَ بَرْدَ الْقَمَرِ  <quranic_text> « وَ اَنْزَلْنٰا عَلَيْكُمُ الْمَنَّ وَ السَّلْويٰ » </quranic_text>   <footnote> [ البقرة ۵۷ ] </footnote>  الْمَنُّ التَّرَنْجَبِينُ كَانَ يَسْقُطُ عَلَي شَجَرِهِمْ فَيَتَنَاوَلُونَهُ وَ السَّلْوَي السُّمَانَي اَطْيَبُ طَيْرٍ لَحْماً يَسْتَرْسِلُ لَهُمْ فَيَصْطَادُونَهُ قَالَ اللَّهُ عَزَّ وَ جَلَّ لَهُمْ  <quranic_text> « كُلُوا مِنْ طَيِّبٰاتِ مٰا رَزَقْنٰاكُمْ » </quranic_text>   <footnote> [ البقرة ۵۷ ] </footnote>  وَ اُشْكُرُوا نِعْمَتِي وَ عَظِّمُوا مَنْ عَظَّمْتُهُ وَ وَقِّرُوا مَنْ وَقَّرْتُهُ مِمَّنْ اَخَذْتُ عَلَيْكُمُ الْعُهُودَ وَ الْمَوَاثِيقَ لَهُمْ مُحَمَّدٍ وَ الِهِ الطَّيِّبِينَ قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مٰا ظَلَمُونٰا » </quranic_text>   <footnote> [ البقرة ۵۷ ] </footnote>  لَمَّا بَدَّلُوا وَ قَالُوا غَيْرَ مَا بِهِ اُمِرُوا وَ لَمْ يَفُوا بِمَا عَلَيْهِ عُوهِدُوا لِاَنَّ كُفْرَ الْكَافِرِ لاَ يَقْدَحُ فِي سُلْطَانِنَا وَ مَمَالِكِنَا كَمَا اَنَّ اِيمَانَ الْمُؤْمِنِ لاَ يَزِيدُ فِي سُلْطَانِنَا  <quranic_text> « وَ لٰكِنْ كٰانُوا اَنْفُسَهُمْ يَظْلِمُونَ » </quranic_text>   <footnote> [ البقرة ۵۷ ] </footnote>  يَضُرُّونَ بِهَا لِكُفْرِهِمْ وَ تَبْدِيلِهِمْ","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الامام","display":"الْاِمَامُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"باستاههم","display":"بِاَسْتَاهِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بدلوا","display":"بدّلوا"},{"kind":"word","token":"حطه","display":"حطّة"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"هطا","display":"هطا"},{"kind":"word","token":"سمقانا","display":"سمقانا"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"حنطه","display":"حِنْطَةٌ"},{"kind":"word","token":"حمراء","display":"حَمْرَاءُ"},{"kind":"word","token":"نتقوتها","display":"نَتَقَوَّتُهَا"},{"kind":"word","token":"احب","display":"اَحَبُّ"},{"kind":"word","token":"الينا","display":"اِلَيْنَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الفعل","display":"الْفِعْلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذكروا","display":"اُذْكُرُوا"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرَائِيلَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"tag_open","tag_name