{"consensus_set_id":"s402357","translation_language":"fa","translation_source":{"hid":"402357"},"segments":[{"source_hadith_segment":"« اِسْاَلْ عَمَّا بَدَا لَكَ » .  فَقَالَ :  نَعَمْ ،  اِنَّ اُنَاساً مِنْ اَصْحَابِكَ يَزْعُمُونَ اَنَّهُمْ يُرَدُّونَ بَعْدَ الْمَوْتِ ؟  فَقَالَ اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) :  « نَعَمْ ،  تَكَلَّمْ بِمَا سَمِعْتَ ،  وَ لاَ تَزِدْ فِي الْكَلاَمِ ،  فَمَا قُلْتَ لَهُمْ » .  قَالَ :  قُلْتُ","translation_segment":"","segment_columns":[{"kind":"word","token":"اسال","display":"اِسْاَلْ"},{"kind":"word","token":"عما","display":"عَمَّا"},{"kind":"word","token":"بدا","display":"بَدَا"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اناسا","display":"اُنَاساً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اصحابك","display":"اَصْحَابِكَ"},{"kind":"word","token":"يزعمون","display":"يَزْعُمُونَ"},{"kind":"word","token":"انهم","display":"اَنَّهُمْ"},{"kind":"word","token":"يردون","display":"يُرَدُّونَ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الموت","display":"الْمَوْتِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"تكلم","display":"تَكَلَّمْ"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"سمعت","display":"سَمِعْتَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تزد","display":"تَزِدْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الكلام","display":"الْكَلاَمِ"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"قلت","display":"قُلْتَ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"}]},{"source_hadith_segment":":  لاَ اُؤْمِنُ بِشَيْءٍ مِمَّا قُلْتُمْ ؟  فَقَالَ لَهُ اَمِيرُ الْمُؤْمِنِينَ ( صَلَوَاتُ اللَّهِ عَلَيْهِ","translation_segment":"","segment_columns":[{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اؤمن","display":"اُؤْمِنُ"},{"kind":"word","token":"بشيء","display":"بِشَيْءٍ"},{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"word","token":"قلتم","display":"قُلْتُمْ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"}]},{"source_hadith_segment":") :  « وَيْلَكَ ،  اِنَّ اللَّهَ عَزَّ وَ جَلَّ اِبْتَلَي قَوْماً بِمَا كَانَ مِنْ ذُنُوبِهِمْ ،  فَاَمَاتَهُمْ قَبْلَ اجَالِهِمُ الَّتِي سُمِّيَتْ لَهُمْ ،  ثُمَّ رَدَّهُمْ اِلَي الدُّنْيَا لِيَسْتَوْفُوا رِزْقَهُمْ ،  ثُمَّ اَمَاتَهُمْ بَعْدَ ذَلِكَ » .  قَالَ :  فَكَبُرَ عَلَي اِبْنِ الْكَوَّاءِ وَ لَمْ يَهْتَدِ لَهُ ،  فَقَالَ لَهُ اَمِيرُ الْمُؤْمِنِينَ :  « وَيْلَكَ تَعْلَمُ اَنَّ اللَّهَ عَزَّ وَ جَلَّ قَالَ فِي كِتَابِهِ :   <quranic_text> « وَ اِخْتٰارَ مُوسيٰ قَوْمَهُ سَبْعِينَ رَجُلاً لِمِيقٰاتِنٰا » </quranic_text>   <footnote> [ الاعراف ۱۵۵ ] </footnote>  فَانْطَلَقَ بِهِمْ لِيَشْهَدُوا لَهُ اِذَا رَجَعُوا عِنْدَ الْمَلَاِ مِنْ بَنِي اِسْرَائِيلَ اَنَّ رَبِّي قَدْ كَلَّمَنِي ،  فَلَوْ اَنَّهُمْ سَلَّمُوا ذَلِكَ لَهُ وَ صَدَّقُوهُ لَكَانَ خَيْراً لَهُمْ ،  وَ لَكِنَّهُمْ قَالُوا لِمُوسَي ( عَلَيْهِ السَّلاَمُ ) :   <quranic_text> « لَنْ نُؤْمِنَ لَكَ حَتّٰي نَرَي اللّٰهَ جَهْرَةً » </quranic_text>   <footnote> [ البقرة ۵۵ ] </footnote>  قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « فَاَخَذَتْكُمُ الصّٰاعِقَةُ » </quranic_text>   <footnote> [ البقرة ۵۵ ] </footnote>  يَعْنِي الْمَوْتَ  <quranic_text> « وَ اَنْتُمْ تَنْظُرُونَ ثُمَّ بَعَثْنٰاكُمْ مِنْ بَعْدِ مَوْتِكُمْ لَعَلَّكُمْ تَشْكُرُونَ » </quranic_text>   <footnote> [ البقرة ۵۵ ] </footnote>  فَتَرَي - يَا اِبْنَ الْكَوَّاءِ - اَنَّ هَؤُلاَءِ رَجَعُوا اِلَي مَنَازِلِهِمْ بَعْدَ مَا مَاتُوا ؟  » .  فَقَالَ اِبْنُ الْكَوَّاءِ :  وَ مَا ذَلِكَ ،  ثُمَّ اَمَاتَهُمْ مَكَانَهُمْ ؟  فَقَالَ لَهُ اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) :  « لاَ ،  وَيْلَكَ !  اَ وَ لَيْسَ قَدْ اَخْبَرَكَ فِي كِتَابِ اللَّهِ حَيْثُ يَقُولُ :   <quranic_text> « وَ ظَلَّلْنٰا عَلَيْكُمُ الْغَمٰامَ وَ اَنْزَلْنٰا عَلَيْكُمُ الْمَنَّ وَ السَّلْويٰ » </quranic_text> <footnote> [ البقرة ۵۷ ] </footnote> ؟  فَهَذَا بَعْدَ الْمَوْتِ اِذْ بَعَثَهُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ويلك","display":"وَيْلَكَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"ابتلي","display":"اِبْتَلَي"},{"kind":"word","token":"قوما","display":"قَوْماً"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ذنوبهم","display":"ذُنُوبِهِمْ"},{"kind":"word","token":"فاماتهم","display":"فَاَمَاتَهُمْ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"اجالهم","display":"اجَالِهِمُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"سميت","display":"سُمِّيَتْ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"ردهم","display":"رَدَّهُمْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الدنيا","d