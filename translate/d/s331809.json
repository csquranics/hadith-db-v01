{"consensus_set_id":"s331809","translation_language":"fa","translation_source":{"hid":"331809"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « وَ اِنِّي لَغَفّٰارٌ لِمَنْ تٰابَ - وَ امَنَ وَ عَمِلَ صٰالِحاً ثُمَّ اِهْتَديٰ » </quranic_text>   <footnote> [ طه ۸۲ ] </footnote>  قَالَ :  اِلَي وَلاَيَةِ اَهْلِ بَيْتِهِ  .","translation_segment":"عن ثابت البنانی فی قوله: (و إنی لغفار لمن تاب و آمن و عمل صالحا ثم اهتدی) قال: إلی ولایه أهل بیته. ثابت بنانی درباره سخن خداوند: «و انی لغفار لمن تاب و آمن و عمل صالحا ثم اهتدی» گفت: به ولایت اهل بیت او.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"لغفار","display":"لَغَفّٰارٌ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"تاب","display":"تٰابَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امن","display":"امَنَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمل","display":"عَمِلَ"},{"kind":"word","token":"صالحا","display":"صٰالِحاً"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اهتدي","display":"اِهْتَديٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"طه","display":"طه"},{"kind":"word","token":"۸۲","display":"۸۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ولايه","display":"وَلاَيَةِ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"بيته","display":"بَيْتِهِ"}]}]}