{"consensus_set_id":"43379","translation_language":"fa","translation_source":{"hid":"106727"},"segments":[{"source_hadith_segment":"<quranic_text> « مَنْ كٰانَ يُؤْمِنُ بِاللّٰهِ وَ الْيَوْمِ الْاخِرِ » </quranic_text>   <footnote> [ الطلاق ۲ ] </footnote>  فَلاَ يَجْلِسُ مَجْلِساً يُنْتَقَصُ فِيهِ اِمَامٌ اَوْ يُعَابُ فِيهِ مُؤْمِنٌ .","translation_segment":"حضرت صادق ع فرمود: هر که ایمان بخدا و روز قیامت دارد در مجلسی که امامی را مذمت کنند یا مومنی را عیب کنند ننشیند.","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"يؤمن","display":"يُؤْمِنُ"},{"kind":"word","token":"بالله","display":"بِاللّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اليوم","display":"الْيَوْمِ"},{"kind":"word","token":"الاخر","display":"الْاخِرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الطلاق","display":"الطلاق"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"يجلس","display":"يَجْلِسُ"},{"kind":"word","token":"مجلسا","display":"مَجْلِساً"},{"kind":"word","token":"ينتقص","display":"يُنْتَقَصُ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"امام","display":"اِمَامٌ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"يعاب","display":"يُعَابُ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٌ"}]}]}