نَ وَ الصِّدِّيقُ الْاَكْبَرُ ،  وَ الْفَارُوقُ الْاَعْظَمُ ،  وَ قَسِيمُ الْجَنَّةِ وَ النَّارِ ،  وَ الْوَصِيُّ ،  وَ الْوَلِيُّ ،  وَ الْخَلِيفَةُ وَ قَاضِي الدَّيْنِ ،  وَ مُنْجِزُ الْوَعْدِ ،  وَ الْمَحَجَّةُ الْكُبْرَي ،  وَ حَيْدَرَةُ الْوَرَي ،  وَ اَبُو اللِّوَاءِ ،  وَ الذَّائِدُ عَنِ الْحَوْضِ ،  وَ مَارِدُ الْجَانِّ وَ الذَّابُّ عَنِ النِّسْوَانِ ،  وَ الْاَنْزَعُ الْبَطِينُ ،  وَ كَاشِفُ الْكُرُوبِ ،  وَ يَعْسُوبُ الدِّينِ ،  وَ بَابُ حِطَّةٍ ،  وَ بَابُ التَّقَادُمِ .  وَ حُجَّةُ الْخِصَامِ ،  وَ الْاَشْرَفُ الْمَكِينُ ،  وَ صَاحِبُ الْعَصَا ،  وَ فَاصِلُ الْفَضَاءِ ،  وَ فَاصِلُ الْقَضَاءِ ،  سَفِينَةُ النَّجَاةِ ،  وَ الْمَنْهَجُ الْوَاضِحُ ،  وَ الْمَحَجَّةُ الْبَيْضَاءُ ،  وَ قَصْدُ السَّبِيلِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"معناه","display":"مَعْنَاهُ"},{"kind":"word","token":"حب","display":"حُبُّ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"اسماء","display":"اَسْمَاءً"},{"kind":"word","token":"كثيره","display":"كَثِيرَةً"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"نذكرها","display":"نَذْكُرُهَا"},{"kind":"word","token":"هاهنا","display":"هَاهُنَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"اشهر","display":"اَشْهَرُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تخفي","display":"تُخْفَي"}]}]}