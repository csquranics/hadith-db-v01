{"consensus_set_id":"s298679","translation_language":"fa","translation_source":{"hid":"298679"},"segments":[{"source_hadith_segment":"لِلدَّابَّةِ اِذَا كَانَتْ حَرُوناً تُكْتَبُ وَ تُعَلَّقُ عَلَيْهَا وَ تُقْرَاُ فِي اُذُنِهَا  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>","translation_segment":"تعویذی دیگر جهت وقتی که حیوان چموش گردد. این تعویذ را نوشته بر حیوان می‌آویزند و در گوشش می‌خوانند. «بسم‌ اللٰه‌ الرحمٰن‌ الرحیم‌ *» * «أ و لم‌ یروا أنٰا خلقنٰا لهم‌ ممٰا عملت‌» «أیدینٰا أنعٰاما","segment_columns":[{"kind":"word","token":"للدابه","display":"لِلدَّابَّةِ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"حرونا","display":"حَرُوناً"},{"kind":"word","token":"تكتب","display":"تُكْتَبُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعلق","display":"تُعَلَّقُ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تقرا","display":"تُقْرَاُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اذنها","display":"اُذُنِهَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"<quranic_text> « اَ وَ لَمْ يَرَوْا اَنّٰا خَلَقْنٰا لَهُمْ مِمّٰا عَمِلَتْ اَيْدِينٰا اَنْعٰاماً فَهُمْ لَهٰا مٰالِكُونَ وَ ذَلَّلْنٰاهٰا لَهُمْ فَمِنْهٰا رَكُوبُهُمْ وَ مِنْهٰا يَاْكُلُونَ » </quranic_text>   <footnote> [ يس ۷۱ ] </footnote>   .","translation_segment":"فهم‌ لهٰا مٰالکون‌؟ *`و ذللنٰاهٰا لهم‌ فمنهٰا رکوبهم‌ و منهٰا یأکلون‌». (به نام خداوند بخشاینده‌ی مهربان؛ *آیا ندیدند که ما به دست قدرت خود چارپایانی برای ایشان آفریدیم و ایشان دارندگان آن‌هایند؟ *آن‌ها را برای ایشان رام کردیم؛ پس از آن‌ها سواری می‌کشند و از آن‌ها می‌خورند.)","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يروا","display":"يَرَوْا"},{"kind":"word","token":"انا","display":"اَنّٰا"},{"kind":"word","token":"خلقنا","display":"خَلَقْنٰا"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"مما","display":"مِمّٰا"},{"kind":"word","token":"عملت","display":"عَمِلَتْ"},{"kind":"word","token":"ايدينا","display":"اَيْدِينٰا"},{"kind":"word","token":"انعاما","display":"اَنْعٰاماً"},{"kind":"word","token":"فهم","display":"فَهُمْ"},{"kind":"word","token":"لها","display":"لَهٰا"},{"kind":"word","token":"مالكون","display":"مٰالِكُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذللناها","display":"ذَلَّلْنٰاهٰا"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"فمنها","display":"فَمِنْهٰا"},{"kind":"word","token":"ركوبهم","display":"رَكُوبُهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"منها","display":"مِنْهٰا"},{"kind":"word","token":"ياكلون","display":"يَاْكُلُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يس","display":"يس"},{"kind":"word","token":"۷۱","display":"۷۱"},{"kind":"tag_close","tag_name":"footnote"}]}]}