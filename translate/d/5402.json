"segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"التفت","display":"اِلْتَفَتَ"},{"kind":"word","token":"الي","display":"اِلَيَّ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رابع","display":"رَابِعَ"},{"kind":"word","token":"الخلفاء","display":"الْخُلَفَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رحمه","display":"رَحْمَةُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بركاته","display":"بَرَكَاتُهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"هو","display":"هو"},{"kind":"word","token":"كذلك","display":"كَذَلِكَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"}]},{"source_hadith_segment":"فَقَالَ لَهُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ بَلَي ثُمَّ مَضَي","translation_segment":"بالحق‌». پس داود (علیه السلام) دوم از خلفاء باشد و حقتعالی حکایت از موسی (علیه السلام) میفرماید هنگامی","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"بلي","display":"بَلَي"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"مضي","display":"مَضَي"}]},{"source_hadith_segment":"فَقُلْتُ يَا رَسُولَ اللَّهِ مَا هَذَا الَّذِي قَالَ لِي هَذَا الشَّيْخُ وَ تَصْدِيقُكَ لَهُ","translation_segment":"که بهارون گفت «اخلفنی فی قومی و أصلح‌» ای هارون در میان قوم من خلیفه باش و اصلاح کن. پس هارون خلیفه سوم است که موسی (علیه","segment_columns":[{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الشيخ","display":"الشَّيْخُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تصديقك","display":"تَصْدِيقُكَ"},{"kind":"word","token":"له","display":"لَهُ"}]},{"source_hadith_segment":"قَالَ اَنْتَ كَذَلِكَ وَ الْحَمْدُ لِلَّهِ اِنَّ اللَّهَ عَزَّ وَ جَلَّ قَالَ فِي كِتَابِهِ  <quranic_text> « اِنِّي جٰاعِلٌ فِي الْاَرْضِ خَلِيفَةً » </quranic_text>   <footnote> [ البقرة ۳۰ ] </footnote>  وَ الْخَلِيفَةُ الْمَجْعُولُ فِيهَا ادَمُ عَلَيْهِ السَّلاَمُ وَ قَالَ  <quranic_text> « يٰا دٰاوُدُ اِنّٰا جَعَلْنٰاكَ خَلِيفَةً فِي الْاَرْضِ فَاحْكُمْ بَيْنَ النّٰاسِ بِالْحَقِّ » </quranic_text>   <footnote> [ ص ۲۶ ] </footnote>  فَهُوَ الثَّانِي وَ قَالَ عَزَّ وَ جَلَّ حِكَايَةً عَنْ مُوسَي حِينَ قَالَ لِهَارُونَ عَلَيْهِ السَّلاَمُ  <quranic_text> « اُخْلُفْنِي فِي قَوْمِي وَ اَصْلِحْ » </quranic_text>   <footnote> [ الاعراف ۱۴۲ ] </footnote>  فَهُوَ هَارُونُ اِذَا اِسْتَخْلَفَهُ مُوسَي عَلَيْهِ السَّلاَمُ فِي قَوْمِهِ فَهُوَ الثَّالِثُ وَ قَالَ عَزَّ وَ جَلَّ  <quranic_text> « وَ اَذٰانٌ مِنَ اللّٰهِ وَ رَسُولِهِ اِلَي النّٰاسِ يَوْمَ الْحَجِّ الْاَكْبَرِ » </quranic_text>   <footnote> [ التوبة ۳ ] </footnote>  فَكُنْتَ اَنْتَ الْمُبَلِّغَ عَنِ اللَّهِ وَ عَنْ رَسُولِهِ وَ اَنْتَ وَصِيِّي وَ وَزِيرِي وَ قَاضِي دَيْنِي وَ الْمُؤَدِّي عَنِّي وَ اَنْتَ مِنِّي بِمَنْزِلَةِ هَارُونَ مِنْ مُوسَي اِلاَّ اَنَّهُ لاَ نَبِيَّ بَعْدِي فَاَنْتَ رَابِعُ الْخُلَفَاءِ كَمَا سَلَّمَ عَلَيْكَ الشَّيْخُ اَ وَ لاَ تَدْرِي مَنْ هُوَ قُلْتُ لاَ قَالَ ذَاكَ اَخُوكَ الْخَضِرُ عَلَيْهِ السَّلاَمُ فَاعْلَمْ .","translation_segment":"السلام) او را خلیفه قرار داد در میان قوم خود و باز حقتعالی میفرماید «و أذٰان‌ من‌ اللٰه‌ و رسوله‌ إلی النٰاس‌ یوم‌ الحج‌ الأکبر» بیزار بودن خدا و رسول خدا از مشرکین اعلامی است از خدا و رسول خدا (صلی الله علیه و آله) بسوی مردم و در روز حج بزرگ عید قربان است. «مترجم گوید» که مصنف در کتاب معانی الاخبار حدیثی روایت کرده است از از حضرت صادق (علیه السلام) باین مضمون که راوی گفت از آن حضرت سوال کردم از معنی این آیه شریفه «و أذٰان‌ من‌ اللٰه‌ و رسوله‌» الی آخر آیه فرمود «أذٰان‌ من‌ اللٰه‌» اسمی است که حقتعالی از آسمان بعلی (علیه السلام) عطا کرده چه او بود که از جانب رسول ادای برائت و اعلام آن بکفار و مشرکین نمود. زیرا که چنین آیه برائت نازل شد اولا حضرت ختمی مرتبت ابی بکر را فرستاد بمکه تا این آیه را بر مشرکان مکه رساند و آنها را به بیزاری حق از آنها مطلع و آگاه سازد بناگاه جبرئیل فرود آمد و عرض کرد یا محمد تبلیغ نباید بکند کسی از جانب تو یا خودت باید تبلیغ کنی و این مطلب را باهل مکه بخوانی یا مردی از خودت که مقصود علی (علیه السلام) است. پس در این حال رسول خدا (صلی الله علیه و آله) علی (علیه السلام) را نزد ابی بکر فرستاده علی (علیه السلام) بتعجیل رفته ملحق بابی بکر شد و صحیفه را از دست او گرفته روانه مکه شد و آنچه باید بمشرکان اعلام کند اعلام کرد. از این جهت او را حقتعالی «أذٰان‌ من‌ اللٰه‌» نامید و این اسمی است که خدا از آسمان بعلی (علیه السلام) فرستاد. القصه حضرت ختمی مرتبت بعد از تلاوت این آیه شریفه فرمود پس توئی تبلیغ‌کننده از جانب خدا و رسول خدا (صلی الله علیه و آله) و توئی وصی من و وزیر من و قضاکننده قرض من و اداکننده امانات از جانب من و توئی نسبت بمن بمنزلت هارون نسبت بموسی مگر فرقی که هست پیغمبری بعد از من نیاید. پس توئی چهارمین خلفاء چنان که آن مرد پیر بر تو سلام کرد و این مطلب را گفت آیا ندانستی آن مرد پیر کیست من عرض کردم نه فرمود این برادر تو خضر (علیه السلام) بود پس بدان این معنی را.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"كذلك","display":"كَذَلِكَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحمد","display":"الْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتابه","display":"كِتَابِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"جاعل","display":"جٰاعِلٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"خليفه","display":"خَلِيفَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۳۰","display":"۳۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الخليفه","display":"الْخَلِيفَةُ"},{"kind":"word","token":"المجعول","display":"الْمَجْعُولُ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"ادم","display":"ادَمُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","tok