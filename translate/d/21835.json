{"consensus_set_id":"21835","translation_language":"fa","translation_source":{"hid":"407022"},"segments":[{"source_hadith_segment":"قَالَ :  « اِنَّ اَبِي كَانَ يَقُولُ :  اِنَّ اللَّهَ قَضَي قَضَاءً حَتْماً لاَ يُنْعِمُ عَلَي عَبْدٍ بِنِعْمَةٍ فَيَسْلُبَهَا اِيَّاهُ قَبْلَ اَنْ يُحْدِثَ الْعَبْدُ ذَنْباً يَسْتَوْجِبُ بِذَلِكَ الذَّنْبِ سَلْبَ تِلْكَ النِّعْمَةِ ،  وَ ذَلِكَ قَوْلُ اللَّهِ :   <quranic_text> « اِنَّ اللّٰهَ لاٰ يُغَيِّرُ مٰا بِقَوْمٍ حَتّٰي يُغَيِّرُوا مٰا بِاَنْفُسِهِمْ » </quranic_text>   <footnote> [ الرعد ۱۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"قضي","display":"قَضَي"},{"kind":"word","token":"قضاء","display":"قَضَاءً"},{"kind":"word","token":"حتما","display":"حَتْماً"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ينعم","display":"يُنْعِمُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"عبد","display":"عَبْدٍ"},{"kind":"word","token":"بنعمه","display":"بِنِعْمَةٍ"},{"kind":"word","token":"فيسلبها","display":"فَيَسْلُبَهَا"},{"kind":"word","token":"اياه","display":"اِيَّاهُ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يحدث","display":"يُحْدِثَ"},{"kind":"word","token":"العبد","display":"الْعَبْدُ"},{"kind":"word","token":"ذنبا","display":"ذَنْباً"},{"kind":"word","token":"يستوجب","display":"يَسْتَوْجِبُ"},{"kind":"word","token":"بذلك","display":"بِذَلِكَ"},{"kind":"word","token":"الذنب","display":"الذَّنْبِ"},{"kind":"word","token":"سلب","display":"سَلْبَ"},{"kind":"word","token":"تلك","display":"تِلْ