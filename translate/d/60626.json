{"consensus_set_id":"60626","translation_language":"fa","translation_source":{"hid":"408496"},"segments":[{"source_hadith_segment":"قَالَ لِي اَبُو عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ )  :  « يَا اَيُّوبُ ،  مَا مِنْ اَحَدٍ اِلاَّ وَ قَدْ يَرِدُ عَلَيْهِ الْحَقُّ حَتَّي يَصْدَعَ قَلْبَهُ ،  قَبِلَهُ اَمْ تَرَكَهُ ،  وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ فِي كِتَابِهِ :   <quranic_text> « بَلْ نَقْذِفُ بِالْحَقِّ عَلَي الْبٰاطِلِ فَيَدْمَغُهُ فَاِذٰا هُوَ زٰاهِقٌ وَ لَكُمُ الْوَيْلُ مِمّٰا تَصِفُونَ » </quranic_text>   <footnote> [ الانبياء ۱۸ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ايوب","display":"اَيُّوبُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"احد","display":"اَحَدٍ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"يرد","display":"يَرِدُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"الحق","display":"الْحَقُّ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"يصدع","display":"يَصْدَعَ"},{"kind":"word","token":"قلبه","display":"قَلْبَهُ"},{"kind":"word","token":"قبله","display":"قَبِلَهُ"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"تركه","display":"تَرَكَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word