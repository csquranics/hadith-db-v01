{"consensus_set_id":"40750","translation_language":"fa","translation_source":{"hid":"383097"},"segments":[{"source_hadith_segment":"فِي اَلصُّدَاعِ :  اُخْرُجْ عَلَيْكَ يَا حُمَّي ،  اَوْ يَا صُدَاعُ ،  اَوْ عِرْقُ ،  اَوْ عَيْنَ اِنْسٍ ،  اَوْ عَيْنَ جِنٍّ ،  اَوْ وَجَعَ فُلاَنِ بْنِ فُلاَنٍ ،  اُخْرُجْ عَلَيْكُمْ بِاللَّهِ الَّذِي اِتَّخَذَ  <quranic_text> «  اِبْرٰاهِيمَ خَلِيلاً » </quranic_text>   <footnote> [ النساء ۱۲۵ ] </footnote>  وَ كَلَّمَ  <quranic_text> «  مُوسيٰ تَكْلِيماً » </quranic_text>   <footnote> [ النساء ۱۶۴ ] </footnote>   ،  وَ بِرَبِّ عِيسَي اِبْنِ مَرْيَمَ الَّذِي هُوَ رُوحُهُ وَ كَلِمَتُهُ اِلاَّ هَدَاْتُمْ وَ طَفِئْتُمْ كَمَا طَفِئَتْ نَارُ اِبْرَاهِيمَ  .  .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الصداع","display":"اَلصُّدَاعِ"},{"kind":"word","token":"اخرج","display":"اُخْرُجْ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"حمي","display":"حُمَّي"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"صداع","display":"صُدَاعُ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"عرق","display":"عِرْقُ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"عين","display":"عَيْنَ"},{"kind":"word","token":"انس","display":"اِنْسٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"عين","display":"عَيْنَ"},{"kind":"word","token":"جن","display":"جِنٍّ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"وجع","display":"وَجَعَ"},{"kind":"word","token":"فلان","display":"فُلاَنِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"فلان","display":"فُلاَنٍ"},{"kind":"word","token":"ن","display":"ن"},{"kind":"word","token":"خ","display":"خ"},{"kind":"word","token":"د","display":"د"},{"kind":"word","token":"اخرج","display":"اُخْرُجْ"},{"kind":"word"