{"consensus_set_id":"18741","translation_language":"fa","translation_source":{"hid":"350987"},"segments":[{"source_hadith_segment":"اَنَّهُ كَانَ يَقْرَاُ هَذِهِ الْايَةَ :  رَبِّ  <quranic_text> « [ رَبَّنَا ]اِغْفِرْ لِي وَ » </quranic_text>   <footnote> [ ابراهيم ۴۱ ] </footnote>  لِوَالِدَيَّ [ لِوُلْدِي ] يَعْنِي اِسْمَاعِيلَ وَ اِسْحَاقَ  .","translation_segment":"در تفسیر عیاشی آمده است که امام باقر و امام صادق علیهما السلام فرموده‌اند: مقصود از آیه «رب‌ اغفر لی و لوٰالدی‌» همان اسماعیل و اسحاق هستند.","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يقرا","display":"يَقْرَاُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"رب","display":"رَبِّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ربنا","display":"رَبَّنَا"},{"kind":"word","token":"اغفر","display":"اِغْفِرْ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لوالدي","display":"لِوٰالِدَيَّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۴۱","display":"۴۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"لوالدي","display":"لِوَالِدَيَّ"},{"kind":"word","token":"لولدي","display":"لِوُلْدِي"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"اسماعيل","display":"اِسْمَاعِيلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسحاق","display":"اِسْحَاقَ"}]}]}