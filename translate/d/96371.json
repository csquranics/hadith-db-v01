َرْسَلَ اللَّهُ تَعَالَي الطَّاعُونَ فَلَمْ يَبْقَ مِنْهُمْ اِنْسَانٌ وَ لاَ دَابَّةٌ اِلاَّ قَتَلَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاَصْبَحَ اَبْكَارُ الِ فِرْعَوْنَ جِيَفاً وَ اَبْكَارُ بَنِي اِسْرَائِيلَ اَحْيَاءً سَالِمِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَمَاتَ مِنْهُمْ ثَمَانُونَ اَلْفاً سِوَي الدَّوَابِّ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ كَانَ لِفِرْعَوْنَ مِنْ اَثَاثِ الدُّنْيَا وَ زَهْرَتِهَا وَ زِينَتِهَا وَ مِنَ الْحُلِيِّ وَ الْحُلَلِ مَا لاَ يَعْلَمُهُ اِلاَّ اللَّهُ تَعَالَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاَوْحَي اللَّهُ جَلَّتْ عَظَمَتُهُ اِلَي مُوسَي صَلَوَاتُ اللَّهِ عَلَيْهِ اَنِّي مُورِثٌ بَنِي اِسْرَائِيلَ مَا فِي اَيْدِي الِ فِرْعَوْنَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَقُلْ لَهُمْ لِيَسْتَعِيرُوا مِنْهُمُ الْحُلِيَّ وَ الزِّينَةَ فَاِنَّهُمْ لاَ يَمْتَنِعُونَ مِنْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"خَوْفِ الْبَلاَءِ وَ اَعْطَي فِرْعَوْنُ جَمِيعَ زِينَةِ اَهْلِهِ وَ وُلْدِهِ وَ مَا كَانَ فِي خَزَائِنِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاَوْحَي اللَّهُ تَعَالَي اِلَي مُوسَي بِالْمَسِيرِ بِجَمِيعِ ذَلِكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"حَتَّي كَانَ مِنَ الْغَرَقِ بِفِرْعَونَ وَ قَوْمِهِ مَا كَانَ .","translation_segment":"","segment_columns":[]}]}