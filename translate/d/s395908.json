{"consensus_set_id":"s395908","translation_language":"fa","translation_source":{"hid":"395908"},"segments":[{"source_hadith_segment":"فَقُلْتُ لَهُ :  يَا بْنَ رَسُولِ اللَّهِ كَيْفَ صَارَتِ الْاِمَامَةُ فِي وُلْدِ الْحُسَيْنِ دُونَ وُلْدِ الْحَسَنِ وَ هُمَا جَمِيعاً وَلَدَا رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سِبْطَاهُ وَ سَيِّدَا شَبَابِ اَهْلِ الْجَنَّةِ ؟  فَقَالَ عَلَيْهِ السَّلاَمُ :  اِنَّ مُوسَي وَ هَارُونَ كَانَا نَبِيَّيْنِ مُرْسَلَيْنِ اَخَوَيْنِ ،  فَجَعَلَ اللَّهُ النُّبُوَّةَ فِي صُلْبِ هَارُونَ دُونَ صُلْبِ مُوسَي ،  وَ لَمْ يَكُنْ لِاَحَدٍ اَنْ يَقُولَ :  لِمَ فَعَلَ اللَّهُ ذَلِكَ ،  فَاِنَّ الْاِمَامَةَ خِلاَفَةُ اللَّهِ عَزَّ وَ جَلَّ لَيْسَ لِاَحَدٍ اَنْ يَقُولَ :  لِمَ جَعَلَهَا فِي صُلْبِ الْحُسَيْنِ دُونَ صُلْبِ الْحَسَنِ ،  لِاَنَّ اللَّهَ هُوَ الْحَكِيمُ فِي اَفْعَالِهِ  <quranic_text> « لاٰ يُسْئَلُ عَمّٰا يَفْعَلُ وَ هُمْ يُسْئَلُونَ » </quranic_text>   <footnote> [ الانبياء ۲۳ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"صارت","display":"صَارَتِ"},{"kind":"word","token":"الامامه","display":"الْاِمَامَةُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ولد","display":"وُلْدِ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"دون","display":"دُونَ"},{"kind":"word","token":"ولد","display":"وُلْدِ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هما","display":"هُمَا"},{"kind":"word","token":"جميعا","display":"جَمِيعاً"},{"kind":"word","token":"ولدا","display":"وَلَدَا"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kin