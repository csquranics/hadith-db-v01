{"consensus_set_id":"60126","translation_language":"fa","translation_source":{"hid":"338944"},"segments":[{"source_hadith_segment":"فِي تَفْسِيرِ قَوْلِهِ <quranic_text>«طه»</quranic_text> <footnote>[طه۱]</footnote> قَالَ قَالَ جَعْفَرُ بْنُ مُحَمَّدٍ الصَّادِقُ عَلَيْهِ السَّلاَمُ <quranic_text>«طه»</quranic_text> <footnote>[طه۱]</footnote> طَهَارَةُ اَهْلِ بَيْتِ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ثُمَّ قَرَاَ - <quranic_text>«اِنَّمٰا يُرِيدُ اللّٰهُ لِيُذْهِبَ عَنْكُمُ الرِّجْسَ اَهْلَ الْبَيْتِ وَ يُطَهِّرَكُمْ تَطْهِيراً»</quranic_text> <footnote>[الاحزاب۳۳]</footnote> .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"طه","display":"طه"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"طه۱","display":"طه۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"جعفر","display":"جَعْفَرُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"طه","display":"طه"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"طه۱","display":"طه۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"طهاره","display":"طَهَارَةُ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"بيت","display":"بَيْتِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind"