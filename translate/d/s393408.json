{"consensus_set_id":"s393408","translation_language":"fa","translation_source":{"hid":"393408"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ :  « وَ  <quranic_text> « اِذٰا تُتْليٰ عَلَيْهِمْ ايٰاتُنٰا بَيِّنٰاتٍ قٰالَ الَّذِينَ لاٰ يَرْجُونَ لِقٰاءَنَا اِئْتِ بِقُرْانٍ غَيْرِ هٰذٰا اَوْ بَدِّلْهُ قُلْ مٰا يَكُونُ لِي اَنْ اُبَدِّلَهُ مِنْ تِلْقٰاءِ نَفْسِي » </quranic_text>   <footnote> [ يونس ۱۵ ] </footnote> قَالُوا :  لَوْ بُدِّلَ مَكَانَ عَلِيٍّ اَبُو بَكْرٍ اَوْ عُمَرُ اِتَّبَعْنَاهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"تتلي","display":"تُتْليٰ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"اياتنا","display":"ايٰاتُنٰا"},{"kind":"word","token":"بينات","display":"بَيِّنٰاتٍ"},{"kind":"word","token":"قال","display":"قٰالَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يرجون","display":"يَرْجُونَ"},{"kind":"word","token":"لقاءنا","display":"لِقٰاءَنَا"},{"kind":"word","token":"ائت","display":"اِئْتِ"},{"kind":"word","token":"بقران","display":"بِقُرْانٍ"},{"kind":"word","token":"غير","display":"غَيْرِ"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"بدله","display":"بَدِّلْهُ"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ابدله","display":"اُبَدِّلَهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"تلقاء","display":"تِلْقٰاءِ"},{"k