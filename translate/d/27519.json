{"consensus_set_id":"27519","translation_language":"fa","translation_source":{"hid":"396382"},"segments":[{"source_hadith_segment":"رَفْعُ اَلْاَيْدِي مِنَ الاِسْتِكَانَةِ ،  قُلْتُ :  وَ مَا الاِسْتِكَانَةُ ؟  قَالَ :  اَ لاَ تَقْرَاُ هَذِهِ الْايَةَ :   <quranic_text> « فَمَا اِسْتَكٰانُوا لِرَبِّهِمْ وَ مٰا يَتَضَرَّعُونَ » </quranic_text>   <footnote> [ المؤمنون ۷۶ ] </footnote>  اَوْرَدَهُ الثَّعْلَبِيُّ وَ الْوَاحِدِيُّ فِي تَفْسِيرَيْهِمَا .","translation_segment":"","segment_columns":[{"kind":"word","token":"رفع","display":"رَفْعُ"},{"kind":"word","token":"الايدي","display":"اَلْاَيْدِي"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الاستكانه","display":"الاِسْتِكَانَةِ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"الاستكانه","display":"الاِسْتِكَانَةُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تقرا","display":"تَقْرَاُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"استكانوا","display":"اِسْتَكٰانُوا"},{"kind":"word","token":"لربهم","display":"لِرَبِّهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يتضرعون","display":"يَتَضَرَّعُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"kind":"word","token":"۷۶","display":"۷۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اورده","display":"اَوْرَدَهُ"},{"kind":"word","token":"الثعلبي","display":"الثَّعْلَبِيُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الواحدي","display":"