{"consensus_set_id":"s358907","translation_language":"fa","translation_source":{"hid":"358907"},"segments":[{"source_hadith_segment":"اَنَّ اَمِيرَ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ مَرَّ بِقَوْمٍ يَلْعَبُونَ بِالشِّطْرَنْجِ فَقَرَاَ  <quranic_text> « مٰا هٰذِهِ التَّمٰاثِيلُ الَّتِي اَنْتُمْ لَهٰا عٰاكِفُونَ » </quranic_text>   <footnote> [ الانبياء ۵۲ ] </footnote>  فَشَبَّهَهُ بِالْاَصْنَامِ الْمَعْبُودَةِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"مر","display":"مَرَّ"},{"kind":"word","token":"بقوم","display":"بِقَوْمٍ"},{"kind":"word","token":"يلعبون","display":"يَلْعَبُونَ"},{"kind":"word","token":"بالشطرنج","display":"بِالشِّطْرَنْجِ"},{"kind":"word","token":"فقرا","display":"فَقَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"هذه","display":"هٰذِهِ"},{"kind":"word","token":"التماثيل","display":"التَّمٰاثِيلُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"انتم","display":"اَنْتُمْ"},{"kind":"word","token":"لها","display":"لَهٰا"},{"kind":"word","token":"عاكفون","display":"عٰاكِفُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۵۲","display":"۵۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فشبهه","display":"فَشَبَّهَهُ"},{"kind":"word","token":"بالاصنام","display":"بِالْاَصْنَامِ"},{"kind":"word","token":"المعبوده","display":"الْمَعْبُودَةِ"}]}]}