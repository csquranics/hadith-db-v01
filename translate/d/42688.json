{"consensus_set_id":"42688","translation_language":"fa","translation_source":{"hid":"407461"},"segments":[{"source_hadith_segment":"« هَلَكَ اَلْعَامِلُونَ اِلاَّ الْعَابِدُونَ ،  وَ هَلَكَ الْعَابِدُونَ اِلاَّ الْعَالِمُونَ ،  وَ هَلَكَ الْعَالِمُونَ اِلاَّ الصَّادِقُونَ ،  وَ هَلَكَ الصَّادِقُونَ اِلاَّ الْمُخْلِصُونَ ،  وَ هَلَكَ الْمُخْلِصُونَ اِلاَّ الْمُتَّقُونَ ،  وَ هَلَكَ الْمُتَّقُونَ اِلاَّ الْمُوقِنُونَ ،  وَ اِنَّ الْمُوقِنِينَ لَعَلَي خُلُقٍ عَظِيمٍ ،  قَالَ اللَّهُ تَعَالَي :   <quranic_text> « وَ اُعْبُدْ رَبَّكَ حَتّٰي يَاْتِيَكَ الْيَقِينُ » </quranic_text>   <footnote> [ الحجر ۹۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"هلك","display":"هَلَكَ"},{"kind":"word","token":"العاملون","display":"اَلْعَامِلُونَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"العابدون","display":"الْعَابِدُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هلك","display":"هَلَكَ"},{"kind":"word","token":"العابدون","display":"الْعَابِدُونَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"العالمون","display":"الْعَالِمُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هلك","display":"هَلَكَ"},{"kind":"word","token":"العالمون","display":"الْعَالِمُونَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"الصادقون","display":"الصَّادِقُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هلك","display":"هَلَكَ"},{"kind":"word","token":"الصادقون","display":"الصَّادِقُونَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"المخلصون","display":"الْمُخْلِصُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هلك","display":"هَلَكَ"},{"kind":"word","token":"المخلصون","display":"الْمُخْلِصُونَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"المتقون","display":"الْمُتَّقُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word"