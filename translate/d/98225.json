{"consensus_set_id":"98225","translation_language":"fa","translation_source":{"hid":"355491"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ تَعَالَي :   <quranic_text> « فَاصْفَحِ الصَّفْحَ الْجَمِيلَ » </quranic_text>   <footnote> [ الحجر ۸۵ ] </footnote>  قَالَ عَفْوٌ بِغَيْرِ عِتَابٍ وَ فِي قَوْلِهِ :   <quranic_text> « خَوْفاً وَ طَمَعاً » </quranic_text>   <footnote> [ الاعراف ۵۶ ] </footnote>  قَالَ خَوْفاً لِلْمُسَافِرِ وَ طَمَعاً لِلْمُقِيمِ .","translation_segment":"و میفرمود: در قول خدای تعالی که «فاصفح‌ الصفح‌ الجمیل‌» یعنی عفو بی‌عتاب و در قول الهی که «خوفا و طمعا»» فرمود که خوف از برای مسافر و طمع از برای مقیم","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاصفح","display":"فَاصْفَحِ"},{"kind":"word","token":"الصفح","display":"الصَّفْحَ"},{"kind":"word","token":"الجميل","display":"الْجَمِيلَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"۸۵","display":"۸۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عفو","display":"عَفْوٌ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"عتاب","display":"عِتَابٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"خوفا","display":"خَوْفاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طمعا","display":"طَمَعاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۵۶","d