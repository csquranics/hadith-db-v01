{"consensus_set_id":"s102996","translation_language":"fa","translation_source":{"hid":"102996"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنِ اِمْرَاَةٍ تَزَوَّجَتْ فِي عِدَّتِهَا","translation_segment":"حسن بن محبوب از یزید کناسی نقل کرده گوید: از امام باقر علیه السلام پرسیدم: زنی در عده بوده و","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"امراه","display":"اِمْرَاَةٍ"},{"kind":"word","token":"تزوجت","display":"تَزَوَّجَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"عدتها","display":"عِدَّتِهَا"}]},{"source_hadith_segment":"فَقَالَ « اِنْ كَانَتْ تَزَوَّجَتْ فِي عِدَّةٍ مِنْ بَعْدِ مَوْتِ زَوْجِهَا مِنْ قَبْلِ اِنْقِضَاءِ الْاَرْبَعَةِ الْاَشْهُرِ وَ عَشْرٍ فَلاَ رَجْمَ عَلَيْهَا وَ عَلَيْهَا ضَرْبُ مِائَةِ جَلْدَةٍ وَ اِنْ كَانَتْ تَزَوَّجَتْ فِي عِدَّةِ طَلاَقٍ لِزَوْجِهَا عَلَيْهَا فِيهَا رَجْعَةٌ فَاِنَّ عَلَيْهَا الرَّجْمَ وَ اِنْ كَانَتْ تَزَوَّجَتْ فِي عِدَّةٍ لَيْسَ لِزَوْجِهَا عَلَيْهَا فِيهَا رَجْعَةٌ فَاِنَّ عَلَيْهَا حَدَّ الزَّانِي غَيْرِ الْمُحْصَنِ وَ اِذَا فَجَرَ نَصْرَانِيٌّ بِامْرَاَةٍ مُسْلِمَةٍ فَلَمَّا اُخِذَ لِيُقَامَ عَلَيْهِ الْحَدُّ اَسْلَمَ فَاِنَّ الْحُكْمَ فِيهِ اَنْ يُضْرَبَ حَتَّي يَمُوتَ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « فَلَمّٰا رَاَوْا بَاْسَنٰا قٰالُوا امَنّٰا بِاللّٰهِ وَحْدَهُ وَ كَفَرْنٰا بِمٰا كُنّٰا بِهِ مُشْرِكِينَ فَلَمْ يَكُ يَنْفَعُهُمْ اِيمٰانُهُمْ لَمّٰا رَاَوْا بَاْسَنٰا سُنَّتَ اللّٰهِ الَّتِي قَدْ خَلَتْ فِي عِبٰادِهِ وَ خَسِرَ هُنٰالِكَ » </quranic_text>   <footnote> [ غافر ۸۴ ] </footnote>  الْمُبْطِلُونَ » .","translation_segment":"شوهر کرده است حکمش چیست‌؟ فرمود: اگر در عده وفات شوهرش پیش از تمام شدن چهار ماه و ده روز بوده حکم او رجم نیست بلکه یک صد ضربه تازیانه است، و اگر در عده طلاق شوهرش بوده که حق‌ رجوع داشته، حکمش رجم است، و اگر طلاق بائن بوده از احصان خارج شده و حدش حد زانیه است که یک صد تازیانه باشد. شرح: «حسن بن محبوب بواسطه ابو أیوب از یزید کناسی روایت کرده چنان که در کافی و تهذیب است و ظاهرا واسطه در سند سقط‍‌ شده است». و هر گاه مردی نصرانی با زن مسلمانی زنا کند و چون دستگیر شود تا حد بر او جاری کنند اظهار اسلام کند حکمش آنست که آنقدر او را بزنند تا جان سپارد، زیرا خداوند میفرماید: «فلمٰا رأوا بأسنٰا قٰالوا آمنٰا باللٰه‌ وحده‌ و کفرنٰا بمٰا کنٰا به‌ مشرکین‌ `فلم‌ یک‌ ینفعهم‌ إیمٰانهم‌ لمٰا رأوا بأسنٰا سنت‌ اللٰه‌ التی قد خلت‌ فی عبٰاده‌ و خسر هنٰالک‌ الکٰافرون‌.» (چون کیفر شدید ما را دیدند آنگاه گفتند: ما بخدای یکتا ایمان آوردیم و به همه بتهائی که انباز خدا گرفتیم کافر شدیم، أما ایمانشان پس از دیدن عقاب و سختی عذاب ما بر ایشان سودی نبخشید، سنت و روش الهی از ازل در میان بندگان چنین حکمفرما بوده است، و آنجاست که کافران زیانکار شده‌اند) (مومن:۸۵).","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"تزوجت","display":"تَزَوَّجَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"عده","display":"عِدَّةٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بعد","display":"بَعْدِ"},{"kind":"word","token":"موت","display":"مَوْتِ"},{"kind":"word","token":"زوجها","display":"زَوْجِهَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبل","display":"قَبْلِ"},{"kind":"word","token":"انقضاء","display":"اِنْقِضَاءِ"},{"kind":"word","token":"الاربعه","display":"الْاَرْبَعَةِ"},{"kind":"word","token":"الاشهر","display":"الْاَشْهُرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عشر","display":"عَشْرٍ"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"رجم","display":"رَجْمَ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token