{"consensus_set_id":"s396378","translation_language":"fa","translation_source":{"hid":"396378"},"segments":[{"source_hadith_segment":"وَ هِيَ خُطْبَةُ الْوَسِيلَةِ يَقُولُ فِيهَا عَلَيْهِ السَّلاَمُ وَ قَدْ ذَكَرَ الْاَشْقَيَيْنِ :  يَقُولُ لِقَرِينِهِ اِذَا اِلْتَقَيَا :   <quranic_text> « يٰا لَيْتَ بَيْنِي وَ بَيْنَكَ بُعْدَ الْمَشْرِقَيْنِ فَبِئْسَ الْقَرِينُ » </quranic_text>   <footnote> [ الزخرف ۳۸ ] </footnote>  فَيُجِيبُهُ الْاَشْقَي عَلَي رُثُوثَةٍ :   <quranic_text> « يٰا وَيْلَتيٰ لَيْتَنِي لَمْ اَتَّخِذْ فُلاٰناً خَلِيلاً لَقَدْ اَضَلَّنِي عَنِ الذِّكْرِ بَعْدَ اِذْ جٰاءَنِي وَ كٰانَ الشَّيْطٰانُ لِلْاِنْسٰانِ خَذُولاً » </quranic_text>   <footnote> [ الفرقان ۲۸ ] </footnote>  فَاَنَا الذِّكْرُ الَّذِي عَنْهُ ضَلَّ ،  وَ السَّبِيلُ الَّذِي عَنْهُ مَالَ ،  وَ الْاِيمَانُ الَّذِي بِهِ كَفَرَ ،  وَ الْقُرْانُ الَّذِي اِيَّاهُ هَجَرَ ،  وَ الدِّينُ الَّذِي بِهِ كَذَّبَ ،  وَ الصِّرَاطُ الَّذِي عَنْهُ نَكَبَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"خطبه","display":"خُطْبَةُ"},{"kind":"word","token":"الوسيله","display":"الْوَسِيلَةِ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"الاشقيين","display":"الْاَشْقَيَيْنِ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"لقرينه","display":"لِقَرِينِهِ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"التقيا","display":"اِلْتَقَيَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ليت","display":"لَيْتَ"},{"kind":"word","token":"بيني","display":"بَيْنِي"},{"kind":"