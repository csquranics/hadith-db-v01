{"consensus_set_id":"19763","translation_language":"fa","translation_source":{"hid":"412402"},"segments":[{"source_hadith_segment":"فِي تَفْسِيرِ  <quranic_text> « وَ اللَّيْلِ اِذٰا يَغْشيٰ » </quranic_text>   <footnote> [ الليل ۱ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الليل","display":"اللَّيْلِ"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"يغشي","display":"يَغْشيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الليل","display":"الليل"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايات","display":"الْايَاتِ"}]},{"source_hadith_segment":"،  قَالَ :  « اِنَّ رَجُلاً [ مِنَ الْاَنْصَارِ ] كَانَ لِرَجُلٍ فِي حَائِطِهِ نَخْلَةٌ ،  وَ كَانَ يَضُرُّ بِهِ ،  فَشَكَا ذَلِكَ اِلَي رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  فَدَعَاهُ ،  فَقَالَ :  اَعْطِنِي نَخْلَتَكَ بِنَخْلَةٍ فِي الْجَنَّةِ ،  فَاَبَي ،  فَسَمِعَ ذَلِكَ رَجُلٌ مِنَ الْاَنْصَارِ يُكَنَّي اَبَا الدَحْدَاحِ ،  فَجَاءَ اِلَي صَاحِبِ النَّخْلَةِ ،  فَقَالَ :  بِعْنِي نَخْلَتَكَ بِحَائِطِي ،  فَبَاعَهُ ،  فَجَاءَ اِلَي رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  فَقَالَ :  يَا رَسُولَ اللَّهِ  ،  قَدِ اِشْتَرَيْتُ نَخْلَةَ فُلاَنٍ بِحَائِطِي ،  قَالَ :  فَقَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :  فَلَكَ بَدَلَهَا نَخْلَةٌ فِي الْجَنَّةِ ،  فَاَنْزَلَ اللَّهُ تَعَالَي عَلَي نَبِيِّهِ ( صَلَوَاتُ اللَّهِ عَلَيْهِ ) :   <quranic_text> « وَ مٰا خَلَقَ الذَّكَرَ وَ الْاُنْثيٰ اِنَّ سَعْيَكُمْ لَشَتّٰي فَاَمّٰا مَنْ اَعْطيٰ » </quranic_text>   <footnote> [ الليل ۳ ] </footnote>  يَعْنِي النَّخْلَةَ  <quranic_text> « وَ اِتَّقيٰ وَ صَدَّقَ بِالْحُسْنيٰ » </quranic_text>   <footnote> [ الليل ۵ ] </footnote>   ،  هُوَ مَا عِنْدَ رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  <quranic_text> « فَسَنُيَسِّرُهُ لِلْيُسْريٰ » </quranic_text>   <footnote> [ الليل ۷ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « تَرَدّٰي » </quranic_text>   <footnote> [ الليل ۱۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الانصار","display":"الْاَنْصَارِ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"لرجل","display":"لِرَجُلٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"حائطه","display":"حَائِطِهِ"},{"kind":"word","token":"نخله","display":"نَخْلَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يضر","display":"يَضُرُّ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"فشكا","display":"فَشَكَا"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فدعاه","display":"فَدَعَاهُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"اعطني","display":"اَعْطِنِي"},{"kind":"word","token":"نخلتك","display":"نَخْلَتَكَ"},{"kind":"word","token":"بن