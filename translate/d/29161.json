{"consensus_set_id":"29161","translation_language":"fa","translation_source":{"hid":"331475"},"segments":[{"source_hadith_segment":"لَمَّا اَنْزَلَ اللَّهُ تَعَالَي قَوْلَهُ :   <quranic_text> « لِلْفُقَرٰاءِ الَّذِينَ اُحْصِرُوا فِي سَبِيلِ اللّٰهِ » </quranic_text>   <footnote> [ البقرة ۲۷۳ ] </footnote>  بَعَثَ","translation_segment":"عن عباس قال: لما أنزل الله تعالی قوله: (للفقراء الذین أحصروا فی سبیل الله) [۲۷۳/البقره:۲] بعث عبد الرحمان بن عوف بدنانیر کثیره إلی أصحاب الصفه، و بعث علی‌ بن ابی طالب فی جوف اللیل بوسق من تمر؛ فکان أحب‌ الصدقتین","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"قوله","display":"قَوْلَهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"للفقراء","display":"لِلْفُقَرٰاءِ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"احصروا","display":"اُحْصِرُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"سبيل","display":"سَبِيلِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۷۳","display":"۲۷۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"بعث","display":"بَعَثَ"}]},{"source_hadith_segment":"عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ بِدَنَانِيرَ كَثِيرَةٍ - اِلَي اَصْحَابِ الصُّفَّةِ ،  وَ بَعَثَ عَلِيُّ بْنُ اَبِي طَالِبٍ فِي جَوْفِ اللَّيْلِ بِوَسْقٍ مِنْ تَمْرٍ ،  فَكَانَ اَحَبَّ الصَّدَقَتَيْنِ اِلَي اللَّهِ عَزَّ وَ جَلَّ - صَدَقَةُ عَلِيِّ بْنِ اَبِي طَالِبٍ فَاَنْزَلَ [ اَللَّهُ ] فِيهِمَا :   <quranic_text> « الَّذِينَ يُنْفِقُونَ اَمْوٰالَهُمْ » </quranic_text>   <footnote> [ البقرة ۲۷۴ ]