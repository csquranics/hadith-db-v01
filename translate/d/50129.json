{"consensus_set_id":"50129","translation_language":"fa","translation_source":{"hid":"49435"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا الْحَسَنِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِهِ تَعَالَي عَزَّ وَ جَلَّ :   <quranic_text> « وَ لَقَدْ وَصَّلْنٰا لَهُمُ الْقَوْلَ لَعَلَّهُمْ يَتَذَكَّرُونَ » </quranic_text>   <footnote> [ القصص ۵۱ ] </footnote>  قَالَ :  اِمَامٍ اِلَي اِمَامٍ .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"وصلنا","display":"وَصَّلْنٰا"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"القول","display":"الْقَوْلَ"},{"kind":"word","token":"لعلهم","display":"لَعَلَّهُمْ"},{"kind":"word","token":"يتذكرون","display":"يَتَذَكَّرُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۵۱","display":"۵۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"امام","display":"اِمَامٍ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"امام","display":"اِمَامٍ"}]}]}