{"consensus_set_id":"52398","translation_language":"fa","translation_source":{"hid":"304813"},"segments":[{"source_hadith_segment":":  قَالَ عَلِيُّ بْنُ مُحَمَّدِ بْنِ عَلِيِّ بْنِ مُوسَي الرِّضَا عَلَيْهِ السَّلاَمُ  :   <quranic_text> « اَمْ تُرِيدُونَ » </quranic_text>   <footnote> [ البقرة ۱۰۸ ] </footnote>  بَلْ تُرِيدُونَ يَا كُفَّارَ قُرَيْشٍ وَ الْيَهُودَ","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"تريدون","display":"تُرِيدُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۰۸","display":"۱۰۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"بل","display":"بَلْ"},{"kind":"word","token":"تريدون","display":"تُرِيدُونَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"كفار","display":"كُفَّارَ"},{"kind":"word","token":"قريش","display":"قُرَيْشٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اليهود","display":"الْيَهُودَ"}]},{"source_hadith_segment":"<quranic_text> « اَنْ تَسْئَلُوا رَسُولَكُمْ » </quranic_text>   <footnote> [ البقرة ۱۰۸ ] </footnote>  مَا تَقْتَرِحُونَهُ مِنَ الْايَاتِ الَّتِي لاَ تَعْلَمُونَ هَلْ فِيهَا صَلاَحُكُمْ اَوْ فَسَادُكُمْ  <quranic_text> « كَمٰا سُئِلَ مُوسيٰ مِنْ قَبْلُ » </quranic_text>   <footnote> [ البقرة ۱۰۸ ] </footnote>  وَ اِقْتَرَحَ عَلَيْهِ لَمَّا قِيلَ لَهُ  <quranic_text> « لَنْ نُؤْمِنَ لَكَ حَتّٰي نَرَي اللّٰهَ جَهْرَةً فَاَخَذَتْكُمُ الصّٰاعِقَةُ » </quranic_text>   <footnote> [ البقرة ۵۵ ] </footnote>   .   <quranic_text> « وَ مَنْ يَتَبَدَّلِ الْكُفْرَ بِالْاِيمٰانِ » </quranic_text>   <footnote> [ البقرة ۱۰۸ ] </footnote>  بَعْدَ جَوَابِ الرَّسُولِ لَهُ اِنَّ مَا سَاَلَهُ لاَ يَصْلُحُ اِقْتِرَاحُهُ عَلَي اللَّهِ وَ بَعْدَ مَا يُظْهِرُ اللَّهُ تَعَالَي لَهُ مَا اِقْتَرَحَ اِنْ كَانَ صَوَاباً .   <quranic_text> « وَ مَنْ يَتَبَدَّلِ الْكُفْرَ بِالْاِيمٰانِ » </quranic_text>   <footnote> [ البقرة ۱۰۸ ] </footnote>  بِاَنْ لاَ يُؤْمِنَ عِنْدَ مُشَاهَدَةِ مَا يَقْتَرِحُ مِنَ الْايَاتِ اَوْ لاَ يُؤْمِنُ اِذَا عَرَفَ اَنَّهُ لَيْسَ لَهُ اَنْ يَقْتَرِحَ ،  وَ اَنَّهُ يَجِبُ اَنْ يَكْتَفِيَ بِمَا قَدْ اَقَامَهُ اللَّهُ تَعَالَي مِنَ الدَّلاَلاَتِ ،  وَ اَوْضَحَهُ مِنَ الْايَاتِ الْبَيِّنَاتِ ،  فَيَتَبَدَّلُ الْكُفْرَ بِالْاِيمَانِ بِاَنْ يُعَانِدَ وَ لاَ يَلْتَزِمَ الْحُجَّةَ الْقَائِمَةَ عَلَيْهِ  <quranic_text> « فَقَدْ ضَلَّ سَوٰاءَ السَّبِيلِ » </quranic_text>   <footnote> [ البقرة ۱۰۸ ] </footnote>  اَخْطَاَ قَصْدَ الطُّرُقِ الْمُؤَدِّيَةِ اِلَي الْجِنَانِ ،  وَ اَخَذَ فِي الطُّرُقِ الْمُؤَدِّيَةِ اِلَي النِّيرَانِ .  قَالَ عَلَيْهِ السَّلاَمُ :  قَالَ اللَّهُ تَعَالَي [ لِلْيَهُودِ ] :  يَا اَيُّهَا الْيَهُودُ  <quranic_text> « اَمْ تُرِيدُونَ » </quranic_text>   <footnote> [ البقرة ۱۰۸ ] </footnote>  بَلْ تُرِيدُونَ مِنْ بَعْدِ مَا","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تسئلوا","display":"تَسْئَلُوا"},{"kind":"word","token":"رسولكم","display":"رَسُولَكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۰۸","display":"۱۰۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ما","display":"م