{"consensus_set_id":"s402223","translation_language":"fa","translation_source":{"hid":"402223"},"segments":[{"source_hadith_segment":"« اَنَّهَا نَزَلَتْ فِي ثَلاَثَةٍ - لَمَّا قَامَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) بِالْوَلاَيَةِ لِاَمِيرِ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) - اَظْهَرُوا الْاِيمَانَ وَ الرِّضَا بِذَلِكَ ،  فَلَمَّا خَلَوْا بِاَعْدَاءِ اَمِيرِ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ )  <quranic_text> « قٰالُوا اِنّٰا مَعَكُمْ اِنَّمٰا نَحْنُ مُسْتَهْزِؤُنَ » </quranic_text>   <footnote> [ البقرة ۱۴ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"انها","display":"اَنَّهَا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"قام","display":"قَامَ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"بالولايه","display":"بِالْوَلاَيَةِ"},{"kind":"word","token":"لامير","display":"لِاَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"اظهروا","display":"اَظْهَرُوا"},{"kind":"word","token":"الايمان","display":"الْاِيمَانَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"بذلك","display":"بِذَلِكَ"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"خلوا","display":"خَلَوْا"},{"kind":"word","token":"باعداء","display":"بِاَعْدَاءِ"},{"kind":"wo