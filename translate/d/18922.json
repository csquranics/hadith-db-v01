{"consensus_set_id":"18922","translation_language":"fa","translation_source":{"hid":"353979"},"segments":[{"source_hadith_segment":"<quranic_text> «   <footnote> [ ایهقران کریم ] </footnote>  قَوْلُهُ تَعَالَي فَاسْتَويٰ عَليٰ سُوقِهِ اِسْتَوَي الْاِسْلاَمُ بِسَيْفِ عَلِيٍّ عَلَيْهِ السَّلاَمُ  .  » </quranic_text>","translation_segment":"و دیگر حسن آورده که «فاستویٰ‌ علیٰ‌ سوقه‌» در شأن آن حضرتست زیرا که استوا و قیام اسلام بشمشیر امیر المومنین ثبوت و رسوخ یافت.","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ایهقران","display":"ایهقران"},{"kind":"word","token":"کریم","display":"کریم"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاستوي","display":"فَاسْتَويٰ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"سوقه","display":"سُوقِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفتح29","display":"الفتح29"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"استوي","display":"اِسْتَوَي"},{"kind":"word","token":"الاسلام","display":"الْاِسْلاَمُ"},{"kind":"word","token":"بسيف","display":"بِسَيْفِ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_close","tag_name":"quranic_text"}]}]}