{"consensus_set_id":"42259","translation_language":"fa","translation_source":{"hid":"310360"},"segments":[{"source_hadith_segment":"<quranic_text> « بَلْ يَدٰاهُ مَبْسُوطَتٰانِ » </quranic_text>   <footnote> [ المائدة ۶۴ ] </footnote>  فَقُلْتُ لَهُ يَدَانِ هَكَذَا وَ اَشَرْتُ بِيَدِي اِلَي يَدِهِ فَقَالَ لاَ لَوْ كَانَ هَكَذَا لَكَانَ مَخْلُوقاً .","translation_segment":"حدیث کرد ما را محمد بن حسن بن احمد بن ولید «رضی» گفت که حدیث کرد ما را محمد بن حسن صفار از محمد بن عیسی از مشرفی بفاء سعفص نه قاف قرشت یعنی عبد اللٰه بن قیس از ابو الحسن حضرت امام رضا (علیه السلام) که گفت شنیدم از آن حضرت که میفرمود «بل‌ یدٰاه‌ مبسوطتٰان‌» بآن حضرت عرض کردم که او را دو دست است همچنین و بدست خود اشاره بدستهای آن حضرت نمودم فرمود نه اگر چنین میبود مخلوق و آفریده بود.","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اَللَّهَ"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"وصف","display":"وَصَفَ"},{"kind":"word","token":"نفسه","display":"نَفْسَهُ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"صمد","display":"صَمَدٌ"},{"kind":"word","token":"نور","display":"نُورٌ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بل","display":"بَلْ"},{"kind":"word","token":"يداه","display":"يَدٰاهُ"},{"kind":"word","token":"مبسوطتان","display":"مَبْسُوطَتٰانِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۶۴","display":"۶۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقلت","display":"فَقُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فله","display":"فَلَهُ"},{"kind":"word","token":"يدان","display":"يَدَانِ"},{"kind":"word","token":"هكذا","display":"هَكَذَا"},{"ki