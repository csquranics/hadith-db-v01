","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال الشامي :  الحسين بن فاطمة و ابن","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"عليّ بن ابي طالب !  !  قال :  نعم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فقال الشامي :  لعنك اللّه يا يزيد ،  تقتل عترة نبيّك و تسبي ذرّيّته","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و اللّه ما توهّمت الاّ انّهم سبي الروم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فقال يزيد :  و اللّه لالحقنّك بهم ،  ثمّ امر به فضربت عنقه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال :  ثمّ تقدّم عليّ بن الحسين بين يدي يزيد و قال :  لا تطمعوا ان تهينونا و نكرمكمو ان نكفّ الاذي عنكم و تؤذونا اللّه يعلم انّا لا نحبّكمو لا نلومكم اذ لم تحبّونا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فقال يزيد :  صدقت و لكن اراد ابوك و جدّك ان يكونا اميرين ،  فالحمد للّه الّذي قتلهما ،  و سفك دمهما","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  ثمّ قال :  يا عليّ ،  انّ اباك قطع رحمي ،  و جهل حقّي ،  و نازعني سلطاني ،  فصنع اللّه به ما قد رايت","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فقال عليّ بن الحسين ع  :   <quranic_text> « مٰا اَصٰابَ مِنْ مُصِيبَةٍ فِي الْاَرْضِ وَ لاٰ فِي اَنْفُسِكُمْ اِلاّٰ فِي كِتٰابٍ مِنْ قَبْلِ اَنْ نَبْرَاَهٰا اِنَّ ذٰلِكَ عَلَي اللّٰهِ يَسِيرٌ » </quranic_text>   <footnote> [ الحديد ۲۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فقال يزيد لابنه [ خالد ] :  اردد عليه ،  فلم يدر ما يقول","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فقال يزيد :   <quranic_text> « وَ مٰا اَصٰابَكُمْ مِنْ مُصِيبَةٍ فَبِمٰا كَسَبَتْ اَيْدِيكُمْ وَ يَعْفُوا عَنْ كَثِيرٍ » </quranic_text>   <footnote> [ الشوري ۳۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  ثمّ قال عليّ بن الحسين ع  :  يا ابن معاوية و هند و صخر ،  انّ النبوّة و الامرة لم تزل لابائي و اجدادي من قبل ان تولد ،  و لقد كان جدّي عليّ بن ابي طالب يوم بدر و احد و الاحزاب في يده راية رسول اللّه صلّي اللّه عليه و اله ،  و ابوك و جدّك في ايديهما رايات الكفّار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  ثمّ جعل صلوات اللّه عليه يقول :  ما ذا تقولون اذ قال النبيّ لكمما ذا فعلتم و انتم اخر الامم ثمّ قال عليّ بن الحسين ع  :  ويلك يا يزيد لو تدري ما صنعت ،  و ما الّذي ارتكبت من ابي و اهل بيتي و اخي و عمومتي اذا لهربت في الجبال ،  و افترشت الرماد ،  و دعوت بالويل و الثبور ان يكون راس الحسين بن فاطمة و عليّ ولده منصوبان علي باب مدينتكم ،  و هو وديعة رسول اللّه صلّي اللّه عليه و اله ،  [ فيكم ] فابشر بالخزي و الندامة غدا اذا جمع الناس ليوم القيامة .","translation_segment":"","segment_columns":[]}]}