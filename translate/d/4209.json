","display":"حَرَامٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اربع","display":"اَرْبَعَ"},{"kind":"word","token":"عشره","display":"عَشْرَةَ"},{"kind":"word","token":"وجها","display":"وَجْهاً"},{"kind":"word","token":"خصله","display":"خَصْلَةً"},{"kind":"word","token":"صاحبها","display":"صَاحِبُهَا"},{"kind":"word","token":"بالخيار","display":"بِالْخِيَارِ"}]},{"source_hadith_segment":"اِنْ شَاءَ صَامَ وَ اِنْ شَاءَ اَفْطَرَ","translation_segment":"خصال از او حرام، و چهارده","segment_columns":[{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"شاء","display":"شَاءَ"},{"kind":"word","token":"صام","display":"صَامَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"شاء","display":"شَاءَ"},{"kind":"word","token":"افطر","display":"اَفْطَرَ"}]},{"source_hadith_segment":"فَصَوْمُ النَّذْرِ وَاجِبٌ وَ صَوْمُ الاِعْتِكَافِ وَاجِبٌ قَالَ قُلْتُ فَسِّرْهُنَّ لِي يَا اِبْنَ رَسُولِ اللَّهِ قَالَ عَلَيْهِ السَّلاَمُ اَمَّا الْوَاجِبُ فَصَوْمُ شَهْرِ رَمَضَانَ وَ صِيَامُ شَهْرَيْنِ مُتَتَابِعَيْنِ فِي قَتْلِ الْخَطَاِ لِمَنْ لَمْ يَجِدِ الْعِتْقَ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « وَ مَنْ قَتَلَ مُؤْمِناً خَطَاً » </quranic_text>   <footnote> [ النساء ۹۲ ] </footnote>  الْايَةَ وَ صِيَامُ ثَلاَثَةِ اَيَّامٍ فِي كَفَّارَةِ الْيَمِينِ لِمَنْ لَمْ يَجِدِ الْاِطْعَامَ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « ذٰلِكَ كَفّٰارَةُ اَيْمٰانِكُمْ اِذٰا حَلَفْتُمْ » </quranic_text>   <footnote> [ المائدة ۸۹ ] </footnote>  الْايَةَ وَ صِيَامُ حَلْقِ الرَّاْسِ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « فَمَنْ كٰانَ مِنْكُمْ مَرِيضاً اَوْ بِهِ اَذيً مِنْ رَاْسِهِ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  الْايَةَ وَ صَاحِبُهُ بِالْخِيَارِ اِنْ شَاءَ صَامَ ثَلاَثاً وَ صَوْمُ دَمِ الْمُتْعَةِ لِمَنْ لَمْ يَجِدِ الْهَدْيَ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « فَمَنْ تَمَتَّعَ بِالْعُمْرَةِ اِلَي الْحَجِّ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  الْايَةَ وَ صَوْمُ جَزَاءِ الصَّيْدِ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « وَ مَنْ قَتَلَهُ مِنْكُمْ مُتَعَمِّداً » </quranic_text>   <footnote> [ المائدة ۹۵ ] </footnote>  الْايَةَ وَ اِنَّمَا يُقَوَّمُ الصَّيْدُ قِيمَةً ثُمَّ يُفَضُّ ذَلِكَ الثَّمَنُ عَلَي الْحِنْطَةِ وَ اَمَّا الَّذِي صَاحِبُهُ بِالْخِيَارِ فَصَوْمُ الْاِثْنَيْنِ وَ الْخَمِيسِ وَ سِتَّةُ اَيَّامٍ عَنْ شَوَّالٍ بَعْدَ رَمَضَانَ وَ يَوْمَ عَرَفَهُ وَ يَوْمَ عَاشُورَاءَ كُلُّ ذَلِكَ صَاحِبُهُ بِالْخِيَارِ اِنْ شَاءَ صَامَ وَ اِنْ شَاءَ اَفْطَرَ وَ اَمَّا صَوْمُ الْاِذْنِ فَالْمَرْاَةُ لاَ تَصُومُ تَطَوُّعاً اِلاَّ بِاِذْنِ زَوْجِهَا وَ كَذَلِكَ الْعَبْدُ وَ الْاَمَةُ وَ اَمَّا صَوْمُ الْحَرَامِ فَصَوْمُ الْفِطْرِ وَ يَوْمِ الْاَضْحَي وَ اَيَّامِ التَّشْرِيقِ وَ يَوْمِ الشَّكِّ نُهِينَا اَنْ نَصُومَهُ لِرَمَضَانَ وَ صَوْمُ الصَّمْتِ حَرَامٌ","translation_segment":"خصلت از آن صاحب آن مخیر است اگر خواهد بدارد و اگر خواهد افطار کند، صوم نذر و صوم اعتکاف واجبست گوید که: من گفتم که تفسیر فرمای از برای من یا ابن رسول اللٰه، فرمود که: اما واجب از آن روزه ماه رمضانست و دو ماه روزه داشتن در قتل خطا کسی که نیابد بنده را که آزاد کند کما قال اللٰه تعالی «و من‌ قتل‌ مومنا خطأ» تا آخر آیت و سه روز روزه داشتن در کفاره یمین کسی که قادر نباشد بر اطعام چنانچه حق تعالی فرمود که «ذٰلک‌ کفٰاره‌ أیمٰانکم‌ إذٰا حلفتم‌» و روزه داشتن حلق رأس در حج کما قال اللٰه تعالی «فمن‌ کٰان‌ منکم‌ مریضا أو به‌ أذی‌ من‌ رأسه‌» تا آخر و صاحب او مخیر است اگر خواهد سه روز روزه بدارد، و صوم دم متعه کسی که قربانی نیابد چنانچه حق جل و علا فرموده که «فمن‌ تمتع‌ بالعمره‌ إلی الحج‌» الآیه و صوم جزای صید کما قال اللٰه تعالی «و من‌ قتله‌ منکم‌ متعمدا» الآیه صید را قیمت باید کرد و قیمت آن را گندم خرید و بفقرا صرف کرد و چون عاجز باشد روزه میدارد بر وجهی که مبین است در کتب فقهیه و اما روزه که صاحب آن مخیر است روزه دوشنبه و پنج شنبه است و شش روز از شوال بعد از رمضان، و روز عرفه و روز عاشورا، صاحب این روزها مخیر است اگر خواهد بدارد و اگر خواهد افطار کند. و اما صوم اذن پس زن روزه تطوع نمیتواند داشت بی‌دستور شوهر و همچنین غلام و کنیزک بی‌اذن سید. و اما صوم حرام روزه عید فطر و عید اضحی است و ایام تشریق و روز شک منهی است که از رمضان بداریم و روزه وصال و صمت و نذر معصیت و","segment_columns":[{"kind":"word","token":"فصوم","display":"فَصَوْمُ"},{"kind":"word","token":"النذر","display":"النَّذْرِ"},{"kind":"word","token":"واجب","display":"وَاجِبٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صوم","display":"صَوْمُ"},{"kind":"word","token":"الاعتكاف","display":"الاِعْتِكَافِ"},{"kind":"word","token":"واجب","display":"وَاجِبٌ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"فسرهن","display":"فَسِّرْهُنَّ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةِ"},{"kind":"word","token":"اوجه","display":"اَوْجُهٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صوم","display":"صَوْمُ"},{"kind":"word","token":"التاديب","display":"التَّاْدِيبِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"منها","display":"مِنْهَا"},{"kind":"word","token":"صوم","display":"صَوْمُ"},{"kind":"word","token":"الاباحه","display":"الْاِبَاحَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صوم","display":"صَوْمُ"},{"kind":"word","token":"السفر","display":"السَّفَرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"تقدم","display":"تَقَدَّمَ"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الصوم","display":"الصَّوْمُ"},{"kind":"word","token":"الواجب","display":"