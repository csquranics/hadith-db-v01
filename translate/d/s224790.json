{"consensus_set_id":"s224790","translation_language":"fa","translation_source":{"hid":"224790"},"segments":[{"source_hadith_segment":"قَالَ قَالَ الصَّادِقُ عَلَيْهِ السَّلاَمُ  :  فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « يَوْمَ يَجْمَعُ اللّٰهُ الرُّسُلَ فَيَقُولُ مٰا ذٰا اُجِبْتُمْ قٰالُوا لاٰ عِلْمَ لَنٰا » </quranic_text>   <footnote> [ المائدة ۱۰۹ ] </footnote>  قَالَ يَقُولُونَ لاَ عِلْمَ لَنَا سِوَاكَ قَالَ وَ قَالَ الصَّادِقُ عَلَيْهِ السَّلاَمُ الْقُرْانُ كُلُّهُ [ ظَاهِرُهُ ] تَقْرِيعٌ وَ بَاطِنُهُ تَقْرِيبٌ .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"يجمع","display":"يَجْمَعُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"الرسل","display":"الرُّسُلَ"},{"kind":"word","token":"فيقول","display":"فَيَقُولُ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ذا","display":"ذٰا"},{"kind":"word","token":"اجبتم","display":"اُجِبْتُمْ"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"علم","display":"عِلْمَ"},{"kind":"word","token":"لنا","display":"لَنٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۱۰۹","display":"۱۰۹"},{"kind":"tag_close","tag_name":"footnote"}