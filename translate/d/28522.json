{"consensus_set_id":"28522","translation_language":"fa","translation_source":{"hid":"407780"},"segments":[{"source_hadith_segment":"« اَتَتْ فَاطِمَةُ اَبَا بَكْرٍ تُرِيدُ فَدَكَ ،  فَقَالَ :  هَاتِي اَسْوَدَ اَوْ اَحْمَرَ يَشْهَدْ بِذَلِكَ - قَالَ - فَاَتَتْ بِاُمِّ اَيْمَنَ ،  فَقَالَ لَهَا :  بِمَ تَشْهَدِينَ ؟  قَالَتْ :  اَشْهَدُ اَنَّ جَبْرَئِيلَ ( عَلَيْهِ السَّلاَمُ ) اَتَي مُحَمَّداً ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  ،  فَقَالَ :  اِنَّ اللَّهَ يَقُولُ :   <quranic_text> « وَ اتِ ذَا الْقُرْبيٰ حَقَّهُ » </quranic_text>   <footnote> [ الاسراء ۲۶ ] </footnote> فَلَمْ يَدْرِ مُحَمَّدٌ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) مَنْ هُمْ ،  فَقَالَ :  يَا جَبْرَئِيلُ ،  سَلْ رَبَّكَ مَنْ هُمْ ،  فَقَالَ :  فَاطِمَةُ ذُو الْقُرْبَي ،  فَاَعْطَاهَا فَدَكَ ،  فَزَعَمُوا اَنَّ عُمَرَ مَحَا الصَّحِيفَةَ وَ قَدْ كَانَ كَتَبَهَا اَبُو بَكْرٍ »","translation_segment":"","segment_columns":[{"kind":"word","token":"اتت","display":"اَتَتْ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"بكر","display":"بَكْرٍ"},{"kind":"word","token":"تريد","display":"تُرِيدُ"},{"kind":"word","token":"فدك","display":"فَدَكَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"هاتي","display":"هَاتِي"},{"kind":"word","token":"اسود","display":"اَسْوَدَ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"احمر","display":"اَحْمَرَ"},{"kind":"word","token":"يشهد","display":"يَشْهَدْ"},{"kind":"word","token":"بذلك","display":"بِذَلِكَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فاتت","display":"فَاَتَتْ"},{"kind":"word","token":"بام","display":"بِاُمِّ"},{"kind":"word","token":"ايمن","display":"اَيْمَنَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لها","display":"لَهَا"},{"kind":"word","token":"بم","display":"بِمَ"},{"kind":"word","