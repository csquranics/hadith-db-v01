َّرْنٰاهُ مَنٰازِلَ حَتّٰي عٰادَ كَالْعُرْجُونِ الْقَدِيمِ لاَ الشَّمْسُ يَنْبَغِي لَهٰا اَنْ تُدْرِكَ الْقَمَرَ وَ لاَ اللَّيْلُ سٰابِقُ النَّهٰارِ وَ كُلٌّ فِي فَلَكٍ يَسْبَحُونَ وَ ايَةٌ لَهُمْ اَنّٰا حَمَلْنٰا ذُرِّيَّتَهُمْ فِي الْفُلْكِ الْمَشْحُونِ وَ خَلَقْنٰا لَهُمْ مِنْ مِثْلِهِ مٰا يَرْكَبُونَ وَ اِنْ نَشَاْ نُغْرِقْهُمْ فَلاٰ صَرِيخَ لَهُمْ وَ لاٰ هُمْ يُنْقَذُونَ اِلاّٰ رَحْمَةً مِنّٰا وَ مَتٰاعاً اِليٰ حِينٍ » </quranic_text>   <footnote> [ يس ۳۸ ] </footnote>   <quranic_text> « وَ نُفِخَ فِي الصُّورِ فَاِذٰا هُمْ مِنَ الْاَجْدٰاثِ اِليٰ رَبِّهِمْ يَنْسِلُونَ » </quranic_text>   <footnote> [ يس ۵۱ ] </footnote>  وَ تُكْتَبُ عَلَي ظَهْرِ الْقِرْطَاسِ هَذِهِ الْايَاتُ  <quranic_text> « كَاَنَّهُمْ يَوْمَ يَرَوْنَ مٰا يُوعَدُونَ لَمْ يَلْبَثُوا اِلاّٰ سٰاعَةً مِنْ نَهٰارٍ بَلاٰغٌ فَهَلْ يُهْلَكُ اِلاَّ الْقَوْمُ الْفٰاسِقُونَ » </quranic_text>   <footnote> [ الاحقاف ۳۵ ] </footnote>   <quranic_text> « كَاَنَّهُمْ يَوْمَ يَرَوْنَهٰا لَمْ يَلْبَثُوا اِلاّٰ عَشِيَّةً اَوْ ضُحٰاهٰا » </quranic_text>   <footnote> [ النازعات ۴۶ ] </footnote>  وَ يُعَلَّقُ الْقِرْطَاسُ فِي وَسَطِهَا فَحِينَ يَقَعُ وَلَدُهَا يُقْطَعُ عَنْهَا وَ لاَ يُتْرَكُ عَلَيْهَا سَاعَةً وَاحِدَةً .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ليكتب","display":"لْيَكْتُبْ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"ير","display":"يَرَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"كفروا","display":"كَفَرُوا"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"السماوات","display":"السَّمٰاوٰاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الارض","display":"الْاَرْضَ"},{"kind":"word","token":"كانتا","display":"كٰانَتٰا"},{"kind":"word","token":"رتقا","dis