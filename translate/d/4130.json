{"consensus_set_id":"4130","translation_language":"fa","translation_source":{"hid":"99271"},"segments":[{"source_hadith_segment":"« اِقْرَاْ  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote> وَ  <quranic_text> « قُلْ يٰا اَيُّهَا الْكٰافِرُونَ » </quranic_text>   <footnote> [ الكافرون ۱ ] </footnote>  عِنْدَ مَنَامِكَ فَاِنَّهَا بَرَاءَةٌ مِنَ الشِّرْكِ وَ  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>  نِسْبَةُ الرَّبِّ عَزَّ وَ جَلَّ » .","translation_segment":"عبد اللٰه بن سنان از امام صادق علیه السلام روایت کرده که آن حضرت به او فرمود: در هنگام خواب دو سوره قل هو اللٰه أحد و قل یا أیها الکافرون را بخوان که سوره اخیر نشانگر بیزاری جستن و دوری از شرک، و سوره توحید بیانگر نسبت (شناسنامه) پروردگار عز و جل‌ است.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"له","display":"له"},{"kind":"word","token":"اقرا","display":"اِقْرَاْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاخلاص","display":"الاخلاص"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الكافرون","display":"الْكٰافِرُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكافرون","display":"الكافرون"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ع