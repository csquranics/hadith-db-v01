{"consensus_set_id":"73585","translation_language":"fa","translation_source":{"hid":"95677"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ طَعٰامُ الَّذِينَ اُوتُوا الْكِتٰابَ حِلٌّ لَكُمْ » </quranic_text>   <footnote> [ المائدة ۵ ] </footnote>  فَقَالَ « اَلْعَدَسُ وَ الْحِمَّصُ وَ غَيْرُ ذَلِكَ .  » .","translation_segment":"* *۱۰۹ - از ابو عبد الله صادق (ع) پرسیدم: خداوند عز و جل که می‌گوید: «خوراک ملتهای اهل کتاب بر شما حلال است». چه خوراکی را منظور کرده است‌؟ ابو عبد الله گفت: عدس. نخود و امثال آن.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"طعامهم","display":"طعامهم"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طعام","display":"طَعٰامُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اوتوا","display":"اُوتُوا"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابَ"},{"kind":"word","token":"حل","display":"حِلٌّ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۵","display":"۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"العدس","display":"اَلْعَدَسُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحمص","display":"الْحِمَّصُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"غير","display":"غَيْرُ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"}]}]}