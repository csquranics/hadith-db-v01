{"consensus_set_id":"s403576","translation_language":"fa","translation_source":{"hid":"403576"},"segments":[{"source_hadith_segment":"قَالَتِ اَلْعُلَمَاءُ :  فَاَخْبِرْنَا هَلْ فَسَّرَ اللَّهُ تَعَالَي الاِصْطِفَاءَ فِي الْكِتَابِ ؟  فَقَالَ الرِّضَا","translation_segment":"","segment_columns":[{"kind":"word","token":"قالت","display":"قَالَتِ"},{"kind":"word","token":"العلماء","display":"اَلْعُلَمَاءُ"},{"kind":"word","token":"فاخبرنا","display":"فَاَخْبِرْنَا"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"فسر","display":"فَسَّرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"الاصطفاء","display":"الاِصْطِفَاءَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الكتاب","display":"الْكِتَابِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"}]},{"source_hadith_segment":"( عَلَيْهِ السَّلاَمُ ) :  « فَسَّرَ الاِصْطِفَاءَ فِي الظَّاهِرِ سِوَي الْبَاطِنِ ،  فِي اِثْنَيْ عَشَرَ مَوْضِعاً - وَ ذَكَرَ الْمَوَاضِعَ مِنَ الْقُرْانِ وَ قَالَ ( عَلَيْهِ السَّلاَمُ ) فِيهَا - وَ اَمَّا الثَّالِثَةُ :  حِينَ مَيَّزَ اللَّهُ تَعَالَي الطَّاهِرِينَ مِنْ خَلْقِهِ ،  وَ اَمَرَ نَبِيَّهُ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) بِالْمُبَاهَلَةِ بِهِمْ فِي ايَةِ الاِبْتِهَالِ ،  فَقَالَ عَزَّ وَ جَلَّ :   <quranic_text> « فَمَنْ حَاجَّكَ فِيهِ مِنْ بَعْدِ مٰا جٰاءَكَ مِنَ الْعِلْمِ فَقُلْ تَعٰالَوْا نَدْعُ اَبْنٰاءَنٰا وَ اَبْنٰاءَكُمْ وَ نِسٰاءَنٰا وَ نِسٰاءَكُمْ وَ اَنْفُسَنٰا وَ اَنْفُسَكُمْ » </quranic_text>   <footnote> [ العمران ۶۱ ] </footnote>   .  قَالَتِ الْعُلَمَاءُ :  عَنَي بِهِ نَفْسَهُ .  قَالَ اَبُو الْحَسَنِ ( عَلَيْهِ السَّلاَمُ ) :  « غَلِطْتُمْ ،  اِنَّمَا عَنَي بِهِ عَلِيَّ بْنَ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ ) ،  وَ مِمَّا يَدُلُّ عَلَي ذَلِكَ قَوْلُ النَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) حِينَ قَالَ :  لَيَنْتَهِيَنَّ بَنُو وَلِيعَةَ اَوْ لَاَبْعَثَنَّ اِلَيْهِمْ رَجُلاً كَنَفْسِي - يَعْنِي عَلِيَّ بْنَ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ ) - وَ عَنَي بِالْاَبْنَاءِ الْحَسَنَ وَ الْحُسَيْنَ ،  وَ عَنَي بِالنِّسَاءِ فَاطِمَةَ ( عَلَيْهَا السَّلاَمُ ) ،  فَهَذِهِ خُصُوصِيَّةٌ لاَ يَتَقَدَّمُ فِيهَا اَحَدٌ ،  وَ فَضْلٌ لاَ يَلْحَقُهُمْ فِيهِ بَشَرٌ ،  وَ شَرَفٌ لاَ يَسْبِقُهُمْ اِلَيْهِ خَلْقٌ ،  اِذْ جَعَلَ نَفْسَ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) كَنَفْسِهِ ( صَلَوَاتُ اللَّهِ عَلَيْهِ وَ عَلَي الِهِ ) ،  فَهَذِهِ الثَّالِثَةُ ،  وَ اَمَّا الرَّابِعَةُ » وَ ذَكَرَهَا وَ مَا بَعْدَهَا اِلَي اخِرِ الْحَدِيثِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فسر","display":"فَسَّرَ"},{"kind":"word","token":"الاصطفاء","display":"الاِصْطِفَاءَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الظاهر","display":"الظَّاهِرِ"},{"kind":"word","token":"سوي","display":"سِوَي"},{"kind":"word","token":"الباطن","display":"الْبَاطِنِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اثني","display":"اِثْنَيْ"},{"kind":"word","token":"عشر","display":"عَشَرَ"},{"kind":"word","token":"موضعا","display":"مَوْضِعاً"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"المواضع","display":"الْمَوَاضِعَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الثالثه","display":"الثَّالِثَةُ"},{"kind":"word","token":"حين","display":"حِينَ"},{"ki