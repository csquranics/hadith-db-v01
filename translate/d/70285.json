{"consensus_set_id":"70285","translation_language":"fa","translation_source":{"hid":"332119"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ :  ]  <quranic_text> « وَ مَنْ يَقْتَرِفْ حَسَنَةً » </quranic_text>   <footnote> [ الشوري ۲۳ ] </footnote>  قَالَ :  الْمَوَدَّةُ لِالِ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  .","translation_segment":"ابی مالک از ابن عباس روایت کرد؛ «و من‌ یقترف‌ حسنه‌» یعنی هر کسی دوستی و مودت آل محمد صلی اللٰه علیه و آله را کسب کند «نزد له‌ فیهٰا حسنا» بر حسنات و خوبی‌هایش افزوده می‌شود.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يقترف","display":"يَقْتَرِفْ"},{"kind":"word","token":"حسنه","display":"حَسَنَةً"},{"kind":"word","token":"نزد","display":"نَزِدْ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"حسنا","display":"حُسْناً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الشوري","display":"الشوري"},{"kind":"word","token":"۲۳","display":"۲۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الموده","display":"الْمَوَدَّةُ"},{"kind":"word","token":"لال","display":"لِالِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"}]}]}