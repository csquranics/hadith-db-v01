{"consensus_set_id":"s332325","translation_language":"fa","translation_source":{"hid":"332325"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَنْ قَوْلِ اللَّهِ :   <quranic_text> « عَنِ النَّبَاِ الْعَظِيمِ » </quranic_text>   <footnote> [ النبا ۲ ] </footnote>  قَالَ :  النَّبَاُ الْعَظِيمُ عَلِيٌّ وَ فِيهِ اِخْتَلَفُوا - لِاَنَّ رَسُولَ اللَّهِ لَيْسَ فِيهِ اِخْتِلاَفٌ .","translation_segment":"عن ابان بن تغلب قال: سألت أبا جعفر عن قول الله: (عن النبأ العظیم) قال: النبأ العظیم علی و فیه اختلفوا لأن رسول الله لیس فیه اختلاف. ابان بن تغلب گفت: از ابو جعفر درباره سخن خداوند: «عن النبأ العظیم» پرسیدم، گفت: خبر بزرگ علی بود و درباره او اختلاف کردند چون درباره پیامبر خدا اختلافی نیست.","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"النبا","display":"النَّبَاِ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النبا","display":"النبا"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"النبا","display":"النَّبَاُ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمُ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"اختلفوا","display":"اِخْتَلَفُوا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"اختلاف","display":"اِخْتِلاَفٌ"}]}]}