{"consensus_set_id":"s332168","translation_language":"fa","translation_source":{"hid":"332168"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اِنَّ فِي ذٰلِكَ لَذِكْريٰ لِمَنْ كٰانَ لَهُ قَلْبٌ » </quranic_text>   <footnote> [ ق ۳۷ ] </footnote>  قَالَ :  فَاَنَا ذُو الْقَلْبِ الَّذِي عَنَي اللَّهُ بِهَذَا .","translation_segment":"عن محمد بن الحنفیه عن علی فی قوله تعالی: (إن‌ فی ذلک لذکری لمن کان له قلب) قال: فأنا ذو القلب الذی عنی الله بهذا. محمد بن حنفیه از علی (علیه السلام) نقل می‌کند که درباره سخن خداوند: «ان‌ فی ذلک لذکری لمن کان له قلب» گفت: من همان صاحب عقل هستم که خداوند در این آیه قصد کرده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"لذكري","display":"لَذِكْريٰ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"قلب","display":"قَلْبٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ق","display":"ق"},{"kind":"word","token":"۳۷","display":"۳۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فانا","display":"فَاَنَا"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"القلب","display":"الْقَلْبِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"عني","display":"عَنَي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"بهذا","display":"بِهَذَا"}]}]}