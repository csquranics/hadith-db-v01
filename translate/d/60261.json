{"consensus_set_id":"60261","translation_language":"fa","translation_source":{"hid":"410656"},"segments":[{"source_hadith_segment":"« ثُمَّ يُدْفَعُ - يَعْنِي الْكَافِرُ - فِي صَدْرِهِ دَفْعَةً ،  فَيَهْوِي عَلَي رَاْسِهِ سَبْعِينَ اَلْفَ عَامٍ حَتَّي يُوَاقِعَ الْحُطَمَةَ ،  فَاِذَا وَاقَعَهَا دُقَّتْ عَلَيْهِ وَ عَلَي شَيْطَانِهِ ،  وَ جَاذَبَهُ الشَّيْطَانُ بِالسِّلْسِلَةِ ،  كُلَّمَا رَفَعَ رَاْسَهُ وَ نَظَرَ اِلَي قُبْحِ وَجْهِهِ ،  كَلَحَ فِي وَجْهِهِ ،  قَالَ :  فَيَقُولُ :   <quranic_text> « يٰا لَيْتَ بَيْنِي وَ بَيْنَكَ بُعْدَ الْمَشْرِقَيْنِ فَبِئْسَ الْقَرِينُ » </quranic_text>   <footnote> [ الزخرف ۳۸ ] </footnote> ،  وَيْحَكَ كَمَا اَغْوَيْتَنِي اِحْمِلْ عَنِّي مِنْ عَذَابِ اللَّهِ مِنْ شَيْءٍ .  فَيَقُولُ :  يَا شَقِيُّ ،  كَيْفَ اَحْمِلُ عَنْكَ مِنْ عَذَابِ اللَّهِ مِنْ شَيْءٍ ،  وَ اَنَا وَ اَنْتَ فِي الْعَذَابِ مُشْتَرِكُونَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يدفع","display":"يُدْفَعُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"الكافر","display":"الْكَافِرُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"صدره","display":"صَدْرِهِ"},{"kind":"word","token":"دفعه","display":"دَفْعَةً"},{"kind":"word","token":"فيهوي","display":"فَيَهْوِي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"راسه","display":"رَاْسِهِ"},{"kind":"word","token":"سبعين","display":"سَبْعِينَ"},{"kind":"word","token":"الف","display":"اَلْفَ"},{"kind":"word","token":"عام","display":"عَامٍ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"يواقع","display":"يُوَاقِعَ"},{"kind":"word","token":"الحطمه","display":"الْحُطَمَةَ"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"واقعها","display":"وَاقَعَهَا"},{"kind":"word","token":"دقت","display":"دُقَّتْ"},{"kind":"word","token":"عليه","displa