{"consensus_set_id":"31928","translation_language":"fa","translation_source":{"hid":"332039"},"segments":[{"source_hadith_segment":"نَزَلَتْ هَذِهِ الْايَةُ فِي خَمْسَةٍ :  فِيَّ وَ فِي عَلِيٍّ وَ حَسَنٍ وَ حُسَيْنٍ وَ فَاطِمَةَ  <quranic_text> « اِنَّمٰا يُرِيدُ اللّٰهُ » </quranic_text>   <footnote> [ الاحزاب ۳۳ ] </footnote>  الْايَةَ .","translation_segment":"عن أبی سعید قال: قال رسول الله: نزلت هذه الآیه فی خمسه: فی‌ و فی علی و حسن و حسین و فاطمه (إنما یرید الله) الآیه. ابو سعید گفت: پیامبر فرمود: این آیه درباره پنج نفر نازل شد، من و علی و حسن و حسین و فاطمه «انما یرید الله لیذهب عنکم الرجس اهل البیت»","segment_columns":[{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"خمسه","display":"خَمْسَةٍ"},{"kind":"word","token":"في","display":"فِيَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حسن","display":"حَسَنٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حسين","display":"حُسَيْنٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"يريد","display":"يُرِيدُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحزاب","display":"الاحزاب"},{"kind":"word","token":"۳۳","display":"۳۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"}]}]}