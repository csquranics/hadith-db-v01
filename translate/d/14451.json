ء قدیر.». معبودی جز خداوند وجود ندارد، که یگانه است و شریکی برای او نیست، فرمانروایی تنها مختص‌ اوست، و ستایش برای اوست، زنده می‌کند و می‌میراند [و می‌میراند و زنده می‌گرداند]، و او خود زنده‌ای است که نمی‌میرد، خیر و خوبی تنها به دست [جمال] اوست، و بر هر چیز قادر و تواناست. و نیز ده بار بگو: «أعوذ باللٰه السمیع العلیم من همزات","segment_columns":[{"kind":"word","token":"تقول","display":"تَقُولُ"},{"kind":"word","token":"عشر","display":"عَشْرَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اصبحت","display":"اَصْبَحَتْ"},{"kind":"word","token":"بي","display":"بِي"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"نعمه","display":"نِعْمَةٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"عافيه","display":"عَافِيَةٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"دين","display":"دِينٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"دنيا","display":"دُنْيَا"},{"kind":"word","token":"فمنك","display":"فَمِنْكَ"},{"kind":"word","token":"وحدك","display":"وَحْدَكَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"شريك","display":"شَرِيكَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذكر","display":"اُذْكُرْ"},{"kind":"word","token":"ربك","display":"رَبَّكَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"نفسك","display":"نَفْسِكَ"},{"kind":"word","token":"تضرعا","display":"تَضَرُّعاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"الشكر","display":"الشُّكْرُ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"علي","displa