{"consensus_set_id":"3724","translation_language":"fa","translation_source":{"hid":"409720"},"segments":[{"source_hadith_segment":"« فَصَبَرَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) فِي جَمِيعِ اَحْوَالِهِ ،  ثُمَّ بَشَّرَ بِالْاَئِمَّةِ مِنْ عِتْرَتِهِ ،  وَ وُصِفُوا بِالصَّبْرِ ،  فَقَالَ :   <quranic_text> « وَ جَعَلْنٰا مِنْهُمْ اَئِمَّةً يَهْدُونَ بِاَمْرِنٰا لَمّٰا صَبَرُوا وَ كٰانُوا بِايٰاتِنٰا يُوقِنُونَ » </quranic_text>   <footnote> [ السجده ۲۴ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"فصبر","display":"فَصَبَرَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"جميع","display":"جَمِيعِ"},{"kind":"word","token":"احواله","display":"اَحْوَالِهِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"بشر","display":"بَشَّرَ"},{"kind":"word","token":"بالائمه","display":"بِالْاَئِمَّةِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عترته","display":"عِتْرَتِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وصفوا","display":"وُصِفُوا"},{"kind":"word","token":"بالصبر","display":"بِالصَّبْرِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جعلنا","display":"جَعَلْنٰا"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"ائمه","display":"اَئِمَّةً"},{"kind":"word","token":"يهدون","display":"يَهْدُونَ"},{"kind":"word","token":"بامرنا","display":"بِاَمْرِنٰا"},{"kind":"word","token":"لما","display":"لَمّٰا"},{"kind":"word","token":"صبروا","display":"ص