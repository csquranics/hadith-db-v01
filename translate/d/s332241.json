{"consensus_set_id":"s332241","translation_language":"fa","translation_source":{"hid":"332241"},"segments":[{"source_hadith_segment":"كَانَ عَلِيٌّ اِذَا صَفَّ فِي الْقِتَالِ - كَاَنَّهُ  <quranic_text> « بُنْيٰانٌ مَرْصُوصٌ » </quranic_text>   <footnote> [ الصف ۴ ] </footnote>  فَاَنْزَلَ اللَّهُ تَعَالَي هَذِهِ الْايَةَ .","translation_segment":"عن ابن عباس قال: کان علی‌ إذا صف‌ فی القتال کأنه بنیان مرصوص فأنزل الله تعالی هذه الآیه. ابن عباس گفت: وقتی علی در صف جنگ بود مانند بنایی آهنین بود و خدا این آیه را نازل کرد.","segment_columns":[{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"صف","display":"صَفَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القتال","display":"الْقِتَالِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"كانه","display":"كَاَنَّهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بنيان","display":"بُنْيٰانٌ"},{"kind":"word","token":"مرصوص","display":"مَرْصُوصٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الصف","display":"الصف"},{"kind":"word","token":"۴","display":"۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فانزل","display":"فَاَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"}]}]}