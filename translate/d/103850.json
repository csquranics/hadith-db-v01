{"consensus_set_id":"103850","translation_language":"fa","translation_source":{"hid":"312975"},"segments":[{"source_hadith_segment":"اَنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ مَرَّ بِقَوْمٍ يَلْعَبُونَ بِالشِّطْرَنْجِ قَالَ  <quranic_text> « مٰا هٰذِهِ التَّمٰاثِيلُ الَّتِي اَنْتُمْ لَهٰا عٰاكِفُونَ » </quranic_text>   <footnote> [ الانبياء ۵۲ ] </footnote>   .","translation_segment":"و روایت کرد عبد اللٰه بن مسعود که گذشت پیغمبر (صلی الله علیه و آله) بقومی که بازی میکردند بشطرنج فرمود «مٰا هٰذه‌ التمٰاثیل‌ التی أنتم‌ لهٰا عٰاکفون‌» چیست این بتان که شما از برای ایشان نشسته‌اید","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"مر","display":"مَرَّ"},{"kind":"word","token":"بقوم","display":"بِقَوْمٍ"},{"kind":"word","token":"يلعبون","display":"يَلْعَبُونَ"},{"kind":"word","token":"بالشطرنج","display":"بِالشِّطْرَنْجِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"هذه","display":"هٰذِهِ"},{"kind":"word","token":"التماثيل","display":"التَّمٰاثِيلُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"انتم","display":"اَنْتُمْ"},{"kind":"word","token":"لها","display":"لَهٰا"},{"kind":"word","token":"عاكفون","display":"عٰاكِفُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۵۲","display":"۵۲"},{"kind":"tag_close","tag_name":"footnote"}]}]}