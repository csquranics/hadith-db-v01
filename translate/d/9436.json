َ امَنُوا » </quranic_text>   <footnote> [ الحجرات ۱ ] </footnote>  اَ دَخَلَ فِي ذَلِكَ الْمُنَافِقُونَ مَعَهُمْ قَالَ","translation_segment":"آنچه خداوند مومنین را خوانده است از این که فرموده است: «ای کسانی که ایمان آورده‌اید» آیا منافقان هم در این خطاب وارد میشوند (و خطاب شامل آنان نیز گردد)؟ فرمود: آری و شامل گمراهان نیز گردد، و شامل هر کس که","segment_columns":[{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"رايت","display":"رَاَيْتَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"ندب","display":"نَدَبَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحجرات","display":"الحجرات"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"المنافقون","display":"الْمُنَافِقُونَ"},{"kind":"word","token":"معهم","display":"مَعَهُمْ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"نَعَمْ وَ الضُّلاَّلُ وَ كُلُّ مَنْ اَقَرَّ بِالدَّعْوَةِ الظَّاهِرَةِ وَ كَانَ اِبْلِيسُ مِمَّنْ اَقَر