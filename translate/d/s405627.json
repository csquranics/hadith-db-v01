anic_text>   <footnote> [ النساء ۱۵۳ ] </footnote> فَلَمَّا وَجَدْنَا اِخْتِيَارَ مَنْ قَدِ اِصْطَفَاهُ اللَّهُ لِلنُّبُوَّةِ وَاقِعاً عَلَي الْاَفْسَدِ دُونَ الْاَصْلَحِ ،  وَ هُوَ يَظُنُّ اَنَّهُ الْاَصْلَحُ دُونَ الْاَفْسَدِ ،  عَلِمْنَا اَنَّ الاِخْتِيَارَ لَيْسَ اِلاَّ لِمَنْ يَعْلَمُ مَا تُخْفِي الصُّدُورُ ،  وَ مَا تُكِنُّ الضَّمَائِرُ وَ تَنْصَرِفُ عَلَيْهِ السَّرَائِرُ ،  وَ اَنْ لاَ خَطَرَ لاِخْتِيَارِ الْمُهَاجِرِينَ وَ الْاَنْصَارِ بَعْدَ وُقُوعِ خِيَرَةِ الْاَنْبِيَاءِ عَلَي ذَوِي الْفَسَادِ لَمَّا اَرَادُوا اَهْلَ الصَّلاَحِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"كليم","display":"كَلِيمُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"وفور","display":"وُفُورِ"},{"kind":"word","token":"عقله","display":"عَقْلِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كمال","display":"كَمَالِ"},{"kind":"word","token":"علمه","display":"عِلْمِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نزول","display":"نُزُولِ"},{"kind":"word","token":"الوحي","display":"الْوَحْيِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"اختار","display":"اِخْتَارَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اعيان","display":"اَعْيَانِ"},{"kind":"word","token":"قومه","display":"قَوْمِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وجوه","display":"وُجُوهِ"},{"kind":"word","token":"عسكره","display":"عَسْكَرِهِ"},{"kind":"word","token":"لميقات","display":"لِمِيقَاتِ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},{"kind":"word","token":"سبعين","display":"سَبْعِينَ"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"ممن","display":"مِمَّنْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يشك","display":"يَشُكُّ"},{"