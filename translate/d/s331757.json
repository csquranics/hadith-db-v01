{"consensus_set_id":"s331757","translation_language":"fa","translation_source":{"hid":"331757"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « فَسْئَلُوا اَهْلَ الذِّكْرِ » </quranic_text>   <footnote> [ النحل ۴۳ ] </footnote>","translation_segment":"عن أبی جعفر فی قوله تعالی: (فاسألوا أهل الذکر) قال: هم الأئمه من عتره رسول الله صلی الله","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فسئلوا","display":"فَسْئَلُوا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"الذكر","display":"الذِّكْرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النحل","display":"النحل"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ :  هُمُ الْاَئِمَّةُ مِنْ عِتْرَةِ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ","translation_segment":"علیه و آله و سلم، و تلا (و أنزلنا علیکم ذکرا رسولا) ابو جعفر درباره سخن خداوند: «فاسألوا","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"الائمه","display":"الْاَئِمَّةُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عتره","display":"عِتْرَةِ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"}]},{"source_hadith_segment":"،  وَ تَلاَ وَ اَنْزَلْنَا عَلَيْكُمْ  <quranic_text> « ذِكْراً رَسُولاً » </quranic_text>   <footnote> [ الطلاق ۱۰ ] </footnote>   .","translation_segment":"اهل الذکر» گفت: آنان امامان از عترت پیامبر خدا هستند و این آیه را تلاوت کرد: «و انزلنا علیکم ذکرا رسولا».","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تلا","display":"تَلاَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انزلنا","display":"اَنْزَلْنَا"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ذكرا","display":"ذِكْراً"},{"kind":"word","token":"رسولا","display":"رَسُولاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الطلاق","display":"الطلاق"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"}]}]}