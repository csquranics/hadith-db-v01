{"consensus_set_id":"8426","translation_language":"fa","translation_source":{"hid":"337465"},"segments":[{"source_hadith_segment":"اِنَّمَا  <quranic_text> « اِتَّخَذَ اللّٰهُ » </quranic_text>   <footnote> [ النساء ۱۲۵ ] </footnote>  عَزَّ وَ جَلَّ  <quranic_text> «  اِبْرٰاهِيمَ خَلِيلاً » </quranic_text>   <footnote> [ النساء ۱۲۵ ] </footnote>  لِكَثْرَةِ صَلاَتِهِ عَلَي مُحَمَّدٍ وَ اَهْلِ بَيْتِهِ صَلَوَاتُ اللَّهِ عَلَيْهِمْ  .","translation_segment":"احمد بن محمد شیبانی رضی اللٰه عنه می‌گوید: محمد بن احمد اسدی کوفی، از سهل بن زیاد آدمی، از عبد العظیم بن عبد اللٰه الحسنی نقل کرده که وی فرمود: از حضرت علی بن محمد العسکری علیه السلام شنیدم که می‌فرمودند: خداوند عز و جل‌ حضرت ابراهیم را به خاطر این که زیاد بر محمد و اهل بیتش صلوات اللٰه علیهم درود و صلوات می‌فرستاد خلیل و دوست خود قرار داد.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اتخذ","display":"اِتَّخَذَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۵","display":"۱۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ابراهيم","display":"اِبْرٰاهِيمَ"},{"kind":"word","token":"خليلا","display":"خَلِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۵","display":"۱۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"لكثره","display":"لِكَثْرَةِ"},{"kind":"word","token":"صلاته","display":"صَلاَتِهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","to