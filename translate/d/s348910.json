{"consensus_set_id":"s348910","translation_language":"fa","translation_source":{"hid":"348910"},"segments":[{"source_hadith_segment":"اَللَّهُمَّ اِنَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « الْحَيُّ الْقَيُّومُ » </quranic_text>   <footnote> [ البقرة ۲۵۵ ] </footnote>  الْعَلِيمُ الْعَظِيمُ الْحَلِيمُ الْكَرِيمُ الْخَالِقُ الرَّازِقُ الْمُحْيِي الْمُمِيتُ الْبَدِيءُ الْبَدِيعُ","translation_segment":"اللهم‌، إنه لا إله إلا أنت الحی‌ القیوم العلیم العظیم الحلیم الکریم الخالق الرازق المحیی الممیت البدیء البدیع، لک الحمد و لک الکرم، و لک المن‌ و لک الجود، و الأمر وحدک لا شریک لک. یا واحد، یا أحد، یا صمد، یا من «لم‌ یلد و لم‌ یولد`و لم‌ یکن‌ له‌ کفوا أحد»، و لم یتخذ صاحبه و لا ولدا، صل علی محمد و آله، و افعل بی کذا و کذا.». -خداوندا،","segment_columns":[{"kind":"word","token":"اللهم","display":"اَللَّهُمَّ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اله","display":"اِلَهَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحي","display":"الْحَيُّ"},{"kind":"word","token":"القيوم","display":"الْقَيُّومُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۵۵","display":"۲۵۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"العليم","display":"الْعَلِيمُ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمُ"},{"kind":"word","token":"الحليم","display":"الْحَلِيمُ"},{"kind":"word","token":"الكريم","display":"الْكَرِيمُ"},{"kind":"word","token":"الخالق","display":"الْخَالِقُ"},{"kind":"word","token":"الرازق","display":"الرَّازِقُ"},{"kind":"word","token":"المحيي","display":"الْمُحْيِي"},{"kind":"word","token":"المميت","display":"الْمُمِيتُ"},{"kind":"word","token":"البديء","display":"الْبَدِيءُ"},{"kind":"word","token":"البديع","display":"الْ