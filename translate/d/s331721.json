{"consensus_set_id":"s331721","translation_language":"fa","translation_source":{"hid":"331721"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مَنْ عِنْدَهُ عِلْمُ الْكِتٰابِ » </quranic_text>   <footnote> [ الرعد ۴۳ ] </footnote>  قَالَ :  [ قَالَ ] رَجُلٌ مِنْ قُرَيْشٍ :  هُوَ عَلِيٌّ وَ لَكِنَّا لاَ نُسَمِّيهِ .","translation_segment":"عن أبی صالح فی قوله عز و جل‌: (و من عنده علم الکتاب) قال: قال رجل من قریش: هو علی‌ و لکنا لا نسمیه. ابو صالح درباره سخن خداوند: «و من عنده علم الکتاب» گفت: مردی از قریش و او علی است ولی ما نام او را نمی‌بریم.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"علم","display":"عِلْمُ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قريش","display":"قُرَيْشٍ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكنا","display":"لَكِنَّا"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"نسميه","display":"نُسَمِّيهِ"}]}]}