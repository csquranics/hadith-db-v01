{"consensus_set_id":"1624","translation_language":"fa","translation_source":{"hid":"99588"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ مَا حَدُّ الْجِزْيَةِ عَلَي اَهْلِ الْكِتَابِ وَ هَلْ عَلَيْهِمْ فِي ذَلِكَ شَيْءٌ مُوَظَّفٌ لاَ يَنْبَغِي اَنْ يَجُوزَ اِلَي غَيْرِهِ","translation_segment":"و حریز از زراره روایت کرده است که گفت: به امام صادق علیه السلام معروض داشتم که: حد جزیه بر اهل کتاب چیست و آیا در این باره مبلغ معینی بر عهده دارند که سزاوار نیست از آن بغیر آن تجاوز کنند؟ پس امام","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"حد","display":"حَدُّ"},{"kind":"word","token":"الجزيه","display":"الْجِزْيَةِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الجزيه","display":"الْجِزْيَةِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"موظف","display":"مُوَظَّفٌ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ينبغي","display":"يَنْبَغِي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"لا","display":"لا"},{"kind":"word","token":"يجو