{"consensus_set_id":"51034","translation_language":"fa","translation_source":{"hid":"410003"},"segments":[{"source_hadith_segment":"فِي رِسَالَتِهِ اِلَي اَهْلِ الْاَهْوَازِ حِينَ سَاَلُوهُ عَنِ الْجَبْرِ وَ التَّفْوِيضِ - وَ ذَكَرَ الرِّسَالَةَ اِلَي اَنْ قَالَ ( عَلَيْهِ السَّلاَمُ ) :","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"رسالته","display":"رِسَالَتِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الاهواز","display":"الْاَهْوَازِ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"سالوه","display":"سَاَلُوهُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الجبر","display":"الْجَبْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"التفويض","display":"التَّفْوِيضِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"الرساله","display":"الرِّسَالَةَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]},{"source_hadith_segment":"- « [ فَاِنْ قَالُوا مَا الْحُجَّةُ فِي قَوْلِ اللَّهِ تَعَالَي :  ]  <quranic_text> « فَيُضِلُّ اللّٰهُ مَنْ يَشٰاءُ وَ يَهْدِي مَنْ يَشٰاءُ » </quranic_text>   <footnote> [ ابراهيم ۴ ] </footnote>   ،  وَ مَا اَشْبَهَ ذَلِكَ ؟  قُلْنَا :  فَعَلَي مَجَازِ هَذِهِ الْايَةِ يَقْتَضِي مَعْنَيَيْنِ :  اَحَدُهُمَا :  اَنَّهُ اِخْبَارٌ عَنْ كَوْنِهِ تَعَالَي قَادِراً عَلَي هِدَايَةِ مَنْ يَشَاءُ وَ ضَلاَلَةِ مَنْ يَشَاءُ ،  وَ لَوْ اَجْبَرَهُمْ عَلَي اَحَدِهِمَا لَمْ يَجِبْ لَهُمْ ثَوَابٌ ،  وَ لاَ عَلَيْهِمْ عِقَابٌ ،  عَلَي مَا شَرَحْنَاهُ .  وَ الْمَعْنَي الْاخَرُ :  اَنَّ الْهِدَايَةَ مِنْهُ :  التَّعْرِيفُ ،  كَقَوْلِهِ تَعَالَي :   <quranic_text> « وَ اَمّٰا ثَمُودُ فَهَدَيْنٰاهُمْ فَاسْتَحَبُّوا الْعَميٰ عَلَي الْهُديٰ » </quranic_text>   <footnote> [ فصلت ۱۷ ] </footnote> .  وَ لَيْسَ كُلُّ ايَةٍ مُشْتَبِهَةً فِي الْقُرْانِ كَانَتِ الْايَةُ حُجَّةً عَلَي حُكْمِ الْايَاتِ اللاَّتِي اُمِرَ بِالْاَخْذِ بِهَا وَ تَقْلِيدِهَا ،  وَ هِيَ قَوْلُهُ :   <quranic_text> « هُوَ الَّذِي اَنْزَلَ عَلَيْكَ الْكِتٰابَ مِنْهُ ايٰاتٌ مُحْكَمٰاتٌ هُنَّ اُمُّ الْكِتٰابِ وَ اُخَرُ مُتَشٰابِهٰاتٌ فَاَمَّا الَّذِينَ فِي قُلُوبِهِمْ زَيْغٌ فَيَتَّبِعُونَ مٰا تَشٰابَهَ مِنْهُ اِبْتِغٰاءَ الْفِتْنَةِ وَ اِبْتِغٰاءَ تَاْوِيلِهِ » </quranic_text>   <footnote> [ العمران ۷ ] </footnote>  الْايَةَ ،  وَ قَالَ :   <quranic_text> « فَبَشِّرْ عِبٰادِ الَّذِينَ يَسْتَمِعُونَ الْقَوْلَ فَيَتَّبِعُونَ اَحْسَنَهُ اُولٰئِكَ الَّذِينَ هَدٰاهُمُ اللّٰهُ وَ اُولٰئِكَ هُمْ اُولُوا الْاَلْبٰابِ » </quranic_text>   <footnote> [ الزمر ۱۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"الحجه","display":"الْحُجَّةُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فيضل","display":"فَيُضِلُّ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يشاء","display":"يَشٰاءُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يهدي","display":"يَهْدِي"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يشاء","display":"يَشٰاءُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۴","