{"consensus_set_id":"42439","translation_language":"fa","translation_source":{"hid":"404410"},"segments":[{"source_hadith_segment":"« اَلْمُرَادُ بِقَوْلِهِ تَعَالَي :   <quranic_text> « قَوْمٍ بَيْنَكُمْ وَ بَيْنَهُمْ مِيثٰاقٌ » </quranic_text>   <footnote> [ النساء ۹۰ ] </footnote>  هُوَ هِلاَلُ بْنُ عُوَيْمِرَ السُّلَمِيُّ وَاثَقَ عَنْ قَوْمِهِ رَسُولَ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  وَ قَالَ فِي مُوَادَعَتِهِ :  عَلَي اَنْ لاَ تُخِيفَ - يَا مُحَمَّدُ - مَنْ اَتَانَا ،  وَ لاَ نُخِيفَ مَنْ اَتَاكَ .  فَنَهَي اللَّهُ سُبْحَانَهُ اَنْ يَتَعَرَّضَ لِاَحَدٍ مِنْهُمْ عَهِدَ اِلَيْهِمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"المراد","display":"اَلْمُرَادُ"},{"kind":"word","token":"بقوله","display":"بِقَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قوم","display":"قَوْمٍ"},{"kind":"word","token":"بينكم","display":"بَيْنَكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بينهم","display":"بَيْنَهُمْ"},{"kind":"word","token":"ميثاق","display":"مِيثٰاقٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۹۰","display":"۹۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"هلال","display":"هِلاَلُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"عويمر","display":"عُوَيْمِرَ"},{"kind":"word","token":"السلمي","display":"السُّلَمِيُّ"},{"kind":"word","token":"واثق","display":"وَاثَقَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قومه","display":"قَوْمِهِ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَي