{"consensus_set_id":"33372","translation_language":"fa","translation_source":{"hid":"110023"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « لاٰ خَيْرَ فِي كَثِيرٍ مِنْ نَجْوٰاهُمْ اِلاّٰ مَنْ اَمَرَ بِصَدَقَةٍ اَوْ مَعْرُوفٍ » </quranic_text>   <footnote> [ النساء ۱۱۴ ] </footnote>  قَالَ يَعْنِي بِالْمَعْرُوفِ الْقَرْضَ .","translation_segment":"ابراهیم بن عبد الحمید گوید: امام صادق علیه السلام درباره گفتار خدای تعالی که می‌فرماید: «خیری در بیشتر نجواهای آنان نیست مگر کسی‌که به صدقه یا کار نیکی بین مردم امر کند» فرمود: معروف و کار نیک همان وام دادن است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"خير","display":"خَيْرَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كثير","display":"كَثِيرٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"نجواهم","display":"نَجْوٰاهُمْ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"امر","display":"اَمَرَ"},{"kind":"word","token":"بصدقه","display":"بِصَدَقَةٍ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"معروف","display":"مَعْرُوفٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۱۴","display":"۱۱۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"بالمعروف","display":"بِالْمَعْرُوفِ"},{"kind":"word","token":"القرض","display":"الْقَرْضَ"}]}]}