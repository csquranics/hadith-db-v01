{"consensus_set_id":"s199098","translation_language":"fa","translation_source":{"hid":"199098"},"segments":[{"source_hadith_segment":"اَوْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَالَ :  سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ تَعَالَي  <quranic_text> « اِنَّ الصَّلاٰةَ كٰانَتْ عَلَي الْمُؤْمِنِينَ كِتٰاباً مَوْقُوتاً » </quranic_text>   <footnote> [ النساء ۱۰۳ ] </footnote>  قَالَ كِتَابٌ وَاجِبٌ الْخَبَرَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةَ"},{"kind":"word","token":"كانت","display":"كٰانَتْ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"كتابا","display":"كِتٰاباً"},{"kind":"word","token":"موقوتا","display":"مَوْقُوتاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۰۳","display":"۱۰۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كتاب","display":"كِتَابٌ"},{"kind":"word","token":"واجب","display":"وَاجِبٌ"},{"kind":"word","token":"الخبر","display":"الْخَبَرَ"}]}]}