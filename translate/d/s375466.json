{"consensus_set_id":"s375466","translation_language":"fa","translation_source":{"hid":"375466"},"segments":[{"source_hadith_segment":"مَا مِنْ عَبْدٍ يَقْرَاُ اخِرَ الْكَهْفِ  <quranic_text> « قُلْ اِنَّمٰا اَنَا بَشَرٌ مِثْلُكُمْ » </quranic_text>   <footnote> [ الكهف ۱۱۰ ] </footnote>  اِلَي اخِرِهَا حِينَ يَنَامُ اِلاَّ اِسْتَيْقَظَ فِي السَّاعَةِ الَّتِي يُرِيدُ .","translation_segment":"از امام ششم (علیه السلام): هیچ بنده‌ای آیه آخر سوره کهف («قل‌ إنمٰا أنا بشر مثلکم‌» …) را وقت خواب نخواند مگر آنکه در ساعتی که دوست دارد از خواب بر خواهد خاست.","segment_columns":[{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عبد","display":"عَبْدٍ"},{"kind":"word","token":"يقرا","display":"يَقْرَاُ"},{"kind":"word","token":"اخر","display":"اخِرَ"},{"kind":"word","token":"الكهف","display":"الْكَهْفِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"بشر","display":"بَشَرٌ"},{"kind":"word","token":"مثلكم","display":"مِثْلُكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","token":"۱۱۰","display":"۱۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"اخرها","display":"اخِرِهَا"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"ينام","display":"يَنَامُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"استيقظ","display":"اِسْتَيْقَظَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الساعه","display":"السَّاعَةِ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"يريد","display":"يُرِيدُ"}]}]}