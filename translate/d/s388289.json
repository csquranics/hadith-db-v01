{"consensus_set_id":"s388289","translation_language":"fa","translation_source":{"hid":"388289"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ جَلَّ وَ عَزَّ  <quranic_text> « فَمِنْكُمْ كٰافِرٌ وَ مِنْكُمْ مُؤْمِنٌ » </quranic_text>   <footnote> [ التغابن ۲ ] </footnote>  قَالَ :  قَالَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ  :  « اَخَذَ اللَّهُ اِيمَانَهُمْ بِوَلاَيَتِنَا يَوْمَ اَخَذَ عَلَيْهِمُ الْمِيثَاقَ فِي صُلْبِ ادَمَ عَلَيْهِ السَّلاَمُ وَ هُمْ ذَرٌّ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمنكم","display":"فَمِنْكُمْ"},{"kind":"word","token":"كافر","display":"كٰافِرٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التغابن","display":"التغابن"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"ايمانهم","display":"اِيمَانَهُمْ"},{"kind":"word","token":"بولايتنا","display":"بِوَلاَيَتِنَا"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"عليهم","display":"عَلَيْ