{"consensus_set_id":"67858","translation_language":"fa","translation_source":{"hid":"336786"},"segments":[{"source_hadith_segment":"اَلاَ صَلَوَاتُ اللَّهِ عَلَي الْمُتَسَحِّرِينَ  <quranic_text> « وَ الْمُسْتَغْفِرِينَ بِالْاَسْحٰارِ » </quranic_text>   <footnote> [ العمران ۱۷ ] </footnote>   .","translation_segment":"و از معصومین-علیهم السلام-روایت شده است که فرمودند: «هان! درود خدا بر سحرخیزان و استغفارکنندگان در سحرها».","segment_columns":[{"kind":"word","token":"الا","display":"اَلاَ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المتسحرين","display":"الْمُتَسَحِّرِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المستغفرين","display":"الْمُسْتَغْفِرِينَ"},{"kind":"word","token":"بالاسحار","display":"بِالْاَسْحٰارِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"}]}]}