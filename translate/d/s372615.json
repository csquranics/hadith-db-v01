{"consensus_set_id":"s372615","translation_language":"fa","translation_source":{"hid":"372615"},"segments":[{"source_hadith_segment":"وَ بَعْدَ فَرَاغِكَ مِنَ الرَّكْعَتَيْنِ الْاُولَيَيْنِ تَقُولُ اللَّهُمَّ اِنَّهُ لاَ اِلَهَ اَنْتَ الْحَيُّ الْقَيُّومُ - الْعَلِيُّ الْعَظِيمُ الْحَلِيمُ الْكَرِيمُ الْخَالِقُ الرَّازِقُ الْمُحْيِي الْمُمِيتُ الْبَدِيءُ الْبَدِيعُ لَكَ الْحَمْدُ وَ لَكَ الْمَنُّ وَ لَكَ الْجُودُ وَ لَكَ الْكَرَمُ وَ الْجُودُ وَ لَكَ الْاَمْرُ وَحْدَكَ لاَ شَرِيكَ لَكَ يَا وَاحِدُ يَا اَحَدُ يَا فَرْدُ يَا صَمَدُ يَا مَنْ  <quranic_text> « لَمْ يَلِدْ وَ لَمْ يُولَدْ وَ لَمْ يَكُنْ لَهُ كُفُواً اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۳ ] </footnote>  وَ لَمْ يَتَّخِذْ  <quranic_text> « صٰاحِبَةً وَ لاٰ وَلَداً » </quranic_text>   <footnote> [ الجن ۳ ] </footnote>  صَلِّ عَلَي مُحَمَّدٍ وَ الِهِ وَ اِفْعَلْ بِي كَذَا وَ كَذَا .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"فراغك","display":"فَرَاغِكَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الركعتين","display":"الرَّكْعَتَيْنِ"},{"kind":"word","token":"الاوليين","display":"الْاُولَيَيْنِ"},{"kind":"word","token":"تقول","display":"تَقُولُ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اله","display":"اِلَهَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"الحي","display":"الْحَيُّ"},{"kind":"word","token":"القيوم","display":"الْقَيُّومُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"العلي","display":"الْعَلِيُّ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمُ"},{"kind":"word","token":"الحليم","display":"الْحَلِيمُ"},{"kind":"word","token":"الكريم","display":"الْكَرِيمُ"},{"kind":"word","token":"الخالق","display":"الْخَالِقُ"},{"kind":"word","token":"الرازق","display":"ال