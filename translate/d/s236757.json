":"و","display":"وَ"},{"kind":"word","token":"دمدموا","display":"دَمْدَمُوا"}]},{"source_hadith_segment":".  فَلَمَّا رَجَعَ اَبُو بَكْرٍ اِلَي مَنْزِلِهِ بَعَثَ اِلَي عُمَرَ فَقَالَ :  وَيْحَكَ يَا اِبْنَ الْخَطَّابِ !  اَ مَا رَاَيْتَ عَلِيّاً وَ مَا فَعَلَ بِنَا ؟  وَ اللَّهِ لَئِنْ قَعَدَ مَقْعَداً اخَرَ لَيُفْسِدَنَّ هَذَا الْاَمْرَ عَلَيْنَا وَ لاَ نَتَهَنَّاُ بِشَيْءٍ مَا دَامَ حَيّاً","translation_segment":"","segment_columns":[{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"رجع","display":"رَجَعَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"بكر","display":"بَكْرٍ"},{"kind":"word","token":"الي","display":"اِلَي"}]},{"source_hadith_segment":".  قَالَ عُمَرُ :  مَا لَهُ اِلاَّ خَالِدُ بْنُ الْوَلِيدِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَبَعَثُوا اِلَيْهِ ،  فَقَالَ لَهُ اَبُو بَكْرٍ :  نُرِيدُ اَنْ نَحْمِلَكَ عَلَي اَمْرٍ عَظِيمٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قَالَ :  اِحْمِلْنِي عَلَي مَا شِئْتَ وَ لَوْ عَلَي قَتْلِ عَلِيٍّ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قَالَ :  فَهُوَ قَتْلُ عَلِيٍّ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قَالَ :  فَصْرِ بِجَنْبِهِ ،  فَاِذَا اَنَا سَلَّمْتُ فَاضْرِبْ عُنُقَهُ .  [ فَبَعَثَتْ ] اَسْمَاءُ بِنْتُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"عُمَيْسٍ - وَ هِيَ اُمُّ مُحَمَّدِ بْنِ اَبِي بَكْرٍ - خَادِمَتَهَا فَقَالَتْ :  اِذْهَبِي اِلَي فَاطِمَةَ فَاَقْرِئِيهَا السَّلاَمَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِذَا دَخَلَتْ مِنَ الْبَابِ فَقُولِي :   <quranic_text> « اِنَّ الْمَلَاَ يَاْتَمِرُونَ بِكَ لِيَقْتُلُوكَ فَاخْرُجْ اِنِّي لَكَ مِنَ النّٰاصِحِينَ » </quranic_text>   <footnote> [ القصص ۲۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنْ فَهِمَتْهَا وَ اِلاَّ فَاَعِيدِيهَا مَرَّةً اُخْرَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَجَاءَتْ فَدَخَلَتْ ،  وَ قَالَتْ :  اِنَّ مَوْلاَتِي تَقُولُ يَا بِنْتَ رَسُولِ اللَّهِ كَيْفَ اَنْتَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  ثُمَّ قَرَاَتْ هَذِهِ الْايَةَ :   <quranic_text> « اِنَّ الْمَلَاَ يَاْتَمِرُونَ بِكَ لِيَقْتُلُوكَ » </quranic_text>   <footnote> [ القصص ۲۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَلَمَّا اَرَادَتْ اَنْ تَخْرُجَ قَرَاَتْهَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالَ لَهَا اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ :  اَقْرِئِيهَا السَّلاَمَ وَ قُولِي لَهَا :  اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَحُولُ بَيْنَهُمْ وَ بَيْنَ مَا يُرِيدُونَ اِنْ شَاءَ اللَّهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَوَقَفَ خَالِدُ بْنُ الْوَلِيدِ بِجَنْبِهِ ،  فَلَمَّا اَرَادَ اَنْ يُسَلِّمَ لَمْ يُسَلِّمْ ،  [ وَ ] قَالَ :  يَا خَالِدُ !  لاَ تَفْعَلْ مَا اَمَرْتُكَ ،  السَّلاَمُ عَلَيْكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ :  مَا هَذَا الَّذِي اَمَرَكَ بِهِ ثُمَّ نَهَاكَ قَبْلَ اَنْ يُسَلِّمَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  قَالَ :  اَمَرَنِي بِضَرْبِ عُنُقِكَ ،  وَ اِنَّمَا اَمَرَنِي بَعْدَ التَّسْلِيمِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالَ :  وَ كُنْتَ فَاعِلاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  فَقَالَ :  اِي وَ اللَّهِ ،  لَوْ لَمْ يَنْهَنِي لَفَعَلْتُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قَالَ :  فَقَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ فَاَخَذَ بِمَجَامِعِ ثَوْبِ خَالِدٍ ،  ثُمَّ ضَرَبَ بِهِ الْحَائِطَ ،  وَ قَالَ لِعُمَرَ :  يَا اِبْنَ الصُّهَاكِ !  وَ اللَّهِ لَوْ لاَ عَهْدٌ مِنْ رَسُولِ اللَّهِ وَ  <quranic_text>