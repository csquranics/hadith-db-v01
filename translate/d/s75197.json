نْ ظَاهِرِ قَدَمِهِ ،  فَوَرِمَتْ رِجْلُهُ فَمَاتَ","translation_segment":"عبور کرد و جبرئیل بطرف پای او اشاره کرد در این هنگام میخی بکف پای او فرو رفت، و از پشت پا بیرون شد، و در نتیجه پای او ورم کرد و درگذشت. طلاطله نیز از نزدیکی پیغمبر","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"مر","display":"مَرَّ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"العاص","display":"الْعَاصُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"الوائل","display":"الوائل"},{"kind":"word","token":"فاشار","display":"فَاَشَارَ"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"رجله","display":"رِجْلِهِ"},{"kind":"word","token":"فدخلت","display":"فَدَخَلَتْ"},{"kind":"word","token":"جذله","display":"جِذْلَةٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اخمص","display":"اَخْمَصِ"},{"kind":"word","token":"قدميه","display":"قَدَمَيْهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"خرجت","display":"خَرَجَتْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ظاهر","display":"ظَاهِرِ"},{"kind":"word","token":"قدمه","display":"قَدَمِهِ"},{"kind":"word","token":"فورمت","display":"فَوَرِمَتْ"},{"kind":"word","token":"رجله","display":"رِجْلُهُ"},{"kind":"word","token":"فمات","display":"فَمَاتَ"}]},{"source_hadith_segment":".  و مرّ به [ ابن ] الطَّلاَطِلَةُ ،  فَتَفَلَ جَبْرَئِيلُ فِي وَجْهِهِ فَخَرَجَ اِلَي جِبَالِ تِهَامَةَ فاصابه السمائم فَاحْتَرَقَ و اِسْوَدَّ ،  فَرَجَعَ اِلَي مَنْزِلِهِ فَلَمْ يَدَعُوهُ اَنْ يَدْخُلَ و قَالُوا :  لَسْتَ بِصَاحِبِنَا ،  فَخَرَجَ مِنْ مَنْزِلِهِ فَاَصَابَهُ الْعَطَشُ فَمَا زَالَ يَسْتَسْقِي حَتَّي اِنْشَقَّ بَطْنُهُ و هُوَ قَوْلُ اللَّهِ تَعَالَي :   <quranic_text> « اِنّٰا كَفَيْنٰاكَ الْمُسْتَهْزِئِينَ » </quranic_text>   <footnote> [ الحجر ۹۵ ] </footnote>   .","translation_segment":"عبور کرد، جبرئیل آب دهان بصورت او افکند، وی بطرف کوه تهامه بیرون شد، و گرفتار باد سموم گردید. در این هنگام از شدت حرارت چهره‌اش سوخت و سیاه شد، و هنگامی که بطرف منزلش مراجعت کرد، وی را از ورود در منزل منع کردند، و گفتند: تو صاحب ما نیستی! او پس از این از منزل بیرون شد و گرفتار تشنگی گردید، و همواره در طلب آب بود تا شکمش از هم شکافته شد آیه شریفه: «إنٰا کفینٰاک‌ المستهزئین‌» ناظر به این افراد است که حضرت را استهزاء میکردند.","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"مر","display":"مرّ"},{"kind":"word","token":"به","display":"به"},{"kind":"word","token":"ابن","display":"ابن"},{"kind":"word","token":"الطلاطله","display":"الطَّلاَطِلَةُ"},{"kind":"word","token":"فتفل","display":"فَتَفَلَ"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"وجهه","display":"وَجْهِهِ"},{"kind":"word","token":"فخرج","display":"فَخَرَجَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"جبال","display":"جِبَالِ"},{"kind":"word","token":"تهامه","display":"تِهَامَةَ"},{"kind":"word","token":"فاصابه","display":"فاصابه"},{"kind":"word","token":"السمائم","display":"السمائم"},{"kind":"word","token":"فاحترق","display":"فَاحْتَرَقَ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اسود","display":"اِسْوَدَّ"},{"kind":"word","token":"فرجع","display":"فَرَجَعَ"},{"kind":"word","token":"الي","display":"اِلَي"}]}]}