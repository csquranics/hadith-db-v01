{"consensus_set_id":"s273360","translation_language":"fa","translation_source":{"hid":"273360"},"segments":[{"source_hadith_segment":"اَنَّهُ سُئِلَ عَنْ قَوْلِهِ <quranic_text>«وَ سَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوعِ الشَّمْسِ وَ قَبْلَ الْغُرُوبِ»</quranic_text> <footnote>[ق۳۹]</footnote> فَقَالَ تَقُولُ حِينَ تُصْبِحُ وَ حِينَ تُمْسِي عَشْرَ مَرَّاتٍ لاَ اِلَهَ اِلاَّ اللَّهُ وَحْدَهُ <quranic_text>«لاٰ شَرِيكَ لَهُ»</quranic_text> <footnote>[الانعام۱۶۳]</footnote> - <quranic_text>«لَهُ الْمُلْكُ وَ لَهُ الْحَمْدُ»</quranic_text> <footnote>[التغابن۱]</footnote> <quranic_text>«يُحْيِي وَ يُمِيتُ»</quranic_text> <footnote>[العمران۱۵۶]</footnote> وَ يُمِيتُ وَ يُحْيِي - <quranic_text>«وَ هُوَ عَليٰ كُلِّ شَيْءٍ قَدِيرٌ»</quranic_text> <footnote>[التغابن۱]</footnote> .","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سبح","display":"سَبِّحْ"},{"kind":"word","token":"بحمد","display":"بِحَمْدِ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"طلوع","display":"طُلُوعِ"},{"kind":"word","token":"الشمس","display":"الشَّمْسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"الغروب","display":"الْغُرُوبِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ق۳۹","display":"ق۳۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"تقول","display":"تَقُولُ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"تصبح","display":"تُصْبِحُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"w