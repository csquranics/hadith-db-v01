{"consensus_set_id":"4368","translation_language":"fa","translation_source":{"hid":"373879"},"segments":[{"source_hadith_segment":"اَنَّهُ قَالَ لِرَجُلٍ مِنْ اَصْحَابِهِ اِذَا اَرَدْتَ الْحِجَامَةَ وَ خَرَجَ الدَّمُ مِنْ مَحَاجِمِكَ فَقُلْ قَبْلَ اَنْ تَفْرُغَ وَ الدَّمُ يَسِيلُ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  اَعُوذُ بِاللَّهِ الْكَرِيمِ فِي حِجَامَتِي هَذِهِ مِنَ الْعَيْنِ فِي الدَّمِ وَ مِنْ كُلِّ سُوءٍ فَاِنَّكَ اِذَا قُلْتَ هَذَا فَقَدْ جَمَعْتَ الْخَيْرَ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ فِي كِتَابِهِ  <quranic_text> « وَ لَوْ كُنْتُ اَعْلَمُ الْغَيْبَ لاَسْتَكْثَرْتُ مِنَ الْخَيْرِ وَ مٰا مَسَّنِيَ السُّوءُ » </quranic_text>   <footnote> [ الاعراف ۱۸۸ ] </footnote>   .","translation_segment":"و فرمود وقتی حجامت میکنی و خون از جای حجامت بیرون زد، قبل از تمام شدن حجامت بهنگام روان بودن خون بگو: (بسم اللٰه الرحمن الرحیم- در این حجامت از چشم زخم و هر بدی بخداوند کریم پناه میبرم) که با این همه دعا همه چیز را بدست می‌آوری که خداوند در قرآن میفرماید (اگر از غیب خبر می‌داشتم بر خیرها میافزودم، و هیچ بدی را بخود راه نمیدادم).","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"الباقر","display":"الْبَاقِرُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"لرجل","display":"لِرَجُلٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اصحابه","display":"اَصْحَابِهِ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اردت","display":"اَرَدْتَ"},{"kind":"word","token":"الحجامه","display":"الْحِجَامَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"خرج","display":"خَرَجَ"},{"kind":"word","token":"الدم","display":"الدَّمُ"},{"kind":"word","token":"من","disp