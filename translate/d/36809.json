َا ظَهَرَتْ كَلِمَةُ النِّفَاقِ وَ سُيِّرَتْ رَايَاتُ اَهْلِ الشِّقَاقِ وَ تَكَالَبَتْ جُيُوشُ اَهْلِ الْمَرَاقِّ مِنَ الشَّامِ وَ الْعِرَاقِ هَلُمُّوا رَحِمَكُمُ اللَّهُ اِلَي الاِفْتِتَاحِ وَ النُّورِ الْوَضَّاحِ وَ الْعِلْمِ الْجَحْجَاحِ وَ النُّورِ الَّذِي لاَ يُطْفَي وَ الْحَقِّ الَّذِي لاَ يَخْفَي اَيُّهَا النَّاسُ تَيَقَّظُوا مِنْ رَقْدَةِ الْغَفْلَةِ وَ مِنْ تَكَاثُفِ الظُّلْمَةِ فَوَ الَّذِي فَلَقَ الْحَبَّةَ وَ بَرَاَ النَّسَمَةَ وَ تَرَدَّي بِالْعَظَمَةِ لَئِنْ قَامَ اِلَيَّ مِنْكُمْ عَصَبَةٌ بِقُلُوبٍ صَافِيَةٍ وَ نِيَّاتٍ مُخْلِصَةٍ - لاَ يَكُونُ فِيهَا شَوْبُ نِفَاقٍ وَ لاَ نِيَّةُ اِفْتِرَاقٍ لَاُجَاهِدَنَّ بِالسَّيْفِ قُدُماً قُدُماً وَ لَاُضِيقَنَّ مِنَ السُّيُوفِ جَوَانِبَهَا وَ مِنَ الرِّمَاحِ اَطْرَافَهَا وَ مِنَ الْخَيْلِ سَنَابِكَهَا فَتَكَلَّمُوا رَحِمَكُمُ اللَّهُ فَكَاَنَّمَا اُلْجِمُوا بِلِجَامِ الصَّمْتِ عَنْ اِجَابَةِ الدَّعْوَةِ اِلاَّ عِشْرُونَ رَجُلاً فَاِنَّهُمْ قَامُوا اِلَيَّ فَقَالُوا يَا اِبْنَ رَسُولِ اللَّهِ مَا نَمْلِكُ اِلاَّ اَنْفُسَنَا وَ سُيُوفَنَا فَهَا نَحْنُ بَيْنَ يَدَيْكَ لِاَمْرِكَ طَائِعُونَ وَ عَنْ رَاْيِكَ صَادِرُونَ فَمُرْنَا بِمَا شِئْتَ فَنَظَرْتُ يَمْنَةً وَ يَسْرَةً فَلَمْ اَرَ اَحَداً غَيْرَهُمْ فَقُلْتُ لِي اُسْوَةٌ بِجَدِّي رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ حِينَ عَبَدَ اللَّهَ","translation_segment":"","segment_columns":[{"kind":"word","token":"فوصاني","display":"فَوَصَّانِي"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"وصيته","display":"وَصَّيْتَهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"جداه","display":"جَدَّاهْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بلغ","display":"بَلَغَ"},{"kind":"word","token":"اللعين","display":"اللَّعِينَ"},{"kind":"word","token":"معاويه","display":"مُعَاوِيَةَ"},{"kind":"word","token":"قتل","display":"قَتْلُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"فانفذ","display":"فَاَنْفَذَ"},{"kind":"word","token":"الدعي","display":"الدَّعِيَّ"},{"kind":"word