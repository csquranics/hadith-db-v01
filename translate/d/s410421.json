{"consensus_set_id":"s410421","translation_language":"fa","translation_source":{"hid":"410421"},"segments":[{"source_hadith_segment":"« لَقَدْ صَلَّتِ الْمَلاَئِكَةُ عَلَيَّ وَ عَلَي عَلِيِّ بْنِ اَبِي طَالِبٍ سَبْعَ سِنِينَ ،  وَ ذَلِكَ اَنَّهُ لَمْ يُؤْمِنْ بِي ذَكَرٌ قَبْلَهُ ،  وَ ذَلِكَ قَوْلُهُ تَعَالَي :   <quranic_text> « الَّذِينَ يَحْمِلُونَ الْعَرْشَ وَ مَنْ حَوْلَهُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ » </quranic_text>   <footnote> [ غافر ۷ ] </footnote>   ،   <quranic_text> « وَ يَسْتَغْفِرُونَ لِمَنْ فِي الْاَرْضِ » </quranic_text>   <footnote> [ الشوري ۵ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"صلت","display":"صَلَّتِ"},{"kind":"word","token":"الملائكه","display":"الْمَلاَئِكَةُ"},{"kind":"word","token":"علي","display":"عَلَيَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"سنين","display":"سِنِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يؤمن","display":"يُؤْمِنْ"},{"kind":"word","token":"بي","display":"بِي"},{"kind":"word","token":"ذكر","display":"ذَكَرٌ"},{"kind":"word","token":"قبله","display":"قَبْلَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يحملون","display":"يَحْمِلُونَ"},{"kind":"word","token":"العر