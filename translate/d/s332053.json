{"consensus_set_id":"s332053","translation_language":"fa","translation_source":{"hid":"332053"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « اِنَّمٰا يَخْشَي اللّٰهَ مِنْ عِبٰادِهِ الْعُلَمٰاءُ » </quranic_text>   <footnote> [ فاطر ۲۸ ] </footnote>  الْعُلَمَاءُ بِاللَّهِ الَّذِينَ يَخَافُونَهُ عَزَّ وَ جَلَّ .","translation_segment":"عن ابن عباس قال: فی قوله تعالی: (إنما یخشی الله من عباده العلماء) العلماء بالله الذین یخافونه عز و جل. ابن عباس درباره سخن خداوند: «انما یخشی الله من عباده العلماء» گفت: دانشمندان الهی کسانی هستند که از خدا می‌ترسند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"يخشي","display":"يَخْشَي"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عباده","display":"عِبٰادِهِ"},{"kind":"word","token":"العلماء","display":"الْعُلَمٰاءُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"فاطر","display":"فاطر"},{"kind":"word","token":"۲۸","display":"۲۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"العلماء","display":"الْعُلَمَاءُ"},{"kind":"word","token":"بالله","display":"بِاللَّهِ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يخافونه","display":"يَخَافُونَهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"}]}]}