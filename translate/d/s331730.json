{"consensus_set_id":"s331730","translation_language":"fa","translation_source":{"hid":"331730"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ نَزَعْنٰا مٰا فِي صُدُورِهِمْ مِنْ غِلٍّ اِخْوٰاناً عَليٰ سُرُرٍ مُتَقٰابِلِينَ » </quranic_text>   <footnote> [ الحجر ۴۷ ] </footnote>","translation_segment":"عن ابن عباس فی قوله تعالی: (و نزعنا ما فی صدورهم من غل‌ إخوانا علی سرر متقابلین) قال: نزلت فی علی‌ بن ابی طالب و حمزه، و جعفر","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نزعنا","display":"نَزَعْنٰا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"صدورهم","display":"صُدُورِهِمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"غل","display":"غِلٍّ"},{"kind":"word","token":"اخوانا","display":"اِخْوٰاناً"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"سرر","display":"سُرُرٍ"},{"kind":"word","token":"متقابلين","display":"مُتَقٰابِلِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"۴۷","display":"۴۷"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ :  نَزَلَتْ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ وَ حَمْزَةَ ،  وَ جَعْفَرٍ وَ عَقِيلٍ وَ اَبِي ذَرٍّ ،  وَ سَلْمَانَ وَ عَمَّارٍ وَ الْمِقْدَادِ ،  وَ الْحَسَنِ وَ الْحُسَيْنِ عَلَيْهِمَا السَّلاَمُ  .","translation_segment":"و عقیل و أبی ذر، و سلمان و عمار و المقداد، و الحسن و الحسین ع. ابن عباس راجع به سخن خداوند: «و نزعنا ما فی صدورهم من غل‌» گفت: این آیه درباره علی‌ بن ابی طالب (علیه السلام) و حمزه و جعفر و عقیل و ابوذر و سلمان و عمار و مقداد و حسن و حسین نازل شده است.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حمزه","display":"حَمْزَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عقيل","display":"عَقِيلٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"ذر","display":"ذَرٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلمان","display":"سَلْمَانَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمار","display":"عَمَّارٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المقداد","display":"الْمِقْدَادِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}