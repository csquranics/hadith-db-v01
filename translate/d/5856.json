{"consensus_set_id":"5856","translation_language":"fa","translation_source":{"hid":"338313"},"segments":[{"source_hadith_segment":"اِنَّ اَلْحَجَّ مُتَّصِلٌ بِالْعُمْرَةِ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ  <quranic_text> « فَاِذٰا اَمِنْتُمْ فَمَنْ تَمَتَّعَ بِالْعُمْرَةِ اِلَي الْحَجِّ فَمَا اِسْتَيْسَرَ مِنَ الْهَدْيِ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  فَلَيْسَ","translation_segment":"پدرم رحمه اللٰه علیه از علی بن ابراهیم بن هاشم، از پدرش، از محمد بن ابی عمیر، از حماد بن عثمان، از عبید اللٰه بن علی الحلبی، از حضرت ابی عبد اللٰه علیه السلام نقل کرده که آن جناب فرمودند: حج‌ به عمره متصل است به دلیل فرموده حق تبارک و تعالی: «فإذٰا أمنتم‌، فمن‌ تمتع‌ بالعمره‌ إلی الحج‌ فما استیسر من‌ الهدی‌» (پس از آنکه منع و ترس بر طرف شد","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الحج","display":"اَلْحَجَّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"تمتع","display":"تَمَتَّعْ"},{"kind":"word","token":"متصل","display":"مُتَّصِلٌ"},{"kind":"word","token":"بالعمره","display":"بِالْعُمْرَةِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"يوم","display":"يَوْمِ"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"w