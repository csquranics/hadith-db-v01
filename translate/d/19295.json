{"consensus_set_id":"19295","translation_language":"fa","translation_source":{"hid":"407509"},"segments":[{"source_hadith_segment":"« يَا عِبَادَ اللَّهِ ،  اِنَّ اَقْرَبَ مَا يَكُونُ الْعَبْدُ مِنَ الْمَغْفِرَةِ وَ الرَّحْمَةِ حِينَ يَعْمَلُ [ لِلَّهِ ] بِطَاعَتِهِ وَ يَنْصَحُهُ فِي تَوْبَتِهِ ،  عَلَيْكُمْ بِتَقْوَي اللَّهِ فَاِنَّهَا تَجْمَعُ الْخَيْرَ ،  وَ لاَ خَيْرَ غَيْرُهَا ،  وَ يُدْرَكُ بِهَا مِنَ الْخَيْرِ مَا لاَ يُدْرَكُ بِغَيْرِهَا مِنْ خَيْرِ الدُّنْيَا وَ خَيْرِ الْاخِرَةِ ،  قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ قِيلَ لِلَّذِينَ اِتَّقَوْا مٰا ذٰا اَنْزَلَ رَبُّكُمْ قٰالُوا خَيْراً لِلَّذِينَ اَحْسَنُوا فِي هٰذِهِ الدُّنْيٰا حَسَنَةٌ وَ لَدٰارُ الْاخِرَةِ خَيْرٌ وَ لَنِعْمَ دٰارُ الْمُتَّقِينَ » </quranic_text>   <footnote> [ النحل ۳۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"عباد","display":"عِبَادَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اقرب","display":"اَقْرَبَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"العبد","display":"الْعَبْدُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المغفره","display":"الْمَغْفِرَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرحمه","display":"الرَّحْمَةِ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"يعمل","display":"يَعْمَلُ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"بطاعته","display":"بِطَاعَتِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ينصحه","display":"يَنْصَحُهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتبه","display":"كَتَبَهُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"توبته","display":"تَوْبَتِهِ"},{"ki