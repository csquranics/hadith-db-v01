{"consensus_set_id":"s406441","translation_language":"fa","translation_source":{"hid":"406441"},"segments":[{"source_hadith_segment":"« اِذَا قَالَ الْعَبْدُ :  ( سُبْحَانَ اللَّهِ ) سَبَّحَ كُلُّ شَيْءٍ مَعَهُ مَا دُونَ الْعَرْشِ ،  فَيُعْطَي قَائِلُهَا عَشْرَ اَمْثَالِهَا ،  وَ اِذَا قَالَ :  ( اَلْحَمْدُ لِلَّهِ ) اَنْعَمَ اللَّهُ عَلَيْهِ بِنَعِيمِ الدُّنْيَا حَتَّي يَلْقَاهُ بِنَعِيمِ الْاخِرَةِ ،  وَ هِيَ الْكَلِمَةُ الَّتِي يَقُولُهَا اَهْلُ الْجَنَّةِ اِذَا دَخَلُوهَا ،  وَ الْكَلاَمِ يَنْقَطِعُ فِي الدُّنْيَا مَا خَلاَ الْحَمْدُ لِلَّهِ ،  وَ ذَلِكَ قَوْلُهُ :   <quranic_text> « تَحِيَّتُهُمْ فِيهٰا سَلاٰمٌ » </quranic_text>   <footnote> [ يونس ۱۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"العبد","display":"الْعَبْدُ"},{"kind":"word","token":"سبحان","display":"سُبْحَانَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"سبح","display":"سَبَّحَ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"معه","display":"مَعَهُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"دون","display":"دُونَ"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"فيعطي","display":"فَيُعْطَي"},{"kind":"word","token":"قائلها","display":"قَائِلُهَا"},{"kind":"word","token":"عشر","display":"عَشْرَ"},{"kind":"word","token":"امثالها","display":"اَمْثَالِهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الحمد","display":"اَلْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"انعم","display":"اَنْعَمَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"بنعيم","display":"بِنَعِيمِ"},{"ki