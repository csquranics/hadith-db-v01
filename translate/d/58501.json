{"consensus_set_id":"58501","translation_language":"fa","translation_source":{"hid":"75984"},"segments":[{"source_hadith_segment":"« لَمَّا بَعَثَ اللَّهُ نُوحاً اِلَي قَوْمِهِ بَعَثَهُ و هُوَ اِبْنُ خَمْسِينَ و مِائَتَيْ سَنَةٍ ،  و لَبِثَ فِي قَوْمِهِ اَلْفَ سَنَةٍ اِلاّٰ خَمْسِينَ عٰاماً ،  و بقي بعد الطوفان مائتين و خمسين سَنَةٍ ،  فَلَمَّا اَتَاهُ مَلَكُ الْمَوْتِ ع قَالَ لَهُ :  يَا نُوحُ ،  يَا اَكْبَرَ الْاَنْبِيَاءِ ،  و يَا طَوِيلَ الْعُمُرِ ،  و يَا مُجَابَ الدَّعْوَةِ ،  كَيْفَ رَاَيْتَ الدنيا ؟  قال :  مثل رجل بني لَهُ بَيْتٌ لَهُ بَابَانِ فَدَخَلَ مِنْ وَاحِدٍ و خَرَجَ مِنْ الاخر »","translation_segment":"","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"بعث","display":"بَعَثَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"نوحا","display":"نُوحاً"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قومه","display":"قَوْمِهِ"},{"kind":"word","token":"بعثه","display":"بَعَثَهُ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"خمسين","display":"خَمْسِينَ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"مائتي","display":"مِائَتَيْ"},{"kind":"word","token":"سنه","display":"سَنَةٍ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"لبث","display":"لَبِثَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قومه","display":"قَوْمِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الف","display":"اَلْفَ"},{"kind":"word","token":"سنه","display":"سَنَةٍ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"خمسين","display":"خَمْسِينَ"},{"kind":"word","token":"عاما","display":"عٰاماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العنكبوت۱۴","display":"العنكبوت۱۴"},{"kind":"tag_close","tag_name":