{"consensus_set_id":"34064","translation_language":"fa","translation_source":{"hid":"410134"},"segments":[{"source_hadith_segment":"« اِذَا دَخَلَ اَهْلُ الْجَنَّةِ الْجَنَّةَ وَ اَهْلُ النَّارِ النَّارَ ،  جِيءَ بِالْمَوْتِ فَيُذْبَحُ كَالْكَبْشِ بَيْنَ الْجَنَّةِ وَ النَّارِ ،  ثُمَّ يُقَالُ لَهُمْ :  خُلُودٌ ،  فَلاَ مَوْتَ اَبَداً .  فَيَقُولُ اَهْلُ الْجَنَّةِ :   <quranic_text> « اَ فَمٰا نَحْنُ بِمَيِّتِينَ اِلاّٰ مَوْتَتَنَا الْاُوليٰ وَ مٰا نَحْنُ بِمُعَذَّبِينَ اِنَّ هٰذٰا لَهُوَ الْفَوْزُ الْعَظِيمُ لِمِثْلِ هٰذٰا فَلْيَعْمَلِ الْعٰامِلُونَ » </quranic_text>   <footnote> [ الصافات ۵۸ ] </footnote> .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"دخل","display":"دَخَلَ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"النار","display":"النَّارِ"},{"kind":"word","token":"النار","display":"النَّارَ"},{"kind":"word","token":"جيء","display":"جِيءَ"},{"kind":"word","token":"بالموت","display":"بِالْمَوْتِ"},{"kind":"word","token":"فيذبح","display":"فَيُذْبَحُ"},{"kind":"word","token":"كالكبش","display":"كَالْكَبْشِ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النار","display":"النَّارِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يقال","display":"يُقَالُ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"خلود","display":"خُلُودٌ"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"موت","display":"مَوْتَ"},{"kind":"word","token":"ابدا","display":"اَبَداً"},{"kind":"word","token":"فيقول","display":"فَيَقُولُ"},{"kind":"word","toke