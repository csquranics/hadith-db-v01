{"consensus_set_id":"s331403","translation_language":"fa","translation_source":{"hid":"331403"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ تَعَالَي :   <quranic_text> « اِهْدِنَا الصِّرٰاطَ الْمُسْتَقِيمَ » </quranic_text>   <footnote> [ الفاتحة ۶ ] </footnote>  قَالَ :  يَقُولُ :  قُولُوا مَعَاشِرَ الْعِبَادِ :  اِهْدِنَا اِلَي حُبِّ النَّبِيِّ وَ اَهْلِ بَيْتِهِ  .","translation_segment":"عن ابن عباس فی قول الله تعالی: (اهدنا الصراط‍‌ المستقیم) قال: یقول: قولوا معاشر العباد: اهدنا إلی حب النبی و أهل بیته. ابن عباس درباره سخن خداوند: «اهدنا الصراط‍‌ المستقیم» گفت: می‌گوید: ای بندگان بگویید ما را به محبت پیامبر و اهل بیت او هدایت فرما.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اهدنا","display":"اِهْدِنَا"},{"kind":"word","token":"الصراط","display":"الصِّرٰاطَ"},{"kind":"word","token":"المستقيم","display":"الْمُسْتَقِيمَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۶","display":"۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"قولوا","display":"قُولُوا"},{"kind":"word","token":"معاشر","display":"مَعَاشِرَ"},{"kind":"word","token":"العباد","display":"الْعِبَادِ"},{"kind":"word","token":"اهدنا","display":"اِهْدِنَا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"حب","display":"حُبِّ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"بيته","display":"بَيْتِهِ"}]}]}