{"consensus_set_id":"s332115","translation_language":"fa","translation_source":{"hid":"332115"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « اِلاَّ الْمَوَدَّةَ فِي الْقُرْبيٰ » </quranic_text>   <footnote> [ الشوري ۲۳ ] </footnote>  قَالَ :  اَنْ تَتَّبِعُونِي وَ تَصِلُوا رَحِمِي .","translation_segment":"عن مجاهد فی قوله تعالی: (إلا الموده فی القربی) قال: أن تتبعونی و تصلوا رحمی. مجاهد درباره سخن خداوند: «الا الموده فی القربی» گفت: یعنی از من پیروی کنید و پیوند خویشاوندی مرا رعایت کنید.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"الموده","display":"الْمَوَدَّةَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القربي","display":"الْقُرْبيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الشوري","display":"الشوري"},{"kind":"word","token":"۲۳","display":"۲۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تتبعوني","display":"تَتَّبِعُونِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تصلوا","display":"تَصِلُوا"},{"kind":"word","token":"رحمي","display":"رَحِمِي"}]}]}