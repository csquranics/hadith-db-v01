{"consensus_set_id":"s224325","translation_language":"fa","translation_source":{"hid":"224325"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « اَوْ كَسَبَتْ فِي اِيمٰانِهٰا خَيْراً » </quranic_text>   <footnote> [ الانعام ۱۵۸ ] </footnote>  قَالَ الْمُؤْمِنُ حَالَتِ الْمَعَاصِي بَيْنَهُ وَ بَيْنَ اِيمَانِهِ كَثُرَتْ ذُنُوبُهُ وَ قَلَّتْ حَسَنَاتُهُ فَلَمْ يَكْسِبْ فِي اِيمَانِهِ خَيْراً .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"كسبت","display":"كَسَبَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ايمانها","display":"اِيمٰانِهٰا"},{"kind":"word","token":"خيرا","display":"خَيْراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۱۵۸","display":"۱۵۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنُ"},{"kind":"word","token":"حالت","display":"حَالَتِ"},{"kind":"word","token":"المعاصي","display":"الْمَعَاصِي"},{"kind":"word","token":"بينه","display":"بَيْنَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"ايمانه","display":"اِيمَانِهِ"},{"kind":"word","token":"كثرت","display":"كَثُرَتْ"},{"kind":"word","token":"ذنوبه","display":"ذُنُوبُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلت","display":"قَلَّتْ"},{"kind":"word","token":"حسناته","display":"حَسَنَاتُهُ"},{"kind":"word","token":"فلم","display":"فَلَمْ"},{"kind":"word","token":"يكسب","display":"يَكْسِبْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ايمانه","display":"اِيمَانِهِ"},{"kind":"word","token":"خيرا","display"