ست که به دوستی تو منتسب باشد مگر آن که خداوند او را در روز رستخیز با ما برمی‌انگیزاند و سپس پیامبر (صلی الله علیه و آله) این آیه شریفه را تلاوت فرمود: «فی مقعد صدق‌ عند ملیک‌ مقتدر».","segment_columns":[{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"دجانه","display":"دُجَانَةَ"},{"kind":"word","token":"الانصاري","display":"الْاَنْصَارِيُّ"},{"kind":"word","token":"رضي","display":"رَضِيَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عنه","display":"عَنْهُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صلّي"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"اخبرتنا","display":"اَخْبَرْتَنَا"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةَ"},{"kind":"word","token":"محرمه","display":"مُحَرَّمَةٌ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الانبياء","display":"الْاَنْبِيَاءِ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"تدخلها","display":"تَدْخُلَهَا"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الامم","display":"الْاُمَمِ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"تدخلها","display":"تَدْخُلَهَا"},{"kind":"word","token":"امتك","display":"اُمَّتُكَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","dis