footnote> [ يس ۸۰ ] </footnote>  اَيْ اِذَا كَانَ قَدْ كَمَنْ النَّارَ الْحَارَّةَ فِي الشَّجَرِ الْاَخْضَرِ كَالرَّطْبِ ،  ثُمَّ يَسْتَخْرِجُهَا ،  يُعَرِّفُكُمْ اَنَّهُ عَلَي اِعَادَةِ مَا يَبْلَي اَقْدَرُ ،  ثُمَّ قَالَ :   <quranic_text> « اَ وَ لَيْسَ الَّذِي خَلَقَ السَّمٰاوٰاتِ وَ الْاَرْضَ بِقٰادِرٍ عَليٰ اَنْ يَخْلُقَ مِثْلَهُمْ بَليٰ وَ هُوَ الْخَلاّٰقُ الْعَلِيمُ » </quranic_text>   <footnote> [ يس ۸۱ ] </footnote>  اَيْ اِذَا كَانَ خَلْقُ السَّمَاوَاتِ وَ الْاَرْضِ اَعْظَمَ وَ اَبْعَدَ فِي اَوْهَامِكُمْ وَ قَدْرِكُمْ اَنْ تَقْدِرُوا عَلَيْهِ مِنْ اِعَادَةِ الْبَالِي ،  فَكَيْفَ جَوَّزْتُمْ مِنَ اللَّهِ خَلَقَ هَذَا الْاَعْجَبَ عِنْدَكُمْ ،  وَ الْاَصْعَبَ لَدَيْكُمْ ،  وَ لَمْ تُجَوِّزُوا مَا هُوَ سَهْلٌ عِنْدَكُمْ مِنْ اِعَادَةِ الْبَالِي ؟  وَ قَالَ الصَّادِقُ ( عَلَيْهِ السَّلاَمُ ) :  فَهَذَا الْجِدَالُ بِالَّتِي هِيَ اَحْسَنُ ،  لِاَنَّ فِيهَا اِنْقِطَاعَ دَعْوَي الْكَافِرِينَ ،  وَ اِزَالَةَ شُبْهَتِهِمْ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"جعل","display":"جَعَلَ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الشجر","display":"الشَّجَرِ"},{"kind":"word","token":"الاخضر","display":"الْاَخْضَرِ"},{"kind":"word","token":"نارا","display":"نٰاراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يس","display":"يس"},{"kind":"word","token":"۸۰","display":"۸۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كمن","display":"كَمَنْ"},{"kind":"word","token":"النار","display":"النَّارَ"},{"kind":