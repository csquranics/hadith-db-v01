{"consensus_set_id":"s222761","translation_language":"fa","translation_source":{"hid":"222761"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ :   <quranic_text> « وَ اِذْ اَخَذَ رَبُّكَ مِنْ بَنِي ادَمَ مِنْ ظُهُورِهِمْ ذُرِّيَّتَهُمْ وَ اَشْهَدَهُمْ عَليٰ اَنْفُسِهِمْ اَ لَسْتُ بِرَبِّكُمْ قٰالُوا بَليٰ » </quranic_text>   <footnote> [ الاعراف ۱۷۲ ] </footnote>  قَالَ نَعَمْ لِلَّهِ الْحُجَّةُ عَلَي جَمِيعِ خَلْقِهِ اَخَذَهُمْ يَوْمَ اَخَذَ الْمِيثَاقَ هَكَذَا وَ قَبَضَ يَدَهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"ربك","display":"رَبُّكَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"ادم","display":"ادَمَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ظهورهم","display":"ظُهُورِهِمْ"},{"kind":"word","token":"ذريتهم","display":"ذُرِّيَّتَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اشهدهم","display":"اَشْهَدَهُمْ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"انفسهم","display":"اَنْفُسِهِمْ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لست","display":"لَسْتُ"},{"kind":"word","token":"بربكم","display":"بِرَبِّكُمْ"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"بلي","display":"بَليٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۷۲","display":"۱۷۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"