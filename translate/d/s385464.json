{"consensus_set_id":"s385464","translation_language":"fa","translation_source":{"hid":"385464"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ ) ،  عَنْ قَوْلِ اللَّهِ :   <quranic_text> « مَثَلُ نُورِهِ كَمِشْكٰاةٍ فِيهٰا مِصْبٰاحٌ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>   ،  الْايَةَ فَقَالَ الْمِصْبَاحُ هُوَ الْاِمَامُ يَتَكَلَّمُ بِصِغَرِ سِنِّهِ بِالْوَحْيِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"مثل","display":"مَثَلُ"},{"kind":"word","token":"نوره","display":"نُورِهِ"},{"kind":"word","token":"كمشكاه","display":"كَمِشْكٰاةٍ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"مصباح","display":"مِصْبٰاحٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۳۵","display":"۳۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"المصباح","display":"الْمِصْبَاحُ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الامام","display":"الْاِمَامُ"},{"kind":"word","token":"يتكلم","display":"يَتَكَلَّمُ"},{"kind":"word","token":"بصغر","display":"بِصِغَرِ"},{"kind":"word","token":"سنه","display":"سِنِّهِ"},{"kind":"word","token":"بالوحي","display":"بِالْوَحْيِ"}]}]}