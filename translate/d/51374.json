{"consensus_set_id":"51374","translation_language":"fa","translation_source":{"hid":"337452"},"segments":[{"source_hadith_segment":"اِنَّ نُوحاً اِنَّمَا سُمِّيَ  <quranic_text> « عَبْداً شَكُوراً » </quranic_text>   <footnote> [ الاسراء ۳ ] </footnote>  لِاَنَّهُ كَانَ يَقُولُ اِذَا اَمْسَي وَ اَصْبَحَ اللَّهُمَّ اِنِّي اُشْهِدُكَ اَنَّهُ مَا اَمْسَي وَ اَصْبَحَ بِي مِنْ نِعْمَةٍ اَوْ عَافِيَةٍ فِي دِينٍ اَوْ دُنْيَا فَمِنْكَ وَحْدَكَ لاَ شَرِيكَ لَكَ لَكَ الْحَمْدُ وَ لَكَ الشُّكْرُ بِهَا عَلَيَّ حَتَّي تَرْضَي وَ بَعْدَ الرِّضَا اِلَهَنَا .","translation_segment":"حدیث کرد مرا پدرم از حضرت باقر علیه السلام که: حضرت نوح را از آن جهت بنده شاکر گفتند که در هر صبح و شام میگفت: اللهم انی اشهدک انه ما امسی و اصبح بی من نعمه او عافیه فی دین او دنیا فمنک وحدک لا شریک لک، لک الحمد، و لک الشکر بها علی حتی ترضی الهنا..","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"نوحا","display":"نُوحاً"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"سمي","display":"سُمِّيَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"عبدا","display":"عَبْداً"},{"kind":"word","token":"شكورا","display":"شَكُوراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"لانه","display":"لِاَنَّهُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"امسي","display":"اَمْسَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اصبح","display":"اَصْبَحَ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"اشهدك","display":"اُشْهِدُكَ"},{"kind":"word","token":"انه","di