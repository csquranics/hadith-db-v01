{"consensus_set_id":"26824","translation_language":"fa","translation_source":{"hid":"71914"},"segments":[{"source_hadith_segment":"قنوت الامام محمّد بن عليّ بن موسي ع  :  « [ اللّهمّ ] منائحك متتابعة ،  و اياديك متوالية ،  و نعمك سابغة ،  و شكرنا قصير ،  و حمدنا يسير ،  و انت بالتعطّف علي من اعترف جدير .  اللّهمّ و قد غصّ اهل الحقّ بالريق ،  و ارتبك اهل الصدق في المضيق ،  و انت اللّهمّ بعبادك و ذوي الرغبة اليك شفيق ،  و باجابة دعائهم و تعجيل الفرج عنهم حقيق .  اللّهمّ فصلّ علي محمّد و ال محمّد و بادرنا منك بالعون الّذي لا خذلان بعده ،  و النصر الّذي لا باطل يتكاّده ، و اتح لنا من لدنك متاحا فيّاحا ، يامن فيه وليّك ،  و يخيب فيه عدوّك ،  و تقام فيه معالمك ،  و تظهر فيه اوامرك ،  و تنكفّ فيه عوادي عداتك .  اللّهمّ بادرنا منك بدار الرّحمة ،  و بادر اعدائك من باسك بدار النقمة .  اللّهمّ اعنّا و اغثنا ،  و ارفع نقمتك عنّا ،  و احلّها بالقوم الظالمين »","translation_segment":"","segment_columns":[{"kind":"word","token":"قنوت","display":"قنوت"},{"kind":"word","token":"الامام","display":"الامام"},{"kind":"word","token":"محمد","display":"محمّد"},{"kind":"word","token":"بن","display":"بن"},{"kind":"word","token":"علي","display":"عليّ"},{"kind":"word","token":"بن","display":"بن"},{"kind":"word","token":"موسي","display":"موسي"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"اللهم","display":"اللّهمّ"},{"kind":"word","token":"منائحك","display":"منائحك"},{"kind":"word","token":"متتابعه","display":"متتابعة"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اياديك","display":"اياديك"},{"kind":"word","token":"متواليه","display":"متوالية"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"نعمك","display":"نعمك"},{"kind":"word","token":"سابغه","display":"سابغة"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"شكرنا","display":"شكرنا"},{"kind":"word","token":"قصير","display":"قصير"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"حمدنا","display":"حمدنا"},{"kind":"word","token":"يسير","display":"يسي