{"consensus_set_id":"s75738","translation_language":"fa","translation_source":{"hid":"75738"},"segments":[{"source_hadith_segment":"خَرَجَ عَلَيَّ اَبُو جَعْفَرٍ حِدْثَانَ مَوْتِ اَبِيهِ فَنَظَرْتُ اِلَي","translation_segment":"معلی بن محمد گوید: پس از چند روز که از وفات حضرت رضا علیه السلام","segment_columns":[{"kind":"word","token":"خرج","display":"خَرَجَ"},{"kind":"word","token":"علي","display":"عَلَيَّ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"حدثان","display":"حِدْثَانَ"},{"kind":"word","token":"موت","display":"مَوْتِ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"فنظرت","display":"فَنَظَرْتُ"},{"kind":"word","token":"الي","display":"اِلَي"}]},{"source_hadith_segment":"قَدِّهِ لِاَصِفَ قَامَتَهُ لِاَصْحَابِنَا فَقَعَدَ ،  ثُمَّ قَالَ :","translation_segment":"گذشته بود پسرش ابو جعفر از منزل بیرون شد، من به قد و قامت","segment_columns":[{"kind":"word","token":"قده","display":"قَدِّهِ"},{"kind":"word","token":"لاصف","display":"لِاَصِفَ"},{"kind":"word","token":"قامته","display":"قَامَتَهُ"},{"kind":"word","token":"لاصحابنا","display":"لِاَصْحَابِنَا"},{"kind":"word","token":"فقعد","display":"فَقَعَدَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« يَا عليّ ،  انّ اللّه تَعَالَي اِحْتَجَّ فِي الْاِمَامَةِ بِمِثْلِ مَا اِحْتَجَّ بِهِ فِي النُّبُوَّةِ فقال :   <quranic_text> « وَ اتَيْنٰاهُ الْحُكْمَ صَبِيًّا » </quranic_text>   <footnote> [ مريم ۱۲ ] </footnote>   .","translation_segment":"وی نگاه میکردم تا او را برای اصحاب خودمان معرفی کنم، در این هنگام حضرت جواد علیه السلام نشستند و فرمودند: ای معلی خداوند به امامت هم مانند نبوت احتجاج کرده و گفته: «و آتینٰاه‌ الحکم‌ صبیا».","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"علي","display":"عليّ"},{"kind":"word","token":"ان","display":"انّ"},{"kind":"word","token":"الله","display":"اللّه