{"consensus_set_id":"11960","translation_language":"fa","translation_source":{"hid":"107593"},"segments":[{"source_hadith_segment":"مَنْ عَطَسَ ثُمَّ وَضَعَ يَدَهُ عَلَي قَصَبَةِ اَنْفِهِ ثُمَّ قَالَ  <quranic_text> « اَلْحَمْدُ لِلّٰهِ رَبِّ الْعٰالَمِينَ » </quranic_text>   <footnote> [ الفاتحة ۲ ] </footnote>  الْحَمْدُ لِلَّهِ حَمْداً كَثِيراً كَمَا هُوَ اَهْلُهُ وَ صَلَّي اللَّهُ عَلَي مُحَمَّدٍ النَّبِيِّ وَ الِهِ وَ سَلَّمَ خَرَجَ مِنْ مَنْخِرِهِ الْاَيْسَرِ طَائِرٌ اَصْغَرُ مِنَ الْجَرَادِ وَ اَكْبَرُ مِنَ الذُّبَابِ حَتَّي يَسِيرَ تَحْتَ الْعَرْشِ يَسْتَغْفِرُ اللَّهَ لَهُ اِلَي يَوْمِ الْقِيَامَةِ .","translation_segment":"حضرت صادق ع فرمود: هر که عطسه زند سپس دستش را بر استخوان تیغه بینی نهد و بگوید: «الحمد للٰه رب العالمین [الحمد للٰه] حمدا کثیرا کما هو اهله و صلی اللٰه علی محمد النبی و آله و سلم». از سوراخ چپ بینی او پرنده‌ای کوچکتر از ملخ و بزرگتر از مگس بیرون آید و برود تا بزیر عرش رسد و تا روز قیامت برای او استغفار کند.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عطس","display":"عَطَسَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"وضع","display":"وَضَعَ"},{"kind":"word","token":"يده","display":"يَدَهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"قصبه","display":"قَصَبَةِ"},{"kind":"word","token":"انفه","display":"اَنْفِهِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحمد","display":"اَلْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"رب","display":"رَبِّ"},{"kind":"word","token":"العالمين","display":"الْعٰالَمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word