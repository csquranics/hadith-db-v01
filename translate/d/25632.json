{"consensus_set_id":"25632","translation_language":"fa","translation_source":{"hid":"99579"},"segments":[{"source_hadith_segment":"فِي اَلرَّجُلِ يَمُوتُ وَ لاَ وَارِثَ لَهُ وَ لاَ مَوْلًي لَهُ فَقَالَ « هُوَ مِنْ اَهْلِ هَذِهِ الْايَةِ  <quranic_text> « يَسْئَلُونَكَ عَنِ الْاَنْفٰالِ » </quranic_text>   <footnote> [ الانفال ۱ ] </footnote>   .","translation_segment":"و أبان بن تغلب از امام صادق علیه السلام روایت کرده است که آن امام علیه السلام در باره مردی که بمیرد، و وارثی و مولائی نداشته باشد، فرمود: او از اهل این آیه است که خدای تعالی فرمود: «یسئلونک عن الانفال …» یعنی وارثش امام است-، زیرا وارث کسی که وارث ندارد او است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الرجل","display":"اَلرَّجُلِ"},{"kind":"word","token":"يموت","display":"يَمُوتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"وارث","display":"وَارِثَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"مولي","display":"مَوْلًي"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يسئلونك","display":"يَسْئَلُونَكَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الانفال","display":"الْاَنْفٰالِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"}]}]}