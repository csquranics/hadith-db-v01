{"consensus_set_id":"6735","translation_language":"fa","translation_source":{"hid":"409976"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « قُلْ اِنَّمٰا اَعِظُكُمْ بِوٰاحِدَةٍ » </quranic_text>   <footnote> [ سبا ۴۶ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"اعظكم","display":"اَعِظُكُمْ"},{"kind":"word","token":"بواحده","display":"بِوٰاحِدَةٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"سبا","display":"سبا"},{"kind":"word","token":"۴۶","display":"۴۶"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"،  قَالَ :  « فَاِنَّ اللَّهَ جَلَّ ذِكْرُهُ اَنْزَلَ عَزَائِمَ الشَّرَائِعِ ،  وَ ايَاتِ الْفَرَائِضِ فِي اَوْقَاتٍ مُخْتَلِفَةٍ كَمَا خَلَقَ السَّمَاوَاتِ وَ الْاَرْضَ فِي سِتَّةِ اَيَّامٍ ،  وَ لَوْ شَاءَ اللَّهُ لَخَلَقَهَا فِي اَقَلَّ مِنْ لَمْحِ الْبَصَرِ ،  وَ لَكِنَّهُ جَعَلَ الْاَنَاةَ وَ الْمُدَارَاةَ مِثَالاً لِاُمَنَائِهِ ،  وَ اِيجَاباً لِحُجَجِهِ عَلَي خَلْقِهِ ،  فَكَانَ اَوَّلُ مَا قَيَّدَهُمْ بِهِ :  الْاِقْرَارَ لَهُ بِالْوَحْدَانِيَّةِ وَ الرُّبُوبِيَّةِ ،  وَ الشَّهَادَةُ بِاَنْ لاَ اِلَهَ اِلاَّ اللَّهُ ،  فَلَمَّا اَقَرُّوا بِذَلِكَ تَلاَهُ بِالْاِقْرَارِ لِنَبِيِّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) بِالنُّبُوَّةِ ،  وَ الشَّهَادَةِ لَهُ بِالرِّسَالَةِ ،  فَلَمَّا اِنْقَادُوا لِذَلِكَ فَرَضَ عَلَيْهِمُ الصَّلاَةَ ،  ثُمَّ الزَّكَاةَ ،  ثُمَّ الصَّوْمَ ،  ثُمَّ الْحَجَّ ،  ثُمَّ الصَّدَقَاتِ وَ مَا يَجْرِي مَجْرَاهَا مِنْ مَالِ الْفَيْءِ .  فَقَالَ الْمُنَافِقُونَ :  هَلْ بَقِيَ لِرَبِّكَ عَلَيْنَا بَعْدَ الَّذِي فَرَضَ شَيْءٌ اخَرُ يَفْتَرِضُهُ ،  فَتَذْكُرَهُ لِتَسْكُنَ اَنْفُسُنَا اِلَي اَنَّهُ لَمْ يَبْقَ غَيْرُهُ ؟  فَاَنْزَلَ اللَّهُ فِي ذَلِكَ :   <quranic_text> « قُلْ اِنَّمٰا اَعِظُكُمْ بِوٰاحِدَةٍ » </quranic_text>   <footnote> [ سبا ۴۶ ] </footnote>  يَعْنِي الْوَلاَيَةَ ،  وَ اَنْزَلَ اللَّهُ :   <quranic_text> « اِنَّمٰا وَلِيُّكُمُ اللّٰهُ وَ رَسُولُهُ وَ الَّذِينَ امَنُوا الَّذِينَ يُقِيمُونَ الصَّلاٰةَ وَ يُؤْتُونَ الزَّكٰاةَ وَ هُمْ رٰاكِعُونَ » </quranic_text>   <footnote> [ المائدة ۵۵ ] </footnote> ،  وَ لَيْسَ بَيْنَ الْاُمَّةِ خِلاَفٌ اَنَّهُ لَمْ يُؤْتِ الزَّكَاةَ يَوْمَئِذٍ اَحَدٌ وَ هُوَ رَاكِعٌ غَيْرُ رَجُلٍ وَاحِدٍ ،  لَوْ ذُكِرَ اِسْمُهُ فِي الْكِتَابِ لَاُسْقِطَ مَعَ مَا اُسْقِطَ مِنْ ذِكْرِهِ ،  وَ هَذَا وَ مَا اَشْبَهَهُ مِنَ الرُّمُوزِ الَّتِي ذَكَرْتَ لَكَ ثُبُوتَهَا فِي الْكِتَابِ لَيَجْهَلُ مَعْنَاهَا الْمُحَرِّفُونَ ،  فَيَبْلُغُ اِلَيْكَ وَ اِلَي اَمْثَالِكَ ،  وَ عِنْدَ ذَلِكَ قَالَ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « الْيَوْمَ اَكْمَلْتُ لَكُمْ دِينَكُمْ وَ اَتْمَمْتُ عَلَيْكُمْ نِعْمَتِي وَ رَضِيتُ لَكُمُ الْاِسْلاٰمَ دِيناً » </quranic_text>   <footnote> [ المائدة ۳ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"ذكره","display":"ذِكْرُهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"عزائم","display":"عَزَائِمَ"},{"kind":"word","token":"الشرائع","display":"الشَّرَائِعِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ايات","display":"ايَاتِ"},{"kind":"word","token":"الفرائض","display":"الْفَرَائِضِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اوقات","display":"اَوْقَاتٍ"},{"kind":"word","token":"مختلفه","display":"مُخْتَلِفَةٍ"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word