{"consensus_set_id":"19044","translation_language":"fa","translation_source":{"hid":"311517"},"segments":[{"source_hadith_segment":"قَالَ قَالَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ  :  مَنِ اِتَّخَذَ خَاتَماً فَصُّهُ عَقِيقٌ لَمْ يَفْتَقِرْ وَ لَمْ يُقْضَ لَهُ  <quranic_text> « اِلاّٰ بِالَّتِي هِيَ اَحْسَنُ » </quranic_text>   <footnote> [ الانعام ۱۵۲ ] </footnote>   .","translation_segment":"حسین بن خالد از حضرت رضا علیه السلام روایت کرده که امام صادق علیه السلام فرمود: هر کس انگشتری که نگینش عقیق باشد بدست کند تهی دست نگردد، و کارش فرجام نیابد مگر بهر چه بهتر (یعنی عاقبتش بخیر و خوبی باشد).","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"اتخذ","display":"اِتَّخَذَ"},{"kind":"word","token":"خاتما","display":"خَاتَماً"},{"kind":"word","token":"فصه","display":"فَصُّهُ"},{"kind":"word","token":"عقيق","display":"عَقِيقٌ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يفتقر","display":"يَفْتَقِرْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يقتض","display":"يقتض"},{"kind":"word","token":"يقض","display":"يُقْضَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"بالتي","display":"بِالَّتِي"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"احسن","display":"اَحْسَنُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"مر","display":"مَرَّ"},