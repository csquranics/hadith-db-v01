{"consensus_set_id":"116942","translation_language":"fa","translation_source":{"hid":"332339"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « يٰا اَيَّتُهَا النَّفْسُ الْمُطْمَئِنَّةُ » </quranic_text>   <footnote> [ الفجر ۲۷ ] </footnote>  اِلَي اخِرِ السُّورَةِ ،  قَالَ :  نَزَلَتْ فِي عَلِيٍّ  .","translation_segment":"حسن بن محبوب از عبد الرحمان بن سالم و او از ابو عبد اللٰه جعفر بن محمد صلی اللٰه علیه و آله در شأن نزول آیه کریمه «یٰا أیتها النفس‌ المطمئنه‌. `ارجعی إلیٰ‌ ربک‌ رٰاضیه‌ مرضیه‌. `فادخلی فی عبٰادی. `و ادخلی جنتی». نقل کرد: آیه شریفه در باره علی بن ابی طالب علیه السلام نازل شد و خدای سبحان نفس آن حضرت را نفس مطمئنه نامید.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايتها","display":"اَيَّتُهَا"},{"kind":"word","token":"النفس","display":"النَّفْسُ"},{"kind":"word","token":"المطمئنه","display":"الْمُطْمَئِنَّةُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفجر","display":"الفجر"},{"kind":"word","token":"۲۷","display":"۲۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"اخره","display":"اخِرِهِ"},{"kind":"word","token":"اخر","display":"اخِرِ"},{"kind":"word","token":"السوره","display":"السُّورَةِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}