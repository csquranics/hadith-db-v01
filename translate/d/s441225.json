{"consensus_set_id":"s441225","translation_language":"fa","translation_source":{"hid":"441225"},"segments":[{"source_hadith_segment":"اِنَّ ادَمَ لَمَّا اَكْرَمَ اللَّهُ تَعَالَي ذِكْرَهُ بِاِسْجَادِ مَلاَئِكَتِهِ لَهُ وَ بِاِدْخَالِهِ الْجَنَّةَ قَالَ فِي نَفْسِهِ :  هَلْ خَلَقَ اللَّهُ بَشَراً هُوَ اَفْضَلُ مِنِّي ؟  فَنَادَاهُ اللَّهُ :  اِرْفَعْ رَاْسَكَ يَا ادَمُ وَ اُنْظُرْ اِلَي سَاقِ عَرْشِي .  فَرَفَعَ رَاْسَهُ ادَمُ فَنَظَرَ اِلَي سَاقِ الْعَرْشِ","translation_segment":"باز هم شیخ صدوق در عیون الاخبار از عبد الواحد بن محمد بن عبدوس نیشابوری عطار از علی بن محمد قتیبه از حمدان بن سلیمان از عبد السلام بن صالح هروی از حضرت رضا ع نقل کرده که حضرت فرمود: وقتی که خداوند آدم ع را بوسیله سجده نمودن ملائکه بر او و داخل کردن او به بهشت کرامت بخشید، آدم ع با خود گفت: آیا خداوند بشری را","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ادم","display":"ادَمَ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"اكرم","display":"اَكْرَمَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"ذكره","display":"ذِكْرَهُ"},{"kind":"word","token":"باسجاد","display":"بِاِسْجَادِ"},{"kind":"word","token":"ملائكته","display":"مَلاَئِكَتِهِ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بادخاله","display":"بِاِدْخَالِهِ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"نفسه","display":"نَفْسِهِ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"بشرا","display":"بَشَراً"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"افضل","display":"اَفْضَلُ"},{"kind":"word","token":"مني","display":"مِنِّي"},{"kind":"word","token":