{"consensus_set_id":"s331791","translation_language":"fa","translation_source":{"hid":"331791"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « سَيَجْعَلُ لَهُمُ الرَّحْمٰنُ وُدًّا » </quranic_text>   <footnote> [ مريم ۹۶ ] </footnote>  قَالَ :  حُبُّ عَلِيِّ بْنِ اَبِي طَالِبٍ فِي قَلْبِ كُلِّ مُؤْمِنٍ .","translation_segment":"عن ابن عباس فی قوله تعالی: (سیجعل لهم الرحمان ودا) قال: حب‌ علی‌ بن أبی طالب فی قلب کل مومن. ابن عباس راجع به سخن خداوند: «سیجعل لهم الرحمن ودا» گفت: محبت علی‌ بن ابی طالب (علیه السلام) در دل هر مومنی.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سيجعل","display":"سَيَجْعَلُ"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"ودا","display":"وُدًّا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"مريم","display":"مريم"},{"kind":"word","token":"۹۶","display":"۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"حب","display":"حُبُّ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قلب","display":"قَلْبِ"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٍ"}]}]}