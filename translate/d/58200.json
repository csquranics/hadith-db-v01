{"consensus_set_id":"58200","translation_language":"fa","translation_source":{"hid":"331688"},"segments":[{"source_hadith_segment":"لاَ نَالَتْنِي شَفَاعَةُ جَدِّي اِنْ لَمْ يَكُنْ هَذِهِ الْايَةُ نَزَلَتْ فِي عَلِيٍّ خَاصَّةً  <quranic_text> « قُلْ هٰذِهِ سَبِيلِي اَدْعُوا اِلَي اللّٰهِ عَليٰ بَصِيرَةٍ اَنَا وَ مَنِ اِتَّبَعَنِي ،  وَ سُبْحٰانَ اللّٰهِ وَ مٰا اَنَا مِنَ الْمُشْرِكِينَ » </quranic_text>   <footnote> [ يوسف ۱۰۸ ] </footnote>","translation_segment":"عن أبی جعفر قال: لا نالتنی شفاعه جدی إن لم یکن هذه الآیه نزلت فی علی خاصه (قل هذه سبیلی أدعو إلی الله علی بصیره أنا و من اتبعنی). ابو جعفر گفت:","segment_columns":[{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"نالتني","display":"نَالَتْنِي"},{"kind":"word","token":"شفاعه","display":"شَفَاعَةُ"},{"kind":"word","token":"جدي","display":"جَدِّي"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"خاصه","display":"خَاصَّةً"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هذه","display":"هٰذِهِ"},{"kind":"word","token":"سبيلي","display":"سَبِيلِي"},{"kind":"word","token":"ادعوا","display":"اَدْعُوا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word",