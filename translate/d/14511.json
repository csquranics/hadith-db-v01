{"consensus_set_id":"14511","translation_language":"fa","translation_source":{"hid":"406529"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ جٰاوَزْنٰا بِبَنِي اِسْرٰائِيلَ الْبَحْرَ فَاَتْبَعَهُمْ فِرْعَوْنُ وَ جُنُودُهُ بَغْياً وَ عَدْواً » </quranic_text>   <footnote> [ يونس ۹۰ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « وَ اَنَا مِنَ الْمُسْلِمِينَ » </quranic_text>   <footnote> [ يونس ۹۰ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جاوزنا","display":"جٰاوَزْنٰا"},{"kind":"word","token":"ببني","display":"بِبَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرٰائِيلَ"},{"kind":"word","token":"البحر","display":"الْبَحْرَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فاتبعهم","display":"فَاَتْبَعَهُمْ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جنوده","display":"جُنُودُهُ"},{"kind":"word","token":"بغيا","display":"بَغْياً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عدوا","display":"عَدْواً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يونس","display":"يونس"},{"kind":"word","token":"۹۰","display":"۹۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المسلمين","display":"الْمُسْلِمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يونس","display":"يونس"},{"kind":"word","token":"۹۰","display":"۹۰"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":":  « فَاِنَّ بَنِي اِسْرَائِيلَ قَالُوا :  يَا مُوسَي  ،  اُدْعُ اللَّهَ اَنْ يَجْعَلَ لَنَا مِمَّا نَحْنُ فِيهِ فَرَجاً فَدَعَا ،  فَاَوْحَي اللَّهُ اِلَيْهِ :  اَنْ اَسْرِ بِهِمْ .  قَالَ :  يَا رَبِّ ،  الْبَحْرُ اَمَامَهُمْ .  قَالَ :  اِمْضِ ،  فَاِنِّي امُرُهُ اَنْ يُطِيعَكَ وَ يَنْفَرِجَ لَكَ .  فَخَرَجَ مُوسَي بِبَنِي اِسْرَائِيلَ ،  وَ اَتْبَعُهُمْ فِرْعَوْنُ حَتَّي اِذَا كَادَ اَنْ يَلْحَقَهُمْ ،  وَ نَظَرُوا اِلَيْهِ وَ قَدْ اَظَلَّهُمْ ،  قَالَ مُوسَي لِلْبَحْرِ :  اِنْفَرِجْ لِي .  قَالَ :  مَا كُنْتُ لِاَفْعَلَ .  وَ قَالَ بَنُو اِسْرَائِيلَ لِمُوسَي  :  غَرَرْتَنَا وَ اَهْلَكْتَنَا ،  فَلَيْتَكَ تَرَكْتَنَا يَسْتَعْبِدُنَا الُ فِرْعَوْنَ ،  وَ لَمْ نَخْرُجْ اِلَي اَنْ نُقْتَلَ قَتْلَةً .  قَالَ : كَلاَّ ،  اِنَّ مَعِي رَبِّي سَيَهْدِينِي .  وَ اِشْتَدَّ عَلَي مُوسَي مَا كَانَ يَصْنَعُ بِهِ عَامَّةُ قَوْمِهِ ،  وَ قَالُوا :  يَا مُوسَي  ،  اِنَّا لَمُدْرَكُونَ ،  وَ زَعَمْتَ اَنَّ الْبَحْرَ يَنْفَرِجُ لَنَا حَتَّي نَمْضِيَ وَ نَذْهَبَ ،  فَقَدْ رَهِقَنَا فِرْعَوْنُ وَ قَوْمُهُ ،  وَ هُمْ هَؤُلاَءِ نَرَاهُمْ قَدْ دَنَوْا مِنَّا .  فَدَعَا مُوسَي رَبَّهُ ،  فَاَوْحَي اللَّهُ اِلَيْهِ :   <quranic_text> « اَنِ اِضْرِبْ بِعَصٰاكَ الْبَحْرَ » </quranic_text>   <footnote> [ الشعراء ۶۳ ] </footnote> فَضَرَبَهُ فَانْفَلَقَ الْبَحْرُ ،  فَمَضَي مُوسَي وَ اَصْحَابُهُ حَتَّي قَطَعُوا الْبَحْرَ ،  وَ اَدْرَكَهُمْ الُ فِرْعَوْنَ ،  فَلَمَّا نَظَرُوا اِلَي الْبَحْرِ ،  قَالُوا لِفِرْعَوْنَ :  مَا تَعْجَبُ مِمَّا تَرَي ؟  قَالَ : اَنَا فَعَلْتُ هَذَا .  فَمَرُّوا وَ مَضَوْا فِيهِ ،  فَلَمَّا تَوَسَّطَ فِرْعَوْنُ وَ مَنْ مَعَهُ اَمَرَ اللَّهُ الْبَحْرَ فَاَطْبَقَ عَلَيْهِمْ ،  فَاَغْرَقَهُمْ اَجْمَعِينَ ،  فَلَمَّا اَدْرَكَ فِرْعَوْنَ الْغَرَقُ  <quranic_text> « قٰالَ امَنْتُ اَنَّهُ لاٰ اِلٰهَ اِلاَّ الَّذِي امَنَتْ بِهِ بَنُوا اِسْرٰائِيلَ وَ اَنَا مِنَ الْمُسْلِمِينَ » </quranic_text>   <footnote> [ يونس ۹۰ ] </footnote>  يَقُولُ اللَّهُ :   <quranic_text> « الْانَ وَ قَدْ عَصَيْتَ قَبْلُ وَ كُنْتَ مِنَ الْمُفْسِدِينَ » </quranic_text>   <footnote> [ يونس ۹۱ ] </footnote>  يَقُولُ :  كُنْتَ مِنَ الْعَاصِينَ <quranic_text> « فَالْيَوْمَ نُنَجِّيكَ بِبَدَنِكَ » </quranic_text>   <footnote> [ يونس ۹۲ ] </footnote> - قَالَ - اِنَّ قَوْمَ فِرْعَوْنَ ذَهَبُوا اَجْمَعِينَ فِي الْبَحْرِ ،  فَلَمْ يُرَ مِنْهُمْ اَحَدٌ ،  هَوَوْا فِي الْبَحْرِ اِلَي النَّارِ ،  وَ اَمَّا فِرْعَوْنُ فَنَبَذَهُ اللَّهُ وَحْدَهُ فَاَلْقَاهُ بِالسَّاحِلِ لِيَنْظُرُوا اِلَيْهِ وَ لِيَعْرِفُوهُ ،  لِيَكُونَ لِمَنْ خَلْفَهُ ايَةً ،  وَ لِئَلاَّ يَشُكَّ اَحَدٌ فِي هَلاَكِهِ ،  لِاَنَّهُمْ كَانُوا اِتَّخَذُوهُ رَبّاً ،  فَاَرَاهُمُ اللَّهُ اِيَّاهُ جِيفَةً مُلْقَاةً بِالسَّاحِلِ ،  لِيَكُونَ لِمَنْ خَلْفَهُ عِبْرَةً وَ عِظَةً ،  يَقُولُ اللَّهُ : <quranic_text> « وَ اِنَّ كَثِيراً مِنَ النّٰاسِ عَنْ ايٰاتِنٰا لَغٰافِلُونَ » </quranic_text>   <footnote> [ يونس ۹۲ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرَائِيلَ"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"ادع","display":"اُدْعُ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يجعل","display":"يَجْعَلَ"},{"kind":"word","token":"لنا","display":"لَنَا"},{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"فرجا","display":"فَرَجاً"},{"kind":"word","token":"فدعا","display":"فَدَعَا"},{"kind":"word","token":"فاوحي","display":"فَا