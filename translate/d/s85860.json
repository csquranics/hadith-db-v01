{"consensus_set_id":"s85860","translation_language":"fa","translation_source":{"hid":"85860"},"segments":[{"source_hadith_segment":"« تَمْسَحُ يَدَكَ الْيُمْنَي عَلَي جَبْهَتِكَ وَ وَجْهِكَ فِي دُبُرِ الْمَغْرِبِ وَ الصَّلَوَاتِ وَ تَقُولُ بِسْمِ اللَّهِ  <quranic_text> « اَلَّذِي لاٰ اِلٰهَ اِلاّٰ هُوَ عٰالِمُ الْغَيْبِ وَ الشَّهٰادَةِ » </quranic_text>   <footnote> [ الحشر ۲۲ ] </footnote> .  .  .   <quranic_text> « اَلرَّحْمٰنُ الرَّحِيمُ » </quranic_text>   <footnote> [ الحشر ۲۲ ] </footnote> اللَّهُمَّ اِنِّي اَعُوذُ بِكَ مِنَ الْهَمِّ وَ الْحَزَنِ وَ السُّقْمِ وَ الْعُدْمِ وَ الصَّغَارِ وَ الذُّلِّ وَ الْفَوَاحِشِ  <quranic_text> « مٰا ظَهَرَ مِنْهٰا وَ مٰا بَطَنَ » </quranic_text>   <footnote> [ الانعام ۱۵۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"تمسح","display":"تَمْسَحُ"},{"kind":"word","token":"يدك","display":"يَدَكَ"},{"kind":"word","token":"اليمني","display":"الْيُمْنَي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"جبهتك","display":"جَبْهَتِكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وجهك","display":"وَجْهِكَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"دبر","display":"دُبُرِ"},{"kind":"word","token":"المغرب","display":"الْمَغْرِبِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصلوات","display":"الصَّلَوَاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تقول","display":"تَقُولُ"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذي","display":"اَلَّذِي"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"اله","display":"اِلٰهَ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"عالم","display":"عٰالِمُ"},{"kind":"word","token":"الغيب","display":"الْغَيْبِ"},{"kind":"word","tok