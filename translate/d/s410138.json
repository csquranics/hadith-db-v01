{"consensus_set_id":"s410138","translation_language":"fa","translation_source":{"hid":"410138"},"segments":[{"source_hadith_segment":"« قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ اِنَّ مِنْ شِيعَتِهِ لَاِبْرٰاهِيمَ » </quranic_text>   <footnote> [ الصافات ۸۳ ] </footnote> اَيْ اِنَّ اِبْرَاهِيمَ ( عَلَيْهِ السَّلاَمُ ) مِنْ شِيعَةِ النَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  فَهُوَ مِنْ شِيعَةِ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) ،  وَ كُلُّ مَنْ كَانَ مِنْ شِيعَةِ عَلِيٍّ فَهُوَ مِنْ شِيعَةِ النَّبِيِّ ( صَلَّي اللَّهُ عَلَيْهِمَا وَ عَلَي ذُرِّيَّتِهِمَا الطَّيِّبِينَ ) »","translation_segment":"","segment_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شيعته","display":"شِيعَتِهِ"},{"kind":"word","token":"لابراهيم","display":"لَاِبْرٰاهِيمَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الصافات","display":"الصافات"},{"kind":"word","token":"۸۳","display":"۸۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شيعه","display":"شِيعَةِ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"ال