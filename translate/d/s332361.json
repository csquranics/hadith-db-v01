{"consensus_set_id":"s332361","translation_language":"fa","translation_source":{"hid":"332361"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « وَ لَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضيٰ » </quranic_text>   <footnote> [ الضحي ۵ ] </footnote>","translation_segment":"عن ابن عباس فی قوله: (و لسوف یعطیک ربک فترضی) قال: رضاء محمد (صلی الله علیه و آله) ان لا یدخل أحد من أهل","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لسوف","display":"لَسَوْفَ"},{"kind":"word","token":"يعطيك","display":"يُعْطِيكَ"},{"kind":"word","token":"ربك","display":"رَبُّكَ"},{"kind":"word","token":"فترضي","display":"فَتَرْضيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الضحي","display":"الضحي"},{"kind":"word","token":"۵","display":"۵"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ :  رِضَاءُ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ اَنْ لاَ يَدْخُلَ اَحَدٌ مِنْ اَهْلِ بَيْتِهِ النَّارَ .","translation_segment":"بیته النار. ابن عباس درباره سخن خداوند: «و لسوف یعطیک ربک فترضی» گفت: خوشنودی محمد این است که کسی از اهل بیت او داخل آتش نشود.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رضاء","display":"رِضَاءُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يدخل","display":"يَدْخُلَ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"بيته","display":"بَيْتِهِ"},{"kind":"word","token":"النار","display":"النَّارَ"}]}]}