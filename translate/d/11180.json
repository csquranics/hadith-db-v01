ُ عَزَّ وَ جَلَّ فِي الرَّجْعَةِ ،  وَ قَوْلُهُ :   <quranic_text> « حَتّٰي اِذٰا فَتَحْنٰا عَلَيْهِمْ بٰاباً ذٰا عَذٰابٍ شَدِيدٍ » </quranic_text>   <footnote> [ المؤمنون ۷۷ ] </footnote> هُوَ عَلِيُّ بْنُ اَبِي طَالِبٍ اِذَا رَجَعَ فِي الرَّجْعَةِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الامه","display":"الْاُمَّةِ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"بر","display":"بَرٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"فاجر","display":"فَاجِرٌ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ينشر","display":"يُنْشَرُ"},{"kind":"word","token":"فاما","display":"فَاَمَّا"},{"kind":"word","token":"المؤمنون","display":"الْمُؤْمِنُونَ"},{"kind":"word","token":"فينشرون","display":"فَيُنْشَرُونَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قره","display":"قُرَّةِ"},{"kind":"word","token":"اعينهم","display":"اَعْيُنِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الفجار","display":"الْفُجَّارُ"},{"kind":"word","token":"فينشرون","display":"فَيُنْشَرُونَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"خزي","display":"خِزْيِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"اياهم","display":"اِيَّاهُمْ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تسمع","display":"تَسْمَعْ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{