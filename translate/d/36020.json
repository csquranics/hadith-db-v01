{"consensus_set_id":"36020","translation_language":"fa","translation_source":{"hid":"62954"},"segments":[{"source_hadith_segment":"كانت فاطمة عليها السّلام تذكر لرسول اللّه صلي اللّه عليه و اله","translation_segment":"","segment_columns":[{"kind":"word","token":"كانت","display":"كانت"},{"kind":"word","token":"فاطمه","display":"فاطمة"},{"kind":"word","token":"عليها","display":"عليها"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"تذكر","display":"تذكر"},{"kind":"word","token":"لرسول","display":"لرسول"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"صلي","display":"صلي"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"}]},{"source_hadith_segment":"و سلم فلا يذكرها احد الاّ صدّ عنه حتّي يئسوا منها ؛","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلم"},{"kind":"word","token":"فلا","display":"فلا"},{"kind":"word","token":"يذكرها","display":"يذكرها"},{"kind":"word","token":"احد","display":"احد"},{"kind":"word","token":"الا","display":"الاّ"},{"kind":"word","token":"صد","display":"صدّ"},{"kind":"word","token":"عنه","display":"عنه"},{"kind":"word","token":"حتي","display":"حتّي"},{"kind":"word","token":"يئسوا","display":"يئسوا"},{"kind":"word","token":"منها","display":"منها"}]},{"source_hadith_segment":"فلقي سعد بن معاذ عليّا ،  فقال :","translation_segment":"","segment_columns":[{"kind":"word","token":"فلقي","display":"فلقي"},{"kind":"word","token":"سعد","display":"سعد"},{"kind":"word","token":"بن","display":"بن"},{"kind":"word","token":"معاذ","display":"معاذ"},{"kind":"word","token":"عليا","display":"عليّا"},{"kind":"word","token":"فقال","display":"فقال"}]},{"source_hadith_segment":"انّي - و اللّه - ما اري رسول اللّه صلي اللّه عليه و اله و سلم يحبسها الاّ عليك .  فقال له عليّ :  فلم تري [ ذلك ] ؟  ! - فو اللّه - ما انا بواحد الرجلين :  ما انا بصاحب دنيا يلتمس ما عندي ،  و قد علم ما لي صفراء و لا بيضاء ؛  و ما انا بالكافر الّذي يترفّق بها عن دينه - يعني يتالّفه- ،  و انّي لاوّل من اسلم .  قال سعد :  فانّي اعزم عليك لتفرّجنّها عنّي ،  فانّ لي في ذلك فرجا ؛  قال :  فاقول ما ذا ؟  قال تقول :  جئت خاطبا الي اللّه و الي رسوله فاطمة بنت محمّد صلي اللّه عليه و اله و سلم .  قال :  فانطلق عليّ فعرض للنبيّ صلي اللّه عليه و اله و سلم و هو ثقيل حصر .  فقال له النبيّ صلي اللّه عليه و اله و سلم :  كانّ لك حاجة يا عليّ ؟  قال :  اجل ،  جئتك خاطبا الي اللّه و الي رسوله فاطمة بنت محمّد .  فقال له النبيّ صلي اللّه عليه و اله و سلم :  مرحبا ،  كلمة ضعيفة .  فعاد الي سعد فاخبره فقال :  انكحك ،  فو الّذي بعثه بالحقّ انّه لا خلف الان و لا كذب عنده ،  اعزم عليك لتاتينّه غدا و لتقولنّ :  يا نبيّ اللّه متي تبيّن لي ؟  قال عليّ :  هذا اشدّ عليّ من الاولي ،  اولا اقول :  يا رسول اللّه حاجتي ؟  قال :  قل كما امرتك .  فانطلق عليّ عليه السّلام فقال :  يا رسول اللّه ،  متي تبيّن لي ؟  قال :  الليلة ان شاء اللّه ،  ثمّ دعا بلالا فقال :  يا بلال ،  انّي قد زوّجت ابنتي من ابن عمّي ،  و انا احبّ ان يكون من سنّة امّتي الطعام عند النكاح .  فات الغنم فخذ شاة منها و اربعة امداد فاجعل لي قصعة لعلّي اجمع عليها المهاجرين و الانصار ،  فاذا فرغت منها فاذنّي بها ،  فانطلق ،  ففعل ما امر به ،  ثمّ اتاه بقصعة فوضعها بين يديه ،  فطعن رسول اللّه صلي اللّه عليه و اله و سلم في راسها ثمّ قال :  ادخل عليّ الناس زفّة زفّة لا تغادر زفّة الي غيرها - يعني اذا فرغت زفّة لم تعد ثانية- ؛  فجعل الناس يزفّون كلّما فرغت زفّة ،  وردت اخري حتّي فرغ الناس .  ثمّ عهد النبيّ صلي اللّه عليه و اله و سلم الي فضل ما فيها فتفل فيه و بارك ،  و قال :  يا بلال !  احملها الي امّهاتك ،  و قل لهنّ :  كلن و اطعمن من غشيكنّ .  ثمّ انّ النبيّ صلي اللّه عليه و اله و سلم قام حتّي دخل علي النساء ،  فقال :  انّي زوّجت ابنتي ابن عمّي ،  و قد علمتنّ منزلتها منّي و انّي لدافعها اليه ؛  الا فدونكنّ ابنتكنّ ،  فقام النساء فغلّفنها من طيبهنّ و حليّهنّ ،  و جعلن في بيتها فراشا حشوه ليف ،  و وسادة ،  و كساء خيبريّا ،  و مخضبا ،  و اتّخذن امّ ايمن بوّابة .  ثمّ انّ النبيّ صلي اللّه عليه و اله و سلم دخل فلمّا راه النساء وثبن ،  و بينهنّ و بين النبيّ صلي اللّه عليه و اله و سلم سترة ؛  و تخلّفت اسماء بنت عميس ،  فقال لها النبيّ صلي اللّه عليه و اله و سلم :  كما انت علي رسلك ،  من انت ؟  قالت :  انا الّتي احرس ابنتك ،  انّ الفتاة ليلة يبني بها لا بدّ لها من امراة تكون قريبة منها ،  ان عرضت لها حاجة ،  او ارادت شيئا افضت بذلك اليها .  قال :  فانّي اسال اللّه ان يحرسك من بين يديك و من خلفك و عن يمينك و عن شمالك من الشيطان الرجيم .  ثمّ صرخ بفاطمة عليها السّلام ،  فاقبلت ،  فلمّا رات عليّا عليه السّلام جالسا الي جنب رسول اللّه صلي اللّه عليه و اله","translation_segment":"","segment_columns":[{"kind":"word","token":"اني","display":"انّي"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"اري","display":"اري"},{"kind":"word","token":"رسول","display":"رسول"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"صلي","display":"صلي"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"اله"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلم"},{"kind":"word","token":"يحبسها","display":"يحبسها"},{"kind":"word","token":"الا","display":"الاّ"},{"kind":"word","token":"عليك","display":"عليك"},{"kind":"word","token":"فقال","display":"فقال"},{"kind":"word","token":"له","display":"له"},{"kind":"word","token":"علي","display":"عليّ"},{"kind":"word","token":"فلم","display":"فلم"},{"kind":"word","token":"تري","display":"تري"},{"kind":"word","token":"ذلك","display":"ذلك"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فو","display":"فو"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ما","displ