{"consensus_set_id":"s406139","translation_language":"fa","translation_source":{"hid":"406139"},"segments":[{"source_hadith_segment":"« اِنَّ اَللَّهَ عَزَّ وَ جَلَّ خَلَقَ بَيْتاً مِنْ نُورٍ ،  وَ جَعَلَ قِوَامَهُ اَرْبَعَةَ اَرْكَانٍ :  اللَّهُ اَكْبَرُ ،  وَ لاَ اِلَهَ اِلاَّ اللَّهُ ،  وَ سُبْحَانَ اللَّهِ ،  وَ الْحَمْدُ لِلَّهِ .  ثُمَّ خَلَقَ مِنَ الْاَرْبَعَةِ اَرْبَعَةً ،  وَ مِنَ الْاَرْبَعَةِ اَرْبَعَةً ،  ثُمَّ قَالَ عَزَّ وَ جَلَّ :   <quranic_text> « اِنَّ عِدَّةَ الشُّهُورِ عِنْدَ اللّٰهِ اِثْنٰا عَشَرَ شَهْراً فِي كِتٰابِ اللّٰهِ » </quranic_text>   <footnote> [ التوبة ۳۶ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اَللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"بيتا","display":"بَيْتاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"نور","display":"نُورٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جعل","display":"جَعَلَ"},{"kind":"word","token":"قوامه","display":"قِوَامَهُ"},{"kind":"word","token":"اربعه","display":"اَرْبَعَةَ"},{"kind":"word","token":"اركان","display":"اَرْكَانٍ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"اكبر","display":"اَكْبَرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اله","display":"اِلَهَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سبحان","display":"سُبْحَانَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحمد","display":"الْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token"