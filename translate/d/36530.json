 مِنْ خَلِيلٍ خَيْراً ،  كُنْتَ تَاْمُرُنِي بِطَاعَةِ اللَّهِ ،  وَ تَنْهَانِي عَنْ مَعْصِيَتِهِ .  وَ اَمَّا الْكَافِرَانِ فَتَخَالاَّ بِمَعْصِيَةِ اللَّهِ ،  وَ تَبَاذَلاَ عَلَيْهَا ،  وَ تَوَادَّا عَلَيْهَا ،  فَمَاتَ اَحَدُهُمَا قَبْلَ صَاحِبِهِ ،  فَاَرَاهُ اللَّهُ تَعَالَي مَنْزِلَهُ فِي النَّارِ .  فَقَالَ :  يَا رَبِّ خَلِيلِي فُلاَنٌ كَانَ يَاْمُرُنِي بِمَعْصِيَتِكَ ،  وَ يَنْهَانِي عَنْ طَاعَتِكَ ،  فَثَبِّتْهُ عَلَي مَا ثَبَّتَّنِي عَلَيْهِ مِنَ الْمَعَاصِي حَتَّي تُرِيَهُ مَا اَرَيْتَنِي مِنَ الْعَذَابِ ؛ فَيَلْتَقِيَانِ عِنْدَ اللَّهِ يَوْمَ الْقِيَامَةِ ،  يَقُولُ كُلُّ وَاحِدٍ مِنْهُمَا لِصَاحِبِهِ : جَزَاكَ اللَّهُ عَنِّي مِنْ خَلِيلٍ شَرّاً ،  كُنْتَ تَاْمُرُنِي بِمَعْصِيَةِ اللَّهِ ،  وَ تَنْهَانِي عَنْ طَاعَتِهِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"فاما","display":"فَاَمَّا"},{"kind":"word","token":"الخليلان","display":"الْخَلِيلاَنِ"},{"kind":"word","token":"المؤمنان","display":"الْمُؤْمِنَانِ"},{"kind":"word","token":"فتخالا","display":"فَتَخَالاَّ"},{"kind":"word","token":"حياتهما","display":"حَيَاتَهُمَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"طاعه","display":"طَاعَةِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تباذلا","display":"تَبَاذَلاَ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"توادا","display":"تَوَادَّا"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"فمات","display":"فَمَاتَ"},{"kind":"word","token":"احدهما","display":"اَحَدُهُمَا"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"صاحبه","display":"صَاحِبِهِ"},{"kind":"word","token":"فاراه","display":"فَاَرَاهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"ki