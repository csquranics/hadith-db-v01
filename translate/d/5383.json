{"consensus_set_id":"5383","translation_language":"fa","translation_source":{"hid":"111510"},"segments":[{"source_hadith_segment":"اَنَّ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ حِينَ فَرَغَ مِنْ طَوَافِهِ وَ رَكْعَتَيْهِ قَالَ اَبْدَاُ بِمَا بَدَاَ اللَّهُ عَزَّ وَ جَلَّ بِهِ مِنْ اِتْيَانِ الصَّفَا اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « اِنَّ الصَّفٰا وَ الْمَرْوَةَ مِنْ شَعٰائِرِ اللّٰهِ » </quranic_text>   <footnote> [ البقرة ۱۵۸ ] </footnote>","translation_segment":"معاویه بن عمار گوید: امام صادق علیه السلام فرمود: هنگامی که رسول خدا صلی الله علیه و اله طواف را به پایان رساند و دو رکعت نماز خواند فرمود: از صفا آغاز می‌کنم که","segment_columns":[{"kind":"word","token":"اذا","display":"إذا"},{"kind":"word","token":"اراد","display":"أراد"},{"kind":"word","token":"الانسان","display":"الإنسان"},{"kind":"word","token":"الخروج","display":"الخروج"},{"kind":"word","token":"الي","display":"إلى"},{"kind":"word","token":"الصفا","display":"الصفا"},{"kind":"word","token":"يستحب","display":"يستحب"},{"kind":"word","token":"له","display":"له"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"يستلم","display":"يستلم"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"الاسود","display":"الأسود"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"فرغ","display":"فَرَغَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"طوافه","display":"طَوَافِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ركعتيه","display":"رَكْعَتَيْهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابدا","display":"اَبْدَاُ"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"بدا","display":"بَدَاَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اتيان","display":"اِتْيَانِ"},{"kind":"word","token":"الصفا","display":"الصَّفَا"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الصفا","display":"الصَّفٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المروه","display":"الْمَرْوَةَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شعائر","display":"شَعٰائِرِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۵۸","display":"۱۵۸"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ ثُمَّ اُخْرُجْ اِلَي الصَّفَا مِنَ الْبَابِ الَّذِي خَرَجَ مِنْهُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ هُوَ الْبَابُ الَّذِي يُقَابِلُ الْحَجَرَ الْاَسْوَدَ حَتَّي تَقْطَعَ الْوَادِيَ وَ عَلَيْكَ السَّكِينَةَ وَ الْوَقَارَ فَاصْعَدْ عَلَي الصَّفَا حَتَّي تَنْظُرَ اِلَي الْبَيْتِ وَ تَسْتَقْبِلَ الرُّكْنَ الَّذِي فِيهِ الْحَجَرُ الْاَسْوَدُ وَ اِحْمَدِ اللَّهَ وَ اَثْنِ عَلَيْهِ ثُمَّ اُذْكُرْ مِنْ الاَئِهِ وَ بَلاَئِهِ وَ حُسْنِ مَا صَنَعَ اِلَيْكَ مَا قَدَرْتَ عَلَي ذِكْرِهِ ثُمَّ كَبِّرِ اللَّهَ سَبْعاً وَ اِحْمَدْهُ سَبْعاً وَ هَلِّلْهُ سَبْعاً وَ قُلْ  <quranic_text> « لاٰ اِلٰهَ اِلاَّ اللّٰهُ » </quranic_text>   <footnote> [ محمد ۱۹ ] </footnote>  وَحْدَهُ  <quranic_text> « لاٰ شَرِيكَ لَهُ » </quranic_text>   <footnote> [ الانعام ۱۶۳ ] </footnote>   <quranic_text> « لَهُ الْمُلْكُ وَ لَهُ الْحَمْدُ » </quranic_text>   <footnote> [ التغابن ۱ ] </footnote>   <quranic_text> « يُحْيِي وَ يُمِيتُ » </quranic_text>   <footnote> [ العمران ۱۵۶ ] </footnote>  وَ هُوَ حَيٌّ لاَ يَمُوتُ  <quranic_text> « وَ هُوَ عَليٰ كُلِّ شَيْءٍ قَدِيرٌ » </quranic_text>   <footnote> [ التغابن ۱ ] </footnote>  ثَلاَثَ مَرَّاتٍ ثُمَّ صَلِّ عَلَي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ قُلِ اللَّهُ اَكْبَرُ عَلَي مَا هَدَانَا وَ الْحَمْدُ لِلَّهِ عَلَي مَا اَوْلاَنَا وَ الْحَمْدُ لِلَّهِ الْحَيِّ الْقَيُّومِ وَ الْحَمْدُ لِلَّهِ الْحَيِّ الدَّائِمِ ثَلاَثَ مَرَّاتٍ وَ قُلْ اَشْهَدُ اَنْ لاَ اِلَهَ اِلاَّ اللَّهُ وَ اَشْهَدُ اَنَّ مُحَمَّداً عَبْدُهُ وَ رَسُولُهُ لاَ نَعْبُدُ اِلاَّ اِيَّاهُ  <quranic_text> « مُخْلِصِينَ لَهُ الدِّينَ » </quranic_text>   <footnote> [ الاعراف ۲۹ ] </footnote>   <quranic_text> « وَ لَوْ كَرِهَ الْمُشْرِكُونَ » </quranic_text>   <footnote> [ التوبة ۳۳ ] </footnote>  ثَلاَثَ مَرَّاتٍ اللَّهُمَّ اِنِّي اَسْاَلُكَ","translation_segment":"خداوند متعال از آن آغاز نمود که خدای عز و جل می‌فرماید: «همانا صفا و مروه از شعائر خداوند است». امام صادق علیه السلام فرمود: سپس برو به صفا از دربی که پیامبر خدا صلی الله علیه و اله از آن خارج شد - و آن دری است که مقابل حجر الاسود است - تا وادی را بپیمایی و بر تو باد به آرامش و وقار! سپس بالای صفا برو تا به کعبه بنگری و با رکنی که در آن حجر الاسود است روبه‌رو شوی و سپاس و ستایش خدا را کن سپس از نعمت‌های خداوند و بلای او و نیکی‌هایی که در حق تو کرده، هرچه که می‌توانی به یاد آور. سپس هفت مرتبه تکبیر و «الحمد لله» بگو و هفت مرتبه «لا إله الا الله» بگو و سه مرتبه بگو: «لا إله إلا الله وحده لا شریک له له الملک و له الحمد یحیی و یمیت و هو حی‌ لا یموت و هو علی کل‌ شیء قدیر». سپس بر پیامبر صلی الله علیه و اله صلوات بفرست و سه مرتبه بگو: «الله أکبر علی ما هدانا و الحمد لله علی ما أولانا و الحمد لله الحی‌ القیوم و الحمد لله الحی‌ الدائم». و سه مرتبه بگو: «أشهد أن لا إله إلا الله و أشهد أن‌ محمدا عبده و رسوله لا نعبد إلا إیاه مخلصین له الدین و لو کره المشرکون». و سه مرتبه بگو: «اللهم‌ إنی أسألک العفو و العافیه و الیقین فی الدنیا و الآخره». و سه مرتبه بگو: «اللهم‌ آتنا فی الدنیا حسنه و فی الآخره","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"ياتي","display":"يأتي"},{"kind":"word","token":"زمزم","display":"زمزم"},{"kind":"word","token":"فيشرب","display":"فيشرب"},{"kind":"word","token":"منها","display":"منها"},{"kind":"word","token":"ويصب","display":"ويصب"},{"kind":"word","token":"علي","display":"على"},{"kind":"word","token":"بدنه","display":"بدنه"},{"kind":"word","token":"دلوا","display":"دلوا"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"مائه","display":"مائه"},{"kind":"word","token":"ويكون","display":"ويكون"},{"kind":"word","token":"ذلك","display":"ذلك"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"الدلو","display":"الدلو"},{"kind":"word","token":"الذي","display":"الذي"},{"kind":"word","token":"بحذاء","display":"بحذاء"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"فاذا","display":"فإذا"},{"kind":"word","token":"اراد","display":"أراد"},{"kind":"word","token":"اخرج","display":"اُخْرُجْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الصفا","display":"الصَّفَا"},{"kind":"word","token":"فليكن","display