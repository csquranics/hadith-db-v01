lay":"الْمَشْرِقِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المغرب","display":"الْمَغْرِبِ"},{"kind":"word","token":"صلاتهم","display":"صَلاَتَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صيامهم","display":"صِيَامَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يغفر","display":"يَغْفِرَ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"ذنوبهم","display":"ذُنُوبَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يستجيب","display":"يَسْتَجِيبَ"},{"kind":"word","token":"دعاءهم","display":"دُعَاءَهُمْ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يخبر","display":"يُخْبِرُ"},{"kind":"word","token":"به","display":"بِهِ"}]},{"source_hadith_segment":"وَ الَّذِي بَعَثَنِي بِالْحَقِّ اِنَّ مَنْ صَلَّي هَذِهِ الصَّلاَةَ وَ اِسْتَغْفَرَ هَذَا الاِسْتِغْفَارَ يَتَقَبَّلُ اللَّهُ صَلاَتَهُ وَ صِيَامَهُ وَ قِيَامَهُ وَ يَغْفِرُ لَهُ وَ يَسْتَجِيبُ دُعَاءَهُ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ قَالَ فِي كِتَابِهِ -  <quranic_text> « وَ اَنِ اِسْتَغْفِرُوا رَبَّكُمْ ثُمَّ تُوبُوا اِلَيْهِ » </quranic_text>   <footnote> [ هود ۳ ] </footnote>  وَ قَالَ  <quranic_text> « وَ الَّذِينَ اِذٰا فَعَلُوا فٰاحِشَةً اَوْ ظَلَمُوا اَنْفُسَهُمْ ذَكَرُوا اللّٰهَ فَاسْتَغْفَرُوا لِذُنُوبِهِمْ وَ مَنْ يَغْفِرُ الذُّنُوبَ اِلاَّ اللّٰهُ » </quranic_text>   <footnote> [ العمران ۱۳۵ ] </footnote>  وَ قَالَ  <quranic_text> « وَ اِسْتَغْفِرُوا اللّٰهَ اِنَّ اللّٰهَ غَفُورٌ رَحِيمٌ » </quranic_text>   <footnote> [ المزمل ۲۰ ] </footnote>  وَ قَالَ  <quranic_text> « وَ اِسْتَغْفِرْهُ اِنَّهُ كٰانَ تَوّٰاباً » </quranic_text>   <footnote> [ النصر ۳ ] </footnote>  وَ قَالَ النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ هَذِهِ هَدِيَّةٌ لِي وَ لِاُمَّتِي خَاصَّةً مِنَ الرِّجَالِ وَ النِّسَاءِ وَ لَمْ يُعْطِهَا اَحَداً مِنَ الْاَنْبِيَاءِ الَّذِينَ كَانُوا قَبْلِي وَ لاَ غَيْرَهُمْ .","translation_segment":"و بآن کسی که تو را بحق‌ بپیغمبری مبعوث کرد هر کس بجا آورد این نمازها را و طلب آمرزش کند بدین استغفار خداوند نماز و روزه و شب‌زنده‌داری او را قبول فرماید و او را بیامرزد و دعایش را مستجاب فرمایدزیرا خدای عز و جل‌ در کتاب خود فرموده: «و أن‌ استغفروا ربکم‌ ثم‌ توبوا إلیه‌» (و آنکه از خدا طلب آمرزش کنید سپس بدو رو آورید) و نیز فرموده: «و الذین‌ إذٰا فعلوا فٰاحشه‌ أو ظلموا أنفسهم‌ ذکروا اللٰه‌ فاستغفروا لذنوبهم‌ و من‌ یغفر الذنوب‌ إلا اللٰه‌» (آنان که چون کار زشت مرتکب شدند یا بخویشتن ستم نمودند یاد خدا کردند پس طلب آمرزش نمودند برای گناهان خویش، و کیست که بیامرزد گناهان را جز خدا) و همچنین فرموده: «و استغفروا اللٰه‌ إن‌ اللٰه‌ غفور رحیم‌» (از خدا آمرزش طلبید زیرا او بخشنده و مهربان است) و باز فرموده «و استغفره‌ إنه‌ کٰان‌ توٰابا» (آمرزش خواه از او چون او توبه پذیر است). و رسول خدا صلی اللٰه علیه و اله و سلم فرمود: این هدیه و تحفه‌ای است برای من و امتم بخصوص، از مردان و زنان، و بهیچ یک از انبیایی که پیش از من بوده‌اند و غیر ایشان نداده است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"بعثني","display":"بَعَثَنِي"},{"kind":"word","token":"بالحق","display":"بِالْحَقِّ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"استغفر","display":"اِسْتَغْفَرَ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الاستغفار","display":"الاِسْتِغْفَارَ"},{"kind":"word","token":"يتقبل","display":"يَتَقَبَّلُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"صلاته","display":"صَلاَتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صيامه","display":"صِيَامَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قيامه","display":"قِيَامَهُ"},{"kind":"word","token