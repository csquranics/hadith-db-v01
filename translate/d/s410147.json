 وَ لَقَدْ قَالَ اِبْرَاهِيمُ ( عَلَيْهِ السَّلاَمُ ) :   <quranic_text> « بَلْ فَعَلَهُ كَبِيرُهُمْ هٰذٰا » </quranic_text>   <footnote> [ الانبياء ۶۳ ] </footnote>   ،  وَ مَا فَعَلَهُ ،  وَ لاَ كَذَبَ ،  وَ لَقَدْ قَالَ يُوسُفُ ( عَلَيْهِ السَّلاَمُ ) :   <quranic_text> « اَيَّتُهَا الْعِيرُ اِنَّكُمْ لَسٰارِقُونَ » </quranic_text>   <footnote> [ يوسف ۷۰ ] </footnote>   ،  وَ اللَّهِ مَا كَانُوا سَارِقِينَ ،  وَ مَا كَذَبَ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يريد","display":"يُرِيدُ"},{"kind":"word","token":"سالم","display":"سَالِمٌ"},{"kind":"word","token":"مني","display":"مِنِّي"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"يريد","display":"يُرِيدُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"اجيء","display":"اَجِيءَ"},{"kind":"word","token":"بالملائكه","display":"بِالْمَلاَئِكَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"جاءت","display":"جَاءَتْ"},{"kind":"word","token":"بهذا","display":"بِهَذَا"},{"kind":"word","token":"النبيون","display":"النَّبِيُّونَ"},{"kind":"word","token":"فلقد","display":"فَلَقَدْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابراهيم","display":"اِبْرَاهِيمُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"سقيم","display":"سَقِيمٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الصافات","display":"الصافات"},{"kind":"word","token":"۸۹","display":"۸۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","di