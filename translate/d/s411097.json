{"consensus_set_id":"s411097","translation_language":"fa","translation_source":{"hid":"411097"},"segments":[{"source_hadith_segment":"« لَمْ يَنْزِلْ مِنَ السَّمَاءِ شَيْءٌ اَقَلُّ وَ لاَ اَعَزُّ مِنْ ثَلاَثَةِ اَشْيَاءَ :  اَمَّا اَوَّلُهَا فَالتَّسْلِيمُ ،  وَ الثَّانِيَةُ الْبِرُّ ،  وَ الثَّالِثَةُ الْيَقِينُ ،  اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ فِي كِتَابِهِ :   <quranic_text> « فَمٰا وَجَدْنٰا فِيهٰا غَيْرَ بَيْتٍ مِنَ الْمُسْلِمِينَ » </quranic_text>   <footnote> [ الذاريات ۳۶ ] </footnote> .  وَ قَدْ تَقَدَّمَتْ رِوَايَاتٌ كَثِيرَةٌ فِي مَعْنَي هَذِهِ الْايَاتِ فِي سُورَةِ هُودٍ ،  مَنْ اَرَادَهَا وَقَفَ عَلَيْهَا مِنْ هُنَاكَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"ينزل","display":"يَنْزِلْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"السماء","display":"السَّمَاءِ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"اقل","display":"اَقَلُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اعز","display":"اَعَزُّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةِ"},{"kind":"word","token":"اشياء","display":"اَشْيَاءَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"اولها","display":"اَوَّلُهَا"},{"kind":"word","token":"فالتسليم","display":"فَالتَّسْلِيمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الثانيه","display":"الثَّانِيَةُ"},{"kind":"word","token":"البر","display":"الْبِرُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الثالثه","display":"الثَّالِثَةُ"},{"kind":"word","token":"اليقين","display":"الْيَقِينُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"k