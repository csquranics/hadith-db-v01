{"consensus_set_id":"s332283","translation_language":"fa","translation_source":{"hid":"332283"},"segments":[{"source_hadith_segment":"نَزَلَتْ عَلَي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ هَذِهِ الْايَةُ :  [   <quranic_text> « وَ تَعِيَهٰا اُذُنٌ وٰاعِيَةٌ » </quranic_text>   <footnote> [ الحاقة ۱۲ ] </footnote>   ] فَسَاَلَهُ اَنْ يَجْعَلَهَا اُذُنَ عَلِيٍّ فَفَعَلَ .","translation_segment":"عن جابر قال: نزلت علی النبی صلی الله علیه و آله و سلم هذه الآیه (و تعیها أذن واعیه) فسأله أن یجعلها أذن علی‌ ففعل. جابر گفت: این آیه بر پیامبر نازل شد: «و تعیها اذن واعیه» پس از خدا خواست که گوش او را چنین کند و کرد.","segment_columns":[{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعيها","display":"تَعِيَهٰا"},{"kind":"word","token":"اذن","display":"اُذُنٌ"},{"kind":"word","token":"واعيه","display":"وٰاعِيَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحاقه","display":"الحاقة"},{"kind":"word","token":"۱۲","display":"۱۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فساله","display":"فَسَاَلَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يجعلها","display":"يَجْعَلَهَا"},{"kind":"word","token":"اذن","display":"اُذُنَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"ففعل","display":"فَفَعَلَ"}]}]}