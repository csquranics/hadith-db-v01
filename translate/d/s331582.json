{"consensus_set_id":"s331582","translation_language":"fa","translation_source":{"hid":"331582"},"segments":[{"source_hadith_segment":"حُذِّرْنَا فِتْنَةً وَ مَا نَدْرِي مَنْ تَخَلَّفَ لَهَا ،  ثُمَّ قَرَاَ  <quranic_text> « وَ اِتَّقُوا فِتْنَةً » </quranic_text>   <footnote> [ الانفال ۲۵ ] </footnote>  فَقَالَ بَعْضُهُمْ :  سُبْحَانَ اللَّهِ فَمَا لَكُمْ فَقَالَ :  وَيْحَكَ اِنَّمَا نُبْصِرُ وَ لَكِنْ لاَ نَصْبِرُ .","translation_segment":"أن‌ الزبیر قال: حذرنا فتنه و ما ندری من تخلف لها، ثم‌ قرأ (اتقوا فتنه) فقال بعضهم: سبحان الله فما لکم‌؟ فقال: و یحک إنما نبصر و لکن لا نصبر. زبیر گفت: از فتنه‌ای بر حذر شدیم و نمی‌دانستیم چه کسی در آن می‌ماند؟ سپس این آیه را خواند: «و اتقوا فتنه» بعضی از آنان گفتند: سبحان الله شما را چه شده است‌؟ پس گفت: وای بر تو ما می‌بینیم ولی صبر نمی‌کنیم.","segment_columns":[{"kind":"word","token":"حذرنا","display":"حُذِّرْنَا"},{"kind":"word","token":"فتنه","display":"فِتْنَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"ندري","display":"نَدْرِي"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"تخلف","display":"تَخَلَّفَ"},{"kind":"word","token":"لها","display":"لَهَا"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"فتنه","display":"فِتْنَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۲۵","display":"۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"بعضهم","display":"بَعْضُهُمْ"},{"kind":"word","token":"سبحان","display":"سُبْحَانَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","