{"consensus_set_id":"s345473","translation_language":"fa","translation_source":{"hid":"345473"},"segments":[{"source_hadith_segment":"مَنْ قَرَاَ سُورَةَ  <quranic_text> « اِذٰا زُلْزِلَتِ الْاَرْضُ » </quranic_text>   <footnote> [ الزلزلة ۱ ] </footnote>  اَرْبَعَ مَرَّاتٍ كَانَ كَمَنْ قَرَاَ الْقُرْانَ كُلَّهُ .","translation_segment":"باین اسناد گوید که رسول خدا (صلی الله علیه و آله) فرمود هر کس چهار مرتبه سوره اذا زلزلت را بخواند مثل آنست که تمام قرآن را خوانده باشد.","segment_columns":[{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"سوره","display":"سُورَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اذا","display":"اِذٰا"},{"kind":"word","token":"زلزلت","display":"زُلْزِلَتِ"},{"kind":"word","token":"الارض","display":"الْاَرْضُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزلزله","display":"الزلزلة"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اربع","display":"اَرْبَعَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"كمن","display":"كَمَنْ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"القران","display":"الْقُرْانَ"},{"kind":"word","token":"كله","display":"كُلَّهُ"}]}]}