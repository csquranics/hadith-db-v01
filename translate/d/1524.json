splay":"اِلَي"},{"kind":"word","token":"السماء","display":"السَّمَاءِ"},{"kind":"word","token":"الرابعه","display":"الرَّابِعَةِ"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"بملك","display":"بِمَلَكٍ"},{"kind":"word","token":"متك","display":"مُتَّكٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"سرير","display":"سَرِيرٍ"},{"kind":"word","token":"تحت","display":"تَحْتَ"},{"kind":"word","token":"يده","display":"يَدِهِ"},{"kind":"word","token":"ثلاث","display":"ثَلاَثُ"},{"kind":"word","token":"مائه","display":"مِائَةِ"},{"kind":"word","token":"الف","display":"اَلْفِ"},{"kind":"word","token":"ملك","display":"مَلَكٍ"},{"kind":"word","token":"تحت","display":"تَحْتَ"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"ملك","display":"مَلَكٍ"},{"kind":"word","token":"ثلاث","display":"ثَلاَثُ"},{"kind":"word","token":"مائه","display":"مِائَةِ"},{"kind":"word","token":"الف","display":"اَلْفِ"},{"kind":"word","token":"ملك","display":"مَلَكٍ"}]},{"source_hadith_segment":".  قَالَ :  « وَ فُتِحَ الْبَابُ ،  وَ مَرَّ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) حَتَّي اِنْتَهَي اِلَي السَّمَاءِ السَّابِعَةِ - قَالَ - وَ اِنْتَهَي اِلَي سِدْرَةِ الْمُنْتَهَي - قَالَ - فَقَالَتِ السِّدْرَةُ :  مَا جَاوَزَنِي مَخْلُوقٌ قَبْلَكَ ؛  ثُمَّ مَضَي فَتَدَانَي فَتَدَلَّي فَكَانَ قَابَ قَوْسَيْنِ اَوْ اَدْنَي ،  فَاَوْحَي اللَّهُ اِلَي عَبْدِهِ مَا اَوْحَي - قَالَ - فَدَفَعَ اِلَيْهِ كِتَابَيْنِ :  كِتَابَ اَصْحَابِ الْيَمِينِ بِيَمِينِهِ ،  وَ [ كِتَابَ ] اَصْحَابِ الشِّمَالِ بِشِمَالِهِ ،  فَاَخَذَ كِتَابَ اَصْحَابِ الْيَمِينِ بِيَمِينِهِ ،  وَ فَتَحَهُ وَ نَظَرَ فِيهِ ،  فَاِذَا فِيهِ اَسْمَاءُ اَهْلِ الْجَنَّةِ ،  وَ اَسْمَاءُ ابَائِهِمْ وَ قَبَائِلِهِمْ - قَالَ - فَقَالَ اللَّهُ :   <quranic_text> « امَنَ الرَّسُولُ بِمٰا اُنْزِلَ اِلَيْهِ مِنْ رَبِّهِ » </quranic_text>   <footnote> [ البقرة ۲۸۵ ] </footnote> ،  فَقَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  <quranic_text> « وَ الْمُؤْمِنُونَ كُلٌّ امَنَ بِاللّٰهِ وَ مَلاٰئِكَتِهِ وَ كُتُبِهِ وَ رُسُلِهِ لاٰ نُفَرِّقُ بَيْنَ اَحَدٍ مِنْ رُسُلِهِ » </quranic_text>   <footnote> [ البقرة ۲۸۵ ] </footnote> ،  فَقَالَ اللَّهُ :   <quranic_text> « وَ قٰالُوا سَمِعْنٰا وَ اَطَعْنٰا » </quranic_text>   <footnote> [ البقرة ۲۸۵ ] </footnote> ،  فَقَالَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  <quranic_text> « غُفْرٰانَكَ رَبَّنٰا وَ اِلَيْكَ الْمَصِيرُ » </quranic_text>   <footnote> [ البقرة ۲۸۵ ] </footnote> ،  قَالَ اللَّهُ :   <quranic_text> « لاٰ يُكَلِّفُ اللّٰهُ نَفْساً اِلاّٰ وُسْعَهٰا لَهٰا مٰا كَسَبَتْ وَ عَلَيْهٰا مَا اِكْتَسَبَتْ » </quranic_text>   <footnote> [ البقرة ۲۸۶ ] </footnote> .  قَالَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :   <quranic_text> « رَبَّنٰا لاٰ تُؤٰاخِذْنٰا اِنْ نَسِينٰا اَوْ اَخْطَاْنٰا » </quranic_text>   <footnote> [ البقرة ۲۸۶ ] </footnote> ،  - قَالَ - فَقَالَ اللَّهُ :  قَدْ فَعَلْتُ .  فَقَالَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :   <quranic_text> « رَبَّنٰا وَ لاٰ تَحْمِلْ عَلَيْنٰا اِصْراً كَمٰا حَمَلْتَهُ عَلَي الَّذِينَ مِنْ قَبْلِنٰا » </quranic_text>   <footnote> [ البقرة ۲۸۶ ] </footnote> ،  قَالَ :  قَدْ فَعَلْتُ .  فَقَالَ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :   <quranic_text> « رَبَّنٰا وَ لاٰ تُحَمِّلْنٰا مٰا لاٰ طٰاقَةَ لَنٰا بِهِ وَ اُعْفُ عَنّٰا وَ اِغْفِرْ لَنٰا وَ اِرْحَمْنٰا اَنْتَ مَوْلاٰنٰا فَانْصُرْنٰا عَلَي الْقَوْمِ الْكٰافِرِينَ » </quranic_text>   <footnote> [ البقرة ۲۸۶ ] </footnote> ،  كُلَّ ذَلِكَ يَقُولُ اللَّهُ :  قَدْ فَعَلْتُ .  ثُمَّ طَوَي الصَّحِيفَةَ فَاَمْسَكَهَا بِيَمِينِهِ ،  وَ فَتَحَ الْاُخْرَي ،  صَحِيفَةَ اَصْحَابِ الشِّمَالِ ،  فَاِذَا فِيهَا اَسْمَاءُ اَهْلِ النَّارِ ،  وَ اَسْمَاءُ ابَائِهِمْ وَ قَبَائِلِهِمْ ،  - قَالَ - فَقَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :  اِنَّ هَؤُلاَءِ قَوْمٌ لاَ يُؤْمِنُونَ .  فَقَالَ اللَّهُ :  يَا مُحَمَّدُ  ،   <quranic_text> « فَاصْفَحْ عَنْهُمْ وَ قُلْ سَلاٰمٌ فَسَوْفَ يَعْلَمُونَ » </quranic_text>   <footnote> [ الزخرف ۸۹ ] </footnote> .  قَالَ :  « فَلَمَّا فَرَغَ مِنْ مُنَاجَاةِ رَبِّهِ ،  رُدَّ اِلَي الْبَيْتِ الْمَعْمُورِ ،  وَ هُوَ فِي السَّمَاءِ السَّابِعَةِ بِحِذَاءِ الْكَعْبَةِ - قَالَ - فَجَمَعَ لَهُ النَّبِيِّينَ وَ الْمُرْسَلِينَ وَ الْمَلاَئِكَةَ ،  ثُمَّ اَمَرَ جَبْرَئِيلَ فَاَتَمَّ الْاَذَانَ ،  وَ اَقَامَ الصَّلاَةَ ،  وَ تَقَدَّمَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  ،  فَصَلَّي بِهِمْ ،  فَلَمَّا فَرَغَ اِلْتَفَتَ اِلَيْهِمْ ،  فَقَالَ اللَّهُ لَهُ :   <quranic_text> « فَسْئَلِ الَّذِينَ يَقْرَؤُنَ الْكِتٰابَ مِنْ قَبْلِكَ لَقَدْ جٰاءَكَ الْحَقُّ مِنْ رَبِّكَ فَلاٰ تَكُونَنَّ مِنَ المُمْتَرِينَ » </quranic_text>   <footnote> [ يونس ۹۴ ] </footnote>  فَسَاَلَهُمْ يَوْمَئِذٍ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  ،  ثُمَّ نَزَلَ وَ مَعَهُ صَحِيفَتَانِ ،  فَدَفَعَهُمَا اِلَي اَمِيرِ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ )  » .  فَقَالَ اَبُو عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ )  :  « فَهَذَا كَانَ بَدْءَ الْاَذَانِ » .","translation_segment":"","segment_columns":[]}]}