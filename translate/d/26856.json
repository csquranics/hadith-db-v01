gment":".  « اللهمّ خذ [ لنا ] بحقّنا ،  و انتقم من ظالمنا ، و احلل غضبك بمن سفك دماءنا ،  و قتل حماتنا »","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فو اللّه ما فويت الاّ جلدك ،  و لا جززت الاّ لحمك","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و لتردنّ علي رسول اللّه صلّي اللّه عليه و اله بما تحمّلت من سفك دماء ذرّيّته","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و انتهكت من حرمته في عترته و لحمته","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  حيث يجمع اللّه شملهم ،  و يلمّ شعثهم ،  و ياخذ بحقّهم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،   <quranic_text> « وَ لاٰ تَحْسَبَنَّ الَّذِينَ قُتِلُوا فِي سَبِيلِ اللّٰهِ اَمْوٰاتاً بَلْ اَحْيٰاءٌ عِنْدَ رَبِّهِمْ يُرْزَقُونَ » </quranic_text>   <footnote> [ العمران ۱۶۹ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"، [ و ] حسبك باللّه حاكما ،  و بمحمّد صلّي اللّه عليه و اله خصيما ،  و بجبرئيل ظهيرا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و سيعلم من سوّي لك و مكّنك من رقاب المسلمين ،  بئس للظالمين بدلا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و ايّكم شرّ مكانا و اضعف جندا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و لئن جرت عليّ الدواهي مخاطبتك انّي لاستصغر قدرك","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و استعظم تقريعك و استكبر توبيخك ،  لكن العيون عبري ،  و الصدور حرّي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  الا فالعجب كلّ العجب لقتل حزب اللّه النجباء بحزب الشيطان الطلقاء","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فهذه الايدي تنطف من دمائنا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و الافواه تتحلّب من لحومنا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و تلك الجثث الطواهر الزواكي تنتابها العواسل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و تعفّرها امّهات الفراعل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و لئن اتّخذتنا مغنما لتجدنا وشيكا مغرما","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  حين لا تجد الاّ ما قدّمت [ يداك ] و ما ربّك بظلاّم للعبيد","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فالي اللّه المشتكي و عليه المعوّل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فكد كيدك واسع سعيك ،  و ناصب جاهدك","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فو اللّه لا تمحو ذكرنا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و لا تميت وحينا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و لا تدرك امدنا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و لا ترحض عنك عارها","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و هل رايك الاّ فند","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و ايّامك الاّ عدد","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و جمعك الاّ بدد","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  يوم ينادي المنادي الا لعنة اللّه علي الظالمين","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فالحمد للّه الّذي ختم لاوّلنا بالسعادة [ و المغفرة","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"] ،  و لاخرنا بالشهادة و الرحمة","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و نسال اللّه ان يكمل لهم الثواب","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و يوجب لهم المزيد","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و يحسن علينا الخلافة انّه رحيم ودود [ و ] حسبنا اللّه و نعم الوكيل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فقال يزيد لعنه اللّه :  يا صيحة تحمد من صوائحما اهون الموت علي النوائح","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قال :  ثمّ استشار اهل الشام فيما يصنع بهم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فقالوا : « لا تتّخذ [ نّ ] من كلب سوء جروا »","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"، فقال له النعمان بن بشير :  انظر ما كان الرسول يصنعه بهم فاصنعه بهم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و قال المفيد « ره » :  ثمّ قال لعليّ بن الحسين عليهما السّلام :  يا ابن الحسين ابوك قطع رحمي ،  و جهل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و نازعني ( في ) سلطاني","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فصنع اللّه به ما قد رايت","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فقال عليّ بن الحسين عليهما السّلام :   <quranic_text> « مٰا اَصٰابَ مِنْ مُصِيبَةٍ فِي الْاَرْضِ وَ لاٰ فِي اَنْفُسِكُمْ اِلاّٰ فِي كِتٰابٍ مِنْ قَبْلِ اَنْ نَبْرَاَهٰا اِنَّ ذٰلِكَ عَلَي اللّٰهِ يَسِيرٌ » </quranic_text>   <footnote> [ الحديد ۲۲ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"، فقال يزيد لابنه خالد :  اردد عليه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"!  فلم يدر خالد ما يردّ عليه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فقال له يزيد قل :   <quranic_text> « وَ مٰا اَصٰابَكُمْ مِنْ مُصِيبَةٍ فَبِمٰا كَسَبَتْ اَيْدِيكُمْ وَ يَعْفُوا عَنْ كَثِيرٍ » </quranic_text>   <footnote> [ الشوري ۳۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و قال صاحب المناقب بعد ذلك :  فقال عليّ بن الحسين عليهما السّلام :  يا ابن معاوية و هند و صخر لم تزل النبوّة و الامرة لابائي و اجدادي من قبل ان تولد","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و لقد كان جدّي عليّ بن ابي طالب عليه السّلام في يوم بدر و احد و الاحزاب في يده راية رسول اللّه صلّي اللّه عليه و اله","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"و ابوك و جدّك في ايديهما رايات الكفّار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  ثم جعل عليّ بن الحسين عليهما السّلام يقول :  ما ذا تقولون اذ قال النبيّ لكمما ذا فعلتم و انتم اخر الامم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  بعترتي و باهلي عند مفتقديمنهم اساري و منهم ضرّجوا بدم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ثمّ قال عليّ بن الحسين عليهما السّلام :  ويلك يا يزيد انّك لو تدري ما ذا صنعت","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  و ما الّذي ارتكبت من ابي و اهل بيتي و اخي و عمومتي اذا لهربت في الجبال ،  و افترشت الرماد ،  و دعوت بالويل و الثبور ،  ان يكون راس ابي الحسين بن فاطمة و عليّ منصوبا علي باب مدينتكم و هو وديعة رسول اللّه صلّي اللّه عليه و اله فيكم ،  فابشر بالخزي و الندامة غدا اذا جمع الناس ليوم القيامة","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و قال المفيد « ره » :  ثمّ دعا بالنساء و الصبيان فاجلسوا بين يديه ،  فراي هيئة قبيحة ،  فقال :  قبّح اللّه ابن مرجانة لو كانت بينكم و بينه قرابة و رحم ما فعل هذا بكم و لا بعث بكم علي هذه الحالة فقالت فاطمة بنت الحسين عليه السّلام :  و لمّا جلسنا بين يدي يزيد رقّ لنا ،  فقام اليه رجل من [ اهل ] الشام احمر ،  فقال :  يا امير المؤمنين هب لي هذه الجارية - يعنيني - و كنت جارية وضيئة ،  فارعدت و ظننت انّ ذلك جائز لهم ،  فاخذت بثياب عمّتي زينب ،  و كانت تعلم انّ ذلك لا يكون","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و في رواية السيّد :  قلت :  او تمت و استخدم ؟  فقالت عمّتي للشاميّ :  كذبت و اللّه و لؤمت ، و اللّه ما ذلك لك و لا له ،  فغضب يزيد و قال :  كذبت و اللّه انّ ذلك لي و لو شئت ان افعل لفعلت ،  قالت :  كلاّ و اللّه ما جعل اللّه لك ذلك الاّ ان تخرج من ملّتنا ،  و تدين بغيرها ،  فاستطار يزيد لعنه اللّه غضبا ،  و قال :  ايّاي تستقبلين بهذا ؟  انّما خرج من الدين ابوك و اخوك ،  قالت زينب عليها السّلام :  بدين اللّه و دين ابي و دين اخي اهتديت انت و ابوك و جدّك ان كنت مسلما ،  قال :  كذبت يا عدوّة اللّه ،  قالت [ له ] :  انت امير تشتم ظالما و تقهر بسلطانك ، فكانّه استحيا و سكت ،  و عاد الشاميّ ،  فقال :  هب لي هذه الجارية ،  فقال له يزيد :  اعزب ،  و هب اللّه لك حتفا قاضيا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و في بعض الكتاب :  قالت امّ كلثوم للشامي :  اسكت يا لكع الرجال ،  قطع اللّه لسانك ،  و اعمي عينيك ،  و ايبس يديك","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و جعل النار مثواك","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  انّ اولاد الانبياء لا يكونون خدمة لاولاد الادعياء","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  قال :  فو اللّه ما استتمّ كلامها حتّي اجاب اللّه دعاءها في ذلك الرجل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فقالت :  الحمد للّه الّذي عجّل لك العقوبة في الدنيا قبل الاخرة","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فهذا جزاء من يتعرّض لحرم رسول اللّه صلّي اللّه عليه و اله","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و في رواية السيّد « ره » :  فقال الشاميّ :  من هذه الجارية","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  فقال يزيد :  هذه فاطمة بنت الحسين ،  و تلك زينب بنت عليّ بن ابي طالب","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فقال الشامي :  الحسين بن فاطمة و عليّ بن ابي طالب عليهم السّلام","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  !  قال :  نعم ،  فقال الشامي :  لعنك اللّه يا يزيد ،  [ ا ] تقتل عترة نبيّك و تسبي ذرّيّته","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"!  و اللّه ما توهّمت الاّ انّهم [ من ] سبيّ الروم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فقال يزيد :  و اللّه لالحقنّك بهم ،  ثمّ امر به فضرب عنقه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال السيّد :  و دعا يزيد بالخطيب و امره ان يصعد المنبر فيذمّ الحسين عليه السّلام و اباه صلوات اللّه عليهما","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فصعد و بالغ في ذمّ ابي الحسن امير المؤمنين و الحسين الشهيد صلوات اللّه عليهما و المدح لمعاوية و يزيد","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فصاح به عليّ بن الحسين عليهما السّلام :  ويلك ايّها الخطيب اشتريت مرضاة المخلوق بسخط الخالق فتبوّا مقعدك من النار","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  و لقد احسن ابن سنان الخفاجيّ في وصف امير المؤمنين عليه السّلام بقوله :  اعلي المنابر تعلنون بسبّهو بسيفه نصبت لكم اعوادها ؟","translation_segment":"","segment_columns":[]}]}