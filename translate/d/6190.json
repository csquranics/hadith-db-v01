{"consensus_set_id":"6190","translation_language":"fa","translation_source":{"hid":"104470"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا الْحَسَنِ الرِّضَا عَلَيْهِ السَّلاَمُ عَنْ قَوْلِهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ لِكُلٍّ جَعَلْنٰا مَوٰالِيَ مِمّٰا تَرَكَ الْوٰالِدٰانِ وَ الْاَقْرَبُونَ وَ الَّذِينَ عَقَدَتْ اَيْمٰانُكُمْ » </quranic_text>   <footnote> [ النساء ۳۳ ] </footnote>  قَالَ اِنَّمَا عَنَي بِذَلِكَ الْاَئِمَّةَ عَلَيْهِمُ السَّلاَمُ بِهِمْ عَقَدَ اللَّهُ عَزَّ وَ جَلَّ اَيْمَانَكُمْ .","translation_segment":"حسن بن محبوب گوید: از حضرت رضا ع راجع بقول خدای عز و جل پرسیدم (آیه ۳۳ - سوره ۴) «همه را در ترکه پدران و مادران و خویشان، بستگانی قرار داده‌ایم و کسانی را که با آنها دست (بیعت یا پیمان) داده‌اید» (بهره آنها را بدهید) حضرت فرمود: مقصود ائمه ع باشند که خدای عز و جل پیمان شما را با ایشان بسته است.","segment_columns":[{"kind":"word","token":"كتبت","display":"كَتَبْتُ"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكل","display":"لِكُلٍّ"},{"kind":"word","token":"جعلنا","display":"جَعَلْنٰا"},{"kind":"word","token":"موالي","display":"مَوٰالِيَ"},{"kind":"word","token":"مما","display":"مِمّٰا"},{"kind":"word","token":"ترك","display":"تَرَكَ"