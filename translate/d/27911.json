{"consensus_set_id":"27911","translation_language":"fa","translation_source":{"hid":"393914"},"segments":[{"source_hadith_segment":"ذَكَرَ بَنَي يَعْقُوبَ قَالَ :  كَانُوا اِذَا غَضِبُوا اِشْتَدَّ غَضَبُهُمْ حَتَّي تَقْطُرَ جُلُودُهُمْ دَماً اِصْفَرَّ وَ هُمْ يَقُولُونَ :   <quranic_text> « فَخُذْ اَحَدَنٰا مَكٰانَهُ » </quranic_text>   <footnote> [ يوسف ۷۸ ] </footnote>  يَعْنِي جَزَاءَهُ فَاَخَذَ الَّذِي وَجَدَ الصَّاعَ عِنْدَهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"بني","display":"بَنَي"},{"kind":"word","token":"يعقوب","display":"يَعْقُوبَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"غضبوا","display":"غَضِبُوا"},{"kind":"word","token":"اشتد","display":"اِشْتَدَّ"},{"kind":"word","token":"غضبهم","display":"غَضَبُهُمْ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"تقطر","display":"تَقْطُرَ"},{"kind":"word","token":"جلودهم","display":"جُلُودُهُمْ"},{"kind":"word","token":"دما","display":"دَماً"},{"kind":"word","token":"اصفر","display":"اِصْفَرَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فخذ","display":"فَخُذْ"},{"kind":"word","token":"احدنا","display":"اَحَدَنٰا"},{"kind":"word","token":"مكانه","display":"مَكٰانَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۷۸","display":"۷۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"جزاءه","display":"جَزَاءَهُ"},{"kind":"word","token":"فاخذ","display":"فَاَخَذَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","tok