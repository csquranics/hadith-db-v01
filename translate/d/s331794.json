{"consensus_set_id":"s331794","translation_language":"fa","translation_source":{"hid":"331794"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « سَيَجْعَلُ لَهُمُ الرَّحْمٰنُ وُدًّا » </quranic_text>   <footnote> [ مريم ۹۶ ] </footnote>  قَالَ :  لاَ تَلْقَي مُؤْمِناً اِلاَّ وَ فِي قَلْبِهِ مَوَدَّةٌ لِعَلِيٍّ وَ ذُرِّيَّتِهِ .","translation_segment":"عن محمد بن الحنفیه فی قوله تعالی: (سیجعل لهم الرحمان ودا) قال: لا تلقی مومنا إلا و فی قلبه موده لعلی و ذریته. محمد بن حنفیه راجع به آیه: «سیجعل لهم الرحمن ودا» گفت هیچ مومنی را ملاقات نمی‌کنی مگر اینکه در دل او محبتی برای علی و اولاد اوست.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سيجعل","display":"سَيَجْعَلُ"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"ودا","display":"وُدًّا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"مريم","display":"مريم"},{"kind":"word","token":"۹۶","display":"۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تلقي","display":"تَلْقَي"},{"kind":"word","token":"مؤمنا","display":"مُؤْمِناً"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قلبه","display":"قَلْبِهِ"},{"kind":"word","token":"موده","display":"مَوَدَّةٌ"},{"kind":"word","token":"لعلي","display":"لِعَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذريته","display":"ذُرِّيَّتِهِ"}]}]}