:"اَنْفُسَكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۶۱","display":"۶۱"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"ثُمَّ قَالَ فَاَيَّ شَيْءٍ قَالُوا ؟  قَالَ قُلْتُ قَالُوا قَدْ يَكُونُ وَلَدُ الْبِنْتِ","translation_segment":"جماعت در آن حال چه گفتند؟ گفتم: که ایشان گفتند که: پسر دختر پسر پدر است نه پسر پدر مادر- است و اگر أحیانا پسر دختر را پسر گویند هر آینه آن پسر صلبی نیست. أبا الجارود","segment_columns":[{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فاي","display":"فَاَيَّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"ولد","display":"وَلَدُ"},{"kind":"word","token":"البنت","display":"الْبِنْتِ"}]},{"source_hadith_segment":"مِنَ الْوَلَدِ وَ لاَ يَكُونُ مِنَ الصُّلْبِ قَالَ فَقَالَ اَبُو جَعْفَرٍ وَ اللَّهِ يَا اَبَا الْجَارُودِ لَاُعْطِيَنَّكُمْ مِنْ كِتَابِ اللَّهِ ايَةً يُسَمِّي لِصُلْبِ رَسُولِ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لاَ يَرُدُّهَا اِلاَّ كَافِرٌ قَالَ قُلْتُ جُعِلْتُ فِدَاكَ وَ اَيْنَ ؟  قَالَ قَالَ حَيْثُ قَالَ -  <quranic_text> « حُرِّمَتْ عَلَيْكُمْ اُمَّهٰاتُكُمْ وَ بَنٰاتُكُمْ وَ اَخَوٰاتُكُمْ » </quranic_text>   <footnote> [ النساء ۲۳ ] </footnote>  اِلَي قَوْلِهِ  <quranic_text> « وَ حَلاٰئِلُ اَبْنٰائِكُمُ الَّذِينَ مِنْ اَصْلاٰبِكُمْ » </quranic_text>   <footnote> [ النساء ۲۳ ] </footnote>  فَسَلْهُمْ يَا اَبَا الْجَارُودِ وَ هَلْ يَحِلُّ لِرَسُولِ اللَّهِ نِكَاحُ حَلِيلَتَيْهِمَا ؟  فَاِنْ قَالُوا نَعَمْ فَكَذَبُوا وَ اللَّهِ وَ اِنْ قَالُوا لاَ فَهُمَا وَ اللَّهِ اِبْنَا رَسُولِ اللَّهِ لِصُلْبِهِ وَ مَا حَرُمْنَ عَلَيْهِ اِلاَّ لِلصُّلْبِ .","translation_segment":"فرمود که: حضرت أبو جعفر (علیه السلام) روی مبارک بمن آورد، و گفت: من سند این کلام از آیه کتاب ایزد علام بشما بنمایم که حضرت اللٰه- تعالی آن دو نفر بزرگوار را از صلب رسول اللٰه (صلی الله علیه و آله) شمردند و پسران حضرت رسول ایزد منان نامیدند و رد این آیه وافی هدایت نمیکند مگر کافر منکر. من گفتم: فدای تو شوم یا بن رسول اللٰه (صلی الله علیه و آله) کجاست آن محل‌ که: حضرت عز و جل‌ حسن و حسین را پسران رسول ذو المنن نامیدند؟ آن حضرت فرمود که: یا أبا الجارود در جایی که خدای تبارک و تعالی میفرماید که: حرمت‌ علیکم‌ أمهٰاتکم‌ و بنٰاتکم‌ الی قوله و حلاٰئل‌ أبنٰائکم‌ الذین‌ من‌ أصلاٰبکم‌ باید که از آن جماعت سوال نمائید که آیا حضرت رسول صلی اللٰه علیه و آله و سلم را حلال است که حلیله حسن و حسین را نکاح کند. اگر گویند نعم و اللٰه که دروغ میگویند. و اگر گویند که روا نیست پس و اللٰه ایشان پسران صلبی حضرت رسول صلی اللٰه علیه و آله و سلم‌اند و حلیله ایشان بر آن حضرت علیه الصلوه و السلام حرام نشد مگر به علت آنکه آن أعیان از صلب رسول صلی اللٰه علیه و آله و سلم ایزد منان‌اند.","segment_columns":[{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الولد","display":"الْوَلَدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الصلب","display":"الصُّلْبِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"