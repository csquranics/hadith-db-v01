{"consensus_set_id":"11018","translation_language":"fa","translation_source":{"hid":"405173"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي  <quranic_text> « الَّذِينَ كَذَّبُوا بِايٰاتِنٰا صُمٌّ وَ بُكْمٌ » </quranic_text>   <footnote> [ الانعام ۳۹ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"ثم","display":"ثمّ"},{"kind":"word","token":"يجتمعون","display":"يجتمعون"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"موطن","display":"موطن"},{"kind":"word","token":"اخر","display":"اخر"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"فيستنطقون","display":"فَيَسْتَنْطِقُونَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"كذبوا","display":"كَذَّبُوا"},{"kind":"word","token":"باياتنا","display":"بِايٰاتِنٰا"},{"kind":"word","token":"صم","display":"صُمٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بكم","display":"بُكْمٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۳۹","display":"۳۹"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":".  يَقُولُ :  « صُمٌّ عَنِ الْهُدَي ،  وَ بُكْمٌ لاَ يَتَكَلَّمُونَ بِخَيْرٍ  <quranic_text> « فِي الظُّلُمٰاتِ » </quranic_text>   <footnote> [ الانعام ۳۹ ] </footnote>  يَعْنِي ظُلُمَاتِ الْكُفْرِ <quranic_text> « مَنْ يَشَاِ اللّٰهُ يُضْلِلْهُ وَ مَنْ يَشَاْ يَجْعَلْهُ عَليٰ صِرٰاطٍ مُسْتَقِيمٍ » </quranic_text>   <footnote> [ الانعام ۳۹ ] </footnote>  وَ هُوَ رَدٌّ عَلَي قَدَرِيَّةِ هَذِهِ الْاُمَّةِ ،  يَحْشُرُهُمُ اللَّهُ يَوْمَ الْقِيَامَةِ مَعَ الصَّابِئِينَ وَ النَّصَارَي وَ الْمَجُوسِ فَيَقُولُونَ :   <quranic_text> « وَ اللّٰهِ رَبِّنٰا مٰا كُنّٰا مُشْرِكِينَ » </quranic_text>   <footnote> [ الانعام ۲۳ ] </footnote> يَقُولُ اللَّهُ :   <quranic_text> « اُنْظُرْ كَيْفَ كَذَبُوا عَليٰ اَنْفُسِهِمْ وَ ضَلَّ عَنْهُمْ مٰا كٰانُوا يَفْتَرُونَ » </quranic_text>   <footnote> [ الانعام ۲۴ ] </footnote> - قَالَ - فَقَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  :  اَلاَ اِنَّ لِكُلِّ اُمَّةٍ مَجُوساً ،  وَ مَجُوسُ هَذِهِ الْاُمَّةِ الَّذِينَ يَقُولُونَ :  لاَ قَدَرَ ،  وَ لاَ يَزْعُمُونَ اَنَّ الْمَشِيئَةَ وَ الْقُدْرَةَ اِلَيْهِمْ وَ لَهُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"صم","display":"صُمٌّ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الهدي","display":"الْهُدَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بكم","display":"بُكْمٌ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يتكلمون","display":"يَتَكَلَّمُونَ"},{"kind":"word","token":"بخير","display":"بِخَيْرٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الظلمات","display":"الظُّلُمٰاتِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۳۹","display":"۳۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"ظلمات","display":"ظُلُمَاتِ"},{"kind":"word","token":"الكفر","display":"الْكُفْرِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يشا","display":"يَشَاِ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"يضلله","display":"يُضْلِلْهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يشا","display":"يَشَاْ"},{"kind":"word","token":"يجعله","display":