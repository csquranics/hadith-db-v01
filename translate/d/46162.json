{"consensus_set_id":"46162","translation_language":"fa","translation_source":{"hid":"106787"},"segments":[{"source_hadith_segment":"اَلْمُسْتَضْعَفُونَ اَلَّذِينَ  <quranic_text> « لاٰ يَسْتَطِيعُونَ حِيلَةً وَ لاٰ يَهْتَدُونَ سَبِيلاً » </quranic_text>   <footnote> [ النساء ۹۸ ] </footnote>  قَالَ لاَ يَسْتَطِيعُونَ حِيلَةً اِلَي الْاِيمَانِ وَ لاَ يَكْفُرُونَ الصِّبْيَانُ وَ اَشْبَاهُ عُقُولِ الصِّبْيَانِ مِنَ الرِّجَالِ وَ النِّسَاءِ .","translation_segment":"و نیز زراره از آن حضرت علیه السلام حدیث کند که فرمود: مستضعفان «آن کسانند که چاره‌ای نتوانند و راه بجائی نبرند» فرمود: (یعنی) چاره بسوی ایمان نتوانند و کافر هم نشوند، (و اینها کودکانند. و کسانی که عقلشان چون کودکان است از مردان و زنان.","segment_columns":[{"kind":"word","token":"المستضعفون","display":"اَلْمُسْتَضْعَفُونَ"},{"kind":"word","token":"الذين","display":"اَلَّذِينَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يستطيعون","display":"يَسْتَطِيعُونَ"},{"kind":"word","token":"حيله","display":"حِيلَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يهتدون","display":"يَهْتَدُونَ"},{"kind":"word","token":"سبيلا","display":"سَبِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۹۸","display":"۹۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يستطيعون","display":"يَسْتَطِيعُونَ"},{"kind":"word","token":"حيله","display":"حِيلَةً"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الايمان","display":"الْاِيمَانِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يكفرون","display":"يَكْفُرُونَ"},{"kind":"word","token":"