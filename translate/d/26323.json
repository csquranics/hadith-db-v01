{"consensus_set_id":"26323","translation_language":"fa","translation_source":{"hid":"382861"},"segments":[{"source_hadith_segment":"يَا اَيُّهَا النَّاسُ !  اِتَّقُوا اللَّهَ ،  وَ لاَ تُكْثِرُوا السُّؤَالَ ،  اِنَّمَا هَلَكَ مَنْ كَانَ قَبْلَكُمْ بِكَثْرَةِ سُؤَالِهِمْ اَنْبِيَاءَهُمْ وَ قَدْ قَالَ اللَّهُ - عَزَّ وَ جَلَّ-  <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا لاٰ تَسْئَلُوا عَنْ اَشْيٰاءَ اِنْ تُبْدَ لَكُمْ تَسُؤْكُمْ » </quranic_text>   <footnote> [ المائدة ۱۰۱ ] </footnote>  وَ اِسْاَلُوا عَمَّا اِفْتَرَضَ اللَّهُ عَلَيْكُمْ ،  وَ اللَّهِ اِنَّ الرَّجُلَ يَاْتِينِي فَيَسْاَلُنِي فَاُخْبِرُهُ فَيَكْفُرُ ،  وَ لَوْ لَمْ يَسْاَلْنِي مَا ضَرَّهُ ،  وَ قَالَ اللَّهُ :   <quranic_text> « وَ اِنْ تَسْئَلُوا عَنْهٰا حِينَ يُنَزَّلُ الْقُرْانُ تُبْدَ لَكُمْ » </quranic_text>   <footnote> [ المائدة ۱۰۱ ] </footnote>  الْايَةَ وَ  <quranic_text> « قَدْ سَاَلَهٰا قَوْمٌ مِنْ قَبْلِكُمْ ثُمَّ اَصْبَحُوا بِهٰا كٰافِرِينَ » </quranic_text>   <footnote> [ المائدة ۱۰۲ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"يقول","display":"يقول"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تكثروا","display":"تُكْثِرُوا"},{"kind":"word","token":"السؤال","display":"السُّؤَالَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"هلك","display":"هَلَكَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"قبلكم","display":"قَبْلَكُمْ"},{"kind":"word","token":"بكثره","display":"بِكَثْرَةِ"},{"kind":"word","token":"سؤالهم","display":"سُؤَالِهِمْ"},{"kind":"word","token":"انبياءهم","display":"اَنْبِيَاءَهُمْ"},{"kind":"word","token":"و",