{"consensus_set_id":"39381","translation_language":"fa","translation_source":{"hid":"305371"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنْ رَجُلٍ طَلَّقَ اِمْرَاَتَهُ عِنْدَ قُرْئِهَا تَطْلِيقَةً ثُمَّ لَمْ يُرَاجِعْهَا ثُمَّ طَلَّقَهَا عِنْدَ قُرْئِهَا الثَّالِثَةَ فَبَانَتْ مِنْهُ ،  اَ لَهُ اَنْ يُرَاجِعَهَا قَالَ :  نَعَمْ ،  قُلْتُ :  قَبْلَ اَنْ يَتَزَوَّجَ زَوْجاً غَيْرَهُ قَالَ :  نَعَمْ ،  قُلْتُ لَهُ فَرَجُلٌ طَلَّقَ اِمْرَاَتَهُ تَطْلِيقَةً ثُمَّ رَاجَعَهَا ثُمَّ طَلَّقَهَا ثُمَّ رَاجَعَهَا ثُمَّ طَلَّقَهَا ،  قَالَ لاَ تَحِلُّ لَهُ  <quranic_text> « حَتّٰي تَنْكِحَ زَوْجاً غَيْرَهُ » </quranic_text>   <footnote> [ البقرة ۲۳۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"طلق","display":"طَلَّقَ"},{"kind":"word","token":"امراته","display":"اِمْرَاَتَهُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"قرئها","display":"قُرْئِهَا"},{"kind":"word","token":"تطليقه","display":"تَطْلِيقَةً"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يراجعها","display":"يُرَاجِعْهَا"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"طلقها","display":"طَلَّقَهَا"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"قرئها","display":"قُرْئِهَا"},{"kind":"word","token":"الثالثه","display":"الثَّالِثَةَ"},{"kind":"word","token":"فبانت","display":"فَبَانَتْ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يراجعها","display":"يُرَاجِعَهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"wor