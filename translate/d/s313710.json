{"consensus_set_id":"s313710","translation_language":"fa","translation_source":{"hid":"313710"},"segments":[{"source_hadith_segment":"فَبَلَغَ ذَلِكَ اَمِيرَ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ","translation_segment":"خطبه حسن بن علی چون سخنان ابن زبیر به گوش علی","segment_columns":[{"kind":"word","token":"فبلغ","display":"فَبَلَغَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]},{"source_hadith_segment":"فَقَالَ لِوَلَدِهِ الْحَسَنِ عَلَيْهِ السَّلاَمُ قُمْ يَا بُنَيَّ فَاخْطُبْ","translation_segment":"رسید به پسرش حسن فرمود: پسرم! برخیز و سخنرانی کن. حسن (علیه","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لولده","display":"لِوَلَدِهِ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قم","display":"قُمْ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"بني","display":"بُنَيَّ"},{"kind":"word","token":"فاخطب","display":"فَاخْطُبْ"}]},{"source_hadith_segment":"فَقَامَ خَطِيباً فَحَمِدَ اللَّهَ وَ اَثْنَي عَلَيْهِ وَ قَالَ","translation_segment":"السلام) برخاست و پس از حمد و ثنای خداوند چنین گفت: ای","segment_columns":[{"kind":"word","token":"فقام","display":"فَقَامَ"},{"kind":"word","token":"خطيبا","display":"خَطِيباً"},{"kind":"word","token":"فحمد","display":"فَحَمِدَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اثني","display":"اَثْنَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« اَيُّهَا النَّاسُ قَدْ بَلَغَنَا مَقَالَةُ اِبْنِ الزُّبَيْرِ وَ قَدْ كَانَ وَ اللَّهِ اَبُوهُ يَتَجَنَّي عَلَي عُثْمَانَ الذُّنُوبَ وَ قَدْ ضَيَّقَ عَلَيْهِ الْبِلاَدَ حَتَّي قُتِلَ وَ اِنَّ طَلْحَةَ رَاكِزٌ رَايَتَهُ عَلَي بَيْتِ مَالِهِ وَ هُوَ حَيٌّ وَ اَمَّا قَوْلُهُ اِنَّ عَلِيّاً اِبْتَزَّ النَّاسَ اُمُورَهُمْ فَاِنَّهُ اَعْظَمُ حُجَّةً لِاَبِيهِ زَعَمَ اَنَّهُ بَايَعَهُ بِيَدِهِ وَ لَمْ يُبَايِعْهُ بِقَلْبِهِ فَقَدْ اَقَرَّ بِالْبَيْعَةِ وَ اِدَّعَي الْوَلِيجَةَ فَلْيَاْتِ عَلَي مَا اِدَّعَاهُ بِبُرْهَانٍ وَ اَنَّي لَهُ ذَلِكَ وَ اَمَّا تَعَجُّبُهُ مِنْ تَوَرُّدِ اَهْلِ الْكُوفَةِ عَلَي اَهْلِ الْبَصْرَةِ فَمَا عَجَبُهُ مِنْ اَهْلِ حَقٍّ تَوَرَّدُوا عَلَي اَهْلِ بَاطِلٍ وَ لَعَمْرِي وَ اللَّهِ لَيَعْلَمَنَّ اَهْلُ الْبَصْرَةِ فَمِيعَادُ مَا بَيْنَنَا وَ بَيْنَهُمْ يَوْمَ نُحَاكِمُهُمْ اِلَي اللَّهِ فَيَقْضِي اللَّهُ بِالْحَقِّ <quranic_text> « وَ هُوَ خَيْرُ الْفٰاصِلِينَ » </quranic_text>   <footnote> [ الانعام ۵۷ ] </footnote> فَلَمَّا فَرَغَ الْحَسَنُ عَلَيْهِ السَّلاَمُ مِنْ كَلاَمِهِ قَامَ رَجُلٌ يُقَالُ لَهُ عُمَرُ بْنُ مَحْمُودٍ فَقَالَ شِعْراً يَمْدَحُ الْحَسَنَ عَلَيْهِ السَّلاَمُ فِيهِ عَلَي خُطْبَتِهِ .","translation_segment":"مردم! سخنان ابن زبیر به اطلاع ما رسید و به خدا سوگند که او بر عثمان گناهانش را بر می‌شمرد و گاه به او تهمت می‌زد و چنان سرزمینها را بر عثمان تنگ کرد تا کشته شد و طلحه در حالی که هنوز عثمان زنده بود رایت خود را بر بیت المال برافراشت. اما اینکه می‌گوید علی حکومت مردم را با زور غصب کرده است پدرش مدعی است که با دست خود با علی بیعت کرده ولی با قلب خود بیعت نکرده است. بنابراین اقرار به بیعت می‌کند و بعد بهانه می‌تراشد. لازم است برای ادعای خود برهان و دلیل آورد و کجا ممکن است بتواند دلیل بیاورد؟ اما شگفت کردن ابن زبیر از اینکه مردم کوفه به سوی مردم بصره آمده‌اند؛ چه جای شگفت است که اهل حق به سوی اهل باطل هجوم آورند و به جان خودم و به خدا سوگند مردم بصره خواهند دانست و امروز وعده‌گاه ما و ایشان است. به پیشگاه خداوند متعال درباره آنان داوری می‌بریم و خدای بر حق قضاوت خواهد کرد که بهترین قضاوت کنندگان است. چون سخنان حسن (علیه السلام) تمام شد، مردی بنام عمر بن محمود برخاست و شعری در ستایش حسن (علیه السلام) خواند.","segment_columns":[{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"بلغنا","display":"بَلَغَنَا"},{"kind":"word","token":"مقاله","display":"مَقَالَةُ"},{"kind":"word","token":"ابن","display":"اِبْنِ"},{"kind":"word","token":"الزبير","display":"الزُّبَيْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ابوه","display":"اَبُوهُ"},{"kind":"word","token":"يتجني","display":"يَتَجَنَّي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"عثمان","display":"عُثْمَانَ"},{"kind":"word","token":"الذنوب","display":"الذُّنُوبَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"ضيق","display":"ضَيَّقَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"البلاد","display":"الْبِلاَدَ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"قتل","display":"قُتِلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"طلحه","display":"طَلْحَةَ"},{"kind":"word","token":"راكز","display":"رَاكِزٌ"},{"kind":"word","token":"رايته","display":"رَايَتَهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"بيت","display":"بَيْتِ"},{"kind":"word","token":"ماله","display":"مَالِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"حي","display":"حَيٌّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"عليا","dis