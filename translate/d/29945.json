{"consensus_set_id":"29945","translation_language":"fa","translation_source":{"hid":"115858"},"segments":[{"source_hadith_segment":"اَوْ اَبِي عَبْدِ اللَّهِ عَلَيْهِمَا السَّلاَمُ  :  فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « فَلْيَنْظُرْ اَيُّهٰا اَزْكيٰ طَعٰاماً فَلْيَاْتِكُمْ بِرِزْقٍ مِنْهُ » </quranic_text>   <footnote> [ الكهف ۱۹ ] </footnote>  قَالَ اَزْكَي طَعَاماً التَّمْرُ .","translation_segment":"عبد العزیز گوید: امام باقر یا امام صادق علیهما السلام درباره آیه‌ای که می‌فرماید: «بایستی بنگرد کدام یک از آنها غذای پاکیزه‌تری دارند؛ مقداری از آن برای روزی شما بیاورد» فرمود: «پاکیزه‌ترین غذا» همان خرما است.","segment_columns":[{"kind":"word","token":"عن","display":"عن"},{"kind":"word","token":"ابي","display":"أبي"},{"kind":"word","token":"جعفر","display":"جعفر"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلينظر","display":"فَلْيَنْظُرْ"},{"kind":"word","token":"ايها","display":"اَيُّهٰا"},{"kind":"word","token":"ازكي","display":"اَزْكيٰ"},{"kind":"word","token":"طعاما","display":"طَعٰاماً"},{"kind":"word","token":"فلياتكم","display":"فَلْيَاْتِكُمْ"},{"kind":"word","token":"برزق","display":"بِرِزْقٍ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","