{"consensus_set_id":"13227","translation_language":"fa","translation_source":{"hid":"108878"},"segments":[{"source_hadith_segment":"اِذَا كُنْتَ خَلْفَ اِمَامٍ فَقَرَاَ الْحَمْدَ وَ فَرَغَ مِنْ قِرَاءَتِهَا فَقُلْ اَنْتَ  <quranic_text> « اَلْحَمْدُ لِلّٰهِ رَبِّ الْعٰالَمِينَ » </quranic_text>   <footnote> [ الفاتحة ۲ ] </footnote>  وَ لاَ تَقُلْ امِينَ .","translation_segment":"جمیل گوید: امام صادق علیه السلام فرمود: هرگاه پشت سر امام جماعت نماز می‌خوانی، و امام، سوره حمد را می‌خواند و از قرائت آن فارغ می‌شود، بگو: «الحمد لله رب‌ العالمین» و «آمین» نگو.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"كنت","display":"كُنْتَ"},{"kind":"word","token":"خلف","display":"خَلْفَ"},{"kind":"word","token":"امام","display":"اِمَامٍ"},{"kind":"word","token":"فقرا","display":"فَقَرَاَ"},{"kind":"word","token":"الحمد","display":"الْحَمْدَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فرغ","display":"فَرَغَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قراءتها","display":"قِرَاءَتِهَا"},{"kind":"word","token":"فقل","display":"فَقُلْ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحمد","display":"اَلْحَمْدُ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"رب","display":"رَبِّ"},{"kind":"word","token":"العالمين","display":"الْعٰالَمِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تقل","display":"تَقُلْ"},{"kind":"word","token":"امين","display":"امِينَ"}]}]}