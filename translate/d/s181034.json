{"consensus_set_id":"s181034","translation_language":"fa","translation_source":{"hid":"181034"},"segments":[{"source_hadith_segment":"وَ سُئِلَ الصَّادِقُ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « اِنَّ اللّٰهَ لاٰ يَغْفِرُ اَنْ يُشْرَكَ بِهِ وَ يَغْفِرُ مٰا دُونَ ذٰلِكَ لِمَنْ يَشٰاءُ » </quranic_text>   <footnote> [ النساء ۴۸ ] </footnote>","translation_segment":"از امام صادق علیه السلام در باره این آیه: خداوند نمی‌آمرزد اینکه شرک ورزیده شود و می‌آمرزد غیر از آن را بر هر که بخواهد (نساء/۴۸) سوال شد که آیا گناهان کبیره در این استثناء (و غیر از آن را می‌آمرزد بر","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يغفر","display":"يَغْفِرُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يشرك","display":"يُشْرَكَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يغفر","display":"يَغْفِرُ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"دون","display":"دُونَ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"يشاء","display":"يَشٰاءُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء