{"consensus_set_id":"71583","translation_language":"fa","translation_source":{"hid":"323544"},"segments":[{"source_hadith_segment":"اِنَّ مَثَلَ اَبِي طَالِبٍ مَثَلُ اَصْحَابِ الْكَهْفِ حِينَ كَتَمُوا الْاِيمَانَ وَ اَظْهَرُوا الشِّرْكَ فَاتَاهُمْ  <quranic_text> « اَجْرَهُمْ مَرَّتَيْنِ » </quranic_text>   <footnote> [ القصص ۵۴ ] </footnote>   .","translation_segment":"امام صادق (علیه السلام) هم فرموده است: مثل ابو طالب مثل اصحاب کهف است که ایمان خود را پوشیده داشتند و تظاهر به شرک کردند و خداوند پاداش آنان را دو برابر عنایت فرمود.","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"مثل","display":"مَثَلَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"مثل","display":"مَثَلُ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابِ"},{"kind":"word","token":"الكهف","display":"الْكَهْفِ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"كتموا","display":"كَتَمُوا"},{"kind":"word","token":"الايمان","display":"الْاِيمَانَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اظهروا","display":"اَظْهَرُوا"},{"kind":"word","token":"الشرك","display":"الشِّرْكَ"},{"kind":"word","token":"فاتاهم","display":"فَاتَاهُمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اجرهم","display":"اَجْرَهُمْ"},{"kind":"word","token":"مرتين","display":"مَرَّتَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۵۴","display":"۵۴"},{"kind":"tag_close","tag_name":"footnote"}]}]}