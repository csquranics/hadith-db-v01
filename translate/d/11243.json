قَوْلِهِمْ ،  وَ اِتَّبَعُوا مَا اَمَرُوهُمْ بِهِ ،  وَ دَانُوا بِمَا دَعَوْهُمْ اِلَيْهِ ،  فَاتَّخَذُوهُمْ اَرْبَاباً بِطَاعَتِهِمْ لَهُمْ وَ تَرْكِهِمْ اَمْرَ اللَّهِ وَ كُتُبَهُ وَ رُسُلَهُ ،  فَنَبَذُوهُ وَرَاءَ ظُهُورِهِمْ ،  وَ مَا اَمَرَهُمْ بِهِ الْاَحْبَارُ وَ الرُّهْبَانُ اِتَّبَعُوهُ وَ اَطَاعُوهُمْ وَ عَصَوُا اللَّهَ ،  وَ اِنَّمَا ذَكَرَ هَذَا فِي كِتَابِنَا لِكَيْ يَتَّعِظَ بِهِ ،  فَعَيَّرَ اللَّهُ بَنِي اِسْرَائِيلَ بِمَا صَنَعُوا ،  يَقُولُ اللَّهُ : <quranic_text> « وَ مٰا اُمِرُوا اِلاّٰ لِيَعْبُدُوا اِلٰهاً وٰاحِداً لاٰ اِلٰهَ اِلاّٰ هُوَ سُبْحٰانَهُ عَمّٰا يُشْرِكُونَ » </quranic_text>   <footnote> [ التوبة ۳۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"المسيح","display":"الْمَسِيحُ"},{"kind":"word","token":"فعصوه","display":"فعصوه"},{"kind":"word","token":"فبعض","display":"فَبَعْضٌ"},{"kind":"word","token":"عظموه","display":"عَظَّمُوهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"انفسهم","display":"اَنْفُسِهِمْ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"زعموا","display":"زَعَمُوا"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"اله","display":"اِلَهٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طائفه","display":"طَائِفَةٌ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"ثالث","display":"ثَالِثُ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طائفه","display":"طَائِفَةٌ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"قالوا","display":"قَالُوا"},{"kind":"word","token":"هو","di