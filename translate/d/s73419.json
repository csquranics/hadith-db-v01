{"consensus_set_id":"s73419","translation_language":"fa","translation_source":{"hid":"73419"},"segments":[{"source_hadith_segment":"حيث دخلنا عليه قال :  « مرحبا و سهلا و اهلا بكم ،  و اللّه انّا لنسرّ بكم ،  فانّكم ما احببتمونا لدنيا تصيبونها منازلها ،  و لا مال ،  و انّما احببتمونا لقرابتنا من رسول اللّه في توحيده للّه وحده لا شريك له ،  انّ اللّه قضي علي اهل السماوات و الارض الموت ،  فقال :   <quranic_text> « كُلُّ شَيْءٍ هٰالِكٌ اِلاّٰ وَجْهَهُ » </quranic_text>   <footnote> [ القصص ۸۸ ] </footnote> ،  اللّهمّ فكما كانوا مع ال محمّد في الدنيا فاجعلهم معهم في الاخرة ،  اللّهمّ كما كان سرّهم مع سرّهم فاجعلهم في ثقل محمّد يوم القيامة و ال محمّد »","translation_segment":"","segment_columns":[{"kind":"word","token":"حيث","display":"حيث"},{"kind":"word","token":"دخلنا","display":"دخلنا"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"مرحبا","display":"مرحبا"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سهلا","display":"سهلا"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اهلا","display":"اهلا"},{"kind":"word","token":"بكم","display":"بكم"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"انا","display":"انّا"},{"kind":"word","token":"لنسر","display":"لنسرّ"},{"kind":"word","token":"بكم","display":"بكم"},{"kind":"word","token":"فانكم","display":"فانّكم"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"احببتمونا","display":"احببتمونا"},{"kind":"word","token":"لدنيا","display":"لدنيا"},{"kind":"word","token":"تصيبونها","display":"تصيبونها"},{"kind":"word","token":"منازلها","display":"منازلها"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"لا","display":"لا"},{"kind":"word","token":"مال","display":"مال"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"انما","display":"انّما"},{"kind":"word","token":"احببتمونا","display":"احببتمونا"},{"kind