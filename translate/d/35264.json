ذَا اِشْتَدَّ الْقَتْلُ قُلْتُمْ :  مَاتَ وَ هَلَكَ وَ اَيَّ وَادٍ سَلَكَ ،  وَ ذَلِكَ تَاْوِيلُ هَذِهِ الْايَةِ :   <quranic_text> « ثُمَّ رَدَدْنٰا لَكُمُ الْكَرَّةَ عَلَيْهِمْ وَ اَمْدَدْنٰاكُمْ بِاَمْوٰالٍ وَ بَنِينَ وَ جَعَلْنٰاكُمْ اَكْثَرَ نَفِيراً » </quranic_text>   <footnote> [ الاسراء ۶ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ثكلتك","display":"ثَكِلَتْكَ"},{"kind":"word","token":"امك","display":"اُمُّكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اي","display":"اَيُّ"},{"kind":"word","token":"العجب","display":"الْعَجَبِ"},{"kind":"word","token":"اعجب","display":"اَعْجَبُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اموات","display":"اَمْوَاتٍ"},{"kind":"word","token":"يضربون","display":"يَضْرِبُونَ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"عدو","display":"عَدُوٍّ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لرسوله","display":"لِرَسُولِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لاهل","display":"لِاَهْلِ"},{"kind":"word","token":"بيته","display":"بَيْتِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"تاويل","display":"تَاْوِيلُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تتولوا","display":"تَتَوَلَّوْا"},{"kind":"word","token":"قوما","display":"قَوْماً"},{"kind":"word","token":"غضب","display":"غَضِبَ"},{"kind":"word","token":"الله","disp