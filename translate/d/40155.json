{"consensus_set_id":"40155","translation_language":"fa","translation_source":{"hid":"407656"},"segments":[{"source_hadith_segment":"« اَنَّ رَجُلاً سَاَلَ الْعَالِمَ ( عَلَيْهِ السَّلاَمُ ) :  اَ كَلَّفَ اللَّهُ الْعِبَادَ مَا لاَ يُطِيقُونَ ؟  فَقَالَ :  كَلَّفَ اللَّهُ جَمِيعَ الْخَلْقِ مَا لاَ يُطِيقُونَهُ ،  اِنْ لَمْ يُعِنْهُمْ عَلَيْهِ ،  فَاِنْ اَعَانَهُمْ عَلَيْهِ اَطَاقُوهُ ،  قَالَ اللَّهُ جَلَّ وَ عَزَّ لِنَبِيِّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :   <quranic_text> « وَ اِصْبِرْ وَ مٰا صَبْرُكَ اِلاّٰ بِاللّٰهِ » </quranic_text>   <footnote> [ النحل ۱۲۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"العالم","display":"الْعَالِمَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"كلف","display":"كَلَّفَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"العباد","display":"الْعِبَادَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يطيقون","display":"يُطِيقُونَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"كلف","display":"كَلَّفَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"جميع","display":"جَمِيعَ"},{"kind":"word","token":"الخلق","display":"الْخَلْقِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يطيقونه","display":"يُطِيقُونَهُ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يعنهم","display":"يُعِنْهُمْ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"اعانهم","display":"اَعَانَ