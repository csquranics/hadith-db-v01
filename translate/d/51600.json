{"consensus_set_id":"51600","translation_language":"fa","translation_source":{"hid":"102368"},"segments":[{"source_hadith_segment":"وَ سَاَلْتُهُ اَ يُكْرَهُ الْجِمَاعُ فِي سَاعَةٍ مِنَ","translation_segment":"عمرو بن عثمان گوید: از امام باقر علیه","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"يكره","display":"يُكْرَهُ"},{"kind":"word","token":"الجماع","display":"الْجِمَاعُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ساعه","display":"سَاعَةٍ"},{"kind":"word","token":"من","display":"مِنَ"}]},{"source_hadith_segment":"السَّاعَاتِ قَالَ « نَعَمْ يُكْرَهُ فِي لَيْلَةٍ يَنْخَسِفُ فِيهَا الْقَمَرُ وَ الْيَوْمِ الَّذِي تَنْكَسِفُ فِيهِ الشَّمْسُ وَ فِيمَا بَيْنَ غُرُوبِ الشَّمْسِ اِلَي اَنْ يَغِيبَ الشَّفَقُ وَ مِنْ طُلُوعِ الْفَجْرِ اِلَي طُلُوعِ الشَّمْسِ وَ فِي الرِّيحِ السَّوْدَاءِ وَ الْحَمْرَاءِ وَ الصَّفْرَاءِ وَ الزَّلْزَلَةِ وَ لَقَدْ بَاتَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ لَيْلَةً عِنْدَ بَعْضِ نِسَائِهِ فَانْخَسَفَ الْقَمَرُ فِي تِلْكَ اللَّيْلَةِ فَلَمْ يَكُنْ مِنْهُ شَيْءٌ فَقَالَتْ لَهُ زَوْجَتُهُ يَا رَسُولَ اللَّهِ بِاَبِي اَنْتَ وَ اُمِّي اَ كُلُّ هَذَا لِبُغْضٍ فَقَالَ « وَيْحَكِ حَدَثَ هَذَا الْحَادِثُ فِي السَّمَاءِ فَكَرِهْتُ اَنْ اَتَلَذَّذَ وَ اَدْخُلَ فِي شَيْءٍ وَ لَقَدْ عَيَّرَ اللَّهُ تَعَالَي قَوْماً فَقَالَ :   <quranic_text> « وَ اِنْ يَرَوْا كِسْفاً مِنَ السَّمٰاءِ سٰاقِطاً يَقُولُوا سَحٰابٌ مَرْكُومٌ » </quranic_text>   <footnote> [ الطور ۴۴ ] </footnote>  وَ اَيْمُ اللَّهِ لاَ يُجَامِعُ اَحَدٌ فِي هَذِهِ السَّاعَاتِ الَّتِي وَصَفْتُ فَيُرْزَقَ مِنْ جِمَاعِهِ وَلَداً وَ قَدْ سَمِعَ هَذَا الْحَدِيثَ فَيَرَي مَا يُحِبُّ » .","translation_segment":"السلام پرسیدم: آیا همبستری در ساعتی از ساعات مکروه است‌؟ فرمود: آری، در شبی که ماه بگیرد (خسوف) و روزی که خورشید بگیرد (کسوف)، و ما بین غروب آفتاب تا غایب شدن سرخی در آسمان، و ما بین طلوع فجر تا طلوع خورشید، و در هنگامی که باد سیاه یا سرخ و یا زرد می‌وزد، همچنین در موقع زلزله، و رسول خدا صلی اللٰه علیه و آله شبی با یکی از همسرانش در بستر بود که ماه گرفت حضرت بستر را ترک نمود، همسرش پرسید: آیا از من رنجیده شده‌اید؟ فرمود: نه، خدایت رحمت کند، خوش ندارم در حالی که این پدیده در آسمان پیش آمده به خوشگذرانی بپردازم، و براستی که خداوند ملامت فرموده و گوید: «إن یروا کسفا من السماء ساقطا یقولوا سحاب مرکوم …» و بخدا سوگند اگر در چنین اوقاتی هر کس که این حدیث را شنیده باشد انعقاد نطفه نماید آنچه آرزو کرده در چنین فرزندی نخواهد دید (یعنی خیری در او نیست).","segment_columns":[{"kind":"word","token":"الساعات","display":"السَّاعَاتِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"يكره","display":"يُكْرَهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ليله","display":"لَيْلَةٍ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"ينخسف","display":"يَنْخَسِفُ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"القمر","display":"الْقَمَرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اليوم","display":"الْيَوْمِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"تنكسف","display":"تَنْكَسِفُ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"الشمس","display":"الشَّمْسُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فيما","display":"فِيمَا"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"غروب","display":"غُرُوبِ"},{"kind":"word","token":"الشمس","display":"الشَّمْسِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يغيب","display":"يَغِيبَ"},{"kind":"word","token":"الشفق","displ