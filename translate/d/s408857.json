{"consensus_set_id":"s408857","translation_language":"fa","translation_source":{"hid":"408857"},"segments":[{"source_hadith_segment":"« اِنَّ اَللَّهَ تَبَارَكَ وَ تَعَالَي خَلَقَ الْاَرْوَاحَ قَبْلَ الْاَبْدَانِ بِاَلْفَيْ عَامٍ ،  ثُمَّ خَلَقَ الْاَبْدَانَ بَعْدَ ذَلِكَ ،  فَمَا تَعَارَفَ مِنْهَا فِي السَّمَاءِ تَعَارَفَ فِي الْاَرْضِ ،  وَ مَا تَنَاكَرَ مِنْهَا فِي السَّمَاءِ تَنَاكَرَ فِي الْاَرْضِ ،  فَاِذَا قَامَ الْقَائِمُ ( عَلَيْهِ السَّلاَمُ ) ،  وَرَّثَ الْاَخَ فِي الدِّينِ ،  وَ لَمْ يُوَرِّثِ الْاَخَ فِي الْوِلاَدَةِ ،  وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ فِي كِتَابِهِ :   <quranic_text> « فَاِذٰا نُفِخَ فِي الصُّورِ فَلاٰ اَنْسٰابَ بَيْنَهُمْ يَوْمَئِذٍ وَ لاٰ يَتَسٰاءَلُونَ » </quranic_text>   <footnote> [ المؤمنون ۱۰۱ ] </footnote> .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اَللَّهَ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"الارواح","display":"الْاَرْوَاحَ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"الابدان","display":"الْاَبْدَانِ"},{"kind":"word","token":"بالفي","display":"بِاَلْفَيْ"},{"kind":"word","token":"عام","display":"عَامٍ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"الابدان","display":"الْاَبْدَانَ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"تعارف","display":"تَعَارَفَ"},{"kind":"word","token":"منها","display":"مِنْهَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السماء","display":"السَّمَاءِ"},{"kind":"word","token":"تعارف","display":"تَعَارَفَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","t