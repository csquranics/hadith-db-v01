{"consensus_set_id":"7391","translation_language":"fa","translation_source":{"hid":"103301"},"segments":[{"source_hadith_segment":"فِي رَجُلٍ مُسْلِمٍ كَانَ فِي اَرْضِ الشِّرْكِ فَقَتَلَهُ الْمُسْلِمُونَ ثُمَّ عَلِمَ بِهِ الْاِمَامُ بَعْدُ","translation_segment":"ابن أبی عمیر از پاره‌ای یارانش از امام صادق علیه السلام نقل کرده که در باره مسلمانی که در سرزمین شرک میزیسته و مسلمین","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"مسلم","display":"مُسْلِمٍ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ارض","display":"اَرْضِ"},{"kind":"word","token":"الشرك","display":"الشِّرْكِ"},{"kind":"word","token":"فقتله","display":"فَقَتَلَهُ"},{"kind":"word","token":"المسلمون","display":"الْمُسْلِمُونَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"علم","display":"عَلِمَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"الامام","display":"الْاِمَامُ"},{"kind":"word","token":"بعد","display":"بَعْدُ"}]},{"source_hadith_segment":"فَقَالَ « يُعْتِقُ مَكَانَهُ رَقَبَةً مُؤْمِنَةً وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « فَاِنْ كٰانَ مِنْ قَوْمٍ عَدُوٍّ لَكُمْ وَ هُوَ مُؤْمِنٌ فَتَحْرِيرُ رَقَبَةٍ مُؤْمِنَةٍ » </quranic_text>   <footnote> [ النساء ۹۲ ] </footnote>   .","translation_segment":"او را کشته‌اند و سپس امام خبر یافته است، فرمود: بجای او رقبه مسلمانی آزاد کند، و این حکم خداوند است عز و جل‌ که فرموده: «فإن‌ کٰان‌ من‌ قوم‌ عدو لکم‌ و هو مومن‌ فتحریر رقبه‌ مومنه‌» نساء:۹۲ (و اگر مومن مقتول از مردمی است که دشمن شمایند (محاربند) پس باید بنده مومنی را آزاد کند)","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يعتق","display":"يُعْتِقُ"},{"kind":"word","token":"مكانه","display":"مَكَانَهُ"},{"kind":"word","token":"رقبه","display":"رَقَبَةً"},{"kind":"word","token":"مؤمنه","display":"مُؤْمِنَةً"},{"kind":"word","token