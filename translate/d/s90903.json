{"consensus_set_id":"s90903","translation_language":"fa","translation_source":{"hid":"90903"},"segments":[{"source_hadith_segment":"« اِذَا اَصَابَ الْمُحْرِمُ الصَّيْدَ فَلَيْسَ لَهُ اَنْ يَنْفِرَ فِي النَّفْرِ الْاَوَّلِ وَ مَنْ نَفَرَ فِي النَّفْرِ الْاَوَّلِ فَلَيْسَ لَهُ اَنْ يُصِيبَ الصَّيْدَ حَتَّي يَنْفِرَ النَّاسُ وَ هُوَ قَوْلُ اللَّهِ تَعَالَي  <quranic_text> « فَمَنْ تَعَجَّلَ فِي يَوْمَيْنِ فَلاٰ اِثْمَ عَلَيْهِ » </quranic_text>   <footnote> [ البقرة ۲۰۳ ] </footnote>   .  .  .   <quranic_text> « لِمَنِ اِتَّقيٰ » </quranic_text>   <footnote> [ البقرة ۲۰۳ ] </footnote> قَالَ « اِتَّقَي الصَّيْدَ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اصاب","display":"اَصَابَ"},{"kind":"word","token":"المحرم","display":"الْمُحْرِمُ"},{"kind":"word","token":"الصيد","display":"الصَّيْدَ"},{"kind":"word","token":"فليس","display":"فَلَيْسَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ينفر","display":"يَنْفِرَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"النفر","display":"النَّفْرِ"},{"kind":"word","token":"الاول","display":"الْاَوَّلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"نفر","display":"نَفَرَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"النفر","display":"النَّفْرِ"},{"kind":"word","token":"الاول","display":"الْاَوَّلِ"},{"kind":"word","token":"فليس","display":"فَلَيْسَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يصيب","display":"يُصِيبَ"},{"kind":"word","token":"الصيد","display":"الصَّيْدَ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"ينفر","display":"يَنْفِرَ"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display