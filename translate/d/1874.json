 تُبَيِّضُ بِهَا وَجْهِي وَ تَعْصِمُنِي بِهَا مِنْ كُلِّ سُوءٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ اَعْطِنِي اِيمَاناً صَادِقاً وَ يَقِيناً لَيْسَ بَعْدَهُ كُفْرٌ وَ رَحْمَةً اَنَالُ بِهَا شَرَفَ كَرَامَتِكَ فِي الدُّنْيَا وَ الْاخِرَةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ اِنِّي اَسْاَلُكَ الْفَوْزَ عِنْدَ الْقَضَاءِ وَ مَنَازِلَ الْعُلَمَاءِ وَ عَيْشَ السُّعَدَاءِ وَ مُرَافَقَةَ الْاَنْبِيَاءِ وَ النَّصْرَ عَلَي الْاَعْدَاءِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ اِنِّي اَنْزَلْتُ بِكَ حَاجَتِي وَ اِنْ قَصُرَ عَمَلِي وَ ضَعُفَ بَدَنِي وَ قَدِ اِفْتَقَرْتُ اِلَيْكَ وَ اِلَي رَحْمَتِكَ فَاَسْاَلُكَ يَا قَاضِيَ الْاُمُورِ يَا شَافِيَ الصُّدُورِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"كَمَا تُجِيرُ مَنْ فِي الْبُحُورِ اَنْ تُصَلِّيَ عَلَي مُحَمَّدٍ وَ الِهِ وَ اَنْ تُجِيرَنِي مِنْ عَذَابِ السَّعِيرِ وَ مِنْ دَعْوَةِ الثُّبُورِ وَ مِنْ فِتْنَةِ الْقُبُورِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ مَا قَصُرَتْ عَنْهُ مَسْاَلَتِي وَ لَمْ تَبْلُغْهُ نِيَّتِي وَ لَمْ تُحِطْ بِهِ مَعْرِفَتِي مِنْ خَيْرٍ وَعَدْتَهُ اَحَداً مِنْ خَلْقِكَ اَوْ اَنْتَ مُعْطِيهِ اَحَداً مِنْ عِبَادِكَ فَاِنِّي اَرْغَبُ اِلَيْكَ فِيهِ وَ اَسْاَلُكَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ يَا ذَا الْحَبْلِ الشَّدِيدِ وَ الْاَمْرِ الرَّشِيدِ اَسْاَلُكَ الْاَمْنَ يَوْمَ الْوَعِيدِ وَ الْجَنَّةَ يَوْمَ الْخُلُودِ مَعَ الْمُقَرَّبِينَ الشُّهُودِ الرُّكَّعِ السُّجُودِ الْمُوفِينَ بِالْعُهُودِ اِنَّكَ  <quranic_text> « رَحِيمٌ وَدُودٌ » </quranic_text>   <footnote> [ هود ۹۰ ] </footnote>  وَ اِنَّكَ تَفْعَلُ مَا تُرِيدُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِهِ وَ اِجْعَلْنَا صَادِقِينَ مَهْدِيِّينَ غَيْرَ ضَالِّينَ وَ لاَ مُضِلِّينَ سِلْماً لِاَوْلِيَائِكَ حَرْباً لِاَعْدَائِكَ نُحِبُّ لِحُبِّكَ النَّاسَ وَ نُعَادِي لِعَدَاوَتِكَ مَنْ خَالَفَكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ هَذَا الدُّعَاءُ وَ عَلَيْكَ الْاِجَابَةُ وَ هَذَا الْجُهْدُ وَ عَلَيْكَ التُّكْلاَنُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ اَنْتَ الَّذِي اِصْطَنَعَ الْعِزَّ وَ فَازَ بِهِ سُبْحَانَ الَّذِي لَبِسَ الْمَجْدَ وَ تَكَرَّمَ بِهِ سُبْحَانَ الَّذِي لاَ يَنْبَغِي التَّسْبِيحُ اِلاَّ لَهُ سُبْحَانَ ذِي الْفَضْلِ وَ النِّعَمِ سُبْحَانَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ذِي الْعِزِّ وَ الْكَرَمِ سُبْحَانَ الَّذِي اَحْصَي كُلَّ شَيْءٍ عِلْمُهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ اِجْعَلْ لِي نُوراً فِي قَلْبِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً فِي قَبْرِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً بَيْنَ يَدَيَّ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً مِنْ خَلْفِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً عَنْ يَمِينِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً عَنْ شِمَالِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً مِنْ فَوْقِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً مِنْ تَحْتِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً فِي سَمْعِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً فِي بَصَرِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً فِي شَعْرِي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ نُوراً فِي لَحْمِي","translation_segmen