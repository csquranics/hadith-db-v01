{"consensus_set_id":"4039","translation_language":"fa","translation_source":{"hid":"115413"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ طَعٰامُ الَّذِينَ اُوتُوا الْكِتٰابَ حِلٌّ لَكُمْ وَ طَعٰامُكُمْ حِلٌّ لَهُمْ » </quranic_text>   <footnote> [ المائدة ۵ ] </footnote>  فَقَالَ عَلَيْهِ السَّلاَمُ الْحُبُوبُ وَ الْبُقُولُ .","translation_segment":"ابو جارود گوید: از امام باقر علیه السلام درباره گفتار خداوند که می‌فرماید: «غذای اهل کتاب و نیز غذای شما برای آنان حلال است» فرمود: منظور حبوبات و سبزیجات است.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طعام","display":"طَعٰامُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اوتوا","display":"اُوتُوا"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابَ"},{"kind":"word","token":"حل","display":"حِلٌّ"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"طعامكم","display":"طَعٰامُكُمْ"},{"kind":"word","token":"حل","display":"حِلٌّ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"k