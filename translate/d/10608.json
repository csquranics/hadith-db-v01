{"consensus_set_id":"10608","translation_language":"fa","translation_source":{"hid":"100296"},"segments":[{"source_hadith_segment":"عَنِ اَلظَّبْيِ يَدْخُلُ الْحَرَمَ فَقَالَ « لاَ يُؤْخَذُ وَ لاَ يُمَسُّ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « وَ مَنْ دَخَلَهُ كٰانَ امِناً » </quranic_text>   <footnote> [ العمران ۹۷ ] </footnote>   .","translation_segment":"و محمد بن مسلم در باره آهوئی که داخل حرم شود، از یکی از آن دو امام باقر یا صادق علیهما السلام سوال کرد، امام فرمود: دستگیر نمیشود و دست بر آن سوده نمیگردد. زیرا خدای عز و جل‌ میگوید: «و من‌ دخله‌ کٰان‌ آمنا».","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سال","display":"سَاَلَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"طير","display":"طَيْرٍ"},{"kind":"word","token":"اهلي","display":"اَهْلِيٍّ"},{"kind":"word","token":"الظبي","display":"اَلظَّبْيِ"},{"kind":"word","token":"يدخل","display":"يَدْخُلُ"},{"kind":"word","token":"الحرم","display":"الْحَرَمَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يؤخذ","display":"يُؤْخَذُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يمس","display":"يُمَسُّ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","tok