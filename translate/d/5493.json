{"consensus_set_id":"5493","translation_language":"fa","translation_source":{"hid":"113696"},"segments":[{"source_hadith_segment":"كُنْتُ عِنْدَ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ فَاَتَاهُ رَجُلٌ فَسَاَلَهُ عَنْ رَجُلٍ تَزَوَّجَ اِمْرَاَةً فَمَاتَتْ قَبْلَ اَنْ يَدْخُلَ بِهَا","translation_segment":"منصور بن حازم گوید: در خدمت امام صادق علیه السلام نشسته بودم، مردی آمد و از آن حضرت سوال کرد: اگر کسی با زنی ازدواج کند و آن زن پیش از زفاف، بمیرد آیا","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"رواه","display":"رَوَاهُ"},{"kind":"word","token":"كنت","display":"كُنْتُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فاتاه","display":"فَاَتَاهُ"},{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"فساله","display":"فَسَاَلَهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"تزوج","display":"تَزَوَّجَ"},{"kind":"word","token":"امراه","display":"اِمْرَاَةً"},{"kind":"word","token":"فماتت","display":"فَمَاتَتْ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يدخل","display":"يَدْخُلَ"},{"kind":"word","token":"بها","display":"بِهَا"}]},{"source_hadith_segment":"اَ يَتَزَوَّجُ بِاُمِّهَا فَقَالَ","translation_segment":"می‌تواند با مادر آن زن ازدواج کند؟","segment_columns":[{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"يتزوج","display":"يَتَزَوَّجُ"},{"kind":"word","token":"بامها","display":"بِاُمِّهَا"},{"kind":"word","token":"فقال","display":"فَقَالَ"}]},{"source_hadith_segment":"اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ قَدْ فَعَلَهُ رَجُلٌ مِنَّا فَلَمْ نَرَ بِهِ بَاْساً فَقُلْتُ جُعِلْتُ فِدَاكَ مَا تَفْخَرُ الشِّيعَةُ اِلاَّ بِقَضَاءِ عَلِيٍّ عَلَيْهِ السَّلاَمُ فِي هَذِهِ الشَّمْخِيَّةِ الَّتِي اَفْتَاهَا اِبْنُ مَسْعُودٍ اَنَّهُ لاَ بَاْسَ بِذَلِكَ ثُمَّ اَتَي عَلِيّاً عَلَيْهِ السَّلاَمُ فَسَاَلَهُ فَقَالَ لَهُ عَلِيٌّ عَلَيْهِ السَّلاَمُ مِنْ اَيْنَ اَخَذْتَهَا فَقَالَ مِنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ رَبٰائِبُكُمُ اللاّٰتِي فِي حُجُورِكُمْ مِنْ نِسٰائِكُمُ اللاّٰتِي دَخَلْتُمْ بِهِنَّ فَاِنْ لَمْ تَكُونُوا دَخَلْتُمْ بِهِنَّ فَلاٰ جُنٰاحَ عَلَيْكُمْ » </quranic_text>   <footnote> [ النساء ۲۳ ] </footnote>  فَقَالَ عَلِيٌّ عَلَيْهِ السَّلاَمُ اِنَّ هَذِهِ مُسْتَثْنَاةٌ وَ هَذِهِ مُرْسَلَةٌ  <quranic_text> « وَ اُمَّهٰاتُ نِسٰائِكُمْ » </quranic_text>   <footnote> [ النساء ۲۳ ] </footnote>  فَقَالَ اَبُو عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ لِلرَّجُلِ اَ مَا تَسْمَعُ مَا يَرْوِي هَذَا عَنْ عَلِيٍّ عَلَيْهِ السَّلاَمُ فَلَمَّا","translation_segment":"فرمود: مردی از بنی هاشم به همین صورت ازدواج کرد، و ما ایرادی بر او نگرفتیم. گفتم: فدایت بشوم! شیعیان افتخار نمی‌کنند مگر به قضاوت حضرت علی علیه السلام در مورد «شمخیه» که ابن مسعود فتوا داده بود چنین ازدواجی ایراد ندارد. سپس ابن مسعود به خدمت امیر مومنان علی علیه السلام رسید و در این مورد پرسید. حضرت به او فرمود: این حکم را از کجا برداشت نمودی‌؟ عرض کرد: از فرموده خداوند متعال که می‌فرماید: «و دختران همسرانتان که در دامان شما پرورش یافته‌اند از همسرانی که با آنها آمیزش کرده‌اید و اگر با زنان آمیزش نداشته‌اید، دختران آنها برای شما مانعی ندارد. حضرت علیه السلام فرمود: ربیبه‌ها استثنا دارند، اما حکم ما در زنان مطلق است. (به هیچ وجه ازدواج با مادرزن جایز نیست). امام صادق علیه السلام به آن مرد فرمود: مگر نشنیدی این شخص، چه روایتی از حضرت علی علیه السلام نقل نمود؟! هنگامی که برخاستم و رفتم پشیمان گشتم، با خود گفتم: این چه کاری بود که من کردم‌؟ امام صادق علیه السلام می‌فرماید: «مردی از بنی هاشم در همین شرایط‍‌ با مادرزن خود ازدواج کرد 