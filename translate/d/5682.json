{"consensus_set_id":"5682","translation_language":"fa","translation_source":{"hid":"407703"},"segments":[{"source_hadith_segment":"« كَانَ نُوحٌ ( عَلَيْهِ السَّلاَمُ ) اِذَا اَصْبَحَ وَ اَمْسَي يَقُولُ :  اَشْهَدُ اَنَّهُ مَا اَمْسَي بِي مِنْ نِعْمَةٍ فِي دِينٍ اَوْ دُنْيَا فَاِنَّهَا مِنَ اللَّهِ ،  وَحْدَهُ لاَ شَرِيكَ لَهُ ،  لَهُ الْحَمْدُ عَلَيَّ بِهَا وَ الشُّكْرُ كَثِيراً ،  فَاَنْزَلَ اللَّهُ :   <quranic_text> « اِنَّهُ كٰانَ عَبْداً شَكُوراً » </quranic_text>   <footnote> [ الاسراء ۳ ] </footnote>  فَهَذَا كَانَ شُكْرَهُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"عبدا","display":"عَبْداً"},{"kind":"word","token":"شكورا","display":"شَكُوراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء۳","display":"الاسراء۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"نوح","display":"نُوحٌ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"اصبح","display":"اَصْبَحَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امسي","display":"اَمْسَي"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"امسيت","display":"اَمْسَيْتُ"},{"kind":"word","token":"اشهد","display":"اَشْهَدُ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"امسي","display":"اَمْسَي"},{"kind":"word","token":"بي","display":"بِي"},{"kind":"word","token":"من","display