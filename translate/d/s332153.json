{"consensus_set_id":"s332153","translation_language":"fa","translation_source":{"hid":"332153"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ جَلَّ وَ عَزَّ  <quranic_text> « وَ لَتَعْرِفَنَّهُمْ فِي لَحْنِ الْقَوْلِ » </quranic_text>   <footnote> [ محمد ۳۰ ] </footnote>  قَالَ :  بِبُغْضِهِمْ عَلِيَّ بْنَ اَبِي طَالِبٍ  .","translation_segment":"هارون عبدی از ابو سعید خدری در شرح و تفسیر آیه کریمه نقل کرد؛ «لتعرفنهم‌ فی لحن‌ القول‌» یعنی منافقان و بیمار دلان را از لحن گفتار و سخنانی که در بغض و کینه نسبت به علی علیه السلام ابراز و اعلام می‌دارند می‌توان شناخت.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لتعرفنهم","display":"لَتَعْرِفَنَّهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"لحن","display":"لَحْنِ"},{"kind":"word","token":"القول","display":"الْقَوْلِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"محمد","display":"محمد"},{"kind":"word","token":"۳۰","display":"۳۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ببغضهم","display":"بِبُغْضِهِمْ"},{"kind":"word","token":"علي","display":"عَلِيَّ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"}]}]}