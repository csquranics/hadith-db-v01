{"consensus_set_id":"s222195","translation_language":"fa","translation_source":{"hid":"222195"},"segments":[{"source_hadith_segment":"قِيلَ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ وَ اَنَا عِنْدَهُ اِنَّ سَالِمَ بْنَ اَبِي حَفْصَةَ يَرْوِي عَنْكَ اَنَّكَ تَتَكَلَّمُ عَلَي سَبْعِينَ وَجْهاً لَكَ مِنْ كُلِّهَا الْمَخْرَجُ قَالَ فَقَالَ مَا يُرِيدُ سَالِمٌ مِنِّي اَ يُرِيدُ اَنْ اَجِيءَ بِالْمَلاَئِكَةِ فَوَ اللَّهِ مَا جَاءَ بِهَا النَّبِيُّونَ وَ لَقَدْ قَالَ اِبْرَاهِيمُ  <quranic_text> « اِنِّي سَقِيمٌ » </quranic_text>   <footnote> [ الصافات ۸۹ ] </footnote>  وَ اللَّهِ مَا كَانَ سَقِيماً وَ مَا كَذَبَ وَ لَقَدْ قَالَ اِبْرَاهِيمُ  <quranic_text> « بَلْ فَعَلَهُ كَبِيرُهُمْ هٰذٰا » </quranic_text>   <footnote> [ الانبياء ۶۳ ] </footnote>  وَ مَا فَعَلَهُ وَ مَا كَذَبَ وَ لَقَدْ قَالَ يُوسُفُ  <quranic_text> « اِنَّكُمْ لَسٰارِقُونَ » </quranic_text>   <footnote> [ يوسف ۷۰ ] </footnote>  وَ اللَّهِ مَا كَانُوا سَارِقِينَ وَ مَا كَذَبَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"سالم","display":"سَالِمَ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"حفصه","display":"حَفْصَةَ"},{"kind":"word","token":"يروي","display":"يَرْوِي"},{"kind":"word","token":"عنك","display":"عَنْكَ"},{"kind":"word","token":"انك","display":"اَنَّكَ"},{"kind":"word","token":"تتكلم","display":"تَتَكَلَّمُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"سبعين","display":"سَبْعِينَ"