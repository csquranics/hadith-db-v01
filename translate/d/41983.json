{"consensus_set_id":"41983","translation_language":"fa","translation_source":{"hid":"90590"},"segments":[{"source_hadith_segment":"فِي رَجُلٍ اَعْطَي رَجُلاً دَرَاهِمَ يَحُجُّ بِهَا عَنْهُ حَجَّةً مُفْرَدَةً قَالَ « لَيْسَ لَهُ اَنْ يَتَمَتَّعَ  <quranic_text> « بِالْعُمْرَةِ اِلَي الْحَجِّ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  لاَ يُخَالِفُ صَاحِبَ الدَّرَاهِمِ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"اعطي","display":"اَعْطَي"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"دراهم","display":"دَرَاهِمَ"},{"kind":"word","token":"يحج","display":"يَحُجُّ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"عنه","display":"عَنْهُ"},{"kind":"word","token":"حجه","display":"حَجَّةً"},{"kind":"word","token":"مفرده","display":"مُفْرَدَةً"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتمتع","display":"يَتَمَتَّعَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بالعمره","display":"بِالْعُمْرَةِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۶","display":"۱۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يخالف","display":"يُخَالِفُ"},{"kind":"word","token":"صاحب","display":"صَاحِبَ"},{"kind":"word","token":"الدراهم","display":"الدَّرَاهِمِ"}]}]}