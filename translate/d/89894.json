{"consensus_set_id":"89894","translation_language":"fa","translation_source":{"hid":"332199"},"segments":[{"source_hadith_segment":"،  عَنْ اَبِيهِ عَنْ جَدِّهِ عَنِ اِبْنِ عَبَّاسٍ :  فِي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ السّٰابِقُونَ السّٰابِقُونَ اُولٰئِكَ الْمُقَرَّبُونَ » </quranic_text>   <footnote> [ الواقعة ۱۰ ] </footnote>  قَالَ :  نَزَلَتْ فِي عَلِيٍّ عَلَيْهِ السَّلاَمُ  .","translation_segment":"عن ابن عباس فی قوله تعالی: (و السابقون السابقون أولئک المقربون قال: نزلت فی علی ع. ابن عباس گفت: «السابقون السابقون اولئک المقربون» درباره علی نازل شده است.","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"جده","display":"جَدِّهِ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"ابن","display":"اِبْنِ"},{"kind":"word","token":"عباس","display":"عَبَّاسٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"المقربون","display":"الْمُقَرَّبُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الواقعه","display":"الواقعة"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}