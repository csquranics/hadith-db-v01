{"consensus_set_id":"s332144","translation_language":"fa","translation_source":{"hid":"332144"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اَمْ حَسِبَ الَّذِينَ اِجْتَرَحُوا السَّيِّئٰاتِ » </quranic_text>   <footnote> [ الجاثية ۲۱ ] </footnote>  يَعْنِي بَنِي اُمَيَّةَ  <quranic_text> « اَنْ نَجْعَلَهُمْ كَالَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ » </quranic_text>   <footnote> [ الجاثية ۲۱ ] </footnote>  النَّبِيُّ وَ عَلِيٌّ وَ حَمْزَةُ وَ جَعْفَرٌ وَ الْحَسَنُ وَ الْحُسَيْنُ وَ فَاطِمَةُ عَلَيْهِمُ السَّلاَمُ  .","translation_segment":"عن ابن عباس فی قوله تعالی: (أم حسب الذین اجترحوا السیئات) یعنی بنی أمیه (أن نجعلهم کالذین آمنوا و عملوا الصالحات) النبی و علی و حمزه و جعفر و الحسن و الحسین و فاطمه ع. ابن عباس درباره سخن خداوند: «ام حسب الذین اجترحوا السیئات» گفت: منظور بنی امیه است و «الذین آمنوا و عملوا الصالحات» پیامبر و علی و حمزه و جعفر و حسن و حسین و فاطمه هستند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"حسب","display":"حَسِبَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اجترحوا","display":"اِجْتَرَحُوا"},{"kind":"word","token":"السيئات","display":"السَّيِّئٰاتِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الجاثيه","display":"الجاثية"},{"kind":"word","token":"۲۱","display":"۲۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اميه","display":"اُمَيَّةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"نجعلهم","display":"نَجْعَلَهُمْ"},{"kind":"word","token":"كالذين","display":"كَالَّذِينَ"},{"