{"consensus_set_id":"s480108","translation_language":"fa","translation_source":{"hid":"480108"},"segments":[{"source_hadith_segment":"اَنَّهُ كَانَ يُصَلِّي فِي لَيْلَةِ النِّصْفِ مِنْ رَجَبٍ اِثْنَتَيْ عَشْرَةَ رَكْعَةً ( اَيْ بِسِتَّةِ تَسْلِيمَاتٍ","translation_segment":"و شیخ طوسی رحمه الله به سند صحیح از حضرت صادق علیه السلام روایت کرده است که در شب نصف رجب","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يصلي","display":"يُصَلِّي"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ليله","display":"لَيْلَةِ"},{"kind":"word","token":"النصف","display":"النِّصْفِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"رجب","display":"رَجَبٍ"},{"kind":"word","token":"اثنتي","display":"اِثْنَتَيْ"},{"kind":"word","token":"عشره","display":"عَشْرَةَ"},{"kind":"word","token":"ركعه","display":"رَكْعَةً"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"بسته","display":"بِسِتَّةِ"},{"kind":"word","token":"تسليمات","display":"تَسْلِيمَاتٍ"}]},{"source_hadith_segment":") يَقْرَاُ فِي كُلٍّ مِنْهُمَا سُورَةَ الْحَمْدِ وَ اَيَّةَ سُورَةٍ شَاءَ","translation_segment":"دوازده رکعت نماز به جای آوری، یعنی به شش سلام، با حمد و","segment_columns":[{"kind":"word","token":"يقرا","display":"يَقْرَاُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كل","display":"كُلٍّ"},{"kind":"word","token":"منهما","display":"مِنْهُمَا"},{"kind":"word","token":"سوره","display":"سُورَةَ"},{"kind":"word","token":"الحمد","display":"الْحَمْدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ايه","display":"اَيَّةَ"},{"kind":"word","token":"سوره","display":"سُورَةٍ"},{"kind":"word","token":"شاء","display":"شَاءَ"}]},{"source_hadith_segment":"،  فَاِذَا فَرَغَ قَرَاَ كُلاً مِنْ سُورَةِ الْحَمْدِ وَ سُورَةِ  <quranic_text> « قُلْ اَعُوذُ بِرَبِّ الْفَلَقِ » </quranic_text>   <footnote> [ الفلق ۱ ] </footnote>  وَ  <quranic_text> « قُلْ اَعُوذُ بِرَبِّ النّٰاسِ » </quranic_text>   <footnote> [ الناس ۱ ] </footnote>  وَ  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>  وَ ايَةَ الْكُرْسِيِّ اَرْبَعَ مَرَّاتٍ","translation_segment":"هرسوره که خواهی، و چون فارغ شوی، هریک از سوره‌ی حمد و قل اعوذ برب‌ الفلق و قل اعوذ برب‌ الناس و قل هو الله احد و آیه الکرسی چهار مرتبه می‌خوانی، پس چهار مرتبه می‌گویی: سبحان الله و الحمد لله و لا إله إلا الله و الله أکبر؛ منزه است خدا و ستایش بر خدا راست و نیست معبودی جز خدا و خدا بزرگ‌تر است. پس می‌گویی: ألله ألله","segment_columns":[{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"فرغ","display":"فَرَغَ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"كلا","display":"كُلاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"سوره","display":"سُورَةِ"},{"kind":"word","token":"الحمد","display":"الْحَمْدِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سوره","display":"سُورَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"اعوذ","display":"اَعُوذُ"},{"kind":"word","token":"برب","display":"بِرَبِّ"},{"kind":"word","token":"الفلق","display":"الْفَلَقِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفلق","display":"الفلق"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"اعوذ","display":"اَعُوذُ"},{"kind":"word","token":"برب","display":"بِرَبِّ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الناس","display":"الناس"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag