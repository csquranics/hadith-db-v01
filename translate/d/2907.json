{"consensus_set_id":"2907","translation_language":"fa","translation_source":{"hid":"338401"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ لِاَيِّ شَيْءٍ صَارَ الْحَاجُّ لاَ يُكْتَبُ لَهُمْ ذَنْبٌ اَرْبَعَةَ اَشْهُرٍ قَالَ","translation_segment":"محمد بن الحسن از محمد بن الحسن الصفار، از احمد بن محمد بن عیسی، از پدرش، از حسین بن خالد نقل کرده، وی گفت: محضر حضرت ابی عبد اللٰه علیه السلام عرض کردم: برای چه بر حاجی‌ها تا","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لاي","display":"لِاَيِّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"صار","display":"صَارَ"},{"kind":"word","token":"الحاج","display":"الْحَاجُّ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يكتب","display":"يُكْتَبُ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"ذنب","display":"ذَنْبٌ"},{"kind":"word","token":"اربعه","display":"اَرْبَعَةَ"},{"kind":"word","token":"اشهر","display":"اَشْهُرٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"يوم","display":"يَوْمِ"},{"kind":"word","token":"يحلق","display":"يَحْلِقُ"},{"kind":"word","token":"راسه","display":"رَاْسَهُ"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"لِاَنَّ اللَّهَ تَبَارَكَ وَ تَعَالَي اَبَاحَ لِلْمُشْرِكِينَ الْاَشْهُرَ الْحُرُمَ اَرْبَعَةَ اَشْهُرٍ اِذْ يَقُولُ  <quranic_text> « فَسِيحُوا فِي الْاَرْضِ اَرْبَعَةَ اَشْهُرٍ » </quranic_text>   <footnote> [ التوبة ۲ ] </footnote>  فَمِنْ ثَمَّ وَهَبَ لِمَنْ حَجَّ مِنَ الْمُؤْمِنِينَ الْبَيْتَ الذُّنُوبَ اَرْبَعَةَ اَشْهُرٍ .","translation_segment":"چهار ماه گناه نوشته نمی‌شود؟ حضرت فرمودند: زیرا خداوند تبارک و تعالی برای مشرکین اشهر حرم را که چهار ماه است مباح و آنها را در این چهار ماه در توسعه و آزادی مطلق قرار داد چنانچه در قرآن کریم می‌فرماید: «فسیحوا فی الأرض‌ أربعه‌ أشهر» یعنی پس ای مشرکان سیر کنید در زمین و از ترس تعرض مسلمانان در امان باشید به مدت چهار ماه. فلذا حق تعالی تا چهار ماه از مراسم حج گذشته گناهان آنان که بیت اللٰه را زیارت کرده‌اند می‌بخشد و منظور نمی‌فرماید.","segment_columns":[{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جلّ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"اباح","display":"اَبَاحَ"},{"kind":"word","token":"للمشركين","display":"لِلْمُشْرِكِينَ"},{"kind":"word","token":"الاشهر","display":"الْاَشْهُرَ"},{"kind":"word","token":"الحرم","display":"الْحُرُمَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اربعه","display":"اَرْبَعَةَ"},{"kind":"word","token":"اشهر","display":"اَشْهُرٍ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فسيحوا","display":"فَسِيحُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"اربعه","display":"اَرْبَعَةَ"},{"kind":"word","token":"اشهر","display":"اَشْهُرٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فاباح","display":"فَاَبَاحَ"},{"kind":"word","token":"للمؤمنين","display":"لِلْمُؤْمِنِينَ"},{"kind":"word","token":"ا