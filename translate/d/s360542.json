{"consensus_set_id":"s360542","translation_language":"fa","translation_source":{"hid":"360542"},"segments":[{"source_hadith_segment":"اَجْهَدَتْهُمُ اَلْعِبَادَةُ قَالَ اللَّهُ تَعَالَي  <quranic_text> « وَ الَّذِينَ يُؤْتُونَ مٰا اتَوْا وَ قُلُوبُهُمْ وَجِلَةٌ » </quranic_text>   <footnote> [ المؤمنون ۶۰ ] </footnote>   .","translation_segment":"حسن گوید: آنها کسانی هستند که عبادت تاب و طاقت را از ایشان گرفته است. خداوند متعال فرماید: «و آنان که می‌دهند آنچه که باید از صدقات بدهند، و دلهایشان ترسان است.»","segment_columns":[{"kind":"word","token":"اجهدتهم","display":"اَجْهَدَتْهُمُ"},{"kind":"word","token":"العباده","display":"اَلْعِبَادَةُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يؤتون","display":"يُؤْتُونَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"اتوا","display":"اتَوْا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلوبهم","display":"قُلُوبُهُمْ"},{"kind":"word","token":"وجله","display":"وَجِلَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"kind":"word","token":"۶۰","display":"۶۰"},{"kind":"tag_close","tag_name":"footnote"}]}]}