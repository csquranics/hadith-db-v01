{"consensus_set_id":"s377036","translation_language":"fa","translation_source":{"hid":"377036"},"segments":[{"source_hadith_segment":"نَزَلَ فِيهِمْ  <quranic_text> « وَ الَّذِينَ امَنُوا وَ هٰاجَرُوا وَ جٰاهَدُوا فِي سَبِيلِ اللّٰهِ وَ الَّذِينَ اوَوْا وَ نَصَرُوا اُولٰئِكَ هُمُ الْمُؤْمِنُونَ حَقًّا لَهُمْ مَغْفِرَةٌ وَ رِزْقٌ كَرِيمٌ وَ الَّذِينَ امَنُوا مِنْ بَعْدُ وَ هٰاجَرُوا وَ جٰاهَدُوا مَعَكُمْ فَاُولٰئِكَ مِنْكُمْ وَ اُولُوا الْاَرْحٰامِ بَعْضُهُمْ اَوْليٰ بِبَعْضٍ فِي كِتٰابِ اللّٰهِ » </quranic_text>   <footnote> [ الانفال ۷۴ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"فيهم","display":"فِيهِمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هاجروا","display":"هٰاجَرُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جاهدوا","display":"جٰاهَدُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"سبيل","display":"سَبِيلِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اووا","display":"اوَوْا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نصروا","display":"نَصَرُوا"},{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"المؤمنون","display":"الْمُؤْمِنُونَ"},{"kind":"word","token":"حقا","display":"حَقًّا"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"مغفره","display":"مَغْفِرَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رزق","display":"رِزْقٌ"},{"kind":"word","token":"كريم","display":"كَرِيمٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word",