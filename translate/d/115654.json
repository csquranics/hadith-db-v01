{"consensus_set_id":"115654","translation_language":"fa","translation_source":{"hid":"331841"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ تَعَالَي :   <quranic_text> « وَ اِنَّ الَّذِينَ لاٰ يُؤْمِنُونَ بِالْاخِرَةِ عَنِ الصِّرٰاطِ لَنٰاكِبُونَ » </quranic_text>   <footnote> [ المؤمنون ۷۴ ] </footnote>  قَالَ :  عَنْ وَلاَيَتِنَا .","translation_segment":"عن الأصبغ بن نباته عن علی‌ ع فی قول الله تعالی: (و إن‌ الذین لا یومنون بالآخره عن الصراط‍‌ لناکبون) قال: عن ولایتنا. اصبغ بن نباته از علی درباره سخن خداوند: «و ان الذین لا یومنون بالاخره عن الصراط‍‌ لناکبون» نقل کرد که گفت: از ولایت ما.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يؤمنون","display":"يُؤْمِنُونَ"},{"kind":"word","token":"بالاخره","display":"بِالْاخِرَةِ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الصراط","display":"الصِّرٰاطِ"},{"kind":"word","token":"لناكبون","display":"لَنٰاكِبُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"kind":"word","token":"۷۴","display":"۷۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ناكبون","display":"نَاكِبُونَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ولايتنا","display":"وَلاَيَتِنَا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"}]}]}