{"consensus_set_id":"s223405","translation_language":"fa","translation_source":{"hid":"223405"},"segments":[{"source_hadith_segment":"وَ اَبِي عَبْدِ اللَّهِ عَلَيْهِمَا السَّلاَمُ  :  فِي قَوْلِهِ :   <quranic_text> « وَ كُلَّ اِنسٰانٍ اَلْزَمْنٰاهُ طٰائِرَهُ فِي عُنُقِهِ » </quranic_text>   <footnote> [ الاسراء ۱۳ ] </footnote>  قَالَ قَدَّرَهُ الَّذِي قَدَّرَهُ عَلَيْهِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"انسان","display":"اِنسٰانٍ"},{"kind":"word","token":"الزمناه","display":"اَلْزَمْنٰاهُ"},{"kind":"word","token":"طائره","display":"طٰائِرَهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"عنقه","display":"عُنُقِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۱۳","display":"۱۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قدره","display":"قَدَّرَهُ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قدره","display":"قَدَّرَهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"}]}]}