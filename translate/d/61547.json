{"consensus_set_id":"61547","translation_language":"fa","translation_source":{"hid":"408086"},"segments":[{"source_hadith_segment":"« نَزَلَ جَبْرَئِيلُ بِهَذِهِ الْايَةِ هَكَذَا عَلَي مُحَمَّدٍ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) فَقَالَ :   <quranic_text> « وَ قُلِ الْحَقُّ مِنْ رَبِّكُمْ فَمَنْ شٰاءَ فَلْيُؤْمِنْ وَ مَنْ شٰاءَ فَلْيَكْفُرْ اِنّٰا اَعْتَدْنٰا لِلظّٰالِمِينَ » </quranic_text>   <footnote> [ الكهف ۲۹ ] </footnote> الَ مُحَمَّدٍ حَقَّهُمْ  <quranic_text> « نٰاراً » </quranic_text>   <footnote> [ الكهف ۲۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلُ"},{"kind":"word","token":"بهذه","display":"بِهَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"word","token":"هكذا","display":"هَكَذَا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قل","display":"قُلِ"},{"kind":"word","token":"الحق","display":"الْحَقُّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ربكم","display":"رَبِّكُمْ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"شاء","display":"شٰاءَ"},{"kind":"word","token":"فليؤمن","display":"فَلْيُؤْمِنْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"شاء","display":"شٰاءَ"},{"kind":"word","token":"فليكفر","display":"فَلْيَكْفُرْ"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"اعتدنا","display":"اَعْتَدْنٰا"},{"kind":"wo