{"consensus_set_id":"17579","translation_language":"fa","translation_source":{"hid":"404556"},"segments":[{"source_hadith_segment":"« اِنَّ لِلْمُؤْمِنِ عَلَي الْمُؤْمِنِ سَبْعَ حُقُوقِ ،  فَاَوْجَبُهَا اَنْ يَقُولَ الرَّجُلُ حَقّاً وَ اِنْ كَانَ عَلَي نَفْسِهِ اَوْ عَلَي وَالِدَيْهِ ،  فَلاَ يَمِيلُ لَهُمْ عَنِ الْحَقِّ - ثُمَّ قَالَ- :   <quranic_text> « فَلاٰ تَتَّبِعُوا الْهَويٰ اَنْ تَعْدِلُوا وَ اِنْ تَلْوُوا اَوْ تُعْرِضُوا » </quranic_text>   <footnote> [ النساء ۱۳۵ ] </footnote>  يَعْنِي عَنِ الْحَقِّ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"للمؤمن","display":"لِلْمُؤْمِنِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنِ"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"حقوق","display":"حُقُوقِ"},{"kind":"word","token":"فاوجبها","display":"فَاَوْجَبُهَا"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يقول","display":"يَقُولَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"حقا","display":"حَقّاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"نفسه","display":"نَفْسِهِ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"والديه","display":"وَالِدَيْهِ"},{"kind":"word","token":"فلا","display":"فَلاَ"},{"kind":"word","token":"يميل","display":"يَمِيلُ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الحق","display":"الْحَقِّ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال-","display":"قَالَ-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلا","display":"فَلاٰ"