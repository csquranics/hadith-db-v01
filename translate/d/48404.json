{"consensus_set_id":"48404","translation_language":"fa","translation_source":{"hid":"405877"},"segments":[{"source_hadith_segment":"مَعْنَاهُ وَ مَا اَوْلِيَاءُ الْمَسْجِدِ الْحَرَامِ اِلاَّ الْمُتَّقُونَ .  قَالَ :  وَ هُوَ الْمَرْوِيُّ عَنْ اَبِي جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ ) .","translation_segment":"","segment_columns":[{"kind":"word","token":"معناه","display":"مَعْنَاهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اولياء","display":"اَوْلِيَاءُ"},{"kind":"word","token":"المسجد","display":"الْمَسْجِدِ"},{"kind":"word","token":"الحرام","display":"الْحَرَامِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"المتقون","display":"الْمُتَّقُونَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"المروي","display":"الْمَرْوِيُّ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال۳۴","display":"الانفال۳۴"},{"kind":"tag_close","tag_name":"footnote"}]}]}