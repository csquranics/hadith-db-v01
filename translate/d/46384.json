{"consensus_set_id":"46384","translation_language":"fa","translation_source":{"hid":"111304"},"segments":[{"source_hadith_segment":"مَنْ وَجَبَ عَلَيْهِ هَدْيٌ فِي اِحْرَامِهِ فَلَهُ اَنْ يَنْحَرَهُ حَيْثُ شَاءَ اِلاَّ فِدَاءَ الصَّيْدِ فَاِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « هَدْياً بٰالِغَ الْكَعْبَةِ » </quranic_text>   <footnote> [ المائدة ۹۵ ] </footnote>   .","translation_segment":"راوی گوید: امام صادق علیه السلام فرمود: هرکه در احرام یک شتر قربانی بر او واجب شود می‌تواند هرجا که خواست آن را نحر نماید، مگر قربانی شکار را، زیرا خداوند متعال می‌فرماید: «قربانی که به کعبه رسیده باشد».","segment_columns":[{"kind":"word","token":"وقال","display":"وقال"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السلام"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"وجب","display":"وَجَبَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"هدي","display":"هَدْيٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"احرامه","display":"اِحْرَامِهِ"},{"kind":"word","token":"فله","display":"فَلَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ينحره","display":"يَنْحَرَهُ"},{"kind":"word","token":"حيث","display":"حَيْثُ"},{"kind":"word","token":"شاء","display":"شَاءَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"فداء","display":"فِدَاءَ"},{"kind":"word","token":"الصيد","display":"الصَّيْدِ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هديا","display":"هَدْياً"},{"kind":"word","token":"بالغ","display":"بٰالِغَ"},{"kind":"word","token":"الكعبه","display":"الْكَعْبَةِ"},{"kind":"tag_close","tag