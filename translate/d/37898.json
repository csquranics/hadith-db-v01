{"consensus_set_id":"37898","translation_language":"fa","translation_source":{"hid":"264855"},"segments":[{"source_hadith_segment":"قَوْلُهُ عَزَّ وَ جَلَّ  <quranic_text> « وَ اَقِيمُوا الصَّلاٰةَ وَ اتُوا الزَّكٰاةَ وَ مٰا تُقَدِّمُوا لِاَنْفُسِكُمْ مِنْ خَيْرٍ تَجِدُوهُ عِنْدَ اللّٰهِ اِنَّ اللّٰهَ بِمٰا تَعْمَلُونَ بَصِيرٌ » </quranic_text>   <footnote> [ البقرة ۱۱۰ ] </footnote>  قَالَ الْاِمَامُ  <quranic_text> « اَقِيمُوا الصَّلاٰةَ » </quranic_text>   <footnote> [ البقرة ۱۱۰ ] </footnote>  بِاِتْمَامِ وُضُوئِهَا وَ تَكْبِيرَاتِهَا وَ قِيَامِهَا وَ قِرَاءَتِهَا وَ رُكُوعِهَا وَ سُجُودِهَا وَ حُدُودِهَا -  <quranic_text> « وَ اتُوا الزَّكٰاةَ » </quranic_text>   <footnote> [ البقرة ۱۱۰ ] </footnote>  مُسْتَحِقِّيهَا لاَ تُؤْتُوهَا كَافِراً وَ لاَ مُنَافِقاً","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اقيموا","display":"اَقِيمُوا"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتوا","display":"اتُوا"},{"kind":"word","token":"الزكاه","display":"الزَّكٰاةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"تقدموا","display":"تُقَدِّمُوا"},{"kind":"word","token":"لانفسكم","display":"لِاَنْفُسِكُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"خير","display":"خَيْرٍ"},{"kind":"word","token":"تجدوه","display":"تَجِدُوهُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"بما","display":"بِمٰا"