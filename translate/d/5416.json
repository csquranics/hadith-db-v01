َعْدَ اِمَامٍ » .   <quranic_text> « يَهْدِي اللّٰهُ لِنُورِهِ مَنْ يَشٰاءُ » </quranic_text>   <footnote> [ النور ۳۵ ] </footnote>   ،  قَالَ : « يَهْدِي اللَّهُ عَزَّ وَ جَلَّ لِوَلاَيَتِنَا مَنْ يَشَاءُ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"المشكاه","display":"اَلْمِشْكَاةُ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةُ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"المصباح","display":"الْمِصْبَاحُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور۳۵","display":"النور۳۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الحسن","display":"الْحَسَنُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الزجاجه","display":"الزُّجَاجَةُ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الزجاجه","display":"الزُّجٰاجَةُ"},{"kind":"word","token":"كانها","display":"كَاَنَّهٰا"},{"kind":"word","token":"كوكب","display":"كَوْكَبٌ"},{"kind":"word","token":"دري","display":"دُرِّيٌّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۳۵","display":"۳۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةُ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","to