{"consensus_set_id":"25058","translation_language":"fa","translation_source":{"hid":"117007"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنِ الْوَصِيَّةِ لِلْوَارِثِ فَقَالَ تَجُوزُ قَالَ ثُمَّ تَلاَ هَذِهِ الْايَةَ :   <quranic_text> « اِنْ تَرَكَ خَيْراً الْوَصِيَّةُ لِلْوٰالِدَيْنِ وَ الْاَقْرَبِينَ » </quranic_text>   <footnote> [ البقرة ۱۸۰ ] </footnote>   .","translation_segment":"محمد بن مسلم گوید: از امام باقر علیه السلام درباره وصیت کردن برای یکی از ورثه سوال کردم. فرمود: جایز است. آن‌گاه حضرتش این آیه را تلاوت فرمود: «چنان چه میت چیزی به جای گذاشت برای پدر و مادر و نزدیکانش وصیت کند».","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الوصيه","display":"الْوَصِيَّةِ"},{"kind":"word","token":"للوارث","display":"لِلْوَارِثِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"تجوز","display":"تَجُوزُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"تلا","display":"تَلاَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"ترك","display":"تَرَكَ"},{"kind":"word","token":"خيرا","display":"خَيْراً"},{"kind":"word","token":"الوصيه","display":"الْوَصِيَّةُ"},{"kind":"word","token":"للوالدين","display":"لِلْوٰالِدَيْنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الاقربين","display":"الْاَقْرَبِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۸۰","display":"۱۸۰"},{"kind":"tag_close","tag_name":"footnote"}]}]}