{"consensus_set_id":"s331728","translation_language":"fa","translation_source":{"hid":"331728"},"segments":[{"source_hadith_segment":"( فِي قَوْلِهِ تَعَالَي )  <quranic_text> « يُثَبِّتُ اللّٰهُ الَّذِينَ امَنُوا بِالْقَوْلِ الثّٰابِتِ » </quranic_text>   <footnote> [ ابراهيم ۲۷ ] </footnote>  قَالَ :  بِوَلاَيَةِ عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ  .","translation_segment":"عن ابن عباس قال: فی قوله تعالی (یثبت الله الذین آمنوا بالقول الثابت) قال: بولایه علی‌ بن ابی طالب ع. … ابن عباس درباره سخن خداوند: «یثبت الله الذین آمنوا بالقول الثابت» گفت: به ولایت علی‌ بن ابی طالب (علیه السلام).","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يثبت","display":"يُثَبِّتُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"بالقول","display":"بِالْقَوْلِ"},{"kind":"word","token":"الثابت","display":"الثّٰابِتِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۲۷","display":"۲۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"بولايه","display":"بِوَلاَيَةِ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}