{"consensus_set_id":"s370803","translation_language":"fa","translation_source":{"hid":"370803"},"segments":[{"source_hadith_segment":"وَ تَقُولُ سَبْعَ مَرَّاتٍ وَ اَنْتَ اخِذٌ بِلِحْيَتِكَ بِيَدِكَ الْيُمْنَي وَ يَدُكَ الْيُسْرَي مَبْسُوطٌ بَاطِنُهَا","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تقول","display":"تَقُولُ"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"اخذ","display":"اخِذٌ"},{"kind":"word","token":"بلحيتك","display":"بِلِحْيَتِكَ"},{"kind":"word","token":"بيدك","display":"بِيَدِكَ"},{"kind":"word","token":"اليمني","display":"الْيُمْنَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يدك","display":"يَدُكَ"},{"kind":"word","token":"اليسري","display":"الْيُسْرَي"},{"kind":"word","token":"مبسوط","display":"مَبْسُوطٌ"},{"kind":"word","token":"باطنها","display":"بَاطِنُهَا"}]},{"source_hadith_segment":"مِمَّا يَلِي السَّمَاءَ يَا رَبَّ مُحَمَّدٍ وَ الِ مُحَمَّدٍ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ وَ عَجِّلْ فَرَجَ الِ مُحَمَّدٍ وَ سَبْعَ مَرَّاتٍ مِثْلَ ذَلِكَ يَا رَبَّ مُحَمَّدٍ وَ الِ مُحَمَّدٍ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ وَ اَعْتِقْ رَقَبَتِي مِنَ النَّارِ وَ قُلْ اَرْبَعِينَ مَرَّةً سُبْحَانَ اللَّهِ وَ الْحَمْدُ لِلَّهِ وَ لاَ اِلَهَ اِلاَّ اللَّهُ وَ اللَّهُ اَكْبَرُ ثُمَّ قُلْ يَا اَسْمَعَ السَّامِعِينَ وَ يَا اَبْصَرَ النَّاظِرِينَ وَ يَا اَسْرَعَ الْحَاسِبِينَ وَ يَا اَرْحَمَ الرَّاحِمِينَ وَ يَا اَحْكَمَ الْحَاكِمِينَ وَ يَا صَرِيخَ الْمَكْرُوبِينَ وَ يَا مُجِيبَ دَعْوَةِ الْمُضْطَرِّينَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « رَبُّ الْعٰالَمِينَ » </quranic_text>   <footnote> [ الاعراف ۵۴ ] </footnote>  وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « الْعَلِيُّ الْعَظِيمُ » </quranic_text>   <footnote> [ البقرة ۲۵۵ ] </footnote>  وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « الرَّحْمٰنُ الرَّحِيمُ » </quranic_text>   <footnote> [ البقرة ۱۶۳ ] </footnote>  وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ مَالِكُ  <quranic_text> « يَوْمِ الدِّينِ » </quranic_text>   <footnote> [ الفاتحة ۴ ] </footnote>  وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ مِنْكَ بَدَاَ الْخَلْقُ وَ اِلَيْكَ يَعُودُ وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ لَمْ تَزَلْ وَ لَنْ تَزَالَ وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ مَالِكُ الْخَيْرِ وَ الشَّرِّ وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ خَالِقُ الْجَنَّةِ وَ النَّارِ وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ الْوَاحِدُ الْاَحَدُ الصَّمَدُ لَمْ تَلِدْ وَ لَمْ تُولَدْ وَ لَمْ يَكُنْ لَكَ كُفُواً اَحَدٌ وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « عٰالِمُ الْغَيْبِ وَ الشَّهٰادَةِ » </quranic_text>   <footnote> [ الحشر ۲۲ ] </footnote>   .  .  .   <quranic_text> « الرَّحْمٰنُ الرَّحِيمُ » </quranic_text>   <footnote> [ الحشر ۲۲ ] </footnote>  وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « الْمَلِكُ الْقُدُّوسُ السَّلاٰمُ الْمُؤْمِنُ الْمُهَيْمِنُ الْعَزِيزُ الْجَبّٰارُ الْمُتَكَبِّرُ سُبْحٰانَ اللّٰهِ عَمّٰا يُشْرِكُونَ » </quranic_text>   <footnote> [ الحشر ۲۳ ] </footnote>  وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « الْخٰالِقُ الْبٰارِئُ الْمُصَوِّرُ » </quranic_text>   <footnote> [ الحشر ۲۴ ] </footnote>  لَكَ الْاَسْمَاءُ الْحُسْنَي يُسَبِّحُ لَكَ مَا فِي السَّمَاوَاتِ وَ الْاَرْضِ وَ اَنْتَ اللَّهُ  <quranic_text> « الْعَزِيزُ الْحَكِيمُ » </quranic_text>   <footnote> [ البقرة ۱۲۹ ] </footnote>  وَ اَنْتَ اللَّهُ لاَ اِلَهَ اِلاَّ اَنْتَ  <quranic_text> « الْكَبِيرُ الْمُتَعٰالِ » </quranic_text>   <footnote> [ الرعد ۹ ] </footnote>  وَ الْكِبْرِيَاءُ رِدَاؤُكَ اللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ وَ اِغْفِرْ لِي مَغْفِرَةً عَزْماً جَزْماً لاَ تُغَادِرُ ذَنْباً وَ لاَ اَرْتَكِبُ بَعْدَهَا مُحَرَّماً وَ عَافِنِي مُعَافَاةً لاَ تَبْتَلِيَنِّي بَعْدَهَا اَبَداً وَ اِهْدِنِي هُدًي لاَ اَضِلُّ بَعْدَهَا اَبَداً وَ عَلِّمْنِي مَا يَنْفَعُنِي وَ اِنْفَعْنِي بِمَا عَلَّمْتَنِي وَ اِجْعَلْهُ حُجَّةً لِي لاَ عَلَيَّ وَ اُرْزُقْنِي مِنْ فَضْلِكَ صَبّاً صَبّاً كَفَافاً كَفَافاً وَ رَضِّنِي بِهِ يَا رَبَّاهْ وَ تُبْ عَلَيَّ يَا اللَّهُ يَا رَحْمَانُ يَا رَحِيمُ صَلِّ عَلَي مُحَمَّدٍ وَ الِهِ وَ اِرْحَمْنِي وَ اَجِرْنِي مِنَ النَّارِ ذَاتِ","translation_segment":"","segment_columns":[{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"word","token":"يلي","display":"يَلِي"},{"kind":"word","token":"السماء","display":"السَّمَاءَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رب","display":"رَبَّ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صل","display":"صَلِّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عجل","display":"عَجِّلْ"},{"kind":"word","token":"فرج","display":"فَرَجَ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"word","token":"مثل","display":"مِثْلَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رب","display":"رَبَّ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صل","display":"صَلِّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","d