{"consensus_set_id":"s331585","translation_language":"fa","translation_source":{"hid":"331585"},"segments":[{"source_hadith_segment":"قَرَاْتُ هَذِهِ الْايَةَ بضع [ بِضْعاً ] وَ عِشْرِينَ ،  اَوْ بضع [ بِضْعاً ] وَ ثَلاَثِينَ سَنَةً - وَ لاَ اَخَافُ اَنْ تُصِيبَنِي  <quranic_text> « وَ اِتَّقُوا فِتْنَةً » </quranic_text>   <footnote> [ الانفال ۲۵ ] </footnote>  الْايَةَ .","translation_segment":"قال الزبیر بن العوام: قرأت هذه الآیه بضع و عشرین، أو بضع و ثلاثین سنه و لا أخاف أن تصیبنی (و اتقوا فتنه). زبیر بن عوام گفت: این آیه را بیست و چند یا سی و چند سال خواندم و نمی‌ترسیدم از این که شامل من شود: «و اتقوا فتنه»","segment_columns":[{"kind":"word","token":"قرات","display":"قَرَاْتُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"بضع","display":"بضع"},{"kind":"word","token":"بضعا","display":"بِضْعاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عشرين","display":"عِشْرِينَ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"بضع","display":"بضع"},{"kind":"word","token":"بضعا","display":"بِضْعاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ثلاثين","display":"ثَلاَثِينَ"},{"kind":"word","token":"سنه","display":"سَنَةً"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اخاف","display":"اَخَافُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تصيبني","display":"تُصِيبَنِي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"فتنه","display":"فِتْنَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۲۵","display":"۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word