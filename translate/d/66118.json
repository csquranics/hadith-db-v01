{"consensus_set_id":"66118","translation_language":"fa","translation_source":{"hid":"373837"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ عَزَّ وَ جَلَّ  <quranic_text> « خُذُوا زِينَتَكُمْ عِنْدَ كُلِّ مَسْجِدٍ » </quranic_text>   <footnote> [ الاعراف ۳۱ ] </footnote>  قَالَ الْمُشْطُ فَاِنَّ الْمَشْطَ يُحَسِّنُ الشَّعْرَ وَ يُنْجِزُ الْحَاجَةَ وَ يَزِيدُ فِي الصُّلْبِ وَ يَقْطَعُ الْبَلْغَمَ .","translation_segment":"و حضرت صادق (علیه السلام) فرمود: مراد از زینت در آیه فوق شانه زدن است که شانه مویها را می‌آراید، و حاجت را بر می‌آورد، و به نیروی کمر می‌افزاید، و بلغم را قطع میکند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"خذوا","display":"خُذُوا"},{"kind":"word","token":"زينتكم","display":"زِينَتَكُمْ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"مسجد","display":"مَسْجِدٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۳۱","display":"۳۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"المشط","display":"الْمُشْطُ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"المشط","display":"الْمَشْطَ"},{"kind":"word","token":"يحسن","display":"يُحَسِّنُ"},{"kind":"word","token":"الشعر","display":"الشَّعْرَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ينجز","display":"يُنْجِزُ"},{"kind":"word","token":"الحاجه","display":"الْحَاجَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يزيد","display":"يَزِيدُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","