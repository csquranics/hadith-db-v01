{"consensus_set_id":"13643","translation_language":"fa","translation_source":{"hid":"106873"},"segments":[{"source_hadith_segment":"مَنْ عَمِلَ سَيِّئَةً اُجِّلَ فِيهَا سَبْعَ سَاعَاتٍ مِنَ النَّهَارِ فَاِنْ قَالَ اَسْتَغْفِرُ اللَّهَ الَّذِي لاَ اِلَهَ اِلاَّ هُوَ الْحَيُّ الْقَيُّومُ وَ اَتُوبُ اِلَيْهِ ثَلاَثَ مَرَّاتٍ لَمْ تُكْتَبْ عَلَيْهِ .","translation_segment":"و نیز آن حضرت علیه السلام فرمود: هر که کار بدی (و گناهی) کند تا هفت ساعت از روز مهلت دارد پس اگر (در این مدت) سه مرتبه گفت: «استغفر اللٰه الذی لا اله الا هو الحی القیوم و اتوب الیه». بر او نوشته نشود.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عمل","display":"عَمِلَ"},{"kind":"word","token":"سيئه","display":"سَيِّئَةً"},{"kind":"word","token":"اجل","display":"اُجِّلَ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"ساعات","display":"سَاعَاتٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"النهار","display":"النَّهَارِ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"استغفر","display":"اَسْتَغْفِرُ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"اله","display":"اِلَهَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الحي","display":"الْحَيُّ"},{"kind":"word","token":"القيوم","display":"الْقَيُّومُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتوب","display":"اَتُوبُ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره۲۵۵","display":"البقرة۲۵۵"},{"kind":"tag_c