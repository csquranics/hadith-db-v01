{"consensus_set_id":"84123","translation_language":"fa","translation_source":{"hid":"251971"},"segments":[{"source_hadith_segment":"<quranic_text> « وَ لَنُذِيقَنَّهُمْ مِنَ الْعَذٰابِ الْاَدْنيٰ دُونَ الْعَذٰابِ الْاَكْبَرِ » </quranic_text>   <footnote> [ السجده ۲۱ ] </footnote>  قَالَ الْعَذَابُ الْاَدْنَي عَذَابُ الرَّجْعَةِ بِالسَّيْفِ وَ مَعْنَي قَوْلِهِ :   <quranic_text> « لَعَلَّهُمْ يَرْجِعُونَ » </quranic_text>   <footnote> [ السجده ۲۱ ] </footnote>  اَيْ يَرْجِعُونَ فِي الرَّجْعَةِ حَتَّي يُعَذَّبُوا .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لنذيقنهم","display":"لَنُذِيقَنَّهُمْ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"العذاب","display":"الْعَذٰابِ"},{"kind":"word","token":"الادني","display":"الْاَدْنيٰ"},{"kind":"word","token":"دون","display":"دُونَ"},{"kind":"word","token":"العذاب","display":"الْعَذٰابِ"},{"kind":"word","token":"الاكبر","display":"الْاَكْبَرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"السجده","display":"السجده"},{"kind":"word","token":"۲۱","display":"۲۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"العذاب","display":"الْعَذَابُ"},{"kind":"word","token":"الادني","display":"الْاَدْنَي"},{"kind":"word","token":"عذاب","display":"عَذَابُ"},{"kind":"word","token":"الرجعه","display":"الرَّجْعَةِ"},{"kind":"word","token":"بالسيف","display":"بِالسَّيْفِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"معني","display":"مَعْنَي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لعلهم","display":"لَعَلَّهُمْ"},{"kind":"word","token":"يرجعون","display":"يَرْجِعُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","