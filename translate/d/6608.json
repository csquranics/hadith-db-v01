{"consensus_set_id":"6608","translation_language":"fa","translation_source":{"hid":"106309"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « فَمٰا اَصْبَرَهُمْ عَلَي النّٰارِ » </quranic_text>   <footnote> [ البقرة ۱۷۵ ] </footnote>  فَقَالَ مَا اَصْبَرَهُمْ عَلَي فِعْلِ مَا يَعْلَمُونَ اَنَّهُ يُصَيِّرُهُمْ اِلَي النَّارِ .","translation_segment":"امام صادق ع در باره قول خدای عز و جل: «چه صبری بر آتش دوزخ دارند ۲۷۵ سوره ۲» فرمود: یعنی چه صبری دارند بر کارهائی که میکنند که آنها را بسوی آتش میکشاند.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فما","display":"فَمٰا"},{"kind":"word","token":"اصبرهم","display":"اَصْبَرَهُمْ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"النار","display":"النّٰارِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۷۵","display":"۱۷۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اصبرهم","display":"اَصْبَرَهُمْ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"فعل","display":"فِعْلِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يعلمون","display":"يَعْلَمُونَ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"يصيرهم","display":"يُصَيِّرُهُمْ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"النار","display":"النَّارِ"}]}]}