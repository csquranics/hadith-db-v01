{"consensus_set_id":"s331795","translation_language":"fa","translation_source":{"hid":"331795"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « سَيَجْعَلُ لَهُمُ الرَّحْمٰنُ وُدًّا » </quranic_text>   <footnote> [ مريم ۹۶ ] </footnote>  قَالَ :  لاَ يَلْقَي مُؤْمِنٌ اِلاَّ وَ فِي قَلْبِهِ وُدٌّ لِعَلِيٍّ عَلَيْهِ السَّلاَمُ  .","translation_segment":"همین مضمون با چند سند دیگر نیز از محمد حنفیه نقل شده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سيجعل","display":"سَيَجْعَلُ"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"ودا","display":"وُدًّا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"مريم","display":"مريم"},{"kind":"word","token":"۹۶","display":"۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يلقي","display":"يَلْقَي"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٌ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قلبه","display":"قَلْبِهِ"},{"kind":"word","token":"ود","display":"وُدٌّ"},{"kind":"word","token":"لعلي","display":"لِعَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}