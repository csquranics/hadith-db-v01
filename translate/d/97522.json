{"consensus_set_id":"97522","translation_language":"fa","translation_source":{"hid":"250434"},"segments":[{"source_hadith_segment":"خَطَرَ بِبَالِي اَنَّ الْقُرْانَ مَخْلُوقٌ اَمْ غَيْرُ مَخْلُوقٍ فَقَالَ اَبُو مُحَمَّدٍ عَلَيْهِ السَّلاَمُ يَا اَبَا هَاشِمٍ  <quranic_text> « اللّٰهُ خٰالِقُ كُلِّ شَيْءٍ » </quranic_text>   <footnote> [ الزمر ۶۲ ] </footnote>  وَ مَا سِوَاهُ مَخْلُوقٌ .","translation_segment":"","segment_columns":[{"kind":"word","token":"خطر","display":"خَطَرَ"},{"kind":"word","token":"ببالي","display":"بِبَالِي"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"القران","display":"الْقُرْانَ"},{"kind":"word","token":"مخلوق","display":"مَخْلُوقٌ"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"غير","display":"غَيْرُ"},{"kind":"word","token":"مخلوق","display":"مَخْلُوقٍ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"هاشم","display":"هَاشِمٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"خالق","display":"خٰالِقُ"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزمر","display":"الزمر"},{"kind":"word","token":"۶۲","display":"۶۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"سواه","display":"سِوَاهُ"},{"kind":"word","token":"مخلوق","display":"مَخْلُوقٌ"}]}]}