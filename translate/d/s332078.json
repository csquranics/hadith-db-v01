{"consensus_set_id":"s332078","translation_language":"fa","translation_source":{"hid":"332078"},"segments":[{"source_hadith_segment":"،  عَنْ اَبِيهِ  ،  عَنْ جَدِّهِ  :  فِي قَوْلِهِ :   <quranic_text> « اَمْ نَجْعَلُ » </quranic_text>   <footnote> [ ص ۲۸ ] </footnote>  الْايَةَ [ قَالَ ] نَزَلَتْ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ  .","translation_segment":"عن جعفر بن محمد، عن أبیه، عن جده فی قوله: (أم نجعل) الآیه قال نزلت فی علی بن أبی طالب ع. جعفر بن محمد از پدرانش نقل می‌کند که سخن خداوند: «ام نجعل الذین آمنوا» درباره علی‌ بن ابی طالب (علیه السلام) نازل شده است.","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"جده","display":"جَدِّهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"نجعل","display":"نَجْعَلُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ص","display":"ص"},{"kind":"word","token":"۲۸","display":"۲۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}