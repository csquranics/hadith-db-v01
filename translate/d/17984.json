{"consensus_set_id":"17984","translation_language":"fa","translation_source":{"hid":"372190"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « الشُّعَرٰاءُ يَتَّبِعُهُمُ الْغٰاوُونَ » </quranic_text>   <footnote> [ الشعراء ۲۲۴ ] </footnote>  قَالَ هَلْ رَاَيْتَ شَاعِراً يَتَّبِعُهُ اَحَدٌ اِنَّمَا هُمْ قَوْمٌ تَفَقَّهُوا لِغَيْرِ الدِّينِ فَضَلُّوا وَ اَضَلُّوا .","translation_segment":"حماد بن عثمان گوید: امام باقر علیه السلام در معنای فرموده خدای عز و جل «الشعرٰاء یتبعهم‌ الغٰاون‌» (و شاعران را پیروی کنند زیانکاران و نادانان- الشعرا ۲۲۴:۲۶) فرمود: آیا شاعری را دیده‌ای که کسی از او پیروی کند؟ جز این نیست که آنها گروهی‌اند که دانش می‌آموزند برای غیر دین، به این دلیل گمراه می‌شوند و مردم را نیز به گمراهی میکشند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الشعراء","display":"الشُّعَرٰاءُ"},{"kind":"word","token":"يتبعهم","display":"يَتَّبِعُهُمُ"},{"kind":"word","token":"الغاوون","display":"الْغٰاوُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الشعراء","display":"الشعراء"},{"kind":"word","token":"۲۲۴","display":"۲۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"رايت","display":"رَاَيْتَ"},{"kind":"word","token":"شاعرا","display":"شَاعِراً"},{"kind":"word","token":"يتبعه","display":"يَتَّبِعُهُ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"قوم","display