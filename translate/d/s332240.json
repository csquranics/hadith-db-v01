{"consensus_set_id":"s332240","translation_language":"fa","translation_source":{"hid":"332240"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اِنَّ اللّٰهَ يُحِبُّ الَّذِينَ - يُقٰاتِلُونَ فِي سَبِيلِهِ صَفًّا - كَاَنَّهُمْ بُنْيٰانٌ مَرْصُوصٌ » </quranic_text>   <footnote> [ الصف ۴ ] </footnote>","translation_segment":"عن ضحاک عن ابن عباس فی قوله تعالی: (إن‌ الله یحب‌ الذین یقاتلون فی سبیله صفا کأنهم بنیان مرصوص) أنه قیل له: من هولاء؟ قال: حمزه أسد الله و أسد رسوله و علی‌ بن أبی طالب و عبیده بن الحارث و المقداد بن الأسود. ضحاک از","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"يحب","display":"يُحِبُّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يقاتلون","display":"يُقٰاتِلُونَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"سبيله","display":"سَبِيلِهِ"},{"kind":"word","token":"صفا","display":"صَفًّا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"كانهم","display":"كَاَنَّهُمْ"},{"kind":"word","token":"بنيان","display":"بُنْيٰانٌ"},{"kind":"word","token":"مرصوص","display":"مَرْصُوصٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الصف","display":"الصف"},{"kind":"word","token":"۴","display":"۴"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"[ اَنَّهُ قِيلَ لَهُ :  ] مَنْ هَؤُلاَءِ","translation_segment":"ابن عباس نقل می‌کند که درباره سخن خداوند: «ان‌ الله یحب‌ الذین","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قيل","display":"قِيلَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"هؤلاء","display":"هَؤُلاَءِ"}]},{"source_hadith_segment":"قَالَ :  حَمْزَةُ اَسَدُ اللَّهِ وَ اَسَدُ رَسُولِهِ","translation_segment":"یقاتلون فی سبیله صفا کانهم بنیان مرصوص» از او پرسیده شد که آنان","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"حمزه","display":"حَمْزَةُ"},{"kind":"word","token":"اسد","display":"اَسَدُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسد","display":"اَسَدُ"},{"kind":"word","token":"رسوله","display":"رَسُولِهِ"}]},{"source_hadith_segment":"،  وَ عَلِيُّ بْنُ اَبِي طَالِبٍ وَ عُبَيْدَةُ بْنُ الْحَارِثِ وَ الْمِقْدَادُ بْنُ الْاَسْوَدِ .","translation_segment":"چه کسانی هستند؟ او گفت: حمزه شیر خدا و شیر پیامبرش و علی‌ بن ابی طالب (علیه السلام) و عبیده بن حارث و مقداد بن اسود.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عبيده","display":"عُبَيْدَةُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"الحارث","display":"الْحَارِثِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المقداد","display":"الْمِقْدَادُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"الاسود","display":"الْاَسْوَدِ"}]}]}