","display":"۱۶۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"صاحب","display":"صَاحِبُ"},{"kind":"word","token":"المجلس","display":"الْمَجْلِسِ"},{"kind":"word","token":"جزاك","display":"جَزَاكَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"خيرا","display":"خَيْراً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لعن","display":"لَعَنَ"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"وشي","display":"وَشَي"},{"kind":"word","token":"بك","display":"بِكَ"},{"kind":"word","token":"الي","display":"اِلَيَّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"}]},{"source_hadith_segment":"لَهُ مُوسَي بْنُ جَعْفَرٍ عَلَيْهِمَا السَّلاَمُ لَيْسَ كَمَا ظَنَنْتَ وَ لَكِنَّ صَاحِبَكَ اَفْقَهُ مِنْكَ اِنَّمَا قَالَ مُوسَي غَيْرُ اِمَامٍ اَيْ اِنَّ الَّذِي هُوَ غَيْرُ اِمَامٍ فَمُوسَي غَيْرُهُ فَهُوَ اِذاً اِمَامٌ فَاِنَّمَا اَثْبَتَ بِقَوْلِهِ هَذَا اِمَامَتِي وَ نَفَي اِمَامَةَ غَيْرِي يَا عَبْدَ اللَّهِ مَتَي يَزُولُ عَنْكَ هَذَا الَّذِي ظَنَنْتَهُ بِاَخِيكَ هَذَا مِنَ النِّفَاقِ تُبْ اِلَي اللَّهِ فَفَهِمَ الرَّجُلُ مَا قَالَهُ وَ اِغْتَمَّ ثُمَّ قَالَ يَا اِبْنَ رَسُولِ اللَّهِ مَا لِي مَالٌ فَاُرْضِيَهُ بِهِ وَ لَكِنْ قَدْ وَهَبْتُ لَهُ شَطْرَ عَمَلِي كُلِّهِ مِنْ تَعَبُّدِي وَ صَلاَتِي عَلَيْكُمْ اَهْلَ الْبَيْتِ وَ مِنْ لَعْنَتِي لِاَعْدَائِكُمْ قَالَ مُوسَي عَلَيْهِ السَّلاَمُ الْانَ خَرَجْتَ مِنَ النَّارِ .","translation_segment":"این بیرون می‌آئی زیرا که این ظن‌ ناموتمن تو بر آن مومن بمضمون صدق مشحون إن‌ بعض‌ الظن‌ إثم‌ سبب نفاق و موجب گناه و شقاق و وسیله دوری از رحمت حضرت مهیمن خلاق است. آن مومن خاص‌ چون این کلام از آن ولی‌ بیچون علیه السلام استماع نمود بغایت غمگین و حزین گردید و گفت: یا ابن رسول اللٰه مرا مال دنیا چیزی نیست تا آن مومن را بآن از خود راضی و شادمان گردانم لیکن شطر از ثواب عمل از عبادت و بندگی حضرت عز و جل‌ صلوات بر شما أهل البیت و جزا و پاداشت لعنت من بر أعدای شما أولاد و أحفاد سید الرسل باو هبه بصدق دل نمودم. حضرت موسی ع الملک الغفار فرمود که: ای مومن نیکوکار الحال از نار بیرون آمدی و منخرط‍‌ در سلک أبرار و أخیار شدی. و نیز از أبو محمد الحسن العسکری منقول و مروی است که حضرت امام موسی الکاظم علیه السلام فرمود که: یک فقیه از فقهای ما که یتیم از أیتام ما را که منقطع از مشاهده ما و محروم از صحبت کثیر البهجه و المنفعه ما شده باشد و او را بوسیله تعلیم ما یحتاج الیه نگاه از مکاره دارد او أشد است بر ابلیس از هزار عابد زیرا که همگی همت و تمامی بهمت عابد وقایت و صیانت نفس اوست و بس بخلاف فقیه که همت او با ذات نفس خود ذات جمیع بندگان ایزد تعالی و تقدس است که همگی بندگان قادر سبحان را از دست ابلیس و باقی مرده شیطان بسعی او در حفظ‍‌ و امان ایزد منان باشد و این در نزد خدای واحد أفضل است از هزار عابد بلکه از هزار هزار عابد.","segment_columns":[{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"ظننت","display":"ظَنَنْتَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لَكِنَّ"},{"kind":"word","token":"صاحبك","display":"صَاحِبَكَ"},{"kind":"word","token":"افقه","display":"اَفْقَهُ"},{"kind":"word","token":"منك","display":"مِنْكَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"غير","display":"غَيْرُ"},{"kind":"word","token":"امام","display":"اِمَامٍ"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"غير