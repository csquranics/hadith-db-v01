s":[]},{"source_hadith_segment":"اَخِّرْ عَنْ فُلاَنِ بْنِ فُلاَنٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"كُلَّمَا يَغْدُو وَ يَرُوحُ مِنْ ذِي حَيٍّ اَوْ عَقْرَبٍ اَوْ سَاحِرٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اَوْ شَيْطَانٍ رَجِيمٍ اَوْ سُلْطَانٍ عَنِيدٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اَخَذْتُ عَنْهُ مَا يُرَي وَ مَا لاَ يُرَي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ مَا رَاَتْ عَيْنُ نَائِمٍ اَوْ يَقْظَانَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"بِاِذْنِ اللَّهِ اللَّطِيفِ الْخَبِيرِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لاَ سُلْطَانَ لَكُمْ عَلَي اللَّهِ لاَ شَرِيكَ لَهُ وَ صَلَّي اللَّهُ عَلَي رَسُولِهِ سَيِّدِنَا مُحَمَّدٍ النَّبِيِّ وَ الِهِ الطَّاهِرِينَ وَ سَلَّمَ تَسْلِيماً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"عُوذَةُ يَوْمِ الثَّلاَثَاءِ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  اُعِيذُ نَفْسِي بِاللَّهِ الْاَكْبَرِ رَبِّ السَّمَاوَاتِ الْقَائِمَاتِ بِلاَ عَمَدٍ وَ الَّذِي خَلَقَهَا فِي يَوْمَيْنِ وَ قَضَي  <quranic_text> « فِي كُلِّ سَمٰاءٍ اَمْرَهٰا » </quranic_text>   <footnote> [ فصلت ۱۲ ] </footnote>  وَ  <quranic_text> « خَلَقَ الْاَرْضَ فِي يَوْمَيْنِ » </quranic_text>   <footnote> [ فصلت ۹ ] </footnote>   <quranic_text> « وَ قَدَّرَ فِيهٰا اَقْوٰاتَهٰا » </quranic_text>   <footnote> [ فصلت ۱۰ ] </footnote>  وَ جَعَلَ فِيهَا جِبِالاً وَ اَوْتَاداً وَ جَعَلَهَا فِجَاجاً وَ سُبُلاً وَ اَنْشَاَ السَّحَابَ وَ سَخَّرَهُ وَ اَجْرَي الْفُلْكَ وَ  <quranic_text> « سَخَّرَ الْبَحْرَ » </quranic_text>   <footnote> [ النحل ۱۴ ] </footnote>  وَ جَعَلَ فِي الْاَرْضِ  <quranic_text> « رَوٰاسِيَ وَ اَنْهٰاراً » </quranic_text>   <footnote> [ الرعد ۳ ] </footnote>   <quranic_text> « فِي اَرْبَعَةِ اَيّٰامٍ سَوٰاءً لِلسّٰائِلِينَ » </quranic_text>   <footnote> [ فصلت ۱۰ ] </footnote>  وَ مِنْ شَرِّ مَا يَكُونُ فِي اللَّيْلِ وَ النَّهَارِ وَ يَعْقِدُ عَلَيْهِ الْقُلُوبُ وَ تَرَاهُ الْعُيُونُ مِنَ الْجِنِّ وَ الْاِنْسِ كَفَانَا اللَّهُ كَفَانَا اللَّهُ كَفَانَا اللَّهُ لاَ اِلَهَ اِلاَّ اللَّهُ مُحَمَّدٌ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَي مُحَمَّدٍ وَ الِهِ الطَّاهِرِينَ وَ سَلَّمَ تَسْلِيماً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"عُوذَةُ يَوْمِ الْاَرْبِعَاءِ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  اُعِيذُ نَفْسِي بِالْاَحَدِ الصَّمَدِ  <quranic_text> « مِنْ شَرِّ النَّفّٰاثٰاتِ فِي الْعُقَدِ » </quranic_text>   <footnote> [ الفلق ۴ ] </footnote>  وَ مِنْ شَرِّ اِبْنِ فِتْرَةٍ وَ مَا وَلَدَ بِاللَّهِ الْوَاحِدِ الْفَرْدِ الْكَبِيرِ الْاَعْلَي مِنْ شَرِّ مَا رَاَتْ عَيْنِي وَ مَا لَمْ تَرَ اَسْتَعِيذُ بِاللَّهِ الْوَاحِدِ الْفَرْدِ مِنْ شَرِّ مَنْ اَرَادَنِي بِاَمْرٍ عَسِيرٍ اللَّهُمَّ صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ وَ اِجْعَلْنِي فِي جِوَارِكَ وَ حِصْنِكَ الْحَصِينِ الْعَزِيزِ الْجَبَّارِ الْمَلِكِ الْقُدُّوسِ الْقَهَّارِ السَّلاَمِ الْمُؤْمِنِ الْمُهَيْمِنِ الْغَفَّارِ عَالِمِ الْغَيْبِ وَ الشَّهَادَةِ الْكَبِيرِ الْمُتَعَالِ هُوَ اللَّهُ هُوَ اللَّهُ هُوَ اللَّهُ لاَ شَرِيكَ لَهُ مُحَمَّدٌ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ كَثِيراً دَائِماً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"عُوذَةُ يَوْمِ الْخَمِيسِ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  اُعِيذُ نَفْسِي  <quranic_text> « بِرَبِّ الْمَشٰارِقِ وَ الْمَغٰارِبِ » </quranic_text>   <footnote> [ المعارج ۴۰ ] </footnote>   <quranic_text> « مِنْ كُلِّ شَيْطٰانٍ مٰارِدٍ » </quranic_text>   <footnote> [ الصافات ۷ ] </footnote>  وَ قَائِمٍ وَ قَاعِدٍ وَ عَدُوٍّ وَ حَاسِدٍ وَ مُعَانِدٍ  <quranic_text> « وَ يُنَزِّلُ عَلَيْكُمْ مِنَ السَّمٰاءِ مٰاءً لِيُطَهِّرَكُمْ بِهِ وَ يُذْهِبَ عَنْكُمْ رِجْزَ الشَّيْطٰانِ وَ لِيَرْبِطَ عَليٰ قُلُوبِكُمْ وَ يُثَبِّتَ بِهِ الْاَقْدٰامَ » </quranic_text>   <footnote> [ الانفال ۱۱ ] </footnote>   <quranic_text> « اُرْكُضْ بِرِجْلِكَ هٰذٰا مُغْتَسَلٌ بٰارِدٌ وَ شَرٰابٌ » </quranic_text>   <footnote> [ ص ۴۲ ] </footnote>   <quranic_text> « وَ اَنْزَلْنٰا مِنَ السَّمٰاءِ مٰاءً طَهُوراً لِنُحْيِيَ بِهِ بَلْدَةً مَيْتاً وَ نُسْقِيَهُ مِمّٰا خَلَقْنٰا اَنْعٰاماً وَ اَنٰاسِيَّ كَثِيراً » </quranic_text>   <footnote> [ الفرقان ۴۹ ] </footnote>   <quranic_text> « الْانَ خَفَّفَ اللّٰهُ عَنْكُمْ » </quranic_text>   <footnote> [ الانفال ۶۶ ] </footnote>   <quranic_text> « ذٰلِكَ تَخْفِيفٌ مِنْ رَبِّكُمْ وَ رَحْمَةٌ » </quranic_text>   <footnote> [ البقرة ۱۷۸ ] </footnote>   <quranic_text> « يُرِيدُ اللّٰهُ اَنْ يُخَفِّفَ عَنْكُمْ » </quranic_text>   <footnote> [ النساء ۲۸ ] </footnote>   <quranic_text> « فَسَيَكْفِيكَهُمُ اللّٰهُ وَ هُوَ السَّمِيعُ الْعَلِيمُ » </quranic_text>   <footnote> [ البقرة ۱۳۷ ] </footnote>  لاَ اِلَهَ اِلاَّ اللَّهُ وَ لاَ غَالِبَ اِلاَّ اللَّهُ لاَ اِلَهَ اِلاَّ اللَّهُ مُحَمَّدٌ رَسُولُ اللَّهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ تَسْلِيماً عُوذَةُ يَوْمِ الْجُمُعَةِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"<quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لاَ حَوْلَ وَ لاَ قُوَّةَ اِلاَّ بِاللَّهِ الْعَلِيِّ الْعَظِيمِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ رَبَّ الْمَلاَئِكَةِ وَ النَّبِيِّينَ وَ الْمُرْسَلِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَاهِرَ مَنْ فِي السَّمَاوَاتِ وَ الْاَرَضِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ خَالِقَ كُلِّ شَيْءٍ وَ مَالِكَهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"كُفَّ عَنِّ