{"consensus_set_id":"s410493","translation_language":"fa","translation_source":{"hid":"410493"},"segments":[{"source_hadith_segment":"« اِنَّ اَلْهِدَايَةِ مِنْهُ :  التَّعْرِيفُ ،  كَقَوْلِهِ تَعَالَي :   <quranic_text> « وَ اَمّٰا ثَمُودُ فَهَدَيْنٰاهُمْ فَاسْتَحَبُّوا الْعَميٰ عَلَي الْهُديٰ » </quranic_text>   <footnote> [ فصلت ۱۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الهدايه","display":"اَلْهِدَايَةِ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"التعريف","display":"التَّعْرِيفُ"},{"kind":"word","token":"كقوله","display":"كَقَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمّٰا"},{"kind":"word","token":"ثمود","display":"ثَمُودُ"},{"kind":"word","token":"فهديناهم","display":"فَهَدَيْنٰاهُمْ"},{"kind":"word","token":"فاستحبوا","display":"فَاسْتَحَبُّوا"},{"kind":"word","token":"العمي","display":"الْعَميٰ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الهدي","display":"الْهُديٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"فصلت","display":"فصلت"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"}]}]}