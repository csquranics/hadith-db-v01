{"consensus_set_id":"s245018","translation_language":"fa","translation_source":{"hid":"245018"},"segments":[{"source_hadith_segment":"وَ اَبُو عَبْدِ اللَّهِ عَلَيْهِمَا السَّلاَمُ  :  نَزَلَتْ قَوْلُهُ :   <quranic_text> « وَ لاٰ يَرْهَقُ وُجُوهَهُمْ قَتَرٌ وَ لاٰ ذِلَّةٌ » </quranic_text>   <footnote> [ يونس ۲۶ ] </footnote>  فِي اَمِيرِ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ  .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يرهق","display":"يَرْهَقُ"},{"kind":"word","token":"وجوههم","display":"وُجُوهَهُمْ"},{"kind":"word","token":"قتر","display":"قَتَرٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"ذله","display":"ذِلَّةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يونس","display":"يونس"},{"kind":"word","token":"۲۶","display":"۲۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}