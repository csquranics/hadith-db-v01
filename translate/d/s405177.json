{"consensus_set_id":"s405177","translation_language":"fa","translation_source":{"hid":"405177"},"segments":[{"source_hadith_segment":"« اَمَّا قَوْلُهُ  <quranic_text> « فَلَمّٰا نَسُوا مٰا ذُكِّرُوا بِهِ » </quranic_text>   <footnote> [ الانعام ۴۴ ] </footnote> يَعْنِي فَلَمَّا تَرَكُوا وَلاَيَةَ عَلِيٍّ وَ قَدْ اُمِرُوا بِهَا  <quranic_text> « فَتَحْنٰا عَلَيْهِمْ اَبْوٰابَ كُلِّ شَيْءٍ » </quranic_text>   <footnote> [ الانعام ۴۴ ] </footnote> ] يَعْنِي دَوْلَتَهُمْ فِي الدُّنْيَا وَ مَا بُسِطَ لَهُمْ فِيهَا ،  وَ اَمَّا قَوْلُهُ  <quranic_text> « حَتّٰي اِذٰا فَرِحُوا بِمٰا اُوتُوا اَخَذْنٰاهُمْ بَغْتَةً فَاِذٰا هُمْ مُبْلِسُونَ » </quranic_text>   <footnote> [ الانعام ۴۴ ] </footnote>  يَعْنِي قِيَامَ الْقَائِمِ ( عَلَيْهِ السَّلاَمُ ) » .","translation_segment":"","segment_columns":[{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلما","display":"فَلَمّٰا"},{"kind":"word","token":"نسوا","display":"نَسُوا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ذكروا","display":"ذُكِّرُوا"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۴۴","display":"۴۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"تركوا","display":"تَرَكُوا"},{"kind":"word","token":"ولايه","display":"وَلاَيَةَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"امروا","display":"اُمِرُوا"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فتحنا","display":"فَتَحْنٰا"},{"kind":"word","token":"علي