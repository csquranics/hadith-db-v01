{"consensus_set_id":"s402316","translation_language":"fa","translation_source":{"hid":"402316"},"segments":[{"source_hadith_segment":"« قَالَ اَللَّهُ تَعَالَي :   <quranic_text> « وَ الَّذِينَ كَفَرُوا وَ كَذَّبُوا بِايٰاتِنٰا » </quranic_text>   <footnote> [ البقرة ۳۹ ] </footnote>  الدَّالاَّتِ عَلَي صِدْقِ مُحَمَّدٍ عَلَي مَا جَاءَ بِهِ مِنْ اَخْبَارِ الْقُرُونِ السَّالِفَةِ ،  وَ عَلَي مَا اَدَّاهُ اِلَي عِبَادِ اللَّهِ مِنْ ذِكْرِ تَفْضِيلِهِ لِعَلِيٍّ وَ الِهِ الطَّيِّبِينَ خَيْرِ الْفَاضِلِينَ وَ الْفَاضِلاَتِ ،  بَعْدَ مُحَمَّدٍ سَيِّدِ الْبَرِيَّاتِ  <quranic_text> « اُولٰئِكَ » </quranic_text>   <footnote> [ البقرة ۳۹ ] </footnote>  الدَّافِعُونَ لِصِدْقِ مُحَمَّدٍ فِي اِنْبَائِهِ ،  وَ الْمُكَذِّبُونَ لَهُ فِي نَصْبِ اَوْلِيَائِهِ :  عَلِيٍّ سَيِّدِ الْاَوْصِيَاءِ ،  وَ الْمُنْتَجَبِينَ مِنْ ذُرِّيَّتِهِ الطَّاهِرِينَ اَصْحَابُ النَّارِ هُمْ فِيهَا خَالِدُونَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"كفروا","display":"كَفَرُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كذبوا","display":"كَذَّبُوا"},{"kind":"word","token":"باياتنا","display":"بِايٰاتِنٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۳۹","display":"۳۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الدالات","display":"الدَّالاَّتِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"صدق","display":"صِدْقِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"جاء","displ