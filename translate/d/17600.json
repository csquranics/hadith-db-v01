hadith_segment":"قَالَ « لَمْ يَحْكُمَا اِنَّمَا كَانَا يَتَنَاظَرَانِ <quranic_text> « فَفَهَّمْنٰاهٰا سُلَيْمٰانَ  » </quranic_text>   <footnote> [ الانبياء ۷۹ ] </footnote>   .","translation_segment":"که در مورد مزرعه‌ای که به شب گوسفندان در آن چریده بودند حکم کردند و بسلیمان حکم را آموختیم.) فرمود: هنوز حکمی نکرده بودند بلکه با هم مشورت و گفتگو می‌کردند که خداوند می‌فرماید ما به سلیمان حکم را آموختیم. یا مطابق پاره‌ای از نسخ: سلیمان خود حکم و راه چاره را دریافت.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يحكما","display":"يَحْكُمَا"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"كانا","display":"كَانَا"},{"kind":"word","token":"يتناظران","display":"يَتَنَاظَرَانِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ففهمناها","display":"فَفَهَّمْنٰاهٰا"},{"kind":"word","token":"سليمان","display":"سُلَيْمٰانَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۷۹","display":"۷۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}