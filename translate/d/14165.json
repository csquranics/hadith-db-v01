{"consensus_set_id":"14165","translation_language":"fa","translation_source":{"hid":"104268"},"segments":[{"source_hadith_segment":"فِي هَذِهِ الْايَةِ :   <quranic_text> « يَمْحُوا اللّٰهُ مٰا يَشٰاءُ وَ يُثْبِتُ » </quranic_text>   <footnote> [ الرعد ۳۹ ] </footnote>  قَالَ فَقَالَ وَ هَلْ يُمْحَي اِلاَّ مَا كَانَ ثَابِتاً وَ هَلْ يُثْبَتُ اِلاَّ مَا لَمْ يَكُنْ .","translation_segment":"امام صادق ع راجع بآیه (۴۱ سوره ۱۳) «و خدا آنچه را خواهد محو میکند و ثبت میکند» فرمود: مگر نه اینست که محو شود چیزی که ثابت بوده و ثبت شود چیزی که نبوده (و بدا چیزی جز این نیست).","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يمحوا","display":"يَمْحُوا"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يشاء","display":"يَشٰاءُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يثبت","display":"يُثْبِتُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۳۹","display":"۳۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"يمحي","display":"يُمْحَي"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ثابتا","display":"ثَابِتاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"يثبت","display":"يُثْبَتُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"م