{"consensus_set_id":"s392571","translation_language":"fa","translation_source":{"hid":"392571"},"segments":[{"source_hadith_segment":"ذُو اَلْقَعْدَةِ ثَلَثُونَ يَوْماً لِقَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ وٰاعَدْنٰا مُوسيٰ ثَلاٰثِينَ لَيْلَةً » </quranic_text>   <footnote> [ الاعراف ۱۴۲ ] </footnote>   .  وَ الْحَدِيثُ طَوِيلٌ اَخَذْنَا مِنْهُ مَوْضِعَ الْحَاجَةِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"القعده","display":"اَلْقَعْدَةِ"},{"kind":"word","token":"ثلثون","display":"ثَلَثُونَ"},{"kind":"word","token":"يوما","display":"يَوْماً"},{"kind":"word","token":"لقول","display":"لِقَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"واعدنا","display":"وٰاعَدْنٰا"},{"kind":"word","token":"موسي","display":"مُوسيٰ"},{"kind":"word","token":"ثلاثين","display":"ثَلاٰثِينَ"},{"kind":"word","token":"ليله","display":"لَيْلَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۴۲","display":"۱۴۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحديث","display":"الْحَدِيثُ"},{"kind":"word","token":"طويل","display":"طَوِيلٌ"},{"kind":"word","token":"اخذنا","display":"اَخَذْنَا"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"موضع","display":"مَوْضِعَ"},{"kind":"word","token":"الحاجه","display":"الْحَاجَةِ"}]}]}