{"consensus_set_id":"s401862","translation_language":"fa","translation_source":{"hid":"401862"},"segments":[{"source_hadith_segment":"« لَوْ وَجَدْتُ لِعِلْمِيَ الَّذِي اتَانِيَ اللَّهُ عَزَّ وَ جَلَّ حَمَلَةً لَنَشَرْتُ التَّوْحِيدَ ،  وَ الْاِسْلاَمَ ،  وَ الْاِيمَانَ ،  وَ الدِّينَ ،  وَ الشَّرَائِعَ مِنَ الصَّمَدِ ،  وَ كَيْفَ لِي بِذَلِكَ وَ لَمْ يَجِدْ جَدِّي اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) حَمَلَةً لِعِلْمِهِ ؟  !  حَتَّي كَانَ يَتَنَفَّسُ الصُّعَدَاءَ وَ يَقُولُ عَلَي الْمِنْبَرِ :  سَلُونِي قَبْلَ اَنْ تَفْقِدُونِي ،  فَاِنَّ بَيْنَ الْجَوَانِحِ مِنِّي لَعِلْماً جَمّاً ،  لاَ يُحْصَي وَ لاَ يُحَدُّ ،  اَلاَ وَ اِنِّي عَلَيْكُمْ مِنَ اللَّهِ الْحُجَّةُ الْبَالِغَةُ فَ  <quranic_text> « لاٰ تَتَوَلَّوْا قَوْماً غَضِبَ اللّٰهُ عَلَيْهِمْ قَدْ يَئِسُوا مِنَ الْاخِرَةِ كَمٰا يَئِسَ الْكُفّٰارُ مِنْ اَصْحٰابِ الْقُبُورِ » </quranic_text>   <footnote> [ الممتحنة ۱۳ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"وجدت","display":"وَجَدْتُ"},{"kind":"word","token":"لعلمي","display":"لِعِلْمِيَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"اتاني","display":"اتَانِيَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"حمله","display":"حَمَلَةً"},{"kind":"word","token":"لنشرت","display":"لَنَشَرْتُ"},{"kind":"word","token":"التوحيد","display":"التَّوْحِيدَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الاسلام","display":"الْاِسْلاَمَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الايمان","display":"الْاِيمَانَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الدين","display":"الدِّينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الشرائع","display":"الشَّرَائِعَ"},{"kind":"word","token":"من","d