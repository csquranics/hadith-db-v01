{"consensus_set_id":"9934","translation_language":"fa","translation_source":{"hid":"371658"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنِ  <quranic_text> « التّٰابِعِينَ غَيْرِ اُولِي الْاِرْبَةِ مِنَ الرِّجٰالِ » </quranic_text>   <footnote> [ النور ۳۱ ] </footnote>  قَالَ هُوَ الْاَبْلَهُ الْمُوَلَّي عَلَيْهِ الَّذِي لاَ يَاْتِي النِّسَاءَ .","translation_segment":"أبو بصیر گوید: از امام صادق ع معنی این آیه را پرسیدم: «التٰابعین‌ غیر أولی الإربه‌ من‌ الرجٰال‌» (و پیروان از مردانی که میل جنسی ندارند) فرمود: مردان نادانی هستند که با زنان همبستر نمی‌گردند.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"التابعين","display":"التّٰابِعِينَ"},{"kind":"word","token":"غير","display":"غَيْرِ"},{"kind":"word","token":"اولي","display":"اُولِي"},{"kind":"word","token":"الاربه","display":"الْاِرْبَةِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الرجال","display":"الرِّجٰالِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النور","display":"النور"},{"kind":"word","token":"۳۱","display":"۳۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الابله","display":"الْاَبْلَهُ"},{"kind":"word","token":"المولي","display":"الْمُوَلَّي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يا