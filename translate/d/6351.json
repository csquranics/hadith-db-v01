{"consensus_set_id":"6351","translation_language":"fa","translation_source":{"hid":"118637"},"segments":[{"source_hadith_segment":"لاَ يُحْلَفُ الْيَهُودِيُّ وَ لاَ النَّصْرَانِيُّ وَ لاَ الْمَجُوسِيُّ بِغَيْرِ اللَّهِ اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « فَاحْكُمْ بَيْنَهُمْ بِمٰا اَنْزَلَ اللّٰهُ » </quranic_text>   <footnote> [ المائدة ۴۸ ] </footnote>   .","translation_segment":"سلیمان بن خالد گوید: امام صادق علیه السلام فرمود: یهودی، نصرانی و مجوسی را جز به نام خدا نمی‌توانند سوگند دهند. خداوند عز و جل می‌فرماید: «در میان یهود و نصارا به حکم آن‌چه خداوند نازل فرموده داوری کن».","segment_columns":[{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يحلف","display":"يُحْلَفُ"},{"kind":"word","token":"اليهودي","display":"الْيَهُودِيُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"النصراني","display":"النَّصْرَانِيُّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"المجوسي","display":"الْمَجُوسِيُّ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاحكم","display":"فَاحْكُمْ"},{"kind":"word","token":"بينهم","display":"بَيْنَهُمْ"},{"kind":"word","token":"بما","display":"بِمٰا"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۴۸","display":"۴۸"},{"kind":"tag_close","tag_name":"