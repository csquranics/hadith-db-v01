{"consensus_set_id":"90141","translation_language":"fa","translation_source":{"hid":"375952"},"segments":[{"source_hadith_segment":"<quranic_text> « وَ لَمّٰا جٰاءَ مُوسيٰ لِمِيقٰاتِنٰا » </quranic_text>   <footnote> [ الاعراف ۱۴۳ ] </footnote>  اِلَي قَوْلِهِ  <quranic_text> « اَوَّلُ الْمُؤْمِنِينَ » </quranic_text>   <footnote> [ الاعراف ۱۴۳ ] </footnote>  يَقْرَاُ عَلَي الْمَاءِ وَ يَمْسَحُ بِهِ رَاْسَهُ وَ وَجْهَهُ وَ ذِرَاعَيْهِ .","translation_segment":"و لمٰا جٰاء موسیٰ‌ لمیقٰاتنٰا» …تا … «أول‌ المومنین‌») بر آب خوانده شود و بوسیله آن سرو صورت و ساق دست را مسح کند).","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لما","display":"لَمّٰا"},{"kind":"word","token":"جاء","display":"جٰاءَ"},{"kind":"word","token":"موسي","display":"مُوسيٰ"},{"kind":"word","token":"لميقاتنا","display":"لِمِيقٰاتِنٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۴۳","display":"۱۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اول","display":"اَوَّلُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۴۳","display":"۱۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقرا","display":"يَقْرَاُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الماء","display":"الْمَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يمسح","display":"يَمْسَحُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"راسه","display":"رَاْسَهُ"},{"kind":"word","token":"و","displa