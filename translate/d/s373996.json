{"consensus_set_id":"s373996","translation_language":"fa","translation_source":{"hid":"373996"},"segments":[{"source_hadith_segment":"وَ اُخْرِجَ اِلَيْنَا خَاتَمُ اَبِي الْحَسَنِ عَلَيْهِ السَّلاَمُ فَكَانَ نَقْشُهُ  <quranic_text> « حَسْبِيَ اللّٰهُ » </quranic_text>   <footnote> [ التوبة ۱۲۹ ] </footnote>  وَ فِيهِ وَرْدَةٌ فِي اَسْفَلِ الْكِتَابِ وَ هِلاَلٌ فِي اَعْلاَهُ .","translation_segment":"ابراهیم بن عبد الحمید مثل این حدیث را نقل کرده و گوید: انگشتر حضرت ابو الحسن را برای ما آوردند نقش آن بود: (حسبی اللٰه). و در پایین نوشته شکل گلی و در بالای آن هلال نقش شده بود.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اخرج","display":"اُخْرِجَ"},{"kind":"word","token":"الينا","display":"اِلَيْنَا"},{"kind":"word","token":"خاتم","display":"خَاتَمُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"فكان","display":"فَكَانَ"},{"kind":"word","token":"نقشه","display":"نَقْشُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حسبي","display":"حَسْبِيَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۱۲۹","display":"۱۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"ورده","display":"وَرْدَةٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اسفل","display":"اَسْفَلِ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هلال","display":"هِلاَلٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اعلاه","display":"اَعْلاَهُ"}]}]}