{"consensus_set_id":"10247","translation_language":"fa","translation_source":{"hid":"411821"},"segments":[{"source_hadith_segment":"« اِنَّ لِلَّهِ عَزَّ وَ جَلَّ وُجُوهاً ،  خَلَقَهُمْ مِنْ خَلْقِهِ وَ اَرْضِهِ لِقَضَاءِ حَوَائِجِ اِخْوَانِهِمْ يَرَوْنَ الْحَمْدَ مَجْداً ،  وَ اللَّهُ عَزَّ وَ جَلَّ يُحِبُّ مَكَارِمَ الْاَخْلاَقِ ،  وَ كَانَ فِيمَا خَاطَبَ اللَّهُ تَعَالَي نَبِيَّهُ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اَنْ قَالَ لَهُ :  يَا مُحَمَّدُ  :   <quranic_text> « وَ اِنَّكَ لَعَليٰ خُلُقٍ عَظِيمٍ » </quranic_text> <footnote> [ القلم ۴ ] </footnote> قَالَ :  السَّخَاءُ وَ حُسْنُ الْخُلُقِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"وجوها","display":"وُجُوهاً"},{"kind":"word","token":"خلقهم","display":"خَلَقَهُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"خلقه","display":"خَلْقِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امشاهم","display":"اَمْشَاهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ارضه","display":"اَرْضِهِ"},{"kind":"word","token":"لقضاء","display":"لِقَضَاءِ"},{"kind":"word","token":"حوائج","display":"حَوَائِجِ"},{"kind":"word","token":"اخوانهم","display":"اِخْوَانِهِمْ"},{"kind":"word","token":"يرون","display":"يَرَوْنَ"},{"kind":"word","token":"الحمد","display":"الْحَمْدَ"},{"kind":"word","token":"مجدا","display":"مَجْداً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يحب","display":"يُحِبُّ"},{"kind":"word","token":"مكارم","display":"مَكَارِمَ"},{"kind":"word","token":"الاخلاق","display":"الْاَخ