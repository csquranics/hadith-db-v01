{"consensus_set_id":"s408036","translation_language":"fa","translation_source":{"hid":"408036"},"segments":[{"source_hadith_segment":"قَالَ لِي اَبُو جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ )  :  « لاَ تَقْرَاْ يَبْشُرَ اِنَّمَا الْبَشْرُ بَشْرُ الْاَدِيمِ » .  قَالَ :  فَصَلَّيْتُ بَعْدَ ذَلِكَ خَلْفَ الْحَسَنِ فَقَرَاَ  <quranic_text> « يُبَشِّرَ » </quranic_text>   <footnote> [ الكهف ۲ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تقرا","display":"تَقْرَاْ"},{"kind":"word","token":"يبشر","display":"يَبْشُرَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"البشر","display":"الْبَشْرُ"},{"kind":"word","token":"بشر","display":"بَشْرُ"},{"kind":"word","token":"الاديم","display":"الْاَدِيمِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فصليت","display":"فَصَلَّيْتُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"خلف","display":"خَلْفَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"فقرا","display":"فَقَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يبشر","display":"يُبَشِّرَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"}]}]}