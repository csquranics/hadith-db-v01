{"consensus_set_id":"s405773","translation_language":"fa","translation_source":{"hid":"405773"},"segments":[{"source_hadith_segment":"« وَ لِي بِاَخِي هَارُونَ اُسْوَةٌ اِذْ قَالَ لِاَخِيهِ :   <quranic_text> « اِبْنَ اُمَّ اِنَّ الْقَوْمَ اِسْتَضْعَفُونِي وَ كٰادُوا يَقْتُلُونَنِي » </quranic_text>   <footnote> [ الاعراف ۱۵۰ ] </footnote> فَاِنْ قُلْتُمْ لَمْ يَسْتَضْعِفُوهُ وَ لَمْ يُشْرِفُوا عَلَي قَتْلِهِ فَقَدْ كَفَرْتُمْ ،  وَ اِنْ قُلْتُمْ اِسْتَضْعَفُوهُ وَ اَشْرَفُوا عَلَي قَتْلِهِ ،  فَلِذَلِكَ سَكَتَ عَنْهُمْ ،  فَالْوَصِيُّ اَعْذَرُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"باخي","display":"بِاَخِي"},{"kind":"word","token":"هارون","display":"هَارُونَ"},{"kind":"word","token":"اسوه","display":"اُسْوَةٌ"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لاخيه","display":"لِاَخِيهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"ام","display":"اُمَّ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"القوم","display":"الْقَوْمَ"},{"kind":"word","token":"استضعفوني","display":"اِسْتَضْعَفُونِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كادوا","display":"كٰادُوا"},{"kind":"word","token":"يقتلونني","display":"يَقْتُلُونَنِي"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۱۵۰","display":"۱۵۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"قلتم","display":"قُلْتُمْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يستضعفوه","display":"يَسْتَضْعِفُوهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word"