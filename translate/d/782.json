{"consensus_set_id":"782","translation_language":"fa","translation_source":{"hid":"356004"},"segments":[{"source_hadith_segment":"كُنَّا عِنْدَ مُعَاوِيَةَ اَنَا وَ الْحَسَنُ وَ الْحُسَيْنُ وَ عَبْدُ","translation_segment":"و دیگر مرویست از سلیم بن قیس الهلالی که او","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سمعت","display":"سمعت"},{"kind":"word","token":"عبد","display":"عبد"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"بن","display":"بن"},{"kind":"word","token":"جعفر","display":"جعفر"},{"kind":"word","token":"الطيار","display":"الطيار"},{"kind":"word","token":"يقول","display":"يقول"},{"kind":"word","token":"كنا","display":"كُنَّا"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"معاويه","display":"مُعَاوِيَةَ"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عبد","display":"عَبْدُ"}]},{"source_hadith_segment":"اللَّهِ بْنُ عَبَّاسٍ وَ عُمَرُ بْنُ اَبِي سَلَمَةَ وَ اُسَامَةُ بْنُ زَيْدٍ فَذَكَرْنَا حَدِيثاً جَرَي بَيْنَهُ وَ بَيْنَ مُعَاوِيَةَ وَ اَنَّهُ قَالَ لِمُعَاوِيَةَ سَمِعْتُ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ يَقُولُ اَنَا  <quranic_text> « اَوْليٰ بِالْمُؤْمِنِينَ مِنْ اَنْفُسِهِمْ » </quranic_text>   <footnote> [ الاحزاب ۶ ] </footnote>  ثُمَّ اَخِي عَلِيٌّ عَلَيْهِ السَّلاَمُ  <quranic_text> « اَوْليٰ بِالْمُؤْمِنِينَ مِنْ اَنْفُسِهِمْ » </quranic_text>   <footnote> [ الاحزاب ۶ ] </footnote>  فَاِذَا اُسْتُشْهِدَ فَابْنِيَ الْحَسَنُ  <quranic_text> « اَوْليٰ بِالْمُؤْمِنِينَ مِنْ اَنْفُسِهِمْ » </quranic_text>   <footnote> [ الاحزاب ۶ ] </footnote>  ثُمَّ اِبْنِيَ الْحُسَيْنُ  <quranic_text> « اَوْليٰ بِالْمُؤْمِنِينَ مِنْ اَنْفُسِهِمْ » </quranic_text>   <footnote> [ الاحزاب ۶ ] </footnote>  فَاِذَا اُسْتُشْهِدَ فَابْنُهُ عَلِيُّ بْنُ الْحُسَيْنِ  <quranic_text> « اَوْليٰ بِالْمُؤْمِنِينَ مِنْ اَنْفُسِهِمْ » </quranic_text>   <footnote> [ الاحزاب ۶ ] </footnote>  وَ سَتُدْرِكُهُ يَا عَلِيُّ ثُمَّ اِبْنِي مُحَمَّدُ بْنُ عَلِيٍّ  <quranic_text> « اَوْليٰ بِالْمُؤْمِنِينَ مِنْ اَنْفُسِهِمْ » </quranic_text>   <footnote> [ الاحزاب ۶ ] </footnote>  وَ سَتُدْرِكُهُ يَا حُسَيْنُ ثُمَّ تُكَمِّلُهُ اِثْنَا عَشَرَ اِمَاماً تِسْعَةٌ مِنْ وُلْدِ الْحُسَيْنِ قَالَ عَبْدُ اللَّهِ ثُمَّ اِسْتَشْهَدْتُ الْحَسَنَ وَ الْحُسَيْنَ","translation_segment":"گفت: شنیدم از عبد اللٰه بن جعفر طیار که او گفت که: ما نزد معاویه بودیم من بودم و امام حسن و امام حسین و عبد اللٰه بن عباس و عمر بن أبی سلمه و زید بن اسامه پس ذکر میکردیم حدیثی را که جاری بود میان او و میان معاویه غاویه و اسامه بن زید می‌گفت که من شنیدم از رسول اللٰه (صلی الله علیه و آله) که میفرمودکه من اولی‌ام بمومنان از نفسهای ایشان، باز برادر من علی اولی است بمومنان از نفسهای ایشان، باز پسر من حسن اولی است بمومنان از نفسهای ایشان، باز پسر من حسین اولی است بمومنان از نفسهای ایشان، پس هر گاه که او شهادت یابد پس پسر او علی بن حسین اولی است بمومنان از نفسهای ایشان، و زود باشد که دریابی او را ای علی، و بعد از پسر من محمد بن علی اولی است بمومنان از نفسهای ایشان و زود باشد که دریابی او را ای حسین که تکمله دوازده امام نه نفر باشند از ولد حسین، عبد اللٰه گفت گواه گرفتم حسن و حسین و عبد اللٰه و عمر بن","segment_columns":[{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"عباس","display":"عَبَّاسٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمر","display":"عُمَرُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"سلمه","display":"سَلَمَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسامه","display":"اُسَامَةُ"},{"kind":"word"