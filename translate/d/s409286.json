{"consensus_set_id":"s409286","translation_language":"fa","translation_source":{"hid":"409286"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ ) عَنِ الْعَرْشِ وَ الْكُرْسِيِّ ،  فَقَالَ :","translation_segment":"","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الكرسي","display":"الْكُرْسِيِّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"}]},{"source_hadith_segment":"« اِنَّ لِلْعَرْشِ صِفَاتٍ كَثِيرَةً مُخْتَلِفَةً ،  لَهُ فِي كُلِّ سَبَبٍ وُضِعَ فِي الْقُرْانِ صِفَةً عَلَي حِدَةٍ ،  فَقَوْلُهُ :   <quranic_text> « رَبُّ الْعَرْشِ الْعَظِيمِ » </quranic_text>   <footnote> [ النمل ۲۶ ] </footnote>  يَقُولُ :  الْمُلْكِ الْعَظِيمِ ،  وَ قَوْلُهُ :   <quranic_text> « الرَّحْمٰنُ عَلَي الْعَرْشِ اِسْتَويٰ » </quranic_text>   <footnote> [ طه ۵ ] </footnote>  يَقُولُ :  عَلَي الْمُلْكِ اِحْتَوَي ،  وَ هَذَا مُلْكُ الْكَيْفُوفِيَّةِ فِي الْاَشْيَاءِ .  ثُمَّ الْعَرْشُ فِي الْوَصْلِ مُنْفَرِدٌ عَنِ الْكُرْسِيِّ ،  لِاَنَّهُمَا بَابَانِ مِنَ اَكْبَرِ اَبْوَابِ الْغُيُوبِ ،  وَ هُمَا جَمِيعاً غَيْبَانِ ،  وَ هُمَا فِي الْغَيْبِ مَقْرُونَانِ ،  لِاَنَّ الْكُرْسِيَّ هُوَ الْبَابُ الظَّاهِرُ مِنَ الْغَيْبِ الَّذِي مِنْهُ مَطْلَعُ الْبِدَعِ وَ مِنْهُ الْاَشْيَاءُ كُلُّهَا ،  وَ الْعَرْشُ هُوَ الْبَابُ الْبَاطِنُ الَّذِي يُوجَدُ فِيهِ عِلْمُ الْكَيْفِ ،  وَ الْكَوْنِ ،  وَ الْقَدَرِ ،  وَ الْحَدِّ وَ الْاَيْنِ ،  وَ الْمَشِيئَةِ ،  وَ صِفَةُ الْاِرَادَةِ ،  وَ عِلْمُ الْاَلْفَاظِ وَ الْحَرَكَاتِ وَ التَّرْكِ ،  وَ عِلْمِ الْعَوْدِ وَ الْبَدَاءِ ،  فَهُمَا فِي الْعِلْمِ بَابَانِ مَقْرُونَانِ ،  لِاَنَّ مُلْكَ الْعَرْشِ سِوَي مُلْكِ الْكُرْسِيِّ ،  وَ عِلْمَهُ اَغْيَبُ مِنْ عِلْمِ الْكُرْسِيِّ ،  فَمِنْ ذَلِكَ قَالَ :   <quranic_text> « رَبُّ الْعَرْشِ الْعَظِيمِ » </quranic_text>   <footnote> [ النمل ۲۶ ] </footnote>  اَيْ صِفَتُهُ اَعْظَمُ مِنْ صِفَةِ الْكُرْسِيِّ ،  وَ هُمَا فِي ذَلِكَ مَقْرُونَانِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"للعرش","display":"لِلْعَرْشِ"},{"kind":"word","token":"صفات","display":"صِفَاتٍ"},{"kind":"word","token":"كثيره","display":"كَثِيرَةً"},{"kind":"word","token":"مختلفه","display":"مُخْتَلِفَةً"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كل","display":"كُلِّ"},{"kind":"word","token":"سبب","display":"سَبَبٍ"},{"kind":"word","token":"وضع","display":"وُضِعَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"صفه","display":"صِفَةً"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"حده","display":"حِدَةٍ"},{"kind":"word","token":"فقوله","display":"فَقَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"رب","display":"رَبُّ"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النمل","display":"النمل"},{"kind":"word","token":"۲۶","display":"۲۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"الملك","display":"الْمُلْكِ"},{"kind":"word","token":"العظيم","display":"الْعَظِيمِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"