{"consensus_set_id":"50760","translation_language":"fa","translation_source":{"hid":"409516"},"segments":[{"source_hadith_segment":"« اِعْلَمُوا - يَا عِبَادَ اللَّهِ - اَنَّ الْمُؤْمِنَ مَنْ يَعْمَلُ الثَّلاَثَ مِنَ الثَّوَابِ :  اَمَّا الْخَيْرُ فَاِنَّ اللَّهَ يُثِيبُهُ بِعَمَلِهِ فِي دُنْيَاهُ ،  قَالَ اللَّهُ سُبْحَانَهُ لِاِبْرَاهِيمَ :   <quranic_text> « وَ اتَيْنٰاهُ اَجْرَهُ فِي الدُّنْيٰا وَ اِنَّهُ فِي الْاخِرَةِ لَمِنَ الصّٰالِحِينَ » </quranic_text>   <footnote> [ العنكبوت ۲۷ ] </footnote> فَمَنْ عَمِلَ لِلَّهِ تَعَالَي ،  اَعْطَاهُ اَجْرَهُ فِي الدُّنْيَا وَ الْاخِرَةِ ،  وَ كَفَاهُ الْمُهِمَّ فِيهِمَا »","translation_segment":"","segment_columns":[{"kind":"word","token":"اعلموا","display":"اِعْلَمُوا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"عباد","display":"عِبَادَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يعمل","display":"يَعْمَلُ"},{"kind":"word","token":"الثلاث","display":"الثَّلاَثَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الثواب","display":"الثَّوَابِ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الخير","display":"الْخَيْرُ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يثيبه","display":"يُثِيبُهُ"},{"kind":"word","token":"بعمله","display":"بِعَمَلِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"دنياه","display":"دُنْيَاهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"سبحانه","display":"سُبْحَانَهُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"لابراهيم","display":"لِاِبْرَاهِيمَ"},{"kind":"t