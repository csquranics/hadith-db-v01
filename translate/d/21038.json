{"consensus_set_id":"21038","translation_language":"fa","translation_source":{"hid":"113970"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنِ اِمْرَاَةٍ حُرَّةٍ تَكُونُ تَحْتَ الْمَمْلُوكِ فَتَشْتَرِيهِ هَلْ يَبْطُلُ نِكَاحُهُ قَالَ نَعَمْ لِاَنَّهُ عَبْدٌ مَمْلُوكٌ  <quranic_text> « لاٰ يَقْدِرُ عَليٰ شَيْءٍ » </quranic_text>   <footnote> [ النحل ۷۵ ] </footnote>   .","translation_segment":"سعید بن یسار گوید: به امام صادق علیه السلام گفتم: اگر زن آزادی با برده‌ای ازدواج کند، و بعد او را از صاحبش بخرد، آیا پیوند ازدواجشان باطل می‌شود؟ فرمود: آری، زیرا شوهرش برده تحت تصرفی است که نسبت به هیچ امری اختیار ندارد.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"امراه","display":"اِمْرَاَةٍ"},{"kind":"word","token":"حره","display":"حُرَّةٍ"},{"kind":"word","token":"تكون","display":"تَكُونُ"},{"kind":"word","token":"تحت","display":"تَحْتَ"},{"kind":"word","token":"المملوك","display":"الْمَمْلُوكِ"},{"kind":"word","token":"فتشتريه","display":"فَتَشْتَرِيهِ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"يبطل","display":"يَبْطُلُ"},{"kind":"word","token":"نكاحه","display":"نِكَاحُهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"لانه","display":"لِاَنَّهُ"},{"kind":"word","token":"عبد","display":"عَبْدٌ"},{"kind":"word","token":"مملوك","display":"مَمْلُوكٌ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يقدر","display":"يَقْدِرُ"},{"kind":"word","token":"علي","display":"عَليٰ"},{