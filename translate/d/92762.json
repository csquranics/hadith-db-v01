"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"خمسه","display":"خَمْسَةِ"},{"kind":"word","token":"اسهم","display":"اَسْهُمٍ"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"اصاب","display":"اَصَابَ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةً"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"للابنه","display":"لِلاِبْنَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اصاب","display":"اَصَابَ"},{"kind":"word","token":"سهمين","display":"سَهْمَيْنِ"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"للابوين","display":"لِلْاَبَوَيْنِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قرات","display":"قَرَاْتُ"},{"kind":"word","token":"فيها","display":"فِيهَا"}]},{"source_hadith_segment":"« رَجُلٌ تَرَكَ اِبْنَتَهُ وَ اَبَاهُ لِلْبِنْتِ النِّصْفُ وَ لِلْاَبِ سَهْمٌ يُقْسَمُ الْمَالُ عَلَي اَرْبَعَةِ اَسْهُمٍ فَمَا اَصَابَ ثَلاَثَةً فَهُوَ لِلاِبْنَةِ وَ مَا اَصَابَ سَهْماً فَلِلْاَبِ وَ اِنْ تَرَكَ اَبَوَيْنِ وَ اِبْناً وَ اِبْنَةً اَوْ بَنِينَ وَ بَنَاتٍ فَلِلْاَبَوَيْنِ السُّدُسَانِ وَ مَا بَقِيَ فَلِلْبَنِينَ وَ الْبَنَاتِ  <quranic_text> « لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>  فَاِنْ تَرَكَ اِبْناً وَ اَبَوَيْنِ فَلِلْاَبَوَيْنِ السُّدُسَانِ وَ مَا بَقِيَ فَلِلاِبْنِ فَاِنْ تَرَكَ اُمّاً وَ اِبْناً فَلِلْاُمِّ السُّدُسُ وَ مَا بَقِيَ فَلِلاِبْنِ فَاِنْ تَرَكَ اَباً وَ اِبْناً فَلِلْاَبِ السُّدُسُ وَ مَا بَقِيَ فَلِلاِبْنِ فَاِنْ تَرَكَ اُمّاً وَ بَنِينَ وَ بَنَاتٍ فَلِلْاُمِّ السُّدُسُ وَ مَا بَقِيَ فَلِلْبَنِينَ وَ الْبَنَاتِ  <quranic_text> « لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>  فَاِنْ تَرَكَ اَبَاهُ وَ بَنِينَ وَ بَنَاتٍ فَلِلْاَبِ السُّدُسُ وَ مَا بَقِيَ فَلِلْبَنِينَ وَ الْبَنَاتِ  <quranic_text> « لِلذَّكَرِ مِثْلُ حَظِّ الْاُنْثَيَيْنِ » </quranic_text>   <footnote> [ النساء ۱۱ ] </footnote>   .","translation_segment":"بر این گونه که مال به پنج سهم قسمت می‌شود، پس آنچه بسه سهم اصابت کند متعلق بدختر، و آنچه بدو سهم اصابت کند متعلق بوالدین است. گفت: و در آن صحیفه خواندم که چون مردی دخترش و پدرش را بجا گذارد، نصف مال متعلق بدختر، و یک سهم متعلق بپدر است، بر این گونه که مال بچهار سهم قسمت می‌شود، پس آنچه به سه بخش اصابت کند، مربوط‍‌ بدختر، و آنچه به یک بخش اصابت کند مربوط‍‌ به پدر است. شرح: «این قسمت اخیر در کافی و تهذیب ذکر نشده چون مبنی بر آنچه در باره مادر گذشت میباشد و آن را لازم بذکر ندیده‌اند. و از اینجا به بعد کلام مصنف است». اگر متوفی والدین و پسری و دختری، یا پسران و دخترانی را بجای گذارد، دو سدس از مال متعلق بوالدین، و بقیه آن مخصوص پسران و دخترانست که بقاعده «للذکر مثل‌ حظ‍‌ الأنثیین‌» میان ایشان قسمت می‌شود، و اگر پسری و والدین را بجا گذارد، دو سدس مال متعلق بوالدین، و بقیه آن مخصوص پسر است، و اگر مادر و پسری را بجا گذارد، سهم مادر سدس و بقیه مال از آن پسر است، و اگر پدر و پسری را بجا گذارد سهم پدر سدس و بقیه مال متعلق به پسر است و اگر مادر و پسران و دخترانی را بجا گذارد سهم مادر سدس و بقیه مال مخصوص پسران و دخترانست، که بپیروی از قاعده «للذکر مثل‌ حظ‍‌ الأنثیین‌» میان ایشان قسمت می‌شود، و اگر پدر و پسران و دخترانی را بجا گذارد سهم پدر سدس است، و بقیه مال بپسران و دختران اختصاص دارد، که بهمان قاعده میان ایشان قسمت می‌شود.","segment_columns":[{"kind":"word","token":"رجل","display":"رَجُلٌ"},{"kind":"word","token":"ترك","display":"تَرَكَ"},{"kind":"word","token":"ابنته","display":"اِبْنَتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اباه","display":"اَبَاهُ"},{"kind":"word","token":"للبنت","display":"لِلْبِنْتِ"},{"kind":"word","token":"النصف","display":"النِّصْفُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"للاب","display":"لِلْاَبِ"},{"kind":"word","token":"سهم","display":"سَهْمٌ"},{"kind":"word","token":"يقسم","display":"يُقْسَمُ"},{"kind":"word","token":"المال","display":"الْمَالُ"},{"kind":"word","token":"علي",