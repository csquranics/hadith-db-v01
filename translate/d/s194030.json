{"consensus_set_id":"s194030","translation_language":"fa","translation_source":{"hid":"194030"},"segments":[{"source_hadith_segment":"فِي حَدِيثِ النَّصِّ عَلَي الرِّضَا عَلَيْهِ السَّلاَمُ اَنَّهُ قَالَ :  وَ اِنْ سُئِلْتَ عَنِ الشَّهَادَةِ فَاَدِّهَا فَاِنَّ اللَّهَ يَقُولُ  <quranic_text> « اِنَّ اللّٰهَ يَاْمُرُكُمْ اَنْ تُؤَدُّوا الْاَمٰانٰاتِ اِليٰ اَهْلِهٰا » </quranic_text>   <footnote> [ النساء ۵۸ ] </footnote>   ،  وَ قَالَ  <quranic_text> « وَ مَنْ اَظْلَمُ مِمَّنْ كَتَمَ شَهٰادَةً عِنْدَهُ مِنَ اللّٰهِ » </quranic_text>   <footnote> [ البقرة ۱۴۰ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"حديث","display":"حَدِيثِ"},{"kind":"word","token":"النص","display":"النَّصِّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"سئلت","display":"سُئِلْتَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الشهاده","display":"الشَّهَادَةِ"},{"kind":"word","token":"فادها","display":"فَاَدِّهَا"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"يامركم","display":"يَاْمُرُكُمْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تؤدوا","display":"تُؤَدُّوا"},{"kind":"word","token":"الامانات","display":"الْاَمٰانٰاتِ"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"اهلها","display":"اَهْلِهٰا"},