{"consensus_set_id":"12874","translation_language":"fa","translation_source":{"hid":"406009"},"segments":[{"source_hadith_segment":"« يَا عَلِيُّ  ،  هَلْ نَزَلَ فِيَّ شَيْءٌ مُنْذُ فَارَقْتُ رَسُولَ اللَّهِ ؟  قَالَ :  لاَ ،  وَ لَكِنْ اَبَي اللَّهُ اَنْ يُبَلِّغَ عَنْ مُحَمَّدٍ اِلاَّ رَجُلٌ مِنْهُ .  فَوَافَي الْمَوْسِمَ ،  فَبَلَّغَ عَنِ اللَّهِ وَ عَنْ رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) بِعَرَفَةَ وَ الْمُزْدَلِفَةِ ،  وَ يَوْمَ النَّحْرِ عِنْدَ الْجِمَارِ ،  وَ فِي اَيَّامِ التَّشْرِيقِ كُلِّهَا يُنَادِي  <quranic_text> « بَرٰاءَةٌ مِنَ اللّٰهِ وَ رَسُولِهِ اِلَي الَّذِينَ عٰاهَدْتُمْ مِنَ الْمُشْرِكِينَ فَسِيحُوا فِي الْاَرْضِ اَرْبَعَةَ اَشْهُرٍ » </quranic_text>   <footnote> [ التوبة ۱ ] </footnote> وَ لاَ يَطُوفَنَّ بِالْبَيْتِ عُرْيَانٌ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"ابو","display":"ابو"},{"kind":"word","token":"بكر","display":"بكر"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"في","display":"فِيَّ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"منذ","display":"مُنْذُ"},{"kind":"word","token":"فارقت","display":"فَارَقْتُ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللّٰه"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلم"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لَكِن