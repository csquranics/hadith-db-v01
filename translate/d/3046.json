بْيَضَّتْ ،  ثُمَّ نُفِخَ عَلَيْهَا اَلْفَ عَامٍ حَتَّي اِحْمَرَّتْ ،  ثُمَّ نُفِخَ عَلَيْهَا اَلْفَ عَامٍ حَتَّي اِسْوَدَّتْ ،  فَهِيَ سَوْدَاءُ مُظْلِمَةٌ ،  لَوْ اَنَّ قَطْرَةً مِنَ الضَّرِيعِ قَطَرَتْ فِي شَرَابِ اَهْلِ الدُّنْيَا لَمَاتَ اَهْلُهَا مِنْ نَتْنِهَا ،  وَ لَوْ اَنَّ حَلْقَةً وَاحِدَةً مِنَ السِّلْسِلَةِ الَّتِي طُولُهَا سَبْعُونَ ذِرَاعاً وُضِعَتْ عَلَي الدُّنْيَا لَذَابَتْ مِنْ حَرِّهَا ،  وَ لَوْ اَنَّ سِرْبَالاً مِنْ سَرَابِيلِ اَهْلِ النَّارِ عُلِّقَ بَيْنَ السَّمَاءِ وَ الْاَرْضِ لَمَاتَ اَهْلُ الْاَرْضِ مِنْ رِيحِهِ وَ وَهَجِهِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"استعد","display":"اِسْتَعِدَّ"},{"kind":"word","token":"للحياه","display":"لِلْحَيَاةِ"},{"kind":"word","token":"الطويله","display":"الطَّوِيلَةِ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"جبرئيل","display":"جَبْرَئِيلَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"وهو","display":"وهو"},{"kind":"word","token":"كئيب","display":"كئيب"},{"kind":"word","token":"حزين","display":"حزين"},{"kind":"word","token":"متغير","display":"متغير"},{"kind":"word","token":"اللون","display":"اللون"},{"kind":"word","token":"جاء","display":"جَاءَ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"النبي","display":"النبي"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"يا","displa