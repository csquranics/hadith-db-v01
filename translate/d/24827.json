{"consensus_set_id":"24827","translation_language":"fa","translation_source":{"hid":"297812"},"segments":[{"source_hadith_segment":"قَالَ ( تَبَارَكَ وَ تَعَالَي ) :   <quranic_text> « كُلَّ يَوْمٍ هُوَ فِي شَاْنٍ » </quranic_text>   <footnote> [ الرحمن ۲۹ ] </footnote>  فَاِنَّ مِنْ شَاْنِهِ اَنْ يَغْفِرَ ذَنْباً ،  وَ يُفَرِّجَ كَرْباً ،  وَ يَرْفَعَ قَوْماً وَ يَضَعَ اخَرِينَ .","translation_segment":"با همان سند پیامبر گرامی درباره این سخن خداوند پاک و والا که فرموده است: «او هر روز در کاری است.» [رحمان: آیه ۲۹] فرمودند: و از کار او این است که گناهی را بیامرزد، نگرانی‌ای را برطرف کند و گروهی را بالا ببرد و گروهی را به زمین بزند.","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابائه","display":"ابَائِهِ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ان","display":"انّ"},{"kind":"word","token":"النبي","display":"النَّبِيَّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"يوم","display":"يَوْمٍ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"شان","display":"شَاْنٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرحمن","display":"الرحمن"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شانه"