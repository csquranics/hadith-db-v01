{"consensus_set_id":"32130","translation_language":"fa","translation_source":{"hid":"106884"},"segments":[{"source_hadith_segment":"قُلْتُ لَهُ  <quranic_text> « اَلَّذِينَ يَجْتَنِبُونَ كَبٰائِرَ الْاِثْمِ وَ الْفَوٰاحِشَ اِلاَّ اللَّمَمَ » </quranic_text>   <footnote> [ النجم ۳۲ ] </footnote>  قَالَ الْهَنَةُ بَعْدَ الْهَنَةِ اَيِ الذَّنْبُ بَعْدَ الذَّنْبِ يُلِمُّ بِهِ الْعَبْدُ .","translation_segment":"و نیز محمد بن مسلم از یکی از دو امام باقر و یا صادق علیهما السلام حدیث کند که فرموده: بآن حضرت عرضکردم: (در باره تفسیر لمم در این آیه) فرمود: آن گناه پس از گناه است که بنده دست بدان زند.","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"اَلَّذِينَ"},{"kind":"word","token":"يجتنبون","display":"يَجْتَنِبُونَ"},{"kind":"word","token":"كبائر","display":"كَبٰائِرَ"},{"kind":"word","token":"الاثم","display":"الْاِثْمِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الفواحش","display":"الْفَوٰاحِشَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"اللمم","display":"اللَّمَمَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النجم","display":"النجم"},{"kind":"word","token":"۳۲","display":"۳۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الهنه","display":"الْهَنَةُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الهنه","display":"الْهَنَةِ"},{"kind":"word","token":"اي","display":"اَيِ"},{"kind":"word","token":"الذنب","display":"الذَّنْبُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الذنب","display":"الذَّنْبِ"},{"kind":"word","token":"يلم","display":"يُلِمُّ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"العبد","display":"الْعَبْدُ"}]}]}