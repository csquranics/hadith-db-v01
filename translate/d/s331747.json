{"consensus_set_id":"s331747","translation_language":"fa","translation_source":{"hid":"331747"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي جَعْفَرٍ مُحَمَّدِ بْنِ عَلِيٍّ قَوْلُ اللَّهِ تَعَالَي :   <quranic_text> « وَ عَلاٰمٰاتٍ وَ بِالنَّجْمِ هُمْ يَهْتَدُونَ » </quranic_text>   <footnote> [ النحل ۱۶ ] </footnote>  قَالَ :  النَّجْمُ :  مُحَمَّدٌ [ كَذَا ] وَ الْعَلاَمَاتُ الْاَوْصِيَاءُ عَلَيْهِمُ السَّلاَمُ  .","translation_segment":"عن أبان بن تغلب قال: قلت لأبی جعفر محمد بن علی قول الله تعالی: (و علامات و بالنجم هم یهتدون) قال: النجم: محمد و (العلامات) الأوصیاء ع. ابان بن تغلب گفت: به ابو جعفر محمد بن علی درباره آیه: «و علامات و بالنجم هم یهتدون» گفتم، گفت: ستاره محمد است و نشانه‌ها اوصیاء هستند.","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"محمد","display":"مُحَمَّدِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علامات","display":"عَلاٰمٰاتٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بالنجم","display":"بِالنَّجْمِ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يهتدون","display":"يَهْتَدُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النحل","display":"النحل"},{"kind":"word","token":"۱۶","display":"۱۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"النجم","display":"النَّجْمُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٌ"},{"kind":"word","token":"كذا","display":"كَذَا"},{"kind":"word","token":"و",