{"consensus_set_id":"s49252","translation_language":"fa","translation_source":{"hid":"49252"},"segments":[{"source_hadith_segment":"<quranic_text> « اِنّٰا كَفَيْنٰاكَ الْمُسْتَهْزِئِينَ » </quranic_text>   <footnote> [ الحجر ۹۵ ] </footnote>  مَا حَاصِلُهُ :  اَنَّهُمْ كَانُوا خَمْسَةً فَدَعَا عَلَيْهِمُ النَّبِيَّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ سَلَّمَ فَاسْتُجِيبَ دُعَاؤُهُ وَ هَلَكُوا وَ قِصَّتُهُمْ طَوِيلَةٌ .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"كفيناك","display":"كَفَيْنٰاكَ"},{"kind":"word","token":"المستهزئين","display":"الْمُسْتَهْزِئِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحجر","display":"الحجر"},{"kind":"word","token":"۹۵","display":"۹۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"حاصله","display":"حَاصِلُهُ"},{"kind":"word","token":"انهم","display":"اَنَّهُمْ"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"خمسه","display":"خَمْسَةً"},{"kind":"word","token":"فدعا","display":"فَدَعَا"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"النبي","display":"النَّبِيَّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلم","display":"سَلَّمَ"},{"kind":"word","token":"فاستجيب","display":"فَاسْتُجِيبَ"},{"kind":"word","token":"دعاؤه","display":"دُعَاؤُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هلكوا","display":"هَلَكُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قصتهم","display":"قِصَّتُهُمْ"},{"kind":"word","token":"