{"consensus_set_id":"22880","translation_language":"fa","translation_source":{"hid":"402125"},"segments":[{"source_hadith_segment":"« اِذَا اَمَّ الرَّجُلُ الْقَوْمَ ،  جَاءَ شَيْطَانٌ اِلَي الشَّيْطَانِ الَّذِي هُوَ قَرِيبٌ اِلَي الْاِمَامِ ،  فَيَقُولُ :  هَلْ ذَكَرَ اللَّهَ ؟  يَعْنِي هَلْ قَرَاَ  <quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote> فَاِنْ قَالَ :  نَعَمْ ،  هَرَبَ مِنْهُ ،  وَ اِنْ قَالَ :  لاَ ،  رَكِبَ عُنُقَ الْاِمَامِ ،  وَ دَلَّي رِجْلَيْهِ فِي صَدْرِهِ ،  فَلَمْ يَزَلِ الشَّيْطَانُ اِمَامَ الْقَوْمِ حَتَّي يَفْرُغُوا مِنْ صَلاَتِهِمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"ام","display":"اَمَّ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"القوم","display":"الْقَوْمَ"},{"kind":"word","token":"جاء","display":"جَاءَ"},{"kind":"word","token":"شيطان","display":"شَيْطَانٌ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الشيطان","display":"الشَّيْطَانِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قريب","display":"قَرِيبٌ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الامام","display":"الْاِمَامِ"},{"kind":"word","token":"فيقول","display":"فَيَقُولُ"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"ذكر","display":"ذَكَرَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_clo