{"consensus_set_id":"17295","translation_language":"fa","translation_source":{"hid":"407286"},"segments":[{"source_hadith_segment":"« اِتَّقُوا اَللَّهَ ،  وَ عَلَيْكُمْ بِالطَّاعَةِ لِاَئِمَّتِكُمْ ،  قُولُوا مَا يَقُولُونَ ،  وَ اُصْمُتُوا عَمَّا صَمَتُوا ،  فَاِنَّكُمْ فِي سُلْطَانِ مَنْ قَالَ اللَّهُ تَعَالَي :   <quranic_text> « وَ اِنْ كٰانَ مَكْرُهُمْ لِتَزُولَ مِنْهُ الْجِبٰالُ » </quranic_text>   <footnote> [ ابراهيم ۴۶ ] </footnote>  - يَعْنِي بِذَلِكَ وُلْدَ الْعَبَّاسِ - فَاتَّقُوا اللَّهَ فَاِنَّكُمْ فِي هُدْنَةٍ ،  صَلُّوا فِي عَشَائِرِهِمْ ،  وَ اِشْهَدُوا جَنَائِزَهُمْ ،  وَ اَدُّوا الْاَمَانَةَ اِلَيْهِمْ ،  وَ عَلَيْكُمْ بِحَجِّ هَذَا الْبَيْتِ فَاَدْمِنُوهُ ،  فَاِنَّ فِي اِدْمَانِكُمُ الْحَجَّ دَفْعَ مَكَارِهِ الدُّنْيَا عَنْكُمْ وَ اَهْوَالِ يَوْمِ الْقِيَامَةِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"سمعت","display":"سمعت"},{"kind":"word","token":"ابا","display":"أبا"},{"kind":"word","token":"عبدالله","display":"عبدالله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السلام"},{"kind":"word","token":"يقول","display":"يقول"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"الله","display":"اَللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عليكم","display":"عَلَيْكُمْ"},{"kind":"word","token":"بالطاعه","display":"بِالطَّاعَةِ"},{"kind":"word","token":"لائمتكم","display":"لِاَئِمَّتِكُمْ"},{"kind":"word","token":"قولوا","display":"قُولُوا"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اصمتوا","display":"اُصْمُتُوا"},{"kind":"word","token":"عما","display":"عَمَّا"},{"kind":"word","token":"صمتوا","display":"صَمَتُوا"},{"kind":"word","token":"فانكم","display":"فَاِنَّكُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"سلطان","display":"سُلْطَانِ"},{"kind":"word","token":"من","d