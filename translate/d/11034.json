{"consensus_set_id":"11034","translation_language":"fa","translation_source":{"hid":"118816"},"segments":[{"source_hadith_segment":"قُلْتُ لَهُ قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « لَاَقْعُدَنَّ لَهُمْ صِرٰاطَكَ الْمُسْتَقِيمَ ثُمَّ لَاتِيَنَّهُمْ مِنْ بَيْنِ اَيْدِيهِمْ وَ مِنْ خَلْفِهِمْ وَ عَنْ اَيْمٰانِهِمْ وَ عَنْ شَمٰائِلِهِمْ وَ لاٰ تَجِدُ اَكْثَرَهُمْ شٰاكِرِينَ » </quranic_text>   <footnote> [ الاعراف ۱۶ ] </footnote>  قَالَ فَقَالَ اَبُو جَعْفَرٍ عَلَيْهِ السَّلاَمُ يَا زُرَارَةُ اِنَّهُ اِنَّمَا صَمَدَ لَكَ وَ لِاَصْحَابِكَ فَاَمَّا الْاخَرُونَ فَقَدْ فَرَغَ مِنْهُمْ .","translation_segment":"زراره می‌گوید: از امام باقر علیه السلام پیرامون آیه: «…لأقعدن‌ لهم‌ صرٰاطک‌ المستقیم‌ *`ثم‌ لآتینهم‌ من‌ بین‌ أیدیهم‌ و من‌ خلفهم‌ و عن‌ أیمٰانهم‌ و عن‌ شمٰائلهم‌ و لاٰ تجد أکثرهم‌ شٰاکرین‌» پرسش کردم و امام علیه السلام فرمود: همانا شیطان قصد تو و یاران تو را دارد و از کار دیگران فارغ شده است.","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لاقعدن","display":"لَاَقْعُدَنَّ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"صراطك","display":"صِرٰاطَكَ"},{"kind":"word","token":"المستقيم","display":"الْمُسْتَقِيمَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"لاتينهم","display":"لَاتِيَنَّهُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بين","display":"بَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word"