{"consensus_set_id":"41587","translation_language":"fa","translation_source":{"hid":"351653"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي  <quranic_text> « قُتِلَ اَصْحٰابُ الْاُخْدُودِ » </quranic_text>   <footnote> [ البروج ۴ ] </footnote>  قَالَ كَانَ سَبَبُهُمْ","translation_segment":"در تفسیر علی بن ابراهیم در تفسیر آیه «قتل‌ أصحٰاب‌ الأخدود» آمده است:","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اليوم","display":"الْيَوْمِ"},{"kind":"word","token":"الموعود","display":"الْمَوْعُودِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البروج۲","display":"البروج۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"يوم","display":"يَوْمِ"},{"kind":"word","token":"القيامه","display":"الْقِيَامَةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شاهد","display":"شٰاهِدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مشهود","display":"مَشْهُودٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البروج۳","display":"البروج۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الشاهد","display":"الشَّاهِدُ"},{"kind":"word","token":"يوم","display":"يَوْمُ"},{"kind":"word","token":"الجمعه","display":"الْجُمُعَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قتل","display":"قُتِلَ"},{"kind":"word","token":"اصحاب","display":"اَصْحٰابُ"},{"kind":"word","token":"الاخدود","display":"الْاُخْدُودِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البروج","display":"البروج"},{"kind":"word","token":"۴","display":"۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"سببهم","display":"سَبَبُهُمْ"}]},{"source_hadith_segment":"اَنَّ الَّذِي هَيَّجَ الْحَبَشَةَ عَلَي غَزْوَةِ الْيَمَنِ ذَانُوسُ وَ هُوَ اخِرُ مَلِكٍ مِنْ مُلُوكِ حِمْيَرٍ تَهَوَّدَ وَ اِجْتَمَعَتْ مَعَهُ حِمْيَرٌ عَلَي الْيَهُودِيَّةِ وَ سَمَّي نَفْسَهُ يُوسُفَ ثُمَّ اُخْبِرَ اَنَّ بِنَجْرَانَ بَقَايَا قَوْمٍ عَلَي دِينِ النَّصْرَانِيَّةِ وَ كَانُوا عَلَي دِينِ عِيسَي عَلَيْهِ السَّلاَمُ وَ عَلَي حُكْمِ الْاِنْجِيلِ وَ رَاْسُ ذَلِكَ الدِّينِ عَبْدُ اللَّهِ بْنُ يَاسٍ وَ حَمَلَهُ اَهْلُ دِينِهِ عَلَي اَنْ يَسِيرَ اِلَيْهِمْ وَ يَحْمِلَهُمْ عَلَي الْيَهُودِيَّةِ وَ يُدْخِلَهُمْ فِيهَا .  فَسَارَ حَتَّي قَدِمَ نَجْرَانَ فَجَمَعَ مَا كَانَ بِهَا عَلَي دِينِ النَّصْرَانِيَّةِ ثُمَّ عَرَضَ عَلَيْهِمْ دِينَ الْيَهُودِيَّةِ وَ الدُّخُولِ فِيهَا فَاَبَوْا عَلَيْهِ فَجَادَلَهُمْ وَ عَرَضَ عَلَيْهِمْ وَ عَلَي الْحَرَسِ كُلِّهِ فَاَبَوْا عَلَيْهِ وَ اِمْتَنَعُوا مِنَ الْيَهُودِيَّةِ وَ الدُّخُولِ فِيهَا وَ اِخْتَارُوا الْقَتْلَ فَخَدَّ لَهُمْ اُخْدُوداً وَ جَمَعَ فِيهِ الْحَطَبَ وَ اَشْعَلَ فِيهِ النَّارَ فَمِنْهُمْ مَنْ اَحْرَقَ بِالنَّارِ وَ مِنْهُمْ مَنْ قَتَلَ بِالسَّيْفِ وَ مَثَّلَ بِهِمْ كُلَّ مُثْلَةٍ فَبَلَغَ عَدَدُ مَنْ قَتَلَ وَ اَحْرَقَ بِالنَّارِ عِشْرِينَ اَلْفَ اَلْفِ رَجُلٍ .","translation_segment":"یکی از پادشاهان حمیر «ذونواس» نام داشت و خود را یوسف نام نهاده بود. او به دین یهود بود و با هوادارانش به سوی مردم نجران که مسیحی بودند حمله‌ور شد. مردم نجران از پادشاه مسیحی خود که عبد الله بن بریا نام داشت پیروی می‌کردند. ذو نواس، نجران را تصاحب کرد و آنگاه به مسیحیان گفت: یا به دین یهود درآیید و یا در آتش خواهید سوخت. مسیحیان سوختن در آتش را برگزیدند. ذو نواس دستور داد که حفره‌هایی در زمین حفر کنند و هیزم‌های بسیاری را در آنها بریزند و آتش بزرگی را بر افروزند. در یک روز بیست هزار نفر سوزانده شدند و گروهی نیز تکه‌تکه شدند.","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"هيج","display":"هَيَّجَ"},{"kind":"word","token":"الحبشه","display":"الْحَبَشَةَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"غزوه","display":"غَزْوَةِ"},{"kind":"word","token":"اليمن","display":"الْيَمَنِ"},{"kind":"word","token":"ذانوس","display":"ذَانُوسُ"},{"kind":"word","token":"نواس","display":"نُوَاسٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"اخر","display":"اخِرُ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"ملك","display":"مَلِكٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ملوك","display":"مُلُوكِ"},{"kind":"word","token":"حمير","display":"حِمْيَرٍ"},{"kind":"word","token":"تهود","display":"تَهَوَّدَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اجتمعت","display":"اِجْتَمَعَتْ"},{"kind":"word","token":"معه","display":"مَعَهُ"},{"kind":"word","token":"حمير","display":"حِمْيَرٌ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اليهوديه","display":"الْيَهُودِيَّةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سمي","display":"سَمَّي"},{"kind":"word","token":"نفسه","display":"نَفْسَهُ"},{"kind":"word","token":"يوسف","display":"يُوسُفَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اقام","display":"اَقَامَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"حينا","display":"حِيناً"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الدهر","display":"الدَّهْرِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"اخبر","display":"اُخْبِرَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","tok