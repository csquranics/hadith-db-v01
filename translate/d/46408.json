{"consensus_set_id":"46408","translation_language":"fa","translation_source":{"hid":"112230"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « قُوا اَنْفُسَكُمْ وَ اَهْلِيكُمْ نٰاراً » </quranic_text>   <footnote> [ التحريم ۶ ] </footnote>  كَيْفَ نَقِي اَهْلَنَا قَالَ تَاْمُرُونَهُمْ وَ تَنْهَوْنَهُمْ .","translation_segment":"ابو بصیر گوید: از امام صادق علیه السلام در مورد آیه‌ای که می‌فرماید: «خود و خانواده‌تان را از آتش حفظ‍‌ کنید» پرسیدم که چگونه خانواده‌مان را حفظ‍‌ کنیم‌؟ فرمود: آنها را امر (به معروف) و نهی (از منکر) کنید.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قوا","display":"قُوا"},{"kind":"word","token":"انفسكم","display":"اَنْفُسَكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اهليكم","display":"اَهْلِيكُمْ"},{"kind":"word","token":"نارا","display":"نٰاراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التحريم","display":"التحريم"},{"kind":"word","token":"۶","display":"۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"نقي","display":"نَقِي"},{"kind":"word","token":"اهلنا","display":"اَهْلَنَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"تامرونهم","display":"تَاْمُرُونَهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تنهونهم","display":"تَنْهَوْنَهُمْ"}]}]}