{"consensus_set_id":"57060","translation_language":"fa","translation_source":{"hid":"356472"},"segments":[{"source_hadith_segment":"قَوْلُهُ تَعَالَي  <quranic_text> « وَ اِنَّ الَّذِينَ لاٰ يُؤْمِنُونَ بِالْاخِرَةِ عَنِ الصِّرٰاطِ لَنٰاكِبُونَ » </quranic_text>   <footnote> [ المؤمنون ۷۴ ] </footnote>  عَنْ عَلِيٍّ عَلَيْهِ السَّلاَمُ قَالَ نَاكِبُونَ عَنْ وَلاَيَتِنَا .","translation_segment":"علی (علیه السلام) در باره آیه: «و إن‌ الذین‌ لاٰ یومنون‌ بالآخره‌ عن‌ الصرٰاط‍‌ لنٰاکبون‌» -می‌فرماید: مقصود، منحرفان از ولایت ما هستند.","segment_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يؤمنون","display":"يُؤْمِنُونَ"},{"kind":"word","token":"بالاخره","display":"بِالْاخِرَةِ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الصراط","display":"الصِّرٰاطِ"},{"kind":"word","token":"لناكبون","display":"لَنٰاكِبُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"kind":"word","token":"۷۴","display":"۷۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ناكبون","display":"نَاكِبُونَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ولايتنا","display":"وَلاَيَتِنَا"}]}]}