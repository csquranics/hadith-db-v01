{"consensus_set_id":"s409101","translation_language":"fa","translation_source":{"hid":"409101"},"segments":[{"source_hadith_segment":"« خَطَبَ اَمِيرُ الْمُؤْمِنِينَ عَلِيُّ بْنُ اَبِي طَالِبٍ ( صَلَوَاتُ اللَّهِ عَلَيْهِ ) بِالْكُوفَةِ ،  بَعْدَ مُنْصَرَفِهِ مِنَ النَّهْرَوَانِ ،  وَ بَلَغَهُ اَنَّ مُعَاوِيَةَ يَسُبُّهُ ،  وَ يَعِيبُهُ ،  وَ يَقْتُلُ اَصْحَابَهُ ،  فَقَامَ خَطِيباً - وَ ذَكَرَ الْخُطْبَةَ ،  اِلَي اَنْ قَالَ فِيهَا ( عَلَيْهِ السَّلاَمُ ) - وَ اَنَا الصِّهْرُ ،  يَقُولُ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ هُوَ الَّذِي خَلَقَ مِنَ الْمٰاءِ بَشَراً فَجَعَلَهُ نَسَباً وَ صِهْراً » </quranic_text>   <footnote> [ الفرقان ۵۴ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"خطب","display":"خَطَبَ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"بالكوفه","display":"بِالْكُوفَةِ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"منصرفه","display":"مُنْصَرَفِهِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"النهروان","display":"النَّهْرَوَانِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بلغه","display":"بَلَغَهُ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"معاويه","display":"مُعَاوِيَةَ"},{"kind":"word","token":"يسبه","display":"يَسُبُّهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يعيبه","display":"يَعِيبُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يقتل","display":"يَقْتُلُ"},{"kind":"word","token":"اصحابه","display":"اَصْحَ