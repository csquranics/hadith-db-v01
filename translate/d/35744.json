ضَبُ لِغَضَبِكِ وَ يَرْضَي","translation_segment":"هر کس که‌ای فاطمه تو ازو راضی باشی حضرت واجب الوجود ازو راضی است و خشنود و آنکه مغضوب تست واحد معبود نیز بی‌شبهه از او در غضب و ناخشنود است. راوی گوید: که امام الهمام جعفر بن محمد علیه السلام این کلام صدق التیام در محضر جمعی کثیر از أهل اسلام بیان نمود محدثون این حدیث قایل گشته‌اند و در کتب خود نقل نمودند لیکن چون ابن جریج در آن محضر حاضر بود گفت: یا أبا عبد اللٰه علیه السلام امروز حدیث برای ما نقل کردید که مردمان را در حیرت","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"المحدثون","display":"الْمُحَدِّثُونَ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فاتاه","display":"فَاَتَاهُ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"جريح","display":"جريح"},{"kind":"word","token":"جريج","display":"جُرَيْجٍ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"حدثنا","display":"حُدِّثْنَا"},{"kind":"word","token":"اليوم","display":"الْيَوْمَ"},{"kind":"word","token":"حديثا","display":"حَدِيثاً"},{"kind":"word","token":"استهزاه","display":"اِسْتَهْزَاَهُ"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"حديث","display":"حَدِيثُ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللّه"},{"kind":"word","token":"عليه","display"