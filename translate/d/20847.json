ونَ يَسْتَغِيثُونَ ،  ثُمَّ لَقِيَ اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) مِنَ الشِّدَّةِ وَ الْبَلاَءِ وَ التَّظَاهُرِ عَلَيْهِ ،  وَ لَمْ يَكُنْ مَعَهُ اَحَدٌ مِنْ قَوْمِهِ بِمَنْزِلَتِهِ ،  اَمَّا حَمْزَةُ فَقُتِلَ يَوْمَ اُحُدٍ ،  وَ اَمَّا جَعْفَرٌ فَقُتِلَ يَوْمَ مُؤْتَةَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"لقي","display":"لَقِيَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قومه","display":"قَوْمِهِ"},{"kind":"word","token":"بلاء","display":"بَلاَءً"},{"kind":"word","token":"شديدا","display":"شَدِيداً"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"اتوه","display":"اَتَوْهُ"},{"kind":"word","token":"ذات","display":"ذَاتَ"},{"kind":"word","token":"يوم","display":"يَوْمٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ساجد","display":"سَاجِدٌ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"طرحوا","display":"طَرَحُوا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"رحم","display":"رَحِمَ"},{"kind":"word","token":"شاه","display":"شَاةٍ"},{"kind":"word","token":"فاتته","display":"فَاَتَتْهُ"},{"kind":"word","token":"ابنته","display":"اِبْنَتُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ساجد","display":"سَاجِدٌ"},{"kind