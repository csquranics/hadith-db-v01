{"consensus_set_id":"111293","translation_language":"fa","translation_source":{"hid":"355205"},"segments":[{"source_hadith_segment":"<quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ - » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  تِيجَانُ الْعَرَبِ وَ قَالَ صُحْبَةُ عِشْرِينَ يَوْماً قَرَابَةٌ .","translation_segment":"دیگر آن حضرت فرمود که بسم اللٰه الرحمن الرحیم. تاج عربست. و دیگر فرموده که صحبت بیست روزه قرابت است.","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"تيجان","display":"تِيجَانُ"},{"kind":"word","token":"العرب","display":"الْعَرَبِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صحبه","display":"صُحْبَةُ"},{"kind":"word","token":"عشرين","display":"عِشْرِينَ"},{"kind":"word","token":"يوما","display":"يَوْماً"},{"kind":"word","token":"قرابه","display":"قَرَابَةٌ"}]}]}