{"consensus_set_id":"48498","translation_language":"fa","translation_source":{"hid":"352400"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ اِذَا الْمَوْؤُدَةُ سُئِلَتْ بِاَيِّ ذَنْبٍ قُتِلَتْ » </quranic_text>   <footnote> [ التكوير ۸ ] </footnote>  قَالَ نَزَلَتْ فِي الْحُسَيْنِ بْنِ عَلِيٍّ عَلَيْهِ السَّلاَمُ  .","translation_segment":"پدرم رحمه اللٰه علیه از سعد بن عبد اللٰه، از یعقوب بن یزید و ابراهیم بن هاشم، از محمد بن ابی عمیر، از برخی رجالش از حضرت ابی عبد اللٰه علیه السلام در ذیل فرموده خداوند عز و جل: «و إذا المووده‌ سئلت‌، `بأی‌ ذنب‌ قتلت‌». فرمودند: این آیه در شأن حسین بن علی علیهما السلام نازل شده.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"الموؤده","display":"الْمَوْؤُدَةُ"},{"kind":"word","token":"سئلت","display":"سُئِلَتْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التكوير۸","display":"التكوير۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"باي","display":"بِاَيِّ"},{"kind":"word","token":"ذنب","display":"ذَنْبٍ"},{"kind":"word","token":"قتلت","display":"قُتِلَتْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التكوير","display":"التكوير"},{"kind":"word","token":"۸","display":"۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في