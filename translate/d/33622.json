{"consensus_set_id":"33622","translation_language":"fa","translation_source":{"hid":"345331"},"segments":[{"source_hadith_segment":"اَقْرَبُ مَا يَكُونُ الْعَبْدُ مِنَ اللَّهِ عَزَّ وَ جَلَّ وَ هُوَ سَاجِدٌ وَ ذَلِكَ قَوْلُهُ تَبَارَكَ وَ تَعَالَي  <quranic_text> « وَ اُسْجُدْ وَ اِقْتَرِبْ » </quranic_text>   <footnote> [ العلق ۱۹ ] </footnote>   .","translation_segment":"از حسن بن علی الوشا مروی است که گفت از حضرت رضا (علیه السلام) شنیدم که فرمود در حالتی که بنده در آن حالت نزدیکتر است از همه حالات بخدا حالت سجده است و اینست مضمون آیه شریفه سجده «و اسجد و اقترب‌».","segment_columns":[{"kind":"word","token":"اقرب","display":"اَقْرَبُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"العبد","display":"الْعَبْدُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ساجد","display":"سَاجِدٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسجد","display":"اُسْجُدْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اقترب","display":"اِقْتَرِبْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العلق","display":"العلق"},{"kind":"word","token":"۱۹","display":"۱۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}