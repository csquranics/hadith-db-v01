{"consensus_set_id":"56300","translation_language":"fa","translation_source":{"hid":"353933"},"segments":[{"source_hadith_segment":"وَ قَوْلُهُ تَعَالَي :   <quranic_text> « اِنَّ الَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ سَيَجْعَلُ لَهُمُ الرَّحْمٰنُ وُدًّا » </quranic_text>   <footnote> [ مريم ۹۶ ] </footnote>  قَالَ اِبْنُ عَبَّاسٍ هُوَ عَلِيُّ بْنُ اَبِي طَالِبٍ  .","translation_segment":"و دیگر «إن‌ الذین‌ آمنوا و عملوا الصٰالحٰات‌ سیجعل‌ لهم‌ الرحمٰن‌ ودا» یعنی بدرستی آنان که بگرویدند و کردند عملهای پسندیده زود باشد که پدید کند بر ایشان حضرت رحمان دوستی در دلهای خلق، یعنی محبت ایشان در دلها افکند بی‌اسباب وسائط‍‌، ابن عباس گوید که: آن علی بن ابی طالب (علیه السلام) است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عملوا","display":"عَمِلُوا"},{"kind":"word","token":"الصالحات","display":"الصّٰالِحٰاتِ"},{"kind":"word","token":"سيجعل","display":"سَيَجْعَلُ"},{"kind":"word","token":"لهم","display":"لَهُمُ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"ودا","display":"وُدًّا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"مريم","display":"مريم"},{"kind":"word","token":"۹۶","display":"۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ابن","display":"اِبْنُ"},{"kind":"word","token":"عباس","display":"عَبَّاسٍ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","t