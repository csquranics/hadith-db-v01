{"consensus_set_id":"17929","translation_language":"fa","translation_source":{"hid":"410680"},"segments":[{"source_hadith_segment":"« قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ اِنَّهُ لَذِكْرٌ لَكَ وَ لِقَوْمِكَ وَ سَوْفَ تُسْئَلُونَ » </quranic_text>   <footnote> [ الزخرف ۴۴ ] </footnote> فَرَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) الذِّكْرُ ،  وَ اَهْلُ بَيْتِهِ ( صَلَوَاتُ اللَّهِ عَلَيْهِمْ ) اَهْلُ الذِّكْرِ ،  وَ هُمُ الْمَسْؤُولُونَ ،  اَمَرَ اللَّهُ النَّاسَ يَسْاَلُونَهُمْ ،  فَهُمْ وُلاَةُ النَّاسِ وَ اَوْلاَهُمْ ،  فَلَيْسَ يَحِلُّ لِاَحَدٍ مِنَ النَّاسِ اَنْ يَاْخُذَ هَذَا الْحَقَّ الَّذِي اِفْتَرَضَهُ اللَّهُ لَهُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"لذكر","display":"لَذِكْرٌ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقومك","display":"لِقَوْمِكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سوف","display":"سَوْفَ"},{"kind":"word","token":"تسئلون","display":"تُسْئَلُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزخرف","display":"الزخرف"},{"kind":"word","token":"۴۴","display":"۴۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فرسول","display":"فَرَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":