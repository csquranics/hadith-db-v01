{"consensus_set_id":"s123652","translation_language":"fa","translation_source":{"hid":"123652"},"segments":[{"source_hadith_segment":"قيل لابي جعفر عليه السّلام و انا عنده ان سالم بن ابي حفصة و اصحابه يروون عنك انك تكلم علي سبعين وجها لك منها المخرج فقال ما يريد سالم مني ا يريد ان اجيء بالملائكة و اللّٰه ما جاءت بها النبيون و لقد قال ابراهيم عليه السّلام اني سقيم و ما كان سقيما و ما كذب و لقد قال ابراهيم عليه السّلام بل فعله كبيرهم هذا - و ما فعله و ما كذب و لقد قال يوسف عليه السّلام  <quranic_text> « اَيَّتُهَا الْعِيرُ اِنَّكُمْ لَسٰارِقُونَ » </quranic_text>   <footnote> [ يوسف ۷۰ ] </footnote>  و اللّٰه ما كانوا سارقين و ما كذب .","translation_segment":"","segment_columns":[{"kind":"word","token":"قيل","display":"قيل"},{"kind":"word","token":"لابي","display":"لابي"},{"kind":"word","token":"جعفر","display":"جعفر"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"انا","display":"انا"},{"kind":"word","token":"عنده","display":"عنده"},{"kind":"word","token":"ان","display":"ان"},{"kind":"word","token":"سالم","display":"سالم"},{"kind":"word","token":"بن","display":"بن"},{"kind":"word","token":"ابي","display":"ابي"},{"kind":"word","token":"حفصه","display":"حفصة"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"اصحابه","display":"اصحابه"},{"kind":"word","token":"يروون","display":"يروون"},{"kind":"word","token":"عنك","display":"عنك"},{"kind":"word","token":"انك","display":"انك"},{"kind":"word","token":"تكلم","display":"تكلم"},{"kind":"word","token":"علي","display":"علي"},{"kind":"word","token":"سبعين","display":"سبعين"},{"kind":"word","token":"وجها","display":"وجها"},{"kind":"word","token":"لك","display":"لك"},{"kind":"word","token":"منها","display":"منها"},{"kind":"word","token":"المخرج","display":"المخرج"},{"kind":"word","token":"فقال","display":"فقال"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"يريد","display":