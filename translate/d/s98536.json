{"consensus_set_id":"s98536","translation_language":"fa","translation_source":{"hid":"98536"},"segments":[{"source_hadith_segment":"« اَقْرَبُ مَا يَكُونَ الْعَبْدُ اِلَي اللَّهِ عَزَّ وَ جَلَّ وَ هُوَ سَاجِدٌ قَالَ اللَّهُ تَعَالَي  <quranic_text> « وَ اُسْجُدْ وَ اِقْتَرِبْ » </quranic_text>   <footnote> [ العلق ۱۹ ] </footnote>","translation_segment":"امام صادق علیه السلام فرمود: نزدیکترین حالات بنده به خداوند عز و جل‌ حال او در سجده است یا حالتی است که او در سجده باشد. خداوند تعالی فرموده است: «سجده کن و تقرب یاب». (آیه سجده اقرء باسم).","segment_columns":[{"kind":"word","token":"اقرب","display":"اَقْرَبُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يكون","display":"يَكُونَ"},{"kind":"word","token":"العبد","display":"الْعَبْدُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ساجد","display":"سَاجِدٌ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسجد","display":"اُسْجُدْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اقترب","display":"اِقْتَرِبْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العلق","display":"العلق"},{"kind":"word","token":"۱۹","display":"۱۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}