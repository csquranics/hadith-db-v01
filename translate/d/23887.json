{"consensus_set_id":"23887","translation_language":"fa","translation_source":{"hid":"112489"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « فَلْيَاْكُلْ بِالْمَعْرُوفِ » </quranic_text>   <footnote> [ النساء ۶ ] </footnote>  قَالَ الْمَعْرُوفُ هُوَ الْقُوتُ وَ اِنَّمَا عَنَي الْوَصِيَّ اَوِ الْقَيِّمَ فِي اَمْوَالِهِمْ وَ مَا يُصْلِحُهُمْ .","translation_segment":"عبد الله بن سنان گوید: امام صادق علیه السلام در مورد گفتار خدا که می‌فرماید: «پس باید به اندازه معروف بخورد» فرمود: معروف یعنی خوراک ضروری است و این تنها در مورد وصی یا سرپرست یتیمان است که اموال آن‌ها را نگهداری و به مصالح آنها رسیدگی می‌کند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلياكل","display":"فَلْيَاْكُلْ"},{"kind":"word","token":"بالمعروف","display":"بِالْمَعْرُوفِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۶","display":"۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"المعروف","display":"الْمَعْرُوفُ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"القوت","display":"الْقُوتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"عني","display":"عَنَي"},{"kind":"word","token":"الوصي","display":"الْوَصِيَّ"},{"kind":"word","token":"او","display":"اَوِ"},{"kind":"word","token":"القيم","display":"الْقَيِّمَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اموالهم","display":"اَمْوَالِهِمْ"},{"kind":"word","token":"و","display":"وَ"