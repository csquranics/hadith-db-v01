{"consensus_set_id":"s244329","translation_language":"fa","translation_source":{"hid":"244329"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « فَاِمّٰا نَذْهَبَنَّ بِكَ فَاِنّٰا مِنْهُمْ مُنْتَقِمُونَ » </quranic_text>   <footnote> [ الزخرف ۴۱ ] </footnote>  نَزَلَتْ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ اَنَّهُ يَنْتَقِمُ مِنَ النَّاكِثِينَ وَ الْقَاسِطِينَ بَعْدِي .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاما","display":"فَاِمّٰا"},{"kind":"word","token":"نذهبن","display":"نَذْهَبَنَّ"},{"kind":"word","token":"بك","display":"بِكَ"},{"kind":"word","token":"فانا","display":"فَاِنّٰا"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"منتقمون","display":"مُنْتَقِمُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزخرف","display":"الزخرف"},{"kind":"word","token":"۴۱","display":"۴۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"ينتقم","display":"يَنْتَقِمُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الناكثين","display":"النَّاكِثِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"القاسطين","display":"الْقَاسِطِينَ"},{"kind":"word","token":"بعدي","display":"بَعْدِي"}]}]}