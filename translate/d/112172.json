{"consensus_set_id":"112172","translation_language":"fa","translation_source":{"hid":"394286"},"segments":[{"source_hadith_segment":"وَ اُخْبِرُكُمْ عَمَّا اَرَدْتُمْ اَنْ تَسْئَلُوا عَنْهُ فِي قَوْلِهِ تَعَالَي :  « شَجَرَةٍ  <quranic_text> « اَصْلُهٰا ثٰابِتٌ وَ فَرْعُهٰا فِي السَّمٰاءِ » </quranic_text>   <footnote> [ ابراهيم ۲۴ ] </footnote>  نَحْنُ نُعْطِي شِيعَتَنَا مَا نَشَاءُ مِنَ الْعِلْمِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اخبركم","display":"اُخْبِرُكُمْ"},{"kind":"word","token":"عما","display":"عَمَّا"},{"kind":"word","token":"اردتم","display":"اَرَدْتُمْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تسئلوا","display":"تَسْئَلُوا"},{"kind":"word","token":"عنه","display":"عَنْهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"شجره","display":"شَجَرَةٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اصلها","display":"اَصْلُهٰا"},{"kind":"word","token":"ثابت","display":"ثٰابِتٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فرعها","display":"فَرْعُهٰا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السماء","display":"السَّمٰاءِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ابراهيم","display":"ابراهيم"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"نعطي","display":"نُعْطِي"},{"kind":"word","token":"شيعتنا","display":"شِيعَتَنَا"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"نشاء","display":"نَشَاءُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"العلم","display":"الْعِلْمِ"}]}]}