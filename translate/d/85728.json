{"consensus_set_id":"85728","translation_language":"fa","translation_source":{"hid":"307998"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ [ قَوْلِ اللَّهِ ]  <quranic_text> « الَّذِينَ اُخْرِجُوا مِنْ دِيٰارِهِمْ بِغَيْرِ حَقٍّ اِلاّٰ اَنْ يَقُولُوا رَبُّنَا اللّٰهُ » </quranic_text>   <footnote> [ الحج ۴۰ ] </footnote>  قَالَ نَزَلَ فِي عَلِيٍّ [ اَمِيرِ الْمُؤْمِنِينَ  ] وَ جَعْفَرٍ وَ حَمْزَةَ وَ جَرَتْ فِي الْحُسَيْنِ بْنِ عَلِيٍّ عَلَيْهِمُ السَّلاَمُ [ وَ التَّحِيَّةُ وَ الْاِكْرَامُ ] .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اخرجوا","display":"اُخْرِجُوا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ديارهم","display":"دِيٰارِهِمْ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"حق","display":"حَقٍّ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يقولوا","display":"يَقُولُوا"},{"kind":"word","token":"ربنا","display":"رَبُّنَا"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۴۰","display":"۴۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزل","display":"نَزَلَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جعف