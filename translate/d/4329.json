{"consensus_set_id":"4329","translation_language":"fa","translation_source":{"hid":"99857"},"segments":[{"source_hadith_segment":"عَنْ رَجُلَيْنِ قَامَا فَنَظَرَا اِلَي الْفَجْرِ","translation_segment":"و سماعه بن مهران از آن امام علیه السلام در باره دو","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجلين","display":"رَجُلَيْنِ"},{"kind":"word","token":"قاما","display":"قَامَا"},{"kind":"word","token":"فنظرا","display":"فَنَظَرَا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الفجر","display":"الْفَجْرِ"}]},{"source_hadith_segment":"فَقَالَ اَحَدُهُمَا هُوَ ذَا","translation_segment":"مرد سوال کرد، که برخاستند و","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"احدهما","display":"اَحَدُهُمَا"},{"kind":"word","token":"هو","display":"هو"},{"kind":"word","token":"ذا","display":"ذا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"الفجر","display":"الْفَجْرُ"}]},{"source_hadith_segment":"وَ قَالَ الْاخَرُ مَا اَرَي شَيْئاً","translation_segment":"به آسمان نگاه کردند. یکی از آن دو گفت:","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الاخر","display":"الْاخَرُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اري","display":"اَرَي"},{"kind":"word","token":"شيئا","display":"شَيْئاً"}]},{"source_hadith_segment":"قَالَ « فَلْيَاْكُلِ الَّذِي لَمْ يَتَبَيَّنْ لَهُ الْفَجْرُ وَ لْيَشْرَبْ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « وَ كُلُوا وَ اِشْرَبُوا حَتّٰي يَتَبَيَّنَ لَكُمُ الْخَيْطُ الْاَبْيَضُ مِنَ الْخَيْطِ الْاَسْوَدِ مِنَ الْفَجْرِ ثُمَّ اَتِمُّوا الصِّيٰامَ اِلَي اللَّيْلِ » </quranic_text> <footnote> [ البقرة ۱۸۷ ] </footnote> قَالَ سَمَاعَةُ وَ سَاَلْتُهُ عَنْ رَجُلٍ اَكَلَ وَ شَرِبَ بَعْدَ مَا طَلَعَ الْفَجْرُ فِي شَهْرِ رَمَضَانَ فَقَالَ « اِنْ كَانَ قَامَ فَنَظَرَ فَلَمْ يَرَ الْفَجْرَ فَاَكَلَ ثُمَّ اَعَادَ النَّظَرَ فَرَاَي الْفَجْرَ فَلْيُتِمَّ صَوْمَهُ وَ لاَ اِعَادَةَ عَلَيْهِ وَ اِنْ كَانَ قَامَ فَاَكَلَ وَ شَرِبَ ثُمَّ نَظَرَ اِلَي الْفَجْرِ فَرَاهُ قَدْ طَلَعَ فَلْيُتِمَّ صَوْمَهُ ذَلِكَ وَ يَقْضِي يَوْماً اخَرَ لِاَنَّهُ بَدَاَ بِالْاَكْلِ قَبْلَ النَّظَرِ فَعَلَيْهِ الْاِعَادَةُ » .","translation_segment":"اینک آن فجر است، و آن دیگر گفت: من چیزی نمی‌بینم. فرمود: پس آن یک که فجر بر او مبین و روشن نشده است می‌تواند بخورد و بیاشامد، زیرا خدای عز و جل‌ می‌گوید: «و بخورید و بیاشامید، تا آنگاه که روشنی سپیده بمانند رشته‌ای سپید در سراسر افق پدید آید، و از رشته سیاه تاریکی باقیمانده شب جدا شود، و آنگاه روزه را تا شب کامل بسازید». و سماعه گفت از آن امام در باره مردی سوال کردم که پس از طالع شدن فجر در ماه رمضان بخورد و بیاشامد، پس فرمود: اگر بپاخیزد، و نگاه کند، و فجر را نبیند و بخورد و پس از آن بار دیگر نگاه کند و فجر را ببیند، می‌باید روزه‌اش را کامل سازد، و اعاده آن بر ذمه‌اش نیست، ولی اگر بپاخیزد و بخورد و بیاشامد، و پس از آن به فجر بنگرد، و مشاهده کند که آن طلوع کرده است، می‌باید روزه‌اش را کامل سازد، و روزی دیگر نیز به عنوان قضا روزه بگیرد، زیرا که او پیش از تحقیق و نگریستن به افق به خوردن پرداخته، و از این رو می‌باید روزه را اعاده کند.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فلياكل","display":"فَلْيَاْكُلِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يتبين","display":"يَتَبَيَّنْ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"الفجر","display":"الْفَجْرُ"},{"kind":"word","token":"و","display":"و"},{"kind":"word