ُ فَبِرَحْمَتِهِ » .  قُلْتُ :  فَيُدْخِلُهُ النَّارَ وَ هُوَ مُؤْمِنٌ ؟  قَالَ :  « نَعَمْ ،  لِاَنَّهُ لَيْسَ مِنَ الْمُؤْمِنِينَ الَّذِينَ عَنَي اللَّهُ اَنَّهُ وَلِيُّ الْمُؤْمِنِينَ ،  لِاَنَّ الَّذِينَ عَنَي اللَّهُ اَنَّهُ لَهُمْ وَلِيُّ ،  وَ اَنَّهُ لاَ خَوْفٌ عَلَيْهِمْ وَ لاَ هُمْ يَحْزَنُونَ ،  هُمُ الْمُؤْمِنُونَ الَّذِينَ يَتَّقُونَ اللَّهَ ،  وَ الَّذِينَ عَمِلُوا الصَّالِحَاتِ ،  وَ الَّذِينَ لَمْ يَلْبِسُوا اِيمَانَهُمْ بِظُلْمٍ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"لقي","display":"لَقِيَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عز"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عملوا","display":"عَمِلُوا"},{"kind":"word","token":"الصالحات","display":"الصّٰالِحٰاتِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۵","display":"۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كانوا","display":"كٰانُوا"},{"kind":"word","token":"يتقون","display":"يَتَّقُونَ"},{"kind":"tag_close","tag_name":"