{"consensus_set_id":"35843","translation_language":"fa","translation_source":{"hid":"356760"},"segments":[{"source_hadith_segment":"وَ سُئِلَ الصَّادِقُ عَلَيْهِ السَّلاَمُ عَنْ هَذِهِ الْايَةِ فَقَالَ الْايَاتُ هُمُ الْاَئِمَّةُ وَ الْايَةُ الْمُنْتَظَرَةُ هُوَ الْقَائِمُ الْمَهْدِيُّ عَلَيْهِ السَّلاَمُ فَاِذَا قَامَ  <quranic_text> « لاٰ يَنْفَعُ نَفْساً اِيمٰانُهٰا » </quranic_text>   <footnote> [ الانعام ۱۵۸ ] </footnote>  لَمْ تَكُنْ امَنَتْ مِنْ قَبْلِ قِيَامِهِ بِالسَّيْفِ وَ اِنْ امَنَتْ بِمَنْ تَقَدَّمَ مِنْ ابَائِهِ عَلَيْهِمُ السَّلاَمُ  .","translation_segment":"امام صادق از تفسیر این آیه پرسش شد فرمود آیات امامانند و آیت منتظر همان قائم مهدی است ع چون قیام کند ایمان هیچ کس که پیش از قیام او با شمشیر ایمان نداشته سود ندهد اگر چه بپدران گذشته او هم ایمان داشته و تصدیق اینکه مقصود از آیات حجج هستند از قرآن مجید قول خدای عز و جل است","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"الايات","display":"الْايَاتُ"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"الائمه","display":"الْاَئِمَّةُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليهم","display":"عليهم"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"word","token":"المنتظره","display":"الْمُنْتَظَرَةُ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"القائم","display":"الْقَائِمُ"},{"kind":"word","token":"المهدي","display":"الْمَهْدِيُّ"},{"kin