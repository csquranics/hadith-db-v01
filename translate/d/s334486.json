otnote> [ النور ۳۵ ] </footnote>   <quranic_text> « الَّذِي خَلَقَ السَّمٰاوٰاتِ وَ الْاَرْضَ بِالْحَقِّ » </quranic_text>   <footnote> [ الانعام ۷۳ ] </footnote>   .  .  .   <quranic_text> « قَوْلُهُ الْحَقُّ وَ لَهُ الْمُلْكُ يَوْمَ يُنْفَخُ فِي الصُّورِ عٰالِمُ الْغَيْبِ وَ الشَّهٰادَةِ وَ هُوَ الْحَكِيمُ الْخَبِيرُ » </quranic_text>   <footnote> [ الانعام ۷۳ ] </footnote>   <quranic_text> « اللّٰهُ الَّذِي خَلَقَ سَبْعَ سَمٰاوٰاتٍ وَ مِنَ الْاَرْضِ مِثْلَهُنَّ يَتَنَزَّلُ الْاَمْرُ بَيْنَهُنَّ لِتَعْلَمُوا اَنَّ اللّٰهَ عَليٰ كُلِّ شَيْءٍ قَدِيرٌ وَ اَنَّ اللّٰهَ قَدْ اَحٰاطَ بِكُلِّ شَيْءٍ عِلْماً » </quranic_text>   <footnote> [ الطلاق ۱۲ ] </footnote>   <quranic_text> « وَ اَحْصيٰ كُلَّ شَيْءٍ عَدَداً » </quranic_text>   <footnote> [ الجن ۲۸ ] </footnote>  مِنْ شَرِّ كُلِّ ذِي شَرِّ يُعْلِنُ بِهِ اَوْ يُسِرُّ وَ مِنْ شَرِّ الْجِنَّةِ وَ الْبَشَرِ","translation_segment":"","segment_columns":[{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"الاحد","display":"الْاَحَدِ"},{"kind":"word","token":"الصمد","display":"الصَّمَدِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يلد","display":"يَلِدْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يولد","display":"يُولَدْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"كفوا","display":"كُفُواً"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاخلاص","display":"الاخلاص"},{"kind":"word","token":"۲","display":"۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"نور","display":"نُورِ"},{"kind":"word","token":"النور","display":"النُّورِ"},{"kind":"word","token":"و","display"