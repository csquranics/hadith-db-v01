{"consensus_set_id":"s449899","translation_language":"fa","translation_source":{"hid":"449899"},"segments":[{"source_hadith_segment":"<quranic_text> « اَمْ حَسِبَ الَّذِينَ اِجْتَرَحُوا السَّيِّئٰاتِ اَنْ نَجْعَلَهُمْ كَالَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ سَوٰاءً مَحْيٰاهُمْ وَ مَمٰاتُهُمْ » </quranic_text>   <footnote> [ الجاثية ۲۱ ] </footnote>  فَ  <quranic_text> « سَوٰاءً » </quranic_text>   <footnote> [ الجاثية ۲۱ ] </footnote>  هَاشِمٌ وَ بَنُو عَبْدِ الْمُطَّلِبِ ،  وَ اَمَّا  <quranic_text> « الَّذِينَ اِجْتَرَحُوا السَّيِّئٰاتِ » </quranic_text>   <footnote> [ الجاثية ۲۱ ] </footnote>  فَبَنُو عَبْدِ شَمْسٍ .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"حسب","display":"حَسِبَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اجترحوا","display":"اِجْتَرَحُوا"},{"kind":"word","token":"السيئات","display":"السَّيِّئٰاتِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"نجعلهم","display":"نَجْعَلَهُمْ"},{"kind":"word","token":"كالذين","display":"كَالَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عملوا","display":"عَمِلُوا"},{"kind":"word","token":"الصالحات","display":"الصّٰالِحٰاتِ"},{"kind":"word","token":"سواء","display":"سَوٰاءً"},{"kind":"word","token":"محياهم","display":"مَحْيٰاهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مماتهم","display":"مَمٰاتُهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الجاثيه","display":"الجاثية"},{"kind":"word","token":"۲۱","display":"۲۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ف","display":"فَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سواء","display":"سَوٰاءً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag