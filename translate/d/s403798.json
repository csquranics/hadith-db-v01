{"consensus_set_id":"s403798","translation_language":"fa","translation_source":{"hid":"403798"},"segments":[{"source_hadith_segment":"« اَ لَمْ يَنْسُبُوا نَبِيَّنَا مُحَمَّداً ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اِلَي اَنَّهُ يَوْمَ بَدْرٍ اَخَذَ [ لِنَفْسِهِ ] مِنَ الْمَغْنَمِ قَطِيفَةً حَمْرَاءَ ،  حَتَّي اَظْهَرَهُ اللَّهُ عَزَّ وَ جَلَّ عَلَي الْقَطِيفَةِ ،  وَ بَرَّاَ نَبِيَّهُ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) مِنَ الْخِيَانَةِ ،  وَ اَنْزَلَ فِي كِتَابِهِ :   <quranic_text> « وَ مٰا كٰانَ لِنَبِيٍّ اَنْ يَغُلَّ وَ مَنْ يَغْلُلْ يَاْتِ بِمٰا غَلَّ يَوْمَ الْقِيٰامَةِ » </quranic_text>   <footnote> [ العمران ۱۶۱ ] </footnote>   ؟  !  » .","translation_segment":"","segment_columns":[{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"ينسبوا","display":"يَنْسُبُوا"},{"kind":"word","token":"نبينا","display":"نَبِيَّنَا"},{"kind":"word","token":"محمدا","display":"مُحَمَّداً"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"بدر","display":"بَدْرٍ"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"لنفسه","display":"لِنَفْسِهِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المغنم","display":"الْمَغْنَمِ"},{"kind":"word","token":"قطيفه","display":"قَطِيفَةً"},{"kind":"word","token":"حمراء","display":"حَمْرَاءَ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"اظهره","display":"اَظْهَرَهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"