{"consensus_set_id":"23742","translation_language":"fa","translation_source":{"hid":"371630"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ عَزَّ وَ جَلَّ  <quranic_text> « فَلَمّٰا كُتِبَ عَلَيْهِمُ الْقِتٰالُ تَوَلَّوْا اِلاّٰ قَلِيلاً مِنْهُمْ » </quranic_text>   <footnote> [ البقرة ۲۴۶ ] </footnote>  قَالَ كَانَ الْقَلِيلُ سِتِّينَ اَلْفاً .","translation_segment":"ابو بصیر از حضرت باقر ع روایت کرد، که در تفسیر فرموده خداوند: «فلمٰا کتب‌ علیهم‌ القتٰال‌ تولوا إلاٰ قلیلا منهم‌» (پس چون حکم جهاد برایشان مقرر گردید، همه روی گرداندند جز اندکی-بقره:۲۴۶) فرمود: قلیل معهود در آیه شصت هزار است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فلما","display":"فَلَمّٰا"},{"kind":"word","token":"كتب","display":"كُتِبَ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"القتال","display":"الْقِتٰالُ"},{"kind":"word","token":"تولوا","display":"تَوَلَّوْا"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"قليلا","display":"قَلِيلاً"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۴۶","display":"۲۴۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"القليل","display":"الْقَلِيلُ"},{"kind":"word","token":"ستين","display":"سِتِّينَ"},{"kind":"word","token":"الفا","display":"اَلْفاً"}]}]}