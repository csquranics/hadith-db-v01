{"consensus_set_id":"7551","translation_language":"fa","translation_source":{"hid":"297443"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ ( عَزَّ وَ جَلَّ ) :   <quranic_text> « اَلْقِيٰا فِي جَهَنَّمَ كُلَّ كَفّٰارٍ عَنِيدٍ » </quranic_text>   <footnote> [ ق ۲۴ ] </footnote>  قَالَ :  نَزَلَتْ فِيَّ وَ فِي عَلِيِّ بْنِ اَبِي طَالِبٍ  ،  وَ ذَلِكَ اَنَّهُ اِذَا كَانَ يَوْمُ الْقِيَامَةِ شَفَّعَنِي رَبِّي وَ شَفَّعَكَ يَا عَلِيُّ  ،  وَ كَسَانِي وَ كَسَاكَ يَا عَلِيُّ  ،  ثُمَّ قَالَ لِي وَ لَكَ يَا عَلِيُّ  :  اَلْقِيَا فِي جَهَنَّمَ كُلَّ مَنْ اَبْغَضَكُمَا ،  وَ اَدْخِلاَ الْجَنَّةَ كُلَّ مَنْ اَحَبَّكُمَا ،  فَاِنَّ ذَلِكَ هُوَ الْمُؤْمِنُ .","translation_segment":"رسول خدا صلی الله علیه و اله درباره این سخن خدای فرازمند «همه کافران ستیزه‌جو را در دوزخ افکنید» [ق: آیه ۲۴] فرمود: درباره من و علی بن ابی طالب نازل شده است. آن بدین جهت است که چون روز قیامت شود پروردگارم من و تو را ای علی شفیع قرار می‌دهد و من و تو را ای علی جامه می‌دهد. سپس به من و تو ای علی می‌فرماید: هرکس را که با شما دشمنی کرد در دوزخ افکنید و هرکس را که با شما دوستی کرد به بهشت ببرید که او مومن است.","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابائه","display":"ابَائِهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"امير","display":"اَمِيرِ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","di