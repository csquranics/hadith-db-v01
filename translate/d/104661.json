{"consensus_set_id":"104661","translation_language":"fa","translation_source":{"hid":"354963"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اُوْلٰئِكَ يُجْزَوْنَ الْغُرْفَةَ بِمٰا صَبَرُوا » </quranic_text>   <footnote> [ الفرقان ۷۵ ] </footnote>  قَالَ الْغُرْفَةُ الْجَنَّةُ بِمَا صَبَرُوا عَلَي الْفَقْرِ فِي دَارِ الدُّنْيَا .","translation_segment":"و ثابت گوید که: محمد بن علی (علیه السلام) میفرمود در این آیت که «أولٰئک‌ یجزون‌ الغرفه‌ بمٰا صبروا» که غرفه بهشت است از برای آن کسان که صبر کردند بر فقر در دار دنیا.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اولئك","display":"اُوْلٰئِكَ"},{"kind":"word","token":"يجزون","display":"يُجْزَوْنَ"},{"kind":"word","token":"الغرفه","display":"الْغُرْفَةَ"},{"kind":"word","token":"بما","display":"بِمٰا"},{"kind":"word","token":"صبروا","display":"صَبَرُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفرقان","display":"الفرقان"},{"kind":"word","token":"۷۵","display":"۷۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الغرفه","display":"الْغُرْفَةُ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةُ"},{"kind":"word","token":"بما","display":"بِمَا"},{"kind":"word","token":"صبروا","display":"صَبَرُوا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الفقر","display":"الْفَقْرِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"دار","display":"دَارِ"},{"kind":"word","token":"الدنيا","display":"الدُّنْيَا"}]}]}