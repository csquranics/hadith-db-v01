{"consensus_set_id":"29811","translation_language":"fa","translation_source":{"hid":"225454"},"segments":[{"source_hadith_segment":"اِنَّ فِي جَهَنَّمَ لَوَادِياً يُقَالُ لَهُ سَعِيرٌ اِذَا خَبَتْ جَهَنَّمُ فُتِحَ سَعِيرُهَا وَ هُوَ قَوْلُهُ :   <quranic_text> « كُلَّمٰا خَبَتْ زِدْنٰاهُمْ سَعِيراً » </quranic_text>   <footnote> [ الاسراء ۹۷ ] </footnote>  اَيْ كُلَّمَا اِنْطَفَاَتْ .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"جهنم","display":"جَهَنَّمَ"},{"kind":"word","token":"لواديا","display":"لَوَادِياً"},{"kind":"word","token":"يقال","display":"يُقَالُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"سعير","display":"سَعِيرٌ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"خبت","display":"خَبَتْ"},{"kind":"word","token":"جهنم","display":"جَهَنَّمُ"},{"kind":"word","token":"فتح","display":"فُتِحَ"},{"kind":"word","token":"سعيرها","display":"سَعِيرُهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كلما","display":"كُلَّمٰا"},{"kind":"word","token":"خبت","display":"خَبَتْ"},{"kind":"word","token":"زدناهم","display":"زِدْنٰاهُمْ"},{"kind":"word","token":"سعيرا","display":"سَعِيراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۹۷","display":"۹۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"كلما","display":"كُلَّمَا"},{"kind":"word","token":"انطفات","display":"اِنْطَفَاَتْ"}]}]}