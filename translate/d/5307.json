{"consensus_set_id":"5307","translation_language":"fa","translation_source":{"hid":"100898"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « اَلْحَجُّ اَشْهُرٌ مَعْلُومٰاتٌ » </quranic_text>   <footnote> [ البقرة ۱۹۷ ] </footnote>  قَالَ « شَوَّالٌ وَ ذُو الْقَعْدَةِ وَ ذُو الْحِجَّةِ لَيْسَ لِاَحَدٍ اَنْ يُحْرِمَ بِالْحَجِّ فِيمَا سِوَاهُنَّ » .","translation_segment":"زراره از امام ابو جعفر علیه السلام در باره قول خدای عز و جل‌ «الحج‌ أشهر معلومٰات‌» روایت کرده است که فرمود: مقصود از این ماهها شوال و ذو القعده و ذو الحجه است. و برای هیچ کس روا نیست که در غیر این ماهها احرام حج ببندد.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحج","display":"اَلْحَجُّ"},{"kind":"word","token":"اشهر","display":"اَشْهُرٌ"},{"kind":"word","token":"معلومات","display":"مَعْلُومٰاتٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۷","display":"۱۹۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"شوال","display":"شَوَّالٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"القعده","display":"الْقَعْدَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"الحجه","display":"الْحِجَّةِ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"لاحد","display":"لِاَحَدٍ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يحرم","display":"ي