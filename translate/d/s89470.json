{"consensus_set_id":"s89470","translation_language":"fa","translation_source":{"hid":"89470"},"segments":[{"source_hadith_segment":"« اِذَا دَخَلْتَ الْمَسْجِدَ الْحَرَامَ فَامْشِ حَتَّي تَدْنُوَ مِنَ الْحَجَرِ الْاَسْوَدِ فَتَسْتَقْبِلَهُ وَ تَقُولُ  <quranic_text> « اَلْحَمْدُ لِلّٰهِ الَّذِي هَدٰانٰا لِهٰذٰا وَ مٰا كُنّٰا لِنَهْتَدِيَ لَوْ لاٰ اَنْ هَدٰانَا اللّٰهُ » </quranic_text>   <footnote> [ الاعراف ۴۳ ] </footnote> سُبْحَانَ اللَّهِ وَ الْحَمْدُ لِلَّهِ وَ لاَ اِلَهَ اِلاَّ اللَّهُ وَ اللَّهُ اَكْبَرُ مِنْ خَلْقِهِ وَ اللَّهُ اَكْبَرُ مِمَّا اَخْشَي وَ اَحْذَرُ <quranic_text> « لاٰ اِلٰهَ اِلاَّ اللّٰهُ » </quranic_text>   <footnote> [ محمد ۱۹ ] </footnote>  وَحْدَهُ  <quranic_text> « لاٰ شَرِيكَ لَهُ » </quranic_text>   <footnote> [ الانعام ۱۶۳ ] </footnote> <quranic_text> « لَهُ الْمُلْكُ وَ لَهُ الْحَمْدُ » </quranic_text>   <footnote> [ التغابن ۱ ] </footnote> <quranic_text> « يُحْيِي وَ يُمِيتُ » </quranic_text>   <footnote> [ العمران ۱۵۶ ] </footnote>  وَ هُوَ حَيٌّ لاَ يَمُوتُ وَ يُمِيتُ وَ يُحْيِي بِيَدِهِ الْخَيْرُ  <quranic_text> « وَ هُوَ عَليٰ كُلِّ شَيْءٍ قَدِيرٌ » </quranic_text>   <footnote> [ التغابن ۱ ] </footnote> وَ تُصَلِّي عَلَي النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ تُسَلِّمُ عَلَي الْمُرْسَلِينَ كَمَا فَعَلْتَ حِينَ دَخَلْتَ الْمَسْجِدَ ثُمَّ تَقُولُ اللَّهُمَّ اِنِّي اُومِنُ بِوَعْدِكَ وَ اُوفِي بِعَهْدِكَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"دخلت","display":"دَخَلْتَ"},{"kind":"word","token":"المسجد","display":"الْمَسْجِدَ"},{"kind":"word","token":"الحرام","display":"الْحَرَامَ"},{"kind":"word","token":"فامش","display":"فَامْشِ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"تدنو","display":"تَدْنُوَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الحجر","display":"الْحَجَرِ"},{"kind":"word","token":"الاسود","display":"الْاَسْوَدِ"},{"kind":"word","token":"فتستقبله","display":"فَتَسْتَقْبِلَهُ