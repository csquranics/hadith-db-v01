{"consensus_set_id":"s331505","translation_language":"fa","translation_source":{"hid":"331505"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ تَعَالَي :   <quranic_text> « وَ لاٰ تَقْتُلُوا اَنْفُسَكُمْ » </quranic_text>   <footnote> [ النساء ۲۹ ] </footnote>  قَالَ :  لاَ تَقْتُلُوا اَهْلَ بَيْتِ نَبِيِّكُمْ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  .","translation_segment":"عن ابن عباس فی قول الله تعالی: (و لا تقتلوا أنفسکم) قال: لا تقتلوا أهل بیت نبیکم (صلی الله علیه و آله). ابن عباس درباره سخن خداوند: «لا تقتلوا انفسکم» گفت: یعنی اهل بیت پیامبرتان را نکشید.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تقتلوا","display":"تَقْتُلُوا"},{"kind":"word","token":"انفسكم","display":"اَنْفُسَكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۲۹","display":"۲۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تقتلوا","display":"تَقْتُلُوا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"بيت","display":"بَيْتِ"},{"kind":"word","token":"نبيكم","display":"نَبِيِّكُمْ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"}]}]}