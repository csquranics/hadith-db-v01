{"consensus_set_id":"7693","translation_language":"fa","translation_source":{"hid":"297121"},"segments":[{"source_hadith_segment":"عَنْ اَبِي جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ )  ،  فِي قَوْلِهِ :   <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا اِتَّقُوا اللّٰهَ وَ كُونُوا مَعَ الصّٰادِقِينَ » </quranic_text>   <footnote> [ التوبة ۱۱۹ ] </footnote>  قَالَ :  مَعَ عَلِيِّ بْنِ اَبِي طَالِبٍ ( عَلَيْهِ السَّلاَمُ )  .","translation_segment":"امام باقر علیه السلام درباره سخن خداوند که می‌فرماید: «ای مومنان از خدا بترسید و با راستگویان باشید» [توبه: آیه ۱۱۹] فرمود: با علی بن ابی طالب علیه السلام باشید.","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تفسير","display":"تفسير"},{"kind":"word","token":"هذه","display":"هذه"},{"kind":"word","token":"الايه","display":"الآية"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"يؤيد","display":"يؤيد"},{"kind":"word","token":"ما","display":"ما"},{"kind":"word","token":"فهمه","display":"فهمه"},{"kind":"word","token":"اصحابنا","display":"أصحابنا"},{"kind":"word","token":"رضي","display":"رضي"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عنهم","display":"عنهم"},{"kind":"word","token":"منها","display":"منها"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سالته","display":"سألته"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind"