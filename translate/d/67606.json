{"consensus_set_id":"67606","translation_language":"fa","translation_source":{"hid":"266277"},"segments":[{"source_hadith_segment":"مَا اِنْتَصَرَ اللَّهُ مِنْ ظَالِمٍ اِلاَّ بِظَالِمٍ وَ ذَلِكَ قَوْلُ اللَّهِ -  <quranic_text> « وَ كَذٰلِكَ نُوَلِّي بَعْضَ الظّٰالِمِينَ بَعْضاً بِمٰا كٰانُوا يَكْسِبُونَ » </quranic_text>   <footnote> [ الانعام ۱۲۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"انتصر","display":"اِنْتَصَرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ظالم","display":"ظَالِمٍ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"بظالم","display":"بِظَالِمٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كذلك","display":"كَذٰلِكَ"},{"kind":"word","token":"نولي","display":"نُوَلِّي"},{"kind":"word","token":"بعض","display":"بَعْضَ"},{"kind":"word","token":"الظالمين","display":"الظّٰالِمِينَ"},{"kind":"word","token":"بعضا","display":"بَعْضاً"},{"kind":"word","token":"بما","display":"بِمٰا"},{"kind":"word","token":"كانوا","display":"كٰانُوا"},{"kind":"word","token":"يكسبون","display":"يَكْسِبُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۱۲۹","display":"۱۲۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}