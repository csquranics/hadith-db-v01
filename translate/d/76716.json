مْ دِمَاءَكُمْ وَ خَالَفْتُمْ اِمَامَكُمْ فَاَنْتُمْ اَكَلَةُ الْاكِلِ وَ فَرِيسَةُ الظَّافِرِ فَالنَّارُ لَكُمْ مُدَّخَرٌ وَ الْعَارُ لَكُمْ مَفْخَرٌ يَا اَهْلَ الْبَصْرَةِ نَكَثْتُمْ بَيْعَتِي وَ ظَاهَرْتُمْ عَلَي ذَوِي عَدَاوَتِي فَمَا ظَنُّكُمْ يَا اَهْلَ الْبَصْرَةِ »","translation_segment":"ع فرمود: علم بارث منتقل می‌شود و عالمی نمیرد جز اینکه کسیرا که","segment_columns":[{"kind":"word","token":"فحمد","display":"فَحَمِدَ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اثني","display":"اَثْنَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"رسوله","display":"رَسُولِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ذو","display":"ذُو"},{"kind":"word","token":"رحمه","display":"رَحْمَةٍ"},{"kind":"word","token":"واسعه","display":"وٰاسِعَةٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۱۴۷","display":"۱۴۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مغفره","display":"مَغْفِرَةٍ"},{"kind":"word","token":"دائمه","display":"دَائِمَةٍ"},{"kind":"word","token":"لاهل","display":"لِاَهْلِ"},{"kind":"word","token":"طاعته","display":"طَاعَتِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word",