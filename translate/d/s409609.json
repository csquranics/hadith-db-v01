{"consensus_set_id":"s409609","translation_language":"fa","translation_source":{"hid":"409609"},"segments":[{"source_hadith_segment":"« اِنَّ اَلْعَمَلَ الصَّالِحَ لَيَذْهَبُ اِلَي الْجَنَّةِ ،  فَيَمْهَدُ لِصَاحِبِهِ ،  كَمَا يَبْعَثُ الرَّجُلُ غُلاَماً فَيَفْرُشُ لَهُ ،  ثُمَّ قَرَاَ :   <quranic_text> « وَ مَنْ عَمِلَ صٰالِحاً فَلِاَنْفُسِهِمْ يَمْهَدُونَ » </quranic_text>   <footnote> [ الروم ۴۴ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"العمل","display":"اَلْعَمَلَ"},{"kind":"word","token":"الصالح","display":"الصَّالِحَ"},{"kind":"word","token":"ليذهب","display":"لَيَذْهَبُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"فيمهد","display":"فَيَمْهَدُ"},{"kind":"word","token":"لصاحبه","display":"لِصَاحِبِهِ"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"يبعث","display":"يَبْعَثُ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"غلاما","display":"غُلاَماً"},{"kind":"word","token":"فيفرش","display":"فَيَفْرُشُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عمل","display":"عَمِلَ"},{"kind":"word","token":"صالحا","display":"صٰالِحاً"},{"kind":"word","token":"فلانفسهم","display":"فَلِاَنْفُسِهِمْ"},{"kind":"word","token":"يمهدون","display":"يَمْهَدُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الروم","display":"الروم"},{"kind":"word","token":"۴۴","display":"۴۴"},{"kind":"tag_close","tag_name":"footnote"}]}]}