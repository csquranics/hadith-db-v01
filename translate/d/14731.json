{"consensus_set_id":"14731","translation_language":"fa","translation_source":{"hid":"88916"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :  وَ اَمَّا مَنْ اُوتِيَ كِتَابَهُ بِيَمِينِهِ فَهُوَ اَبُو سَلَمَةَ عَبْدُ اللَّهِ بْنُ عَبْدِ الْاَسْوَدِ بْنِ هِلاَلٍ الْمَخْزُومِيُّ وَ هُوَ مِنْ بَنِي مَخْزُومٍ .   <quranic_text> « وَ اَمّٰا مَنْ اُوتِيَ كِتٰابَهُ وَرٰاءَ ظَهْرِهِ » </quranic_text>   <footnote> [ الانشقاق ۱۰ ] </footnote>  فَهُوَ اَخُوهُ الْاَسْوَدُ بْنُ عَبْدِ الْاَسْوَدِ بْنِ هِلاَلٍ الْمَخْزُومِيُّ فَقَتَلَهُ حَمْزَةُ بْنُ عَبْدِ الْمُطَّلِبِ يَوْمَ بَدْرٍ .","translation_segment":"* *۲ - ابو عبد الله صادق (ع) گفت: کسی که با عذر شرعی روزه ماه رمضان را افطار کرده باشد، بهتر آن است که پی‌درپی قضای آن را بگیرد و اگر به‌طور پراکنده روزه بگیرد، اشکالی نخواهد داشت.","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"اوتي","display":"اُوتِيَ"},{"kind":"word","token":"كتابه","display":"كِتَابَهُ"},{"kind":"word","token":"بيمينه","display":"بِيَمِينِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانشقاق۷","display":"الانشقاق۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"سلمه","display":"سَلَمَةَ"},{"kind":"word","token":"عبد","display":"عَبْدُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الاسود","display":"الْاَسْوَدِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"هلال","display":"هِلاَلٍ"},{"kind":"word","tok