{"consensus_set_id":"s241252","translation_language":"fa","translation_source":{"hid":"241252"},"segments":[{"source_hadith_segment":"عَنْ اَبِيهِ عَنْ جَدِّهِ عَلَيْهِمُ السَّلاَمُ  :  فِي قَوْلِهِ تَعَالَي :   <quranic_text> « فِطْرَتَ اللّٰهِ الَّتِي فَطَرَ النّٰاسَ عَلَيْهٰا » </quranic_text>   <footnote> [ الروم ۳۰ ] </footnote>  قَالَ هُوَ التَّوْحِيدُ وَ مُحَمَّدٌ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ رَسُولُ اللَّهِ وَ عَلِيٌّ عَلَيْهِ السَّلاَمُ اَمِيرُ الْمُؤْمِنِينَ اِلَي هَاهُنَا التَّوْحِيدُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"جده","display":"جَدِّهِ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فطرت","display":"فِطْرَتَ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"فطر","display":"فَطَرَ"},{"kind":"word","token":"الناس","display":"النّٰاسَ"},{"kind":"word","token":"عليها","display":"عَلَيْهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الروم","display":"الروم"},{"kind":"word","token":"۳۰","display":"۳۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"التوحيد","display":"التَّوْحِيدُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٌ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"wo