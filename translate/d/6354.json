{"consensus_set_id":"6354","translation_language":"fa","translation_source":{"hid":"113456"},"segments":[{"source_hadith_segment":"لاَ يَنْبَغِي نِكَاحُ اَهْلِ الْكِتَابِ قُلْتُ جُعِلْتُ فِدَاكَ وَ اَيْنَ تَحْرِيمُهُ قَالَ قَوْلُهُ  <quranic_text> « وَ لاٰ تُمْسِكُوا بِعِصَمِ الْكَوٰافِرِ » </quranic_text>   <footnote> [ الممتحنة ۱۰ ] </footnote>   .","translation_segment":"زراره بن اعین گوید: امام باقر علیه السلام فرمود: ازدواج با زنان اهل کتاب جایز نیست. گفتم: فدایت گردم! این تحریم در کجا آمده است‌؟ فرمود: آنجا که خداوند متعال می‌فرماید: «و زنان کافر را در همسری (دائم خود) نگه ندارید».","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"ينبغي","display":"يَنْبَغِي"},{"kind":"word","token":"نكاح","display":"نِكَاحُ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"الكتاب","display":"الْكِتَابِ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"جعلت","display":"جُعِلْتُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اين","display":"اَيْنَ"},{"kind":"word","token":"تحريمه","display":"تَحْرِيمُهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تمسكوا","display":"تُمْسِكُوا"},{"kind":"word","token":"بعصم","display":"بِعِصَمِ"},{"kind":"word","token":"الكوافر","display":"الْكَوٰافِرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الممتحنه","display":"الممتحنة"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"}]}]}