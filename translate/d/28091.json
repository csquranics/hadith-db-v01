{"consensus_set_id":"28091","translation_language":"fa","translation_source":{"hid":"85960"},"segments":[{"source_hadith_segment":"« اِقْرَاْ فِي رَكْعَتَيِ الْفَجْرِ بِاَيِّ سُورَتَيْنِ اَحْبَبْتَ » وَ قَالَ « اَمَّا اَنَا فَاُحِبُّ اَنْ اَقْرَاَ فِيهِمَا بِ‍  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>  وَ  <quranic_text> « قُلْ يٰا اَيُّهَا الْكٰافِرُونَ » </quranic_text>   <footnote> [ الكافرون ۱ ] </footnote>   .","translation_segment":"* *۲۹۷ - ابو عبد الله صادق (ع) گفت: در نافله صبحدم هر سوره‌ای که تلاوت کنی روا خواهد بود، ولی من دوست دارم که سوره قل هو الله احد و سوره قل یا ایها الکافرون بخوانم.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"اقرا","display":"اِقْرَاْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ركعتي","display":"رَكْعَتَيِ"},{"kind":"word","token":"الفجر","display":"الْفَجْرِ"},{"kind":"word","token":"باي","display":"بِاَيِّ"},{"kind":"word","token":"سورتين","display":"سُورَتَيْنِ"},{"kind":"word","token":"احببت","display":"اَحْبَبْتَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"فاحب","display":"فَاُحِبُّ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"اقرا","display":"اَقْرَاَ"},{"kind":"word","token":"فيهما","display":"فِيهِمَا"},{"kind":"word","token":"ب","display":"بِ‍"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاخلاص","display":"الاخلاص"},{"kind":"word","token":"۱","display":"۱"}