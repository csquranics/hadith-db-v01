{"consensus_set_id":"1618","translation_language":"fa","translation_source":{"hid":"103864"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ","translation_segment":"و حسن بن محبوب، از أبو ولاد","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"}]},{"source_hadith_segment":"جَعْفَرَ بْنَ مُحَمَّدٍ الصَّادِقَ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ بِالْوٰالِدَيْنِ اِحْسٰاناً » </quranic_text>   <footnote> [ البقرة ۸۳ ] </footnote>  مَا هَذَا الْاِحْسَانُ فَقَالَ","translation_segment":"حناط‍‌ روایت کرده است که گفت: از أبو عبد اللٰه جعفر بن محمد صادق - علیهما السلام - در باره قول خداوند عز و جل‌: «و بالوٰالدین‌ إحسٰانا»» سوال کردم که این احسان چیست‌؟ امام فرمود: احسان اینست","segment_columns":[{"kind":"word","token":"جعفر","display":"جَعْفَرَ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"الصادق","display":"الصَّادِقَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بالوالدين","display":"بِالْوٰالِدَيْنِ"},{"kind":"word","token":"احسانا","display":"اِحْسٰاناً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۸۳","display":"۸۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الاحسان","display":"الْاِحْسَانُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"}]},{"source_hadith_segment":"« اَلْاِحْسَانُ اَنْ تُحْسِنَ صُحْبَتَهُمَا وَ اَنْ لاَ تُكَلِّفَهُمَا اَنْ يَسْاَلاَكَ شَيْئاً مِمَّا يَحْتَاجُونَ اِلَيْهِ وَ اِنْ كَانَا مُسْتَغْنِيَيْنِ اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ :   <quranic_text> « لَنْ تَنٰالُوا الْبِرَّ حَتّٰي تُنْفِقُوا مِمّٰا تُحِبُّونَ » </quranic_text>   <footnote> [ العمران ۹۲ ] </footnote>  ثُمَّ قَالَ عَلَيْهِ السَّلاَمُ  <quranic_text> « اِمّٰا يَبْلُغَنَّ عِنْدَكَ الْكِبَرَ اَحَدُهُمٰا اَوْ كِلاٰهُمٰا فَلاٰ تَقُلْ لَهُمٰا اُفٍّ » </quranic_text>   <footnote> [ الاسراء ۲۳ ] </footnote>  اِنْ اَضْجَرَاكَ  <quranic_text> « وَ لاٰ تَنْهَرْهُمٰا » </quranic_text>   <footnote> [ الاسراء ۲۳ ] </footnote>  اِنْ ضَرَبَاكَ  <quranic_text> « وَ قُلْ لَهُمٰا قَوْلاً كَرِيماً » </quranic_text>   <footnote> [ الاسراء ۲۳ ] </footnote>  وَ الْقَوْلُ الْكَرِيمُ اَنْ تَقُولَ لَهُمَا غَفَرَ اللَّهُ لَكُمَا فَذَاكَ مِنْكَ قَوْلٌ كَرِيمٌ  <quranic_text> « وَ اِخْفِضْ لَهُمٰا جَنٰاحَ الذُّلِّ مِنَ الرَّحْمَةِ » </quranic_text>   <footnote> [ الاسراء ۲۴ ] </footnote>  وَ هُوَ اَنْ لاَ تَمْلَاَ عَيْنَيْكَ مِنَ النَّظَرِ اِلَيْهِمَا وَ تَنْظُرَ اِلَيْهِمَا بِرَحْمَةٍ وَ رَاْفَةٍ وَ اَنْ لاَ تَرْفَعَ صَوْتَكَ فَوْقَ اَصْوَاتِهِمَا وَ لاَ يَدَكَ فَوْقَ اَيْدِيهِمَا وَ لاَ تَتَقَدَّمَ قُدَّامَهُمَا » .","translation_segment":"که حق‌ صحبتشان را نیکو ادا کنی و ایشان را بر آن نداری که چیز مورد احتیاجشان را از تو سوال کنند، اگر چه مستغنی باشند، زیرا خداوند عز و جل‌ میفرماید: «لن‌ تنٰالوا البر حتٰی تنفقوا ممٰا تحبون‌» (به بهشت دست نخواهید یافت، مگر زمانی که از آنچه دوست دارید انفاق کنید - آل عمران:۹۲). و آنگاه امام این آیه را قراءت فرمود: «إمٰا یبلغن‌ عندک‌ الکبر أحدهمٰا أو کلاٰهمٰا فلاٰ تقل‌ لهمٰا أف‌» (اگر یکی از آن دو یا هر دو نزد تو پیر شوند، پس سخنی کاشف از ملالت و آزردگی با ایشان مگوی - اسراء ۲۳) اگر چه تو را خسته و ملول سازند، «و لاٰ تنهرهمٰا» (و ایشان را میازار) اگر تو را بزنند، «و قل‌ لهمٰا قولا کریما» (و با ایشان سخنی کریم بگوی) و سخن کریم اینست که به ایشان بگوئی: خدا خطاهای شما را بیامرزد! که این از سوی تو قول کریمست «و اخفض‌ لهمٰا جنٰاح‌ الذل‌ من‌ الرحمه‌» (و بال تذلل و خضوع را از سر رحمت و شفقت برای ایشان فرود آور - اسراء:۲۴) بر این گونه که بهنگام نگریستن با چشم دریده به ایشان ننگری زیرا که «چشم دریده ادب نگاه ندارد» - و از روی رحمت و رأفت به ایشان نظر کنی و صدایت را و دستت را بر صدای ایشان و دستشان بلند نکنی، و در جلو ایشان گام بر نداری.","segment_columns":[{"kind":"word","token":"الاحسان","display":"اَلْاِحْسَانُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تحسن","display":"تُحْسِنَ"},{"kind":"word","token":"صحبتهما","display":"صُحْبَتَهُمَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تكلفهما","display":"تُكَلِّفَهُمَا"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يسالاك","display":"يَسْاَلاَكَ"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"مما","display":"مِمَّا"},{"kind":"word","token":"يحتاجون","display":"يَحْتَاجُونَ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كانا","display":"كَانَا"},{"kind":"word","token":"مستغنيين","display":"مُسْتَغْنِيَيْنِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind