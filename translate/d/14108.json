{"consensus_set_id":"14108","translation_language":"fa","translation_source":{"hid":"346375"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ فِي السَّمٰاءِ رِزْقُكُمْ وَ مٰا تُوعَدُونَ » </quranic_text>   <footnote> [ الذاريات ۲۲ ] </footnote>   .  قَالَ هُوَ خُرُوجُ الْمَهْدِيِّ عَلَيْهِ السَّلاَمُ  .","translation_segment":"ابن عباس در مورد این آیه قرآن که می‌فرماید: «و روزی شما با همه وعده‌ها که به شما دادند، در آسمان است.» گفته است: مقصود از وعده، خروج مهدی علیه السلام است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السماء","display":"السَّمٰاءِ"},{"kind":"word","token":"رزقكم","display":"رِزْقُكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"توعدون","display":"تُوعَدُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الذاريات","display":"الذاريات"},{"kind":"word","token":"۲۲","display":"۲۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"خروج","display":"خُرُوجُ"},{"kind":"word","token":"المهدي","display":"الْمَهْدِيِّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"}]}]}