{"consensus_set_id":"s331896","translation_language":"fa","translation_source":{"hid":"331896"},"segments":[{"source_hadith_segment":"نَزَلَتْ هَذِهِ الْايَةُ :   <quranic_text> « اَ فَمَنْ كٰانَ مُؤْمِناً كَمَنْ كٰانَ فٰاسِقاً » </quranic_text>   <footnote> [ السجده ۱۸ ] </footnote>  فِي عَلِيِّ بْنِ اَبِي طَالِبٍ وَ الْوَلِيدِ بْنِ عُقْبَةَ .","translation_segment":"عن ابن عباس قال: نزلت هذه الآیه: (أفمن کان مومنا کمن کان فاسقا) فی علی‌ بن ابی طالب و الولید بن عقبه. ابن عباس گفت: این آیه: «افمن کان مومنا کمن کان فاسقا» راجع به علی‌ بن ابی طالب (علیه السلام) و ولید بن عقبه نازل شده است.","segment_columns":[{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"مؤمنا","display":"مُؤْمِناً"},{"kind":"word","token":"كمن","display":"كَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"فاسقا","display":"فٰاسِقاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"السجده","display":"السجده"},{"kind":"word","token":"۱۸","display":"۱۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الوليد","display":"الْوَلِيدِ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"عقبه","display":"عُقْبَةَ"}]}]}