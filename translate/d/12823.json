{"consensus_set_id":"12823","translation_language":"fa","translation_source":{"hid":"118102"},"segments":[{"source_hadith_segment":"قَالَ فِي الرَّجُلِ يَقْتُلُ مَمْلُوكَهُ مُتَعَمِّداً قَالَ يُعْجِبُنِي اَنْ يُعْتِقَ رَقَبَةً وَ يَصُومَ  <quranic_text> « شَهْرَيْنِ مُتَتٰابِعَيْنِ » </quranic_text>   <footnote> [ النساء ۹۲ ] </footnote>  وَ يُطْعِمَ سِتِّينَ مِسْكِيناً ثُمَّ تَكُونَ التَّوْبَةُ بَعْدَ ذَلِكَ .","translation_segment":"حلبی گوید: امام صادق علیه السلام درباره مردی که برده خود را از روی عمد می‌کشد فرمود: دوست دارم که برده‌ای را آزاد کند، دو ماه پیاپی روزه بگیرد و شصت فقیر را اطعام نماید سپس توبه کند.","segment_columns":[{"kind":"word","token":"انه","display":"انه"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الرجل","display":"الرَّجُلِ"},{"kind":"word","token":"يقتل","display":"يَقْتُلُ"},{"kind":"word","token":"مملوكه","display":"مَمْلُوكَهُ"},{"kind":"word","token":"متعمدا","display":"مُتَعَمِّداً"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعجبني","display":"يُعْجِبُنِي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يعتق","display":"يُعْتِقَ"},{"kind":"word","token":"رقبه","display":"رَقَبَةً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يصوم","display":"يَصُومَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"شهرين","display":"شَهْرَيْنِ"},{"kind":"word","token":"متتابعين","display":"مُتَتٰابِعَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۹۲","display":"۹۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يطعم","display":"يُطْعِمَ"},{"kind":"word","token":"ستين","display":"سِتِّينَ"},{"kind":"word","token":"مسكينا","display":"مِسْكِيناً"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind"