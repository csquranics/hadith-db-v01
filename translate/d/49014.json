{"consensus_set_id":"49014","translation_language":"fa","translation_source":{"hid":"367573"},"segments":[{"source_hadith_segment":"اِنَّ اَلذَّنْبَ يَحْرِمُ الْعَبْدَ الرِّزْقَ وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ -  <quranic_text> « اِنّٰا بَلَوْنٰاهُمْ كَمٰا بَلَوْنٰا اَصْحٰابَ الْجَنَّةِ » </quranic_text>   <footnote> [ القلم ۱۷ ] </footnote>   .","translation_segment":"امام صادق علیه السلام فرمود: گناه مانع رسیدن روزی به بنده می‌شود، و این اشاره به قول خداوند عز و جل است که: (ما آنان را به سختی آزمودیم چنان که باغداران را آزمودیم).","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الذنب","display":"اَلذَّنْبَ"},{"kind":"word","token":"يحرم","display":"يَحْرِمُ"},{"kind":"word","token":"العبد","display":"الْعَبْدَ"},{"kind":"word","token":"الرزق","display":"الرِّزْقَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"بلوناهم","display":"بَلَوْنٰاهُمْ"},{"kind":"word","token":"كما","display":"كَمٰا"},{"kind":"word","token":"بلونا","display":"بَلَوْنٰا"},{"kind":"word","token":"اصحاب","display":"اَصْحٰابَ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القلم","display":"القلم"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"}]}]}