{"consensus_set_id":"s351326","translation_language":"fa","translation_source":{"hid":"351326"},"segments":[{"source_hadith_segment":"مَنْ لَبِسَ نَعْلاً اَصْفَرَ لَمْ يَزَلْ يَنْظُرُ فِي سُرُورٍ مَا دَامَتْ عَلَيْهِ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ  <quranic_text> « صَفْرٰاءُ فٰاقِعٌ لَوْنُهٰا تَسُرُّ النّٰاظِرِينَ » </quranic_text>   <footnote> [ البقرة ۶۹ ] </footnote>   .","translation_segment":"امام باقر علیه السلام فرموده‌اند: هرکه کفش زردرنگ بپوشد پیوسته شادمان باشد؛ چرا که خداوند در قرآن فرموده است: «صفرٰاء فٰاقع‌ لونهٰا تسر النٰاظرین‌»","segment_columns":[{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"لبس","display":"لَبِسَ"},{"kind":"word","token":"نعلا","display":"نَعْلاً"},{"kind":"word","token":"اصفر","display":"اَصْفَرَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يزل","display":"يَزَلْ"},{"kind":"word","token":"ينظر","display":"يَنْظُرُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"سرور","display":"سُرُورٍ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"دامت","display":"دَامَتْ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"لان","display":"لِاَنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"صفراء","display":"صَفْرٰاءُ"},{"kind":"word","token":"فاقع","display":"فٰاقِعٌ"},{"kind":"word","token":"لونها","display":"لَوْنُهٰا"},{"kind":"word","token":"تسر","display":"تَسُرُّ"},{"kind":"word","token":"الناظرين","display":"النّٰاظِرِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۶۹","display":"۶۹"},{"kind":"tag_close","tag_name":"footnote"}]}