{"consensus_set_id":"21946","translation_language":"fa","translation_source":{"hid":"406043"},"segments":[{"source_hadith_segment":"« قَامَ خِدَاشٌ وَ سَعِيدٌ اَخُو عَمْرِو بْنِ عَبْدِ وُدٍّّّ ،  فَقَالاَ :  وَ مَا يُسَيِّرُنَا عَلَي اَرْبَعَةِ اَشْهُرٍ ،  بَلْ بَرِئْنَا مِنْكَ وَ مِنِ اِبْنِ عَمِّكَ ،  وَ لَيْسَ بَيْنَنَا وَ بَيْنَ اِبْنِ عَمِّكَ اِلاَّ السَّيْفُ وَ الرُّمْحُ ،  وَ اِنْ شِئْتَ بَدَاْنَا بِكَ .  فَقَالَ عَلِيٌّ ( عَلَيْهِ السَّلاَمُ ) :  هَلُمُّوا ،  ثُمَّ قَالَ :   <quranic_text> « وَ اِعْلَمُوا اَنَّكُمْ غَيْرُ مُعْجِزِي اللّٰهِ » </quranic_text>   <footnote> [ التوبة ۲ ] </footnote> اِلَي قَوْلِهِ :   <quranic_text> « اِليٰ مُدَّتِهِمْ » </quranic_text>   <footnote> [ التوبة ۴ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قام","display":"قَامَ"},{"kind":"word","token":"خداش","display":"خِدَاشٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سعيد","display":"سَعِيدٌ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"وصل","display":"وَصَلَ"},{"kind":"word","token":"مولانا","display":"مَوْلاَنَا"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"المشركين","display":"الْمُشْرِكِينَ"},{"kind":"word","token":"بايات","display":"بِايَاتِ"},{"kind":"word","token":"براءه","display":"بَرَاءَةَ"},{"kind":"word","token":"لقيه","display":"لَقِيَهُ"},{"kind":"word","token":"خراش","display":"خِرَاشُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"اخو","display":"اَخُو"},{"kind":"word","token":"عمرو","display":"عَمْرِو"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"عبد","display":"عبد"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token