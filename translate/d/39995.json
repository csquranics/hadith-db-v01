{"consensus_set_id":"39995","translation_language":"fa","translation_source":{"hid":"85436"},"segments":[{"source_hadith_segment":"« صَلاَةُ اَلنَّافِلَةِ ثَمَانُ رَكَعَاتٍ حِينَ تَزُولُ الشَّمْسُ قَبْلَ الظُّهْرِ وَ سِتُّ رَكَعَاتٍ بَعْدَ الظُّهْرِ وَ رَكْعَتَانِ قَبْلَ الْعَصْرِ وَ اَرْبَعُ رَكَعَاتٍ بَعْدَ الْمَغْرِبِ وَ رَكْعَتَانِ بَعْدَ الْعِشَاءِ الْاخِرَةِ تَقْرَاُ فِيهِمَا مِائَةَ ايَةٍ قَائِماً اَوْ قَاعِداً وَ الْقِيَامُ اَفْضَلُ وَ لاَ تَعُدُّهُمَا مِنَ الْخَمْسِينَ وَ ثَمَانُ رَكَعَاتٍ مِنْ اخِرِ اللَّيْلِ تَقْرَاُ فِي صَلاَةِ اللَّيْلِ بِ‍  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>  وَ  <quranic_text> « قُلْ يٰا اَيُّهَا الْكٰافِرُونَ » </quranic_text>   <footnote> [ الكافرون ۱ ] </footnote>  فِي الرَّكْعَتَيْنِ الْاَوَّلَتَيْنِ وَ تَقْرَاُ فِي سَائِرِهَا مَا اَحْبَبْتَ مِنَ الْقُرْانِ ثُمَّ الْوَتْرُ ثَلاَثُ رَكَعَاتٍ تَقْرَاُ فِيهَا جَمِيعاً  <quranic_text> « قُلْ هُوَ اللّٰهُ اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote> وَ تَفْصِلُ بَيْنَهُنَّ بِتَسْلِيمٍ ثُمَّ الرَّكْعَتَانِ اللَّتَانِ قَبْلَ الْفَجْرِ تَقْرَاُ فِي الْاُولَي مِنْهُمَا -  <quranic_text> « قُلْ يٰا اَيُّهَا الْكٰافِرُونَ » </quranic_text>   <footnote> [ الكافرون ۱ ] </footnote> وَ فِي الثَّانِيَةِ  <quranic_text> « قُلْ هُوَ اللّٰهُ » </quranic_text>   <footnote> [ الاخلاص ۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صلاه","display":"صَلاَةُ"},{"kind":"word","token":"النافله","display":"اَلنَّافِلَةِ"},{"kind":"word","token":"ثمان","display":"ثَمَانُ"},{"kind":"word","token":"ركعات","display":"رَكَعَاتٍ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"تزول","display":"تَزُولُ"},{"kind":"word","token":"الشمس","display":"الشَّمْسُ"},{"kind":"word","token":"قبل","display":"قَبْلَ"},{"kind":"word","token":"الظهر","display":"الظُّهْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"س