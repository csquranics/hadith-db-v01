{"consensus_set_id":"7723","translation_language":"fa","translation_source":{"hid":"106386"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « فَمَنْ كٰانَ يَرْجُوا لِقٰاءَ رَبِّهِ فَلْيَعْمَلْ عَمَلاً صٰالِحاً وَ لاٰ يُشْرِكْ بِعِبٰادَةِ رَبِّهِ اَحَداً » </quranic_text>   <footnote> [ الكهف ۱۱۰ ] </footnote>","translation_segment":"امام صادق علیه السلام در باره قول خدای عز و جل: «هر که امید لقاء پروردگارش را دارد باید عملی صالح کند و در عبادت پروردگارش هیچ کس را شریک نسازد ۱۱۰ سوره ۱۸»","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فمن","display":"فَمَنْ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"يرجوا","display":"يَرْجُوا"},{"kind":"word","token":"لقاء","display":"لِقٰاءَ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},{"kind":"word","token":"فليعمل","display":"فَلْيَعْمَلْ"},{"kind":"word","token":"عملا","display":"عَمَلاً"},{"kind":"word","token":"صالحا","display":"صٰالِحاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يشرك","display":"يُشْرِكْ"},{"kind":"word","token":"بعباده","display":"بِعِبٰادَةِ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},{"kind":"word","token":"احدا","display":"اَحَداً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الكهف","display":"الكهف"},{"kind":"word","token":"۱۱۰","display":"۱۱۰"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ الرَّجُلُ يَعْمَلُ شَيْئاً مِنَ الثَّوَابِ لاَ يَطْلُبُ بِهِ وَجْهَ اللَّهِ اِنَّمَا يَطْلُبُ تَزْكِيَةَ النَّاسِ يَشْتَهِي اَنْ يُسْمِعَ بِهِ النَّاسَ فَهَذَا الَّذِي اَشْرَكَ بِعِبَادَةِ رَبِّهِ ثُمَّ قَالَ مَا مِنْ عَبْدٍ اَسَرَّ خَيْراً فَذَهَبَتِ الْاَيَّامُ اَبَداً حَتَّي يُظْهِرَ اللَّهُ لَهُ خَيْراً وَ مَا مِنْ عَبْدٍ يُسِرُّ شَرّاً فَذَهَبَتِ الْاَيَّامُ اَبَداً حَتَّي يُظْهِرَ اللَّهُ لَهُ شَرّاً .","translation_segment":"فرمود: شخصی کار ثوابی میکند و مقصودش خدا نیست، بلکه میخواهد مردم بشنوند و او را بستایند، اینست کسی که در عبادت پروردگارش شریک می‌آورد، سپس فرمود: هرگز نباشد بنده‌ئی که در نهان کار خیری کند و روزگار بگذرد، جز آنکه خدا برایش خیری ظاهر سازد، و هرگز بنده‌ئی نباشد که در نهان شری کند و روزگار بگذرد، جز آنکه خدا برایش شری آشکار کند.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"يعمل","display":"يَعْمَلُ"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الثواب","display":"الثَّوَابِ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يطلب","display":"يَطْلُبُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"وجه","display":"وَجْهَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"يطلب","display":"يَطْلُبُ"},{"kind":"word","token":"تزكيه","display":"تَزْكِيَةَ"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"word","token":"يشتهي","display":"يَشْتَهِي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يسمع","display":"يُسْمِعَ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"الناس","display":"النَّاسَ"},{"kind":"word","token":"فهذا","display":"فَهَذَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"اشرك","display":"اَشْرَكَ"},{"kind":"word","token":"بعباده","display":"بِعِبَادَةِ"},{"kind":"word","token":"ربه","display":"رَبِّهِ"},