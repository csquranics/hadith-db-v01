{"consensus_set_id":"s406167","translation_language":"fa","translation_source":{"hid":"406167"},"segments":[{"source_hadith_segment":"قُلْتُ لَهُ :  قَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « هَلْ تَرَبَّصُونَ بِنٰا اِلاّٰ اِحْدَي الْحُسْنَيَيْنِ » </quranic_text>   <footnote> [ التوبة ۵۲ ] </footnote>   ؟  قَالَ :","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هل","display":"هَلْ"},{"kind":"word","token":"تربصون","display":"تَرَبَّصُونَ"},{"kind":"word","token":"بنا","display":"بِنٰا"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"احدي","display":"اِحْدَي"},{"kind":"word","token":"الحسنيين","display":"الْحُسْنَيَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۵۲","display":"۵۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"« اِمَّا مَوْتٌ فِي طَاعَةِ اللَّهِ ،  اَوْ اِدْرَاكُ ظُهُورِ اِمَامٍ  <quranic_text> « وَ نَحْنُ نَتَرَبَّصُ بِكُمْ » </quranic_text>   <footnote> [ التوبة ۵۲ ] </footnote>  مَعَ مَا نَحْنُ فِيهِ مِنَ الْمَشَقَّةِ <quranic_text> « اَنْ يُصِيبَكُمُ اللّٰهُ بِعَذٰابٍ مِنْ عِنْدِهِ » </quranic_text>   <footnote> [ التوبة ۵۲ ] </footnote>  - قَالَ :  - هُوَ الْمَسْخُ  <quranic_text> « اَوْ بِاَيْدِينٰا » </quranic_text>   <footnote> [ التوبة ۵۲ ] </footnote>  وَ هُوَ الْقَتْلُ ،  قَالَ اللَّهُ عَزَّ وَ جَلَّ لِنَبِيِّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :   <quranic_text> « فَتَرَبَّصُوا اِنّٰا مَعَكُمْ مُتَرَبِّصُونَ » </quranic_text>   <footnote> [ التوبة ۵۲ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"اما","display":"اِمَّا"},{"kind":"word","token":"موت","display":"مَوْتٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"طاعه","display":"طَاعَةِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"ادراك","display":"اِدْرَاكُ"},{"kind":"word","token":"ظهور","display":"ظُهُورِ"},{"kind":"word","token":"امام","display":"اِمَامٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"نتربص","display":"نَتَرَبَّصُ"},{"kind":"word","token":"بكم","display":"بِكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۵۲","display":"۵۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"نحن","display":"نَحْنُ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المشقه","display":"الْمَشَقَّةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يصيبكم","display":"يُصِيبَكُمُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"بعذاب","display":"بِعَذٰابٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عنده","display":"عِنْدِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۵۲","display":"۵۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token