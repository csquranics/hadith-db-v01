نیئا لا أظمأ بعده أبدا إنک علی کل‌ شیء قدیر اللهم‌ کما آمنت بمحمد و لم أره فعرفنی فی الجنان وجهه اللهم‌ بلغ روح محمد عنی تحیه کثیره و سلاما». به راستی، هر که با این صلوات","segment_columns":[{"kind":"word","token":"دعاء","display":"دُعَاءٌ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"شرك","display":"شَرَّكَ"},{"kind":"word","token":"ال","display":"الَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"صل","display":"صَلِّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الاولين","display":"الْاَوَّلِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صل","display":"صَلِّ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":