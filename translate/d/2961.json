{"consensus_set_id":"2961","translation_language":"fa","translation_source":{"hid":"91410"},"segments":[{"source_hadith_segment":"وَ اِبْنِ اَبِي عُمَيْرٍ عَنْ حَمَّادٍ عَنِ الْحَلَبِيِّ عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ اَنَّهُمَا قَالاَ :  فِي الرَّجُلِ يَكُونُ عَلَيْهِ الدَّيْنُ اِلَي اَجَلٍ مُسَمًّي فَيَاْتِيهِ غَرِيمُهُ فَيَقُولُ اُنْقُدْ لِي مِنَ الَّذِي لِي كَذَا وَ كَذَا وَ اَضَعُ عَنْكَ بَقِيَّتَهُ اَوْ يَقُولُ اُنْقُدْ لِي بَعْضاً وَ اُمُدُّ لَكَ فِي الْاَجَلِ فِيمَا","translation_segment":"* *۶ - به ابو جعفر باقر (ع) و ابو عبد الله صادق (ع) گفتند: اگر انسان مبلغی با سررسید معین بدهکار باشد و طلبکار او بگوید: ده درصد آن را کم می‌کنم با این شرط‍‌ که مابقی را نقدا بپردازی و یا بگوید: پنجاه درصد آن را بپرداز و من به سررسید مابقی یک ماه می‌افزایم. این صلح و سازش چه صورت دارد؟","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"ابن","display":"اِبْنِ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عمير","display":"عُمَيْرٍ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"حماد","display":"حَمَّادٍ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الحلبي","display":"الْحَلَبِيِّ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"انهما","display":"اَنَّهُمَا"},{"kind":"word","token":"قالا","display":"قَالاَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الرجل","display":"الرَّجُلِ"},{"kind":"word","token":"يكون","display":"يَكُونُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"الدين","display":"الدَّيْنُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"