{"consensus_set_id":"39451","translation_language":"fa","translation_source":{"hid":"412507"},"segments":[{"source_hadith_segment":"« اَللَّهُ رَاضٍ عَنِ الْمُؤْمِنِ فِي الدُّنْيَا وَ الْاخِرَةِ ،  وَ الْمُؤْمِنِ وَ اِنْ كَانَ رَاضِياً عَنِ اللَّهِ فَاِنَّ فِي قَلْبِهِ مَا فِيهِ ،  لِمَا يَرَي فِي هَذِهِ الدُّنْيَا مِنَ التَّمْحِيصِ ،  فَاِذَا عَايَنَ الثَّوَابَ يَوْمَ الْقِيَامَةِ رَضِيَ عَنِ اللَّهِ الْحَقِّ حَقَّ الرِّضَا ،  وَ هُوَ قَوْلُهُ :   <quranic_text> « وَ رَضُوا عَنْهُ » </quranic_text>   <footnote> [ البينة ۸ ] </footnote> ،  وَ قَوْلُهُ :   <quranic_text> « ذٰلِكَ لِمَنْ خَشِيَ رَبَّهُ » </quranic_text>   <footnote> [ البينة ۸ ] </footnote>  اَيْ اَطَاعَ رَبَّهُ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"راض","display":"رَاضٍ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الدنيا","display":"الدُّنْيَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الاخره","display":"الْاخِرَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"راضيا","display":"رَاضِياً"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قلبه","display":"قَلْبِهِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"لما","display":"لِمَا"},{"kind":"word","token":"يري","display":"يَرَي"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الدنيا","display":"ال