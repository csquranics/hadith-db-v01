{"consensus_set_id":"33288","translation_language":"fa","translation_source":{"hid":"98446"},"segments":[{"source_hadith_segment":"« مَا مِنْ عَبْدٍ مُؤْمِنٍ زَارَ قَبْرَ مُؤْمِنٍ فَقَرَاَ عِنْدَهُ  <quranic_text> « اِنّٰا اَنْزَلْنٰاهُ فِي لَيْلَةِ الْقَدْرِ » </quranic_text>   <footnote> [ القدر ۱ ] </footnote>  سَبْعَ مَرَّاتٍ اِلاَّ غَفَرَ اللَّهُ لَهُ وَ لِصَاحِبِ الْقَبْرِ » .","translation_segment":"حضرت رضا علیه السلام فرمود: هیچ بنده [مومنی] نیست که قبر مومنی را زیارت کند و در کنار قبر او هفت بار سوره «إنا انزلناه فی لیله القدر» را بخواند مگر اینکه خداوند او را و صاحب آن قبر را می‌آمرزد.","segment_columns":[{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عبد","display":"عَبْدٍ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٍ"},{"kind":"word","token":"زار","display":"زَارَ"},{"kind":"word","token":"قبر","display":"قَبْرَ"},{"kind":"word","token":"مؤمن","display":"مُؤْمِنٍ"},{"kind":"word","token":"فقرا","display":"فَقَرَاَ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"انزلناه","display":"اَنْزَلْنٰاهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ليله","display":"لَيْلَةِ"},{"kind":"word","token":"القدر","display":"الْقَدْرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القدر","display":"القدر"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"غفر","display":"غَفَرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لصاحب","display":"لِصَاحِبِ"},{"kind":