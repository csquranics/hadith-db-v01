{"consensus_set_id":"s332200","translation_language":"fa","translation_source":{"hid":"332200"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « وَ السّٰابِقُونَ السّٰابِقُونَ » </quranic_text>   <footnote> [ الواقعة ۱۰ ] </footnote>  قَالَ :  يُوشَعُ بْنُ نُونٍ اِلَي مُوسَي وَ شَمْعُونُ بْنُ يُوحَنَّا اِلَي عِيسَي  ،  وَ عَلِيُّ بْنُ اَبِي طَالِبٍ اِلَي النَّبِيِّ  .","translation_segment":"عن ابن عباس فی قوله تعالی: (و السابقون السابقون أولئک المقربون قال: نزلت فی علی ع. ابن عباس گفت: «السابقون السابقون اولئک المقربون» درباره علی نازل شده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الواقعه","display":"الواقعة"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يوشع","display":"يُوشَعُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"نون","display":"نُونٍ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شمعون","display":"شَمْعُونُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"يوحنا","display":"يُوحَنَّا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"عيسي","display":"عِيسَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب