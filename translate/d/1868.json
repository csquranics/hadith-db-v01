مُ اللَّهُ  <quranic_text> « بِغَيْظِهِمْ لَمْ يَنٰالُوا خَيْراً » </quranic_text>   <footnote> [ الاحزاب ۲۵ ] </footnote>  وَ اَنْزَلَ اللَّهُ عَزَّ وَ جَلَّ فِي الْقُرْانِ ايَتَيْنِ فِي سُورَةِ الْاَحْزَابِ فَسَمَّي اَبَا سُفْيَانَ وَ اَصْحَابَهُ كُفَّاراً وَ مُعَاوِيَةُ مُشْرِكٌ عَدُوٌّ لِلَّهِ وَ لِرَسُولِهِ وَ الْخَامِسَةُ يَوْمَ الْحُدَيْبِيَةِ","translation_segment":"شما عزی ندارید در پاسخش فرمود خدا مولا و یاور ماست و شما مولا و یاور ندارید. چهارم-در روز جنگ خندق بود که ابو سفیان با همه افراد قریش برای نبرد با پیغمبر آمده بود و خدا آنها را نومید و خشمناک و دست خالی برگردانید و دو آیه در سوره احزاب فرستاد و ابو سفیان و یارانش را کفار نامید و معاویه را مشرک و دشمن خدا و پیغمبرش","segment_columns":[{"kind":"word","token":"مولي","display":"مَوْلَي"},{"kind":"word","token":"لكم","display":"لَكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرابعه","display":"الرَّابِعَةُ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"الخندق","display":"الْخَنْدَقِ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"جاء","display":"جَاءَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"سفيان","display":"سُفْيَانَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"جمع","display":"جَمْعِ"},{"kind":"word","token":"قريش","display":"قُرَيْشٍ"},{"kind":"word","token":"فردهم","display":"فَرَدَّهُمُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بغيظهم","display":"بِغَيْظِهِمْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"ينالوا","display":"يَنٰالُوا"},{"kind":"word","token":"خيرا","display":"خَيْراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحزاب","display":"الاحزاب"},{"kind":"word","token":"۲۵","display":"۲۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"