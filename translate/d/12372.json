{"consensus_set_id":"12372","translation_language":"fa","translation_source":{"hid":"323864"},"segments":[{"source_hadith_segment":"زُرَارَةُ وَ اَبُو بَصِيرٍ وَ مُحَمَّدُ بْنُ مُسْلِمٍ وَ بُرَيْدٌ مِنَ الَّذِينَ قَالَ اللَّهُ تَعَالَي  <quranic_text> « وَ السّٰابِقُونَ السّٰابِقُونَ اُولٰئِكَ الْمُقَرَّبُونَ » </quranic_text>   <footnote> [ الواقعة ۱۰ ] </footnote>   .","translation_segment":"امام صادق (علیه السلام) فرموده است: زراره و ابو بصیر و محمد بن مسلم و برید از کسانی هستند که خداوند متعال فرموده است: «آنان که در ایمان بر همگان پیشی گرفتند آنان به حقیقت مقربان درگاهند.»","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"ابو","display":"أبو"},{"kind":"word","token":"عبد","display":"عبد"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السلام"},{"kind":"word","token":"زراره","display":"زُرَارَةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"بصير","display":"بَصِيرٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"مسلم","display":"مُسْلِمٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بريد","display":"بُرَيْدٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"word","token":"السابقون","display":"السّٰابِقُونَ"},{"kind":"word","token":"اولئك","display":"اُولٰئِكَ"},{"kind":"word","token":"المقربون","display":"الْمُقَرَّبُونَ"},{"kind":"tag_close","tag_name":"quranic_text