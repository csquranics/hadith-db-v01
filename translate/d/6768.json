":"","segment_columns":[]},{"source_hadith_segment":"ثُمَّ قَالَ يَا بُرَيْدَةُ اَ تَرَي لِعَلِيٍّ مِنَ الْحَقِّ عَلَيْكُمْ مَعَاشِرَ الْمُسْلِمِينَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اَلاَّ تُكَايِدُوهُ وَ لاَ تُعَانِدُوهُ وَ لاَ تُزَايِدُوهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"هَيْهَاتَ اِنَّ قَدْرَ عَلِيٍّ عِنْدَ اللَّهِ اَعْظَمُ مِنْ قَدْرِهِ عِنْدَكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اَ وَ لاَ اُخْبِرُكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالُوا بَلَي يَا رَسُولَ اللَّهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ فَاِنَّ اللَّهَ يَبْعَثُ يَوْمَ الْقِيَامَةِ اَقْوَاماً يَمْتَلِئُ مِنْ جِهَةِ السَّيِّئَاتِ مَوَازِينُهُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَيُقَالُ لَهُمْ هَذِهِ السَّيِّئَاتُ فَاَيْنَ الْحَسَنَاتُ وَ اِلاَّ فَقَدْ عَصَيْتُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَيَقُولُونَ يَا رَبَّنَا مَا نَعْرِفُ لَنَا حَسَنَاتٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاِذَا النِّدَاءُ مِنْ قِبَلِ اللَّهِ عَزَّ وَ جَلَّ لَئِنْ لَمْ تَعْرِفُوا لِاَنْفُسِكُمْ عِبَادِي حَسَنَاتٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَاِنِّي اَعْرِفُهَا لَكُمْ وَ اُوَفِّرُهَا عَلَيْكُمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ثُمَّ يَاْتِي بِرُقْعَةٍ صَغِيرَةٍ يَطْرَحُهَا فِي كِفَّةِ حَسَنَاتِهِمْ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَتَرْجَحُ بِسَيِّئَاتِهِمْ بِاَكْثَرَ مِمَّا بَيْنَ السَّمَاءِ اِلَي الْاَرْضِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَيُقَالُ لِاَحَدِهِمْ خُذْ بِيَدِ اَبِيكَ وَ اُمِّكَ وَ اِخْوَانِكَ وَ اَخَوَاتِكَ وَ خَاصَّتِكَ وَ قَرَابَاتِكَ وَ اَخْدَامِكَ وَ مَعَارِفِ