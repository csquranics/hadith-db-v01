{"consensus_set_id":"s347224","translation_language":"fa","translation_source":{"hid":"347224"},"segments":[{"source_hadith_segment":"اِنَّ اَصْحَابَ طَالُوتَ اُبْتُلُوا بِالنَّهَرِ الَّذِي قَالَ اللَّهُ تَعَالَي-  <quranic_text> « مُبْتَلِيكُمْ بِنَهَرٍ » </quranic_text>   <footnote> [ البقرة ۲۴۹ ] </footnote>  وَ اِنَّ اَصْحَابَ الْقَائِمِ عَلَيْهِ السَّلاَمُ يُبْتَلَوْنَ بِمِثْلِ ذَلِكَ .","translation_segment":"ابو بصیر از امام صادق علیه السلام روایت کرده که فرمود: «همانا اصحاب طالوت به رودی که خدای تعالی فرمود: «مبتلیکم‌ بنهر» - الآیه «به زودی شما را به رودی خواهیم آزمود» مورد آزمایش قرار گرفتند، و اصحاب قائم علیه السلام نیز به همانند آن آزمایش مبتلا خواهند شد» (لفظ‍‌ آیه «إن‌ اللٰه‌ مبتلیکم‌» است).","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابَ"},{"kind":"word","token":"طالوت","display":"طَالُوتَ"},{"kind":"word","token":"ابتلوا","display":"اُبْتُلُوا"},{"kind":"word","token":"بالنهر","display":"بِالنَّهَرِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي-","display":"تَعَالَي-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"مبتليكم","display":"مُبْتَلِيكُمْ"},{"kind":"word","token":"بنهر","display":"بِنَهَرٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۴۹","display":"۲۴۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابَ"},{"kind":"word","token":"القائم","display":"الْقَائِمِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"يبتلون","display":"يُبْتَلَوْنَ"},{"kind":"word","token":"بمثل","display":