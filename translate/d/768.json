{"consensus_set_id":"768","translation_language":"fa","translation_source":{"hid":"331825"},"segments":[{"source_hadith_segment":"سَمِعْتُ اَبَا ذَرٍّ يُقْسِمُ قَسَماً - اَنَّ [ قَوْلَهُ تَعَالَي ]  <quranic_text> « هٰذٰانِ خَصْمٰانِ اِخْتَصَمُوا فِي رَبِّهِمْ » </quranic_text>   <footnote> [ الحج ۱۹ ] </footnote>  نَزَلَتْ فِي الَّذِينَ بَرَزُوا يَوْمَ بَدْرٍ ،  حَمْزَةَ وَ عَلِيٍّ وَ عُبَيْدَةَ بْنِ الْحَرْثِ وَ عُتْبَةَ وَ شَيْبَةَ وَ الْوَلِيدِ بْنِ عُتْبَةَ .","translation_segment":"با سلسله سند دیگر از قیس بن عباده نقل شده است که گفت از ابو ذر شنیدم سوگند یاد کرد، آیه شریفه «هٰذٰان‌ خصمٰان‌ اختصموا فی ربهم‌» در باره متخاصمین جنگ بدر نازل شد. که علی علیه السلام حمزه و ابو عبیده با مشرکان به نبرد پرداختند و سرانجام سه نفر مبارزان مشرک با شمشیر سه تن از دلاوران اسلام به هلاکت رسیدند.","segment_columns":[{"kind":"word","token":"سمعت","display":"سَمِعْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"ذر","display":"ذَرٍّ"},{"kind":"word","token":"يقسم","display":"يُقْسِمُ"},{"kind":"word","token":"قسما","display":"قَسَماً"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"قوله","display":"قَوْلَهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"هذان","display":"هٰذٰانِ"},{"kind":"word","token":"خصمان","display":"خَصْمٰانِ"},{"kind":"word","token":"اختصموا","display":"اِخْتَصَمُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ربهم","display":"رَبِّهِمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۱۹","display":"۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بالاسناد","display":"بِالْاِسْنَادِ"},{"kind":"word","token":"المقدم","display":"الْمُقَدَّمِ"},{"kind":"word","token":"قال","display":"قَا