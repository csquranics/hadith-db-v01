{"consensus_set_id":"s292313","translation_language":"fa","translation_source":{"hid":"292313"},"segments":[{"source_hadith_segment":"وَ كَانَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ يَقُولُ فِي دُعَائِهِ اللَّهُمَّ اِغْفِرْ لِي كُلَّ ذَنْبٍ عَلَيَّ  <quranic_text> « اِنَّكَ اَنْتَ التَّوّٰابُ الرَّحِيمُ » </quranic_text>   <footnote> [ البقرة ۱۲۸ ] </footnote>   .","translation_segment":"و حضرت رسول صلی اللٰه علیه و آله میفرمود در دعایش: اللهم‌ اغفر لی کل ذنب و تب علی‌ انک أنت التواب الرحیم. بار پروردگارا بیامرز برای من تمام گناهان را و بپذیر توبه مرا همانا تو پذیرنده‌ای مهربانی.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"دعائه","display":"دُعَائِهِ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"اغفر","display":"اِغْفِرْ"},{"kind":"word","token":"لي","display":"لِي"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"ذنب","display":"ذَنْبٍ"},{"kind":"word","token":"علي","display":"عَلَيَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انك","display":"اِنَّكَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"التواب","display":"التَّوّٰابُ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۲۸","display":"۱۲۸"},{"kind":"tag_close","tag_name":"footnote"}]}]}