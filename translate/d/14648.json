وده که خلاق و آفریننده‌اند و هر گاه حق‌ عز و جل‌ اراده کرد موجودی را بیافریند به آن دو فرشته امر می‌کند. پس آن دو فرشته از آن تربتی که حق‌ عز و جل‌ به آن اشاره کرده و فرموده: «منهٰا خلقنٰاکم‌ و فیهٰا نعیدکم‌ و منهٰا نخرجکم‌ تٰاره‌ أخریٰ‌» (از آن خاک شما را آفریده و به آن شما را باز گردانده و بار دیگر شما را از آن بیرون می‌آوریم) مقداری برداشته پس آن را با نطفه‌ای که در رحم قرار می‌گیرد عجین می‌نمایند و","segment_columns":[{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"اعلي","display":"اَعْلَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اخلص","display":"اَخْلَصُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يبعث","display":"يَبْعَثَ"},{"kind":"word","token":"اشياء","display":"اَشْيَاءَ"},{"kind":"word","token":"بيده","display":"بِيَدِهِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ملكين","display":"مَلَكَيْنِ"},{"kind":"word","token":"خلاقين","display":"خَلاَّقَيْنِ"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"اراد","display":"اَرَادَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يخلق","display":"يَخْلُقَ"},{"kind":"word","token":"خلقا","display":"خَلْقاً"},{"kind":"word","token":"امر","display":"اَمَرَ"},{"kind":"word","token":"اولئك","display":"اُولَئِكَ"},{"kind":"word","token":"الخلاقين","display":"الْخَلاَّقِينَ"},{"kind":"word","token":"فاخذوا","