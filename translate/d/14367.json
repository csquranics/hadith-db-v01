{"consensus_set_id":"14367","translation_language":"fa","translation_source":{"hid":"338275"},"segments":[{"source_hadith_segment":"سُمِّيَتْ مَكَّةُ مَكَّةَ لِاَنَّ النَّاسَ كَانُوا يَمْكُونَ فِيهَا وَ كَانَ يُقَالُ لِمَنْ قَصَدَهَا قَدْ مَكَا وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ مٰا كٰانَ صَلاٰتُهُمْ عِنْدَ الْبَيْتِ اِلاّٰ مُكٰاءً وَ تَصْدِيَةً » </quranic_text>   <footnote> [ الانفال ۳۵ ] </footnote>  فَالْمُكَاءُ التَّصْفِيرُ وَ التَّصْدِيَةُ صَفْقُ الْيَدَيْنِ .","translation_segment":"علی بن احمد بن محمد رضی اللٰه عنه از محمد بن ابی عبد اللٰه کوفی، از محمد بن اسماعیل برمکی از علی بن عباس از قاسم بن ربیع صحاف، از محمد بن سنان نقل کرده که وی گفت: حضرت ابا الحسن الرضا علیه السلام در جواب مسائل وی مرقوم فرمودند: مکه را از این جهت مکه نامیده‌اند که مردم در آن جا فریاد می‌زدند و هر کسی که آن جا را قصد می‌کرد می‌گفتند فلانی فریاد کشید و به همین معنا آمده است فرموده حق تعالی در قرآن شریف: «و مٰا کٰان‌ صلاٰتهم‌ عند البیت‌ إلاٰ مکٰاء و تصدیه‌» (نمازشان در بیت اللٰه چیزی غیر از فریاد و کف زدن نبود) پس «مکاء» تصفیر و فریاد باشد و «تصدیه» کف زدن را گویند.","segment_columns":[{"kind":"word","token":"علل","display":"علل"},{"kind":"word","token":"الشرائع","display":"الشرائع"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"كتب","display":"كَتَبَ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"فيما","display":"فِيمَا"},{"kind":"word","token":"كتب","display":"كَتَبَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"جواب","display":"جَوَابِ"},{"kind":"word","token":"مسائله","display":"مَسَا