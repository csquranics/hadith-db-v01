{"consensus_set_id":"s393818","translation_language":"fa","translation_source":{"hid":"393818"},"segments":[{"source_hadith_segment":"وَ اَمَّا قَوْلُهُ فِي يُوسُفَ عَلَيْهِ السَّلاَمُ :  وَ  <quranic_text> « لَقَدْ هَمَّتْ بِهِ وَ هَمَّ بِهٰا » </quranic_text>   <footnote> [ يوسف ۲۴ ] </footnote>  فَاِنَّهَا هَمَّتْ بِالْمَعْصِيَةِ وَ هَمَّ يُوسُفُ بِقَتْلِهَا اِنْ اَجْبَرَتْهُ لِعِظَمِ مَا تَدَاخَلَهُ ،  فَصَرَفَ اللَّهُ عَنْهُ قَتْلَهَا وَ الْفَاحِشَةَ ،  وَ هُوَ قَوْلُهُ :   <quranic_text> « كَذٰلِكَ لِنَصْرِفَ عَنْهُ السُّوءَ وَ الْفَحْشٰاءَ » </quranic_text>   <footnote> [ يوسف ۲۴ ] </footnote>  يَعْنِي الْقَتْلَ وَ الزِّنَا .","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"يوسف","display":"يُوسُفَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"همت","display":"هَمَّتْ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هَمَّ"},{"kind":"word","token":"بها","display":"بِهٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فانها","display":"فَاِنَّهَا"},{"kind":"word","token":"همت","display":"هَمَّتْ"},{"kind":"word","token":"بالمعصيه","display":"بِالْمَعْصِيَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هَمَّ"},{"kind":"word","token":"يوسف","display":"يُوسُفُ"},{"kind":"word","token":"بقتلها","display":"بِقَتْلِهَا"},{"ki