{"consensus_set_id":"s369908","translation_language":"fa","translation_source":{"hid":"369908"},"segments":[{"source_hadith_segment":"اَللَّهُمَّ اَنْتَ اللَّهُ  <quranic_text> « الْحَيُّ الْقَيُّومُ » </quranic_text>   <footnote> [ البقرة ۲۵۵ ] </footnote>  الْخَالِقُ الرَّازِقُ الْمُحْيِي الْمُمِيتُ الْبَدِيءُ الْبَدِيعُ لَكَ الْكَرَمُ وَ لَكَ [ اَلْحَمْدُ ] الْمَجْدُ وَ لَكَ الْمَنُّ وَ لَكَ الْجُودُ وَ لَكَ الْاَمْرُ وَحْدَكَ لاَ شَرِيكَ لَكَ يَا وَاحِدُ يَا اَحَدُ يَا فَرْدُ يَا صَمَدُ يَا مَنْ  <quranic_text> « لَمْ يَلِدْ وَ لَمْ يُولَدْ وَ لَمْ يَكُنْ لَهُ كُفُواً اَحَدٌ » </quranic_text>   <footnote> [ الاخلاص ۳ ] </footnote>  صَلِّ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ وَ اِفْعَلْ بِي كَذَا وَ كَذَا وَ سَلْ حَاجَتَكَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"اللهم","display":"اَللَّهُمَّ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الحي","display":"الْحَيُّ"},{"kind":"word","token":"القيوم","display":"الْقَيُّومُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۵۵","display":"۲۵۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الخالق","display":"الْخَالِقُ"},{"kind":"word","token":"الرازق","display":"الرَّازِقُ"},{"kind":"word","token":"المحيي","display":"الْمُحْيِي"},{"kind":"word","token":"المميت","display":"الْمُمِيتُ"},{"kind":"word","token":"البديء","display":"الْبَدِيءُ"},{"kind":"word","token":"البديع","display":"الْبَدِيعُ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"الكرم","display":"الْكَرَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"الحمد","display":"اَلْحَمْدُ"},{"kind":"word","token":"المجد","display":"الْمَجْدُ"},{"kind":"word","token":"و","display":"وَ"},{"k