{"consensus_set_id":"23482","translation_language":"fa","translation_source":{"hid":"113184"},"segments":[{"source_hadith_segment":"اَنَّ اَمِيرَ الْمُؤْمِنِينَ صَلَوَاتُ اللَّهِ عَلَيْهِ كَرِهَ مُشَارَكَةَ الْيَهُودِيِّ وَ النَّصْرَانِيِّ وَ الْمَجُوسِيِّ  <quranic_text> « اِلاّٰ اَنْ تَكُونَ تِجٰارَةً حٰاضِرَةً » </quranic_text>   <footnote> [ البقرة ۲۸۲ ] </footnote>  لاَ يَغِيبُ عَنْهَا الْمُسْلِمُ .","translation_segment":"سکونی گوید: امام صادق علیه السلام فرمود: امیر مومنان علی علیه السلام از شریک شدن با یهودی، نصرانی و مجوسی خوشش نمی‌آمد؛ مگر در صورتی که تجارتی در حضور مسلمانان صورت بگیرد و آن مسلمان در محل‌ معامله حاضر باشد.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"كره","display":"كَرِهَ"},{"kind":"word","token":"مشاركه","display":"مُشَارَكَةَ"},{"kind":"word","token":"اليهودي","display":"الْيَهُودِيِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"النصراني","display":"النَّصْرَانِيِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المجوسي","display":"الْمَجُوسِيِّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تكون","display":"تَكُونَ"},{"kind":"word","token":"تجاره","display":"تِجٰارَةً"},{"kind":"word","token":"حاضره","display":"حٰاضِرَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۸۲","display":"۲۸۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","to