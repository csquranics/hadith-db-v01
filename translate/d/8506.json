ord","token":"الخير","display":"الخير"},{"kind":"word","token":"ببابي","display":"ببابي"},{"kind":"word","token":"يا","display":"يا"},{"kind":"word","token":"سلمان","display":"سلمان"}]},{"source_hadith_segment":"خذ درعي هذا ،  ثمّ امض به الي شمعون اليهودي","translation_segment":"","segment_columns":[{"kind":"word","token":"خذ","display":"خذ"},{"kind":"word","token":"درعي","display":"درعي"},{"kind":"word","token":"هذا","display":"هذا"},{"kind":"word","token":"ثم","display":"ثمّ"},{"kind":"word","token":"امض","display":"امض"},{"kind":"word","token":"به","display":"به"},{"kind":"word","token":"الي","display":"الي"}]},{"source_hadith_segment":"،  و قل له :  تقول فاطمة بنت محمّد :  اقرضني عليه صاعا من تمر و صاعا من شعير اردّه عليك ان شاء اللّه تعالي","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال :  فاخذ سلمان الدرع ،  ثمّ اتي به الي شمعون اليهودي ؛","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قال :  فاخذ شمعون الدرع","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  ثمّ جعل يقلّبه في كفّه و عيناه تذرفان بالدموع و هو يقول :  يا سلمان !  هذا هو الزهد في الدنيا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  هذا الّذي اخبرنا به موسي بن عمران في التوراة","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  انا اشهد ان لا اله الاّ اللّه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و اشهد انّ محمّدا عبده و رسوله","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فاسلم و حسن اسلامه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  ثمّ دفع الي سلمان صاعا من تمر","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و صاعا من شعير","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فاتي به سلمان الي فاطمة عليها السّلام ،  فطحنته بيدها ،  و اختبزته خبزا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  ثمّ اتت به الي سلمان ؛","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فقالت له :  خذه و امض به الي النبيّ صلي اللّه عليه و اله و سلم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال :  فقال لها سلمان :  يا فاطمة ،  خذي منه قرصا تعلّلين به الحسن و الحسين","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فقالت :  يا سلمان ،  هذا شيء امضيناه للّه عزّ و جلّ لسنا ناخذ منه شيئا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال :  فاخذه سلمان","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فاتي به النبيّ صلي اللّه عليه و اله و سلم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فلمّا نظر النبيّ صلي اللّه عليه و اله و سلم الي سلمان قال له :  يا سلمان ،  من اين لك هذا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  !  قال :  من منزل بنتك فاطمة","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال :  و كان النبيّ صلي اللّه عليه و اله و سلم لم يطعم طعاما منذ ثلاث","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال :  فوثب النبيّ صلي اللّه عليه و اله و سلم حتّي ورد الي حجرة فاطمة ،  فقرع الباب","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و كان اذا قرع النبيّ صلي اللّه عليه و اله و سلم الباب لا يفتح له الباب الاّ فاطمة ؛","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فلمّا ان فتحت له الباب","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  نظر النبيّ صلي اللّه عليه و اله و سلم الي صفار وجهها و تغيّر حدقتيها","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فقال لها :  يا بنيّة ،  ما الّذي اراه من صفار وجهك و تغيّر حدقتيك","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  فقالت :  يا ابة ،  انّ لنا ثلاثا ما طعمنا طعاما ؛  و انّ الحسن و الحسين قد اضطربا عليّ من شدّة الجوع ،  ثمّ رقدا كانّهما فرخان منتوفان","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قال :  فانبههما النبيّ صلي اللّه عليه و اله و سلم فاخذ واحدا علي فخذه الايمن ،  و الاخر علي فخذه الايسر ،  و اجلس فاطمة عليها السّلام بين يديه و اعتنقها النبيّ صلي اللّه عليه و اله و سلم","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و دخل عليّ بن ابي طالب عليه السّلام","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فاعتنق النبيّ صلي اللّه عليه و اله و سلم من ورائه","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  ثمّ رفع النبيّ صلي اللّه عليه و اله و سلم طرفه نحو السماء","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فقال :  الهي و سيّدي و مولاي ،  هؤلاء اهل بيتي ،  اللهمّ اذهب عنهم الرجس و طهّرهم تطهيرا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"!  قال :  ثمّ وثبت فاطمة بنت محمّد صلي اللّه عليه و اله و سلم حتّي دخلت الي مخدع لها ،  فصفّت قدميها ،  فصلّت ركعتين","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"ثمّ رفعت باطن كفّيها الي السماء و قالت :  الهي و سيّدي ،  هذا محمّد نبيّك ،  و هذا عليّ ابن عمّ نبيّك ،  و هذان الحسن و الحسين سبطا نبيّك ،  الهي انزل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"علينا مائدة [ من السماء ] كما انزلتها علي بني اسرائيل","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اكلوا منها و كفروا بها","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  اللهمّ انزلها علينا فانّا بها مؤمنون","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قال ابن عبّاس : - و اللّه - ما استتمّت الدعوة","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فاذا هي بصحفة من ورائها يفور قتارها","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و اذا قتارها ازكي من المسك الاذفر ،  فاحتضنتها","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  ثمّ اتت بها الي النبيّ صلي اللّه عليه و اله و سلم و عليّ و الحسن و الحسين","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فلمّا ان نظر اليها عليّ بن ابي طالب عليه السّلام قال لها :  يا فاطمة ،  من اين لك هذا ؟  و لم يكن اجد عندك شيئا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"!  فقال له النبيّ صلي اللّه عليه و اله و سلم :  كل يا ابا الحسن ،  و لا تسال ،  الحمد للّه الّذي لم يمتني حتّي رزقني ولدا ،  مثلها مثل مريم بنت عمران  <quranic_text> « كُلَّمٰا دَخَلَ عَلَيْهٰا زَكَرِيَّا الْمِحْرٰابَ وَجَدَ عِنْدَهٰا رِزْقاً قٰالَ يٰا مَرْيَمُ اَنّٰي لَكِ هٰذٰا قٰالَتْ هُوَ مِنْ عِنْدِ اللّٰهِ اِنَّ اللّٰهَ يَرْزُقُ مَنْ يَشٰاءُ بِغَيْرِ حِسٰابٍ » </quranic_text>   <footnote> [ العمران ۳۷ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قال :  فاكل النبيّ صلي اللّه عليه و اله و سلم و عليّ و الحسن و الحسين","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  و خرج النبيّ صلي اللّه عليه و اله و سلم ،  الحديث .","translation_segment":"","segment_columns":[]}]}