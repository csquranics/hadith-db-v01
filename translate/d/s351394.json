{"consensus_set_id":"s351394","translation_language":"fa","translation_source":{"hid":"351394"},"segments":[{"source_hadith_segment":"اَنَّهُ عَلَيْهِ السَّلاَمُ قَالَ لِمَنْ وَعَدَهُ لَوْ لَمْ يَجِئْنِي لَكَانَ مِنْهُ الْمَحْشَرُ فَاَنْزَلَ اللَّهُ  <quranic_text> « وَ اُذْكُرْ فِي الْكِتٰابِ اِسْمٰاعِيلَ اِنَّهُ كٰانَ صٰادِقَ الْوَعْدِ » </quranic_text>   <footnote> [ مريم ۵۴ ] </footnote>   .","translation_segment":"در روایتی دیگر آمده است که اسماعیل با کسی قرار گذاشت ولی او بر سر قرار نیامد. اسماعیل به او گفت: اگر تا روز قیامت هم نمی‌آمدی بر سر قرار می‌ایستادم.","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"وعده","display":"وَعَدَهُ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يجئني","display":"يَجِئْنِي"},{"kind":"word","token":"لكان","display":"لَكَانَ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"word","token":"المحشر","display":"الْمَحْشَرُ"},{"kind":"word","token":"فانزل","display":"فَاَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذكر","display":"اُذْكُرْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابِ"},{"kind":"word","token":"اسماعيل","display":"اِسْمٰاعِيلَ"},{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"كان","display":"كٰانَ"},{"kind":"word","token":"صادق","display":"صٰادِقَ"},{"kind":"word","token":"الوعد","display":"الْوَعْدِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"مريم","display":"مريم"},{"kind":"word","token":"۵۴","display":"۵۴"},{"kind"