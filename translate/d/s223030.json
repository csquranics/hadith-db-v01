{"consensus_set_id":"s223030","translation_language":"fa","translation_source":{"hid":"223030"},"segments":[{"source_hadith_segment":"قَالَ الرِّضَا عَلَيْهِ السَّلاَمُ لِسُلَيْمَانَ الْمَرْوَزِيِّ مَا اَنْكَرْتَ مِنَ الْبَدَاءِ يَا سُلَيْمَانُ وَ اللَّهُ عَزَّ وَ جَلَّ يَقُولُ  <quranic_text> « اَ وَ لاٰ يَذْكُرُ الْاِنْسٰانُ اَنّٰا خَلَقْنٰاهُ مِنْ قَبْلُ وَ لَمْ يَكُ شَيْئاً » </quranic_text>   <footnote> [ مريم ۶۷ ] </footnote>  وَ يَقُولُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ هُوَ الَّذِي يَبْدَؤُا الْخَلْقَ ثُمَّ يُعِيدُهُ » </quranic_text>   <footnote> [ الروم ۲۷ ] </footnote>  وَ يَقُولُ  <quranic_text> « بَدِيعُ السَّمٰاوٰاتِ وَ الْاَرْضِ » </quranic_text>   <footnote> [ البقرة ۱۱۷ ] </footnote>  وَ يَقُولُ عَزَّ وَ جَلَّ :   <quranic_text> « يَزِيدُ فِي الْخَلْقِ مٰا يَشٰاءُ » </quranic_text>   <footnote> [ فاطر ۱ ] </footnote>  وَ يَقُولُ  <quranic_text> « وَ بَدَاَ خَلْقَ الْاِنْسٰانِ مِنْ طِينٍ » </quranic_text>   <footnote> [ السجده ۷ ] </footnote>  وَ يَقُولُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ اخَرُونَ مُرْجَوْنَ لِاَمْرِ اللّٰهِ اِمّٰا يُعَذِّبُهُمْ وَ اِمّٰا يَتُوبُ عَلَيْهِمْ » </quranic_text>   <footnote> [ التوبة ۱۰۶ ] </footnote>  وَ يَقُولُ عَزَّ وَ جَلَّ :   <quranic_text> « وَ مٰا يُعَمَّرُ مِنْ مُعَمَّرٍ وَ لاٰ يُنْقَصُ مِنْ عُمُرِهِ اِلاّٰ فِي كِتٰابٍ » </quranic_text>   <footnote> [ فاطر ۱۱ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"لسليمان","display":"لِسُلَيْمَانَ"},{"kind":"word","token":"المروزي","display":"الْمَرْوَزِيِّ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"انكرت","display":"اَنْكَرْتَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"البداء","display":"الْبَدَاءِ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","toke