{"consensus_set_id":"24400","translation_language":"fa","translation_source":{"hid":"316222"},"segments":[{"source_hadith_segment":"قَالَ قَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ  :  يَنْبَغِي لِلرَّجُلِ اَنْ يَتَوَقَّي النُّورَةَ يَوْمَ الْاَرْبِعَاءِ فَاِنَّهُ يَوْمُ  <quranic_text> « نَحْسٍ مُسْتَمِرٍّ » </quranic_text>   <footnote> [ القمر ۱۹ ] </footnote>   .","translation_segment":"محمد بن مسلم از امام صادق (علیه السلام) نقل می‌کند که امیر المومنین فرمود: شایسته است که مومن از نوره گذاشتن در روز چهارشنبه بپرهیزد که روز چهارشنبه روز نحس پایدار است.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"امير","display":"اَمِيرُ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ينبغي","display":"يَنْبَغِي"},{"kind":"word","token":"للرجل","display":"لِلرَّجُلِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتوقي","display":"يَتَوَقَّي"},{"kind":"word","token":"النوره","display":"النُّورَةَ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"الاربعاء","display":"الْاَرْبِعَاءِ"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"يوم","display":"يَوْمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"نحس","display":"نَحْسٍ"},{"kind":"word","token":"مستمر","display":"مُسْتَمِرٍّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القمر","display":"القمر"},{"kind":"word","token":"تجوز","display":"تَجُوزُ"},{"kind":"word","token":"النوره","display":"النُّورَةُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"سائر","display":"سَائِرِ"},{"kind":"word","token":"۱۹","display":"۱۹"},{"kind":"tag_close","tag_name":"foot