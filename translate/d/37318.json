َ بْنِ مَاثَانَ ،  وَ بَنُو مَاثَانَ ،  اِذْ ذَاكَ رُؤَسَاءُ بَنِي اِسْرَائِيلَ وَ بَنُو مُلُوكِهِمْ ،  وَ هُمْ مِنْ وُلْدِ سُلَيْمَانَ بْنِ دَاوُدَ  ،  فَقَالَ زَكَرِيَّا :   <quranic_text> « فَهَبْ لِي مِنْ لَدُنْكَ وَلِيًّا يَرِثُنِي وَ يَرِثُ مِنْ الِ يَعْقُوبَ وَ اِجْعَلْهُ رَبِّ رَضِيًّا يٰا زَكَرِيّٰا اِنّٰا نُبَشِّرُكَ بِغُلاٰمٍ اِسْمُهُ يَحْييٰ لَمْ نَجْعَلْ لَهُ مِنْ قَبْلُ سَمِيًّا » </quranic_text>   <footnote> [ مريم ۵ ] </footnote>  يَقُولُ :  لَمْ يُسَمَّ بِاسْمِ يَحْيَي اَحَدٌ قَبْلَهُ <quranic_text> « قٰالَ رَبِّ اَنّٰي يَكُونُ لِي غُلاٰمٌ وَ كٰانَتِ اِمْرَاَتِي عٰاقِراً وَ قَدْ بَلَغْتُ مِنَ الْكِبَرِ عِتِيًّا » </quranic_text>   <footnote> [ مريم ۸ ] </footnote>  فَهُوَ الْيَؤُوسُ <quranic_text> « قٰالَ كَذٰلِكَ قٰالَ رَبُّكَ هُوَ عَلَيَّ هَيِّنٌ وَ قَدْ خَلَقْتُكَ مِنْ قَبْلُ وَ لَمْ تَكُ شَيْئاً قٰالَ رَبِّ اِجْعَلْ لِي ايَةً قٰالَ ايَتُكَ اَلاّٰ تُكَلِّمَ النّٰاسَ ثَلاٰثَ لَيٰالٍ سَوِيًّا » </quranic_text>   <footnote> [ مريم ۹ ] </footnote>  صَحِيحاً مِنْ غَيْرِ مَرَضٍ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"لزكريا","display":"لِزَكَرِيَّا"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"ولد","display":"وَلَدٌ"},{"kind":"word","token":"يقوم","display":"يَقُومُ"},{"kind":"word","token":"مقامه","display":"مَقَامَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يرثه","display":"يَرِثُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"هدايا","display":"هَدَايَا"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرَائِيلَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نذورهم","display":"نُذُورُهُمْ"},{"kind":"word","token":"للاحبار","display":"لِلْاَحْبَارِ"},{"kind":"word","token"