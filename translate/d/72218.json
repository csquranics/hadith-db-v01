{"consensus_set_id":"72218","translation_language":"fa","translation_source":{"hid":"331838"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « الَّذِينَ اِنْ مَكَّنّٰاهُمْ فِي الْاَرْضِ » </quranic_text>   <footnote> [ الحج ۴۱ ] </footnote>  الْايَةَ قَالَ :  فِينَا وَ اللَّهِ نَزَلَتْ هَذِهِ الْايَةُ .","translation_segment":"عن أبان تغلب: عن أبی محمد بن علی‌ ع فی قوله تعالی: (الذین إن مکناهم فی الأرض) الآیه قال: فینا و الله نزلت هذه الآیه. ابان بن تغلب از ابو جعفر محمد بن علی درباره سخن خداوند: «الذین ان مکناهم فی الارض» نقل می‌کند که گفت: به خدا سوگند که این آیه درباره ما نازل شده است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"مكناهم","display":"مَكَّنّٰاهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"اقاموا","display":"اَقٰامُوا"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتوا","display":"اتَوُا"},{"kind":"word","token":"الزكاه","display":"الزَّكٰاةَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۴۱","display":"۴۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"فينا","display":"فِينَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"}]}]}