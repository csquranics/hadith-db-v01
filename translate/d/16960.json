{"consensus_set_id":"16960","translation_language":"fa","translation_source":{"hid":"111309"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « اَوْ عَدْلُ ذٰلِكَ صِيٰاماً » </quranic_text>   <footnote> [ المائدة ۹۵ ] </footnote>","translation_segment":"یکی از اصحاب ما گوید: امام صادق علیه السلام در مورد گفتار خداوند متعال که می‌فرماید: «یا برابر آن (اطعام مساکین) روزه بگیرد»","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"عدل","display":"عَدْلُ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"صياما","display":"صِيٰاماً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۹۵","display":"۹۵"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ يُثَمِّنُ قِيمَةَ الْهَدْيِ طَعَاماً ثُمَّ يَصُومُ لِكُلِّ مُدٍّ يَوْماً فَاِذَا زَادَتِ الْاَمْدَادُ عَلَي شَهْرَيْنِ فَلَيْسَ عَلَيْهِ اَكْثَرُ مِنْهُ .","translation_segment":"فرمود: به اندازه قیمت قربانی طعام محاسبه می‌شود و برای هرمد یک روز، روزه می‌گیرد. هنگامی که اندازه مدها بیشتر از دوماه شد، پس بیشتر از آن بر ذمه او نیست (که روزه بگیرد).","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يقوم","display":"يُقَوَّمُ"},{"kind":"word","token":"يثمن","display":"يُثَمِّنُ"},{"kind":"word","token":"قيمه","display":"قِيمَةَ"},{"kind":"word","token":"الهدي","display":"الْهَدْيِ"},{"kind":"word","token":"طعاما","display":"طَعَاماً"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يصوم","display":"