{"consensus_set_id":"42539","translation_language":"fa","translation_source":{"hid":"412443"},"segments":[{"source_hadith_segment":"« كَانَ اَبِي ( رَضِيَ اللَّهُ عَنْهُ ) ] يَقُولُ فِي قَوْلِهِ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « فَاِذٰا فَرَغْتَ فَانْصَبْ وَ اِليٰ رَبِّكَ فَارْغَبْ » </quranic_text>   <footnote> [ الشرح ۷ ] </footnote> :  فَاِذَا قَضَيْتَ الصَّلاَةَ قَبْلَ اَنْ تُسَلِّمَ وَ اَنْتَ جَالِسٌ ،  فَانْصَبْ فِي الدُّعَاءِ مِنْ اَمْرِ الدُّنْيَا وَ الْاخِرَةِ ،  وَ اِذَا فَرَغْتَ مِنَ الدُّعَاءِ فَارْغَبْ اِلَي اللَّهِ تَبَارَكَ وَ تَعَالَي [ اَنْ يَتَقَبَّلَهَا مِنْكَ ] »","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"رضي","display":"رَضِيَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عنه","display":"عَنْهُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاذا","display":"فَاِذٰا"},{"kind":"word","token":"فرغت","display":"فَرَغْتَ"},{"kind":"word","token":"فانصب","display":"فَانْصَبْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"فارغب","display":"فَارْغَبْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الشرح","display":"الشرح"},{"kind":"word","token":"۷","display":"۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"قضيت","display":"قَ