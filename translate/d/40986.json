{"consensus_set_id":"40986","translation_language":"fa","translation_source":{"hid":"409053"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « اِلاّٰ اِفْكٌ اِفْتَرٰاهُ » </quranic_text>   <footnote> [ الفرقان ۴ ] </footnote>  قَالَ :  « اَلْاِفْكُ :  الْكَذِبُ <quranic_text> « وَ اَعٰانَهُ عَلَيْهِ قَوْمٌ اخَرُونَ » </quranic_text>   <footnote> [ الفرقان ۴ ] </footnote>  يَعْنُونَ اَبَا فُكَيْهَةَ ،  وَ حِبْراً ،  وَ عَدَّاساً ،  وَ عَابِساً مَوْلَي حُوَيْطِبٍ ،  وَ قَوْلُهُ :   <quranic_text> « اَسٰاطِيرُ الْاَوَّلِينَ اِكْتَتَبَهٰا » </quranic_text>   <footnote> [ الفرقان ۵ ] </footnote>  فَهُوَ قَوْلُ النَّضْرِ بْنِ الْحَارِثِ بْنِ عَلْقَمَةَ بْنِ كَلَدَةَ ،  قَالَ :  اَسَاطِيرُ الْاَوَّلِينَ اِكْتَتَبَهَا مُحَمَّدٌ  ،  فَهِيَ تُمْلَي عَلَيْهِ بُكْرَةً وَ اَصِيلاً »","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"افك","display":"اِفْكٌ"},{"kind":"word","token":"افتراه","display":"اِفْتَرٰاهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفرقان","display":"الفرقان"},{"kind":"word","token":"۴","display":"۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الافك","display":"اَلْاِفْكُ"},{"kind":"word","token":"الكذب","display":"الْكَذِبُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعانه","display":"اَعٰانَهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"قوم","display":"قَوْمٌ"},{"kind":"word","token":"اخرون","display":"اخَرُونَ"},{"kind":"tag_close","tag_nam