{"consensus_set_id":"s175188","translation_language":"fa","translation_source":{"hid":"175188"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ  <quranic_text> « ذٰلِكَ لِمَنْ لَمْ يَكُنْ اَهْلُهُ حٰاضِرِي الْمَسْجِدِ الْحَرٰامِ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>   ،  قَالَ ذَلِكَ اَهْلُ مَكَّةَ لَيْسَ لَهُمْ مُتْعَةٌ وَ لاَ عَلَيْهِمْ عُمْرَةٌ قَالَ قُلْتُ :  فَمَا حَدُّ ذَلِكَ قَالَ ثَمَانِيَةً وَ اَرْبَعِينَ مِيلاً مِنْ جَمِيعِ نَوَاحِي مَكَّةَ ،  دُونَ عُسْفَانَ وَ دُونَ ذَاتِ عِرْقٍ .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"اهله","display":"اَهْلُهُ"},{"kind":"word","token":"حاضري","display":"حٰاضِرِي"},{"kind":"word","token":"المسجد","display":"الْمَسْجِدِ"},{"kind":"word","token":"الحرام","display":"الْحَرٰامِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۶","display":"۱۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"مكه","display":"مَكَّةَ"},{"kind":"word","token":"ليس","display":"لَيْسَ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"متعه","display":"مُتْعَةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"عمره","display"