{"consensus_set_id":"5813","translation_language":"fa","translation_source":{"hid":"87951"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « فَاِنْ خِفْتُمْ فَرِجٰالاً اَوْ رُكْبٰاناً » </quranic_text>   <footnote> [ البقرة ۲۳۹ ] </footnote>  كَيْفَ نُصَلِّي وَ مَا تَقُولُ اِنْ خَافَ مِنْ سَبُعٍ اَوْ لِصٍّ كَيْفَ يُصَلِّي قَالَ « يُكَبِّرُ وَ يُومِئُ بِرَاْسِهِ »","translation_segment":"* *۳ - از ابو عبد الله صادق (ع) پرسیدم: به هنگام ترس از دشمن که خداوند عز و جل می‌فرماید: «پیاده یا سواره نماز بخوانید» این نماز چه شرائطی دارد؟ و اگر کسی از درندگان و دزدان خائف باشد، به چه صورت باید نماز بخواند؟ ابو عبد الله گفت: باید با اشاره","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"خفتم","display":"خِفْتُمْ"},{"kind":"word","token":"فرجالا","display":"فَرِجٰالاً"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"ركبانا","display":"رُكْبٰاناً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۳۹","display":"۲۳۹"},