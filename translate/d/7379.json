{"consensus_set_id":"7379","translation_language":"fa","translation_source":{"hid":"100347"},"segments":[{"source_hadith_segment":"كَانَ الصَّادِقُ عَلَيْهِ السَّلاَمُ « اِذَا وَضَعَ رِجْلَهُ فِي الرِّكَابِ يَقُولُ : <quranic_text> « سُبْحٰانَ الَّذِي سَخَّرَ لَنٰا هٰذٰا وَ مٰا كُنّٰا لَهُ مُقْرِنِينَ » </quranic_text>   <footnote> [ الزخرف ۱۳ ] </footnote> وَ يُسَبِّحُ اللَّهَ سَبْعاً وَ يُحَمِّدُ اللَّهَ سَبْعاً وَ يُهَلِّلُ اللَّهَ سَبْعاً »","translation_segment":"و امام صادق علیه السلام چون پای خود را در رکاب مینهاد، میگفت: «سبحٰان‌ الذی سخر لنٰا هٰذٰا و مٰا کنٰا له‌ مقرنین‌». (منزهست خدائی که","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الصادق","display":"الصَّادِقُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"وضع","display":"وَضَعَ"},{"kind":"word","token":"رجله","display":"رِجْلَهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الركاب","display":"الرِّكَابِ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سبحان","display":"سُبْحٰانَ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"سخر","display":"سَخَّرَ"},{"kind":"word","token":"لنا","display":"لَنٰا"},{"kind":"word","token":"هذا","display":"هٰذٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"كنا","display":"كُنّٰا"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"مقرنين","display":"مُقْرِنِينَ"},{"kind":"tag_close","tag_name":"qura