{"consensus_set_id":"45508","translation_language":"fa","translation_source":{"hid":"290530"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ رُوحٌ مِنْهُ » </quranic_text>   <footnote> [ النساء ۱۷۱ ] </footnote>  قَالَ هِيَ مَخْلُوقَةٌ خَلَقَهَا اللَّهُ بِحِكْمَتِهِ فِي ادَمَ وَ فِي عِيسَي عَلَيْهِ السَّلاَمُ  .","translation_segment":"و از أبی الیاس چنان مرویست که من از حضرت أبا جعفر محمد الباقر علیه السلام از معنی قول خدای تعالی و أیده بروح منه استعلام و استفهام نمودم آن حضرت فرمود که: روح مخلوقیست حضرت خالق آن را بحکمت خود در حضرت آدم و عیسی خلق و ایجاد فرمود.","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"روح","display":"رُوحٌ"},{"kind":"word","token":"منه","display":"مِنْهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۷۱","display":"۱۷۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السّلام"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"مخلوقه","display":"مَخْلُوقَةٌ"},{"kind":"word","token":"خلقها","display":"خَلَقَهَا"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"k