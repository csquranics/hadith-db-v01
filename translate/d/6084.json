{"consensus_set_id":"6084","translation_language":"fa","translation_source":{"hid":"449253"},"segments":[{"source_hadith_segment":"<quranic_text> « بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيمِ » </quranic_text>   <footnote> [ الفاتحة ۱ ] </footnote>  اللَّهُمَّ اَنْتَ اللَّهُ وَ اَنْتَ الرَّحْمَنُ وَ اَنْتَ الرَّحِيمُ  <quranic_text> « الْمَلِكُ الْقُدُّوسُ السَّلاٰمُ الْمُؤْمِنُ الْمُهَيْمِنُ الْعَزِيزُ الْجَبّٰارُ الْمُتَكَبِّرُ » </quranic_text>   <footnote> [ الحشر ۲۳ ] </footnote>  الْاَوَّلُ الْاخِرُ الظَّاهِرُ الْبَاطِنُ الْحَمِيدُ الْمَجِيدُ الْمُبْدِئُ الْمُعِيدُ الْوَدُودُ الشَّهِيدُ الْقَدِيمُ الْعَلِي الصَّادِقُ الرَّؤُفُ الرَّحِيمُ الشَّكُورُ الْغَفُورُ الْعَزِيزُ","translation_segment":"و از جمله دعاهای آن حضرت علیه السلام در ذکر أسماء حسنی (نامهای نیک) خداوند بنام خداوند بخشنده مهربان خدایا توئی خداوند، و توئی بخشاینده، و توئی مهربان، پادشاه، منزه، سلام (سلامتی بخش)، امان بخش، نگهبان، نیرومند، با جبروت دارنده کبریاء و بزرگی، آغاز، انجام، هویدا، نهان، پسندیده، ستوده، آغازنده (آفرینش)، بازگرداننده، گواه، دیرینه. والا، راستگو، مهرورز، مهربان، قدردان، آمرزنده، با عزت، فرزانه، دارای نیروی محکم، مراقب، نگهبان، صاحب","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بسم","display":"بِسْمِ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"بسمل","display":"بَسْمِلْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنِ"},{"kind":"word","token":"الرحيم","display":"الرَّحِيمِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفاتحه","display":"الفاتحة"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","