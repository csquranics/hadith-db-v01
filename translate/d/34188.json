{"consensus_set_id":"34188","translation_language":"fa","translation_source":{"hid":"346645"},"segments":[{"source_hadith_segment":"مَثَلُ اَمْرِنَا فِي كِتَابِ اللَّهِ مَثَلُ صَاحِبِ الْحِمَارِ  <quranic_text> « فَاَمٰاتَهُ اللّٰهُ مِائَةَ عٰامٍ ثُمَّ بَعَثَهُ » </quranic_text>   <footnote> [ البقرة ۲۵۹ ] </footnote>   .","translation_segment":"/۲-ابی بصیر می‌گوید که از امام باقر علیه السلام شنیدم که می‌فرمودند: مثل ما در کتاب خداوند-قرآن کریم-مثل صاحب حمار است که خداوند او را یک‌صد سال میراند و سپس او را زنده کرد.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سمعت","display":"سمعت"},{"kind":"word","token":"ابا","display":"أبا"},{"kind":"word","token":"جعفر","display":"جعفر"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السلام"},{"kind":"word","token":"يقول","display":"يقول"},{"kind":"word","token":"مثل","display":"مَثَلُ"},{"kind":"word","token":"امرنا","display":"اَمْرِنَا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"كتاب","display":"كِتَابِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"مثل","display":"مَثَلُ"},{"kind":"word","token":"صاحب","display":"صَاحِبِ"},{"kind":"word","token":"الحمار","display":"الْحِمَارِ"},{"kind":"word","token":"اماته","display":"اَمَاتَهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فاماته","display":"فَاَمٰاتَهُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"مائه","display":"مِائَةَ"},{"kind":"word","token":"عام","display":"عٰامٍ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"بعثه","display":"بَعَثَهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۵۹","display":"۲۵۹"},{"kind":"tag_close","tag_name":"footnote"}]}]}