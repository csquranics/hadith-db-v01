{"consensus_set_id":"11055","translation_language":"fa","translation_source":{"hid":"404596"},"segments":[{"source_hadith_segment":"« مِنَ اَلْاَنْبِيَاءِ مُسْتَخْفِينَ ،  وَ لِذَلِكَ خَفِيَ ذِكْرُهُمْ فِي الْقُرْانِ ،  فَلَمْ يُسَمَّوْا كَمَا سُمِّيَ مَنِ اِسْتَعْلَنَ مِنَ الْاَنْبِيَاءِ ( صَلَوَاتُ اللَّهِ عَلَيْهِمْ اَجْمَعِينَ ) ،  وَ هُوَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ رُسُلاً قَدْ قَصَصْنٰاهُمْ عَلَيْكَ مِنْ قَبْلُ وَ رُسُلاً لَمْ نَقْصُصْهُمْ عَلَيْكَ » </quranic_text>   <footnote> [ النساء ۱۶۴ ] </footnote> يَعْنِي لَمْ اُسَمِّ الْمُسْتَخْفِينَ كَمَا سَمَّيْتُ الْمُسْتَعْلِنِينَ مِنَ الْاَنْبِيَاءِ ( صَلَوَاتُ اللَّهِ عَلَيْهِمْ ) »","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"ادم","display":"ادَمَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"نوح","display":"نُوحٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الانبياء","display":"اَلْاَنْبِيَاءِ"},{"kind":"word","token":"مستخفين","display":"مُسْتَخْفِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مستعلنين","display":"مُسْتَعْلِنِينَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لذلك","display":"لِذَلِكَ"},{"kind":"word","token":"خفي","display":"خَفِيَ"},{"kind":"word","token":"ذكرهم","display":"ذِكْرُهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"فلم","display":"فَلَمْ"},{"kind":"word","token":"يسموا","display":"يُسَمَّوْا"},{"kind":"word","token":"كما","display":"كَمَا"},{"kind":"word","token":"سمي","display":"سُمِّيَ"},{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"استعلن","display":"اِسْتَعْلَنَ"},{"kind":"word","token":"من","d