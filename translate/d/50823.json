{"consensus_set_id":"50823","translation_language":"fa","translation_source":{"hid":"383215"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنِ التَّسْبِيحِ ،  قَالَ :  مَا عَلِمْتُ شَيْئاً فِيهِ مُوَظَّفاً اِلاَّ تَسْبِيحَ فَاطِمَةَ عَلَيْهَا السَّلاَمُ وَ عَشْراً بَعْدَ الْغَدَاةِ :   <quranic_text> « لاٰ اِلٰهَ اِلاَّ اللّٰهُ » </quranic_text>   <footnote> [ الصافات ۳۵ ] </footnote>  وَحْدَهُ  <quranic_text> « لاٰ شَرِيكَ لَهُ » </quranic_text>   <footnote> [ الانعام ۱۶۳ ] </footnote>   ،   <quranic_text> « لَهُ الْمُلْكُ وَ لَهُ الْحَمْدُ » </quranic_text>   <footnote> [ التغابن ۱ ] </footnote>   ،   <quranic_text> « يُحْيِي وَ يُمِيتُ » </quranic_text>   <footnote> [ البقرة ۲۵۸ ] </footnote>  وَ يُمِيتُ وَ يُحْيِي ،  وَ هُوَ حَيٌّ لاَ يَمُوتُ ،  بِيَدِهِ الْخَيْرُ ،   <quranic_text> « وَ هُوَ عَليٰ كُلِّ شَيْءٍ قَدِيرٌ » </quranic_text>   <footnote> [ التغابن ۱ ] </footnote>   .  .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"التسبيح","display":"التَّسْبِيحِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"علمت","display":"عَلِمْتُ"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"word","token":"موظفا","display":"مُوَظَّفاً"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"تسبيح","display":"تَسْبِيحَ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةَ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عشرا","display":"عَشْراً"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الغداه","display":"الْغَدَاةِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","displ