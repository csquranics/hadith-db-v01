{"consensus_set_id":"11911","translation_language":"fa","translation_source":{"hid":"119180"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « وَ كٰانُوا مِنْ قَبْلُ يَسْتَفْتِحُونَ عَلَي الَّذِينَ كَفَرُوا فَلَمّٰا جٰاءَهُمْ مٰا عَرَفُوا كَفَرُوا بِهِ » </quranic_text>   <footnote> [ البقرة ۸۹ ] </footnote>  قَالَ كَانَ قَوْمٌ فِيمَا بَيْنَ","translation_segment":"اسحاق بن عمار می‌گوید: تفسیر این آیه شریفه را: «و کٰانوا من‌ قبل‌ یستفتحون‌ علی الذین‌ کفروا فلمٰا جٰاءهم‌ مٰا عرفوا کفروا به‌» از امام صادق علیه السلام پرسیدم. حضرت فرمود: در فاصله زمانی مانند محمد و عیسی-که درود فراوان بر","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جلّ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كانوا","display":"كٰانُوا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"قبل","display":"قَبْلُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره۸۹","display":"البقرة۸۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يستفتحون","displa