ذابی سخت میکنم و یا سرش را میبرم و یا باید دلیل روشنی پیشم آرد» و خشم سلیمان بر شانه سر برای این بود که او سلیمان را بمحل آب راهنمائی میکرد، (موقعی که سلیمان و همراهانش بوسیله باد در هوا حرکت میکردند) خدا باین پرنده چیزی عطا کرده بود که بسلیمان عطا نفرموده بود، در صورتی که باد و مور و انس و جن و شیاطین و سرکشان مطیع او بودند ولی او جای آب را در زیر هوا نمیدانست و پرنده میدانست. خدا در کتابش فرماید (۲۹ سوره ۱۳) «و اگر قرآنی","segment_columns":[{"kind":"word","token":"يحيي","display":"يُحْيِي"},{"kind":"word","token":"الموتي","display":"الْمَوْتَي"},{"kind":"word","token":"باذن","display":"بِاِذْنِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صدقت","display":"صَدَقْتَ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"سليمان","display":"سُلَيْمَانَ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"داود","display":"دَاوُدَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يفهم","display":"يَفْهَمُ"},{"kind":"word","token":"منطق","display":"مَنْطِقَ"},{"kind":"word","token":"الطير","display":"الطَّيْرِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صدقت","display":"صَدَقْتَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"ki