{"consensus_set_id":"63569","translation_language":"fa","translation_source":{"hid":"112723"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنْ قَوْمٍ يُصَغِّرُونَ الْقُفْزَانَ يَبِيعُونَ بِهَا قَالَ اُولَئِكَ الَّذِينَ يَبْخَسُونَ  <quranic_text> « اَلنّٰاسَ اَشْيٰاءَهُمْ » </quranic_text>   <footnote> [ الاعراف ۸۵ ] </footnote>   .","translation_segment":"سعد بن سعد گوید: از امام کاظم علیه السلام در مورد گروهی که پیمانه‌های گندم را کوچک می‌گیرند و با آن فروش می‌کنند پرسیدم. فرمود: اینان کسانی هستند که اجناس مردم را کاهش می‌دهند.","segment_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوم","display":"قَوْمٍ"},{"kind":"word","token":"يصغرون","display":"يُصَغِّرُونَ"},{"kind":"word","token":"القفزان","display":"الْقُفْزَانَ"},{"kind":"word","token":"يبيعون","display":"يَبِيعُونَ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اولئك","display":"اُولَئِكَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يبخسون","display":"يَبْخَسُونَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الناس","display":"اَلنّٰاسَ"},{"kind":"word","token":"اشياءهم","display":"اَشْيٰاءَهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۸۵","display":"۸۵"},{"kind":"tag_close","tag_name":"footnote"}]}]}