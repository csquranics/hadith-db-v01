{"consensus_set_id":"3674","translation_language":"fa","translation_source":{"hid":"181045"},"segments":[{"source_hadith_segment":"وَ فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ لَمْ يُصِرُّوا عَليٰ مٰا فَعَلُوا وَ هُمْ يَعْلَمُونَ » </quranic_text>   <footnote> [ العمران ۱۳۵ ] </footnote>   ،  قَالَ الْاِصْرَارُ اَنْ يُذْنِبَ الذَّنْبَ فَلاَ يَسْتَغْفِرَ اللَّهَ وَ لاَ يُحَدِّثَ نَفْسَهُ بِالتَّوْبَةِ فَذَلِكَ الْاِصْرَارُ .","translation_segment":"جابر گوید: امام باقر علیه السلام در باره این آیه: و بر آنچه (از گناهان) انجام دادند اصرار نکردند، و ایشان می‌دانند (خداوند ایشان را می‌آمرزد) (آل عمران /۱۳۰) فرمود: اصرار این است که انسان گناهی بکند و استغفار ننماید و زمینه توبه را در خود فراهم نیاورد این، اصرار است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يغفر","display":"يَغْفِرُ"},{"kind":"word","token":"الذنوب","display":"الذُّنُوبَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يصروا","display":"يُصِرُّوا"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"فعلوا","display":"فَعَلُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"يعلمون","display":"يَعْلَمُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{