{"consensus_set_id":"2947","translation_language":"fa","translation_source":{"hid":"345435"},"segments":[{"source_hadith_segment":"اَتَانِي جَبْرَئِيلُ عَلَيْهِ السَّلاَمُ عَنْ رَبِّي تَبَارَكَ وَ تَعَالَي وَ هُوَ يَقُولُ اِنَّ رَبَّكَ يُقْرِئُكَ السَّلاَمَ وَ يَقُولُ يَا مُحَمَّدُ بَشِّرِ الْمُؤْمِنِينَ  <quranic_text> « الَّذِينَ يَعْمَلُونَ الصّٰالِحٰاتِ » </quranic_text>   <footnote> [ الاسراء ۹ ] </footnote>  وَ يُؤْمِنُونَ بِكَ وَ بِاَهْلِ بَيْتِكَ بِالْجَنَّةِ فَاِنَّ لَهُمْ عِنْدِي جَزَاءً الْحُسْنَي وَ سَيَدْخُلُونَ الْجَنَّةَ .","translation_segment":"نیز رسول خدا صلی الله علیه و آله فرمود: جبرئیل علیه السلام از جانب پروردگار متعال آمد و گفت: پروردگار من تو را سلام می‌رساند و می‌گوید: یا محمد! مومنانی را که اعمال صالحه می‌کنند و ایمان به تو و اهل بیت تو دارند به بهشت بشارت ده. پس ایشان را نزد من نیکو پاداشی است و زود باشد داخل بهشت شوند.","segment_columns":[{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمّٰا"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"امن","display":"امَنَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عمل","display":"عَمِلَ"},{"kind":"word","token":"صالحا","display":"صٰالِحاً"},{"kind":"word","token":"فله","display":"فَلَهُ"},{"kind":"word","token":"جزاء","display":"جَزٰاءً"},{"kind":"word","token":"الحسني","display":"الْحُسْنيٰ"},{"kind":"word","token":"الكهف۸۸","display":"الكهف۸۸"},{"kind":"word","token":"تاويله","display":"تَاْوِيلُهُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"العباس","display":"الْعَبَّاسِ"},{"kind":"word","token":"حدثنا","display":"حَدَّثَنَا"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"علي","display":"عَلِيِّ"},{"kin