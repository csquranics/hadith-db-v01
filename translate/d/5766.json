{"consensus_set_id":"5766","translation_language":"fa","translation_source":{"hid":"93547"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « وَ الْمُحْصَنٰاتُ مِنَ النِّسٰاءِ اِلاّٰ مٰا مَلَكَتْ اَيْمٰانُكُمْ » </quranic_text>   <footnote> [ النساء ۲۴ ] </footnote>","translation_segment":"* *۴۸ - از ابو جعفر باقر (ع) پرسیدم: خداوند عز و جل که می‌گوید: «و خانمهای شوهردار، بر شما حرامند، مگر آن خانمهایی که زرخرید شما باشند» چه منظوری دارد؟ ابو جعفر گفت: مورد آیه آنجا است که انسان کنیز خود را با غلام خود تزویج کرده باشد،","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المحصنات","display":"الْمُحْصَنٰاتُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"النساء","display":"النِّسٰاءِ"},{"kind":"word","token":"الا","display":"اِلاّٰ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ملكت","display":"مَلَكَتْ"},{"kind":"word","token":"ايمانكم","display":"اَيْمٰانُكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۲۴","display":"۲۴"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"قَالَ « هُوَ اَنْ يَاْمُرَ الرَّجُلُ عَبْدَهُ وَ تَحْتَهُ اَمَتُهُ فَيَقُولَ لَهُ اِعْتَزِلِ اِمْرَاَتَكَ وَ لاَ تَقْرَبْهَا ثُمَّ يَحْبِسَهَا عَنْهُ حَتَّي تَحِيضَ ثُمَّ يَمَسَّهَا فَاِذَا حَاضَتْ بَعْدَ مَسِّهِ اِيَّاهَا رَدَّهَا عَلَيْهِ بِغَيْرِ نِكَاحٍ » .","translation_segment":"و یک‌روز به غلام خود بگوید: از همسرت کناره بگیر و در تعقیب آن، کنیز را از نزدیک شدن به آن غلام ممنوع سازد تا یک نوبت عادت شود و پاکی رحم او ثابت گردد سپس مدتی آن کنیز را ویژه خود سازد و با او به بستر برود، و چون با عادت ماهیانه پاکی رحم او روشن گردد، مجددا کنیز را به غلام خود بازگرداند بی‌آنکه صیغه عقد بخواند.","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يامر","display":"يَاْمُرَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"عبده","display":"عَبْدَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تحته","display":"تَحْتَهُ"},{"kind":"word","token":"امته","display":"اَمَتُهُ"},{"kind":"word","token":"فيقول","display":"فَيَقُولَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"اعتزل","display":"اِعْتَزِلِ"},{"kind":"word","token":"امراتك","display":"اِمْرَاَتَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تقربها","display":"تَقْرَبْهَا"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يحبسها","display":"يَحْبِسَهَا"},{"kind":"word","token":"عنه","display":"عَنْهُ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"تحيض","display":"تَحِيضَ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يمسها","display":"يَمَسَّهَا"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"حاضت","display":"حَاضَتْ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"مسه","display":"مَسِّهِ"},{"kind":"