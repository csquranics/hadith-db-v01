{"consensus_set_id":"19899","translation_language":"fa","translation_source":{"hid":"255582"},"segments":[{"source_hadith_segment":"<quranic_text>«قُلْ اَعُوذُ بِرَبِّ النّٰاسِ»</quranic_text> <footnote>[الناس۱]</footnote> وَ اِنَّمَا هُوَ اَعُوذُ بِرَبِّ النَّاسِ <quranic_text>«مَلِكِ النّٰاسِ اِلٰهِ النّٰاسِ مِنْ شَرِّ الْوَسْوٰاسِ الْخَنّٰاسِ»</quranic_text> <footnote>[الناس۲]</footnote> اِسْمُ الشَّيْطَانِ فِي صُدُورِ النَّاسِ يُوَسْوِسُ فِيهَا وَ يُؤْيِسُهُمْ مِنَ الْخَيْرِ وَ يَعِدُهُمُ الْفَقْرَ وَ يَحْمِلُهُمْ عَلَي الْمَعَاصِي وَ الْفَوَاحِشِ وَ هُوَ قَوْلُ اللَّهِ: <quranic_text>«الشَّيْطٰانُ يَعِدُكُمُ الْفَقْرَ وَ يَاْمُرُكُمْ بِالْفَحْشٰاءِ»</quranic_text> <footnote>[البقرة۲۶۸]</footnote> وَ قَالَ الصَّادِقُ عَلَيْهِ السَّلاَمُ مَا مِنْ قَلْبٍ اِلاَّ وَ لَهُ اُذُنَانِ عَلَي اَحَدِهِمَا مَلَكٌ مُرْشِدٌ وَ عَلَي الْاخَرِ شَيْطَانٌ مُفْتَرٍ هَذَا يَاْمُرُهُ وَ ذَا يَزْجُرُهُ كَذَلِكَ مِنَ النَّاسِ شَيْطَانٌ يَحْمِلُ النَّاسَ عَلَي الْمَعَاصِي كَمَا يَحْمِلُ الشَّيْطَانُ مِنَ الْجِنِّ.","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"اعوذ","display":"اَعُوذُ"},{"kind":"word","token":"برب","display":"بِرَبِّ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الناس۱","display":"الناس۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"اعوذ","display":"اَعُوذُ"},{"kind":"word","token":"برب","display":"بِرَبِّ"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ملك","display":"مَلِكِ"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"word","token":"اله","display":"اِلٰهِ"},{"kind":"word","token":