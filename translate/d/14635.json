{"consensus_set_id":"14635","translation_language":"fa","translation_source":{"hid":"410063"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ جَعَلْنٰا مِنْ بَيْنِ اَيْدِيهِمْ سَدًّا وَ مِنْ خَلْفِهِمْ سَدًّا فَاَغْشَيْنٰاهُمْ » </quranic_text>   <footnote> [ يس ۹ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جعلنا","display":"جَعَلْنٰا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بين","display":"بَيْنِ"},{"kind":"word","token":"ايديهم","display":"اَيْدِيهِمْ"},{"kind":"word","token":"سدا","display":"سَدًّا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"خلفهم","display":"خَلْفِهِمْ"},{"kind":"word","token":"سدا","display":"سَدًّا"},{"kind":"word","token":"فاغشيناهم","display":"فَاَغْشَيْنٰاهُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يس","display":"يس"},{"kind":"word","token":"۹","display":"۹"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"،  يَقُولُ :  « فَاَعْمَيْنَاهُمْ  <quranic_text> « فَهُمْ لاٰ يُبْصِرُونَ » </quranic_text>   <footnote> [ يس ۹ ] </footnote>  الْهُدَي ،  اَخَذَ اللَّهُ بِسَمْعِهِمْ ،  وَ اَبْصَارِهِمْ ،  وَ قُلُوبِهِمْ ،  فَاَعْمَاهُمْ عَنِ الْهُدَي ،  نَزَلَتْ فِي اَبِي جَهْلِ بْنِ هِشَامٍ وَ نَفَرٍ مِنْ اَهْلِ بَيْتِهِ ،  وَ ذَلِكَ اَنَّ النَّبِيَّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) قَامَ يُصَلِّي وَ قَدْ حَلَفَ اَبُو جَهْلٍ ( لَعَنَهُ اللَّهُ ) لَئِنْ رَاهُ يُصَلِّي لَيَدْمَغَنَّهُ ،  فَجَاءَ وَ مَعَهُ حَجَرٌ ،  وَ النَّبِيُّ قَائِمٌ يُصَلِّي ،  فَجَعَلَ كُلَّمَا رَفَعَ الْحَجَرَ لِيَرْمِيَهُ اَثْبَتَ اللَّهُ يَدَهُ اِلَي عُنُقِهِ ،  وَ لاَ يَدُورُ الْحَجَرُ بِيَدِهِ ،  فَلَمَّا رَجَعَ اِلَي اَصْحَابِهِ سَقَطَ الْحَجَرُ مِنْ يَدِهِ ،  ثُمَّ قَامَ رَجُلٌ اخَرُ ،  وَ هُوَ مِنْ رَهْطِهِ اَيْضاً ،  وَ قَالَ :  اَنَا اَقْتُلُهُ .  فَلَمَّا دَنَا مِنْهُ فَجَعَلَ يَسْمَعُ قِرَاءَةَ رَسُولِ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) فَاُرْعِبَ ،  فَرَجَعَ اِلَي اَصْحَابِهِ ،  فَقَالَ :  حَالَ بَيْنِي وَ بَيْنَهُ كَهَيْئَةِ الْفَحْلِ ،  يَخْطِرُ بِذَنَبِهِ ،  فَخِفْتُ اَنْ اَتَقَدَّمَ »","translation_segment":"","segment_columns":[{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"فاعميناهم","display":"فَاَعْمَيْنَاهُمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فهم","display":"فَهُمْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يبصرون","display":"يُبْصِرُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يس","display":"يس"},{"kind":"word","token":"۹","display":"۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الهدي","display":"الْهُدَي"},{"kind":"word","token":"اخذ","display":"اَخَذَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"بسمعهم","display":"بِسَمْعِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ابصارهم","display":"اَبْصَارِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلوبهم","display":"قُلُوبِهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فاعماهم","display":"فَاَعْمَاهُمْ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الهدي","display":"الْهُدَي"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جهل","display":"جَهْلِ"},{"kind":"word","token":"بن