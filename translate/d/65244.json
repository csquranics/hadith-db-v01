{"consensus_set_id":"65244","translation_language":"fa","translation_source":{"hid":"409853"},"segments":[{"source_hadith_segment":"« تَسْبِيحُ فَاطِمَةَ الزَّهْرَاءِ ( عَلَيْهَا السَّلاَمُ ) مِنَ الذِّكْرِ الْكَثِيرِ الَّذِي قَالَ اللَّهُ عَزَّ وَ جَلَّ :   <quranic_text> « اُذْكُرُوا اللّٰهَ ذِكْراً كَثِيراً » </quranic_text>   <footnote> [ الاحزاب ۴۱ ] </footnote>   .  وَ عَنْهُ :  عَنْ مُحَمَّدِ بْنِ يَحْيَي ،  عَنْ اَحْمَدَ بْنِ مُحَمَّدِ بْنِ عِيسَي ،  عَنْ عَلِيِّ بْنِ الْحَكَمِ ،  عَنْ سَيْفِ بْنِ عَمِيرَةَ ،  عَنْ اَبِي اُسَامَةَ زَيْدٍ الشَّحَّامِ ،  وَ مَنْصُورِ بْنِ حَازِمٍ ،  وَ سَعِيدٍ الْاَعْرَجِ ،  عَنْ اَبِي عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ )  ،  مِثْلَهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"تسبيح","display":"تَسْبِيحُ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةَ"},{"kind":"word","token":"الزهراء","display":"الزَّهْرَاءِ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الذكر","display":"الذِّكْرِ"},{"kind":"word","token":"الكثير","display":"الْكَثِيرِ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اذكروا","display":"اُذْكُرُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"ذكرا","display":"ذِكْراً"},{"kind":"word","token":"كثيرا","display":"كَثِيراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحزاب","display":"الاحزاب"},{"kind":"word","token":"۴۱","display":"۴۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","to