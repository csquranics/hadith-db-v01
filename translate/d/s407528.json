{"consensus_set_id":"s407528","translation_language":"fa","translation_source":{"hid":"407528"},"segments":[{"source_hadith_segment":"قَالَ جَلَّ ذِكْرُهُ :   <quranic_text> « فَسْئَلُوا اَهْلَ الذِّكْرِ اِنْ كُنْتُمْ لاٰ تَعْلَمُونَ » </quranic_text>   <footnote> [ النحل ۴۳ ] </footnote>   .  قَالَ :  « اَلْكِتَابُ :  الذِّكْرُ ،  وَ اَهْلُهُ :  الُ مُحَمَّدٍ ( عَلَيْهِمُ السَّلاَمُ ) ،  اَمَرَ اللَّهُ عَزَّ وَ جَلَّ بِسُؤَالِهِمْ وَ لَمْ يَاْمُرْ بِسُؤَالِ الْجُهَّالِ ،  وَ سَمَّي اللَّهُ عَزَّ وَ جَلَّ الْقُرْانَ ذِكْراً ،  فَقَالَ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « وَ اَنْزَلْنٰا اِلَيْكَ الذِّكْرَ لِتُبَيِّنَ لِلنّٰاسِ مٰا نُزِّلَ اِلَيْهِمْ وَ لَعَلَّهُمْ يَتَفَكَّرُونَ » </quranic_text>   <footnote> [ النحل ۴۴ ] </footnote> وَ قَالَ عَزَّ وَ جَلَّ :   <quranic_text> « وَ اِنَّهُ لَذِكْرٌ لَكَ وَ لِقَوْمِكَ وَ سَوْفَ تُسْئَلُونَ » </quranic_text>   <footnote> [ الزخرف ۴۴ ] </footnote> .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"ذكره","display":"ذِكْرُهُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فسئلوا","display":"فَسْئَلُوا"},{"kind":"word","token":"اهل","display":"اَهْلَ"},{"kind":"word","token":"الذكر","display":"الذِّكْرِ"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"كنتم","display":"كُنْتُمْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تعلمون","display":"تَعْلَمُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النحل","display":"النحل"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الكتاب","display":"اَلْكِتَابُ"},{"kind":"word","token":"الذكر","display":"الذِّكْرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اهله","display":"اَهْلُهُ"},{"kind":"