{"consensus_set_id":"7413","translation_language":"fa","translation_source":{"hid":"109877"},"segments":[{"source_hadith_segment":"فِي اَلزَّرْعِ حَقَّانِ حَقٌّ تُؤْخَذُ بِهِ وَ حَقٌّ","translation_segment":"معاویه بن شریح گوید: از امام صادق علیه السلام شنیدم","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الزرع","display":"اَلزَّرْعِ"},{"kind":"word","token":"حقان","display":"حَقَّانِ"},{"kind":"word","token":"حق","display":"حَقٌّ"},{"kind":"word","token":"تؤخذ","display":"تُؤْخَذُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حق","display":"حَقٌّ"}]},{"source_hadith_segment":"تُعْطِيهِ قُلْتُ وَ مَا الَّذِي اُوخَذُ بِهِ وَ مَا الَّذِي اُعْطِيهِ قَالَ اَمَّا","translation_segment":"که می‌فرمود: در مزرعه و کشتزار، دو حق بر عهده توست: حقی که از تو می‌گیرند، حقی که","segment_columns":[{"kind":"word","token":"تعطيه","display":"تُعْطِيهِ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"اوخذ","display":"اُوخَذُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"اعطيه","display":"اُعْطِيهِ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اما","display":"اَمَّا"}]},{"source_hadith_segment":"الَّذِي تُؤْخَذُ بِهِ فَالْعُشْرُ وَ نِصْفُ الْعُشْرِ وَ اَمَّا الَّذِي تُعْطِيهِ فَقَوْلُ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ اتُوا حَقَّهُ يَوْمَ حَصٰادِهِ » </quranic_text>   <footnote> [ الانعام ۱۴۱ ] </footnote>  يَعْنِي مِنْ حَصْدِكَ الشَّيْءَ بَعْدَ الشَّيْءِ وَ لاَ اَعْلَمُهُ اِلاَّ قَالَ الضِّغْثَ ثُمَّ الضِّغْثَ حَتَّي يَفْرُغَ .","translation_segment":"خود عطا خواهی کرد. پرسیدم: کدام حق است که باید بگیرند؟ و کدام حقی است که خود باید بدهم‌؟ فرمود: حقی که از تو می‌گیرند، ضریب ده‌یک و بیست‌یک محصول است. حقی که تو خواهی پرداخت، گفتار خدای عز و جل‌ است که می‌فرماید: «حق برداشت را در روز چیدن محصول بپردازید» یعنی از خوشه‌های گندم و جو، یک مشت یک مشت به فقیران حاضر بدهید تا از برداشت محصول فارغ شوید.","segment_columns":[{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"تؤخذ","display":"تُؤْخَذُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"فالعشر","display":"فَالْعُشْرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نصف","display":"نِصْفُ"},{"kind":"word","token":"العشر","display":"الْعُشْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الحق","display":"الْحَقُّ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"تعطيه","display":"تُعْطِيهِ"},{"kind":"word","token":"فانه","display":"فَاِنَّهُ"},{"kind":"word","token":"فقول","display":"فَقَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اتوا","display":"اتُوا"},{"kind":"word","token":"حقه","display":"حَقَّهُ"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"حصاده","display":"حَصٰادِهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانعام","display":"الانعام"},{"kind":"word","token":"۱۴۱","display":"۱۴۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"حصدك","display":"حَصْدِكَ"},{"kind":"word","token":"الشيء","display