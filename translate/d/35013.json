{"consensus_set_id":"35013","translation_language":"fa","translation_source":{"hid":"55119"},"segments":[{"source_hadith_segment":"اِنَّ اَصْحَابَ مُوسَي اُبْتُلُوا بِنَهَرٍ وَ هُوَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « اِنَّ اللّٰهَ مُبْتَلِيكُمْ بِنَهَرٍ » </quranic_text>   <footnote> [ البقرة ۲۴۹ ] </footnote>  وَ اِنَّ اَصْحَابَ الْقَائِمِ عَلَيْهِ السَّلاَمُ يُبْتَلُونَ بِمِثْلِ ذَلِكَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابَ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"ابتلوا","display":"اُبْتُلُوا"},{"kind":"word","token":"بنهر","display":"بِنَهَرٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"قول","display":"قَوْلُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"مبتليكم","display":"مُبْتَلِيكُمْ"},{"kind":"word","token":"بنهر","display":"بِنَهَرٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۴۹","display":"۲۴۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابَ"},{"kind":"word","token":"القائم","display":"الْقَائِمِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"يبتلون","display":"يُبْتَلُونَ"},{"kind":"word","token":"بمثل","display":"بِمِثْلِ"},{"kind":"word","tok