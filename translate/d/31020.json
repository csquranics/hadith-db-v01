{"consensus_set_id":"31020","translation_language":"fa","translation_source":{"hid":"331886"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « اَمْ حَسِبَ الَّذِينَ يَعْمَلُونَ السَّيِّئٰاتِ » </quranic_text>   <footnote> [ العنكبوت ۴ ] </footnote>  [ قَالَ :  ] نَزَلَتْ فِي عُتْبَةَ وَ شَيْبَةَ وَ الْوَلِيدِ بْنِ عُتْبَةَ ،  وَ هُمُ الَّذِينَ بَارَزُوا عَلِيّاً وَ حَمْزَةَ وَ عُبَيْدَةَ","translation_segment":"عن ابن عباس فی قوله تعالی: (أم حسب الذین یعملون السیئات) قال: نزلت فی عتبه و شیبه و الولید بن عتبه، و هم الذین بارزوا علیا و حمزه و عبیده. و فی قوله تعالی: (من کان یرجو لقاء الله فإن‌ أجل الله لآت و هو السمیع العلیم، و من جاهد فإنما یجاهد لنفسه) قال: نزلت فی علی‌ و صاحبیه","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"حسب","display":"حَسِبَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يعملون","display":"يَعْمَلُونَ"},{"kind":"word","token":"السيئات","display":"السَّيِّئٰاتِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يسبقونا","display":"يَسْبِقُونٰا"},{"kind":"word","token":"ساء","display":"سٰاءَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يحكمون","display":"يَحْكُمُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العنكبوت","display":"العنكبوت"},{"kind":"word","token":"۴","display":"۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"عتبه","display":"عُتْبَةَ"},{"kind":"word","token":"و"