{"consensus_set_id":"116937","translation_language":"fa","translation_source":{"hid":"331953"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « اِنَّمٰا يُرِيدُ اللّٰهُ » </quranic_text>   <footnote> [ الاحزاب ۳۳ ] </footnote>  [ قَالَ :  ] نَزَلَتْ فِي رَسُولِ اللَّهِ وَ عَلِيٍّ وَ فَاطِمَةَ وَ الْحَسَنِ وَ الْحُسَيْنِ  .","translation_segment":"عن أبی صالح، عن ابن عباس فی قوله تعالی: (إنما یرید الله) قال: نزلت فی رسول الله و علی و فاطمه و الحسن و الحسین. و الرجس الشک. ابن عباس راجع به سخن خداوند: «انما یرید الله» گفت: درباره پیامبر خدا و علی و فاطمه و حسن و حسین نازل شده است و منظور از پلیدی شرک است.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"يريد","display":"يُرِيدُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاحزاب","display":"الاحزاب"},{"kind":"word","token":"۳۳","display":"۳۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"خمسه","display":"خَمْسَةٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فاطمه","display":"فَاطِمَةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الح