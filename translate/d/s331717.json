{"consensus_set_id":"s331717","translation_language":"fa","translation_source":{"hid":"331717"},"segments":[{"source_hadith_segment":"سَاَلْتُ رَسُولَ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ عَنْ قَوْلِ اللَّهِ تَعَالَي :   <quranic_text> « وَ مَنْ عِنْدَهُ عِلْمُ الْكِتٰابِ » </quranic_text>   <footnote> [ الرعد ۴۳ ] </footnote>  قَالَ :  ذَاكَ اَخِي عَلِيُّ بْنُ اَبِي طَالِبٍ  .","translation_segment":"عن أبی سعید الخدری قال: سألت رسول الله (صلی الله علیه و آله) عن قول الله تعالی: (و من عنده علم الکتاب) قال: ذاک أخی علی‌ بن ابی طالب. ابو سعید خدری گفت: از پیامبر خدا راجع به سخن خداوند: «و من عنده علم الکتاب» پرسیدم، گفت: او برادرم علی‌ بن ابی طالب (علیه السلام) است.","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"علم","display":"عِلْمُ"},{"kind":"word","token":"الكتاب","display":"الْكِتٰابِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الرعد","display":"الرعد"},{"kind":"word","token":"۴۳","display":"۴۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ذاك","display":"ذَاكَ"},{"kind":"word","token":"اخي","display":"اَخِي"},{"kind":"word","token":"علي","display":"عَلِ