play":"طَيِّباً"}]},{"source_hadith_segment":"وَ اَعْطِنِي فِيمَا رَزَقْتَنِي الْعَافِيَةَ","translation_segment":"تا از روزی و احسان تو بدست آرم،","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعطني","display":"اَعْطِنِي"},{"kind":"word","token":"فيما","display":"فِيمَا"},{"kind":"word","token":"رزقتني","display":"رَزَقْتَنِي"},{"kind":"word","token":"العافيه","display":"الْعَافِيَةَ"}]},{"source_hadith_segment":"غَدَوْتُ بِحَوْلِ اللَّهِ وَ قُوَّتِهِ غَدَوْتُ بِغَيْرِ حَوْلٍ مِنِّي وَ لاَ قُوَّةٍ وَ لَكِنْ بِحَوْلِكَ وَ قُوَّتِكَ وَ","translation_segment":"پس روزی خوب و فراوان و حلال و پاکیزه بمن عنایت کن و آنچه را که بمن روزی دهی","segment_columns":[{"kind":"word","token":"غدوت","display":"غَدَوْتُ"},{"kind":"word","token":"بحول","display":"بِحَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوته","display":"قُوَّتِهِ"},{"kind":"word","token":"غدوت","display":"غَدَوْتُ"},{"kind":"word","token":"بغير","display":"بِغَيْرِ"},{"kind":"word","token":"حول","display":"حَوْلٍ"},{"kind":"word","token":"مني","display":"مِنِّي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"قوه","display":"قُوَّةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لكن","display":"لَكِنْ"},{"kind":"word","token":"بحولك","display":"بِحَوْلِكَ"},{"kind":"word","token":"منك","display":"مِنْكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قوتك","display":"قُوَّتِكَ"},{"kind":"word","token":"و","display":"وَ"}]},{"source_hadith_segment":"اَبْرَاُ اِلَيْكَ مِنَ الْحَوْلِ وَ الْقُوَّةِ اللَّهُمَّ اِنِّي اَسْاَلُكَ بَرَكَةَ هَذَا الْيَوْمِ فَبَارِكْ لِي فِي جَمِيعِ اُمُورِي يَا اَرْحَمَ الرَّاحِمِينَ وَ صَلَّي اللَّهُ عَلَي مُحَمَّدٍ وَ الِهِ الطَّيِّبِينَ فَاِذَا اِنْتَهَيْتَ اِلَي السُّوقِ فَقُلْ اَشْهَدُ اَنْ  <quranic_text> « لاٰ اِلٰهَ اِلاَّ اللّٰهُ » </quranic_text>   <footnote> [ محمد ۱۹ ] </footnote>  وَحْدَهُ  <quranic_text> « لاٰ شَرِيكَ لَهُ » </quranic_text>   <footnote> [ الانعام ۱۶۳ ] </footnote>   <quranic_text> « لَهُ الْمُلْكُ وَ لَهُ الْحَمْدُ » </quranic_text>   <footnote> [ التغابن ۱ ] </footnote>   <quranic_text> « يُحْيِي وَ يُمِيتُ » </quranic_text>   <footnote> [ العمران ۱۵۶ ] </footnote>  وَ يُمِيتُ وَ يُحْيِي وَ هُوَ حَيٌّ لاَ يَمُوتُ بِيَدِهِ الْخَيْرُ  <quranic_text> « وَ هُوَ عَليٰ كُلِّ شَيْءٍ قَدِيرٌ » </quranic_text>   <footnote> [ التغابن ۱ ] </footnote>  وَ اَشْهَدُ اَنَّ مُحَمَّداً عَبْدُهُ وَ رَسُولُهُ اللَّهُمَّ اِنِّي اَسْاَلُكَ خَيْرَهَا وَ خَيْرَ اَهْلِهَا وَ اَعُوذُ بِكَ مِنْ شَرِّهَا وَ مِنْ شَرِّ اَهْلِهَا اللَّهُمَّ اِنِّي اَعُوذُ بِكَ اَنْ اَبْغِيَ اَوْ يُبْغَي عَلَيَّ اَوْ اَنْ اَظْلِمَ اَوْ اُظْلَمَ اَوْ اَعْتَدِيَ اَوْ يُعْتَدَي عَلَيَّ","translation_segment":"وسیله سعادت من قرار ده، بحول و قوه خدا صبح میکنم و بیرون میروم، و بامدادان بدنبال روزی میروم بی‌آنکه خود نیرو و توانی داشته باشم، ولی با نیرو و قدرت تو میروم و از هر قوت دیگری برائت می‌جویم، خداوندا از تو برکت امروز را خواستارم ای بهترین رحم آرندگان بهمه کارهایم برکت ده، و بر محمد و آل پاکش درود بفرست». و چون ببازار رسی بگو: «شهادت میدهم که جز اللٰه خدایی نیست، سلطنت و سپاس مختص اوست، بدست قدرت خود میمیراند و زنده میکند، و زنده میکند و میمیراند، وجود زنده‌ای است که مرگ در او راه ندارد، و بر هر چیز توانا است، و شهادت میدهم که محمد (صلی الله علیه و آله) بنده و پیامبر اوست. خداوندا خیر و سعادت بازار و اهل آن را از تو خواهانم، و از شر آن و اهل آن بتو پناهنده میشوم، و خداوندا، از اینکه بکسی تجاوز کنم یا بمن تجاوزی شود و یا ستم کنم و یا مظلوم واقع شوم بتو پناه","segment_columns":[{"kind":"word","token":"ابرا","display":"اَبْرَاُ"},{"kind":"word","token":"اليك","display":"اِلَيْكَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الحول","display":"الْحَوْلِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"القوه","display":"الْقُوَّةِ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"wor