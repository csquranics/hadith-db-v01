{"consensus_set_id":"45697","translation_language":"fa","translation_source":{"hid":"332118"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « وَ مَنْ يَقْتَرِفْ حَسَنَةً » </quranic_text>   <footnote> [ الشوري ۲۳ ] </footnote>  قَالَ :  الْمَوَدَّةُ لاِلِ مُحَمَّدٍ  .","translation_segment":"عن السدی‌ فی قوله تعالی: (و من یقترف حسنه) قال: الموده لآل محمد. سدی درباره سخن خداوند: «و من یقترف حسنه» گفت: دوستی آل محمد (صلی الله علیه و آله)","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"يقترف","display":"يَقْتَرِفْ"},{"kind":"word","token":"حسنه","display":"حَسَنَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الشوري","display":"الشوري"},{"kind":"word","token":"۲۳","display":"۲۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الموده","display":"الْمَوَدَّةُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"لال","display":"لاِلِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"}]}]}