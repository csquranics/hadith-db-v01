{"consensus_set_id":"31586","translation_language":"fa","translation_source":{"hid":"97952"},"segments":[{"source_hadith_segment":"عَنِ اَلتَّسْبِيحِ فِي الْمَخْرَجِ وَ قِرَاءَةِ الْقُرْانِ فَقَالَ « لَمْ يُرَخَّصْ فِي الْكَنِيفِ اَكْثَرَ مِنْ ايَةِ الْكُرْسِيِّ وَ يَحْمَدَ اللَّهَ اَوْ ايَةِ  <quranic_text> « اَلْحَمْدُ لِلّٰهِ رَبِّ الْعٰالَمِينَ » </quranic_text>   <footnote> [ الفاتحة ۲ ] </footnote>   .","translation_segment":"و عمر بن یزید از امام صادق علیه السلام پرسید: در باره تسبیح خداوند و خواندن قرآن در بیت الخلا که حکم آن چیست‌؟ آن حضرت فرمود: در آبریزگاه بیش از آیه الکرسی و چیزی که حمد خداوند را در بر داشته باشد یا آیه «الحمد للٰه‌ رب‌ العٰالمین‌» به خواندن چیزی رخصت داده نشده است.","segment_columns":[{"kind":"word","token":"انه","display":"انه"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"عمر","display":"عمر"},{"kind":"word","token":"بن","display":"بن"},{"kind":"word","token":"يزيد","display":"يزيد"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"التسبيح","display":"اَلتَّسْبِيحِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"المخرج","display":"الْمَخْرَجِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قراءه","display":"قِرَاءَةِ"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يرخص","display":"يُرَخَّصْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الكنيف","display":"الْكَنِيفِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"اكثر","display":"اَكْثَرَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ايه",