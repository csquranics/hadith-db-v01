{"consensus_set_id":"51515","translation_language":"fa","translation_source":{"hid":"204913"},"segments":[{"source_hadith_segment":"فَاِنْ قَامَ رَجُلاَنِ فَقَالَ اَحَدُهُمَا هَذَا الْفَجْرُ قَدْ طَلَعَ وَ قَالَ الْاخَرُ مَا اَرَي شَيْئاً طَلَعَ بِعَيْنِي وَ هُمَا مَعاً مِنْ اَهْلِ الْعِلْمِ وَ الْمَعْرِفَةِ بِطُلُوعِ الْفَجْرِ وَ صِحَّةِ الْبَصَرِ قَالَ عَلَيْهِ السَّلاَمُ فَلِلَّذِي لَمْ يَسْتَبِنِ الْفَجْرَ اَنْ يَاْكُلَ وَ يَشْرَبَ حَتَّي يِتَبَيَّنَهُ وَ عَلَي الَّذِي تَبَيَّنَهُ اَنْ يُمْسِكَ عَنِ الطَّعَامِ وَ الشَّرَابِ لِاَنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ  <quranic_text> « كُلُوا وَ اِشْرَبُوا حَتّٰي يَتَبَيَّنَ لَكُمُ الْخَيْطُ الْاَبْيَضُ مِنَ الْخَيْطِ الْاَسْوَدِ مِنَ الْفَجْرِ » </quranic_text>   <footnote> [ البقرة ۱۸۷ ] </footnote>  فَاَمَّا اِنْ كَانَ اَحَدُهُمَا اَعْلَمَ اَوْ اَحَدَّ نَظَراً مِنَ الْاخَرِ فَعَلَي الَّذِي هُوَ دُونَهُ فِي النَّظَرِ وَ الْعِلْمِ اَنْ يَقْتَدِيَ بِهِ .","translation_segment":"","segment_columns":[{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"قام","display":"قَامَ"},{"kind":"word","token":"رجلان","display":"رَجُلاَنِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"احدهما","display":"اَحَدُهُمَا"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الفجر","display":"الْفَجْرُ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"طلع","display":"طَلَعَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الاخر","display":"الْاخَرُ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اري","display":"اَرَي"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"طلع","display":"طَلَعَ"},{"kind":"word","token":"بعيني","display":"بِعَيْنِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هما","display":"هُمَا"},{"kind":"word","token":"معا","display":"مَعاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind"