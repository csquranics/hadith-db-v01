{"consensus_set_id":"75245","translation_language":"fa","translation_source":{"hid":"376091"},"segments":[{"source_hadith_segment":"يَتَكَلَّمُ بِهِ سَبْعَ مَرَّاتٍ  <quranic_text> « سَنَشُدُّ عَضُدَكَ بِاَخِيكَ وَ نَجْعَلُ لَكُمٰا سُلْطٰاناً فَلاٰ يَصِلُونَ اِلَيْكُمٰا بِايٰاتِنٰا اَنْتُمٰا وَ مَنِ اِتَّبَعَكُمَا الْغٰالِبُونَ » </quranic_text>   <footnote> [ القصص ۳۵ ] </footnote>   .","translation_segment":"هفت بار بر سحر شده بخواند: («سنشد عضدک‌ بأخیک‌ و نجعل‌ لکمٰا سلطٰانا فلاٰ یصلون‌ إلیکمٰا بآیٰاتنٰا أنتمٰا و من‌ اتبعکما الغٰالبون‌»).","segment_columns":[{"kind":"word","token":"يتكلم","display":"يَتَكَلَّمُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"سنشد","display":"سَنَشُدُّ"},{"kind":"word","token":"عضدك","display":"عَضُدَكَ"},{"kind":"word","token":"باخيك","display":"بِاَخِيكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"نجعل","display":"نَجْعَلُ"},{"kind":"word","token":"لكما","display":"لَكُمٰا"},{"kind":"word","token":"سلطانا","display":"سُلْطٰاناً"},{"kind":"word","token":"فلا","display":"فَلاٰ"},{"kind":"word","token":"يصلون","display":"يَصِلُونَ"},{"kind":"word","token":"اليكما","display":"اِلَيْكُمٰا"},{"kind":"word","token":"باياتنا","display":"بِايٰاتِنٰا"},{"kind":"word","token":"انتما","display":"اَنْتُمٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"اتبعكما","display":"اِتَّبَعَكُمَا"},{"kind":"word","token":"الغالبون","display":"الْغٰالِبُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القصص","display":"القصص"},{"kind":"word","token":"۳۵","display":"۳۵"},{"kind":"tag_close","tag_name":"footnote"}]}]}