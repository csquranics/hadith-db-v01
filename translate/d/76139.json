{"consensus_set_id":"76139","translation_language":"fa","translation_source":{"hid":"312814"},"segments":[{"source_hadith_segment":"اَللَّهُمَّ اِجْعَلْنَا مَشْغُولِينَ بِاَمْرِكَ امِنِينَ بِوَعْدِكَ ايِسِينَ مِنْ خَلْقِكَ انِسِينَ بِكَ مُسْتَوْحِشِينَ مِنْ غَيْرِكَ رَاضِينَ بِقَضَائِكَ صَابِرِينَ عَلَي بَلاَئِكَ شَاكِرِينَ عَلَي نَعْمَائِكَ مُتَلَذِّذِينَ بِذِكْرِكَ فَرِحِينَ بِكِتَابِكَ مُنَاجِينَ اِيَّاكَ انَاءَ اللَّيْلِ وَ اَطْرَافَ النَّهَارِ مُسْتَعِدِّينَ لِلْمَوْتِ مُشْتَاقِينَ اِلَي لِقَائِكَ مُتَبَغِّضِينَ لِلدُّنْيَا مُحِبِّينَ لِلْاخِرَةِ -  <quranic_text> « وَ اتِنٰا مٰا وَعَدْتَنٰا عَليٰ رُسُلِكَ وَ لاٰ تُخْزِنٰا يَوْمَ الْقِيٰامَةِ اِنَّكَ لاٰ تُخْلِفُ الْمِيعٰادَ » </quranic_text>   <footnote> [ العمران ۱۹۴ ] </footnote>   .","translation_segment":"و از دعای آن سرور است اللهم اجعلنا مشغولین بذکرک آمنین بوعدک آیسین من خلقک آنسین بک مستوحشین من غیرک راضین بقضائک صابرین علی بلائک شاکرین علی نعمائک متلذذین بذکرک فرحین بکتابک مناجین ایاک اناء اللیل و اطراف النهار مستعدین للموت مشتاقین الی لقائک مبغضین للدنیا محبین للآخره «ربنٰا و آتنٰا مٰا وعدتنٰا علیٰ‌ رسلک‌ و لاٰ تخزنٰا یوم‌ القیٰامه‌ إنک‌ لاٰ تخلف‌ المیعٰاد».","segment_columns":[{"kind":"word","token":"اللهم","display":"اَللَّهُمَّ"},{"kind":"word","token":"اجعلنا","display":"اِجْعَلْنَا"},{"kind":"word","token":"مشغولين","display":"مَشْغُولِينَ"},{"kind":"word","token":"بامرك","display":"بِاَمْرِكَ"},{"kind":"word","token":"امنين","display":"امِنِينَ"},{"kind":"word","token":"بوعدك","display":"بِوَعْدِكَ"},{"kind":"word","token":"ايسين","display":"ايِسِينَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"خلقك","display":"خَلْقِكَ"},{"kind":"word","token":"انسين","display":"انِسِينَ"},{"kind":"word","token":"بك","display":"بِكَ"},{"kind":"word","token":"مستوحشين","display":"مُسْتَوْحِشِينَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"غيرك","display":"غَيْرِكَ"},{"kind":"word","token":"راضين","display":"رَاضِينَ"},{"kind":"word","token":"بقضائك","displa