{"consensus_set_id":"35295","translation_language":"fa","translation_source":{"hid":"405678"},"segments":[{"source_hadith_segment":".  وَ عَنْ اَبِي بَصِيرٍ ،  عَنْ اَبِي جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ )  :  فِي قَوْلِهِ :   <quranic_text> « لَتُؤْمِنُنَّ بِهِ وَ لَتَنْصُرُنَّهُ » </quranic_text>   <footnote> [ العمران ۸۱ ] </footnote>   .  قَالَ :","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"بصير","display":"بَصِيرٍ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لتؤمنن","display":"لَتُؤْمِنُنَّ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لتنصرنه","display":"لَتَنْصُرُنَّهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۸۱","display":"۸۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"}]},{"source_hadith_segment":"قَالَ :  « مَا بَعَثَ اللَّهُ نَبِيّاً مِنْ لَدُنْ ادَمَ فَهَلُمَّ جَرّاً اِلاَّ وَ يَرْجِعُ اِلَي الدُّنْيَا فَيُقَاتِلُ فَيَنْصُرُ رَسُولَ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) وَ اَمِيرَ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ )  .  ثُمَّ اَخَذَ اللَّهُ اَيْضاً مِيثَاقَ الْاَنْبِيَاءِ لِرَسُولِهِ  ،  فَقَالَ :   <quranic_text> « قُلْ » </quranic_text>   <footnote> [ العمران ۸۴ ] </footnote>  - يَا مُحَمَّدُ -  <quranic_text> « امَنّٰا بِاللّٰهِ وَ مٰا اُنْزِلَ عَلَيْنٰا وَ مٰا اُنْزِلَ عَليٰ اِبْرٰاهِيمَ وَ اِسْمٰاعِيلَ وَ اِسْحٰاقَ وَ يَعْقُوبَ وَ الْاَسْبٰاطِ وَ مٰا اُوتِيَ مُوسيٰ وَ عِيسيٰ وَ » </quranic_text>   <footnote> [ العمران ۸۴ ] </footnote>  مَا اُوتِيَ  <quranic_text> « النَّبِيُّونَ مِنْ رَبِّهِمْ لاٰ نُفَرِّقُ بَيْنَ اَحَدٍ مِنْهُمْ وَ نَحْنُ لَهُ مُسْلِمُونَ » </quranic_text>   <footnote> [ العمران ۸۴ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"بعث","display":"بَعَثَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"نبيا","display":"نَبِيّاً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"لدن","display":"لَدُنْ"},{"kind":"word","token":"ادم","display":"ادَمَ"},{"kind":"word","token":"فهلم","display":"فَهَلُمَّ"},{"kind":"word","token":"جرا","display":"جَرّاً"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يرجع","display":"يَرْجِعُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الدنيا","display":"الدُّنْيَا"},{"kind":"word","token":"فيقاتل","display":"فَيُقَاتِلُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فينصر","display":"فَيَنْصُرُ"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"امير","display":"اَمِيرَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token