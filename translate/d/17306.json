{"consensus_set_id":"17306","translation_language":"fa","translation_source":{"hid":"406243"},"segments":[{"source_hadith_segment":"« اِنَّ اَللَّهَ تَعَالَي قَالَ لِمُحَمَّدٍ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ )  : <quranic_text> « اِنْ تَسْتَغْفِرْ لَهُمْ سَبْعِينَ مَرَّةً فَلَنْ يَغْفِرَ اللّٰهُ لَهُمْ » </quranic_text>   <footnote> [ التوبة ۸۰ ] </footnote> فَاسْتَغْفَرَ لَهُمْ مِائَةَ مَرَّةٍ لِيَغْفِرَ لَهُمْ ،  فَاَنْزَلَ اللَّهُ : <quranic_text> « سَوٰاءٌ عَلَيْهِمْ اَسْتَغْفَرْتَ لَهُمْ اَمْ لَمْ تَسْتَغْفِرْ لَهُمْ لَنْ يَغْفِرَ اللّٰهُ لَهُمْ » </quranic_text>   <footnote> [ المنافقون ۶ ] </footnote>   ،  وَ قَالَ : <quranic_text> « وَ لاٰ تُصَلِّ عَليٰ اَحَدٍ مِنْهُمْ مٰاتَ اَبَداً وَ لاٰ تَقُمْ عَليٰ قَبْرِهِ » </quranic_text>   <footnote> [ التوبة ۸۴ ] </footnote> فَلَمْ يَسْتَغْفِرْ لَهُمْ بَعْدَ ذَلِكَ ،  وَ لَمْ يَقُمْ عَلَي قَبْرِ اَحَدٍ مِنْهُمْ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اَللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لمحمد","display":"لِمُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"سلم","display":"سلم"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"تستغفر","display":"تَسْتَغْفِرْ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"سبعين","display":"سَبْعِينَ"},{"kind":"word","token":"مره","display":"مَرَّةً"},{"kind":"word","token":"فلن","display":"فَلَنْ"},{"kind":"word","token":"يغفر","display":"يَغْفِرَ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"لهم","disp