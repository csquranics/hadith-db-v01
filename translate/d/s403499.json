{"consensus_set_id":"s403499","translation_language":"fa","translation_source":{"hid":"403499"},"segments":[{"source_hadith_segment":"« يَا مُعَاوِيَةُ ،  اِنَّا اَهْلُ بَيْتٍ اِخْتَارَ اللَّهُ لَنَا الْاخِرَةَ عَلَي الدُّنْيَا ،  وَ لَمْ يَرْضَ لَنَا بِالدُّنْيَا ثَوَاباً .  يَا مُعَاوِيَةُ ،  اِنَّ نَبِيَّ اللَّهِ زَكَرِيَّا قَدْ نُشِرَ بِالْمَنَاشِيرِ ،  وَ يَحْيَي بْنَ زَكَرِيَّا قَتَلَهُ قَوْمُهُ وَ هُوَ يَدْعُوهُمْ اِلَي اللَّهِ عَزَّ وَ جَلَّ [ وَ ذَلِكَ لِهَوَانِ الدُّنْيَا عَلَي اللَّهِ ] .  اِنَّ اَوْلِيَاءَ الشَّيْطَانِ قَدْ حَارَبُوا اَوْلِيَاءَ الرَّحْمَنِ ،  وَ قَدْ قَالَ اللَّهُ عَزَّ وَ جَلَّ فِي كِتَابِهِ :   <quranic_text> « اِنَّ الَّذِينَ يَكْفُرُونَ بِايٰاتِ اللّٰهِ وَ يَقْتُلُونَ النَّبِيِّينَ بِغَيْرِ حَقٍّ وَ يَقْتُلُونَ الَّذِينَ يَاْمُرُونَ بِالْقِسْطِ مِنَ النّٰاسِ فَبَشِّرْهُمْ بِعَذٰابٍ اَلِيمٍ » </quranic_text>   <footnote> [ العمران ۲۱ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"معاويه","display":"مُعَاوِيَةُ"},{"kind":"word","token":"انا","display":"اِنَّا"},{"kind":"word","token":"اهل","display":"اَهْلُ"},{"kind":"word","token":"بيت","display":"بَيْتٍ"},{"kind":"word","token":"اختار","display":"اِخْتَارَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"لنا","display":"لَنَا"},{"kind":"word","token":"الاخره","display":"الْاخِرَةَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الدنيا","display":"الدُّنْيَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يرض","display":"يَرْضَ"},{"kind":"word","token":"لنا","display":"لَنَا"},{"kind":"word","token":"بالدنيا","display":"بِالدُّنْيَا"},{"kind":"word","token":"ثوابا","display":"ثَوَاباً"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"معاويه","display":"مُعَاوِيَةُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"نبي","display":"نَبِيَّ"}