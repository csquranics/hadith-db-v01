{"consensus_set_id":"11645","translation_language":"fa","translation_source":{"hid":"407369"},"segments":[{"source_hadith_segment":"« اِبْلِيسُ قَالَ :  اَنْظِرْنِي اِلَي يَوْمِ يُبْعَثُونَ ،  فَاَبَي اللَّهُ ذَلِكَ عَلَيْهِ ،  فَقَالَ :   <quranic_text> « فَاِنَّكَ مِنَ الْمُنْظَرِينَ اِليٰ يَوْمِ الْوَقْتِ الْمَعْلُومِ » </quranic_text>   <footnote> [ الحجر ۳۷ ] </footnote>  فَاِذَا كَانَ يَوْمُ الْوَقْتِ الْمَعْلُومِ ظَهَرَ اِبْلِيسُ لَعَنَهُ اللَّهُ فِي جَمِيعِ اَشْيَاعِهِ مُنْذُ خَلَقَ اللَّهُ ادَمَ ( عَلَيْهِ السَّلاَمُ ) اِلَي يَوْمِ الْوَقْتِ الْمَعْلُومِ ،  وَ هِيَ اخِرُ كَرَّةٍ يَكُرُّهَا اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) »","translation_segment":"","segment_columns":[{"kind":"word","token":"سمعت","display":"سمعت"},{"kind":"word","token":"ابا","display":"أبا"},{"kind":"word","token":"عبد","display":"عبد"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السلام"},{"kind":"word","token":"يقول","display":"يقول"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"ابليس","display":"اِبْلِيسُ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انظرني","display":"اَنْظِرْنِي"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"يوم","display":"يَوْمِ"},{"kind":"word","token":"يبعثون","display":"يُبْعَثُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف۱۴","display":"الاعراف۱۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فابي","display":"فَاَبَي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"انك","display":"انك"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token"