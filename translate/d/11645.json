 لَهُ اَصْحَابُهُ :  اَيْنَ تُرِيدُ وَ قَدْ ظَفِرْتَ ؟  فَيَقُولُ :  اِنِّي اَرَي مَا لاَ تَرَوْنَ ،  اِنِّي اَخَافُ اللَّهَ رَبَّ الْعَالَمِينَ ،  فَيَلْحَقُهُ النَّبِيُّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) ،  فَيَطْعُنُهُ طَعْنَةً بَيْنَ كَتِفَيْهِ ،  فَيَكُونُ هَلاَكُهُ وَ هَلاَكُ جَمِيعِ اَشْيَاعِهِ ،  فَعِنْدَ ذَلِكَ يُعْبَدُ اللَّهُ عَزَّ وَ جَلَّ وَ لاَ يُشْرَكُ بِهِ شَيْءٌ ،  وَ يَمْلِكُ اَمِيرُ الْمُؤْمِنِينَ ( عَلَيْهِ السَّلاَمُ ) اَرْبَعاً وَ اَرْبَعِينَ اَلْفَ سَنَةٍ ،  حَتَّي يَلِدَ الرَّجُلُ مِنْ شِيعَةِ عَلِيٍّ ( عَلَيْهِ السَّلاَمُ ) اَلْفَ وَلَدٍ مِنْ صُلْبِهِ ذَكَرٍ ،  فِي كُلِّ سَنَةٍ ذَكَرٌ ،  وَ عِنْدَ ذَلِكَ تَظْهَرُ الْجَنَّتَانِ الْمُدْهَامَّتَانِ ،  عِنْدَ مَسْجِدِ الْكُوفَةِ وَ مَا حَوْلَهُ بِمَا شَاءَ اللَّهُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انها","display":"اِنَّهَا"},{"kind":"word","token":"لكرات","display":"لَكَرَّاتٌ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"انها","display":"اِنَّهَا"},{"kind":"word","token":"لكرات","display":"لَكَرَّاتٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كرات","display":"كَرَّاتٌ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"امام","display":"اِمَامٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قرن","display":"قَرْنٍ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يكر","display":"يَكُرُّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قرنه","display":"قَرْنِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يكر","display":"يَكُرُّ"},{"kind":"word","token":"معه","display":"مَعَهُ"},{"kind":"word","token":"البر","display":"الْبَرُّ"},{"kind":"word","token":"و","display":"