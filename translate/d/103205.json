{"consensus_set_id":"103205","translation_language":"fa","translation_source":{"hid":"100964"},"segments":[{"source_hadith_segment":"« يَنْبَغِي لِمَنْ  <quranic_text> « تَعَجَّلَ فِي يَوْمَيْنِ » </quranic_text>   <footnote> [ البقرة ۲۰۳ ] </footnote>  اَنْ يُمْسِكَ عَنِ الصَّيْدِ حَتَّي يَنْقَضِيَ الْيَوْمُ الثَّالِثُ » .","translation_segment":"و معاویه بن عمار از آن امام روایت کرده است که فرمود: برای کسی که توقف سه روز در منی را بدو روز برگزار کند سزاوار چنان است که از شکار خودداری کند، تا روز سوم سپری گردد.","segment_columns":[{"kind":"word","token":"ينبغي","display":"يَنْبَغِي"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"تعجل","display":"تَعَجَّلَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"يومين","display":"يَوْمَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۰۳","display":"۲۰۳"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يمسك","display":"يُمْسِكَ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الصيد","display":"الصَّيْدِ"},{"kind":"word","token":"حتي","display":"حَتَّي"},{"kind":"word","token":"ينقضي","display":"يَنْقَضِيَ"},{"kind":"word","token":"اليوم","display":"الْيَوْمُ"},{"kind":"word","token":"الثالث","display":"الثَّالِثُ"}]}]}