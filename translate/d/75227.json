{"consensus_set_id":"75227","translation_language":"fa","translation_source":{"hid":"236811"},"segments":[{"source_hadith_segment":"<quranic_text> «   <footnote> [ ایهقران کریم ] </footnote>  وَ اُذْكُرُوا اِذْ اَنْتُمْ قَلِيلٌ مُسْتَضْعَفُونَ فِي الْاَرْضِ تَخٰافُونَ اَنْ يَتَخَطَّفَكُمُ النّٰاسُ فَاوٰاكُمْ وَ اَيَّدَكُمْ بِنَصْرِهِ وَ رَزَقَكُمْ مِنَ الطَّيِّبٰاتِ لَعَلَّكُمْ تَشْكُرُونَ اَنَّ الْخِطَابَ فِي تِلْكَ الْايَةِ لِقُرَيْشٍ خَاصَّةً ،  وَ الْمُرَادُ بِالنَّاسِ سَائِرُ الْعَرَبِ اَوِ الْاَعَمُّ .  » </quranic_text>","translation_segment":"","segment_columns":[{"kind":"word","token":"فاما","display":"فَاَمَّا"},{"kind":"word","token":"الايات","display":"اَلْايَاتُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قريش","display":"قُرَيْشٍ"},{"kind":"word","token":"فهي","display":"فَهِيَ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"ایهقران","display":"ایهقران"},{"kind":"word","token":"کریم","display":"کریم"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذكروا","display":"اُذْكُرُوا"},{"kind":"word","token":"اذ","display":"اِذْ"},{"kind":"word","token":"انتم","display":"اَنْتُمْ"},{"kind":"word","token":"قليل","display":"قَلِيلٌ"},{"kind":"word","token":"مستضعفون","display":"مُسْتَضْعَفُونَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"تخافون","display":"تَخٰافُونَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتخطفكم","display":"يَتَخَطَّفَكُمُ"},{"kind":"word","token":"الناس","display":"النّٰاسُ"},{"kind":"word","token":"فاواكم","display":"فَاوٰاكُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"w