{"consensus_set_id":"113633","translation_language":"fa","translation_source":{"hid":"109594"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « رَهْبٰانِيَّةً اِبْتَدَعُوهٰا مٰا كَتَبْنٰاهٰا عَلَيْهِمْ اِلاَّ اِبْتِغٰاءَ رِضْوٰانِ اللّٰهِ » </quranic_text>   <footnote> [ الحديد ۲۷ ] </footnote>  قَالَ صَلاَةُ اللَّيْلِ .","translation_segment":"محمد بن علی بن ابی عبد الله گوید: امام کاظم علیه السلام در مورد تفسیر این آیه که خداوند عز و جل‌ می‌فرماید: رهبٰانیه‌ ابتدعوهٰا مٰا کتبنٰاهٰا علیهم‌ إلا ابتغٰاء رضوٰان‌ اللٰه‌ فرمود: منظور از رهبانیت و رضای خدای، نماز شب است.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رهبانيه","display":"رَهْبٰانِيَّةً"},{"kind":"word","token":"ابتدعوها","display":"اِبْتَدَعُوهٰا"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"كتبناها","display":"كَتَبْنٰاهٰا"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"ابتغاء","display":"اِبْتِغٰاءَ"},{"kind":"word","token":"رضوان","display":"رِضْوٰانِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحديد","display":"الحديد"},{"kind":"word","token":"۲۷","display":"۲۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صلاه","display":"صَلاَةُ"},{"kind":"word","token":"الليل","display":"اللَّيْلِ"}]}]}