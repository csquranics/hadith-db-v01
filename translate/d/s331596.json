{"consensus_set_id":"s331596","translation_language":"fa","translation_source":{"hid":"331596"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي :  ]  <quranic_text> « اِنْ اَوْلِيٰاؤُهُ اِلاَّ الْمُتَّقُونَ » </quranic_text>   <footnote> [ الانفال ۳۴ ] </footnote>  يَعْنِي اَصْحَابَ مُحَمَّدٍ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  .","translation_segment":"عن السدی، عن أصحابه‌؟ فی قوله تعالی: (إن أولیاوه إلا المتقون) یعنی أصحاب محمد صلی الله علیه و آله و سلم. سدی از اصحاب خود درباره آیه «ان اولیاوه الا المتقون» نقل می‌کند که منظور اصحاب محمد هستند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"اولياؤه","display":"اَوْلِيٰاؤُهُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"المتقون","display":"الْمُتَّقُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانفال","display":"الانفال"},{"kind":"word","token":"۳۴","display":"۳۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"اصحاب","display":"اَصْحَابَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"}]}]}