segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ اِنِّي اَعُوذُ بِكَ مِنَ الشَّيْطَانِ الرَّجِيمِ وَ مِنْ مَغَاوِيهِ وَ اِعْتِرَاضِهِ وَ فَزَعِهِ وَ وَسْوَسَتِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"اللَّهُمَّ فَلاَ تَجْعَلْ لَهُ عَلَيَّ سُلْطَاناً وَ لاَ تَجْعَلْ لَهُ عَلَيَّ سَبِيلاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ لاَ تَجْعَلْ لَهُ فِي مَالِي وَ وُلْدِي شِرْكاً وَ لاَ نَصِيباً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"وَ بَاعِدْ بَيْنَنَا وَ بَيْنَهُ كَمَا بَاعَدْتَ بَيْنَ الْمَشْرِقِ وَ الْمَغْرِبِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"حَتَّي لاَ يُفْسِدَ شَيْئاً مِنْ طَاعَتِكَ عَلَيْنَا وَ اَتْمِمْ نِعْمَتَكَ عِنْدَنَا بِمَرْضَاتِكَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"يَا اَرْحَمَ الرَّاحِمِينَ وَ صَلَّي اللَّهُ عَلَي سَيِّدِنَا رَسُولِهِ مُحَمَّدٍ النَّبِيِّ وَ الِهِ الطَّاهِرِينَ وَ سَلَّمَ تَسْلِيماً .","translation_segment":"","segment_columns":[]}]}