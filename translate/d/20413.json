{"consensus_set_id":"20413","translation_language":"fa","translation_source":{"hid":"405589"},"segments":[{"source_hadith_segment":"« اِنَّ مُوسَي وَ هَارُونَ ( عَلَيْهِمَا السَّلاَمُ ) حِينَ دَخَلاَ عَلَي فِرْعَوْنَ لَمْ يَكُنْ فِي جُلَسَائِهِ يَوْمَئِذٍ وَلَدُ سِفَاحٍ ،  كَانُوا وَلَدَ نِكَاحٍ كُلُّهُمْ ،  وَ لَوْ كَانَ فِيهِمْ وَلَدُ سِفَاحٍ لَاَمَرَ بِقَتْلِهِمَا ،  فَقَالُوا :   <quranic_text> « اَرْجِهْ وَ اَخٰاهُ » </quranic_text>   <footnote> [ الاعراف ۱۱۱ ] </footnote>  وَ اَمَرُوهُ بِالتَّاَنِّي وَ النَّظَرِ .  ثُمَّ وَضَعَ يَدَهُ عَلَي صَدْرِهِ ،  وَ قَالَ :  وَ كَذَلِكَ نَحْنُ  ،  لاَ يَنْزِعُ اِلَيْنَا اِلاَّ كُلُّ خَبِيثِ الْوِلاَدَةِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هارون","display":"هَارُونَ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"حين","display":"حِينَ"},{"kind":"word","token":"دخلا","display":"دَخَلاَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"جلسائه","display":"جُلَسَائِهِ"},{"kind":"word","token":"يومئذ","display":"يَوْمَئِذٍ"},{"kind":"word","token":"ولد","display":"وَلَدُ"},{"kind":"word","token":"سفاح","display":"سِفَاحٍ"},{"kind":"word","token":"كانوا","display":"كَانُوا"},{"kind":"word","token":"ولد","display":"وَلَدَ"},{"kind":"word","token":"نكاح","display":"نِكَاحٍ"},{"kind":"word","token":"كلهم","display":"كُلُّهُمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"فيهم","display":"فِيهِمْ"},