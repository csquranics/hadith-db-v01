{"consensus_set_id":"1125","translation_language":"fa","translation_source":{"hid":"107298"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ جُعِلْتُ فِدَاكَ هَذَا الَّذِي قَدْ ظَهَرَ بِوَجْهِي يَزْعُمُ النَّاسُ اَنَّ اللَّهَ عَزَّ وَ جَلَّ لَمْ يَبْتَلِ بِهِ عَبْداً","translation_segment":"یونس بن عمار را (غده یا جراحت دیگری در صورتش پیدا شد) گوید: بحضرت صادق علیه السلام عرضکردم: فدایت شوم این (علتی) که در صورت من پیدا شده مردم پندارند که همانا خدای عز و","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"جعلت","display":"جُعِلْتُ"},{"kind":"word","token":"فداك","display":"فِدَاكَ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"ظهر","display":"ظَهَرَ"},{"kind":"word","token":"بوجهي","display":"بِوَجْهِي"},{"kind":"word","token":"يزعم","display":"يَزْعُمُ"},{"kind":"word","token":"الناس","display":"النَّاسُ"},{"kind":"word","token":"عله","display":"عِلَّةٌ"},{"kind":"word","token":"فليقرا","display":"فَلْيَقْرَاْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"جيبه","display":"جَيْبِهِ"},{"kind":"word","token":"الحمد","display":"الْحَمْدَ"},{"kind":"word","token":"سبع","display":"سَبْعَ"},{"kind":"word","token":"مرات","display":"مَرَّاتٍ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"ذهبت","display":"ذَهَبَتِ"},{"kind":"word","token":"العله","display":"الْعِلَّةُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","toke