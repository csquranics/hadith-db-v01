{"consensus_set_id":"3419","translation_language":"fa","translation_source":{"hid":"404362"},"segments":[{"source_hadith_segment":"« ذِرْوَةُ اَلْاَمْرِ وَ سَنَامُهُ وَ مِفْتَاحُهُ ،  وَ بَابُ الْاَنْبِيَاءِ ،  وَ رِضَا الرَّحْمَنِ ،  الطَّاعَةُ لِلْاِمَامِ بَعْدَ مَعْرِفَتِهِ - ثُمَّ قَالَ - اِنَّ اللَّهَ يَقُولُ :   <quranic_text> « مَنْ يُطِعِ الرَّسُولَ فَقَدْ اَطٰاعَ اللّٰهَ » </quranic_text>   <footnote> [ النساء ۸۰ ] </footnote> اِلَي  <quranic_text> « حَفِيظاً » </quranic_text>   <footnote> [ النساء ۸۰ ] </footnote> اَمَا لَوْ اَنَّ رَجُلاً قَامَ لَيْلَهُ ،  وَ صَامَ نَهَارَهُ ،  وَ تَصَدَّقَ بِجَمِيعِ مَالِهِ ،  وَ حَجَّ جَمِيعَ دَهْرِهِ ،  وَ لَمْ يَعْرِفْ وَلاَيَةَ وَلِيِّ اللَّهِ فَيُوَالِيَهُ ،  وَ تَكُونَ جَمِيعُ اَعْمَالِهِ بِوَلاَيَتِهِ مِنْهُ اِلَيْهِ ،  مَا كَانَ لَهُ عَلَي اللَّهِ حَقٌّ فِي ثَوَابٍ ،  وَ لاَ كَانَ مِنْ اَهْلِ الْاِيمَانِ - ثُمَّ قَالَ - اُولَئِكَ الْمُحْسِنُ مِنْهُمْ يُدْخِلُهُ اللَّهُ الْجَنَّةَ بِفَضْلِهِ وَ رَحْمَتِهِ »","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذروه","display":"ذِرْوَةُ"},{"kind":"word","token":"الامر","display":"اَلْاَمْرِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"خمسه","display":"خَمْسَةِ"},{"kind":"word","token":"اشياء","display":"اَشْيَاءَ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سنامه","display":"سَنَامُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مفتاحه","display":"مِفْتَاحُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"باب","display":"بَابُ"},{"kind":"word","token":"الانبياء","display":"الْاَنْبِيَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رضا","display":"رِضَا"},{"kind":"word","token":"الرحمن","display":"الرَّحْمَنِ"},{"kind":"word","token":"تبارك","display":"تبارك"},{"kind":"word","token":"وت