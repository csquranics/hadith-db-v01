"source_hadith_segment":"،  التَّوْبَةَ ،  اِسْتَغْفِرْ لَنَا فَلَنْ نَعُودَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  فَقَالَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) :","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"لاَ تَابَ اللَّهُ عَلَيْكُمَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَمَا يَنْفَعُكُمَا اِسْتِغْفَارِي وَ مَعَكُمَا هَذِهِ الْجُرْاَةُ عَلَي اللَّهِ وَ عَلَي رَسُولِهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"؟  !  قَالاَ :  يَا رَسُولَ اللَّهِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِنْ اِسْتَغْفَرْتَ لَنَا رَجَوْنَا اَنْ يَغْفِرَ لَنَا رَبُّنَا","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اَنْزَلَ اللَّهُ الْايَةَ الَّتِي فِيهَا :   <quranic_text> « اِنْ تَسْتَغْفِرْ لَهُمْ سَبْعِينَ مَرَّةً فَلَنْ يَغْفِرَ اللّٰهُ لَهُمْ » </quranic_text>   <footnote> [ التوبة ۸۰ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  قَالَ الرِّضَا عَلِيُّ بْنُ مُوسَي ( عَلَيْهِ السَّلاَمُ ) :","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"الْحَمْدُ لِلَّهِ الَّذِي جَعَلَ فِيَّ وَ فِي اِبْنِي مُحَمَّدٍ اُسْوَةً بِرَسُولِ اللَّهِ وَ اِبْنِهِ اِبْرَاهِيمَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ لَمَّا بَلَغَ عُمُرُهُ سِتَّ سِنِينَ وَ شُهُوراً قَتَلَ الْمَاْمُونُ اَبَاهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ بَقِيَتِ الطَّائِفَةُ فِي حَيْرَةٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِخْتَلَفَتِ الْكَلِمَةُ بَيْنَ النَّاسِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اِسْتَصْغَرَ سِنَّ اَبِي جَعْفَرٍ ( عَلَيْهِ السَّلاَمَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":") ،  وَ تَحَيَّرَ الشِّيعَةُ فِي سَائِرِ الْاَمْصَارِ .","translation_segment":"","segment_columns":[]}]}