{"consensus_set_id":"26381","translation_language":"fa","translation_source":{"hid":"408140"},"segments":[{"source_hadith_segment":"« بَيْنَمَا اَلْعَالِمُ يَمْشِي مَعَ مُوسَي ( عَلَيْهِ السَّلاَمُ ) اِذَا هُمْ بِغُلاَمٍ يَلْعَبُ - قَالَ - فَوَكَزَهُ الْعَالِمُ فَقَتَلَهُ ،  فَقَالَ لَهُ مُوسَي  :   <quranic_text> « اَ قَتَلْتَ نَفْساً زَكِيَّةً بِغَيْرِ نَفْسٍ لَقَدْ جِئْتَ شَيْئاً نُكْراً » </quranic_text>   <footnote> [ الكهف ۷۴ ] </footnote> - قَالَ - فَاَدْخَلَ الْعَالِمُ يَدَهُ فَاقْتَلَعَ كَتِفَهُ ،  فَاِذَا عَلَيْهِ مَكْتُوبٌ :  كَافِرٌ مَطْبُوعٌ »","translation_segment":"","segment_columns":[{"kind":"word","token":"سمعته","display":"سَمِعْتُهُ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"word","token":"بينما","display":"بَيْنَمَا"},{"kind":"word","token":"العالم","display":"اَلْعَالِمُ"},{"kind":"word","token":"يمشي","display":"يَمْشِي"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"هم","display":"هُمْ"},{"kind":"word","token":"بغلام","display":"بِغُلاَمٍ"},{"kind":"word","token":"يلعب","display":"يَلْعَبُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"فوكزه","display":"فَوَكَزَهُ"},{"kind":"word","token":"العالم","display":"الْعَالِمُ"},{"kind":"word","token":"فقتله","display":"فَقَتَلَهُ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"موسي","display":"مُوسَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"قتلت","display":"قَتَلْتَ"},{"kind":"word","token":"نفسا","display":"نَفْساً"},{"kind":"word","token":"زكيه","display":"زَكِيَّةً"},{"kind":"word","token":"بغير",