{"consensus_set_id":"10149","translation_language":"fa","translation_source":{"hid":"348779"},"segments":[{"source_hadith_segment":"سَمِعْنَا اَبَا جَعْفَرٍ عَلَيْهِ السَّلاَمُ وَ سَاَلْنَاهُ عَنْ قَوْلِ اللَّهِ  <quranic_text> « حٰافِظُوا عَلَي الصَّلَوٰاتِ وَ الصَّلاٰةِ الْوُسْطيٰ » </quranic_text>   <footnote> [ البقرة ۲۳۸ ] </footnote>","translation_segment":"در روایتی از امام باقر علیه السلام در پاسخ پرسش از معنای فرمایش خداوند که می‌فرماید: «حٰافظوا علی الصلوٰات‌ و الصلاٰه‌ الوسطیٰ‌». -بر تمام نمازها و بخصوص بر نماز میانه محافظت کنید. فرمود:","segment_columns":[{"kind":"word","token":"انهما","display":"اَنَّهُمَا"},{"kind":"word","token":"سمعنا","display":"سَمِعْنَا"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سالناه","display":"سَاَلْنَاهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"حافظوا","display":"حٰافِظُوا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الصلوات","display":"الصَّلَوٰاتِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الصلاه","display":"الصَّلاٰةِ"},{"kind":"word","token":"الوسطي","display":"الْوُسْطيٰ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۲۳۸","display":"۲۳۸"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"فَقَالَ هِيَ صَلاَةُ الظُّهْرِ وَ فِيهَا فَرَضَ اللَّهُ الْجُمُعَةَ وَ فِيهَا السَّاعَةُ الَّتِي لاَ يَسْاَلُ اللَّهَ فِيهَا عَبْدٌ مُسْلِمٌ خَيْراً اِلاَّ اَعْطَاهُ اِيَّاهُ .","translation_segment":