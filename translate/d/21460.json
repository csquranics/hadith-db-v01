{"consensus_set_id":"21460","translation_language":"fa","translation_source":{"hid":"409258"},"segments":[{"source_hadith_segment":"،  عَنْ اَبِيهِ ( عَلَيْهِمُ السَّلاَمُ","translation_segment":"","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"}]},{"source_hadith_segment":")  ،  قَالَ :  « اُعْطِيَ سُلَيْمَانُ بْنُ دَاوُدَ مُلْكَ مَشَارِقِ الْاَرْضِ وَ مَغَارِبِهَا ،  فَمَلَكَ سَبْعَمِائَةِ سَنَةٍ وَ سِتَّةَ اَشْهُرٍ ،  مُلْكَ اَهْلِ الدُّنْيَا كُلِّهِمْ ،  مِنَ الْجِنِّ ،  وَ الْاِنْسِ ،  وَ الشَّيَاطِينِ ،  وَ الدَّوَابِّ ،  وَ الطَّيْرِ ،  وَ السِّبَاعِ ،  وَ اُعْطِيَ عِلْمَ كُلِّ شَيْءٍ ،  وَ مَنْطِقَ كُلِّ شَيْءٍ ،  وَ فِي زَمَانِهِ صُنِعَتِ الصَّنَائِعُ الْمُعْجِبَةُ الَّتِي سَمِعَ بِهَا النَّاسُ ،  وَ ذَلِكَ قَوْلُهُ :   <quranic_text> « عُلِّمْنٰا مَنْطِقَ الطَّيْرِ وَ اُوتِينٰا مِنْ كُلِّ شَيْءٍ اِنَّ هٰذٰا لَهُوَ الْفَضْلُ الْمُبِينُ » </quranic_text>   <footnote> [ النمل ۱۶ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اعطي","display":"اُعْطِيَ"},{"kind":"word","token":"سليمان","display":"سُلَيْمَانُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"داود","display":"دَاوُدَ"},{"kind":"word","token":"ملك","display":"مُلْكَ"},{"kind":"word","token":"مشارق","display":"مَشَارِقِ"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مغاربها","display":"مَغَارِبِهَا"},{"kind":"word","token":"فملك","display":"فَمَلَكَ"},{"kind":"word","token":"سليمان","display":"سليمان"},{"kind":"word","token":"بن","display":"بن"},{"kind":"word","token":"داود","display":"داود"},{"kind":"word","token":"سبعمائه","display":"سَبْعَمِائَةِ"},{"kind"