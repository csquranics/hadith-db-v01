{"consensus_set_id":"65514","translation_language":"fa","translation_source":{"hid":"338362"},"segments":[{"source_hadith_segment":"مَا لِلَّهِ تَعَالَي مَنْسَكٌ اَحَبُّ اِلَي اللَّهِ تَبَارَكَ وَ تَعَالَي مِنْ مَوْضِعِ الْمَسْعَي وَ ذَلِكَ اَنَّهُ يَذِلُّ فِيهِ  <quranic_text> « كُلُّ جَبّٰارٍ عَنِيدٍ » </quranic_text>   <footnote> [ ابراهيم ۱۵ ] </footnote>   .","translation_segment":"پدرم رضی اللٰه عنه، از سعد بن عبد اللٰه، از محمد بن الحسین بن ابی الخطاب، از ابن ابی عمیر، از معاویه بن عمار، وی می‌گوید: حضرت ابو عبد اللٰه علیه السلام فرمودند: هیچ مکان و بقعه‌ای نزد خدا محبوب‌تر از مکان سعی نیست و جهتش آن است که اینجا هر جبار و ستمگر منحرفی ذلیل و خوار می‌گردد.","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"ابو","display":"أبو"},{"kind":"word","token":"عبد","display":"عبد"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"منسك","display":"مَنْسَكٌ"},{"kind":"word","token":"احب","display":"اَحَبُّ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"موضع","display":"مَوْضِعِ"},{"kind":"word","token":"المسعي","display":"الْمَسْعَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"يذل","display":"يَذِلُّ"},{"kind":"word","token":"فيه","display":"فِيهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kin