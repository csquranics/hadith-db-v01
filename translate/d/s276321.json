{"consensus_set_id":"s276321","translation_language":"fa","translation_source":{"hid":"276321"},"segments":[{"source_hadith_segment":"فِي اَلثَّالِثَةِ قُلْ هُوَ اللَّهُ اَحَدٌ وَ ايَةَ الْكُرْسِيِّ وَ فِي الرَّابِعَةِ قُلْ هُوَ اللَّهُ اَحَدٌ وَ اخِرَ الْبَقَرَةِ وَ فِي الْخَامِسَةِ قُلْ هُوَ اللَّهُ اَحَدٌ وَ الْايَاتِ الَّتِي فِي اخِرِ الِ عِمْرَانَ مِنْ قَوْلِهِ تَعَالَي :   <quranic_text> « اِنَّ فِي خَلْقِ السَّمٰاوٰاتِ وَ الْاَرْضِ » </quranic_text>   <footnote> [ العمران ۱۹۰ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « اِنَّكَ لاٰ تُخْلِفُ الْمِيعٰادَ » </quranic_text>   <footnote> [ العمران ۱۹۴ ] </footnote>  وَ فِي السَّادِسَةِ قُلْ هُوَ اللَّهُ اَحَدٌ وَ ايَةَ السُّخْرَةِ وَ هِيَ ثَلاَثُ ايَاتٍ مِنَ الْاَعْرَافِ -  <quranic_text> « اِنَّ رَبَّكُمُ اللّٰهُ الَّذِي خَلَقَ السَّمٰاوٰاتِ وَ الْاَرْضَ » </quranic_text>   <footnote> [ الاعراف ۵۴ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « قَرِيبٌ مِنَ الْمُحْسِنِينَ » </quranic_text>   <footnote> [ الاعراف ۵۶ ] </footnote>  وَ فِي السَّابِعَةِ قُلْ هُوَ اللَّهُ اَحَدٌ وَ الْايَاتِ الَّتِي فِي الْاَنْعَامِ -  <quranic_text> « وَ جَعَلُوا لِلّٰهِ شُرَكٰاءَ الْجِنَّ » </quranic_text>   <footnote> [ الانعام ۱۰۰ ] </footnote>  اِلَي قَوْلِهِ :   <quranic_text> « وَ هُوَ اللَّطِيفُ الْخَبِيرُ » </quranic_text>   <footnote> [ الانعام ۱۰۳ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الثالثه","display":"اَلثَّالِثَةِ"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ايه","display":"ايَةَ"},{"kind":"word","token":"الكرسي","display":"الْكُرْسِيِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الرابعه","display":"الرَّابِعَةِ"},{"kind":"word","token":"قل",