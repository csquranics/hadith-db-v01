{"consensus_set_id":"s331397","translation_language":"fa","translation_source":{"hid":"331397"},"segments":[{"source_hadith_segment":"مَا اَنْزَلَ اللَّهُ فِي الْقُرْانِ  <quranic_text> « يٰا اَيُّهَا الَّذِينَ امَنُوا » </quranic_text>   <footnote> [ البقرة ۱۰۴ ] </footnote>  اِلاَّ كَانَ عَلِيُّ","translation_segment":"مجاهد از عبد اللٰه بن عباس چنین روایت کرده است: ما انزل اللٰه فی القرآن «یٰا أیها الذین‌ آمنوا» الا کان علی‌ امیرها و شریفها لانه اول المومنین ایمانا. هیچ آیه‌ای در قرآن با خطاب «یٰا أیها الذین‌ آمنوا» نازل نشده مگر این که علی علیه","segment_columns":[{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"انزل","display":"اَنْزَلَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"القران","display":"الْقُرْانِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"ايها","display":"اَيُّهَا"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۰۴","display":"۱۰۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"علي","display":"عَلِيُّ"}]},{"source_hadith_segment":"بْنُ اَبِي طَالِبٍ اَمِيرَهَا وَ شَرِيفَهَا","translation_segment":"السلام امیر و شریف آن مومنین است چون او اولین اسلام آورنده و نخستین","segment_columns":[{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"طالب","display":"طَالِبٍ"},{"kind":"word","token":"اميرها","display":"اَمِيرَهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شريفها","display":"شَرِيفَهَا"}]},{"source_hadith_segment":"،  لِاَنَّهُ اَوَّلُ الْمُؤْمِنِينَ اِ