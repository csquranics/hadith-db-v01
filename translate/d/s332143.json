{"consensus_set_id":"s332143","translation_language":"fa","translation_source":{"hid":"332143"},"segments":[{"source_hadith_segment":"اَمَّا  <quranic_text> « الَّذِينَ اِجْتَرَحُوا السَّيِّئٰاتِ » </quranic_text>   <footnote> [ الجاثية ۲۱ ] </footnote>  بَنُو عَبْدِ شَمْسٍ وَ [ اَمَّا ]  <quranic_text> « كَالَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ » </quranic_text>   <footnote> [ الجاثية ۲۱ ] </footnote>","translation_segment":"عن ابن عباس قال: (أما الذین اجترحوا السیئات) بنو عبد شمس و أما (الذین آمنوا و عملوا الصالحات) بنو هاشم و بنو عبد المطلب. ابن عباس گفت: کسانی","segment_columns":[{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"اجترحوا","display":"اِجْتَرَحُوا"},{"kind":"word","token":"السيئات","display":"السَّيِّئٰاتِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الجاثيه","display":"الجاثية"},{"kind":"word","token":"۲۱","display":"۲۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"بنو","display":"بَنُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"شمس","display":"شَمْسٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"كالذين","display":"كَالَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عملوا","display":"عَمِلُوا"},{"kind":"word","token":"الصالحات","display":"الصّٰالِحٰاتِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الجاثيه","display":"الجاثية"},{"kind":"word","token":"۲۱","display":"۲۱"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"بَنُو هَاشِمٍ وَ بَنُو عَبْدِ الْمُطَّلِبِ .","translation_segment":"که مرتکب گناه شدند فرزندان عبد شمس و کسانی که ایمان آوردند و کارهای شایسته انجام دادند، بنی هاشم بودند.","segment_columns":[{"kind":"word","token":"بنو","display":"بَنُو"},{"kind":"word","token":"هاشم","display":"هَاشِمٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بنو","display":"بَنُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"المطلب","display":"الْمُطَّلِبِ"}]}]}