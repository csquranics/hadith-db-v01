{"consensus_set_id":"s332288","translation_language":"fa","translation_source":{"hid":"332288"},"segments":[{"source_hadith_segment":"لَمَّا نَزَلَتْ  <quranic_text> « وَ تَعِيَهٰا اُذُنٌ وٰاعِيَةٌ » </quranic_text>   <footnote> [ الحاقة ۱۲ ] </footnote>  قَالَ :  النَّبِيُّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  :  سَاَلْتُ","translation_segment":"عن ابن عباس عن النبی صلی الله علیه و آله و سلم قال: لما نزلت (و تعیها أذن واعیه) قال النبی صلی الله علیه و آله: سألت ربی أن: یجعلها أذن علی‌. و قال علی: ما سمعت من رسول الله شیئا إلا حفظته و وعیته و لم أنسه. ابن","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعيها","display":"تَعِيَهٰا"},{"kind":"word","token":"اذن","display":"اُذُنٌ"},{"kind":"word","token":"واعيه","display":"وٰاعِيَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحاقه","display":"الحاقة"},{"kind":"word","token":"۱۲","display":"۱۲"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"النبي","display":"النَّبِيُّ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"}]},{"source_hadith_segment":"رَبِّي اَنْ :  يَجْعَلَهَا اُذُنَ عَلِيٍّ","translation_segment":"عباس گفت: وقتی این آیه نازل شد: «و تعیها اذن واعیه»","segment_columns":[{"kind":"word","token":"ربي","display":"رَبِّي"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يجعلها","display":"يَجْعَلَهَا"},{"kind":"word","token":"اذن","display":"اُذُنَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"}]},{"source_hadith_segment":".  [