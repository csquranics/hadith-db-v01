شرکان ما را از آن باز داشتند و راه آن را بما بستند و جلو ما را گرفتند از ورود بمکه و اکنون برمیگردیم و تعهدات پستی دادیم بمشرکان بخدا اگر من یارانی داشتم بآنها تعهدات پست هرگز نمیدادم با اینکه روز جنگ احد و حنین و جز آنها یارانی داشت و گریخت از میدان نبرد. و گفته او بگوش پیغمبر (صلی الله علیه و آله) رسید و در خشم شد و فرمود: شماها روز جنگ احد کجا بودید آنگاه که ببالا میرفتید و گریزان بودید و رو بدیگری بر نمیگرداندید و من شما را فرا میخواندم. آیا روز جنگ احزاب را از یاد بردید که دشمن بر سر شما آمد از فراز شما و از فرود شما آنگاه که دیده‌ها کج شدند و جانها بگلوگاه رسیدند از ترس و گمان بد بخدا بردید؟، آیا فلان روز را فراموش کردید؟ و چون عمر خشم پیغمبر (صلی الله علیه و آله) را دید گفت: پناه بخدا از خشم خدا و خشم رسول خدا بخدا سوگند یا رسول اللٰه که شیطان بر گردن من سوار شد. چگونه شیطان سوار گردن کسی می‌شود که میان دو چشم او","segment_columns":[{"kind":"word","token":"فقام","display":"فَقَامَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بين","display":"بَيْنِ"},{"kind":"word","token":"يديه","display":"يَدَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"مسخط","display":"مُسْخِطٌ"},{"kind":"word","token":"رايه","display":"رَاْيُهُ"},{"kind":"word","token":"غير","display":"غَيْرُ"},{"kind":"word","token":"راض","display":"رَاضٍ"},{"kind":"word","token":"حكمه","display":"حُكْمُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اقبل","display":"اَقْبَلَ"},{"kind":"word","token":"يمشي","display":"يَمْشِي"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"الناس","display":"النَّاسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يؤلب","display":"يُؤَلِّبُ"},{"kind":"word","token":"مع","display":"مع"},{"kind":"word","token":"المعرفين","display":"المعرفين"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"هدينا","display":"هدينا"},{"kind":"word","token":"لم","display":"لم"},{"kind":"word","token":"يصل"