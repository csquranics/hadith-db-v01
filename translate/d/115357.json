{"consensus_set_id":"115357","translation_language":"fa","translation_source":{"hid":"390925"},"segments":[{"source_hadith_segment":"اِذَا بَلَغَتِ النَّفْسُ هَاهُنَا- وَ اَشَارَ بِيَدِهِ اِلَي حَلْقِهِ- لَمْ يَكُنْ لِلْعَالِمِ تَوْبَةٌ .  ثُمَّ قَرَاَ  <quranic_text> « اِنَّمَا التَّوْبَةُ عَلَي اللّٰهِ لِلَّذِينَ يَعْمَلُونَ السُّوءَ بِجَهٰالَةٍ » </quranic_text>   <footnote> [ النساء ۱۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"بلغت","display":"بَلَغَتِ"},{"kind":"word","token":"النفس","display":"النَّفْسُ"},{"kind":"word","token":"هاهنا-","display":"هَاهُنَا-"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اشار","display":"اَشَارَ"},{"kind":"word","token":"بيده","display":"بِيَدِهِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"حلقه-","display":"حَلْقِهِ-"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يكن","display":"يَكُنْ"},{"kind":"word","token":"للعالم","display":"لِلْعَالِمِ"},{"kind":"word","token":"توبه","display":"تَوْبَةٌ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمَا"},{"kind":"word","token":"التوبه","display":"التَّوْبَةُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"للذين","display":"لِلَّذِينَ"},{"kind":"word","token":"يعملون","display":"يَعْمَلُونَ"},{"kind":"word","token":"السوء","display":"السُّوءَ"},{"kind":"word","token":"بجهاله","display":"بِجَهٰالَةٍ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۷","display":"۱۷"},{"kind":"tag_close","tag_name":"footnote"}]}]}