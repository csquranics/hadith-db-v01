{"consensus_set_id":"4285","translation_language":"fa","translation_source":{"hid":"411810"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنْ  <quranic_text> « ن وَ الْقَلَمِ » </quranic_text>   <footnote> [ القلم ۱ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"انّه"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ن","display":"ن"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"القلم","display":"الْقَلَمِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يسطرون","display":"يَسْطُرُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"القلم","display":"القلم"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":".  قَالَ ( عَلَيْهِ السَّلاَمُ ) :  « اِنَّ اللَّهَ تَعَالَي خَلَقَ الْقَلَمَ مِنْ شَجَرَةٍ مِنَ الْجَنَّةِ ،  يُقَالُ لَهَا الْخُلْدُ ،  ثُمَّ قَالَ لِنَهَرٍ فِي الْجَنَّةِ :  كُنْ مِدَاداً ،  فَجَمَدَ النَّهَرُ ،  وَ كَانَ اَشَدَّ بَيَاضاً مِنَ الثَّلْجِ وَ اَحْلَي مِنَ الشَّهْدِ ،  ثُمَّ قَالَ لِلْقَلَمِ :  اُكْتُبْ ،  قَالَ :  يَا رَبِّ وَ مَا اَكْتُبُ ؟  قَالَ :  اُكْتُبْ مَا كَانَ وَ مَا هُوَ كَائِنٌ اِلَي يَوْمِ الْقِيَامَةِ ؛  فَكَتَبَ الْقَلَمُ فِي رَقٍّ اَشَدَّ بَيَاضاً مِنَ الْفِضَّةِ ،  وَ اَصْفَي مِنَ الْيَاقُوتِ ،  ثُمَّ طَوَاهُ فَجَعَلَهُ فِي رُكْنِ الْعَرْشِ ،  ثُمَّ خَتَمَ عَلَي فَمِ الْقَلَمِ فَلَمْ يَنْطِقْ بَعْدَ ذَلِكَ وَ لاَ يَنْطِقُ اَبَداً ،  فَهُوَ الْكِتَابُ الْمَكْنُونُ الَّذِي مِنْهُ النُّسَخُ كُلُّهَا ،  اَ وَ لَسْتُمْ عَرَباً ؟  فَكَيْفَ لاَ تَعْرِفُونَ مَعْنَي الْكَلاَمِ وَ اَحَدُكُمْ يَقُولُ لِصَاحِبِهِ :  اِنْسَخْ ذَلِكَ الْكِتَابَ ،  اَ وَ لَيْسَ اِنَّمَا يُنْسَخُ مِنْ كِتَابٍ اُخِذَ مِنَ الْاَصْلِ ؟  وَ هُوَ قَوْلُهُ :   <quranic_text> « اِنّٰا كُنّٰا نَسْتَنْسِخُ مٰا كُنْتُمْ تَعْمَلُونَ » </quranic_text>   <footnote> [ الجاثية ۲۹ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"القلم","display":"الْقَلَمَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"شجره","display":"شَجَرَةٍ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"يقال","display":"يُقَالُ"},{"kind":"word","token":"لها","display":"لَهَا"},{"kind":"word","token":"الخلد","display":"الْخُلْدُ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لنهر","display":"لِنَهَرٍ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"كن","display":"كُنْ"},{"kind":"word","token":"مدادا","display":"مِدَاداً"},{"kind":"word","token":"و","display":"و"},{"kind":"word","token":"فجمد","display":"فَجَمَدَ"},{"kind":"word","token":"النهر","display":"النَّهَرُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"اشد","display":"اَشَدَّ"},{"kind":"word","token":"بياضا","display":"بَيَاضاً"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الثلج","display":"الثَّلْجِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"احلي","display":"اَحْلَي"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الشهد","display":"الشَّهْدِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kin