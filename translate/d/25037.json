{"consensus_set_id":"25037","translation_language":"fa","translation_source":{"hid":"107054"},"segments":[{"source_hadith_segment":"كَانَ بَيْنَ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « قَدْ اُجِيبَتْ دَعْوَتُكُمٰا » </quranic_text>   <footnote> [ يونس۸۹ ] </footnote>  وَ بَيْنَ اَخْذِ فِرْعَوْنَ اَرْبَعِينَ عَاماً","translation_segment":"و نیز آن حضرت ع فرمود: میان گفته خدای عز و جل (که بموسی و هارون - در مقابل تقاضای نابودی فرعون و پیروانش - فرمود:) «هر آینه دعای شما باجابت رسید» (سوره یونس ۸۹) و میان نابودی فرعون چهل سال طول کشید.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"اجيبت","display":"اُجِيبَتْ"},{"kind":"word","token":"دعوتكما","display":"دَعْوَتُكُمٰا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يونس۸۹","display":"يونس۸۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بين","display":"بَيْنَ"},{"kind":"word","token":"اخذ","display":"اَخْذِ"},{"kind":"word","token":"فرعون","display":"فِرْعَوْنَ"},{"kind":"word","token":"اربعين","display":"اَرْبَعِينَ"},{"kind":"word","token":"عاما","display":"عَاماً"}]}]}