{"consensus_set_id":"117588","translation_language":"fa","translation_source":{"hid":"368154"},"segments":[{"source_hadith_segment":"اِنَّ اَللَّهَ تَبَارَكَ وَ تَعَالَي غَيُورٌ يُحِبُّ كُلَّ غَيُورٍ وَ لِغَيْرَتِهِ حَرَّمَ  <quranic_text> « الْفَوٰاحِشَ مٰا ظَهَرَ مِنْهٰا وَ مٰا بَطَنَ » </quranic_text>   <footnote> [ الاعراف ۳۳ ] </footnote>   .","translation_segment":"امام صادق علیه السلام فرمود: خداوند تبارک و تعالی غیرتمند است و هر غیرتمندی را دوست می‌دارد، و برای همین غیرت است که فواحش را حرام کرده، چه ظاهر باشد و چه پنهان.","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اَللَّهَ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"غيور","display":"غَيُورٌ"},{"kind":"word","token":"يحب","display":"يُحِبُّ"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"غيور","display":"غَيُورٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لغيرته","display":"لِغَيْرَتِهِ"},{"kind":"word","token":"حرم","display":"حَرَّمَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الفواحش","display":"الْفَوٰاحِشَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"ظهر","display":"ظَهَرَ"},{"kind":"word","token":"منها","display":"مِنْهٰا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"بطن","display":"بَطَنَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاعراف","display":"الاعراف"},{"kind":"word","token":"۳۳","display":"۳۳"},{"kind":"tag_close","tag_name":"footnote"}]}]}