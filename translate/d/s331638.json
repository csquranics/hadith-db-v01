{"consensus_set_id":"s331638","translation_language":"fa","translation_source":{"hid":"331638"},"segments":[{"source_hadith_segment":"لَمَّا نَزَلَتْ :   <quranic_text> « اَ جَعَلْتُمْ سِقٰايَةَ الْحٰاجِّ » </quranic_text>   <footnote> [ التوبة ۱۹ ] </footnote>  فِي عَبَّاسٍ وَ عَلِيٍّ وَ شَيْبَةَ بْنِ عُثْمَانَ تَكَلَّمُوا فِي ذَلِكَ الْحَدِيثَ .","translation_segment":"عن الحسن قال: لما نزلت: (أجعلتم سقایه الحاج) فی عباس و علی‌ و شیبه بن عثمان تکلموا فی ذلک. حسن گفت: آیه چون آیه: «اجعلتم سقایه الحاج» درباره عباس و علی و شیبه بن عثمان نازل شد، در این باره گفتگو کردند.","segment_columns":[{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"جعلتم","display":"جَعَلْتُمْ"},{"kind":"word","token":"سقايه","display":"سِقٰايَةَ"},{"kind":"word","token":"الحاج","display":"الْحٰاجِّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۱۹","display":"۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"عباس","display":"عَبَّاسٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شيبه","display":"شَيْبَةَ"},{"kind":"word","token":"بن","display":"بْنِ"},{"kind":"word","token":"عثمان","display":"عُثْمَانَ"},{"kind":"word","token":"تكلموا","display":"تَكَلَّمُوا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"الحديث","display":"الْحَدِيثَ"}]}]}