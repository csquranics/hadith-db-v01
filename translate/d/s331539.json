{"consensus_set_id":"s331539","translation_language":"fa","translation_source":{"hid":"331539"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا جَعْفَرٍ عَنْ قَوْلِهِ :   <quranic_text> « اِنَّمٰا وَلِيُّكُمُ اللّٰهُ وَ رَسُولُهُ وَ الَّذِينَ امَنُوا » </quranic_text>   <footnote> [ المائدة ۵۵ ] </footnote>","translation_segment":"عن عبد الملک بن أبی سلیمان قال: سألت أبا جعفر عن قوله: (إنما ولیکم الله و رسوله و الذین آمنوا). قال: أصحاب النبی صلی الله علیه و آله و سلم. قلت: یقولون: علی‌ قال: علی‌ منهم.","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"جعفر","display":"جَعْفَرٍ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"وليكم","display":"وَلِيُّكُمُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"رسوله","display":"رَسُولُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۵۵","display":"۵۵"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":".  قَالَ :  اَصْحَابُ النَّبِيِّ [ صَلَّي","translation_segment":"عبد الملک بن سلیمان گفت: از ابو جعفر این آیه را پرسیدم «انما ولیکم","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابُ"},{"kind":"word","token":"النبي","display":"النَّبِيِّ"},{"kind":"word","token":"صلي","display":"صَلَّي"}]},{"source_hadith_segment":"اللَّهُ عَلَيْهِ وَ الِهِ ] قُلْتُ :  يَقُولُونَ :  عَلِيٌّ قَالَ :  عَلِيٌّ مِنْهُمْ .","translation_segment":"الله و رسوله و الذین آمنوا» گفت: اصحاب پیامبر. گفتم: می‌گویند: علی. گفت: علی هم از آنان بود.","segment_columns":[{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"يقولون","display":"يَقُولُونَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"منهم","display":"مِنْهُمْ"}]}]}