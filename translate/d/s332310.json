{"consensus_set_id":"s332310","translation_language":"fa","translation_source":{"hid":"332310"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي :   <quranic_text> « وَ يُطْعِمُونَ الطَّعٰامَ عَليٰ حُبِّهِ مِسْكِيناً وَ يَتِيماً وَ اَسِيراً اِنَّمٰا نُطْعِمُكُمْ لِوَجْهِ اللّٰهِ لاٰ نُرِيدُ مِنْكُمْ جَزٰاءً وَ لاٰ شُكُوراً ،  اِنّٰا نَخٰافُ مِنْ رَبِّنٰا يَوْماً عَبُوساً قَمْطَرِيراً » </quranic_text>   <footnote> [ الانسان ۸ ] </footnote>","translation_segment":"عن ابن عباس فی قوله تعالی: (و یطعمون الطعام علی حبه) مسکینا و یتیما و أسیرا إنما نطعمکم لوجه الله لا نرید منکم جزاء و لا شکورا، إنا نخاف من ربنا یوما عبوسا قمطریرا) الآیات قال: نزلت فی علی ابن أبی طالب أطعم عشاءه و أفطر علی القراح. ابن عباس","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يطعمون","display":"يُطْعِمُونَ"},{"kind":"word","token":"الطعام","display":"الطَّعٰامَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"حبه","display":"حُبِّهِ"},{"kind":"word","token":"مسكينا","display":"مِسْكِيناً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يتيما","display":"يَتِيماً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اسيرا","display":"اَسِيراً"},{"kind":"word","token":"انما","display":"اِنَّمٰا"},{"kind":"word","token":"نطعمكم","display":"نُطْعِمُكُمْ"},{"kind":"word","token":"لوجه","display":"لِوَجْهِ"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"نريد","display":"نُرِيدُ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"جزاء","display":"جَزٰاءً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"شكورا","display":"شُكُوراً"},{"kind":"