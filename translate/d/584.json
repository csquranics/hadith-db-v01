م. پس با ورع و پرهیز از گناه و کوشش در کار خیر، ما (آل محمد صلی اللٰه علیه و آله و سلم)","segment_columns":[{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"بورع","display":"بِوَرَعٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اجتهاد","display":"اِجْتِهَادٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اعلموا","display":"اِعْلَمُوا"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"ولايتنا","display":"وَلاَيَتَنَا"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تنال","display":"تُنَالُ"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"بالورع","display":"بِالْوَرَعِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الاجتهاد","display":"الاِجْتِهَادِ"},{"kind":"word","token":"و","display":"وَ"}]},{"source_hadith_segment":"مَنِ اِئْتَمَّ مِنْكُمْ بِقَوْمٍ فَلْيَعْمَلْ","translation_segment":"را در این دوستی یاری کنید و بدانید که ولایت ما","segment_columns":[{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"ائتم","display":"اِئْتَمَّ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"word","token":"بقوم","display":"بِقَوْمٍ"},{"kind":"word","token":"فليعمل","display":"فَلْيَعْمَلْ"}]},{"source_hadith_segment":"بِعَمَلِهِمْ اَنْتُمْ شِيعَةُ اللَّهِ وَ اَنْتُمْ اَنْصَارُ اللَّهِ وَ اَنْتُمُ  <quranic_text> « السّٰابِقُونَ الْاَوَّلُونَ » </quranic_text>   <footnote> [ التوبة ۱۰۰ ] </footnote>  وَ السَّابِقُونَ الْاخِرُونَ وَ السَّابِقُونَ فِي الدُّنْيَا اِلَي مَحَبَّتِنَا وَ السَّابِقُونَ فِي الْاخِرَةِ اِلَي الْجَنَّةِ ضَمِنْتُ لَكُمُ الْجَنَّةَ بِضَمَانِ اللَّهِ عَزَّ وَ جَلَّ وَ ضَمَانِ النَّبِيِّ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ اَنْتُمُ الطَّيِّبُونَ وَ نِسَاؤُكُمُ الطَّيِّبَاتُ- كُلُّ مُؤْمِنَةٍ حَوْرَاءُ وَ كُلُّ مُؤْمِنٍ صِدِّيقٌ كَمْ مِنْ مَرَّةٍ قَالَ اَمِيرُ الْمُؤْمِنِينَ عَلَيْهِ السَّلاَمُ لِقَنْبَرٍ اَبْشِرُوا وَ بَشِّرُوا فَوَ اللَّهِ لَقَدْ مَاتَ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ هُوَ سَاخِطٌ عَلَي اُمَّتِهِ اِلاَّ الشِّيعَةَ اَلاَ وَ اِنَّ لِكُلِّ شَيْءٍ شَرَفاً وَ شَرَفُ الدِّينِ الشِّيعَةُ اَلاَ وَ اِنَّ لِكُلِّ شَيْءٍ سَيِّداً وَ سَيِّدُ الْمَجَالِسِ مَجَالِسُ الشِّيعَةِ اَلاَ وَ اِنَّ لِكُلِّ شَيْءٍ اِمَاماً وَ اِمَامُ الْاَرْضِ اَرْضٌ تَسْكُنُهَا الشِّيعَةُ اَلاَ وَ اِنَّ لِكُلِّ شَيْءٍ شَهْوَةً وَ اِنَّ شَهْوَةَ الدُّنْيَا سُكْنَي شِيعَتِنَا فِيهَا وَ اللَّهِ لَوْ لاَ مَا فِي الْاَرْضِ مِنْكُمْ مَا اِسْتَكْمَلَ اَهْلُ خِلاَفِكُمْ طَيِّبَاتٍ وَ مَا لَهُمْ فِي الْاخِرَةِ مِنْ نَصِيبٍ كُلُّ نَاصِبٍ وَ اِنْ تَعَبَّدَ وَ اِجْتَهَدَ مَنْسُوبٌ اِلَي هَذِهِ الْايَةِ-  <quranic_text> « عٰامِلَةٌ نٰاصِبَةٌ تَصْليٰ نٰاراً حٰامِيَةً » </quranic_text>   <footnote> [ الغاشية ۳ ] </footnote>  مَنْ دَعَا لَكُمْ مُخَالِفاً فَاِجَابَةُ دُعَائِهِ لَكُمْ وَ مَنْ طَلَبَ مِنْكُمْ اِلَي اللَّهِ تَبَارَكَ وَ تَعَالَي اِسْمُهُ حَاجَةً فَلَهُ مِائَةٌ وَ مَنْ دَعَا دَعْوَةً فَلَهُ مِائَةٌ وَ مَنْ عَمِلَ حَسَنَةً فَلاَ يُحْصَي تَضَاعُفاً وَ مَنْ اَسَاءَ","translation_segment":"جز با ورع و کوشش در کار خیر به دست نمی‌آید. هر کدام از شما که از جماعتی پیروی می‌کند، باید مانند آنها رفتار کند. شما شیعه (پیرو) خدا و یاوران او هستید. شما سبقت‌گیرندگان اول و آخر هستید. در دنیا به سوی محبت ما پیشی گرفته‌اید و در آخرت به سوی بهشت سبقت می‌گیرید. من به ضمانت خداوند و عز و جل‌ و تضمین رسول خدا صلی اللٰه علیه و آله و سلم، بهشت را برای شما ضمانت می‌کنم. شما پاک و مطهر هستید و زنانتان پاک و پاکیزه‌اند. هر زن مومنه‌ای، حوریی است و هر مرد مومنی، تصدیق‌کننده [و یا راستگو] است. بارها امیر المومنین علیه السلام به قنبر فرمود: بشارت باد بر شما و [به سایر دوستانتان] بشارت دهید: به خدا سوگند رسول خدا صلی اللٰه علیه و آله و سلم از دنیا رفت در حالی که بر تمام امتش خشمناک بود به جز جماعت شیعه. آگاه باشید برای هر چیز دستاویزی است و دستاویز دین، شیعه است. بدانید، برای هر چیز شرافتی است و شرافت دین، شیعه است. بدانید، برای هر چیز سید و سروری است و سید مجالس، مجالس شیعه است. آگاه باشید، برای هر چیز امام و پیشوایی است و امام زمین، آن قسمت از زمین است که شیعه در آن سکونت دارد. آگاه باشید، برای هر چیزی میل و رغبت شدیدی است و میل و رغبت دنیا به مسکنی است که شیعه در آن جای دارد. به خدا سوگند، اگر شما در زمین نبودید، مخالفین شما نمی‌توانستند از نعمتها بهره‌مند شوند. [البته آنان] در آخرت نصیب و بهره‌ای ندارند. هر ناصبی (دشمن اهل بیت) اگر عبادت و بندگی [خدا را] نماید و در کارهای خوب تلاش و کوشش کند، باز مشمول این آیه از قرآن است که می‌فرماید: «عمل‌کننده رنج کشنده، از آتش سوزان می‌چشد.» هر کدام از مخالفین شما که [برای خودش] دعا کند، خداوند دعای او را در مورد شما اجابت می‌فرماید و هر کس از شما از خداوند تعالی حاجتی درخواست نماید [خدای بزرگ] صد برابر حاجتش را برآورد. هر کس [از شما] یک دعا کند [خداوند] صد دعای او را اجابت می‌فرماید. هر کس [از شما] عمل نیکی انجام دهد، [پاداش عملش] قابل شمارش","segment_columns":[{"kind":"word","token":"بعملهم","display":"بِعَمَلِهِمْ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"انتم","display":"اَنْتُمْ"},{"kind":"word","token":"شيعه","display":"شِيعَةُ"},{"kind":"word","token":"ال","display":"الِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انتم","display":"اَنْتُمْ"},{"kind":"word","token":"شرط","display":"شُرَطُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انتم","display":"اَنْتُمْ"},{"kind":"word","token":"انصار","display":"اَنْصَارُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انتم","display":"اَنْتُمُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"السابقون","display":"السّٰابِقُون