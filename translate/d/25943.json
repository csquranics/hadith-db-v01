{"consensus_set_id":"25943","translation_language":"fa","translation_source":{"hid":"369621"},"segments":[{"source_hadith_segment":"مَا اِشْتَكَي اَحَدٌ مِنَ الْمُؤْمِنِينَ شَيْئاً قَطُّ فَقَالَ بِاِخْلاَصٍ  <quranic_text> « وَ نُنَزِّلُ مِنَ الْقُرْانِ مٰا هُوَ شِفٰاءٌ وَ رَحْمَةٌ لِلْمُؤْمِنِينَ » </quranic_text>   <footnote> [ الاسراء ۸۲ ] </footnote>  وَ مَسَحَ عَلَي الْعِلَّةِ اِلاَّ شَفَاهُ اللَّهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"وقال","display":"وقال"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"حنكوا","display":"حنكوا"},{"kind":"word","token":"اولادكم","display":"أولادكم"},{"kind":"word","token":"بتربه","display":"بتربة"},{"kind":"word","token":"الحسين","display":"الحسين"},{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"فانها","display":"فإنها"},{"kind":"word","token":"امان","display":"أمان"},{"kind":"word","token":"من","display":"من"},{"kind":"word","token":"كل","display":"كل"},{"kind":"word","token":"داء","display":"داء"},{"kind":"word","token":"وبلاء","display":"وبلاء"},{"kind":"word","token":"وافه","display":"وآفة"},{"kind":"word","token":"وعاهه","display":"وعاهة"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"الدنيا","display":"الدنيا"},{"kind":"word","token":"والاخره","display":"والآخرة"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"اشتكي","display":"اِشْتَكَي"},{"kind":"word","token":"احد","display":"اَحَدٌ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"المؤمنين","display":"الْمُؤْمِنِينَ"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"قط","display":"قَطُّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"باخلاص","display":"بِاِخْلاَصٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ننزل","display":"نُنَزِّلُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الق