{"consensus_set_id":"51209","translation_language":"fa","translation_source":{"hid":"408340"},"segments":[{"source_hadith_segment":"قُلْتُ لِاَبِي عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ ) :  قَوْلُهُ :   <quranic_text> « وَ قٰالُوا اِتَّخَذَ الرَّحْمٰنُ وَلَداً » </quranic_text>   <footnote> [ مريم ۸۸ ] </footnote>","translation_segment":"","segment_columns":[{"kind":"word","token":"قلت","display":"قُلْتُ"},{"kind":"word","token":"لابي","display":"لِاَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"قوله","display":"قَوْلُهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قالوا","display":"قٰالُوا"},{"kind":"word","token":"اتخذ","display":"اِتَّخَذَ"},{"kind":"word","token":"الرحمن","display":"الرَّحْمٰنُ"},{"kind":"word","token":"ولدا","display":"وَلَداً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"مريم","display":"مريم"},{"kind":"word","token":"۸۸","display":"۸۸"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":".  قَالَ :  « هَذَا حَيْثُ قَالَتْ قُرَيْشٌ :  اِنَّ لِلَّهِ وَلَداً ،  وَ اِنَّ الْمَلاَئِكَةَ اِنَاثٌ ،  فَقَالَ اللَّهُ تَبَارَكَ وَ تَعَالَي رَدّاً عَلَيْهِمْ :   <quranic_text> « لَقَدْ جِئْتُمْ شَيْئاً اِدًّا » </quranic_text>   <footnote> [ مريم ۸۹ ] </footnote>  اَيْ ظُلْماً .   <quranic_text> « تَكٰادُ السَّمٰاوٰاتُ يَتَفَطَّرْنَ مِنْهُ » </quranic_text>   <footnote> [ مريم ۹۰ ] </footnote>   ،  يَعْنِي مِمَّا قَالُوا وَ مِمَّا رَمَوْهُ .   <quranic_text> « وَ تَنْشَقُّ الْاَرْضُ وَ تَخِرُّ الْجِبٰالُ هَدًّا » </quranic_text>   <footnote> [ مريم ۹۰ ] </footnote>  مِمَّا قَالُوا  <quranic_text> « اَنْ دَعَوْا لِلرَّحْمٰنِ وَلَداً » </quranic_text>   <footnote> [ مريم ۹۱ ] </footnote> فَقَالَ اللَّهُ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « وَ مٰا يَنْبَغِي لِلرَّحْمٰنِ اَنْ يَتَّخِذَ وَلَداً اِنْ كُلُّ مَنْ فِي السَّمٰاوٰاتِ وَ الْاَرْضِ اِلاّٰ اتِي الرَّحْمٰنِ عَبْداً لَقَدْ اَحْصٰاهُمْ وَ عَدَّهُمْ عَدًّا وَ كُلُّهُمْ اتِيهِ يَوْمَ الْقِيٰامَةِ فَرْداً » </quranic_text>   <footnote> [ مريم ۹۲ ] </footnote>  وَاحِداً وَاحِداً » .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"حيث","display":"حَيْثُ"},{"kind":"word","token":"قالت","display":"قَالَتْ"},{"kind":"word","token":"قريش","display":"قُرَيْشٌ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"ولدا","display":"وَلَداً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الملائكه","display":"الْمَلاَئِكَةَ"},{"kind":"word","token":"اناث","display":"اِنَاثٌ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"ردا","display":"رَدّاً"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"جئتم","display":"جِئْتُمْ"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"ادا","display":"اِدًّا"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"مريم","display":"مريم"},{"kind":"word","token":"۸۹","display":"۸۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"اي","display":"اَيْ"},{"kind":"word","token":"ظلما","display":"ظُلْماً"},{"kind":"tag_open","tag_name":"quranic_text"},{"