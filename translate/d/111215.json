{"consensus_set_id":"111215","translation_language":"fa","translation_source":{"hid":"312932"},"segments":[{"source_hadith_segment":"مَنْ رَوَي عَلَي اَخِيهِ الْمُؤْمِنِ رِوَايَةً يُرِيدُ بِهَا شَيْنَهُ وَ هَدْمَ مُرُوءَتِهِ وَقَفَهُ اللَّهُ تَعَالَي فِي طِينَةِ خَبَالٍ -  <quranic_text> « فِي الدَّرْكِ الْاَسْفَلِ مِنَ النّٰارِ » </quranic_text>   <footnote> [ النساء ۱۴۵ ] </footnote>   .","translation_segment":"و فرمود امیر المومنین علیه السلام که فرمود پیغمبر صلی اللٰه علیه و آله هر که روایت کند از برادر مومن روایتی که اراده کند بآن عیب او را و هدم و نقصان و مروت او را بدارد او را خدای تعالی در چرک و ریم در درک الاسفل از دوزخ","segment_columns":[{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"روي","display":"رَوَي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اخيه","display":"اَخِيهِ"},{"kind":"word","token":"المؤمن","display":"الْمُؤْمِنِ"},{"kind":"word","token":"روايه","display":"رِوَايَةً"},{"kind":"word","token":"يريد","display":"يُرِيدُ"},{"kind":"word","token":"بها","display":"بِهَا"},{"kind":"word","token":"شينه","display":"شَيْنَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هدم","display":"هَدْمَ"},{"kind":"word","token":"مروءته","display":"مُرُوءَتِهِ"},{"kind":"word","token":"وقفه","display":"وَقَفَهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"طينه","display":"طِينَةِ"},{"kind":"word","token":"خبال","display":"خَبَالٍ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الدرك","display":"الدَّرْكِ"},{"kind":"word","token":"الاسفل","display":"الْاَسْفَلِ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"النار","display":"النّٰارِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"ki