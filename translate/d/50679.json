{"consensus_set_id":"50679","translation_language":"fa","translation_source":{"hid":"406765"},"segments":[{"source_hadith_segment":"« يَا اِبْنَ مَسْعُودٍ :  اَنْصِفِ النَّاسَ مِنْ نَفْسِكَ ،  وَ اِنْصَحِ الْاُمَّةَ وَ اِرْحَمْهُمْ ،  فَاِذَا كُنْتَ كَذَلِكَ وَ غَضِبَ اللَّهُ عَلَي اَهْلِ بَلْدَةٍ اَنْتَ فِيهَا ،  وَ اَرَادَ اَنْ يُنْزِلَ عَلَيْهِمَ الْعَذَابَ ،  نَظَرَ اِلَيْكَ فَرَحِمَهُمْ بِكَ ،  يَقُولُ اللَّهُ تَعَالَي :   <quranic_text> « وَ مٰا كٰانَ رَبُّكَ لِيُهْلِكَ الْقُريٰ بِظُلْمٍ وَ اَهْلُهٰا مُصْلِحُونَ » </quranic_text>   <footnote> [ هود ۱۱۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"مسعود","display":"مَسْعُودٍ"},{"kind":"word","token":"انصف","display":"اَنْصِفِ"},{"kind":"word","token":"الناس","display":"النَّاسَ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"نفسك","display":"نَفْسِكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انصح","display":"اِنْصَحِ"},{"kind":"word","token":"الامه","display":"الْاُمَّةَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ارحمهم","display":"اِرْحَمْهُمْ"},{"kind":"word","token":"فاذا","display":"فَاِذَا"},{"kind":"word","token":"كنت","display":"كُنْتَ"},{"kind":"word","token":"كذلك","display":"كَذَلِكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"غضب","display":"غَضِبَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"بلده","display":"بَلْدَةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"فيها","display":"فِيهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اراد","display":"اَرَادَ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ينزل","display":"يُن