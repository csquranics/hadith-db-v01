.»","segment_columns":[{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"القدريه","display":"الْقَدَرِيَّةَ"},{"kind":"word","token":"مجوس","display":"مَجُوسُ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الامه","display":"الْاُمَّةِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هم","display":"هُمُ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"ارادوا","display":"اَرَادُوا"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يصفوا","display":"يَصِفُوا"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"بعدله","display":"بِعَدْلِهِ"},{"kind":"word","token":"فاخرجوه","display":"فَاَخْرَجُوهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"سلطانه","display":"سُلْطَانِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"فيهم","display":"فِيهِمْ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يوم","display":"يَوْمَ"},{"kind":"word","token":"يسحبون","display":"يُسْحَبُونَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"النار","display":"النّٰارِ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"وجوههم","display":"وُجُوهِهِمْ"},{"kind":"word","token":"ذوقوا","display":"ذُوقُوا"},{"kind":"word","token":"مس","display":"مَسَّ"},{"kind":"word","token":"سقر","display":"سَقَرَ"},{"kind":"word","token":"انا","display":"اِنّٰا"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"شيء","display":"شَيْءٍ"},{"kind":"word","token":"خلقناه","display":"خَلَقْنٰاهُ"},{"kind":"word","token":"بقدر","display":"بِقَ