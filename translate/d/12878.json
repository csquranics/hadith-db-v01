,"segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"معاديا","display":"مُعَادِياً"},{"kind":"word","token":"لاهل","display":"لِاَهْلِ"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"مخالفا","display":"مُخَالِفاً"},{"kind":"word","token":"للدين","display":"لِلدِّينِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"ضروره","display":"ضَرُورَةً"},{"kind":"word","token":"لعنه","display":"لَعَنَهُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"التكبير","display":"التَّكْبِيرِ"},{"kind":"word","token":"الرابع","display":"الرَّابِعِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"العالمين","display":"العالمين"},{"kind":"word","token":"انك","display":"إنك"},{"kind":"word","token":"حميد","display":"حميد"},{"kind":"word","token":"مجيد","display":"مجيد"},{"kind":"word","token":"ثم","display":"ثم"},{"kind":"word","token":"تكبر","display":"تكبر"},{"kind":"word","token":"الصلاه","display":"الصَّلاَةِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يعرف","display":"يُعْرَفُ"},{"kind":"word","token":"مذهبه","display":"مَذْهَبُهُ"},{"kind":"word","token":"الميت","display":"الميت"},{"kind":"word","token":"فقل","display":"فقل"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"النفس","display":"النَّفْسَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"احييتها","display":"اَحْيَيْتَهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"امتها","display":"اَمَتَّهَا"},{"kind":"word","token":"تعلم","display":"تَعْلَمُ"},{"kind":"word","token":"سرها","display":"سِرَّهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"ولها","display":"وَلِّهَا"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"تولت","display":"تَوَلَّتْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"احشرها","display":"اُحْشُرْهَا"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"احبت","display":"اَحَبَّتْ"}]},{"source_hadith_segment":".  وَ لَوْ كَانَ مُسْتَضْعَفاً - اَيْ ضَعِيفَ الْعَقْلِ - وَ لاَ يُمَيِّزُ بَيْنَ الْمَذَاهِبِ وَ لِهَذَا كَانَ سُنِّيّاً اَوْ مُخَالِفاً لِلْحَقِّ نَاصِبِيّاً مُعَادِياً مُعَانِداً لِلشِّيعَةِ ،  اَوْ كَانَ مُعْتَقِداً بِاَهْلِ الْبَيْتِ وَ غَيْرَ مُعَادٍ لِاَعْدَائِهِمْ قَالَ فِي الصَّلاَةِ عَلَيْهِ :  اللَّهُمَّ اِغْفِرْ لِلَّذِينَ تَابُوا وَ اِتَّبَعُوا سَبِيلَكَ وَ قِهِمْ عَذَابَ الْجَحِيمِ","translation_segment":"می‌داشت و با دوستانت دشمنی می‌کرد و بغض اهل بیت پیامبرت را که درود خدا بر او باد، در دل داشت. و اگر میت مستضعف باشد که ضعیف العقل باشد و تمیز میان مذاهب نکند و به این سبب سنی باشد یا مخالف حق باشد و عناد با شیعیان نداشته باشد یا اعتقاد به اهل بیت علیهم السلام داشته باشد و با دشمنان ایشان بد نباشد در نماز بر او بگوید: اللهم‌ اغفر للذین تابوا و اتبعوا سبیلک و قهم عذاب الجحیم. خداوندا! آنانی که توبه کردند و پیروی راه تو را نمودند بیامرز و از عذاب دوزخ آنان را بازدار. و اگر مذهب میت معلوم","segment_columns":[]},{"source_hadith_segment":".  وَ لَوْ كَانَ مَجْهُولَ الْمَذْهَبِ قَالَ :  اللَّهُمَّ اِنَّ هَذِهِ النَّفْسَ اَنْتَ اَحْيَيْتَهَا وَ اَنْتَ اَمَتَّهَا اللَّهُمَّ وَلِّهَا مَا تَوَلَّتْ وَ اُحْشُرْهَا مَعَ مَنْ اَحَبَّتْ","translation_segment":"نباشد، در نماز او بگوید: اللهم‌ إن‌ هذه النفس أنت احییتها و انت امتها، اللهم‌ و لها ما تولت و احشرها مع من احبت. خدایا! این نفسی است که تو او را زنده کرده‌ای و تو او را میرانده‌ای. خدایا! درست کن او را با دوستانش و او را با کسانی که دوستشان","segment_columns":[]},{"source_hadith_segment":".  فَاِنْ كَانَ الْمَيِّتُ طِفْلاً غَيْرَ بَالِغٍ قَالَ :  اللَّهُمَّ اِجْعَلْهُ لِاَبَوَيْهِ وَ لَنَا سَلَفاً وَ فَرَطاً وَ اَجْراً .","translation_segment":"داشت محشور گردان. و اگر میت طفل نابالغ باشد بگوید: اللهم‌ اجعله لابویه و لنا سلفا و فرطا و اجرا. خدایا! او را برای پدر و مادرش و برای ما گذشته و ذخیره و اجر قرار ده.","segment_columns":[]}]}