{"consensus_set_id":"61440","translation_language":"fa","translation_source":{"hid":"298028"},"segments":[{"source_hadith_segment":"عَنْ اَبِي عَبْدِ اللَّهِ ( عَلَيْهِ السَّلاَمُ )  ،  فِي قَوْلِ اللَّهِ ( عَزَّ وَ جَلَّ ) :   <quranic_text> « وَ هَدَيْنٰاهُ النَّجْدَيْنِ » </quranic_text>   <footnote> [ البلد ۱۰ ] </footnote>  قَالَ :  نَجْدَ الْخَيْرِ وَ الشَّرِّ .","translation_segment":"هشام از امام صادق علیه السلام درباره گفتار خداوند (گرامی و بزرگ) که فرمود: «هر دو راه را بدو نمودیم» [بلد: آیه ۱۰] پرسش کرد. حضرت فرمود: راه خیر و شر.","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هديناه","display":"هَدَيْنٰاهُ"},{"kind":"word","token":"النجدين","display":"النَّجْدَيْنِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البلد","display":"البلد"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نجد","display":"نَجْدَ"},{"kind":"word","token":"الخير","display":"الْخَيْرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الشر","display":"الشَّرِّ"}]}]}