{"consensus_set_id":"s174610","translation_language":"fa","translation_source":{"hid":"174610"},"segments":[{"source_hadith_segment":"قَالَ اَللَّهُ تَعَالَي  <quranic_text> « وَ لِلّٰهِ عَلَي النّٰاسِ حِجُّ الْبَيْتِ ،  مَنِ اِسْتَطٰاعَ اِلَيْهِ سَبِيلاً » </quranic_text>   <footnote> [ العمران ۹۷ ] </footnote>   ،  قَالَ هَذِهِ لِمَنْ كَانَ عِنْدَهُ مَالٌ وَ صِحَّةٌ وَ اِنْ كَانَ سَوَّفَهُ لِلتِّجَارَةِ فَلاَ يَسَعُهُ وَ اِنْ مَاتَ عَلَي ذَلِكَ فَقَدْ تَرَكَ شَرِيعَةً مِنْ شَرَائِعِ الْاِسْلاَمِ ،  اِذَا هُوَ يَجِدُ مَا يَحُجُّ بِهِ الْحَدِيثَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لله","display":"لِلّٰهِ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"الناس","display":"النّٰاسِ"},{"kind":"word","token":"حج","display":"حِجُّ"},{"kind":"word","token":"البيت","display":"الْبَيْتِ"},{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"استطاع","display":"اِسْتَطٰاعَ"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"},{"kind":"word","token":"سبيلا","display":"سَبِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"العمران","display":"العمران"},{"kind":"word","token":"۹۷","display":"۹۷"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"لمن","display":"لِمَنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"عنده","display":"عِنْدَهُ"},{"kind":"word","token":"مال","display":"مَالٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صحه","display":"صِحَّةٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"