{"consensus_set_id":"s227879","translation_language":"fa","translation_source":{"hid":"227879"},"segments":[{"source_hadith_segment":"<quranic_text> « وَ لَقَدْ كَتَبْنٰا فِي الزَّبُورِ مِنْ بَعْدِ الذِّكْرِ » </quranic_text>   <footnote> [ الانبياء ۱۰۵ ] </footnote>  قَالَ الْكُتُبُ كُلُّهَا ذِكْرٌ  <quranic_text> « اَنَّ الْاَرْضَ يَرِثُهٰا عِبٰادِيَ الصّٰالِحُونَ » </quranic_text>   <footnote> [ الانبياء ۱۰۵ ] </footnote>  قَالَ الْقَائِمُ عَلَيْهِ السَّلاَمُ وَ اَصْحَابُهُ قَالَ وَ الزَّبُورُ فِيهِ مَلاَحِمُ وَ تَحْمِيدٌ وَ تَمْجِيدٌ وَ دُعَاءٌ .","translation_segment":"","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"كتبنا","display":"كَتَبْنٰا"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الزبور","display":"الزَّبُورِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بعد","display":"بَعْدِ"},{"kind":"word","token":"الذكر","display":"الذِّكْرِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۱۰۵","display":"۱۰۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الكتب","display":"الْكُتُبُ"},{"kind":"word","token":"كلها","display":"كُلُّهَا"},{"kind":"word","token":"ذكر","display":"ذِكْرٌ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"الارض","display":"الْاَرْضَ"},{"kind":"word","token":"يرثها","display":"يَرِثُهٰا"},{"kind":"word","token":"عبادي","display":"عِبٰادِيَ"},{"kind":"word","token":"الصالحون","display":"الصّٰالِحُونَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الانبياء","display":"الانبياء"},{"kind":"word","token":"۱۰۵","display":"۱۰۵"},{"kind":"tag