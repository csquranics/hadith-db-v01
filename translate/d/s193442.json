{"consensus_set_id":"s193442","translation_language":"fa","translation_source":{"hid":"193442"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ عَزَّ وَ جَلَّ  <quranic_text> « يَحْكُمُ بِهِ ذَوٰا عَدْلٍ مِنْكُمْ » </quranic_text>   <footnote> [ المائدة ۹۵ ] </footnote>   ،  فَالْعَدْلُ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ  ،  وَ الْاِمَامُ مِنْ بَعْدِهِ يَحْكُمُ بِهِ وَ هُوَ ذُو عَدْلٍ فَاِذَا عَلِمْتَ مَا حَكَمَ بِهِ رَسُولُ اللَّهِ صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ وَ الْاِمَامُ فَحَسْبُكَ فَلاَ تَسْاَلْ عَنْهُ .","translation_segment":"","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يحكم","display":"يَحْكُمُ"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"ذوا","display":"ذَوٰا"},{"kind":"word","token":"عدل","display":"عَدْلٍ"},{"kind":"word","token":"منكم","display":"مِنْكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المائده","display":"المائدة"},{"kind":"word","token":"۹۵","display":"۹۵"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"فالعدل","display":"فَالْعَدْلُ"},{"kind":"word","token":"رسول","display":"رَسُولُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اله","display":"الِهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الامام","display":"الْاِمَامُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بعده","display":"بَعْدِهِ"},{"kind":"word","token":"يحكم","display":"يَحْكُمُ"},{"kind":"wo