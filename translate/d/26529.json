{"consensus_set_id":"26529","translation_language":"fa","translation_source":{"hid":"290508"},"segments":[{"source_hadith_segment":"اَنَّ عَلِيَّ بْنَ الْحُسَيْنِ عَلَيْهِمَا السَّلاَمُ كَانَ يَذْكُرُ حَالَ مَنْ مَسَخَهُمُ اللَّهُ قِرَدَةً مِنْ بَنِي اِسْرَائِيلَ وَ يَحْكِي قِصَّتَهُمْ فَلَمَّا بَلَغَ اخِرَهَا قَالَ","translation_segment":"و باسناد که ذکر آن پیشتر مذکور و عیان گردید مروی و منقولست که: روزی حضرت علی‌ بن الحسین علیه السلام ذکر بیان أحوال کثیر الاختلال جمعی از بنی اسرائیل که صورت ایشان مسخ و تبدیل بصورت قرده گشتند می‌نمود","segment_columns":[{"kind":"word","token":"ع","display":"ع"},{"kind":"word","token":"الاحتجاج","display":"الاحتجاج"},{"kind":"word","token":"بالاسناد","display":"بِالْاِسْنَادِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ابي","display":"اَبِي"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"العسكري","display":"الْعَسْكَرِيِّ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابائه","display":"ابَائِهِ"},{"kind":"word","token":"عليهم","display":"عَلَيْهِمُ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"علي","display":"عَلِيَّ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنِ"},{"kind":"word","token":"عليهما","display":"عَلَيْهِمَا"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يذكر","display":"يَذْكُرُ"},{"kind":"word","token":"حال","display":"حَالَ"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"مسخهم","display":"مَسَخَهُمُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"قرده","display":"قِرَدَةً"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بني","display":"بَنِي"},{"kind":"word","token":"اسرائيل","display":"اِسْرَائِيلَ"},{"kind":"word","token":"و","display":"وَ