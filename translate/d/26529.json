play":"يَمْسَخْهُمْ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الدنيا","display":"الدُّنْيَا"}]},{"source_hadith_segment":"فَاِنَّ الْمُعَدَّ لَهُمْ مِنْ عَذَابِ الْاخِرَةِ اَضْعَافُ اَضْعَافِ عَذَابِ الْمَسْخِ فَقِيلَ لَهُ","translation_segment":"خواهد بود اگر چه این قوم بیحیا مسخ صورت در دنیا نشدند لیکن عذاب آخرت که برای آن جماعت معد و مهیاست آن عذاب","segment_columns":[{"kind":"word","token":"فان","display":"فَاِنَّ"},{"kind":"word","token":"بمحمد","display":"بِمُحَمَّدٍ"},{"kind":"word","token":"نبي","display":"نَبِيِّ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المعد","display":"الْمُعَدَّ"},{"kind":"word","token":"لهم","display":"لَهُمْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"عذاب","display":"عَذَابِ"},{"kind":"word","token":"الله","display":"اَللَّهِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الاخره","display":"الْاخِرَةِ"},{"kind":"word","token":"اضعاف","display":"اَضْعَافُ"},{"kind":"word","token":"اضعاف","display":"اَضْعَافِ"},{"kind":"word","token":"عذاب","display":"عَذَابِ"},{"kind":"word","token":"المسخ","display":"الْمَسْخِ"},{"kind":"word","token":"فقيل","display":"فَقِيلَ"},{"kind":"word","token":"له","display":"لَهُ"}]},{"source_hadith_segment":"يَا اِبْنَ رَسُولِ اللَّهِ فَاِنَّا قَدْ سَمِعْنَا مِنْكَ هَذَا الْحَدِيثَ فَقَالَ لَنَا بَعْضُ النُّصَّابِ فَاِنْ كَانَ قُتِلَ الْحُسَيْنُ بَاطِلاً فَهُوَ اَعْظَمُ عِنْدَ اللَّهِ مِنْ صَيْدِ السَّمَكِ فِي السَّبْتِ اَ فَمَا كَانَ اللَّهُ غَضِبَ عَلَي قَاتِلِيهِ كَمَا غَضِبَ عَلَي صَيَّادِي السَّمَكِ ؟  قَالَ عَلِيُّ بْنُ الْحُسَيْنِ عَلَيْهِمَا السَّلاَمُ قُلْ لِهَؤُلاَءِ النُّصَّابِ فَاِنْ كَانَ اِبْلِيسُ مَعَاصِيهِ اَعْظَمَ مِنْ مَعَاصِي مَنْ كَفَرَ بِاِغْوَائِهِ فَاَهْلَكَ اللَّهُ مَنْ شَاءَ مِنْهُمْ كَقَوْمِ نُوحٍ وَ فِرْعَوْنَ وَ لَمْ يُهْلِكْ اِبْلِيسَ وَ هُوَ اَوْلَي بِالْهَلاَكِ فَمَا بَالُهُ اَهْلَكَ هَؤُلاَءِ الَّذِينَ قَصُرُوا عَنْ اِبْلِيسَ فِي عَمَلِ الْمُوبِقَاتِ وَ اَمْهَلَ اِبْلِيسَ مَعَ اِيثَارِهِ لِكَشْفِ الْمُحَرَّمَاتِ اَ مَا كَانَ رَبُّنَا عَزَّ وَ جَلَّ حَكِيماً تَدْبِيرُهُ حِكْمَةً فِيمَنْ اَهْلَكَ وَ فِيمَنِ اِسْتَبْقَي ؟  فَكَذَلِكَ هَؤُلاَءِ الصَّائِدُونَ فِي السَّبْتِ وَ هَؤُلاَءِ الْقَاتِلُونَ لِلْحُسَيْنِ يَفْعَلُ فِي الْفَرِيقَيْنِ مَا يَعْلَمُ اَنَّهُ اَوْلَي بِالصَّوَابِ وَ الْحِكْمَةِ  <quranic_text> « لاٰ يُسْئَلُ عَمّٰا يَفْعَلُ » </quranic_text>   <footnote> [ الانبياء ۲۳ ] </footnote>  وَ عِبَادُهُ  <quranic_text> « يُسْئَلُونَ » </quranic_text>   <footnote> [ الانبياء ۲۳ ] </footnote>  وَ قَالَ الْبَاقِرُ عَلَيْهِ السَّلاَمُ فَلَمَّا حَدَّثَ عَلِيُّ بْنُ الْحُسَيْنِ عَلَيْهِمَا السَّلاَمُ بِهَذَا الْحَدِيثِ قَالَ لَهُ بَعْضُ","translation_segment":"أضعاف مضاعفه از عذاب مسخ است. در آن أثناء شخصی گفت: یا بن رسول اللٰه ما این حدیث را از شما- مکرر شنیدیم اما چون این کلام ببعضی از نواصب رسید بما گفته‌اند اگر قتل امام حسین (علیه السلام) باطل نبودی بیقین آن أعظم و أکبر از سمک است در روز شنبه بایستی که چنانچه حضرت ایزد منان بر آن صیادان غضب کرد هم چنین بر قاتلان امام حسین (علیه السلام) نیز غضب کردی. حضرت علی‌ بن الحسین (علیهما السلام) فرمود که: بآن نواصب بگوی که معاصی ابلیس بیقین زیاده از معاصی آن طایفه باغیه است که باغوای آن لعین کافر و بیدین گشتند مع هذا حضرت اللٰه تعالی هر کرا خواست از آن قوم هلاک گردانید مثل قوم نوح و فرعون و غیر ایشان را و ابلیس با آنکه أولی بهلاکت بود حضرت معبود او را باقی و موجود گذاشت. پس چرا حضرت ایزد تعالی جمعی را که بتقصیر آن ضال‌ کبیر مرتکب عمل موبقات شده هلاک گردانید و حضرت عز و جل‌ آن باغی دغل را با متابعان مضل‌ برای کشف محرمات مهل داد. بیقین ایزد لم یزل این عمل از روی تدبیر و حکمت و عدل بحیز ظهور و فعل آورد و در باب آنکه او را هلاک گردانید و در حق‌ آنکه او را باقی گذاشت همچنین است حال صیادان سمک در روز شنبه و حال قاتلان پدرم امام حسین (علیه السلام). رب‌ العالمین آنچه در حق‌ هر یک از فریقین أولی بصواب و وسیله أجر و ثواب بحکمت و عدل مستطاب دانست به معمول گردانید. لاٰ یسئل‌ عمٰا یفعل‌ و هم‌ یسئلون‌. حضرت ایزد متعال از بندگان سوال از أعمال و أفعال نماید من غیر عکس. و از امام الباطن و الظاهر محمد بن علی‌ بن الحسین الباقر علیهم السلام منقول و مروریست که: چون پدر بزرگوارم علیه السلام این حدیث بیان فرمود بعضی که در مجلس شریف و محفل منیف حاضر بودند گفتند: یا ابن رسول اللٰه صلی اللٰه علیه","segment_columns":[{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"ابن","display":"اِبْنَ"},{"kind":"word","token":"رسول","display":"رَسُولِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"فانا","display":"فَاِنَّا"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"سمعنا","display":"سَمِعْنَا"},{"kind":"word","token":"منك","display":"مِنْكَ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"الحديث","display":"الْحَدِيثَ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لنا","display":"لَنَا"},{"kind":"word","token":"بعض","display":"بَعْضُ"},{"kind":"word","token":"النصاب","display":"النُّصَّابِ"},{"kind":"word","token":"فان","display":"فَاِنْ"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"قتل","display":"قُتِلَ"},{"kind":"word","token":"الحسين","display":"الْحُسَيْنُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"باطلا","display":"بَاطِلاً"},{"kind":"word","token":"فهو","display":"فَهُوَ"},{"kind":"word","token":"اعظم","display":"اَعْظَمُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"صيد","display":"صَيْدِ"},{"kind":"word","token":"السمك","display":"السَّمَكِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"السبت","display":"السَّبْتِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"فما","display":"فَمَا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يغضب","display":"يَغْضَبُ"},{"kind":"word","token":"الله","d