{"consensus_set_id":"61548","translation_language":"fa","translation_source":{"hid":"119158"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ تَعَالَي  <quranic_text> « مَنْ ذَا الَّذِي يُقْرِضُ اللّٰهَ قَرْضاً حَسَناً فَيُضٰاعِفَهُ لَهُ وَ لَهُ اَجْرٌ كَرِيمٌ » </quranic_text>   <footnote> [ الحديد ۱۱ ] </footnote>  قَالَ صِلَةُ الْاِمَامِ فِي دَوْلَةِ الْفَسَقَةِ .","translation_segment":"مردی از حضرت موسی بن جعفر علیه السلام روایت می‌کند که در باره این آیه شریفه: «من‌ ذا الذی یقرض‌ اللٰه‌ قرضا حسنا فیضٰاعفه‌ له‌ و له‌ أجر کریم‌» فرمود: مقصود از آن پیوستن به امام است در دولت تبهکاران.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"من","display":"مَنْ"},{"kind":"word","token":"ذا","display":"ذَا"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"يقرض","display":"يُقْرِضُ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"قرضا","display":"قَرْضاً"},{"kind":"word","token":"حسنا","display":"حَسَناً"},{"kind":"word","token":"فيضاعفه","display":"فَيُضٰاعِفَهُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"اجر","display":"اَجْرٌ"},{"kind":"word","token":"كريم","display":"كَرِيمٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحديد","display":"الحديد"},{"kind":"word","token":"۱۱","display":"۱۱"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"صله","display":"صِلَةُ"},{"kind":"word","token":"الامام","display":"الْاِمَامِ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"دوله","display":"دَوْلَةِ"},{"kind":"word","token":"الفسقه","display":"الْفَسَقَةِ"}]}]}