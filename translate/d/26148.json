{"consensus_set_id":"26148","translation_language":"fa","translation_source":{"hid":"372631"},"segments":[{"source_hadith_segment":"وَ اَمَّا السَّاعَةُ الْعَاشِرَةُ فَمِنْ سَاعَتَيْنِ بَعْدَ صَلاَةِ الْعَصْرِ اِلَي قَبْلِ [ قُبَيْلِ ] اِصْفِرَارِ الشَّمْسِ وَ هِيَ مَنْسُوبَةٌ اِلَي الْهَادِي عَلَيْهِ السَّلاَمُ وَ هَذَا دُعَاؤُهَا :","translation_segment":"","segment_columns":[{"kind":"word","token":"دعاء","display":"دُعَاءٌ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اما","display":"اَمَّا"},{"kind":"word","token":"الساعه","display":"السَّاعَةُ"},{"kind":"word","token":"العاشره","display":"الْعَاشِرَةُ"},{"kind":"word","token":"فمن","display":"فَمِنْ"},{"kind":"word","token":"ساعتين","display":"سَاعَتَيْنِ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"صلاه","display":"صَلاَةِ"},{"kind":"word","token":"العصر","display":"الْعَصْرِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"قبل","display":"قَبْلِ"},{"kind":"word","token":"قبيل","display":"قُبَيْلِ"},{"kind":"word","token":"اصفرار","display":"اِصْفِرَارِ"},{"kind":"word","token":"الشمس","display":"الشَّمْسِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"منسوبه","display":"مَنْسُوبَةٌ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الهادي","display":"الْهَادِي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هذا","display":"هَذَا"},{"kind":"word","token":"دعاؤها","display":"دُعَاؤُهَا"}]},{"source_hadith_segment":"اللَّهُمَّ اَنْتَ  <quranic_text> « الْوَلِيُّ الْحَمِيدُ » </quranic_text>   <footnote> [ الشوري ۲۸ ] </footnote>   <quranic_text> « الْغَفُورُ الْوَدُودُ » </quranic_text>   <footnote> [ البروج ۱۴ ] </footnote>  الْمُبْدِئُ الْمُعِيدُ  <quranic_text> « ذُو الْعَرْشِ الْمَجِيدُ » </quranic_text>   <footnote> [ البروج ۱۵ ] </footnote>  وَ الْبَطْشِ الشَّدِيدِ  <quranic_text> « فَعّٰالٌ لِمٰا يُرِيدُ » </quranic_text>   <footnote> [ البروج ۱۶ ] </footnote>  يَا مَنْ هُوَ اَقْرَبُ اِلَيَّ  <quranic_text> « مِنْ حَبْلِ الْوَرِيدِ » </quranic_text>   <footnote> [ ق ۱۶ ] </footnote>  يَا مَنْ  <quranic_text> « هُوَ عَليٰ كُلِّ شَيْءٍ شَهِيدٌ » </quranic_text>   <footnote> [ سبا ۴۷ ] </footnote>  يَا مَنْ لاَ يَتَعَاظَمُهُ غُفْرَانُ الذُّنُوبِ وَ لاَ يَكْبُرُ عَلَيْهِ الصَّفْحُ عَنِ الْعُيُوبِ اَسْاَلُكَ بِجَلاَلِكَ [ بِجَلاَلِ وَجْهِكَ ] وَ بِنُورِ وَجْهِكَ الَّذِي مَلَاَ اَرْكَانَ عَرْشِكَ وَ بِقُدْرَتِكَ الَّتِي قَدَرْتَ بِهَا عَلَي خَلْقِكَ وَ بِرَحْمَتِكَ الَّتِي  <quranic_text> « وَسِعَتْ كُلَّ شَيْءٍ » </quranic_text>   <footnote> [ الاعراف ۱۵۶ ] </footnote>  وَ بِقُوَّتِكَ الَّتِي ضَعُفَ لَهَا كُلُّ قَوَيٍّ وَ بِعِزَّتِكَ الَّتِي ذَلَّ بِهَا كُلُّ عَزِيزٍ وَ بِمَشِيئَتِكَ الَّتِي صَغُرَ [ ضَعُفَ ] فِيهَا كُلُّ كَبِيرٍ وَ بِرَسُولِكَ الَّذِي رَحِمْتَ بِهِ الْعِبَادَ وَ هَدَيْتَ بِهِ اِلَي سُبُلِ الرَّشَادِ وَ بِاَمِيرِ الْمُؤْمِنِينَ عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ اَوَّلِ مَنْ امَنَ بِرَسُولِكَ وَ صَدَّقَ وَ الَّذِي وَفَي بِمَا عَاهَدَ عَلَيْهِ وَ تَصَدَّقَ وَ بِالْاِمَامِ الْبَرِّ عَلِيِّ بْنِ مُحَمَّدٍ عَلَيْهِ السَّلاَمُ الَّذِي كَفَيْتَهُ حِيلَةَ الْاَعْدَاءِ وَ اَرَيْتَهُمْ عَجِيبَ الْايَةِ اِذْ تَوَسَّلُوا بِهِ فِي الدُّعَاءِ اَنْ تُصَلِّيَ عَلَي مُحَمَّدٍ وَ الِ مُحَمَّدٍ فَقَدِ اِسْتَشْفَعْتُ بِهِمْ اِلَيْكَ وَ قَدَّمْتُهُمْ اَمَامِي وَ بَيْنَ يَدَيْ حَوَائِجِي وَ اَنْ تَجْعَلَنِي مِنْ كِفَايَتِكَ فِي حِرْزٍ حَرِيزٍ وَ مِنْ كِلاَءَتِكَ تَحْتَ عِزٍّ عَزِيزٍ وَ تُوزِعَنِي شُكْرَ الاَئِكَ وَ مِنَنِكَ وَ تُوَفِّقَنِي لِلاِعْتِرَافِ بِاَيَادِيكَ وَ نِعْمَتِكَ يَا اَرْحَمَ الرَّاحِمِينَ .","translation_segment":"","segment_columns":[{"kind":"word","token":"اللهم","display":"اللَّهُمَّ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الولي","display":"الْوَلِيُّ"},{"kind":"word","