{"consensus_set_id":"330","translation_language":"fa","translation_source":{"hid":"310516"},"segments":[{"source_hadith_segment":"عَنْ اَبِي عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ  :  فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « فِطْرَتَ اللّٰهِ الَّتِي فَطَرَ النّٰاسَ عَلَيْهٰا » </quranic_text>   <footnote> [ الروم ۳۰ ] </footnote>  قَالَ التَّوْحِيدُ وَ مُحَمَّدٌ رَسُولُ اللَّهِ وَ عَلِيٌّ اَمِيرُ الْمُؤْمِنِينَ .","translation_segment":"حدیث کرد ما را محمد بن حسن بن احمد بن ولید «ره» گفت که حدیث کرد ما را محمد بن حسن صفار از علی بن حسان واسطی از حسن بن یونس از عبد الرحمن بن کثیر مولای حضرت باقر از حضرت صادق (علیه السلام) در قول خدای عز و جل «فطرت‌ اللٰه‌ التی فطر النٰاس‌ علیهٰا» فرمود که توحید و اقرار باینکه محمد رسول خدا و علی پادشاه مومنانست","segment_columns":[{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"ابيه","display":"اَبِيهِ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"جده","display":"جَدِّهِ"},{"kind":"word","token":"محمد","display":"مُحَمَّدِ"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"احدكم","display":"اَحَدِكُمْ"},{"kind":"word","token":"اذا","display":"اِذَا"},{"kind":"word","token":"دفن","display":"دَفَنَ"},{"kind":"word","token":"ميته","display":"مَيِّتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سوي","display":"سَوَّي"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انصرف","display":"اِنْصَرَفَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قبره","display":"قَبْرِهِ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتخلف","display":"يَتَخَلَّفَ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"قبره","display":"قَبْرِهِ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"يقول","display":"يَقُولَ"},{"kind":"word","token":"يا","displ