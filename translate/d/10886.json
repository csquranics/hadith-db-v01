{"consensus_set_id":"10886","translation_language":"fa","translation_source":{"hid":"352401"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « اُذِنَ لِلَّذِينَ يُقٰاتَلُونَ بِاَنَّهُمْ ظُلِمُوا وَ اِنَّ اللّٰهَ عَليٰ نَصْرِهِمْ لَقَدِيرٌ » </quranic_text>   <footnote> [ الحج ۳۹ ] </footnote>  قَالَ عَلِيٌّ وَ الْحَسَنُ وَ الْحُسَيْنُ عَلَيْهِمُ السَّلاَمُ  .","translation_segment":"پدرم رحمه اللٰه علیه از سعد بن عبد اللٰه، از احمد بن محمد بن عیسی، از عباس بن معروف، از صفوان بن یحیی، از حکم حناط‍‌، از ضریس، از ابی خالد کابلی، از حضرت ابی جعفر علیه السلام نقل نموده که گفت: از آن جناب شنیدم که در ذیل فرموده حق عز و جل‌: «أذن‌ للذین‌ یقٰاتلون‌ بأنهم‌ ظلموا و إن‌ اللٰه‌ علیٰ‌ نصرهم‌ لقدیر». فرمودند: ایشان علی و حسن و حسین علیهم السلام می‌باشند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اذن","display":"اُذِنَ"},{"kind":"word","token":"للذين","display":"لِلَّذِينَ"},{"kind":"word","token":"يقاتلون","display":"يُقٰاتَلُونَ"},{"kind":"word","token":"بانهم","display":"بِاَنَّهُمْ"},{"kind":"word","token":"ظلموا","display":"ظُلِمُوا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"نصرهم","display":"نَصْرِهِمْ"},{"kind":"word","token":"لقدير","display":"لَقَدِيرٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الحج","display":"الحج"},{"kind":"word","token":"۳۹","display":"۳۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","to