{"consensus_set_id":"s331660","translation_language":"fa","translation_source":{"hid":"331660"},"segments":[{"source_hadith_segment":"[ فِي قَوْلِهِ تَعَالَي ] :   <quranic_text> « اِتَّقُوا اللّٰهَ » </quranic_text>   <footnote> [ التوبة ۱۱۹ ] </footnote>  قَالَ :  اَمَرَ اللَّهُ اَصْحَابَ مُحَمَّدٍ بِاَجْمَعِهِمْ اَنْ يَخَافُوا اللَّهَ - ثُمَّ قَالَ لَهُمْ :   <quranic_text> « وَ كُونُوا مَعَ الصّٰادِقِينَ » </quranic_text>   <footnote> [ التوبة ۱۱۹ ] </footnote>   .  يَعْنِي مُحَمَّداً وَ اَهْلَ بَيْتِهِ  .","translation_segment":"عن عبد الله بن عمر فی قوله تعالی: (اتقوا الله) قال: أمر الله أصحاب محمد بأجمعهم أن یخافوا الله ثم قال لهم: (و کونوا مع الصادقین). یعنی محمدا و أهل بیته. عبد الله بن عمر درباره آیه: «اتقوا الله» گفت: خداوند همه اصحاب محمد را امر می‌کند که از خدا بترسند، سپس به آنان می‌گوید: «و کونوا مع الصادقین» یعنی با محمد و اهل بیت او باشند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۱۱۹","display":"۱۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"امر","display":"اَمَرَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"اصحاب","display":"اَصْحَابَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"باجمعهم","display":"بِاَجْمَعِهِمْ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يخافوا","display":"يَخَافُوا"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":