{"consensus_set_id":"s409041","translation_language":"fa","translation_source":{"hid":"409041"},"segments":[{"source_hadith_segment":"« عَلِيٌّ سَيِّدِي ( صَلَوَاتُ اللَّهِ وَ سَلاَمُهُ عَلَيْهِ ) قَرَاَ هَذِهِ الْايَةَ :   <quranic_text> « لاٰ تَجْعَلُوا دُعٰاءَ الرَّسُولِ بَيْنَكُمْ كَدُعٰاءِ بَعْضِكُمْ بَعْضاً » </quranic_text>   <footnote> [ النور ۶۳ ] </footnote> - قَالَتْ فَاطِمَةُ - فَجِئْتُ النَّبِيَّ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اَنْ اَقُولَ لَهُ :  يَا اَبَاهْ ،  فَجَعَلْتُ اَقُولُ :  يَا رَسُولَ اللَّهِ .  فَاَقْبَلَ عَلَيَّ ،  وَ قَالَ :  يَا بُنَيَّةِ ،  لَمْ تَنْزِلْ فِيكِ وَ لاَ فِي اَهْلِكِ مِنْ قَبْلُ ،  قَالَ :  اَنْتِ مِنِّي ،  وَ اَنَا مِنْكِ ،  وَ اِنَّمَا نَزَلَتْ فِي اَهْلِ الْجَفَاءِ ،  وَ اِنَّ قَوْلَكَ :  يَا اَبَاهُ ،  اَحَبُّ اِلَي قَلْبِي ،  وَ اَرْضَي لِلرَّبِّ ،  ثُمَّ قَالَ :  اَنْتَ نِعْمَ الْوَلَدُ ،  وَ قَبَّلَ وَجْهِي ،  وَ مَسَحَنِي مِنْ رِيقِهِ ،  فَمَا اِحْتَجْتُ اِلَي طِيبٍ بَعْدَهُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"سيدي","display":"سَيِّدِي"},{"kind":"word","token":"صلوات","display":"صَلَوَاتُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"سلامه","display":"سَلاَمُهُ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"قرا","display":"قَرَاَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"تجعلوا","display":"تَجْعَلُوا"},{"kind":"word","token":"دعاء","display":"دُعٰاءَ"},{"kind":"word","token":"الرسول","display":"الرَّسُولِ"},{"kind":"word","token":"بينكم","display":"بَيْنَكُمْ"},{"kind":"word","token":"كدعاء","display":"كَدُعٰاءِ"},{"kind":"word","token":"بعضكم","display":"بَعْضِكُمْ"},{"kind":"word","token":"بعضا","display":"بَعْضاً"},{"kind":"tag_close","tag_name":"q