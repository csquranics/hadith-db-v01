{"consensus_set_id":"s409702","translation_language":"fa","translation_source":{"hid":"409702"},"segments":[{"source_hadith_segment":"« اِنَّ اَللَّهَ خَلَقَ بِيَدِهِ جَنَّةً لَمْ يَرَهَا غَيْرُهُ ،  وَ لَمْ يَطَّلِعْ عَلَيْهَا مَخْلُوقٌ ،  تُفَتَّحُ لِلرَّبِّ تَبَارَكَ وَ تَعَالَي كُلَّ صَبَاحٍ ،  فَيَقُولُ :  اِزْدَادِي طِيباً ،  اِزْدَادِي رِيحاً .  وَ تَقُولُ :  قَدْ اَفْلَحَ الْمُؤْمِنُونَ ،  وَ هُوَ قَوْلُ اللَّهِ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « فَلاٰ تَعْلَمُ نَفْسٌ مٰا اُخْفِيَ لَهُمْ مِنْ قُرَّةِ اَعْيُنٍ جَزٰاءً بِمٰا كٰانُوا يَعْمَلُونَ » </quranic_text>   <footnote> [ السجده ۱۷ ] </footnote>   .","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اَللَّهَ"},{"kind":"word","token":"خلق","display":"خَلَقَ"},{"kind":"word","token":"بيده","display":"بِيَدِهِ"},{"kind":"word","token":"جنه","display":"جَنَّةً"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يرها","display":"يَرَهَا"},{"kind":"word","token":"غيره","display":"غَيْرُهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يطلع","display":"يَطَّلِعْ"},{"kind":"word","token":"عليها","display":"عَلَيْهَا"},{"kind":"word","token":"مخلوق","display":"مَخْلُوقٌ"},{"kind":"word","token":"تفتح","display":"تُفَتَّحُ"},{"kind":"word","token":"للرب","display":"لِلرَّبِّ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"كل","display":"كُلَّ"},{"kind":"word","token":"صباح","display":"صَبَاحٍ"},{"kind":"word","token":"فيقول","display":"فَيَقُولُ"},{"kind":"word","token":"ازدادي","display":"اِزْدَادِي"},{"kind":"word","token":"طيبا","display":"طِيباً"},{"kind":"word","token":"ازدادي","display":"اِزْدَادِي"},{"kind":"word","token":"ريحا","display":"رِيحاً"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","t