{"consensus_set_id":"s441261","translation_language":"fa","translation_source":{"hid":"441261"},"segments":[{"source_hadith_segment":"لِمَ سَجَدْتَ يَا رَسُولَ اللَّهِ","translation_segment":"باز هم حافظ‍‌ برسی از ابن عباس، نقل کرده","segment_columns":[{"kind":"word","token":"لم","display":"لِمَ"},{"kind":"word","token":"سجدت","display":"سَجَدْتَ"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"رسول","display":"رَسُولَ"},{"kind":"word","token":"الله","display":"اللَّهِ"}]},{"source_hadith_segment":"؟  فَقَالَ :  لَمَّا شَرِبَ عَلِيٌّ نَادَاهُ اللَّهُ تَعَالَي :  هَنِيئاً مَرِيئاً يَا وَلِيِّي وَ حُجَّتِي عَلَي خَلْقِي وَ اَمِينِي عَلَي عِبَادِي","translation_segment":"که گفت: حضرت علی ع در حضور پیامبر صلی الله علیه و آله آب نوشید. همان موقع رسول خدا صلی الله علیه و آله به سجده رفت. حاضرین از حضرت محمد صلی الله علیه و آله پرسیدند که: یا","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"شرب","display":"شَرِبَ"},{"kind":"word","token":"علي","display":"عَلِيٌّ"},{"kind":"word","token":"ناداه","display":"نَادَاهُ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"هنيئا","display":"هَنِيئاً"},{"kind":"word","token":"مريئا","display":"مَرِيئاً"},{"kind":"word","token":"يا","display":"يَا"},{"kind":"word","token":"وليي","display":"وَلِيِّي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"حجتي","display":"حُجَّتِي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"خلقي","display":"خَلْقِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"اميني","display":"اَمِينِي"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"عبادي","display":"عِبَادِي"}]},{"source_hadith_segment":".  اَقُولُ :  اَكْثَرُ النَّاسِ يُنْكِرُونَ بِهَذَا الْحَدِيثِ وَ يَقُولُونَ :  كَيْفَ يَقُولُ اللَّهُ لِعَلِيٍّ هَنِيئاً مَرِيئاً",