{"consensus_set_id":"7144","translation_language":"fa","translation_source":{"hid":"371712"},"segments":[{"source_hadith_segment":"سَاَلْتُ اَبَا عَبْدِ اللَّهِ عَلَيْهِ السَّلاَمُ عَنْ قَوْلِ الرَّجُلِ لِلرَّجُلِ جَزَاكَ اللَّهُ خَيْراً مَا يَعْنِي بِهِ فَقَالَ اَبُو عَبْدِ","translation_segment":"حسین بن أعین برادر مالک گوید: از امام صادق علیه السلام پرسیدم در باره گفته شخصی به دیگری که: خدا پاداش خیرت دهد-مقصود چیست‌؟","segment_columns":[{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"ابا","display":"اَبَا"},{"kind":"word","token":"عبد","display":"عَبْدِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الرجل","display":"الرَّجُلِ"},{"kind":"word","token":"للرجل","display":"لِلرَّجُلِ"},{"kind":"word","token":"جزاك","display":"جَزَاكَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"خيرا","display":"خَيْراً"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"به","display":"بِهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"ابو","display":"اَبُو"},{"kind":"word","token":"عبد","display":"عَبْدِ"}]},{"source_hadith_segment":"اللَّهِ عَلَيْهِ السَّلاَمُ اِنَّ الْخَيْرَ نَهَرٌ فِي الْجَنَّةِ مَخْرَجُهُ مِنَ الْكَوْثَرِ وَ الْكَوْثَرُ مَخْرَجُهُ مِنْ سَاقِ الْعَرْشِ عَلَيْهِ مَنَازِلُ الْاَوْصِيَاءِ وَ شِيعَتِهِمْ عَلَي حَافَتَيْ ذَلِكَ النَّهَرِ جَوَارٍ نَابِتَاتٌ كُلَّمَا قُلِعَتْ وَاحِدَةٌ نَبَتَتْ اُخْرَي بِاسْمِ ذَلِكَ النَّهَرِ وَ ذَلِكَ قَوْلُ اللَّهِ عَزَّ وَ جَلَّ فِي كِتَابِهِ -  <quranic_text> « فِيهِنَّ خَيْرٰاتٌ حِسٰانٌ » </quranic_text>   <footnote> [ الرحمن ۷۰ ] </footnote>  فَاِذَا قَالَ الرَّجُلُ لِصَاحِبِهِ جَزَاكَ اللَّهُ خَيْراً فَاِنَّمَا يَعْنِي بِهِ تِلْكَ الْمَنَازِلَ الَّتِي اَعَدَّهَا اللَّهُ عَزَّ وَ جَلَّ لِصَفْوَتِهِ وَ خِيَرَتِهِ مِنْ خَلْقِهِ .","translation_segment":"حضرت صادق علیه السلام فرمود: «خیر» نهری در بهشت است که سرچشمه آن از کوثر، و محل‌ خروج آب کوثر از ساق عرش می‌باشد، منازل اوصیاء پیامبران و پیروان ایشان بر روی آن نهر قرار دارد، بر اطرافش جواری پدید آیند، هر زمان یکی از آنان جدا گشته، دیگری به نام آن نهر پدیدار شود، و این است فرموده خدای عز و جل‌ در قرآنش «فیهن‌ خیرٰات‌ حسٰان‌» (در این چهار بهشت زنانی باشند صاحب اخلاق فاضل و صورت زیبا-الرحمن:۷۰) پس وقتی که مردی به رفیقش گفت: خدا به تو پاداش خیر دهد، همانا مقصودش این منزلهائی می‌باشد که خداوند برای برگزیدگان و نیکان از مخلوقش مهیا ساخته است.","segment_columns":[{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الخير","display":"الْخَيْرَ"},{"kind":"word","token":"نهر","display":"نَهَرٌ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"مخرجه","display":"مَخْرَجُهُ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الكوثر","display":"الْكَوْثَرِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الكوثر","display":"الْكَوْثَرُ"},{"kind":"word","token":"مخرجه","display":"مَخْرَجُهُ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"ساق","display":"سَاقِ"},{"kind":"word","token":"العرش","display":"الْعَرْشِ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"منازل","display":"مَنَازِلُ"},{"kind":"word","token":"الاوصياء","display":"الْاَوْصِيَاءِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شيعتهم","display":"شِيعَتِهِمْ"},{"kind":"word","t