{"consensus_set_id":"33581","translation_language":"fa","translation_source":{"hid":"348808"},"segments":[{"source_hadith_segment":"اَللَّهُمَّ لَكَ سَجَدْتُ وَ بِكَ امَنْتُ وَ لَكَ اَسْلَمْتُ وَ عَلَيْكَ تَوَكَّلْتُ وَ اَنْتَ رَبِّي","translation_segment":"اللهم‌، لک سجدت، و بک آمنت، و لک أسلمت، و علیک توکلت، و أنت ربی، سجد لک سمعی و بصری و شعری و عصبی و مخی و عظامی، سجد وجهی البالی الفانی للذی","segment_columns":[{"kind":"word","token":"اللهم","display":"اَللَّهُمَّ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"سجدت","display":"سَجَدْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بك","display":"بِكَ"},{"kind":"word","token":"امنت","display":"امَنْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"اسلمت","display":"اَسْلَمْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عليك","display":"عَلَيْكَ"},{"kind":"word","token":"توكلت","display":"تَوَكَّلْتُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"انت","display":"اَنْتَ"},{"kind":"word","token":"ربي","display":"رَبِّي"}]},{"source_hadith_segment":"سَجَدَ لَكَ سَمْعِي وَ بَصَرِي وَ شَعْرِي وَ عَصَبِي وَ مُخِّي وَ عِظَامِي","translation_segment":"خلقه و صوره و شق‌ سمعه و بصره. تبارک اللٰه أحسن الخالقین.». -خداوندا، تنها برای تو سجده نمودم، و به تو","segment_columns":[{"kind":"word","token":"سجد","display":"سَجَدَ"},{"kind":"word","token":"لك","display":"لَكَ"},{"kind":"word","token":"سمعي","display":"سَمْعِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بصري","display":"بَصَرِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شعري","display":"شَعْرِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عصبي","display":"عَصَبِي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"مخي","display":"مُخِّي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"عظامي","display":"عِظَامِي"}]},{"source_hadith_segment":"سَجَدَ وَجْهِيَ الْبَالِي الْفَانِي لِلَّذِي خَلَقَهُ وَ صَوَّرَهُ وَ شَقَّ سَمْعَهُ وَ بَصَرَهُ تَبَارَكَ","translation_segment":"ایمان آوردم، و تسلیم تو شدم، و تنها بر تو توکل نمودم، و تویی پروردگارم، گوش و چشم و موی و عصب و مغز و استخوانهایم از آن توست، چهره پوسنده و فنا","segment_columns":[{"kind":"word","token":"سجد","display":"سَجَدَ"},{"kind":"word","token":"وجهي","display":"وَجْهِيَ"},{"kind":"word","token":"البالي","display":"الْبَالِي"},{"kind":"word","token":"الفاني","display":"الْفَانِي"},{"kind":"word","token":"للذي","display":"لِلَّذِي"},{"kind":"word","token":"خلقه","display":"خَلَقَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"صوره","display":"صَوَّرَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"شق","display":"شَقَّ"},{"kind":"word","token":"سمعه","display":"سَمْعَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"بصره","display":"بَصَرَهُ"},{"kind":"word","token":"تبارك","display":"تَبَارَكَ"}]},{"source_hadith_segment":"<quranic_text> « اللّٰهُ اَحْسَنُ الْخٰالِقِينَ » </quranic_text>   <footnote> [ المؤمنون ۱۴ ] </footnote>   .","translation_segment":"پذیرم برای کسی که آن را آفرید و صورت نگاری نموده و برای او گوش و چشم قرار داده، سجده نموده است. منزه و بلند مرتبه باد خداوند، که بهترین آفرینندگان می‌باشد.","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"word","token":"احسن","display":"اَحْسَنُ"},{"kind":"word","token":"الخالقين","display":"الْخٰالِقِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"kind":"word","token":"۱۴","display":"۱۴"},{"kind":"tag_close","tag_name":"footnote"}]}]}