{"consensus_set_id":"29560","translation_language":"fa","translation_source":{"hid":"405257"},"segments":[{"source_hadith_segment":"« اَنَّ رَجُلاً اَتَي عَبْدَ اللَّهِ بْنَ الْحَسَنِ ،  وَ هُوَ بِالسِّبَالَةِ فَسَاَلَهُ عَنِ الْحَجِّ ،  فَقَالَ لَهُ :  هَذَاكَ جَعْفَرُ بْنُ مُحَمَّدٍ قَدْ نَصَبَ نَفْسَهُ لِهَذَا فَاسْاَلْهُ .  فَاَقْبَلَ الرَّجُلُ اِلَي جَعْفَرٍ ( عَلَيْهِ السَّلاَمُ ) فَسَاَلَهُ ،  فَقَالَ لَهُ :  قَدْ رَاَيْتُكَ وَاقِفاً عَلَي عَبْدِ اللَّهِ بْنِ الْحَسَنِ ،  فَمَا قَالَ لَكَ ؟  قَالَ :  سَاَلْتُهُ فَاَمَرَنِي اَنْ اتِيَكَ ،  وَ قَالَ :  هَذَاكَ جَعْفَرُ بْنُ مُحَمَّدٍ  ،  نَصَبَ نَفْسَهُ لِهَذَا .  فَقَالَ جَعْفَرٌ ( عَلَيْهِ السَّلاَمُ )  :  نَعَمْ ،  اَنَا مِنَ الَّذِينَ قَالَ اللَّهُ فِي كِتَابِهِ :   <quranic_text> « اُولٰئِكَ الَّذِينَ هَدَي اللّٰهُ فَبِهُدٰاهُمُ اِقْتَدِهْ » </quranic_text>   <footnote> [ الانعام ۹۰ ] </footnote>  سَلْ عَمَّا شِئْتَ .  فَسَاَلَهُ الرَّجُلُ ،  فَاَنْبَاَهُ عَنْ جَمِيعِ مَا سَاَلَهُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"ان","display":"اَنَّ"},{"kind":"word","token":"رجلا","display":"رَجُلاً"},{"kind":"word","token":"اتي","display":"اَتَي"},{"kind":"word","token":"عبد","display":"عَبْدَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"بن","display":"بْنَ"},{"kind":"word","token":"الحسن","display":"الْحَسَنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هو","display":"هُوَ"},{"kind":"word","token":"امام","display":"اِمَامٌ"},{"kind":"word","token":"بالسباله","display":"بِالسِّبَالَةِ"},{"kind":"word","token":"فساله","display":"فَسَاَلَهُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"هذاك","display":"هَذَاكَ"},{"kind":"word","token":"جعفر","display":"جَعْفَرُ"},{"kind":"word","token":"بن","display":"بْنُ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"