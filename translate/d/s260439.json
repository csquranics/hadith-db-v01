َهُ عَزَّ وَ جَلَّ :   <quranic_text> « جَزٰاءً مِنْ رَبِّكَ عَطٰاءً حِسٰاباً » </quranic_text>   <footnote> [ النبا ۳۶ ] </footnote>  وَ قَالَ :   <quranic_text> « فَاُولٰئِكَ لَهُمْ جَزٰاءُ الضِّعْفِ بِمٰا عَمِلُوا وَ هُمْ فِي الْغُرُفٰاتِ امِنُونَ » </quranic_text>   <footnote> [ سبا ۳۷ ] </footnote>  فَارْغَبُوا فِي هَذَا رَحِمَكُمُ اللَّهُ وَ اِعْمَلُوا لَهُ وَ تَحَاضُّوا عَلَيْهِ وَ اِعْلَمُوا يَا عِبَادَ اللَّهِ اَنَّ الْمُتَّقِينَ حَازُوا عَاجِلَ الْخَيْرِ وَ اجِلَهُ شَارَكُوا اَهْلَ الدُّنْيَا فِي دُنْيَاهُمْ وَ لَمْ يُشَارِكْهُمْ اَهْلُ الدُّنْيَا فِي","translation_segment":"","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قد","display":"قَدْ"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"الله","display":"اللَّهُ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يا","display":"يٰا"},{"kind":"word","token":"عباد","display":"عِبٰادِ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"امنوا","display":"امَنُوا"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"ربكم","display":"رَبَّكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الزمر","display":"الزمر"},{"kind":"word","token":"۱۰","display":"۱۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"للذين","display":"لِلَّذِينَ"},{"kind":"word","token":"احسنوا","display":"اَحْسَنُوا"},{"kind":"word","token":"الحسني","display":"الْحُسْنيٰ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"زياده","display":"زِيٰادَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يونس","display":"يونس"},{"kind":"word","token":"۲۶","display":"۲۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"و","dis