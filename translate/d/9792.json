{"consensus_set_id":"9792","translation_language":"fa","translation_source":{"hid":"315828"},"segments":[{"source_hadith_segment":"ثَلاَثَةٌ  <quranic_text> « لاٰ يُكَلِّمُهُمُ اللّٰهُ » </quranic_text>   <footnote> [ البقرة ۱۷۴ ] </footnote>  الْمَنَّانُ الَّذِي لاَ يُعْطِي شَيْئاً اِلاَّ بِمِنَّةٍ وَ الْمُسْبِلُ اِزَارَهُ وَ الْمُنَفِّقُ سِلْعَتَهُ بِالْحَلْفِ الْفَاجِرِ .","translation_segment":"پیغمبر فرمود خداوند با سه کس سخن نگوید، منان آن کسی که چیزی نمیدهد مگر آنکه منت بارگیرنده میکند و کسی که از راه تکبر و خود فروشی دامن بزمین میکشد و کسی که با سوگند دروغ کالای خود را رواج میدهد. شرح-اشراف و بزرگان عرب جامه‌های بلند می‌پوشیدند که دامن آن روی زمین میکشید و این نشانه سرفرازی و بزرگ منشی بود از این راه پیغمبر اسلام از آن قدغن کرده و فرمود دامن دراز در دوزخست.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ثلاثه","display":"ثَلاَثَةٌ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يكلمهم","display":"يُكَلِّمُهُمُ"},{"kind":"word","token":"الله","display":"اللّٰهُ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۷۴","display":"۱۷۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"المنان","display":"الْمَنَّانُ"},{"kind":"word","token":"الذي","display":"الَّذِي"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يعطي","display":"يُعْطِي"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"الا","display":"اِلاَّ"},{"kind":"word","token":"يمنه","display":"يَمُنُّهُ"},{"kind":"word","token":"بمنه","display":"بِمِنَّةٍ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"المسبل","display":"الْمُسْبِلُ"},{"kind":"word","token":"ازاره