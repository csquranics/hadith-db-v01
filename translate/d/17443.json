{"consensus_set_id":"17443","translation_language":"fa","translation_source":{"hid":"406111"},"segments":[{"source_hadith_segment":"« اِنَّهُ لَنْ يَغْضَبَ لِلَّهِ شَيْءٌ كَغَضَبِ الطَّلْحِ وَ السِّدْرِ ،  اِنَّ الطَّلْحَ كَانَتْ كَالْاُتْرُجِّ ،  وَ السِّدْرَ كَالْبِطِّيخِ ،  فَلَمَّا قَالَتِ الْيَهُودُ :  يَدُ اللَّهِ مَغْلُولَةٌ :  نَقَصَ حِمْلُهُمَا فَصَغُرَ ،  فَصَارَ لَهُ عَجَمٌ ،  وَ اِشْتَدَّ الْعَجَمُ .  وَ لَمَّا اَنْ قَالَتِ النَّصَارَي :  الْمَسِيحُ اِبْنُ اللَّهِ .  اَذْعَرَتَا فَخَرَجَ لَهُمَا هَذَا الشَّوْكُ ،  وَ نَقَصَ حِمْلُهُمَا وَ صَارَ الشَّوْكُ اِلَي هَذَا الْحِمْلِ ،  وَ ذَهَبَ حِمْلُ الطَّلْحِ ،  فَلاَ يَحْمِلُ حَتَّي يَقُومَ قَائِمُنَا اَوْ تَقُومَ السَّاعَةُ »","translation_segment":"","segment_columns":[{"kind":"word","token":"انه","display":"اِنَّهُ"},{"kind":"word","token":"لن","display":"لَنْ"},{"kind":"word","token":"يغضب","display":"يَغْضَبَ"},{"kind":"word","token":"لله","display":"لِلَّهِ"},{"kind":"word","token":"شيء","display":"شَيْءٌ"},{"kind":"word","token":"كغضب","display":"كَغَضَبِ"},{"kind":"word","token":"الطلح","display":"الطَّلْحِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السدر","display":"السِّدْرِ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الطلح","display":"الطَّلْحَ"},{"kind":"word","token":"كانت","display":"كَانَتْ"},{"kind":"word","token":"كالاترج","display":"كَالْاُتْرُجِّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"السدر","display":"السِّدْرَ"},{"kind":"word","token":"كالبطيخ","display":"كَالْبِطِّيخِ"},{"kind":"word","token":"فلما","display":"فَلَمَّا"},{"kind":"word","token":"قالت","display":"قَالَتِ"},{"kind":"word","token":"اليهود","display":"الْيَهُودُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"يد","display":"يَدُ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"مغلوله","display":"مَغْلُولَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"foo