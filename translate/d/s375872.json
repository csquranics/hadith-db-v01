{"consensus_set_id":"s375872","translation_language":"fa","translation_source":{"hid":"375872"},"segments":[{"source_hadith_segment":"<quranic_text> « اَ لَمْ تَرَ اِليٰ رَبِّكَ كَيْفَ مَدَّ الظِّلَّ وَ لَوْ شٰاءَ لَجَعَلَهُ سٰاكِناً ثُمَّ جَعَلْنَا الشَّمْسَ عَلَيْهِ دَلِيلاً » </quranic_text>   <footnote> [ الفرقان ۴۵ ] </footnote>   .","translation_segment":"نمی‌بینی که خداوند چطور سایه را گسترد و اگر خواهد آن را آرام میسازد سپس خورشید را دلیل بر آن قرار دادیم-سوره فرقان آیه ۴۵).","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"تر","display":"تَرَ"},{"kind":"word","token":"الي","display":"اِليٰ"},{"kind":"word","token":"ربك","display":"رَبِّكَ"},{"kind":"word","token":"كيف","display":"كَيْفَ"},{"kind":"word","token":"مد","display":"مَدَّ"},{"kind":"word","token":"الظل","display":"الظِّلَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"شاء","display":"شٰاءَ"},{"kind":"word","token":"لجعله","display":"لَجَعَلَهُ"},{"kind":"word","token":"ساكنا","display":"سٰاكِناً"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"جعلنا","display":"جَعَلْنَا"},{"kind":"word","token":"الشمس","display":"الشَّمْسَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"دليلا","display":"دَلِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الفرقان","display":"الفرقان"},{"kind":"word","token":"۴۵","display":"۴۵"},{"kind":"tag_close","tag_name":"footnote"}]}]}