{"consensus_set_id":"59399","translation_language":"fa","translation_source":{"hid":"331691"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ تَعَالَي :","translation_segment":"عن زید بن علی ع قال: قال رسول الله صلی","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"}]},{"source_hadith_segment":"<quranic_text> « قُلْ هٰذِهِ سَبِيلِي اَدْعُوا اِلَي اللّٰهِ عَليٰ بَصِيرَةٍ اَنَا وَ مَنِ اِتَّبَعَنِي » </quranic_text>   <footnote> [ يوسف ۱۰۸ ] </footnote>","translation_segment":"الله علیه و آله و سلم فی قول الله تعالی: (قل هذه سبیلی أدعوا إلی الله علی بصیره أنا و من اتبعنی) من أهل بیتی لا یزال الرجل بعد الرجل یدعو","segment_columns":[{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"هذه","display":"هٰذِهِ"},{"kind":"word","token":"سبيلي","display":"سَبِيلِي"},{"kind":"word","token":"ادعوا","display":"اَدْعُوا"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الله","display":"اللّٰهِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف۱۰۸","display":"يوسف۱۰۸"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"بصيره","display":"بَصِيرَةٍ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"انا","display":"اَنَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"من","display":"مَنِ"},{"kind":"word","token":"اتبعني","display":"اِتَّبَعَنِي"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"يوسف","display":"يوسف"},{"kind":"word","token":"۱۰۸","display":"۱۰۸"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"مِنْ اَهْلِ بَيْتِي","translation_segment":"إلی ما أدعو إلیه. زید بن علی گفت: پیامبر درباره سخن خداوند: «قل هذه سبیلی ادعو الی الله علی بصیره انا","segment_columns":[{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"اهل","display":"اَهْلِ"},{"kind":"word","token":"بيتي","display":"بَيْتِي"}]},{"source_hadith_segment":"لاَ يَزَالُ الرَّجُلُ بَعْدَ الرَّجُلِ يَدْعُو اِلَي مَا اَدْعُو اِلَيْهِ .","translation_segment":"و من اتبعنی» فرمود: از اهل بیت من همواره مردی پس از مردی به سوی همان چیزی می‌خوانند که من می‌خوانم.","segment_columns":[{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يزال","display":"يَزَالُ"},{"kind":"word","token":"الرجل","display":"الرَّجُلُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلِ"},{"kind":"word","token":"يدعو","display":"يَدْعُو"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"ما","display":"مَا"},{"kind":"word","token":"ادعو","display":"اَدْعُو"},{"kind":"word","token":"اليه","display":"اِلَيْهِ"}]}]}