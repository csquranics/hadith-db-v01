{"consensus_set_id":"43776","translation_language":"fa","translation_source":{"hid":"110946"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنِ الْمُجَاوِرِ اَ لَهُ اَنْ يَتَمَتَّعَ  <quranic_text> « بِالْعُمْرَةِ اِلَي الْحَجِّ » </quranic_text>   <footnote> [ البقرة ۱۹۶ ] </footnote>  قَالَ نَعَمْ يَخْرُجُ اِلَي مُهَلِّ اَرْضِهِ فَيُلَبِّي اِنْ شَاءَ .","translation_segment":"سماعه گوید: از امام ابی الحسن علیه السلام در مورد مجاور مکه پرسیدم که آیا می‌تواند حج و عمره تمتع انجام دهد؟ فرمود: آری، اگر خواست به جایگاه احرام سرزمین خود بیرون می‌رود و از آن‌جا لبیک می‌گوید.","segment_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنِ"},{"kind":"word","token":"المجاور","display":"الْمُجَاوِرِ"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"يتمتع","display":"يَتَمَتَّعَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"بالعمره","display":"بِالْعُمْرَةِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الحج","display":"الْحَجِّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"البقره","display":"البقرة"},{"kind":"word","token":"۱۹۶","display":"۱۹۶"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"يخرج","display":"يَخْرُجُ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"مهل","display":"مُهَلِّ"},{"kind":"word","token":"ارضه","display":"اَرْضِهِ"},{"kind":"word","token":"فيلبي","display":"فَيُلَبِّي"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"شاء","display":"شَاءَ"}]}]}