{"consensus_set_id":"41985","translation_language":"fa","translation_source":{"hid":"375364"},"segments":[{"source_hadith_segment":"رَحِمَ اَللَّهُ عَبْداً طَلَبَ مِنَ اللَّهِ عَزَّ وَ جَلَّ حَاجَتَهُ وَ اَلَحَّ فِي الدُّعَاءِ اُسْتُجِيبَ لَهُ اَمْ لَمْ يُسْتَجَبْ وَ تَلاَ هَذِهِ الْايَةَ  <quranic_text> « وَ اَدْعُوا رَبِّي عَسيٰ اَلاّٰ اَكُونَ بِدُعٰاءِ رَبِّي شَقِيًّا » </quranic_text>   <footnote> [ مريم ۴۸ ] </footnote>   .","translation_segment":"نبی اکرم (صلی الله علیه و آله) فرمود: خدا رحمت کند بنده‌ای را که حاجاتش را از خدا بخواهد و در دعا اصرار ورزد مستجاب بشود یا نشود، و بعد این آیه را تلاوت فرمود: (خدا را میخوانم و امیدوارم در دعایم محروم نمانم-سوره مریم ۴۶).","segment_columns":[{"kind":"word","token":"رحم","display":"رَحِمَ"},{"kind":"word","token":"الله","display":"اَللَّهُ"},{"kind":"word","token":"عبدا","display":"عَبْداً"},{"kind":"word","token":"طلب","display":"طَلَبَ"},{"kind":"word","token":"من","display":"مِنَ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"حاجته","display":"حَاجَتَهُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الح","display":"اَلَحَّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الدعاء","display":"الدُّعَاءِ"},{"kind":"word","token":"استجيب","display":"اُسْتُجِيبَ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"لم","display":"لَمْ"},{"kind":"word","token":"يستجب","display":"يُسْتَجَبْ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تلا","display":"تَلاَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"word","token":"-","display":"-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ادعوا","display":"ا