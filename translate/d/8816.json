وَ هُوَ يَقُولُ :  اَشْهَدُ اَنَّكَ تَعْلَمُ مَا فِي الْاَرْحَامِ وَ مَا فِي الضَّمَائِرِ وَ اَنَّكَ عَمَدُ الدِّينِ وَ بَابُهُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  قَالَ :  فَعِنْدَ ذَلِكَ ضَجَّ النَّاسُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ قَالُوا :  يَا اَمِيرَ الْمُؤْمِنِينَ  ،  الْيَوْمَ خَمْسَ سِنِينَ لَمْ تُمْطِرِ السَّمَاءُ عَلَيْنَا غَيْثاً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ قَدْ اَمْسَكَ عَنِ الْكُوفَةِ هَذِهِ الْمُدَّةَ وَ قَدْ  <quranic_text> « مَسَّنٰا وَ اَهْلَنَا الضُّرُّ » </quranic_text>   <footnote> [ يوسف ۸۸ ] </footnote>","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاسْتَسْقِ لَنَا يَا وَارِثَ عِلْمِ مُحَمَّدٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"قَالَ :  فَعِنْدَ ذَلِكَ قَامَ فِي الْحَالِ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  وَ اَشَارَ بِيَدِهِ قِبَلَ السَّمَاءِ ،  فَدَمْدَمَ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَاِذَا الْغَيْثُ قَدِ اِلْتَحَمَ وَ حَمَلَ الْغَيْثُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَحَرَّكَ السَّحَابَ اَسْحَمَ وَ حَمَلَ مُزْناً","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"،  فَهَبَطَ الْغَيْثُ حَتَّي صَارَتِ الْكُوفَةُ غدران [ غُدْرَاناً ] فَتَكَلَّمَ بِكَلاَمٍ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":"فَمَضَي الْغَيْمُ وَ اِنْقَطَعَ الْمَطَرُ ،  وَ طَلَعَتِ الشَّمْسُ","translation_segment":"","segment_columns":[]},{"source_hadith_segment":".  وَ لَعَنَ اللَّهُ الشَّاكَّ فِي فَضْلِ عَلِيِّ بْنِ اَبِي طَالِبٍ عَلَيْهِ السَّلاَمُ .","translation_segment":"","segment_columns":[]}]}