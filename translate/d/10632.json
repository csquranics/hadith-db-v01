{"consensus_set_id":"10632","translation_language":"fa","translation_source":{"hid":"325001"},"segments":[{"source_hadith_segment":"فِي قَوْلِ اللَّهِ عَزَّ وَ جَلَّ  <quranic_text> « يُؤْتُونَ مٰا اتَوْا وَ قُلُوبُهُمْ وَجِلَةٌ » </quranic_text>   <footnote> [ المؤمنون ۶۰ ] </footnote>  قَالَ يَعْمَلُونَ وَ يَعْلَمُونَ اَنَّهُمْ سَيُثَابُونَ عَلَيْهِ .","translation_segment":"عاصم گوید: از امام صادق علیه‌ السلام‌ در باره قول خداوند عز و جل‌: «داده می‌شوند آنچه را که آورده باشند و دلهایشان ترسناک است»، (سوال کرد). فرمود: (وظایف خود را) انجام می‌دهند؛ و می‌دانند که در قبال (زحمات و انجام وظیفه) پاداش داده می‌شوند.","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الذين","display":"الَّذِينَ"},{"kind":"word","token":"يؤتون","display":"يُؤْتُونَ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"اتوا","display":"اتَوْا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"قلوبهم","display":"قُلُوبُهُمْ"},{"kind":"word","token":"وجله","display":"وَجِلَةٌ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"المؤمنون","display":"المؤمنون"},{"kind":"word","token":"۶۰","display":"۶۰"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعملون","display":"يَعْمَلُونَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"يعلمون","display":"يَعْلَمُونَ"},{"kind":"word","token":"انهم","display":"اَنَّهُمْ"},{"kind":"word","token":"سيثابون","display":"سَيُثَابُونَ"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"}]}]}