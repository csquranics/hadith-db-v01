{"consensus_set_id":"114953","translation_language":"fa","translation_source":{"hid":"319553"},"segments":[{"source_hadith_segment":"اَنَّهُ سُئِلَ عَنْ رَجُلٍ اَوْصَي لِقَرَابَتِهِ فَقَالَ يَجُوزُ ذَلِكَ لِقَوْلِ اللَّهِ عَزَّ وَ جَلَّ-  <quranic_text> « اِنْ تَرَكَ خَيْراً الْوَصِيَّةُ لِلْوٰالِدَيْنِ وَ الْاَقْرَبِينَ » </quranic_text>   <footnote> [ البقرة ۱۸۰ ] </footnote>   .","translation_segment":"و همچنین قول امیر المومنین علیه السلام که مضمونش این است: «اللهم انک لا تخلی الارض من حجه علی خلقک اما ظاهرا مشهورا او خائفا مغمورا لئلا تبطل حججک و بیناتک».؛ یعنی بار خدایا به درستی که خالی نمی‌گذاری زمین را از حجتی که مر تو راست بر خلق خود یا ظاهر مشهور یا ترسان پنهان تا آنکه باطل نشود حجتهای تو و گواهان تو.","segment_columns":[{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"سئل","display":"سُئِلَ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"رجل","display":"رَجُلٍ"},{"kind":"word","token":"اوصي","display":"اَوْصَي"},{"kind":"word","token":"لقرابته","display":"لِقَرَابَتِهِ"},{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"يجوز","display":"يَجُوزُ"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"لقول","display":"لِقَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل-","display":"جَلَّ-"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"ان","display":"اِنْ"},{"kind":"word","token":"ترك","display":"تَرَكَ"},{"kind":"word","token":"خيرا","display":"خَيْراً"},{"kind":"word","token":"الوصيه","display":"الْوَصِيَّةُ"},{"kind":"word","token":"للوالدين","display":"لِلْوٰالِدَيْنِ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"الاقربين","display":"الْاَقْرَبِينَ"},{"kind":"word","token":"بالمعروف","display":"بِالْمَعْرُوفِ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"foo