{"consensus_set_id":"s351123","translation_language":"fa","translation_source":{"hid":"351123"},"segments":[{"source_hadith_segment":"وَ فِي تَفْسِيرِ قَوْلِهِ تَعَالَي  <quranic_text> « عَليٰ سُرُرٍ مُتَقٰابِلِينَ » </quranic_text>   <footnote> [ الصافات ۴۴ ] </footnote>  اَنَّهُ اَعْظَمُ لَذَّاتِ الْجَنَّةِ يَجْلِسُ الْاَحِبَّةُ فِي الْمَكَانِ الْوَاحِدِ كُلُّ وَاحِدٍ عَلَي سَرِيرٍ مِنْ سُرُرِ الْجَنَّةِ .","translation_segment":"همچنین آن حضرت در تفسیر آیه فرموده‌اند: بزرگترین لذت‌های بهشتی آن است که دوستان صمیمی در بهشت در کنار هم باشند و هریک بر تختی تکیه زنند.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"تفسير","display":"تَفْسِيرِ"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"علي","display":"عَليٰ"},{"kind":"word","token":"سرر","display":"سُرُرٍ"},{"kind":"word","token":"متقابلين","display":"مُتَقٰابِلِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الصافات","display":"الصافات"},{"kind":"word","token":"۴۴","display":"۴۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"انه","display":"اَنَّهُ"},{"kind":"word","token":"اعظم","display":"اَعْظَمُ"},{"kind":"word","token":"لذات","display":"لَذَّاتِ"},{"kind":"word","token":"الجنه","display":"الْجَنَّةِ"},{"kind":"word","token":"يجلس","display":"يَجْلِسُ"},{"kind":"word","token":"الاحبه","display":"الْاَحِبَّةُ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"المكان","display":"الْمَكَانِ"},{"kind":"word","token":"الواحد","display":"الْوَاحِدِ"},{"kind":"word","token":"كل","display":"كُلُّ"},{"kind":"word","token":"واحد","display":"وَاحِدٍ"},{"kind":"word","token":"علي","display":"عَلَي"},{"kind":"word","token":"سرير","display":"سَرِيرٍ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind