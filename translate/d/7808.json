{"consensus_set_id":"7808","translation_language":"fa","translation_source":{"hid":"93239"},"segments":[{"source_hadith_segment":"رَوَي ذَلِكَ سَاَلْتُ الرِّضَا عَلَيْهِ السَّلاَمُ يُتَمَتَّعُ بِالْاَمَةِ بِاِذْنِ اَهْلِهَا قَالَ « نَعَمْ اِنَّ اللَّهَ عَزَّ وَ جَلَّ يَقُولُ  <quranic_text> « فَانْكِحُوهُنَّ بِاِذْنِ اَهْلِهِنَّ » </quranic_text>   <footnote> [ النساء ۲۵ ] </footnote>   .","translation_segment":"* *۳۵ - از ابو الحسن الرضا (ع) پرسیدم: اگر از خواجه کنیز اجازه بگیرم می‌توانم به صورت موقت با او ازدواج کنم‌؟ ابو الحسن گفت: بلی. خداوند عز و جل می‌گوید: «با اجازه خواجگانشان با کنیزان ازدواج موقت برقرار نمایید».","segment_columns":[{"kind":"word","token":"روي","display":"رَوَي"},{"kind":"word","token":"ذلك","display":"ذَلِكَ"},{"kind":"word","token":"سالت","display":"سَاَلْتُ"},{"kind":"word","token":"الرضا","display":"الرِّضَا"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عليه","display":"عَلَيْهِ"},{"kind":"word","token":"السلام","display":"السَّلاَمُ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"ا","display":"اَ"},{"kind":"word","token":"يتمتع","display":"يُتَمَتَّعُ"},{"kind":"word","token":"بالامه","display":"بِالْاَمَةِ"},{"kind":"word","token":"باذن","display":"بِاِذْنِ"},{"kind":"word","token":"اهلها","display":"اَهْلِهَا"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"نعم","display":"نَعَمْ"},{"kind":"word","token":"ان","display":"اِنَّ"},{"kind":"word","token":"الله","display":"اللَّهَ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"word","token":"يقول","display":"يَقُولُ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"فانكحوهن","display":"فَانْكِحُوهُنَّ"},{"kind":"word","token":"باذن","display":"بِاِذْنِ"},{"kind":"word","token":"اهلهن","display":"اَهْلِهِنَّ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind