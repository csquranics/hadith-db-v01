{"consensus_set_id":"27589","translation_language":"fa","translation_source":{"hid":"407923"},"segments":[{"source_hadith_segment":"« سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ :   <quranic_text> « وَ لَوْ لاٰ اَنْ ثَبَّتْنٰاكَ لَقَدْ كِدْتَ تَرْكَنُ اِلَيْهِمْ شَيْئاً قَلِيلاً » </quranic_text>   <footnote> [ الاسراء ۷۴ ] </footnote> .  قَالَ :  « لَمَّا كَانَ يَوْمُ الْفَتْحِ اَخْرَجَ رَسُولُ اللَّهِ ( صَلَّي اللَّهُ عَلَيْهِ وَ الِهِ ) اَصْنَاماً مِنَ الْمَسْجِدِ ،  وَ كَانَ مِنْهَا صَنَمٌ عَلَي الْمَرْوَةِ ،  فَطَلَبَتْ اِلَيْهِ قُرَيْشٌ اَنْ يَتْرُكَهُ ،  وَ كَانَ مُسْتَحِياً فَهَمَّ بِتَرْكِهِ ثُمَّ اَمَرَ بِكَسْرِهِ ،  فَنَزَلَتْ هَذِهِ الْايَةُ » .","translation_segment":"","segment_columns":[{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"ثبتناك","display":"ثَبَّتْنٰاكَ"},{"kind":"word","token":"لقد","display":"لَقَدْ"},{"kind":"word","token":"كدت","display":"كِدْتَ"},{"kind":"word","token":"تركن","display":"تَرْكَنُ"},{"kind":"word","token":"اليهم","display":"اِلَيْهِمْ"},{"kind":"word","token":"شيئا","display":"شَيْئاً"},{"kind":"word","token":"قليلا","display":"قَلِيلاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الاسراء","display":"الاسراء"},{"kind":"word","token":"۷۴","display":"۷۴"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"لما","display":"لَمَّا"},{"kind":"word","token":"كان","display":"كَانَ"},{"kind":"word","token":"يوم","display":"يَوْمُ"},{"kind":"word","token":"الفتح","display":"الْفَتْحِ"},{"kind":"word","token":"اخرج",