{"consensus_set_id":"10671","translation_language":"fa","translation_source":{"hid":"114675"},"segments":[{"source_hadith_segment":"فِي اَلْمُطَلَّقَةِ تَعْتَدُّ فِي بَيْتِهَا وَ تُظْهِرُ لَهُ زِينَتَهَا  <quranic_text> « لَعَلَّ اللّٰهَ يُحْدِثُ بَعْدَ ذٰلِكَ اَمْراً » </quranic_text>   <footnote> [ الطلاق ۱ ] </footnote>   .","translation_segment":"ابو بصیر گوید: (امام باقر و امام صادق علیهما السلام) درباره زنی که طلاق داده شده فرمود: باید در خانه‌اش عده نگه دارد و آرایش و زینت خود را برای شوهرش آشکار کند، شاید خدا بعد از آن (طلاق) کاری از نو پدید آرد.","segment_columns":[{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"المطلقه","display":"اَلْمُطَلَّقَةِ"},{"kind":"word","token":"تعتد","display":"تَعْتَدُّ"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"بيتها","display":"بَيْتِهَا"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"تظهر","display":"تُظْهِرُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"زينتها","display":"زِينَتَهَا"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"لعل","display":"لَعَلَّ"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"يحدث","display":"يُحْدِثُ"},{"kind":"word","token":"بعد","display":"بَعْدَ"},{"kind":"word","token":"ذلك","display":"ذٰلِكَ"},{"kind":"word","token":"امرا","display":"اَمْراً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الطلاق","display":"الطلاق"},{"kind":"word","token":"۱","display":"۱"},{"kind":"tag_close","tag_name":"footnote"}]}]}