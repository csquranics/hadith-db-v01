{"consensus_set_id":"116929","translation_language":"fa","translation_source":{"hid":"331653"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ :   <quranic_text> « اِتَّقُوا اللّٰهَ وَ كُونُوا مَعَ الصّٰادِقِينَ » </quranic_text>   <footnote> [ التوبة ۱۱۹ ] </footnote>  قَالَ :  [ يَعْنِي مَعَ ] مُحَمَّدٍ وَ عَلِيٍّ  .","translation_segment":"عن جعفر بن محمد، فی قوله: (اتقوا الله و کونوا مع الصادقین) قال: یعنی مع محمد و علی‌. جعفر بن محمد درباره سخن خداوند: «اتقوا الله و کونوا مع الصادقین» گفت: یعنی با محمد (صلی الله علیه و آله) و علی (علیه السلام)","segment_columns":[{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"اتقوا","display":"اِتَّقُوا"},{"kind":"word","token":"وجل","display":"وجل"},{"kind":"word","token":"اتقوا","display":"اتقوا"},{"kind":"word","token":"الله","display":"اللّٰهَ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"كونوا","display":"كُونُوا"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"الصادقين","display":"الصّٰادِقِينَ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"التوبه","display":"التوبة"},{"kind":"word","token":"۱۱۹","display":"۱۱۹"},{"kind":"tag_close","tag_name":"footnote"},{"kind":"word","token":"قال","display":"قَالَ"},{"kind":"word","token":"يعني","display":"يَعْنِي"},{"kind":"word","token":"مع","display":"مَعَ"},{"kind":"word","token":"محمد","display":"مُحَمَّدٍ"},{"kind":"word","token":"وعلي","display":"وعلي"},{"kind":"word","token":"صلي","display":"صلى"},{"kind":"word","token":"الله","display":"الله"},{"kind":"word","token":"عليهما","display":"عليهما"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"علي","display":"عَلِيٍّ"},{"kind":"word","token":"الهما","display":"آلهما"}]}]}