{"consensus_set_id":"30633","translation_language":"fa","translation_source":{"hid":"118860"},"segments":[{"source_hadith_segment":"لاَ يُبَالِي النَّاصِبُ صَلَّي اَمْ زَنَي وَ هَذِهِ الْايَةُ نَزَلَتْ فِيهِمْ  <quranic_text> « عٰامِلَةٌ نٰاصِبَةٌ تَصْليٰ نٰاراً حٰامِيَةً » </quranic_text>   <footnote> [ الغاشية ۳ ] </footnote>   .","translation_segment":"حنان به نقل از امام صادق علیه السلام می‌گوید که فرمود: ناصبی [دشمن خاندان محمد صلی اللٰه علیه و آله و سلم] باکی نداشته باشد که نماز بخواند یا زنا کند، به هر حال این آیه در باره او نازل شده است: «عٰامله‌ نٰاصبه‌*`تصلیٰ‌ نٰارا حٰامیه‌».","segment_columns":[{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"يبالي","display":"يُبَالِي"},{"kind":"word","token":"الناصب","display":"النَّاصِبُ"},{"kind":"word","token":"صلي","display":"صَلَّي"},{"kind":"word","token":"ام","display":"اَمْ"},{"kind":"word","token":"زني","display":"زَنَي"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةُ"},{"kind":"word","token":"نزلت","display":"نَزَلَتْ"},{"kind":"word","token":"فيهم","display":"فِيهِمْ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"عامله","display":"عٰامِلَةٌ"},{"kind":"word","token":"ناصبه","display":"نٰاصِبَةٌ"},{"kind":"word","token":"تصلي","display":"تَصْليٰ"},{"kind":"word","token":"نارا","display":"نٰاراً"},{"kind":"word","token":"حاميه","display":"حٰامِيَةً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"الغاشيه","display":"الغاشية"},{"kind":"word","token":"۳","display":"۳"},{"kind":"tag_close","tag_name":"footnote"}]}]}