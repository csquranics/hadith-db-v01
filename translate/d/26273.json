{"consensus_set_id":"26273","translation_language":"fa","translation_source":{"hid":"395508"},"segments":[{"source_hadith_segment":"فِي قَوْلِهِ عَزَّ وَ جَلَّ :   <quranic_text> « خٰالِدِينَ فِيهٰا لاٰ يَبْغُونَ عَنْهٰا حِوَلاً » </quranic_text>   <footnote> [ الكهف ۱۰۸ ] </footnote>  قَالَ :  خَالِدِينَ فِيهَا لاَ يَخْرُجُونَ مِنْهَا « وَ <quranic_text> « لاٰ يَبْغُونَ عَنْهٰا حِوَلاً » </quranic_text>   <footnote> [ الكهف ۱۰۸ ] </footnote>  قَالَ :  لاَ يُرِيدُونَ بِهَا بَدَلاً ،  قُلْتُ قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « قُلْ لَوْ كٰانَ الْبَحْرُ مِدٰاداً لِكَلِمٰاتِ رَبِّي لَنَفِدَ الْبَحْرُ قَبْلَ اَنْ تَنْفَدَ كَلِمٰاتُ رَبِّي وَ لَوْ جِئْنٰا بِمِثْلِهِ مَدَداً » </quranic_text>   <footnote> [ الكهف ۱۰۹ ] </footnote>  قَالَ :  قَدْ اَخْبَرَكَ اَنَّ كَلاَمَ اللَّهِ عَزَّ وَ جَلَّ لَيْسَ لَهُ اخِرٌ وَ لاَ غَايَةٌ وَ لاَ يَنْقَطِعُ اَبَداً ،  قُلْتُ :  قَوْلُهُ عَزَّ وَ جَلَّ :   <quranic_text> « اِنَّ الَّذِينَ امَنُوا وَ عَمِلُوا الصّٰالِحٰاتِ كٰانَتْ لَهُمْ جَنّٰاتُ الْفِرْدَوْسِ نُزُلاً » </quranic_text>   <footnote> [ الكهف ۱۰۷ ] </footnote>  قَالَ :  هَذِهِ نَزَلَتْ فِي اَبِي ذَرٍّ وَ الْمِقْدَادِ وَ سَلْمَانَ الْفَارِسِيِّ وَ عَمَّارِ بْنِ يَاسِرٍ ،  جَعَلَ اللَّهُ عَزَّ وَ جَلَّ  <quranic_text> « لَهُمْ جَنّٰاتُ الْفِرْدَوْسِ نُزُلاً » </quranic_text>   <footnote> [ الكهف ۱۰۷ ] </footnote>   ،  اَيْ مَاْوًي وَ مَنْزِلاً .","translation_segment":"","segment_columns":[{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"قوله","display":"قَوْلِهِ"},{"kind":"word","token":"-","display":"-"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"خالدين","display":"خٰالِدِينَ"},{"kind":"word","token":"فيها","display":"فِيهٰا"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"يبغون","display":"يَبْغُونَ"},{"kind":"word","toke