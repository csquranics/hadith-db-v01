{"consensus_set_id":"5509","translation_language":"fa","translation_source":{"hid":"114906"},"segments":[{"source_hadith_segment":"سَاَلْتُهُ عَنْ قَوْلِ اللَّهِ عَزَّ وَ جَلَّ :   <quranic_text> « وَ اِنِ اِمْرَاَةٌ خٰافَتْ مِنْ بَعْلِهٰا نُشُوزاً اَوْ اِعْرٰاضاً » </quranic_text>   <footnote> [ النساء ۱۲۸ ] </footnote>","translation_segment":"حلبی گوید: از امام صادق علیه السلام درباره گفتار خدا که می‌فرماید: «و اگر زنی از ناسازگاری یا روی‌گردانی همسرش بیم داشته باشد»","segment_columns":[{"kind":"word","token":"قال","display":"قال"},{"kind":"word","token":"سالته","display":"سَاَلْتُهُ"},{"kind":"word","token":"عن","display":"عَنْ"},{"kind":"word","token":"الصادق","display":"الصادق"},{"kind":"word","token":"عليه","display":"عليه"},{"kind":"word","token":"السلام","display":"السلام"},{"kind":"word","token":"في","display":"في"},{"kind":"word","token":"قول","display":"قَوْلِ"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"عز","display":"عَزَّ"},{"kind":"word","token":"تبارك","display":"تبارك"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"جل","display":"جَلَّ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"ان","display":"اِنِ"},{"kind":"word","token":"امراه","display":"اِمْرَاَةٌ"},{"kind":"word","token":"خافت","display":"خٰافَتْ"},{"kind":"word","token":"من","display":"مِنْ"},{"kind":"word","token":"بعلها","display":"بَعْلِهٰا"},{"kind":"word","token":"نشوزا","display":"نُشُوزاً"},{"kind":"word","token":"او","display":"اَوْ"},{"kind":"word","token":"اعراضا","display":"اِعْرٰاضاً"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","tag_name":"footnote"},{"kind":"word","token":"النساء","display":"النساء"},{"kind":"word","token":"۱۲۸","display":"۱۲۸"},{"kind":"tag_close","tag_name":"footnote"}]},{"source_hadith_segment":"فَقَالَ هِيَ الْمَرْاَةُ تَكُونُ عِنْدَ الرَّجُلِ فَيَكْرَهُهَا فَيَقُولُ لَهَا اِنِّي اُرِيدُ اَنْ اُطَلِّقَكِ فَتَقُولُ لَهُ لاَ تَفْعَلْ اِنِّي اَكْرَهُ اَنْ تُشْمَتَ بِي وَ لَكِنِ اُنْظُرْ فِي لَيْلَتِي فَاصْنَعْ بِهَا مَا شِئْتَ وَ مَا كَانَ سِوَي ذَلِكَ مِنْ شَيْءٍ فَهُوَ لَكَ وَ دَعْنِي عَلَي حَالَتِي فَهُوَ قَوْلُهُ تَبَارَكَ وَ تَعَالَي :   <quranic_text> « فَلاٰ جُنٰاحَ عَلَيْهِمٰا اَنْ يُصْلِحٰا بَيْنَهُمٰا صُلْحاً » </quranic_text>   <footnote> [ النساء ۱۲۸ ] </footnote>  وَ هُوَ هَذَا الصُّلْحُ .","translation_segment":"پرسیدم. فرمود: منظور زنی است که نزد مردی زندگی می‌کند که از او خوشش نمی‌آید. پس به او می‌گوید: «من می‌خواهم تو را طلاق دهم». زن می‌گوید: چنین نکن، من خوش ندارم که دشمن‌شاد شوم. اما شب را به من رسیدگی کن و در آن، هرکاری می‌خواهی انجام بده و غیر از آن، هرچه که هست؛ از آن تو باشد و مرا به همین حالت واگذار. پس این فرموده خداوند است که «مانعی ندارد و با هم صلح کنند» و این، همان صلح است.","segment_columns":[{"kind":"word","token":"فقال","display":"فَقَالَ"},{"kind":"word","token":"هي","display":"هِيَ"},{"kind":"word","token":"المراه","display":"الْمَرْاَةُ"},{"kind":"word","token":"التي","display":"الَّتِي"},{"kind":"word","token":"تكون","display":"تَكُونُ"},{"kind":"word","token":"عند","display":"عِنْدَ"},{"kind":"word","token":"الرجل","display":"الرَّجُلِ"},{"kind":"word","token":"فيكرهها","display":"فَيَكْرَهُهَا"},{"kind":"word","token":"فيقول","display":"فَيَقُولُ"},{"kind":"word","token":"لها","display":"لَهَا"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"اريد","display":"اُرِيدُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"اطلقك","display":"اُطَلِّقَكِ"},{"kind":"word","token":"فتقول","display":"فَتَقُولُ"},{"kind":"word","token":"له","display":"لَهُ"},{"kind":"word","token":"لا","display":"لاَ"},{"kind":"word","token":"تفعل","display":"تَفْعَلْ"},{"kind":"word","token":"اني","display":"اِنِّي"},{"kind":"word","token":"اكره","display":"اَكْرَهُ"},{"kind":"word","token":"ان","display":"اَنْ"},{"kind":"word","token":"تشمت","display":"تُشْمَتَ"},{"kind":"word","token":"بي","display":"بِي"},{"kind":"word"