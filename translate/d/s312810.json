{"consensus_set_id":"s312810","translation_language":"fa","translation_source":{"hid":"312810"},"segments":[{"source_hadith_segment":"اَحَبُّ اَلْاَعْمَالِ اِلَي اللَّهِ تَعَالَي فِي الْاَرْضِ الدُّعَاءُ وَ اَفْضَلُ الْعِبَادَةِ الْعَفَافُ ثُمَّ تَلاَ هَذِهِ الْايَةَ  <quranic_text> « قُلْ مٰا يَعْبَؤُا بِكُمْ رَبِّي لَوْ لاٰ دُعٰاؤُكُمْ » </quranic_text>   <footnote> [ الفرقان ۷۷ ] </footnote>   .","translation_segment":"و فرمود امیر المومنین (علیه السلام) که دوستترین عملها بخدا در روی زمین دعا است و فاضلترین عبادت پرهیزکاری بعد از آن خواند این آیه را که «قل‌ مٰا یعبوا بکم‌ ربی لو لاٰ دعٰاوکم‌» بگو چه قدر دهد شما را خدای من اگر نباشد دعای شما","segment_columns":[{"kind":"word","token":"احب","display":"اَحَبُّ"},{"kind":"word","token":"الاعمال","display":"اَلْاَعْمَالِ"},{"kind":"word","token":"الي","display":"اِلَي"},{"kind":"word","token":"الله","display":"اللَّهِ"},{"kind":"word","token":"تعالي","display":"تَعَالَي"},{"kind":"word","token":"في","display":"فِي"},{"kind":"word","token":"الارض","display":"الْاَرْضِ"},{"kind":"word","token":"الدعاء","display":"الدُّعَاءُ"},{"kind":"word","token":"و","display":"وَ"},{"kind":"word","token":"افضل","display":"اَفْضَلُ"},{"kind":"word","token":"العباده","display":"الْعِبَادَةِ"},{"kind":"word","token":"العفاف","display":"الْعَفَافُ"},{"kind":"word","token":"ثم","display":"ثُمَّ"},{"kind":"word","token":"تلا","display":"تَلاَ"},{"kind":"word","token":"هذه","display":"هَذِهِ"},{"kind":"word","token":"الايه","display":"الْايَةَ"},{"kind":"tag_open","tag_name":"quranic_text"},{"kind":"word","token":"قل","display":"قُلْ"},{"kind":"word","token":"ما","display":"مٰا"},{"kind":"word","token":"يعبؤا","display":"يَعْبَؤُا"},{"kind":"word","token":"بكم","display":"بِكُمْ"},{"kind":"word","token":"ربي","display":"رَبِّي"},{"kind":"word","token":"لو","display":"لَوْ"},{"kind":"word","token":"لا","display":"لاٰ"},{"kind":"word","token":"دعاؤكم","display":"دُعٰاؤُكُمْ"},{"kind":"tag_close","tag_name":"quranic_text"},{"kind":"tag_open","